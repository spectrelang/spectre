val std = use("std")

pub fn main() void! = {
    val x: i32 = 20

    if (x < 30) {
        std.stdio.puts("good")
    } elif (x < 10) {
        std.stdio.puts("what...?")
    }

    for (y = 0; y < 10; y++) {
        std.stdio.print("{d}\n", {y})
    }

//    for {
//        std.stdio.puts("infinite loop")
//    }
}