pub type Node = {
    x: i32
    y: i32
}

pub fn main() void = {
    val node: mut Node = {x: 10, y: 30}
    val ptr1: ref Node = @addr(node)
    val xs: list[ref Node] = [ptr1]
    for x in xs {
        trust @print("{p}\n", {x})
        trust @print("{d} {d}\n", {@deref(x).x, @deref(x).y})
    }
}

