val json = use("std/json")

pub fn main() void = {
	val input: ref u8 = \\{"name":"Alice"}
	val alc: ref void = 0 as ref void
	val doc_opt = trust json.parse[ref void](alc, input)
	match doc_opt {
		none => {
			@puts("got nothing")
			assert false
		}
		some _ => {
			@puts("got something")
		}
	}
}
