val stdio = use("std/stdio")

pub fn main() void! = {
    val result = can_fail(true)
    match result {
        some x => {
            stdio.print("hooray: {d}", {x})
        }
        none => {
            stdio.puts(":(")
        }
    }
}

fn can_fail(should_fail: bool) option[i32]! = {
	if (!should_fail) {
		return some 10
	}
	return none
}
