val stdio = use("std/stdio")

pub fn some_function() void = trust {
    val xs: mut list[i32] = [1, 2, 3, 4]
    for x in xs {
        stdio.print("{d}\n", {x})
    }

    val ys: list[ref u8] = ["hello", "world"]
    for y in ys {
        stdio.print("{s}\n", {y})
    }

    val zs: mut list[i64] = []

    @append(zs, 20)

    val one_x: option[i32] = @get(xs, 0) // get first element from xs

    match one_x {
        some _ => {
            val len = @len(xs)
            stdio.print("and the length of this list is {d}\n", {len})
            @remove(xs, 1)
            @insert(xs, 1, 99) // at position 1 in xs, insert 99.
        }
        none => {
            stdio.puts(":(")
        }
    }

    @reserve(xs, 100)
    val cap: usize = @capacity(xs)

    stdio.print("{d}\n", {cap})
}

pub fn main() i32 = trust {
    some_function()
    return 0
}
