val allocators = use("std/allocators")
val stdio = use("std/stdio")

pub fn main() i32! = {
    //val my_stack = std.allocators.Stack.new(1024)
    //std.allocators.Stack.free(my_stack)

    // Instead we can do:

    val Stack = allocators.Stack
    val my_stack = Stack.new(1024)
    
    Stack.free(my_stack)
    
    stdio.puts("freed.")
    return 0
}