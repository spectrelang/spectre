val std = use("std")

pub fn main() i32! = {
    //val my_stack = std.allocators.Stack.new(1024)
    //std.allocators.Stack.free(my_stack)

    // Instead we can do:

    val Stack = std.allocators.Stack
    val my_stack = Stack.new(1024)
    
    Stack.free(my_stack)
    
    std.io.put("freed.")
    return 0
}