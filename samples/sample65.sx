type Inner = {
    data: mut ref void
    len:  mut i64
}

type Outer = {
    inner: mut Inner
}

fn take_inner(x: ref Inner) i64! = {
    return x.len
}

pub fn main() i64! = {
    val o: mut ref Outer = @alloc(@sizeof(Outer)) as ref Outer
    o.inner.data = none
    o.inner.len  = 42
    val result = take_inner(o.inner)
    if result == 42 {
        @puts("ok")
    } else {
        @puts("wrong")
    }
    return 0
}
