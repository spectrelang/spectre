val std = use("std")

type String = {
    cstr: ref char
    len: mut i32
}

union SomeUnion = {
    Int32(i32)
  | Int64(i64)
  | ChrPtr(ref char)
  | Str(String)
  | Pair(i32, i32)
}

pub fn main() void! = {
    val examples: list[SomeUnion] = [
        Int32(42),
        Int64(1234567890123),
        ChrPtr("hello"),
        Str({ cstr: "world", len: 5 }),
        Pair(5, 10)
    ]
    
    for x in examples {
        match x {
            Int32 a => {
                std.stdio.put("Matched Int32")
                std.stdio.print("Value: {d}\n", {a})
            }

            Int64 b => {
                std.stdio.put("Matched Int64 (big int)")
                std.stdio.print("Value: {lld}\n", {b})
            }

            ChrPtr ptr => {
                std.stdio.put("Matched raw char pointer")
                std.stdio.print("Value: {s}\n", {ptr})
            }

            Str s => {
                std.stdio.put("Matched constructed string")
                std.stdio.print("String: {d} {s}\n", {s.len, s.cstr})
            }

            Pair z, y => {
                std.stdio.put("Matched a pair of ints")
                std.stdio.print("Values: {d} and {d}\n", {z, y})
            }

            else => {
                std.stdio.put("Unknown variant")
            }
        }
    }
}