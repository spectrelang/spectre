val stdio = use("std/stdio")

union SomeUnion = {
    Int32(i32) | Int64(i64) | Str(ref u8)
}

fn some_function(x: SomeUnion) void! = {
    match x {
        Int32 _ => {
            stdio.puts("hi inty int int")
        }
        Int64 _ => {
            stdio.puts("hi bigger inty int")
        }
        else => {
            stdio.puts("hi something else")
        }
    }
}

pub fn main() void = {
    trust some_function(Str(12))
}
