val std = use("std")

union SomeUnion = {
    i32 | i64 | ref char
}

fn some_function(x: SomeUnion) void! = {
    match x {
        i32 => {
            std.stdio.put("hi inty int int")
        }
        i64 => {
            std.stdio.put("hi bigger inty int")
        }
        else => {
            std.stdio.put("hi something else")
        }
    }
}

