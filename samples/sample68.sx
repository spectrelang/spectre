val stdio = use("std/stdio")

/// Some other docstring
type SomeType = {
    x: i32
    y: i32
}

fn (SomeType) add(this: self) i32 = {
    guard (this.x > 10) else { return 0 }
    val res = this.x + this.y
    return res
}

/// Some docstring
fn some_function(_: i32) i32 = {
    return 10
}

pub fn main() void = {
    stdio.puts("Hello, world.")
    
    some_function(10)
    val st: SomeType = {x: 10, y: 20}
    val sum: i64 = SomeType.add(st)

    trust stdio.print("\n{d}", {sum})
}
