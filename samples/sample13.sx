val std = use("std")

type SomeType = {
    x: i32
    y: i32
    z: ref char
}

pub fn (SomeType) do_some_thing(s: Self, times: usize) void! = {
    for (i = 0; i < times; i++) {
        std.io.print("{d}, {d} - {s}\n", {s.x, s.y, s.z})
    }
}

pub fn main() i32! = {
    val x: SomeType = {x: 10, y: 40, z: "hello"}
    SomeType.do_some_thing(x, 20)
    return 0
}
