/// FNV-1a hash.
///
/// This is for pointer-sized keys treated as raw integers.
pub fn hash_fnv(key: usize) usize! = {
    val FNV_OFFSET: usize = 14695981039346656037
    val FNV_PRIME: usize = 1099511628211
    val h: mut usize = FNV_OFFSET
    val k: mut usize = key
    val i: mut usize = 0
    for (i = 0; i < 8; i++) {
        val byte: usize = k & 255
        h = h ^ byte
        h = h * FNV_PRIME
        k = k >> 8
    }
    return h
}
