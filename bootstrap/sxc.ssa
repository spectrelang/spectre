data $__str1060 = { b "define ptr @__sx_get_args() {\nentry:\n  %argc = load i64, ptr @sx_argc_store\n  %argv = load ptr, ptr @sx_argv_store\n  %hdr = call ptr @malloc(i64 24)\n  %cap = mul i64 %argc, 8\n  %buf = call ptr @malloc(i64 %cap)\n  store ptr %buf, ptr %hdr\n  %len_slot = getelementptr i8, ptr %hdr, i64 8\n  store i64 0, ptr %len_slot\n  %cap_slot = getelementptr i8, ptr %hdr, i64 16\n  store i64 %argc, ptr %cap_slot\n  br label %args_loop\n\nargs_loop:\n  %i = phi i64 [0, %entry], [%next_i, %args_body]\n  %done = icmp sge i64 %i, %argc\n  br i1 %done, label %args_done, label %args_body\n\nargs_body:\n  %off = mul i64 %i, 8\n  %slot = getelementptr i8, ptr %argv, i64 %off\n  %str = load ptr, ptr %slot\n  %cur_len = load i64, ptr %len_slot\n  %boff = mul i64 %cur_len, 8\n  %bslot = getelementptr i8, ptr %buf, i64 %boff\n  store ptr %str, ptr %bslot\n  %new_len = add i64 %cur_len, 1\n  store i64 %new_len, ptr %len_slot\n  %next_i = add i64 %i, 1\n  br label %args_loop\n\nargs_done:\n  ret ptr %hdr\n}\n", b 0 }
