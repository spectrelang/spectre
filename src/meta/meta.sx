val stdio = use("std/stdio")

pub fn get_spectre_version() ref u8 = {
    return "v0.0.8"
}

pub fn print_usage() void = {
    stdio.puts("usage:")
    stdio.puts("  spectre <command> [args] | <input.sx> [options]")
    stdio.puts("")
    stdio.puts("commands:")
    stdio.puts("  init   <name>        Initialize a new project")
    stdio.puts("  build  <config>      Build using a config from sx.mod")
    stdio.puts("  run    <input.sx>    Compile and immediately run a program")
    stdio.puts("  doc    <path>        Generate docs for a given .sx into ./docs-out/")
    stdio.puts("  add    <git-url>     Clone a git dependency into ./lib/ and record it")
    stdio.puts("  remove <dep-name>    Remove a dependency by repository name")
    stdio.puts("  ref                  Generate the language reference in the current directory")
    stdio.puts("  clean                Remove build artifacts")
    stdio.puts("  doctor               Show system and Spectre installation information")
    stdio.puts("")
    stdio.puts("options:")
    stdio.puts("  --ast                Print the AST in a unicode tree and exit")
    stdio.puts("  --syntax-check       Check validity of syntax given some program")
    stdio.puts("  --emit-ssa           Print QBE IR to stdout and exit")
    stdio.puts("  --emit-alt           Print alternative IR to stdout and exit")
    stdio.puts("  --emit-asm           Print assembly to stdout and exit")
    stdio.puts("  --src-target=<os>    Mock target OS for when-blocks in source output")
    stdio.puts("  --translate-c        Translate C input into a single .sx file")
    stdio.puts("  --inc-path=<dir>     Add a an include search path for the alt backend")
    stdio.puts("  --show-cmd           Show the command used for linking")
    stdio.puts("  --test               Run the unit tests in the current file")
    stdio.puts("  --release            Build in release mode")
    stdio.puts("  --dll                Build a shared library")
    stdio.puts("  -a, --alt            Compile with fallback backend")
    stdio.puts("  -b, --bootstrap      Display backend output on error")
    stdio.puts("  -c, --compile        Compile only to produce object file, without linking")
    stdio.puts("  -o, --output <file>  Output path for binary or build artifact")
    stdio.puts("  -l, --loud           Show stages of compilation with verbose output")
    stdio.puts("  -v, --version        Show the version of the Spectre compiler")
    stdio.puts("  -h, --help           Print this help message")
}

pub fn print_version() void = {
    trust stdio.print("Spectre {s}\n(C) Navid Momtahen - GPL-3.0 - 2026", {get_spectre_version()})
}

pub fn print_src_target_help() void = {
    stdio.puts("--src-target=<os>")
    stdio.puts("")
    stdio.puts("  Mock the target OS for when blocks in source output.")
    stdio.puts("  Requires --emit-alt or --emit-ssa.")
    stdio.puts("")
    stdio.puts("  Valid targets:")
    stdio.puts("    windows, linux, darwin, freebsd, openbsd, netbsd,")
    stdio.puts("    dragonflybsd, android, haiku, redox, plan9")
    stdio.puts("")
    stdio.puts("  Example:")
    stdio.puts("    spectre file.sx --src-target=windows --emit-alt")
}
