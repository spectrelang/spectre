        \\setSidebar(isOpen,false);
        \\btn.addEventListener('click',function(){setSidebar(!isOpen,true);});
        \\
        \\/* ── Search ── */
        \\var inp=document.getElementById('search');
        \\inp.addEventListener('input',function(){
        \\  var q=this.value.toLowerCase().trim();
        \\  var links=sb.querySelectorAll('.nav-item[data-name]');
        \\  for(var i=0;i<links.length;i++){
        \\    var l=links[i];
        \\    l.classList.toggle('hidden',q!==''&&l.dataset.name.toLowerCase().indexOf(q)===-1);
        \\  }
        \\  var cards=ct.querySelectorAll('.entry[data-name]');
        \\  for(var j=0;j<cards.length;j++){
        \\    var c=cards[j];
        \\    c.classList.toggle('s-hide',q!==''&&c.dataset.name.toLowerCase().indexOf(q)===-1);
        \\  }
        \\});
        \\document.addEventListener('keydown',function(e){
        \\  if(e.key==='/'&&document.activeElement!==inp){
        \\    e.preventDefault();
        \\    if(!isOpen)setSidebar(true,true);
        \\    inp.focus();
        \\  }
        \\  if(e.key==='Escape'&&document.activeElement===inp){inp.blur();}
        \\});
        \\
        \\/* ── Spectre syntax highlighter ── */
        \\(function(){
        \\  var KW=/\b(fn|pub|val|mut|type|enum|union|extern|ref|if|elif|else|for|match|return|break|continue|use|in|as|is|true|false|void|untyped|some|none|ok|err|when|otherwise|guarded|pre|post|assert|test|and|or|not)\b/g;
        \\  var TY=/\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|u8|usize|isize|list|ref|option|result)\b/g;
        \\  var NUM=/\b(0x[0-9a-fA-F]+|\d+(?:\.\d+)?(?:[eE][+-]?\d+)?)\b/g;
        \\  var STR=/(\"(?:[^\"\\]|\\.)*\")/g;
        \\  var CMT=/(\/\/[^\n]*)/g;
        \\  var OP=/([(){}\[\]@!;,.|&^~<>=+\-*/%:])/g;
        \\  var FN=/\bfn\s+([A-Za-z_][A-Za-z0-9_]*)/g;
        \\
        \\  function esc(s){
        \\    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        \\  }
        \\
        \\  function highlight(raw){
        \\    var patterns=[
        \\      {re:/\/\/[^\n]*/g,       cls:'hljs-comment'},
        \\      {re:/"(?:[^"\\]|\\.)*"/g, cls:'hljs-string'},
        \\      {re:/\b(fn|pub|val|mut|type|enum|union|extern|ref|if|elif|else|for|match|return|break|continue|use|in|as|is|true|false|void|untyped|some|none|ok|err|when|otherwise|guarded|pre|post|assert|test|and|or|not)\b/g, cls:'hljs-keyword'},
        \\      {re:/\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|usize|isize)\b/g, cls:'hljs-type'},
        \\      {re:/\b(list|option|result)\b/g, cls:'hljs-built_in'},
        \\      {re:/\b0x[0-9a-fA-F]+|\b\d+(?:\.\d+)?(?:[eE][+-]?\d+)?\b/g, cls:'hljs-number'},
        \\      {re:/[(){}\[\]@!;,.|&^~<>=+\-*\/%:]/g, cls:'hljs-punctuation'},
        \\    ];
        \\
        \\    var tokens=[];
        \\    for(var pi=0;pi<patterns.length;pi++){
        \\      var p=patterns[pi];
        \\      p.re.lastIndex=0;
        \\      var m;
        \\      while((m=p.re.exec(raw))!==null){
        \\        tokens.push({s:m.index,e:m.index+m[0].length,cls:p.cls,text:m[0]});
        \\      }
        \\    }
        \\    tokens.sort(function(a,b){return a.s-b.s||(b.e-b.s)-(a.e-a.s);});
        \\    var clean=[];var pos=0;
        \\    for(var ti=0;ti<tokens.length;ti++){
        \\      var t=tokens[ti];
        \\      if(t.s<pos)continue;
        \\      clean.push(t);pos=t.e;
        \\    }
        \\    var out='';var cur=0;
        \\    for(var ci=0;ci<clean.length;ci++){
        \\      var tk=clean[ci];
        \\      if(cur<tk.s)out+=esc(raw.slice(cur,tk.s));
        \\      out+='<span class="'+tk.cls+'">'+esc(tk.text)+'</span>';
        \\      cur=tk.e;
        \\    }
        \\    if(cur<raw.length)out+=esc(raw.slice(cur));
        \\    return out;
        \\  }
        \\
        \\  document.querySelectorAll('pre code.language-spectre').forEach(function(el){
        \\    var raw=el.textContent;
        \\    el.innerHTML=highlight(raw);
        \\  });
        \\})();
        \\
        \\})();
    )
    std.string.StringBuilder.append_cstr(sb, "</script></body></html>")
    val built = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn render_entry_details_md(sb: ref void, entry: ref DocEntry) void! = {
    val node = entry.node
    if node.kind == parser.NK_TYPEDEF || node.kind == parser.NK_EXTERN_TYPE {
        val fields = node.d2 as list[ref parser.Node]
        if @len(fields) as i64 > 0 {
            std.string.StringBuilder.append_cstr(sb, "\n**Fields**\n\n| Name | Type |\n| --- | --- |\n")
            for field in fields {
                val prefix: mut ref u8 = ""
                if field.d1 != 0 { prefix = "mut " }
                std.string.StringBuilder.append_cstr(sb, @fmt("| `{s}` | `{s}{s}` |\n", {field.d0 as ref u8, prefix, render_type(field.d2 as ref parser.Node)}))
            }
        }
    } elif node.kind == parser.NK_ENUMDEF {
        std.string.StringBuilder.append_cstr(sb, "\n**Variants**\n\n")
        for variant in node.d2 as list[ref u8] {
            std.string.StringBuilder.append_cstr(sb, @fmt("- `{s}`\n", {variant}))
        }
    } elif node.kind == parser.NK_UNIONDEF {
        std.string.StringBuilder.append_cstr(sb, "\n**Variants**\n\n")
        for variant in node.d2 as list[ref parser.Node] {
            std.string.StringBuilder.append_cstr(sb, @fmt("- `{s}`\n", {render_type(variant)}))
        }
    } elif node.kind == parser.NK_TAGGED_UNIONDEF {
        std.string.StringBuilder.append_cstr(sb, "\n**Variants**\n\n")
        for variant in node.d2 as list[ref parser.Node] {
            val types = render_type_list(variant.d1 as list[ref parser.Node], ", ")
            val text: mut ref u8 = variant.d0 as ref u8
            if !str_eq(types, "") { text = @fmt("{s}({s})", {text, types}) } else { text = @fmt("{s}()", {text}) }
            std.string.StringBuilder.append_cstr(sb, @fmt("- `{s}`\n", {text}))
        }
    }
}

fn render_module_page_md(module: ref DocModule, modules: list[ref DocModule]) ref u8! = {
    val sb: ref void = std.string.StringBuilder.new()
    std.string.StringBuilder.append_cstr(sb, @fmt("# {s}\n\n", {safe_cstr(module.module_name)}))
    std.string.StringBuilder.append_cstr(sb, @fmt("Source: `{s}`\n\n", {safe_cstr(module.rel_path)}))
    if @len(modules) as i64 > 1 {
        std.string.StringBuilder.append_cstr(sb, "## Modules\n\n")
        for mod in modules {
            std.string.StringBuilder.append_cstr(sb, @fmt("- [{s}]({s})\n", {safe_cstr(mod.module_name), href_from(module.output_path, mod.output_path)}))
        }
        std.string.StringBuilder.append_cstr(sb, "\n")
    }
    if @len(module.entries) as i64 > 0 {
        std.string.StringBuilder.append_cstr(sb, "## On this page\n\n")
        for entry in module.entries {
            std.string.StringBuilder.append_cstr(sb, @fmt("- [{s}](#{s})\n", {entry.nav_name, entry.anchor}))
        }
        std.string.StringBuilder.append_cstr(sb, "\n")
    }
    for entry in module.entries {
        std.string.StringBuilder.append_cstr(sb, "## ")
        std.string.StringBuilder.append_cstr(sb, entry.name)
        std.string.StringBuilder.append_cstr(sb, " {#")
        std.string.StringBuilder.append_cstr(sb, entry.anchor)
        std.string.StringBuilder.append_cstr(sb, "}\n\n")
        if !str_eq(entry.availability, "") {
            std.string.StringBuilder.append_cstr(sb, @fmt("Availability: `{s}`\n\n", {entry.availability}))
        }
        std.string.StringBuilder.append_cstr(sb, "```spectre\n")
        std.string.StringBuilder.append_cstr(sb, entry.signature)
        std.string.StringBuilder.append_cstr(sb, "\n```\n\n")
        if !str_eq(entry.docs, "") {
            std.string.StringBuilder.append_cstr(sb, entry.docs)
            std.string.StringBuilder.append_cstr(sb, "\n")
        }
        render_entry_details_md(sb, entry)
        std.string.StringBuilder.append_cstr(sb, "\n")
    }
    if @len(module.entries) as i64 == 0 {
        std.string.StringBuilder.append_cstr(sb, "No top-level documented functions or types were found in this module.\n")
    }
    val built = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn render_overview_page(markdown: bool, modules: list[ref DocModule], output_path: ref u8) ref u8! = {
    if markdown {
        val sb = std.string.StringBuilder.new()
        std.string.StringBuilder.append_cstr(sb, "# Docs\n\n## Modules\n\n")
        for mod in modules {
            std.string.StringBuilder.append_cstr(sb, @fmt("- [{s}]({s})\n", {mod.module_name, href_from(output_path, mod.output_path)}))
        }
        val built = std.string.StringBuilder.build(sb)
        std.string.StringBuilder.free(sb)
        return std.string.cstr(built)
    }
    val sb2 = std.string.StringBuilder.new()
    std.string.StringBuilder.append_cstr(sb2,
        \\<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><title>Docs</title>
        \\<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">
        \\<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">
        \\<link href=\"https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">
        \\<style>
