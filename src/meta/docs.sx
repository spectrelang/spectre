    )
    std.string.StringBuilder.append_cstr(sb, "</style></head><body>")

    std.string.StringBuilder.append_cstr(sb, "<button class=\"toggle\" id=\"toggle\" aria-label=\"Toggle sidebar\"><svg viewBox=\"0 0 24 24\"><line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"/><line x1=\"3\" y1=\"12\" x2=\"21\" y2=\"12\"/><line x1=\"3\" y1=\"18\" x2=\"21\" y2=\"18\"/></svg></button>")

    std.string.StringBuilder.append_cstr(sb, "<button class=\"theme-btn\" id=\"theme-btn\" aria-label=\"Toggle theme\"><svg id=\"theme-icon\" viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"5\"/><line x1=\"12\" y1=\"1\" x2=\"12\" y2=\"3\"/><line x1=\"12\" y1=\"21\" x2=\"12\" y2=\"23\"/><line x1=\"4.22\" y1=\"4.22\" x2=\"5.64\" y2=\"5.64\"/><line x1=\"18.36\" y1=\"18.36\" x2=\"19.78\" y2=\"19.78\"/><line x1=\"1\" y1=\"12\" x2=\"3\" y2=\"12\"/><line x1=\"21\" y1=\"12\" x2=\"23\" y2=\"12\"/><line x1=\"4.22\" y1=\"19.78\" x2=\"5.64\" y2=\"18.36\"/><line x1=\"18.36\" y1=\"5.64\" x2=\"19.78\" y2=\"4.22\"/></svg></button>")

    std.string.StringBuilder.append_cstr(sb, "<div class=\"page\">")

    std.string.StringBuilder.append_cstr(sb, "<aside class=\"sidebar\" id=\"sidebar\">")
    std.string.StringBuilder.append_cstr(sb, "<div class=\"sb-search\"><svg class=\"sb-search-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/></svg><input class=\"sb-input\" id=\"search\" type=\"search\" placeholder=\"Search... (/)\" autocomplete=\"off\" spellcheck=\"false\"/></div>")
    std.string.StringBuilder.append_cstr(sb, "<nav class=\"sb-nav\" id=\"sb-nav\">")
    append_nav_html(sb, modules, module)
    std.string.StringBuilder.append_cstr(sb, "</nav></aside>")

    std.string.StringBuilder.append_cstr(sb, "<main class=\"content\" id=\"content\">")
    std.string.StringBuilder.append_cstr(sb, @fmt("<div class=\"hero\"><h1>{s}</h1><div class=\"hero-meta\"><span class=\"label\">source</span><code>{s}</code></div></div>", {
        html_escape(safe_cstr(module.module_name)),
        html_escape(safe_cstr(module.rel_path))
    }))

    for entry in module.entries {
        render_entry_html(sb, entry)
    }
    if @len(module.entries) as i64 == 0 {
        std.string.StringBuilder.append_cstr(sb, "<div class=\"empty\">No documented items found in this module.</div>")
    }
    std.string.StringBuilder.append_cstr(sb, "</main></div>")

    std.string.StringBuilder.append_cstr(sb, "<script>")
    std.string.StringBuilder.append_cstr(sb,
        \\(function(){
        \\'use strict';
        \\
        \\/* ── Theme ── */
        \\var html=document.documentElement;
        \\var stored=localStorage.getItem('theme');
        \\var prefersDark=window.matchMedia('(prefers-color-scheme:dark)').matches;
        \\var dark=stored==='dark'||(stored===null&&prefersDark);
        \\function applyTheme(d){
        \\  html.classList.toggle('dark',d);
        \\  dark=d;
        \\  localStorage.setItem('theme',d?'dark':'light');
        \\  var icon=document.getElementById('theme-icon');
        \\  if(d){
        \\    icon.innerHTML='<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';
        \\  } else {
        \\    icon.innerHTML='<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
        \\  }
        \\}
        \\applyTheme(dark);
        \\document.getElementById('theme-btn').addEventListener('click',function(){applyTheme(!dark);});
        \\
        \\/* ── Sidebar ── */
        \\var sb=document.getElementById('sidebar');
        \\var btn=document.getElementById('toggle');
        \\var ct=document.getElementById('content');
        \\var isOpen=localStorage.getItem('sb-open')!=='0';
        \\function setSidebar(open,animate){
        \\  if(!animate){
        \\    sb.style.transition='none';btn.style.transition='none';ct.style.transition='none';
        \\  }
        \\  if(open){
        \\    sb.classList.remove('collapsed');ct.classList.remove('sb-closed');btn.classList.add('sb-open');
        \\  } else {
        \\    sb.classList.add('collapsed');ct.classList.add('sb-closed');btn.classList.remove('sb-open');
        \\  }
