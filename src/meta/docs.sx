        \\  font-family:var(--mono);font-size:12.5px;
        \\  background:var(--code-bg);padding:3px 8px;
        \\  border-radius:5px;color:var(--code-text);
        \\  border:1px solid var(--border2);display:inline-block;
        \\}
        \\.details{list-style:none;padding:0;display:flex;flex-direction:column;gap:4px}
        \\.details li code{
        \\  font-family:var(--mono);font-size:12.5px;
        \\  background:var(--code-bg);padding:3px 8px;
        \\  border-radius:5px;color:var(--code-text);
        \\  border:1px solid var(--border2);display:inline-block;
        \\}
        \\
        \\/* ── Empty state ── */
        \\.empty{
        \\  background:var(--surface);border:1px dashed var(--border);
        \\  border-radius:var(--radius);padding:40px 28px;
        \\  color:var(--text3);text-align:center;font-size:14px;
        \\}
        \\
        \\/* ── Responsive ── */
        \\@media(max-width:860px){
        \\  .sidebar{transform:translateX(calc(-1 * var(--sb-w)))}
        \\  .sidebar.sb-open-m{transform:translateX(0)}
        \\  .content{margin-left:0!important;padding:28px 20px 60px}
        \\  .toggle{left:14px}
        \\  .toggle.sb-open{left:calc(var(--sb-w) + 10px)}
