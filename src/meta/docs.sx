        \\html.dark{--bg:#000000;--surface:#0f1d35;--border:#162b52;--text:#d8e8ff;--text2:#8badd4;--text3:#4a6d96;--accent:#4a90f7;--accent2:#6aaeff}
        \\*{box-sizing:border-box;margin:0;padding:0}
        \\body{font-family:var(--font);background:var(--bg);color:var(--text);display:flex;align-items:flex-start;justify-content:center;padding:64px 24px;min-height:100vh;transition:background .2s,color .2s}
        \\a{color:var(--accent);text-decoration:none}a:hover{color:var(--accent2)}
        \\.card{width:100%;max-width:600px;background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:40px 44px;box-shadow:0 4px 24px rgba(15,31,61,.07)}
        \\.card h1{margin:0 0 4px;font-size:24px;font-weight:700;letter-spacing:-.02em}
        \\.card .sub{color:var(--text3);margin:0 0 28px;font-size:13px;font-family:var(--mono)}
        \\ul{padding:0;list-style:none;margin:0}
        \\li{margin:3px 0}
        \\li a{font-size:14px;font-family:var(--mono);display:block;padding:8px 12px;border-radius:7px;transition:background .12s,color .12s}
        \\li a:hover{background:color-mix(in srgb,var(--accent) 8%,transparent);text-decoration:none}
        \\.theme-btn{position:fixed;top:16px;right:16px;width:34px;height:34px;background:var(--surface);border:1px solid var(--border);border-radius:8px;color:var(--text2);cursor:pointer;display:flex;align-items:center;justify-content:center}
        \\.theme-btn svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round}
        \\</style></head><body>
    )
    std.string.StringBuilder.append_cstr(sb2, "<button class=\"theme-btn\" id=\"theme-btn\" aria-label=\"Toggle theme\"><svg id=\"theme-icon\" viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"5\"/><line x1=\"12\" y1=\"1\" x2=\"12\" y2=\"3\"/><line x1=\"12\" y1=\"21\" x2=\"12\" y2=\"23\"/><line x1=\"4.22\" y1=\"4.22\" x2=\"5.64\" y2=\"5.64\"/><line x1=\"18.36\" y1=\"18.36\" x2=\"19.78\" y2=\"19.78\"/><line x1=\"1\" y1=\"12\" x2=\"3\" y2=\"12\"/><line x1=\"21\" y1=\"12\" x2=\"23\" y2=\"12\"/><line x1=\"4.22\" y1=\"19.78\" x2=\"5.64\" y2=\"18.36\"/><line x1=\"18.36\" y1=\"5.64\" x2=\"19.78\" y2=\"4.22\"/></svg></button>")
    std.string.StringBuilder.append_cstr(sb2, "<div class=\"card\"><h1>Docs</h1><ul>")
    for mod in modules {
        std.string.StringBuilder.append_cstr(sb2, @fmt("<li><a href=\"{s}\">{s}</a></li>", {href_from(output_path, mod.output_path), html_escape(mod.module_name)}))
    }
    std.string.StringBuilder.append_cstr(sb2, "</ul></div>")
    std.string.StringBuilder.append_cstr(sb2,
        \\<script>(function(){
        \\var h=document.documentElement;
        \\var s=localStorage.getItem('theme');
        \\var d=s==='dark'||(s===null&&window.matchMedia('(prefers-color-scheme:dark)').matches);
        \\function apply(dark){h.classList.toggle('dark',dark);localStorage.setItem('theme',dark?'dark':'light');
        \\var i=document.getElementById('theme-icon');
        \\i.innerHTML=dark?'<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>':'<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';}
        \\apply(d);
        \\document.getElementById('theme-btn').addEventListener('click',function(){d=!d;apply(d);});
        \\})();</script>
    )
    std.string.StringBuilder.append_cstr(sb2, "</body></html>")
    val built2 = std.string.StringBuilder.build(sb2)
    std.string.StringBuilder.free(sb2)
    return std.string.cstr(built2)
}

fn write_page(path: ref u8, content: ref u8) bool! = {
    if !ensure_parent_dir(path) { return false }
    return std.fs.write_all(path, content)
}

fn maybe_root_rel_for_dir() ref u8! = {
    val sxmod_opt = commands.load_sxmod()
    match sxmod_opt {
        some cfg => {
            val entry: ref u8 = (cfg as ref commands.SxMod).entry
            if !str_eq(entry, "") { return normalize_rel_path(entry) }
        }
        none => {}
    }
    return ""
}

pub fn cmd_doc(target: ref u8, markdown: bool) i32! = {
    if str_eq(target, "") {
        std.stdio.puts("error: doc requires a file or directory target")
        return 1
    }
    val out_dir: ref u8 = "./docs-out"
    if !ensure_dir(out_dir) {
        std.stdio.print("error: could not create '{s}'\n", {out_dir})
        return 1
    }

    if dir_exists(target) {
        val clean_target = trim_trailing_slash(target)
        val files: mut list[ref u8] = []
        collect_sx_files(clean_target, "", files)
        if @len(files) as i64 == 0 {
            std.stdio.print("error: no .sx files found in '{s}'\n", {target})
            return 1
        }
        val modules: mut list[ref DocModule] = []
        for rel in files {
            val source_path: mut ref u8 = rel
            if !str_eq(clean_target, ".") && !str_eq(clean_target, "") {
                source_path = std.path.join(clean_target, rel)
            } else {
                source_path = @fmt("./{s}", {rel})
            }
            @append(modules, load_module(source_path, rel))
        }
        val root_rel = maybe_root_rel_for_dir()
        val root_idx = find_root_module(modules, root_rel)
        assign_output_paths(modules, markdown, root_idx)
        if root_idx < 0 {
            val index_rel: mut ref u8 = "index.html"
            if markdown { index_rel = "index.md" }
            val index_path = std.path.join("docs-out", index_rel)
            if !write_page(index_path, render_overview_page(markdown, modules, index_rel)) {
                std.stdio.print("error: could not write '{s}'\n", {index_path})
                return 1
            }
        }
        for mod in modules {
            val full_path = std.path.join("docs-out", mod.output_path)
            val content: mut ref u8 = ""
            if markdown {
                content = render_module_page_md(mod, modules)
            } else {
                content = render_module_page_html(mod, modules)
            }
            if !write_page(full_path, content) {
                std.stdio.print("error: could not write '{s}'\n", {full_path})
                return 1
            }
        }
        std.stdio.print("wrote docs to {s}\n", {out_dir})
        return 0
    }

    if !std.os.exists(target) {
        std.stdio.print("error: could not read '{s}'\n", {target})
        return 1
    }
    if !str.rchar_ends_with(target, ".sx") {
        std.stdio.puts("error: doc expects a .sx file or a directory")
        return 1
    }
    val rel_path = normalize_rel_path(path_basename(target))
    val module: mut ref DocModule = load_module(target, rel_path)
    module.is_root = true
    if markdown { module.output_path = "index.md" } else { module.output_path = "index.html" }
    val modules: mut list[ref DocModule] = []
    @append(modules, module)
    val content: mut ref u8 = ""
    if markdown {
        content = render_module_page_md(module, modules)
    } else {
        content = render_module_page_html(module, modules)
    }
    val out_path = std.path.join(out_dir, module.output_path)
    if !write_page(out_path, content) {
        std.stdio.print("error: could not write '{s}'\n", {out_path})
        return 1
    }
    std.stdio.print("wrote docs to {s}\n", {out_dir})
    return 0
}

test {
    assert(str_eq(trust substr("hello", -5, 2), "he"))
    assert(str_eq(trust substr("hello", 10, 3), ""))
    assert(str_eq(trust substr("hello", 1, 99), "ello"))

    val docs = trust extract_doc_map(
        \\/// hello
        \\/// world
        \\fn greet() void = {}
        \\type Point = { x: i64 }
    )

    assert(str_eq(trust lookup_doc(docs, 3), "hello\nworld"))
    assert(str_eq(trust lookup_doc(docs, 4), ""))

    val docs_no_trailing_nl = trust extract_doc_map(
        \\/// tail docs
        \\fn tail() void = {}
    )

    assert(str_eq(trust lookup_doc(docs_no_trailing_nl, 2), "tail docs"))
    assert(str_eq(trust slugify("Hello.World"), "hello-world"))
    assert(str_eq(trust strip_sx_ext("src/meta/docs.sx"), "src/meta/docs"))

    val fn_src = "fn add(a: i64, b: i64) i64! = { return a + b }"
    val ml: mut i64 = 0

    match regex.re_match("^fn [^=]+", fn_src, @addr(ml)) {
        ok found => {
            match found {
                some pos => {
                    val sig = trust trim_ws(substr(fn_src, pos, ml))
                    assert(str_eq(sig, "fn add(a: i64, b: i64) i64!"))
                }
                none => { assert false }
            }
        }
        err _ => { assert false }
    }
    val type_src = "type Point = { x: i64, y: i64 }"
    val ml2: mut i64 = 0
    match regex.re_match("^type [A-Za-z_]+", type_src, @addr(ml2)) {
        ok found => {
            match found {
                some pos => {
                    assert(str_eq(trust trim_ws(substr(type_src, pos, ml2)), "type Point"))
                }
                none => { assert false }
            }
        }
        err _ => { assert false }
    }
}
