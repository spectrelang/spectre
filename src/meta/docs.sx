val std      = use("std")
val str      = use("std/string")
val regex    = use("std/regex")
val algo     = use("std/algorithms")
val lexer    = use("../ast/lexer.sx")
val parser   = use("../ast/parser.sx")
val commands = use("commands.sx")

type DocMap = {
    lines: mut list[i64]
    docs:  mut list[ref u8]
}

type DocEntry = {
    kind:         mut i64
    line:         mut i64
    name:         mut ref u8
    nav_name:     mut ref u8
    anchor:       mut ref u8
    signature:    mut ref u8
    docs:         mut ref u8
    availability: mut ref u8
    node:         mut ref parser.Node
}

type DocModule = {
    source_path: mut ref u8
    rel_path:    mut ref u8
    module_name: mut ref u8
    output_path: mut ref u8
    is_root:     mut bool
    entries:     mut list[ref DocEntry]
}

fn safe_cstr(s: ref u8) ref u8 = {
    if s == 0 as ref u8 { return "" }
    return s
}

fn str_eq(a: ref u8, b: ref u8) bool = {
    return str.rchar_cmp(safe_cstr(a), safe_cstr(b)) == 0
}

fn is_space(c: u8) bool = {
    return c == 32 || c == 9 || c == 10 || c == 13
}

fn substr(src: ref u8, start: i64, len: i64) ref u8! = {
    guarded pre {
        src_not_null : src != 0 as ref u8
    }

    val src_len: i64 = str.len_raw(src)
    val safe_start: mut i64 = start
    if safe_start < 0 { safe_start = 0 }
    if safe_start > src_len { safe_start = src_len }

    val max_len: i64 = src_len - safe_start
    val safe_len: mut i64 = len
    if safe_len < 0 { safe_len = 0 }
    if safe_len > max_len { safe_len = max_len }

    val out = str.substr(src, safe_start, safe_len)

    guarded post {
        out_not_null : out != 0 as ref u8
    }
    return out
}

fn trim_ws(src: ref u8) ref u8! = {
    val len: i64 = str.len_raw(src)
    if len == 0 { return "" }
    val start: mut i64 = 0
    for {
        if start >= len { break }
        val c: u8 = @load8(@ptradd(src as ref void, start))
        if !is_space(c) { break }
        start++
    }
    val finish: mut i64 = len
    for {
        if finish <= start { break }
        val c: u8 = @load8(@ptradd(src as ref void, finish - 1))
        if !is_space(c) { break }
        finish--
    }
    return substr(src, start, finish - start)
}

fn trim_trailing_slash(src: ref u8) ref u8! = {
    val len: i64 = str.len_raw(src)
    if len <= 1 { return src }
    if @load8(@ptradd(src as ref void, len - 1)) != 47 { return src }
    return substr(src, 0, len - 1)
}

fn normalize_rel_path(path: ref u8) ref u8! = {
    val no_dot = str.trim_prefix_raw(path, "./")
    return trim_trailing_slash(no_dot)
}

fn path_dirname(path: ref u8) ref u8! = {
    val len: i64 = str.len_raw(path)
    val last_slash: mut i64 = -1
    val i: mut i64 = 0
    for {
        if i >= len { break }
        if @load8(@ptradd(path as ref void, i)) == 47 { last_slash = i }
        i++
    }
    if last_slash < 0 { return "." }
    if last_slash == 0 { return "/" }
    return substr(path, 0, last_slash)
}

fn path_basename(path: ref u8) ref u8! = {
    val len: i64 = str.len_raw(path)
    val last_slash: mut i64 = -1
    val i: mut i64 = 0
    for {
        if i >= len { break }
        if @load8(@ptradd(path as ref void, i)) == 47 { last_slash = i }
        i++
    }
    return substr(path, last_slash + 1, len - last_slash - 1)
}

fn strip_sx_ext(path: ref u8) ref u8! = {
    if str.rchar_ends_with(path, ".sx") {
        return str.trim_suffix_raw(path, ".sx")
    }
    return path
}

fn dir_exists(path: ref u8) bool = {
    val dir: ref void = std.fs.opendir(path)
    if dir == 0 as ref void { return false }
    std.fs.closedir(dir)
    return true
}

fn ensure_dir(path: ref u8) bool! = {
    val clean = trim_trailing_slash(path)
    if str_eq(clean, "") || str_eq(clean, ".") { return true }
    if std.os.exists(clean) { return true }
    val len: i64 = str.len_raw(clean)
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = @load8(@ptradd(clean as ref void, i))
        if c == 47 {
            val part = substr(clean, 0, i)
            if !str_eq(part, "") && !str_eq(part, ".") && !std.os.exists(part) {
                if !std.fs.mkdir_path(part) { return false }
            }
        }
        i++
    }
    if !std.os.exists(clean) {
        return std.fs.mkdir_path(clean)
    }
    return true
}

fn ensure_parent_dir(file_path: ref u8) bool! = {
    val dir = path_dirname(file_path)
    return ensure_dir(dir)
}

fn is_hidden_name(name: ref u8) bool! = {
    val len: i64 = str.len_raw(name)
    if len == 0 { return false }
    return @load8(name as ref void) == 46
}

fn collect_sx_files(dir: ref u8, rel_dir: ref u8, out: mut list[ref u8]) void! = {
    val entries_opt = std.fs.walk_dir(dir)
    if entries_opt is some entries {
        val sorted = entries as list[ref u8]
        for entry in sorted {
            if is_hidden_name(entry) { continue }
            if str_eq(entry, "docs-out") { continue }
            val child_path = std.path.join(dir, entry)
            val child_rel: mut ref u8 = entry
            if !str_eq(rel_dir, "") {
                child_rel = std.path.join(rel_dir, entry)
            }
            if dir_exists(child_path) {
                collect_sx_files(child_path, child_rel, out)
            } elif str.rchar_ends_with(entry, ".sx") {
                @append(out, normalize_rel_path(child_rel))
            }
        }
    }
}

fn is_doc_target_line(line: ref u8) bool! = {
    return str.rchar_starts_with(line, "fn ") ||
           str.rchar_starts_with(line, "pub fn ") ||
           str.rchar_starts_with(line, "extern ") ||
           str.rchar_starts_with(line, "pub extern ") ||
           str.rchar_starts_with(line, "type ") ||
           str.rchar_starts_with(line, "pub type ") ||
           str.rchar_starts_with(line, "enum ") ||
           str.rchar_starts_with(line, "pub enum ") ||
           str.rchar_starts_with(line, "union ") ||
           str.rchar_starts_with(line, "pub union ")
}

fn doc_line_text(trimmed: ref u8) ref u8! = {
    val len: i64 = str.len_raw(trimmed)
    if len <= 3 { return "" }
    if len > 3 && @load8(@ptradd(trimmed as ref void, 3)) == 32 {
        return substr(trimmed, 4, len - 4)
    }
    return substr(trimmed, 3, len - 3)
}

fn update_doc_map_for_line(map: ref DocMap, trimmed: ref u8, line_no: i64, current_doc: ref u8) ref u8! = {
    guarded pre {
        map_not_null         : map != 0 as ref DocMap
        trimmed_not_null     : trimmed != 0 as ref u8
        current_doc_not_null : current_doc != 0 as ref u8
        line_is_positive     : line_no > 0
    }

    if str.rchar_starts_with(trimmed, "///") {
        val text = doc_line_text(trimmed)
        if str_eq(current_doc, "") {
            return text
        }
        return @fmt("{s}\n{s}", {current_doc, text})
    }

    if !str_eq(current_doc, "") && is_doc_target_line(trimmed) {
        @append(map.lines, line_no)
        @append(map.docs, current_doc)
        return ""
    }

    if !str_eq(trimmed, "") {
        return ""
    }

    guarded post {
        lengths_match : @len(map.lines) == @len(map.docs)
    }
    return current_doc
}

fn extract_doc_map(src: ref u8) ref DocMap! = {
    guarded pre {
        src_not_null : src != 0 as ref u8
    }

    val map: mut ref DocMap = @alloc(@sizeof(DocMap)) as ref DocMap
    map.lines = []
    map.docs = []
    val len: i64 = str.len_raw(src)
    val line_no: mut i64 = 1
    val line_start: mut i64 = 0
    val i: mut i64 = 0
    val current_doc: mut ref u8 = ""
    for {
        if i >= len {
            val line = substr(src, line_start, len - line_start)
            val trimmed = trim_ws(line)
            current_doc = update_doc_map_for_line(map, trimmed, line_no, current_doc)
            break
        }

        val c: u8 = @load8(@ptradd(src as ref void, i))
        if c == 10 {
            val line = substr(src, line_start, i - line_start)
            val trimmed = trim_ws(line)
            current_doc = update_doc_map_for_line(map, trimmed, line_no, current_doc)
            line_no++
            line_start = i + 1
        }
        i++
    }

    guarded post {
        map_not_null    : map != 0 as ref DocMap
        lengths_match   : @len(map.lines) == @len(map.docs)
    }
    return map
}

fn lookup_doc(map: ref DocMap, line: i64) ref u8! = {
    val len: i64 = @len(map.lines) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val line_opt = @get(map.lines, i as usize)
        match line_opt {
            some v => {
                if ((v as i64) == line) {
                    val doc_opt = @get(map.docs, i as usize)
                    match doc_opt {
                        some d => { return d as ref u8 }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return ""
}

fn slugify(text: ref u8) ref u8! = {
    val sb: ref void = std.string.StringBuilder.new()
    val len: i64 = str.len_raw(text)
    val i: mut i64 = 0
    val prev_dash: mut bool = false
    for {
        if i >= len { break }
        val c: u8 = @load8(@ptradd(text as ref void, i))
        val is_lower: bool = c >= 97 && c <= 122
        val is_upper: bool = c >= 65 && c <= 90
        val is_digit: bool = c >= 48 && c <= 57
        if is_lower || is_digit {
            std.string.StringBuilder.append_char(sb, c)
            prev_dash = false
        } elif is_upper {
            std.string.StringBuilder.append_char(sb, (c + 32) as u8)
            prev_dash = false
        } else {
            if !prev_dash {
                std.string.StringBuilder.append_char(sb, 45 as u8)
                prev_dash = true
            }
        }
        i++
    }
    val built = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn anchor_for(kind_name: ref u8, item_name: ref u8, line: i64) ref u8! = {
    return slugify(@fmt("{s}-{s}-{lld}", {kind_name, item_name, line}))
}

fn render_type(ty: ref parser.Node) ref u8! = {
    if ty == 0 as ref parser.Node { return "" }
    match ty.kind {
        parser.TY_NAMED => { return ty.d0 as ref u8 }
        parser.TY_REF => { return @fmt("ref {s}", {render_type(ty.d0 as ref parser.Node)}) }
        parser.TY_MUT => { return @fmt("mut {s}", {render_type(ty.d0 as ref parser.Node)}) }
        parser.TY_OPTION => { return @fmt("option[{s}]", {render_type(ty.d0 as ref parser.Node)}) }
        parser.TY_LIST => { return @fmt("list[{s}]", {render_type(ty.d0 as ref parser.Node)}) }
        parser.TY_RESULT => { return @fmt("result[{s}, {s}]", {render_type(ty.d0 as ref parser.Node), render_type(ty.d1 as ref parser.Node)}) }
        parser.TY_SLICE => { return @fmt("[]{s}", {render_type(ty.d0 as ref parser.Node)}) }
        parser.TY_FIXED_ARR => {
            val size_name: ref u8 = parser.fixed_arr_size_name(ty)
            if size_name != 0 as ref u8 {
                return @fmt("[{s}]{s}", {size_name, render_type(parser.fixed_arr_inner(ty))})
            }
            return @fmt("[{lld}]{s}", {parser.fixed_arr_size(ty), render_type(parser.fixed_arr_inner(ty))})
        }
        parser.TY_FNPTR => {
            val parts: mut ref u8 = ""
            val params = ty.d0 as list[ref parser.Node]
            for param in params {
                val part = render_type(param)
                if str_eq(parts, "") {
                    parts = part
                } else {
                    parts = @fmt("{s}, {s}", {parts, part})
                }
            }
            return @fmt("fn({s}) {s}", {parts, render_type(ty.d1 as ref parser.Node)})
        }
        parser.TY_VOID => { return "void" }
        parser.TY_UNTYPED => { return "untyped" }
    }
    return "unknown"
}

fn render_fn_params(params: list[ref parser.Node]) ref u8! = {
    val out: mut ref u8 = ""
    for param in params {
        val param_name: ref u8 = param.d0 as ref u8
        val param_ty: ref parser.Node = param.d1 as ref parser.Node
        val piece = @fmt("{s}: {s}", {param_name, render_type(param_ty)})
        if str_eq(out, "") {
            out = piece
        } else {
            out = @fmt("{s}, {s}", {out, piece})
        }
    }
    return out
}

fn render_type_fields(fields: list[ref parser.Node]) ref u8! = {
    val out: mut ref u8 = ""
    for field in fields {
        val prefix: mut ref u8 = ""
        if field.d1 != 0 { prefix = "mut " }
        val piece = @fmt("{s}: {s}{s}", {field.d0 as ref u8, prefix, render_type(field.d2 as ref parser.Node)})
        if str_eq(out, "") {
            out = piece
        } else {
            out = @fmt("{s}, {s}", {out, piece})
        }
    }
    return out
}

fn render_type_list(types: list[ref parser.Node], delim: ref u8) ref u8! = {
    val out: mut ref u8 = ""
    for ty in types {
        val piece = render_type(ty)
        if str_eq(out, "") {
            out = piece
        } else {
            out = @fmt("{s}{s}{s}", {out, delim, piece})
        }
    }
    return out
}

fn render_variant_list(values: list[ref u8], delim: ref u8) ref u8! = {
    val out: mut ref u8 = ""
    for value in values {
        if str_eq(out, "") {
            out = value
        } else {
            out = @fmt("{s}{s}{s}", {out, delim, value})
        }
    }
    return out
}

fn render_tagged_variants(values: list[ref parser.Node]) ref u8! = {
    val out: mut ref u8 = ""
    for value in values {
        val types = value.d1 as list[ref parser.Node]
        val rendered_types = render_type_list(types, ", ")
        val piece: mut ref u8 = value.d0 as ref u8
        if !str_eq(rendered_types, "") {
            piece = @fmt("{s}({s})", {piece, rendered_types})
        } else {
            piece = @fmt("{s}()", {piece})
        }
        if str_eq(out, "") {
            out = piece
        } else {
            out = @fmt("{s} | {s}", {out, piece})
        }
    }
    return out
}

fn render_type_signature(node: ref parser.Node) ref u8! = {
    val public_prefix: mut ref u8 = ""
    if node.d0 != 0 { public_prefix = "pub " }
    if node.kind == parser.NK_TYPEDEF || node.kind == parser.NK_EXTERN_TYPE {
        val extern_prefix: mut ref u8 = ""
        if node.kind == parser.NK_EXTERN_TYPE { extern_prefix = "extern " }
        val fields = render_type_fields(node.d2 as list[ref parser.Node])
        return @fmt("{s}{s}type {s} = \\{ {s} \\}", {public_prefix, extern_prefix, node.d1 as ref u8, fields})
    }
    if node.kind == parser.NK_ENUMDEF {
        val variants = render_variant_list(node.d2 as list[ref u8], ", ")
        return @fmt("{s}enum {s} = \\{ {s} \\}", {public_prefix, node.d1 as ref u8, variants})
    }
    if node.kind == parser.NK_UNIONDEF {
        val variants = render_type_list(node.d2 as list[ref parser.Node], " | ")
        return @fmt("{s}union {s} = \\{ {s} \\}", {public_prefix, node.d1 as ref u8, variants})
    }
    if node.kind == parser.NK_TAGGED_UNIONDEF {
        val variants = render_tagged_variants(node.d2 as list[ref parser.Node])
        return @fmt("{s}union {s} = \\{ {s} \\}", {public_prefix, node.d1 as ref u8, variants})
    }
    return ""
}

fn render_fn_signature(node: ref parser.Node) ref u8! = {
    if node.kind == parser.NK_EXTERN_FN {
        val public_prefix: mut ref u8 = ""
        if node.d0 != 0 { public_prefix = "pub " }
        val conv: ref u8 = node.d3 as ref u8
        val params = render_fn_params(node.d4 as list[ref parser.Node])
        val variadic_suffix: mut ref u8 = ""
        if parser.extern_fn_is_variadic(node) {
            if str_eq(params, "") { variadic_suffix = "..." } else { variadic_suffix = ", ..." }
        }
        val header_mod: mut ref u8 = ""
        if parser.extern_fn_uses_header(node) { header_mod = ", header" }
        val unsafe_suffix: mut ref u8 = ""
        if parser.fn_is_unsafe(node) { unsafe_suffix = "!" }
        return @fmt("{s}extern ({s}{s}) fn {s}({s}{s}) {s}{s} = \"{s}\"", {
            public_prefix,
            conv,
            header_mod,
            node.d1 as ref u8,
            params,
            variadic_suffix,
            render_type(node.d5 as ref parser.Node),
            unsafe_suffix,
            node.d2 as ref u8
        })
    }
    val public_prefix: mut ref u8 = ""
    if node.d0 != 0 { public_prefix = "pub " }
    val receiver: mut ref u8 = ""
    if node.d1 != 0 as i64 {
        receiver = @fmt("({s}) ", {node.d1 as ref u8})
    }
    val type_params: mut ref u8 = ""
    if node.kind == parser.NK_GENERIC_FN {
        val parts = render_variant_list(parser.generic_fn_type_params(node), ", ")
        if !str_eq(parts, "") {
            type_params = @fmt("[{s}]", {parts})
        }
    }
    val unsafe_suffix: mut ref u8 = ""
    if node.kind == parser.NK_FN && parser.fn_is_unsafe(node) { unsafe_suffix = "!" }
    val params = render_fn_params(node.d3 as list[ref parser.Node])
    return @fmt("{s}fn {s}{s}{s}({s}) {s}{s}", {
        public_prefix,
        receiver,
        node.d2 as ref u8,
        type_params,
        params,
        render_type(node.d4 as ref parser.Node),
        unsafe_suffix
    })
}

fn entry_kind_name(kind: i64) ref u8 = {
    if kind == parser.NK_FN || kind == parser.NK_GENERIC_FN || kind == parser.NK_EXTERN_FN { return "function" }
    return "type"
}

fn entry_name(node: ref parser.Node) ref u8! = {
    if node.kind == parser.NK_EXTERN_FN { return node.d1 as ref u8 }
    if node.kind == parser.NK_FN || node.kind == parser.NK_GENERIC_FN { return node.d2 as ref u8 }
    return node.d1 as ref u8
}

fn entry_nav_name(node: ref parser.Node) ref u8! = {
    if ((node.kind == parser.NK_FN || node.kind == parser.NK_GENERIC_FN) && node.d1 != 0 as i64) {
        return @fmt("{s}.{s}", {node.d1 as ref u8, node.d2 as ref u8})
    }
    return entry_name(node)
}

fn add_entry(entries: mut list[ref DocEntry], node: ref parser.Node, doc_map: ref DocMap, availability: ref u8) void! = {
    val item: mut ref DocEntry = @alloc(@sizeof(DocEntry)) as ref DocEntry
    item.kind = node.kind
    item.line = node.line
    item.name = entry_name(node)
    item.nav_name = entry_nav_name(node)
    item.anchor = anchor_for(entry_kind_name(node.kind), item.name, node.line)
    item.docs = lookup_doc(doc_map, node.line)
    item.availability = availability
    item.node = node
    if node.kind == parser.NK_FN || node.kind == parser.NK_GENERIC_FN || node.kind == parser.NK_EXTERN_FN {
        item.signature = render_fn_signature(node)
    } else {
        item.signature = render_type_signature(node)
    }
    @append(entries, item)
}

fn combine_availability(a: ref u8, b: ref u8) ref u8! = {
    if str_eq(a, "") { return b }
    if str_eq(b, "") { return a }
    return @fmt("{s}, {s}", {a, b})
}

fn collect_entries(items: list[ref parser.Node], doc_map: ref DocMap, out: mut list[ref DocEntry], availability: ref u8) void! = {
    for item in items {
        if item.kind == parser.NK_WHEN_ITEMS {
            val branch = combine_availability(availability, @fmt("when {s}", {item.d0 as ref u8}))
            collect_entries(item.d1 as list[ref parser.Node], doc_map, out, branch)
            val or_branches = item.d2 as list[ref parser.Node]
            for branch_item in or_branches {
                val branch_avail = combine_availability(availability, @fmt("when {s}", {branch_item.d0 as ref u8}))
                collect_entries(branch_item.d1 as list[ref parser.Node], doc_map, out, branch_avail)
            }
            val otherwise_items = item.d3 as list[ref parser.Node]
            if @len(otherwise_items) as i64 > 0 {
                collect_entries(otherwise_items, doc_map, out, combine_availability(availability, "otherwise"))
            }
            continue
        }
        if item.kind == parser.NK_FN ||
           item.kind == parser.NK_GENERIC_FN ||
           item.kind == parser.NK_EXTERN_FN ||
           item.kind == parser.NK_TYPEDEF ||
           item.kind == parser.NK_EXTERN_TYPE ||
           item.kind == parser.NK_ENUMDEF ||
           item.kind == parser.NK_UNIONDEF ||
           item.kind == parser.NK_TAGGED_UNIONDEF {
            add_entry(out, item, doc_map, availability)
        }
    }
}

fn load_module(source_path: ref u8, rel_path: ref u8) ref DocModule! = {
    val src_opt = std.fs.read_all(source_path)
    val src: mut ref u8 = ""
    match src_opt {
        some text => { src = text as ref u8 }
        none => {
            std.stdio.print("error: could not read '{s}'\n", {source_path})
            std.os.exit(1)
        }
    }
    val toks_res = lexer.tokenize(src)
    val toks: mut list[ref lexer.Token] = []
    match toks_res {
        ok t => { toks = t }
        err e => {
            std.stdio.print("error: {s}: {s}\n", {source_path, e})
            std.os.exit(1)
        }
    }
    val parse_res = parser.parse_module(toks, source_path)
    val items: mut list[ref parser.Node] = []
    match parse_res {
        ok p => { items = p }
        err e => {
            std.stdio.print("error: {s}\n", {e})
            std.os.exit(1)
        }
    }
    val doc_map = extract_doc_map(src)
    val mod: mut ref DocModule = @alloc(@sizeof(DocModule)) as ref DocModule
    mod.source_path = source_path
    mod.rel_path = rel_path
    mod.module_name = strip_sx_ext(rel_path)
    mod.output_path = ""
    mod.is_root = false
    mod.entries = []
    collect_entries(items, doc_map, mod.entries, "")
    return mod
}

fn find_root_module(modules: list[ref DocModule], root_rel: ref u8) i64! = {
    val len: i64 = @len(modules) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val mod_opt = @get(modules, i as usize)
        if mod_opt is some v {
            val mod: ref DocModule = v as ref DocModule
            if str_eq(mod.rel_path, root_rel) { return i }
        }
        i++
    }
    return -1
}

fn module_output_path(module_name: ref u8, markdown: bool) ref u8! = {
    val ext: ref u8 = "html"
    if markdown { return @fmt("pages/{s}.md", {module_name}) }
    return @fmt("pages/{s}.{s}", {module_name, ext})
}

fn assign_output_paths(modules: list[ref DocModule], markdown: bool, root_idx: i64) void! = {
    val len: i64 = @len(modules) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val mod_opt = @get(modules, i as usize)
        match mod_opt {
            some v => {
                val mod: mut ref DocModule = v as ref DocModule
                if i == root_idx {
                    mod.is_root = true
                    if markdown { mod.output_path = "index.md" } else { mod.output_path = "index.html" }
                } else {
                    mod.output_path = module_output_path(mod.module_name, markdown)
                }
            }
            none => {}
        }
        i++
    }
}

fn html_escape(text: ref u8) ref u8! = {
    val sb: ref void = std.string.StringBuilder.new()
    val len: i64 = str.len_raw(text)
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = @load8(@ptradd(text as ref void, i))
        if c == 38 {
            std.string.StringBuilder.append_cstr(sb, "&amp;")
        } elif c == 60 {
            std.string.StringBuilder.append_cstr(sb, "&lt;")
        } elif c == 62 {
            std.string.StringBuilder.append_cstr(sb, "&gt;")
        } elif c == 34 {
            std.string.StringBuilder.append_cstr(sb, "&quot;")
        } else {
            std.string.StringBuilder.append_char(sb, c)
        }
        i++
    }
    val built = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn append_doc_html(sb: ref void, docs: ref u8) void! = {
    if str_eq(docs, "") { return }
    val len: i64 = str.len_raw(docs)
    val line_start: mut i64 = 0
    val i: mut i64 = 0
    val paragraph: mut ref u8 = ""
    std.string.StringBuilder.append_cstr(sb, "<div class=\"docs\">")
    for {
        if i >= len {
            val line = trim_ws(substr(docs, line_start, len - line_start))
            if str_eq(line, "") {
                if !str_eq(paragraph, "") {
                    std.string.StringBuilder.append_cstr(sb, "<p>")
                    std.string.StringBuilder.append_cstr(sb, html_escape(paragraph))
                    std.string.StringBuilder.append_cstr(sb, "</p>")
                    paragraph = ""
                }
            } else {
                if str_eq(paragraph, "") {
                    paragraph = line
                } else {
                    paragraph = @fmt("{s} {s}", {paragraph, line})
                }
            }
            break
        }
        val c: u8 = @load8(@ptradd(docs as ref void, i))
        if c == 10 {
            val line = trim_ws(substr(docs, line_start, i - line_start))
            if str_eq(line, "") {
                if !str_eq(paragraph, "") {
                    std.string.StringBuilder.append_cstr(sb, "<p>")
                    std.string.StringBuilder.append_cstr(sb, html_escape(paragraph))
                    std.string.StringBuilder.append_cstr(sb, "</p>")
                    paragraph = ""
                }
            } else {
                if str_eq(paragraph, "") {
                    paragraph = line
                } else {
                    paragraph = @fmt("{s} {s}", {paragraph, line})
                }
            }
            line_start = i + 1
        }
        i++
    }
    if !str_eq(paragraph, "") {
        std.string.StringBuilder.append_cstr(sb, "<p>")
        std.string.StringBuilder.append_cstr(sb, html_escape(paragraph))
        std.string.StringBuilder.append_cstr(sb, "</p>")
    }
    std.string.StringBuilder.append_cstr(sb, "</div>")
}

fn render_entry_details_html(sb: ref void, entry: ref DocEntry) void! = {
    val node = entry.node
    if node.kind == parser.NK_TYPEDEF || node.kind == parser.NK_EXTERN_TYPE {
        val fields = node.d2 as list[ref parser.Node]
        if @len(fields) as i64 > 0 {
            std.string.StringBuilder.append_cstr(sb, "<h4>Fields</h4><div class=\"details-table-wrap\"><table class=\"details-table\"><thead><tr><th>Name</th><th>Type</th></tr></thead><tbody>")
            for field in fields {
                val prefix: mut ref u8 = ""
                if field.d1 != 0 { prefix = "mut " }
                std.string.StringBuilder.append_cstr(sb, "<tr><td><code>")
                std.string.StringBuilder.append_cstr(sb, html_escape(field.d0 as ref u8))
                std.string.StringBuilder.append_cstr(sb, "</code></td><td><code>")
                std.string.StringBuilder.append_cstr(sb, html_escape(@fmt("{s}{s}", {prefix, render_type(field.d2 as ref parser.Node)})))
                std.string.StringBuilder.append_cstr(sb, "</code></td></tr>")
            }
            std.string.StringBuilder.append_cstr(sb, "</tbody></table></div>")
        }
    } elif node.kind == parser.NK_ENUMDEF {
        std.string.StringBuilder.append_cstr(sb, "<h4>Variants</h4><ul class=\"details\">")
        for variant in node.d2 as list[ref u8] {
            std.string.StringBuilder.append_cstr(sb, "<li><code>")
            std.string.StringBuilder.append_cstr(sb, html_escape(variant))
            std.string.StringBuilder.append_cstr(sb, "</code></li>")
        }
        std.string.StringBuilder.append_cstr(sb, "</ul>")
    } elif node.kind == parser.NK_UNIONDEF {
        std.string.StringBuilder.append_cstr(sb, "<h4>Variants</h4><ul class=\"details\">")
        for variant in node.d2 as list[ref parser.Node] {
            std.string.StringBuilder.append_cstr(sb, "<li><code>")
            std.string.StringBuilder.append_cstr(sb, html_escape(render_type(variant)))
            std.string.StringBuilder.append_cstr(sb, "</code></li>")
        }
        std.string.StringBuilder.append_cstr(sb, "</ul>")
    } elif node.kind == parser.NK_TAGGED_UNIONDEF {
        std.string.StringBuilder.append_cstr(sb, "<h4>Variants</h4><ul class=\"details\">")
        for variant in node.d2 as list[ref parser.Node] {
            val types = render_type_list(variant.d1 as list[ref parser.Node], ", ")
            val text: mut ref u8 = variant.d0 as ref u8
            if !str_eq(types, "") { text = @fmt("{s}({s})", {text, types}) } else { text = @fmt("{s}()", {text}) }
            std.string.StringBuilder.append_cstr(sb, "<li><code>")
            std.string.StringBuilder.append_cstr(sb, html_escape(text))
            std.string.StringBuilder.append_cstr(sb, "</code></li>")
        }
        std.string.StringBuilder.append_cstr(sb, "</ul>")
    }
}

fn render_entry_html(sb: ref void, entry: ref DocEntry) void! = {
    std.string.StringBuilder.append_cstr(sb, @fmt("<section class=\"entry\" id=\"{s}\" data-name=\"{s}\">", {entry.anchor, html_escape(entry.nav_name)}))
    std.string.StringBuilder.append_cstr(sb, @fmt("<div class=\"entry-header\"><h3>{s}</h3>", {html_escape(entry.name)}))
    if !str_eq(entry.availability, "") {
        std.string.StringBuilder.append_cstr(sb, @fmt("<span class=\"badge\">{s}</span>", {html_escape(entry.availability)}))
    }
    std.string.StringBuilder.append_cstr(sb, "</div>")
    std.string.StringBuilder.append_cstr(sb, "<pre><code class=\"language-spectre\">")
    std.string.StringBuilder.append_cstr(sb, html_escape(entry.signature))
    std.string.StringBuilder.append_cstr(sb, "</code></pre>")
    append_doc_html(sb, entry.docs)
    render_entry_details_html(sb, entry)
    std.string.StringBuilder.append_cstr(sb, "</section>")
}

fn depth_prefix(output_path: ref u8) ref u8! = {
    val len: i64 = str.len_raw(output_path)
    val depth: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= len { break }
        if @load8(@ptradd(output_path as ref void, i)) == 47 { depth++ }
        i++
    }
    val prefix: mut ref u8 = ""
    val j: mut i64 = 0
    for {
        if j >= depth { break }
        prefix = @fmt("{s}../", {prefix})
        j++
    }
    return prefix
}

fn href_from(current_output: ref u8, target_output: ref u8) ref u8! = {
    return @fmt("{s}{s}", {depth_prefix(safe_cstr(current_output)), safe_cstr(target_output)})
}

fn nav_key(label: ref u8, unique: ref u8) ref u8! = {
    return @fmt("{s}\n{s}", {safe_cstr(label), safe_cstr(unique)})
}

fn nav_key_tail(key: ref u8) ref u8! = {
    val len: i64 = str.len_raw(key)
    val i: mut i64 = 0
    for {
        if i >= len { break }
        if @load8(@ptradd(key as ref void, i)) == 10 {
            return substr(key, i + 1, len - i - 1)
        }
        i++
    }
    return ""
}

fn append_sorted_module_nav_html(sb: ref void, modules: list[ref DocModule], current: ref DocModule) void! = {
    val keys: mut list[ref u8] = []
    for mod in modules {
        @append(keys, nav_key(mod.module_name, mod.output_path))
    }
    val sorted = algo.sort_alpha(keys)
    for key in sorted {
        val target_output = nav_key_tail(key)
        for mod in modules {
            if !str_eq(mod.output_path, target_output) { continue }
            val cls: mut ref u8 = "nav-item"
            if str_eq(mod.rel_path, current.rel_path) { cls = "nav-item active" }
            std.string.StringBuilder.append_cstr(sb, @fmt("<a class=\"{s}\" href=\"{s}\">{s}</a>", {
                cls,
                href_from(current.output_path, mod.output_path),
                html_escape(safe_cstr(mod.module_name))
            }))
            break
        }
    }
}

fn append_sorted_entry_nav_html(sb: ref void, entries: list[ref DocEntry]) void! = {
    val keys: mut list[ref u8] = []
    for entry in entries {
        @append(keys, nav_key(entry.nav_name, entry.anchor))
    }
    val sorted = algo.sort_alpha(keys)
    for key in sorted {
        val target_anchor = nav_key_tail(key)
        for entry in entries {
            if !str_eq(entry.anchor, target_anchor) { continue }
            std.string.StringBuilder.append_cstr(sb, @fmt("<a class=\"nav-item\" href=\"#{s}\" data-name=\"{s}\">{s}</a>", {
                entry.anchor,
                html_escape(entry.nav_name),
                html_escape(entry.nav_name)
            }))
            break
        }
    }
}

fn append_nav_html(sb: ref void, modules: list[ref DocModule], current: ref DocModule) void! = {
    if @len(modules) as i64 > 1 {
        std.string.StringBuilder.append_cstr(sb, "<div class=\"nav-section\"><div class=\"nav-label\">Modules</div>")
        append_sorted_module_nav_html(sb, modules, current)
        std.string.StringBuilder.append_cstr(sb, "</div>")
    }
    if @len(current.entries) as i64 > 0 {
        std.string.StringBuilder.append_cstr(sb, "<div class=\"nav-section\"><div class=\"nav-label\">On this page</div>")
        append_sorted_entry_nav_html(sb, current.entries)
        std.string.StringBuilder.append_cstr(sb, "</div>")
    }
}

fn render_module_page_html(module: ref DocModule, modules: list[ref DocModule]) ref u8! = {
    val sb: ref void = std.string.StringBuilder.new()
    std.string.StringBuilder.append_cstr(sb, "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\">")
    std.string.StringBuilder.append_cstr(sb, @fmt("<title>{s} — Docs</title>", {html_escape(safe_cstr(module.module_name))}))
    std.string.StringBuilder.append_cstr(sb, "<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">")
    std.string.StringBuilder.append_cstr(sb, "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">")
    std.string.StringBuilder.append_cstr(sb, "<link href=\"https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">")
    std.string.StringBuilder.append_cstr(sb, "<style>")
    std.string.StringBuilder.append_cstr(sb,
