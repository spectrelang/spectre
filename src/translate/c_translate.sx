fn lookup_local_type(ctx: ref TranslationCtx, name: ref u8) option[ref u8] = {
    val len: i64 = @len(ctx.local_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val existing_opt = @get(ctx.local_names, i as usize)
        match existing_opt {
            some existing_name => {
                if string.rchar_cmp(existing_name as ref u8, name) == 0 {
                    val type_opt = @get(ctx.local_types, i as usize)
                    match type_opt {
                        some type_name => { return some type_name as ref u8 }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    val glen: i64 = @len(ctx.global_names) as i64
    val gi: mut i64 = 0
    for {
        if gi >= glen { break }
        val existing_opt2 = @get(ctx.global_names, gi as usize)
        match existing_opt2 {
            some existing_name2 => {
                if string.rchar_cmp(existing_name2 as ref u8, name) == 0 {
                    val type_opt2 = @get(ctx.global_types, gi as usize)
                    match type_opt2 {
                        some type_name2 => { return some type_name2 as ref u8 }
                        none => {}
                    }
                }
            }
            none => {}
        }
        gi++
    }
    return none
}

