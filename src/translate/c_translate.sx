val std = use("std")

pub val STOP_EOF       : i64 = 0
pub val STOP_ELSE      : i64 = 1
pub val STOP_ENDIF     : i64 = 2
pub val STOP_ELIF      : i64 = 3
pub val COND_NONE      : i64 = 0
pub val COND_WIN_TRUE  : i64 = 1
pub val COND_WIN_FALSE : i64 = 2

type BlockResult = {
    next_index: mut i64
    stop_kind:  mut i64
    stop_line:  mut ref char
}

type DeclInfo = {
    its_ok:    mut bool
    name:      mut ref char
    type_name: mut ref char
    type_src:  mut ref char
}

type LoweredExpr = {
    expr:    mut ref char
    changed: mut bool
}

type SwitchCase = {
    labels: mut list[ref char]
    body_lines: mut list[ref char]
    is_default: mut bool
}

type TranslationCtx = {
    defined_names: mut list[ref char]
    called_names:  mut list[ref char]
    extern_names:  mut list[ref char]
    fnptr_names:   mut list[ref char]
    translated_type_names: mut list[ref char]
    local_names:   mut list[ref char]
    local_types:   mut list[ref char]
    local_array_names: mut list[ref char]
    local_array_types: mut list[ref char]
    mutable_names: mut list[ref char]
    address_taken_names: mut list[ref char]
    flex_struct_names: mut list[ref char]
    flex_field_names:  mut list[ref char]
    flex_field_types:  mut list[ref char]
    temp_counter:  mut i64
}

fn make_block_result(next_index: i64, stop_kind: i64, stop_line: ref char) ref BlockResult = {
    val result: mut ref BlockResult = @alloc(@sizeof(BlockResult)) as ref BlockResult
    result.next_index = next_index
    result.stop_kind  = stop_kind
    result.stop_line  = stop_line
    return result
}

fn new_translation_ctx() ref TranslationCtx = {
    val ctx: mut ref TranslationCtx = @alloc(@sizeof(TranslationCtx)) as ref TranslationCtx
    ctx.defined_names = []
    ctx.called_names  = []
    ctx.extern_names  = []
    ctx.fnptr_names   = []
    ctx.translated_type_names = []
    ctx.local_names   = []
    ctx.local_types   = []
    ctx.local_array_names = []
    ctx.local_array_types = []
    ctx.mutable_names = []
    ctx.address_taken_names = []
    ctx.flex_struct_names = []
    ctx.flex_field_names  = []
    ctx.flex_field_types  = []
    ctx.temp_counter = 0
    return ctx
}

fn make_lowered_expr(expr: ref char, changed: bool) ref LoweredExpr = {
    val lowered: mut ref LoweredExpr = @alloc(@sizeof(LoweredExpr)) as ref LoweredExpr
    lowered.expr = expr
    lowered.changed = changed
    return lowered
}

fn make_switch_case() ref SwitchCase = {
    val item: mut ref SwitchCase = @alloc(@sizeof(SwitchCase)) as ref SwitchCase
    item.labels = []
    item.body_lines = []
    item.is_default = false
    return item
}

fn is_space(c: u8) bool = {
    return c == 32 || c == 9 || c == 10 || c == 13
}

fn is_ident_start(c: u8) bool = {
    return (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95
}

fn is_ident_part(c: u8) bool = {
    return is_ident_start(c) || (c >= 48 && c <= 57)
}

fn sanitize_identifier(name: ref char) ref char = {
    if std.string.rchar_cmp(name, "fn") == 0        { return "func" }
    if std.string.rchar_cmp(name, "val") == 0       { return "value" }
    if std.string.rchar_cmp(name, "mut") == 0       { return "mutable" }
    if std.string.rchar_cmp(name, "pub") == 0       { return "public" }
    if std.string.rchar_cmp(name, "type") == 0      { return "type_value" }
    if std.string.rchar_cmp(name, "pre") == 0       { return "precond" }
    if std.string.rchar_cmp(name, "post") == 0      { return "postcond" }
    if std.string.rchar_cmp(name, "return") == 0    { return "return_value" }
    if std.string.rchar_cmp(name, "if") == 0        { return "if_value" }
    if std.string.rchar_cmp(name, "else") == 0      { return "else_value" }
    if std.string.rchar_cmp(name, "elif") == 0      { return "elif_value" }
    if std.string.rchar_cmp(name, "trust") == 0     { return "trusted_value" }
    if std.string.rchar_cmp(name, "use") == 0       { return "used_value" }
    if std.string.rchar_cmp(name, "ref") == 0       { return "reference" }
    if std.string.rchar_cmp(name, "for") == 0       { return "loop_value" }
    if std.string.rchar_cmp(name, "in") == 0        { return "in_value" }
    if std.string.rchar_cmp(name, "some") == 0      { return "some_value" }
    if std.string.rchar_cmp(name, "none") == 0      { return "none_value" }
    if std.string.rchar_cmp(name, "ok") == 0        { return "ok_value" }
    if std.string.rchar_cmp(name, "err") == 0       { return "error_value" }
    if std.string.rchar_cmp(name, "match") == 0     { return "match_value" }
    if std.string.rchar_cmp(name, "true") == 0      { return "true_value" }
    if std.string.rchar_cmp(name, "false") == 0     { return "false_value" }
    if std.string.rchar_cmp(name, "defer") == 0     { return "deferred_value" }
    if std.string.rchar_cmp(name, "break") == 0     { return "break_value" }
    if std.string.rchar_cmp(name, "continue") == 0  { return "continue_value" }
    if std.string.rchar_cmp(name, "as") == 0        { return "as_value" }
    if std.string.rchar_cmp(name, "assert") == 0    { return "assert_value" }
    if std.string.rchar_cmp(name, "when") == 0      { return "when_value" }
    if std.string.rchar_cmp(name, "union") == 0     { return "union_value" }
    if std.string.rchar_cmp(name, "enum") == 0      { return "enum_value" }
    if std.string.rchar_cmp(name, "extern") == 0    { return "external_value" }
    if std.string.rchar_cmp(name, "link") == 0      { return "link_value" }
    if std.string.rchar_cmp(name, "guarded") == 0   { return "guarded_value" }
    if std.string.rchar_cmp(name, "not") == 0       { return "not_value" }
    if std.string.rchar_cmp(name, "test") == 0      { return "test_value" }
    if std.string.rchar_cmp(name, "guard") == 0     { return "guard_value" }
    if std.string.rchar_cmp(name, "invariant") == 0 { return "invariant_value" }
    return name
}

fn str_contains(haystack: ref char, needle: ref char) bool = {
    val hlen: i64 = std.string.len_raw(haystack)
    val nlen: i64 = std.string.len_raw(needle)
    if nlen == 0 { return true }
    if nlen > hlen { return false }
    val i: mut i64 = 0
    for {
        if i > hlen - nlen { break }
        val matched: mut bool = true
        val j: mut i64 = 0
        for {
            if j >= nlen { break }
            val a: u8 = trust @load8(@ptradd(haystack as ref void, i + j)) as u8
            val b: u8 = trust @load8(@ptradd(needle as ref void, j)) as u8
            if a != b {
                matched = false
                break
            }
            j++
        }
        if matched { return true }
        i++
    }
    return false
}

fn find_char(text: ref char, target: u8) i64 = {
    val len: i64 = std.string.len_raw(text)
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == target { return i }
        i++
    }
    return -1
}

fn find_last_char(text: ref char, target: u8) i64 = {
    val len: i64 = std.string.len_raw(text)
    val i: mut i64 = len - 1
    for {
        if i < 0 { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == target { return i }
        i--
    }
    return -1
}

fn trim_raw(text: ref char) ref char = {
    val len: i64 = std.string.len_raw(text)
    if len == 0 { return "" }
    val start: mut i64 = 0
    for {
        if start >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, start)) as u8
        if !is_space(c) { break }
        start++
    }
    val end: mut i64 = len - 1
    for {
        if end < start { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, end)) as u8
        if !is_space(c) { break }
        end--
    }
    if end < start { return "" }
    return std.string.substr(text, start, end - start + 1)
}

fn flatten_ws(text: ref char) ref char = {
    val sb: ref void = std.string.StringBuilder.new()
    val len: i64 = std.string.len_raw(text)
    val last_space: mut bool = true
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if is_space(c) {
            if !last_space {
                std.string.StringBuilder.append_char(sb, 32)
                last_space = true
            }
        } else {
            std.string.StringBuilder.append_char(sb, c)
            last_space = false
        }
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return trim_raw(std.string.cstr(built))
}

fn split_lines(text: ref char) list[ref char] = {
    val lines: mut list[ref char] = []
    val len: i64 = std.string.len_raw(text)
    val start: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i > len { break }
        val at_end: bool = i == len
        val c: mut u8 = 0
        if !at_end {
            c = trust @load8(@ptradd(text as ref void, i)) as u8
        }
        if at_end || c == 10 {
            val line_len: i64 = i - start
            val trimmed_len: mut i64 = line_len
            if trimmed_len > 0 {
                val last: u8 = trust @load8(@ptradd(text as ref void, start + trimmed_len - 1)) as u8
                if last == 13 { trimmed_len-- }
            }
            @append(lines, std.string.substr(text, start, trimmed_len))
            start = i + 1
        }
        i++
    }
    return lines
}

fn join_lines(lines: list[ref char], start: i64, end_exclusive: i64) ref char = {
    val sb: ref void = std.string.StringBuilder.new()
    val i: mut i64 = start
    for {
        if i >= end_exclusive { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                std.string.StringBuilder.append_cstr(sb, line_val as ref char)
                if i + 1 < end_exclusive {
                    std.string.StringBuilder.append_char(sb, 10)
                }
            }
            none => {}
        }
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn push_indent(sb: ref void, indent: i64) void = {
    val i: mut i64 = 0
    for {
        if i >= indent { break }
        std.string.StringBuilder.append_cstr(sb, "    ")
        i++
    }
}

fn append_line(sb: ref void, indent: i64, line: ref char) void = {
    push_indent(sb, indent)
    std.string.StringBuilder.append_cstr(sb, line)
    std.string.StringBuilder.append_char(sb, 10)
}

fn append_blank_line(sb: ref void) void = {
    std.string.StringBuilder.append_char(sb, 10)
}

fn append_comment_line(sb: ref void, indent: i64, line: ref char) void = {
    val trimmed: ref char = trim_raw(line)
    if std.string.rchar_cmp(trimmed, "") == 0 {
        append_blank_line(sb)
        return
    }
    push_indent(sb, indent)
    std.string.StringBuilder.append_cstr(sb, "// ")
    std.string.StringBuilder.append_cstr(sb, trimmed)
    std.string.StringBuilder.append_char(sb, 10)
}

fn list_contains(items: list[ref char], value: ref char) bool = {
    for item in items {
        if std.string.rchar_cmp(item, value) == 0 { return true }
    }
    return false
}

fn push_unique(items: mut list[ref char], value: ref char) void = {
    if list_contains(items, value) { return }
    @append(items, value)
}

fn clear_local_types(ctx: mut ref TranslationCtx) void = {
    ctx.local_names = []
    ctx.local_types = []
    ctx.local_array_names = []
    ctx.local_array_types = []
    ctx.mutable_names = []
    ctx.address_taken_names = []
    ctx.temp_counter = 0
}

fn remember_local_type(ctx: ref TranslationCtx, name: ref char, type_name: ref char) void = {
    val len: i64 = @len(ctx.local_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val existing_opt = @get(ctx.local_names, i as usize)
        match existing_opt {
            some existing_name => {
                if std.string.rchar_cmp(existing_name as ref char, name) == 0 {
                    @set(ctx.local_types, i as usize, type_name)
                    return
                }
            }
            none => {}
        }
        i++
    }
    @append(ctx.local_names, name)
    @append(ctx.local_types, type_name)
}

fn lookup_local_type(ctx: ref TranslationCtx, name: ref char) option[ref char] = {
    val len: i64 = @len(ctx.local_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val existing_opt = @get(ctx.local_names, i as usize)
        match existing_opt {
            some existing_name => {
                if std.string.rchar_cmp(existing_name as ref char, name) == 0 {
                    val type_opt = @get(ctx.local_types, i as usize)
                    match type_opt {
                        some type_name => { return some type_name as ref char }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return none
}

fn remember_local_array_type(ctx: ref TranslationCtx, name: ref char, array_size_expr: ref char) void = {
    val len: i64 = @len(ctx.local_array_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val existing_opt = @get(ctx.local_array_names, i as usize)
        match existing_opt {
            some existing_name => {
                if std.string.rchar_cmp(existing_name as ref char, name) == 0 {
                    @set(ctx.local_array_types, i as usize, array_size_expr)
                    return
                }
            }
            none => {}
        }
        i++
    }
    @append(ctx.local_array_names, name)
    @append(ctx.local_array_types, array_size_expr)
}

fn lookup_local_array_type(ctx: ref TranslationCtx, name: ref char) option[ref char] = {
    val len: i64 = @len(ctx.local_array_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val existing_opt = @get(ctx.local_array_names, i as usize)
        match existing_opt {
            some existing_name => {
                if std.string.rchar_cmp(existing_name as ref char, name) == 0 {
                    val type_opt = @get(ctx.local_array_types, i as usize)
                    match type_opt {
                        some type_name => { return some type_name as ref char }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return none
}

fn remember_flex_field(ctx: ref TranslationCtx, struct_name: ref char, field_name: ref char, field_type: ref char) void = {
    val len: i64 = @len(ctx.flex_struct_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(ctx.flex_struct_names, i as usize)
        val f_opt = @get(ctx.flex_field_names, i as usize)
        match s_opt {
            some s_name => {
                match f_opt {
                    some f_name => {
                        if std.string.rchar_cmp(s_name as ref char, struct_name) == 0
                            && std.string.rchar_cmp(f_name as ref char, field_name) == 0 {
                            @set(ctx.flex_field_types, i as usize, field_type)
                            return
                        }
                    }
                    none => {}
                }
            }
            none => {}
        }
        i++
    }
    @append(ctx.flex_struct_names, struct_name)
    @append(ctx.flex_field_names, field_name)
    @append(ctx.flex_field_types, field_type)
}

fn lookup_flex_field_name(ctx: ref TranslationCtx, struct_name: ref char) option[ref char] = {
    val len: i64 = @len(ctx.flex_struct_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(ctx.flex_struct_names, i as usize)
        match s_opt {
            some s_name => {
                if std.string.rchar_cmp(s_name as ref char, struct_name) == 0 {
                    val f_opt = @get(ctx.flex_field_names, i as usize)
                    match f_opt {
                        some f_name => { return some f_name as ref char }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return none
}

fn lookup_flex_field_type(ctx: ref TranslationCtx, struct_name: ref char) option[ref char] = {
    val len: i64 = @len(ctx.flex_struct_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(ctx.flex_struct_names, i as usize)
        match s_opt {
            some s_name => {
                if std.string.rchar_cmp(s_name as ref char, struct_name) == 0 {
                    val t_opt = @get(ctx.flex_field_types, i as usize)
                    match t_opt {
                        some t_name => { return some t_name as ref char }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return none
}

fn mark_mutable_name(ctx: ref TranslationCtx, name: ref char) void = {
    if std.string.rchar_cmp(name, "") == 0 { return }
    push_unique(ctx.mutable_names, name)
}

fn mark_address_taken_name(ctx: ref TranslationCtx, name: ref char) void = {
    if std.string.rchar_cmp(name, "") == 0 { return }
    push_unique(ctx.address_taken_names, name)
}

fn is_mutable_name(ctx: ref TranslationCtx, name: ref char) bool = {
    return list_contains(ctx.mutable_names, name)
}

fn is_address_taken_name(ctx: ref TranslationCtx, name: ref char) bool = {
    return list_contains(ctx.address_taken_names, name)
}

fn render_binding_type(ctx: ref TranslationCtx, name: ref char, type_name: ref char) ref char = {
    if !is_mutable_name(ctx, name) { return type_name }
    if std.string.rchar_starts_with(type_name, "mut ") { return type_name }
    return trust @fmt("mut {s}", {type_name})
}

fn render_mutable_type(type_name: ref char) ref char = {
    if std.string.rchar_starts_with(type_name, "mut ") { return type_name }
    return trust @fmt("mut {s}", {type_name})
}

fn is_array_type_name(type_name: ref char) bool = {
    return std.string.rchar_starts_with(type_name, "[")
}

fn array_type_close_index(type_name: ref char) i64 = {
    return find_char(type_name, 93)
}

fn array_type_len_expr(type_name: ref char) ref char = {
    val close_i: i64 = array_type_close_index(type_name)
    if close_i <= 1 { return "" }
    return std.string.substr(type_name, 1, close_i - 1)
}

fn array_type_elem(type_name: ref char) ref char = {
    val close_i: i64 = array_type_close_index(type_name)
    val len: i64 = std.string.len_raw(type_name)
    if close_i < 0 || close_i + 1 >= len { return "void" }
    return std.string.substr(type_name, close_i + 1, len - close_i - 1)
}

fn decay_array_type(type_name: ref char) ref char = {
    return trust @fmt("ref {s}", {array_type_elem(type_name)})
}

fn array_alloc_expr(type_name: ref char) ref char = {
    val len_expr: ref char = array_type_len_expr(type_name)
    val elem_type: ref char = array_type_elem(type_name)
    return trust @fmt("{s} * @sizeof({s})", {len_expr, elem_type})
}

fn extract_assignment_base(lhs: ref char) ref char = {
    val trimmed: ref char = trim_raw(lhs)
    if std.string.rchar_cmp(trimmed, "") == 0 { return "" }
    val lhs_arrow: ref char = replace_arrow_access(trimmed)
    val dot_i: i64 = find_char(lhs_arrow, 46)
    if dot_i > 0 {
        val base: ref char = trim_raw(std.string.substr(lhs_arrow, 0, dot_i))
        if is_ident_text(base) { return rewrite_identifiers(base) }
        return ""
    }
    if str_contains(lhs_arrow, "[") { return "" }
    if is_ident_text(trimmed) { return rewrite_identifiers(trimmed) }
    return ""
}

fn analyze_mutations_in_statement(ctx: ref TranslationCtx, line: ref char) void = {
    val stripped: ref char = strip_trailing_semicolon(trim_raw(line))
    if std.string.rchar_cmp(stripped, "") == 0 { return }
    val compound_i: i64 = find_top_level_compound_assign(stripped)
    if compound_i > 0 {
        mark_mutable_name(ctx, extract_assignment_base(std.string.substr(stripped, 0, compound_i)))
    }
    val assign_i: i64 = find_top_level_assign(stripped)
    if assign_i > 0 {
        val lhs: ref char = trim_raw(std.string.substr(stripped, 0, assign_i))
        val can_be_decl: bool = str_contains(lhs, " ") || str_contains(lhs, "*")
            || std.string.rchar_starts_with(lhs, "struct ") || std.string.rchar_starts_with(lhs, "enum ")
        if !can_be_decl {
            mark_mutable_name(ctx, extract_assignment_base(lhs))
        }
    }
    val len: i64 = std.string.len_raw(stripped)
    val i: mut i64 = 0
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(stripped as ref void, i)) as u8
        if in_string {
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 34 {
                in_string = false
            }
            i++
            continue
        }
        if in_char {
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 39 {
                in_char = false
            }
            i++
            continue
        }
        if c == 34 {
            in_string = true
            i++
            continue
        }
        if c == 39 {
            in_char = true
            i++
            continue
        }
        if is_ident_start(c) {
            val start_i: i64 = i
            i++
            for {
                if i >= len { break }
                val cc: u8 = trust @load8(@ptradd(stripped as ref void, i)) as u8
                if !is_ident_part(cc) { break }
                i++
            }
            val ident: ref char = std.string.substr(stripped, start_i, i - start_i)
            val j: mut i64 = i
            for {
                if j >= len { break }
                val ws: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                if !is_space(ws) { break }
                j++
            }
            if j + 1 < len {
                val c1: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                val c2: u8 = trust @load8(@ptradd(stripped as ref void, j + 1)) as u8
                if ((c1 == 43 && c2 == 43) || (c1 == 45 && c2 == 45)) {
                    mark_mutable_name(ctx, rewrite_identifiers(ident))
                }
            }
            continue
        }
        if i + 1 < len && ((c == 43 && (trust @load8(@ptradd(stripped as ref void, i + 1)) as u8) == 43)
            || (c == 45 && (trust @load8(@ptradd(stripped as ref void, i + 1)) as u8) == 45)) {
            val j: mut i64 = i + 2
            for {
                if j >= len { break }
                val ws: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                if !is_space(ws) { break }
                j++
            }
            if j < len {
                val first: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                if is_ident_start(first) {
                    val start_i2: i64 = j
                    j++
                    for {
                        if j >= len { break }
                        val cc2: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                        if !is_ident_part(cc2) { break }
                        j++
                    }
                    val ident2: ref char = std.string.substr(stripped, start_i2, j - start_i2)
                    mark_mutable_name(ctx, rewrite_identifiers(ident2))
                    i = j
                    continue
                }
            }
        }
        if c == 123 {
            val close_i: i64 = find_matching_delim(stripped, i, 123, 125)
            if close_i > i {
                val inner: ref char = std.string.substr(stripped, i + 1, close_i - i - 1)
                val statements = split_top_level(inner, 59)
                for stmt in statements {
                    analyze_mutations_in_statement(ctx, stmt)
                }
                i = close_i + 1
                continue
            }
        }
        i++
    }
}

fn fresh_temp_name(ctx: mut ref TranslationCtx) ref char = {
    val temp_name: ref char = trust @fmt("t{d}", {ctx.temp_counter})
    ctx.temp_counter = ctx.temp_counter + 1
    return temp_name
}

fn lookup_local_type_or_default(ctx: ref TranslationCtx, name: ref char) ref char = {
    match lookup_local_type(ctx, name) {
        some type_name => { return type_name as ref char }
        none => {}
    }
    return "i32"
}

fn emit_incdec_temp(ctx: ref TranslationCtx, raw_name: ref char, op: ref char, is_prefix: bool, indent: i64, out: ref void) ref char = {
    val name: ref char = rewrite_identifiers(raw_name)
    val temp_name: ref char = fresh_temp_name(ctx)
    val temp_type: ref char = lookup_local_type_or_default(ctx, name)
    remember_local_type(ctx, temp_name, temp_type)
    if is_prefix {
        append_line(out, indent, trust @fmt("{s} {s}= 1", {name, op}))
        append_line(out, indent, trust @fmt("val {s}: {s} = {s}", {temp_name, temp_type, name}))
    } else {
        append_line(out, indent, trust @fmt("val {s}: {s} = {s}", {temp_name, temp_type, name}))
        append_line(out, indent, trust @fmt("{s} {s}= 1", {name, op}))
    }
    return temp_name
}

fn emit_incdec_stmt(raw_name: ref char, op: ref char, indent: i64, out: ref void) void = {
    val name: ref char = rewrite_identifiers(raw_name)
    append_line(out, indent, trust @fmt("{s}{s}{s}", {name, op, op}))
}

fn lower_incdec_text(ctx: ref TranslationCtx, text: ref char, indent: i64, out: ref void) ref LoweredExpr = {
    val trimmed: ref char = strip_trailing_semicolon(text)
    val len: i64 = std.string.len_raw(trimmed)
    val sb: ref void = std.string.StringBuilder.new()
    val changed: mut bool = false
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if in_string {
            std.string.StringBuilder.append_char(sb, c)
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 34 {
                in_string = false
            }
            i++
            continue
        }
        if in_char {
            std.string.StringBuilder.append_char(sb, c)
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 39 {
                in_char = false
            }
            i++
            continue
        }
        if c == 34 {
            in_string = true
            std.string.StringBuilder.append_char(sb, c)
            i++
            continue
        }
        if c == 39 {
            in_char = true
            std.string.StringBuilder.append_char(sb, c)
            i++
            continue
        }
        if i + 1 < len {
            val next: u8 = trust @load8(@ptradd(trimmed as ref void, i + 1)) as u8
            if ((c == 43 && next == 43) || (c == 45 && next == 45)) {
                val op: mut ref char = "+"
                if c == 45 { op = "-" }
                val j: mut i64 = i + 2
                for {
                    if j >= len { break }
                    val ws: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                    if !is_space(ws) { break }
                    j++
                }
                if j < len {
                    val first: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                    if is_ident_start(first) {
                        val start_name: i64 = j
                        j++
                        for {
                            if j >= len { break }
                            val cc: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                            if !is_ident_part(cc) { break }
                            j++
                        }
                        val ident: ref char = std.string.substr(trimmed, start_name, j - start_name)
                        std.string.StringBuilder.append_cstr(sb, emit_incdec_temp(ctx, ident, op, true, indent, out))
                        changed = true
                        i = j
                        continue
                    }
                }
            }
        }
        if is_ident_start(c) {
            val start_name2: i64 = i
            i++
            for {
                if i >= len { break }
                val cc2: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                if !is_ident_part(cc2) { break }
                i++
            }
            val ident2: ref char = std.string.substr(trimmed, start_name2, i - start_name2)
            val j2: mut i64 = i
            for {
                if j2 >= len { break }
                val ws2: u8 = trust @load8(@ptradd(trimmed as ref void, j2)) as u8
                if !is_space(ws2) { break }
                j2++
            }
            if j2 + 1 < len {
                val c1: u8 = trust @load8(@ptradd(trimmed as ref void, j2)) as u8
                val c2: u8 = trust @load8(@ptradd(trimmed as ref void, j2 + 1)) as u8
                if ((c1 == 43 && c2 == 43) || (c1 == 45 && c2 == 45)) {
                    val op2: mut ref char = "+"
                    if c1 == 45 { op2 = "-" }
                    emit_incdec_stmt(ident2, op2, indent, out)
                    std.string.StringBuilder.append_cstr(sb, ident2)
                    changed = true
                    i = j2 + 2
                    continue
                }
            }
            std.string.StringBuilder.append_cstr(sb, ident2)
            continue
        }
        std.string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return make_lowered_expr(std.string.cstr(built), changed)
}

fn lower_incdec_expr(ctx: ref TranslationCtx, text: ref char, indent: i64, out: ref void) ref LoweredExpr = {
    val lowered_text: ref LoweredExpr = lower_incdec_text(ctx, text, indent, out)
    return make_lowered_expr(translate_expr_text(ctx, lowered_text.expr), lowered_text.changed)
}

fn body_has_explicit_return(lines: list[ref char]) bool = {
    for line in lines {
        val trimmed: ref char = trim_raw(line)
        if std.string.rchar_starts_with(trimmed, "return") { return true }
    }
    return false
}

fn contains_incdec_ops(text: ref char) bool = {
    return str_contains(text, "++") || str_contains(text, "--")
}

fn analyze_address_taken_in_statement(ctx: ref TranslationCtx, line: ref char) void = {
    val stripped: ref char = strip_trailing_semicolon(trim_raw(line))
    if std.string.rchar_cmp(stripped, "") == 0 { return }
    val len: i64 = std.string.len_raw(stripped)
    val i: mut i64 = 0
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(stripped as ref void, i)) as u8
        if in_string {
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 34 {
                in_string = false
            }
            i++
            continue
        }
        if in_char {
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 39 {
                in_char = false
            }
            i++
            continue
        }
        if c == 34 {
            in_string = true
            i++
            continue
        }
        if c == 39 {
            in_char = true
            i++
            continue
        }
        if c == 38 {
            val prev: mut u8 = 0
            val next: mut u8 = 0
            if i > 0 { prev = trust @load8(@ptradd(stripped as ref void, i - 1)) as u8 }
            if i + 1 < len { next = trust @load8(@ptradd(stripped as ref void, i + 1)) as u8 }
            if prev != 38 && next != 38 {
                val j: mut i64 = i + 1
                for {
                    if j >= len { break }
                    val ws: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                    if !is_space(ws) { break }
                    j++
                }
                if j < len {
                    val first: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                    if is_ident_start(first) {
                        val start_i: i64 = j
                        j++
                        for {
                            if j >= len { break }
                            val cc: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                            if !is_ident_part(cc) { break }
                            j++
                        }
                        mark_address_taken_name(ctx, rewrite_identifiers(std.string.substr(stripped, start_i, j - start_i)))
                        i = j
                        continue
                    }
                }
            }
        }
        i++
    }
}

fn analyze_mutable_names(ctx: ref TranslationCtx, lines: list[ref char], start: i64) void = {
    val len: i64 = @len(lines) as i64
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => { analyze_mutations_in_statement(ctx, line_val as ref char) }
            none => {}
        }
        i++
    }
}

fn analyze_address_taken_names(ctx: ref TranslationCtx, lines: list[ref char], start: i64) void = {
    val len: i64 = @len(lines) as i64
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => { analyze_address_taken_in_statement(ctx, line_val as ref char) }
            none => {}
        }
        i++
    }
}

fn is_system_include(line: ref char) bool = {
    val open_i: i64 = find_char(line, 60)
    val close_i: i64 = find_char(line, 62)
    return open_i >= 0 && close_i > open_i
}

fn strip_trailing_semicolon(text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    if len <= 0 { return trimmed }
    val last: u8 = trust @load8(@ptradd(trimmed as ref void, len - 1)) as u8
    if last == 59 {
        return trim_raw(std.string.substr(trimmed, 0, len - 1))
    }
    return trimmed
}

fn find_matching_delim(text: ref char, start: i64, open: u8, close: u8) i64 = {
    val len: i64 = std.string.len_raw(text)
    if start < 0 || start >= len { return -1 }
    val first: u8 = trust @load8(@ptradd(text as ref void, start)) as u8
    if first != open { return -1 }
    val depth: mut i64 = 0
    val i: mut i64 = start
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == open {
            depth++
        } elif c == close {
            depth--
            if depth == 0 { return i }
        }
        i++
    }
    return -1
}

fn strip_system_includes(text: ref char) ref char = {
    val lines = split_lines(text)
    val sb: ref void = std.string.StringBuilder.new()
    val first: mut bool = true
    for line in lines {
        val trimmed: ref char = trim_raw(line)
        if std.string.rchar_starts_with(trimmed, "#include") && is_system_include(trimmed) {
            continue
        }
        if !first {
            std.string.StringBuilder.append_char(sb, 10)
        }
        std.string.StringBuilder.append_cstr(sb, line)
        first = false
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn preprocess_source(path: ref char) option[ref char] = {
    val content_opt = std.fs.read_all(path)
    match content_opt {
        none => { return none }
        some content_val => {
            val original: ref char = content_val as ref char
            val filtered: ref char = strip_system_includes(original)
            val current_dir: ref char = std.path.dir(path)
            val temp_path: ref char = std.path.join(current_dir, "__spectre_translate_tmp__.c")
            val wrote: bool = std.fs.write_all(temp_path, filtered)
            if !wrote {
                return some original
            }
            val cmd: ref char = trust @fmt("cc -E -P {s} 2>/dev/null || clang -E -P {s} 2>/dev/null", {temp_path, temp_path})
            val result = std.os.exec(cmd)
            std.fs.delete(temp_path)
            match result {
                ok out => {
                    val text: ref char = std.string.cstr(out)
                    if std.string.rchar_cmp(trim_raw(text), "") == 0 {
                        return some filtered
                    }
                    return some text
                }
                err _ => {
                    return some filtered
                }
            }
        }
    }
}

fn extract_call_name(text: ref char) ref char = {
    val open_i: i64 = find_char(text, 40)
    if open_i <= 0 { return "" }
    return extract_identifier_before(text, open_i)
}

fn rewrite_identifiers(text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    val sb: ref void = std.string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if is_ident_start(c) {
            val start: i64 = i
            i++
            for {
                if i >= len { break }
                val cc: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                if !is_ident_part(cc) { break }
                i++
            }
            val ident: ref char = std.string.substr(trimmed, start, i - start)
            if std.string.rchar_cmp(ident, "NULL") == 0 {
                std.string.StringBuilder.append_cstr(sb, "0")
                continue
            }
            std.string.StringBuilder.append_cstr(sb, sanitize_identifier(ident))
            continue
        }
        std.string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn replace_arrow_access(text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    val sb: ref void = std.string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c == 45 && i + 1 < len {
            val next: u8 = trust @load8(@ptradd(trimmed as ref void, i + 1)) as u8
            if next == 62 {
                std.string.StringBuilder.append_char(sb, 46)
                i += 2
                continue
            }
        }
        std.string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn is_probable_c_type(text: ref char) bool = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    if len == 0 { return false }
    val first: u8 = trust @load8(@ptradd(trimmed as ref void, 0)) as u8
    if !is_ident_start(first) { return false }
    val saw_ident: mut bool = false
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if is_ident_part(c) {
            saw_ident = true
            i++
            continue
        }
        if is_space(c) || c == 42 {
            i++
            continue
        }
        return false
    }
    return saw_ident
}

fn is_ident_text(text: ref char) bool = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    if len == 0 { return false }
    val first: u8 = trust @load8(@ptradd(trimmed as ref void, 0)) as u8
    if !is_ident_start(first) { return false }
    val i: mut i64 = 1
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if !is_ident_part(c) { return false }
        i++
    }
    return true
}

fn parse_index_target(text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val open_i: i64 = find_char(trimmed, 91)
    val close_i: i64 = find_last_char(trimmed, 93)
    if open_i <= 0 || close_i <= open_i { return "" }
    return trim_raw(std.string.substr(trimmed, 0, open_i))
}

fn parse_index_expr(text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val open_i: i64 = find_char(trimmed, 91)
    val close_i: i64 = find_last_char(trimmed, 93)
    if open_i <= 0 || close_i <= open_i { return "" }
    return trim_raw(std.string.substr(trimmed, open_i + 1, close_i - open_i - 1))
}

fn replace_pointer_indexing(text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    val sb: ref void = std.string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if is_ident_start(c) {
            val start: i64 = i
            i++
            for {
                if i >= len { break }
                val cc: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                if !is_ident_part(cc) { break }
                i++
            }
            val chain_end: mut i64 = i
            for {
                if chain_end >= len { break }
                val dot: u8 = trust @load8(@ptradd(trimmed as ref void, chain_end)) as u8
                if dot != 46 || chain_end + 1 >= len { break }
                val next0: u8 = trust @load8(@ptradd(trimmed as ref void, chain_end + 1)) as u8
                if !is_ident_start(next0) { break }
                chain_end += 2
                for {
                    if chain_end >= len { break }
                    val cc_chain: u8 = trust @load8(@ptradd(trimmed as ref void, chain_end)) as u8
                    if !is_ident_part(cc_chain) { break }
                    chain_end++
                }
            }
            val ident: ref char = std.string.substr(trimmed, start, chain_end - start)
            i = chain_end
            if i < len {
                val next: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                if next == 91 {
                    val close_i: mut i64 = i + 1
                    val depth: mut i64 = 1
                    for {
                        if close_i >= len { break }
                        val bc: u8 = trust @load8(@ptradd(trimmed as ref void, close_i)) as u8
                        if bc == 91 { depth++ }
                        elif bc == 93 {
                            depth--
                            if depth == 0 { break }
                        }
                        close_i++
                    }
                    if close_i < len {
                        val inner: ref char = trim_raw(std.string.substr(trimmed, i + 1, close_i - i - 1))
                        std.string.StringBuilder.append_cstr(sb, trust @fmt("@load(@ptradd({s}, {s}))", {ident, inner}))
                        i = close_i + 1
                        continue
                    }
                }
            }
            std.string.StringBuilder.append_cstr(sb, ident)
            continue
        }
        std.string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn ensure_intrinsic_prefixes(text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    val names: list[ref char] = ["load", "store", "ptradd", "sizeof", "alloc", "free"]
    val sb: ref void = std.string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val matched: mut bool = false
        for name in names {
            val nlen: i64 = std.string.len_raw(name)
            if i + nlen + 1 > len { continue }
            val frag: ref char = std.string.substr(trimmed, i, nlen)
            if std.string.rchar_cmp(frag, name) != 0 { continue }
            val prev_ok: bool = i == 0 || !is_ident_part(trust @load8(@ptradd(trimmed as ref void, i - 1)) as u8)
            val nextc: u8 = trust @load8(@ptradd(trimmed as ref void, i + nlen)) as u8
            val already_intrinsic: bool = i > 0 && (trust @load8(@ptradd(trimmed as ref void, i - 1)) as u8) == 64
            if prev_ok && !already_intrinsic && nextc == 40 {
                std.string.StringBuilder.append_char(sb, 64)
                std.string.StringBuilder.append_cstr(sb, name)
                i += nlen
                matched = true
                break
            }
        }
        if matched { continue }
        std.string.StringBuilder.append_char(sb, trust @load8(@ptradd(trimmed as ref void, i)) as u8)
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn normalize_intrinsic_prefixes(text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    val names: list[ref char] = ["load", "store", "ptradd", "sizeof", "alloc", "free"]
    val sb: ref void = std.string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c == 64 {
            val at_start: i64 = i
            for {
                if i < len && (trust @load8(@ptradd(trimmed as ref void, i)) as u8) == 64 {
                    i++
                    continue
                }
                break
            }
            val matched: mut bool = false
            for name in names {
                val nlen: i64 = std.string.len_raw(name)
                if i + nlen > len { continue }
                val frag: ref char = std.string.substr(trimmed, i, nlen)
                if std.string.rchar_cmp(frag, name) != 0 { continue }
                if i + nlen < len && (trust @load8(@ptradd(trimmed as ref void, i + nlen)) as u8) == 40 {
                    std.string.StringBuilder.append_char(sb, 64)
                    std.string.StringBuilder.append_cstr(sb, name)
                    i += nlen
                    matched = true
                    break
                }
            }
            if matched { continue }
            val j: mut i64 = at_start
            for {
                if j >= i { break }
                std.string.StringBuilder.append_char(sb, 64)
                j++
            }
            continue
        }
        std.string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn scan_deref_operand_end(text: ref char, start: i64) i64 = {
    val len: i64 = std.string.len_raw(text)
    if start < 0 || start >= len { return start }
    val first: u8 = trust @load8(@ptradd(text as ref void, start)) as u8
    val i: mut i64 = start
    if is_ident_start(first) {
        i++
        for {
            if i >= len { break }
            val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
            if !is_ident_part(c) { break }
            i++
        }
    } elif first == 40 {
        val close_i: i64 = find_matching_delim(text, start, 40, 41)
        if close_i <= start { return start }
        i = close_i + 1
    } else {
        return start
    }
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == 91 {
            val close_b: i64 = find_matching_delim(text, i, 91, 93)
            if close_b <= i { break }
            i = close_b + 1
            continue
        }
        if c == 46 {
            val j: mut i64 = i + 1
            if j >= len { break }
            val first2: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
            if !is_ident_start(first2) { break }
            j++
            for {
                if j >= len { break }
                val cc: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
                if !is_ident_part(cc) { break }
                j++
            }
            i = j
            continue
        }
        if i + 1 < len {
            val c2: u8 = trust @load8(@ptradd(text as ref void, i + 1)) as u8
            if c == 45 && c2 == 62 {
                val j2: mut i64 = i + 2
                if j2 >= len { break }
                val first3: u8 = trust @load8(@ptradd(text as ref void, j2)) as u8
                if !is_ident_start(first3) { break }
                j2++
                for {
                    if j2 >= len { break }
                    val cc2: u8 = trust @load8(@ptradd(text as ref void, j2)) as u8
                    if !is_ident_part(cc2) { break }
                    j2++
                }
                i = j2
                continue
            }
            if ((c == 43 && c2 == 43) || (c == 45 && c2 == 45)) {
                i += 2
                continue
            }
        }
        break
    }
    return i
}

fn is_unary_deref_context(text: ref char, star_i: i64) bool = {
    val j: mut i64 = star_i - 1
    for {
        if j < 0 { return true }
        val c: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
        if !is_space(c) { break }
        j--
    }
    if j < 0 { return true }
    val prev: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
    if prev == 40 || prev == 44 || prev == 61 || prev == 33 || prev == 126 || prev == 63 || prev == 58 {
        return true
    }
    if prev == 43 || prev == 45 || prev == 42 || prev == 47 || prev == 37 || prev == 38 || prev == 124 || prev == 94 {
        return true
    }
    if prev == 60 || prev == 62 || prev == 123 || prev == 91 {
        return true
    }
    if is_ident_part(prev) {
        val end_i: i64 = j
        for {
            if j < 0 { break }
            val c2: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
            if !is_ident_part(c2) { break }
            j--
        }
        val word: ref char = std.string.substr(text, j + 1, end_i - j)
        if std.string.rchar_cmp(word, "return") == 0 { return true }
        if std.string.rchar_cmp(word, "if") == 0 { return true }
        if std.string.rchar_cmp(word, "while") == 0 { return true }
        if std.string.rchar_cmp(word, "for") == 0 { return true }
        if std.string.rchar_cmp(word, "case") == 0 { return true }
        if std.string.rchar_cmp(word, "switch") == 0 { return true }
        if std.string.rchar_cmp(word, "sizeof") == 0 { return true }
    }
    return false
}

fn translate_addr_deref_expr(ctx: ref TranslationCtx, text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    val sb: ref void = std.string.StringBuilder.new()
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if in_string {
            std.string.StringBuilder.append_char(sb, c)
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 34 {
                in_string = false
            }
            i++
            continue
        }
        if in_char {
            std.string.StringBuilder.append_char(sb, c)
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 39 {
                in_char = false
            }
            i++
            continue
        }
        if c == 34 {
            in_string = true
            std.string.StringBuilder.append_char(sb, c)
            i++
            continue
        }
        if c == 39 {
            in_char = true
            std.string.StringBuilder.append_char(sb, c)
            i++
            continue
        }
        if c == 40 {
            val close_group: i64 = find_matching_delim(trimmed, i, 40, 41)
            val j0: mut i64 = i + 1
            for {
                if j0 >= len { break }
                val ws0: u8 = trust @load8(@ptradd(trimmed as ref void, j0)) as u8
                if !is_space(ws0) { break }
                j0++
            }
            if j0 < len && (trust @load8(@ptradd(trimmed as ref void, j0)) as u8) == 42 && close_group > j0 {
                val inner_start: mut i64 = j0 + 1
                for {
                    if inner_start >= close_group { break }
                    val ws1: u8 = trust @load8(@ptradd(trimmed as ref void, inner_start)) as u8
                    if !is_space(ws1) { break }
                    inner_start++
                }
                val inner_text: ref char = trim_raw(std.string.substr(trimmed, inner_start, close_group - inner_start))
                val translated_inner: ref char = translate_addr_deref_expr(ctx, inner_text)
                val after_group: mut i64 = close_group + 1
                for {
                    if after_group >= len { break }
                    val ws2: u8 = trust @load8(@ptradd(trimmed as ref void, after_group)) as u8
                    if !is_space(ws2) { break }
                    after_group++
                }
                if after_group + 1 < len {
                    val p1: u8 = trust @load8(@ptradd(trimmed as ref void, after_group)) as u8
                    val p2: u8 = trust @load8(@ptradd(trimmed as ref void, after_group + 1)) as u8
                    if ((p1 == 43 && p2 == 43) || (p1 == 45 && p2 == 45)) {
                        std.string.StringBuilder.append_cstr(sb, trust @fmt("@deref({s}){c}{c}", {translated_inner, p1, p2}))
                        i = after_group + 2
                        continue
                    }
                }
                std.string.StringBuilder.append_cstr(sb, trust @fmt("@deref({s})", {translated_inner}))
                i = close_group + 1
                continue
            }
        }
        if c == 38 {
            val prev: mut u8 = 0
            val next: mut u8 = 0
            if i > 0 { prev = trust @load8(@ptradd(trimmed as ref void, i - 1)) as u8 }
            if i + 1 < len { next = trust @load8(@ptradd(trimmed as ref void, i + 1)) as u8 }
            if prev != 38 && next != 38 {
                val j: mut i64 = i + 1
                for {
                    if j >= len { break }
                    val ws: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                    if !is_space(ws) { break }
                    j++
                }
                if j < len {
                    val first: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                    if is_ident_start(first) {
                        val start_i: i64 = j
                        j++
                        for {
                            if j >= len { break }
                            val cc: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                            if !is_ident_part(cc) { break }
                            j++
                        }
                        std.string.StringBuilder.append_cstr(sb, rewrite_identifiers(std.string.substr(trimmed, start_i, j - start_i)))
                        i = j
                        continue
                    }
                }
            }
        }
        if c == 42 {
            if is_unary_deref_context(trimmed, i) {
                val j2: mut i64 = i + 1
                for {
                    if j2 >= len { break }
                    val ws2: u8 = trust @load8(@ptradd(trimmed as ref void, j2)) as u8
                    if !is_space(ws2) { break }
                    j2++
                }
                if j2 < len {
                    val operand_end: i64 = scan_deref_operand_end(trimmed, j2)
                    if operand_end > j2 {
                        val operand_text: ref char = translate_addr_deref_expr(ctx, trim_raw(std.string.substr(trimmed, j2, operand_end - j2)))
                        std.string.StringBuilder.append_cstr(sb, trust @fmt("@deref({s})", {operand_text}))
                        i = operand_end
                        continue
                    }
                }
            }
        }
        std.string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn is_printf_length_char(c: u8) bool = {
    return c == 104 || c == 108 || c == 122 || c == 116 || c == 106 || c == 76
}

fn map_printf_specifier(length_mod: ref char, spec: u8) ref char = {
    val is_size_mod: bool = std.string.rchar_cmp(length_mod, "z") == 0
        || std.string.rchar_cmp(length_mod, "t") == 0
        || std.string.rchar_cmp(length_mod, "j") == 0
    if is_size_mod && (spec == 105 || spec == 100 || spec == 117) { return "d" }
    if is_size_mod && (spec == 120 || spec == 88 || spec == 111) { return trust @fmt("{c}", {spec}) }
    if spec == 105 { return trust @fmt("{s}d", {length_mod}) }
    if spec == 100 { return trust @fmt("{s}d", {length_mod}) }
    if spec == 117 { return trust @fmt("{s}u", {length_mod}) }
    if spec == 120 { return trust @fmt("{s}x", {length_mod}) }
    if spec == 88 { return trust @fmt("{s}X", {length_mod}) }
    if spec == 111 { return trust @fmt("{s}o", {length_mod}) }
    if spec == 99 { return "c" }
    if spec == 115 { return "s" }
    if spec == 112 { return "p" }
    if spec == 102 || spec == 70 || spec == 101 || spec == 69 || spec == 103 || spec == 71 || spec == 97 || spec == 65 {
        return "f"
    }
    return trust @fmt("{c}", {spec})
}

fn translate_printf_format(text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    if len < 2 { return trimmed }
    val first: u8 = trust @load8(@ptradd(trimmed as ref void, 0)) as u8
    val last: u8 = trust @load8(@ptradd(trimmed as ref void, len - 1)) as u8
    if first != 34 || last != 34 { return trimmed }
    val sb: ref void = std.string.StringBuilder.new()
    std.string.StringBuilder.append_char(sb, 34)
    val i: mut i64 = 1
    for {
        if i >= len - 1 { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c == 37 && i + 1 < len - 1 {
            val next: u8 = trust @load8(@ptradd(trimmed as ref void, i + 1)) as u8
            if next == 37 {
                std.string.StringBuilder.append_char(sb, 37)
                i += 2
                continue
            }
            val spec_i: mut i64 = i + 1
            for {
                if spec_i >= len - 1 { break }
                val flag: u8 = trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8
                if flag != 45 && flag != 43 && flag != 32 && flag != 35 && flag != 48 {
                    break
                }
                spec_i++
            }
            for {
                if spec_i >= len - 1 { break }
                val width: u8 = trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8
                if !((width >= 48 && width <= 57) || width == 42) { break }
                spec_i++
            }
            if spec_i < len - 1 && (trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8) == 46 {
                spec_i++
                for {
                    if spec_i >= len - 1 { break }
                    val prec: u8 = trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8
                    if !((prec >= 48 && prec <= 57) || prec == 42) { break }
                    spec_i++
                }
            }
            val length_sb: ref void = std.string.StringBuilder.new()
            for {
                if spec_i >= len - 1 { break }
                val lm: u8 = trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8
                if !is_printf_length_char(lm) { break }
                std.string.StringBuilder.append_char(length_sb, lm)
                spec_i++
            }
            if spec_i < len - 1 {
                val spec: u8 = trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8
                val length_built: ref void = std.string.StringBuilder.build(length_sb)
                std.string.StringBuilder.free(length_sb)
                val mapped: ref char = map_printf_specifier(std.string.cstr(length_built), spec)
                std.string.StringBuilder.append_char(sb, 123)
                std.string.StringBuilder.append_cstr(sb, mapped)
                std.string.StringBuilder.append_char(sb, 125)
                i = spec_i + 1
                continue
            }
            std.string.StringBuilder.free(length_sb)
        }
        std.string.StringBuilder.append_char(sb, c)
        i++
    }
    std.string.StringBuilder.append_char(sb, 34)
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn translate_printf_call(ctx: ref TranslationCtx, args: list[ref char]) ref char = {
    val fmt_opt = @get(args, 0)
    val fmt_expr: mut ref char = "\"\""
    match fmt_opt {
        some fmt_val => { fmt_expr = translate_printf_format(translate_expr_text(ctx, fmt_val as ref char)) }
        none => {}
    }
    val sb: ref void = std.string.StringBuilder.new()
    std.string.StringBuilder.append_char(sb, 123)
    val first: mut bool = true
    val idx: mut i64 = 1
    val len: i64 = @len(args) as i64
    for {
        if idx >= len { break }
        val arg_opt = @get(args, idx as usize)
        match arg_opt {
            some arg_val => {
                if !first { std.string.StringBuilder.append_cstr(sb, ", ") }
                std.string.StringBuilder.append_cstr(sb, translate_expr_text(ctx, arg_val as ref char))
                first = false
            }
            none => {}
        }
        idx++
    }
    std.string.StringBuilder.append_char(sb, 125)
    val args_built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return trust @fmt("@printf({s}, {s})", {fmt_expr, std.string.cstr(args_built)})
}

fn transform_call_expr(ctx: ref TranslationCtx, text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val open_i: i64 = find_char(trimmed, 40)
    val close_i: i64 = find_matching_delim(trimmed, open_i, 40, 41)
    if open_i <= 0 || close_i <= open_i { return trimmed }
    val call_name: ref char = extract_identifier_before(trimmed, open_i)
    if std.string.rchar_cmp(call_name, "") == 0 { return trimmed }
    val call_start: i64 = open_i - std.string.len_raw(call_name)
    if call_start < 0 { return trimmed }
    val prefix_text: ref char = trim_raw(std.string.substr(trimmed, 0, call_start))
    if !(std.string.rchar_cmp(prefix_text, "") == 0 || std.string.rchar_cmp(prefix_text, "@") == 0) {
        return trimmed
    }
    if close_i != std.string.len_raw(trimmed) - 1 { return trimmed }
    val intrinsic_prefix: mut ref char = ""
    if std.string.rchar_starts_with(trimmed, "@") { intrinsic_prefix = "@" }
    val args_raw: ref char = trim_raw(std.string.substr(trimmed, open_i + 1, close_i - open_i - 1))
    val args = split_top_level(args_raw, 44)
    if std.string.rchar_cmp(call_name, "printf") == 0 {
        return translate_printf_call(ctx, args)
    }
    val sb: ref void = std.string.StringBuilder.new()
    val first: mut bool = true
    for arg in args {
        val arg_trimmed: ref char = trim_raw(arg)
        if !first { std.string.StringBuilder.append_cstr(sb, ", ") }
        if is_ident_text(arg_trimmed) && list_contains(ctx.defined_names, arg_trimmed) {
            std.string.StringBuilder.append_cstr(sb, trust @fmt("@addr({s})", {arg_trimmed}))
        } else {
            std.string.StringBuilder.append_cstr(sb, translate_expr_text(ctx, arg_trimmed))
        }
        first = false
    }
    val args_built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    val args_text: ref char = std.string.cstr(args_built)
    if std.string.rchar_cmp(call_name, "sizeof") == 0 {
        return trust @fmt("@sizeof({s})", {args_text})
    }
    if std.string.rchar_cmp(call_name, "malloc") == 0 {
        return trust @fmt("@alloc({s})", {args_text})
    }
    if list_contains(ctx.fnptr_names, call_name) {
        return trust @fmt("@call({s}, {s})", {call_name, args_text})
    }
    return trust @fmt("{s}{s}({s})", {intrinsic_prefix, call_name, args_text})
}

fn find_top_level_ternary(text: ref char) i64 = {
    val len: i64 = std.string.len_raw(text)
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == 40 { paren++ }
        elif c == 41 && paren > 0 { paren-- }
        elif c == 123 { brace++ }
        elif c == 125 && brace > 0 { brace-- }
        elif c == 91 { bracket++ }
        elif c == 93 && bracket > 0 { bracket-- }
        elif c == 63 && paren == 0 && brace == 0 && bracket == 0 {
            return i
        }
        i++
    }
    return -1
}

fn find_matching_colon_for_ternary(text: ref char, q_index: i64) i64 = {
    val len: i64 = std.string.len_raw(text)
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val ternary_depth: mut i64 = 0
    val i: mut i64 = q_index + 1
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == 40 { paren++ }
        elif c == 41 && paren > 0 { paren-- }
        elif c == 123 { brace++ }
        elif c == 125 && brace > 0 { brace-- }
        elif c == 91 { bracket++ }
        elif c == 93 && bracket > 0 { bracket-- }
        elif c == 63 && paren == 0 && brace == 0 && bracket == 0 {
            ternary_depth++
        } elif c == 58 && paren == 0 && brace == 0 && bracket == 0 {
            if ternary_depth == 0 { return i }
            ternary_depth--
        }
        i++
    }
    return -1
}

fn is_wrapped_in_parens(text: ref char) bool = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    if len < 2 { return false }
    val first: u8 = trust @load8(@ptradd(trimmed as ref void, 0)) as u8
    val last: u8 = trust @load8(@ptradd(trimmed as ref void, len - 1)) as u8
    if first != 40 || last != 41 { return false }
    val depth: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c == 40 { depth++ }
        elif c == 41 {
            depth--
            if depth == 0 && i != len - 1 {
                return false
            }
        }
        i++
    }
    return depth == 0
}

fn unwrap_outer_parens(text: ref char) ref char = {
    val current: mut ref char = trim_raw(text)
    for {
        if !is_wrapped_in_parens(current) { break }
        val len: i64 = std.string.len_raw(current)
        current = trim_raw(std.string.substr(current, 1, len - 2))
    }
    return current
}

fn collect_brace_block(lines: list[ref char], start: i64) ref BlockResult = {
    val len: i64 = @len(lines) as i64
    val brace_depth: mut i64 = 0
    val seen_open: mut bool = false
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                val line: ref char = line_val as ref char
                val llen: i64 = std.string.len_raw(line)
                val j: mut i64 = 0
                for {
                    if j >= llen { break }
                    val c: u8 = trust @load8(@ptradd(line as ref void, j)) as u8
                    if c == 123 {
                        brace_depth++
                        seen_open = true
                    } elif c == 125 && brace_depth > 0 {
                        brace_depth--
                        if seen_open && brace_depth == 0 {
                            return make_block_result(i + 1, STOP_EOF, "")
                        }
                    }
                    j++
                }
            }
            none => {}
        }
        i++
    }
    return make_block_result(i, STOP_EOF, "")
}

fn translate_for_init(text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val assign_i: i64 = find_top_level_assign(trimmed)
    if assign_i <= 0 { return trimmed }
    val lhs: ref char = trim_raw(std.string.substr(trimmed, 0, assign_i))
    val rhs: ref char = trim_raw(std.string.substr(trimmed, assign_i + 1, std.string.len_raw(trimmed) - assign_i - 1))
    val decl: ref DeclInfo = parse_named_decl(lhs, "")
    if decl.its_ok && std.string.rchar_cmp(decl.name, "") != 0 && std.string.rchar_cmp(trim_raw(decl.type_src), "") != 0 {
        return trust @fmt("{s} = {s}", {decl.name, rhs})
    }
    return trimmed
}

fn translate_for_loop(lines: list[ref char], start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val span: ref BlockResult = collect_brace_block(lines, start)
    val full_text: ref char = join_lines(lines, start, span.next_index)
    val open_i: i64 = find_char(full_text, 40)
    val close_i: i64 = find_char(full_text, 41)
    val brace_i: i64 = find_char(full_text, 123)
    if open_i < 0 || close_i <= open_i || brace_i < 0 {
        append_comment_line(out, indent, trim_raw(full_text))
        return span
    }
    val inside: ref char = trim_raw(std.string.substr(full_text, open_i + 1, close_i - open_i - 1))
    val parts = split_top_level(inside, 59)
    val init: mut ref char = ""
    val cond: mut ref char = ""
    val postc: mut ref char = ""
    val p0 = @get(parts, 0)
    match p0 { some v => { init = translate_for_init(v as ref char) } none => {} }
    val p1 = @get(parts, 1)
    match p1 { some v => { cond = trim_raw(v as ref char) } none => {} }
    val p2 = @get(parts, 2)
    match p2 { some v => { postc = trim_raw(v as ref char) } none => {} }
    append_open_block_line(out, indent, trust @fmt("for ({s}; {s}; {s}) ", {init, cond, postc}))
    val body_text: ref char = std.string.substr(full_text, brace_i + 1, find_last_char(full_text, 125) - brace_i - 1)
    val body_lines = split_lines(body_text)
    translate_body_lines(body_lines, "", 0, indent + 1, out, ctx)
    append_line(out, indent, "}")
    return span
}

fn translate_while_loop(lines: list[ref char], start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val span: ref BlockResult = collect_brace_block(lines, start)
    val full_text: ref char = join_lines(lines, start, span.next_index)
    val open_i: i64 = find_char(full_text, 40)
    val close_i: i64 = find_matching_delim(full_text, open_i, 40, 41)
    val brace_i: i64 = find_char(full_text, 123)
    if open_i < 0 || close_i <= open_i || brace_i < 0 {
        append_comment_line(out, indent, trim_raw(full_text))
        return span
    }
    val cond_src: ref char = trim_raw(std.string.substr(full_text, open_i + 1, close_i - open_i - 1))
    val cond_out: ref void = std.string.StringBuilder.new()
    val cond_text: ref char = translate_condition_text(ctx, cond_src, indent + 1, cond_out)
    append_line(out, indent, "for {")
    append_builder(out, cond_out)
    append_line(out, indent + 1, trust @fmt("if ({s}) {", {cond_text}))
    val body_text: ref char = std.string.substr(full_text, brace_i + 1, find_last_char(full_text, 125) - brace_i - 1)
    val body_lines = split_lines(body_text)
    translate_body_lines(body_lines, "", 0, indent + 2, out, ctx)
    append_line(out, indent + 1, "} else {")
    append_line(out, indent + 2, "break")
    append_line(out, indent + 1, "}")
    append_line(out, indent, "}")
    return span
}

fn translate_brace_block(lines: list[ref char], start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val span: ref BlockResult = collect_brace_block(lines, start)
    val full_text: ref char = join_lines(lines, start, span.next_index)
    val open_i: i64 = find_char(full_text, 123)
    val close_i: i64 = find_last_char(full_text, 125)
    if open_i < 0 || close_i <= open_i {
        append_comment_line(out, indent, trim_raw(full_text))
        return span
    }
    val body_text: ref char = std.string.substr(full_text, open_i + 1, close_i - open_i - 1)
    val body_lines = split_lines(body_text)
    translate_body_lines(body_lines, "", 0, indent, out, ctx)
    return span
}

fn translate_inline_statement(ctx: ref TranslationCtx, text: ref char, indent: i64, out: ref void) void = {
    val trimmed: ref char = strip_trailing_semicolon(trim_raw(text))
    if std.string.rchar_cmp(trimmed, "") == 0 { return }
    if translate_body_statement(ctx, trimmed, indent, out) { return }
    append_comment_line(out, indent, trimmed)
}

fn translate_if_text(lines: list[ref char], current_dir: ref char, line_index: i64, if_text: ref char, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val trimmed: ref char = trim_raw(if_text)
    val open_i: i64 = find_char(trimmed, 40)
    val close_i: i64 = find_matching_delim(trimmed, open_i, 40, 41)
    if open_i < 0 || close_i <= open_i {
        append_comment_line(out, indent, trimmed)
        return make_block_result(line_index + 1, STOP_EOF, "")
    }
    val cond_src: ref char = trim_raw(std.string.substr(trimmed, open_i + 1, close_i - open_i - 1))
    val cond_text: ref char = translate_condition_text(ctx, cond_src, indent, out)
    val tail: ref char = trim_raw(std.string.substr(trimmed, close_i + 1, std.string.len_raw(trimmed) - close_i - 1))
    append_line(out, indent, trust @fmt("if ({s}) {", {cond_text}))
    val next_i: mut i64 = line_index + 1
    if std.string.rchar_cmp(tail, "") != 0 {
        if std.string.rchar_starts_with(tail, "{") {
            val then_span: ref BlockResult = translate_brace_block(lines, line_index, indent + 1, out, ctx)
            next_i = then_span.next_index
        } else {
            translate_inline_statement(ctx, tail, indent + 1, out)
        }
    } else {
        val next_body_i: i64 = next_significant_line(lines, line_index + 1)
        if next_body_i >= 0 {
            val next_opt = @get(lines, next_body_i as usize)
            match next_opt {
                some next_line => {
                    val next_trimmed: ref char = trim_raw(next_line as ref char)
                    if std.string.rchar_starts_with(next_trimmed, "{") {
                        val then_span2: ref BlockResult = translate_brace_block(lines, next_body_i, indent + 1, out, ctx)
                        next_i = then_span2.next_index
                    } else {
                        val stmt_result: ref BlockResult = translate_statement_at(lines, current_dir, next_body_i, indent + 1, out, ctx)
                        next_i = stmt_result.next_index
                    }
                }
                none => {}
            }
        }
    }
    val else_i: i64 = next_significant_line(lines, next_i)
    if else_i >= 0 {
        val else_opt = @get(lines, else_i as usize)
        match else_opt {
            some else_line => {
                val else_trimmed: ref char = trim_raw(else_line as ref char)
                if std.string.rchar_starts_with(else_trimmed, "else") {
                    val else_tail: ref char = trim_raw(std.string.substr(else_trimmed, 4, std.string.len_raw(else_trimmed) - 4))
                    append_line(out, indent, "} else {")
                    if std.string.rchar_starts_with(else_tail, "if (") {
                        val nested_result: ref BlockResult = translate_if_text(lines, current_dir, else_i, else_tail, indent + 1, out, ctx)
                        append_line(out, indent, "}")
                        return make_block_result(nested_result.next_index, STOP_EOF, "")
                    }
                    if std.string.rchar_cmp(else_tail, "") != 0 {
                        if std.string.rchar_starts_with(else_tail, "{") {
                            val else_span: ref BlockResult = translate_brace_block(lines, else_i, indent + 1, out, ctx)
                            append_line(out, indent, "}")
                            return make_block_result(else_span.next_index, STOP_EOF, "")
                        }
                        translate_inline_statement(ctx, else_tail, indent + 1, out)
                        append_line(out, indent, "}")
                        return make_block_result(else_i + 1, STOP_EOF, "")
                    }
                    val else_body_i: i64 = next_significant_line(lines, else_i + 1)
                    if else_body_i >= 0 {
                        val else_body_opt = @get(lines, else_body_i as usize)
                        match else_body_opt {
                            some else_body_line => {
                                val else_body_trimmed: ref char = trim_raw(else_body_line as ref char)
                                if std.string.rchar_starts_with(else_body_trimmed, "{") {
                                    val else_span2: ref BlockResult = translate_brace_block(lines, else_body_i, indent + 1, out, ctx)
                                    append_line(out, indent, "}")
                                    return make_block_result(else_span2.next_index, STOP_EOF, "")
                                }
                                val else_stmt_result: ref BlockResult = translate_statement_at(lines, current_dir, else_body_i, indent + 1, out, ctx)
                                append_line(out, indent, "}")
                                return make_block_result(else_stmt_result.next_index, STOP_EOF, "")
                            }
                            none => {}
                        }
                    }
                    append_line(out, indent, "}")
                    return make_block_result(else_i + 1, STOP_EOF, "")
                }
            }
            none => {}
        }
    }
    append_line(out, indent, "}")
    return make_block_result(next_i, STOP_EOF, "")
}

fn translate_if_statement(lines: list[ref char], current_dir: ref char, start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val line_opt = @get(lines, start as usize)
    match line_opt {
        some line_val => { return translate_if_text(lines, current_dir, start, trim_raw(line_val as ref char), indent, out, ctx) }
        none => { return make_block_result(start + 1, STOP_EOF, "") }
    }
}

fn is_switch_break_line(text: ref char) bool = {
    val trimmed: ref char = strip_trailing_semicolon(trim_raw(text))
    return std.string.rchar_cmp(trimmed, "break") == 0
}

fn render_switch_case_condition(ctx: ref TranslationCtx, switch_expr: ref char, labels: list[ref char]) ref char = {
    val sb: ref void = std.string.StringBuilder.new()
    val first: mut bool = true
    for label in labels {
        if !first { std.string.StringBuilder.append_cstr(sb, " || ") }
        std.string.StringBuilder.append_cstr(sb, trust @fmt("{s} == {s}", {switch_expr, translate_expr_text(ctx, label)}))
        first = false
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn translate_switch_statement(lines: list[ref char], start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val line_opt = @get(lines, start as usize)
    match line_opt {
        none => { return make_block_result(start + 1, STOP_EOF, "") }
        some line_val => {
            val line: ref char = trim_raw(line_val as ref char)
            val open_i: i64 = find_char(line, 40)
            val close_i: i64 = find_matching_delim(line, open_i, 40, 41)
            if open_i < 0 || close_i <= open_i {
                append_comment_line(out, indent, line)
                return make_block_result(start + 1, STOP_EOF, "")
            }
            val switch_expr: ref char = lower_incdec_expr(ctx, trim_raw(std.string.substr(line, open_i + 1, close_i - open_i - 1)), indent, out).expr
            val body_start: mut i64 = start
            val tail: ref char = trim_raw(std.string.substr(line, close_i + 1, std.string.len_raw(line) - close_i - 1))
            if !std.string.rchar_starts_with(tail, "{") {
                body_start = next_significant_line(lines, start + 1)
            }
            if body_start < 0 {
                append_comment_line(out, indent, line)
                return make_block_result(start + 1, STOP_EOF, "")
            }
            val span: ref BlockResult = collect_brace_block(lines, body_start)
            val full_text: ref char = join_lines(lines, body_start, span.next_index)
            val brace_i: i64 = find_char(full_text, 123)
            val close_b: i64 = find_last_char(full_text, 125)
            if brace_i < 0 || close_b <= brace_i {
                append_comment_line(out, indent, line)
                return span
            }
            val body_text: ref char = std.string.substr(full_text, brace_i + 1, close_b - brace_i - 1)
            val body_lines = split_lines(body_text)
            val cases: mut list[ref SwitchCase] = []
            val current: mut ref SwitchCase = 0 as ref SwitchCase
            for raw_line in body_lines {
                val trimmed: ref char = trim_raw(raw_line)
                if std.string.rchar_cmp(trimmed, "") == 0 {
                    if (current != 0 as ref SwitchCase) {
                        if ((@len(current.body_lines) as i64) > 0) {
                            @append(current.body_lines, raw_line)
                        }
                    }
                    continue
                }
                if std.string.rchar_starts_with(trimmed, "case ") {
                    val colon_i: i64 = find_char(trimmed, 58)
                    if colon_i > 5 {
                        val label: ref char = trim_raw(std.string.substr(trimmed, 5, colon_i - 5))
                        val tail2: ref char = trim_raw(std.string.substr(trimmed, colon_i + 1, std.string.len_raw(trimmed) - colon_i - 1))
                        if current != 0 as ref SwitchCase {
                            if !current.is_default && (@len(current.body_lines) as i64) == 0 {
                                @append(current.labels, label)
                                if std.string.rchar_cmp(tail2, "") != 0 && !is_switch_break_line(tail2) {
                                    @append(current.body_lines, tail2)
                                }
                                continue
                            }
                        }
                        if current != 0 as ref SwitchCase { @append(cases, current) }
                        current = make_switch_case()
                        @append(current.labels, label)
                        if std.string.rchar_cmp(tail2, "") != 0 && !is_switch_break_line(tail2) {
                            @append(current.body_lines, tail2)
                        }
                        continue
                    }
                }
                if std.string.rchar_starts_with(trimmed, "default:") {
                    val tail3: ref char = trim_raw(std.string.substr(trimmed, 8, std.string.len_raw(trimmed) - 8))
                    if current != 0 as ref SwitchCase { @append(cases, current) }
                    current = make_switch_case()
                    current.is_default = true
                    if std.string.rchar_cmp(tail3, "") != 0 && !is_switch_break_line(tail3) {
                        @append(current.body_lines, tail3)
                    }
                    continue
                }
                if current != 0 as ref SwitchCase {
                    if is_switch_break_line(trimmed) { continue }
                    @append(current.body_lines, raw_line)
                }
            }
            if current != 0 as ref SwitchCase { @append(cases, current) }
            val emitted_any: mut bool = false
            for case_item in cases {
                if case_item.is_default {
                    if emitted_any {
                        append_line(out, indent, "} else {")
                    } else {
                        append_line(out, indent, "if (true) {")
                    }
                } else {
                    val cond_text: ref char = render_switch_case_condition(ctx, switch_expr, case_item.labels)
                    if emitted_any {
                        append_line(out, indent, trust @fmt("} elif ({s}) {", {cond_text}))
                    } else {
                        append_line(out, indent, trust @fmt("if ({s}) {", {cond_text}))
                    }
                }
                translate_body_lines(case_item.body_lines, "", 0, indent + 1, out, ctx)
                emitted_any = true
            }
            if emitted_any {
                append_line(out, indent, "}")
            } else {
                append_comment_line(out, indent, line)
            }
            return span
        }
    }
}

fn translate_do_while_loop(lines: list[ref char], start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val line_opt = @get(lines, start as usize)
    match line_opt {
        none => { return make_block_result(start + 1, STOP_EOF, "") }
        some line_val => {
            val line: ref char = trim_raw(line_val as ref char)
            val body_start: mut i64 = start
            val tail_after_do: ref char = trim_raw(std.string.substr(line, 2, std.string.len_raw(line) - 2))
            if !std.string.rchar_starts_with(tail_after_do, "{") {
                body_start = next_significant_line(lines, start + 1)
            }
            if body_start < 0 {
                append_comment_line(out, indent, line)
                return make_block_result(start + 1, STOP_EOF, "")
            }
            val body_span: ref BlockResult = collect_brace_block(lines, body_start)
            val body_full: ref char = join_lines(lines, body_start, body_span.next_index)
            val brace_i: i64 = find_char(body_full, 123)
            val close_b: i64 = find_last_char(body_full, 125)
            if brace_i < 0 || close_b <= brace_i {
                append_comment_line(out, indent, line)
                return body_span
            }
            val while_line: mut ref char = trim_raw(std.string.substr(body_full, close_b + 1, std.string.len_raw(body_full) - close_b - 1))
            val next_i: mut i64 = body_span.next_index
            if !std.string.rchar_starts_with(while_line, "while (") {
                val while_i: i64 = next_significant_line(lines, body_span.next_index)
                if while_i < 0 {
                    append_comment_line(out, indent, line)
                    return body_span
                }
                val while_opt = @get(lines, while_i as usize)
                match while_opt {
                    some while_val => {
                        while_line = trim_raw(while_val as ref char)
                        next_i = while_i + 1
                    }
                    none => {}
                }
            }
            val open_i: i64 = find_char(while_line, 40)
            val close_i: i64 = find_matching_delim(while_line, open_i, 40, 41)
            if open_i < 0 || close_i <= open_i {
                append_comment_line(out, indent, line)
                return make_block_result(next_i, STOP_EOF, "")
            }
            val cond_out: ref void = std.string.StringBuilder.new()
            val cond_text: ref char = translate_condition_text(ctx, trim_raw(std.string.substr(while_line, open_i + 1, close_i - open_i - 1)), indent + 1, cond_out)
            val body_text: ref char = std.string.substr(body_full, brace_i + 1, close_b - brace_i - 1)
            val body_lines = split_lines(body_text)
            append_line(out, indent, "for {")
            translate_body_lines(body_lines, "", 0, indent + 1, out, ctx)
            append_builder(out, cond_out)
            append_line(out, indent + 1, trust @fmt("if ({s}) {", {cond_text}))
            append_line(out, indent + 1, "} else {")
            append_line(out, indent + 2, "break")
            append_line(out, indent + 1, "}")
            append_line(out, indent, "}")
            return make_block_result(next_i, STOP_EOF, "")
        }
    }
}

fn translate_statement_at(lines: list[ref char], current_dir: ref char, start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val line_opt = @get(lines, start as usize)
    match line_opt {
        none => { return make_block_result(start + 1, STOP_EOF, "") }
        some line_val => {
            val trimmed: ref char = trim_raw(line_val as ref char)
            if std.string.rchar_starts_with(trimmed, "for (") {
                return translate_for_loop(lines, start, indent, out, ctx)
            }
            if std.string.rchar_starts_with(trimmed, "while (") {
                return translate_while_loop(lines, start, indent, out, ctx)
            }
            if std.string.rchar_starts_with(trimmed, "if (") {
                return translate_if_statement(lines, current_dir, start, indent, out, ctx)
            }
            if std.string.rchar_starts_with(trimmed, "switch (") {
                return translate_switch_statement(lines, start, indent, out, ctx)
            }
            if std.string.rchar_starts_with(trimmed, "do") {
                return translate_do_while_loop(lines, start, indent, out, ctx)
            }
            if translate_body_statement(ctx, trimmed, indent, out) {
                return make_block_result(start + 1, STOP_EOF, "")
            }
            append_comment_line(out, indent, trimmed)
            return make_block_result(start + 1, STOP_EOF, "")
        }
    }
}

fn parse_function_pointer_param_name(text: ref char, fallback_name: ref char) ref char = {
    val open_i: i64 = find_char(text, 40)
    if open_i < 0 { return fallback_name }
    val star_i: mut i64 = open_i + 1
    val len: i64 = std.string.len_raw(text)
    for {
        if star_i >= len {
            break
        }
        val c: u8 = trust @load8(@ptradd(text as ref void, star_i)) as u8
        if c == 42 { break }
        if !is_space(c) { return fallback_name }
        star_i++
    }
    if star_i >= len { return fallback_name }
    val name_start: mut i64 = star_i + 1
    for {
        if name_start >= len {
            break
        }
        val c: u8 = trust @load8(@ptradd(text as ref void, name_start)) as u8
        if is_ident_start(c) { break }
        name_start++
    }
    if name_start >= len { return fallback_name }
    val name_end: mut i64 = name_start
    for {
        if name_end >= len {
            break
        }
        val c: u8 = trust @load8(@ptradd(text as ref void, name_end)) as u8
        if !is_ident_part(c) { break }
        name_end++
    }
    return sanitize_identifier(std.string.substr(text, name_start, name_end - name_start))
}

fn find_top_level_assign(text: ref char) i64 = {
    val len: i64 = std.string.len_raw(text)
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == 40 { paren++ }
        elif c == 41 && paren > 0 { paren-- }
        elif c == 123 { brace++ }
        elif c == 125 && brace > 0 { brace-- }
        elif c == 91 { bracket++ }
        elif c == 93 && bracket > 0 { bracket-- }
        elif c == 61 && paren == 0 && brace == 0 && bracket == 0 {
            val prev: mut u8 = 0
            val next: mut u8 = 0
            if i > 0 { prev = trust @load8(@ptradd(text as ref void, i - 1)) as u8 }
            if i + 1 < len { next = trust @load8(@ptradd(text as ref void, i + 1)) as u8 }
            if prev != 61 && prev != 33 && prev != 60 && prev != 62
                && prev != 43 && prev != 45 && prev != 42 && prev != 47
                && prev != 37 && prev != 38 && prev != 124 && prev != 94
                && next != 61 {
                return i
            }
        }
        i++
    }
    return -1
}

fn find_top_level_compound_assign(text: ref char) i64 = {
    val len: i64 = std.string.len_raw(text)
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i + 1 >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        val next: u8 = trust @load8(@ptradd(text as ref void, i + 1)) as u8
        if c == 40 { paren++ }
        elif c == 41 && paren > 0 { paren-- }
        elif c == 123 { brace++ }
        elif c == 125 && brace > 0 { brace-- }
        elif c == 91 { bracket++ }
        elif c == 93 && bracket > 0 { bracket-- }
        elif next == 61 && paren == 0 && brace == 0 && bracket == 0
            && (c == 43 || c == 45 || c == 42 || c == 47 || c == 37 || c == 38 || c == 124 || c == 94) {
            return i
        }
        i++
    }
    return -1
}

fn translate_designated_initializer(text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    if !std.string.rchar_starts_with(trimmed, "{") { return trimmed }
    if !str_contains(trimmed, ".") { return trimmed }
    val sb: ref void = std.string.StringBuilder.new()
    val len: i64 = std.string.len_raw(trimmed)
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c == 46 && i + 1 < len {
            val next: u8 = trust @load8(@ptradd(trimmed as ref void, i + 1)) as u8
            if is_ident_start(next) {
                i++
                val start: i64 = i
                for {
                    if i >= len { break }
                    val cc: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                    if !is_ident_part(cc) { break }
                    i++
                }
                val field: ref char = std.string.substr(trimmed, start, i - start)
                std.string.StringBuilder.append_cstr(sb, field)
                for {
                    if i >= len {
                        break
                    }
                    val ws: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                    if !is_space(ws) { break }
                    i++
                }
                if i < len {
                    val eq: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                    if eq == 61 {
                        std.string.StringBuilder.append_cstr(sb, ": ")
                        i++
                        continue
                    }
                }
                continue
            }
        }
        std.string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn translate_sizeof_expr(ctx: ref TranslationCtx, text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    val len: i64 = std.string.len_raw(trimmed)
    val sb: ref void = std.string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        if i + 7 <= len {
            val maybe_kw: ref char = std.string.substr(trimmed, i, 6)
            if std.string.rchar_cmp(maybe_kw, "sizeof") == 0 {
                val after_kw: mut i64 = i + 6
                for {
                    if after_kw >= len {
                        break
                    }
                    val ws: u8 = trust @load8(@ptradd(trimmed as ref void, after_kw)) as u8
                    if !is_space(ws) { break }
                    after_kw++
                }
                if after_kw < len && (trust @load8(@ptradd(trimmed as ref void, after_kw)) as u8) == 40 {
                    val close_i: mut i64 = after_kw + 1
                    val depth: mut i64 = 1
                    for {
                        if close_i >= len { break }
                        val cc: u8 = trust @load8(@ptradd(trimmed as ref void, close_i)) as u8
                        if cc == 40 { depth++ }
                        elif cc == 41 {
                            depth--
                            if depth == 0 { break }
                        }
                        close_i++
                    }
                    if close_i < len {
                        val inner: ref char = trim_raw(std.string.substr(trimmed, after_kw + 1, close_i - after_kw - 1))
                        if is_ident_text(inner) {
                            match lookup_local_array_type(ctx, inner) {
                                some array_size_expr => {
                                    std.string.StringBuilder.append_cstr(sb, array_size_expr as ref char)
                                    i = close_i + 1
                                    continue
                                }
                                none => {}
                            }
                        }
                        val mapped: ref char = translate_c_type(inner, "")
                        std.string.StringBuilder.append_cstr(sb, trust @fmt("@sizeof({s})", {mapped}))
                        i = close_i + 1
                        continue
                    }
                }
            }
        }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        std.string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn translate_c_cast_expr(ctx: ref TranslationCtx, text: ref char) ref char = {
    val trimmed: ref char = trim_raw(text)
    if !std.string.rchar_starts_with(trimmed, "(") { return trimmed }
    val close_i: i64 = find_matching_delim(trimmed, 0, 40, 41)
    if close_i <= 0 { return trimmed }
    val inner: ref char = trim_raw(std.string.substr(trimmed, 1, close_i - 1))
    if !is_probable_c_type(inner) { return trimmed }
    val len: i64 = std.string.len_raw(trimmed)
    val rest: ref char = trim_raw(std.string.substr(trimmed, close_i + 1, len - close_i - 1))
    if std.string.rchar_cmp(rest, "") == 0 { return trimmed }
    val mapped: ref char = translate_c_type(inner, "")
    return trust @fmt("{s} as {s}", {translate_expr_text(ctx, rest), mapped})
}

fn find_top_level_equality(text: ref char) i64 = {
    val len: i64 = std.string.len_raw(text)
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i + 1 >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        val next: u8 = trust @load8(@ptradd(text as ref void, i + 1)) as u8
        if c == 40 { paren++ }
        elif c == 41 && paren > 0 { paren-- }
        elif c == 123 { brace++ }
        elif c == 125 && brace > 0 { brace-- }
        elif c == 91 { bracket++ }
        elif c == 93 && bracket > 0 { bracket-- }
        elif paren == 0 && brace == 0 && bracket == 0
            && ((c == 61 && next == 61) || (c == 33 && next == 61)) {
            return i
        }
        i++
    }
    return -1
}

fn rewrite_null_comparison(ctx: ref TranslationCtx, text: ref char) option[ref char] = {
    val trimmed: ref char = trim_raw(text)
    val cmp_i: i64 = find_top_level_equality(trimmed)
    if cmp_i < 0 { return none }
    val lhs_raw: ref char = trim_raw(std.string.substr(trimmed, 0, cmp_i))
    val rhs_raw: ref char = trim_raw(std.string.substr(trimmed, cmp_i + 2, std.string.len_raw(trimmed) - cmp_i - 2))
    val expr_side: mut ref char = ""
    if std.string.rchar_cmp(lhs_raw, "NULL") == 0 {
        expr_side = rhs_raw
    } elif std.string.rchar_cmp(rhs_raw, "NULL") == 0 {
        expr_side = lhs_raw
    } else {
        return none
    }
    val translated_expr: ref char = translate_expr_text(ctx, expr_side)
    val zero_expr: mut ref char = "0"
    if is_ident_text(translated_expr) {
        match lookup_local_type(ctx, translated_expr) {
            some type_name => { zero_expr = trust @fmt("0 as {s}", {type_name as ref char}) }
            none => {}
        }
    }
    val op: u8 = trust @load8(@ptradd(trimmed as ref void, cmp_i)) as u8
    if op == 61 {
        return some trust @fmt("{s} == {s}", {translated_expr, zero_expr})
    }
    return some trust @fmt("{s} != {s}", {translated_expr, zero_expr})
}

fn translate_expr_text(ctx: ref TranslationCtx, text: ref char) ref char = {
    val no_semicolon: ref char = strip_trailing_semicolon(text)
    val with_init: ref char = translate_designated_initializer(no_semicolon)
    val with_sizeof: ref char = translate_sizeof_expr(ctx, with_init)
    val with_arrow: ref char = replace_arrow_access(with_sizeof)
    val with_rewritten: ref char = rewrite_identifiers(with_arrow)
    val with_addr_deref: ref char = translate_addr_deref_expr(ctx, with_rewritten)
    val with_casts: ref char = translate_c_cast_expr(ctx, with_addr_deref)
    val with_indexing2: ref char = replace_pointer_indexing(with_casts)
    val with_intrinsics: ref char = ensure_intrinsic_prefixes(with_indexing2)
    val normalized_intrinsics: ref char = normalize_intrinsic_prefixes(with_intrinsics)
    if str_contains(normalized_intrinsics, "(") {
        return transform_call_expr(ctx, normalized_intrinsics)
    }
    return normalized_intrinsics
}

fn translate_condition_text(ctx: ref TranslationCtx, text: ref char, indent: i64, out: ref void) ref char = {
    if contains_incdec_ops(text) {
        val lowered_text: ref LoweredExpr = lower_incdec_text(ctx, text, indent, out)
        match rewrite_null_comparison(ctx, lowered_text.expr) {
            some translated => { return translated as ref char }
            none => {}
        }
        return translate_expr_text(ctx, lowered_text.expr)
    }
    match rewrite_null_comparison(ctx, text) {
        some translated => { return translated as ref char }
        none => {}
    }
    return translate_expr_text(ctx, text)
}

fn translate_body_statement(ctx: ref TranslationCtx, line: ref char, indent: i64, out: ref void) bool = {
    val stripped: ref char = strip_trailing_semicolon(line)
    if std.string.rchar_cmp(stripped, "") == 0 {
        append_blank_line(out)
        return true
    }
    if std.string.rchar_starts_with(stripped, "return") {
        val tail: ref char = trim_raw(std.string.substr(stripped, 6, std.string.len_raw(stripped) - 6))
        if std.string.rchar_cmp(tail, "") == 0 {
            append_line(out, indent, "return")
        } else {
            if contains_incdec_ops(tail) { append_blank_line(out) }
            val lowered_ret: ref LoweredExpr = lower_incdec_expr(ctx, tail, indent, out)
            if lowered_ret.changed { append_blank_line(out) }
            append_line(out, indent, trust @fmt("return {s}", {lowered_ret.expr}))
        }
        return true
    }
    val compound_i: i64 = find_top_level_compound_assign(stripped)
    if compound_i > 0 {
        val lhs: ref char = trim_raw(std.string.substr(stripped, 0, compound_i))
        val op: ref char = std.string.substr(stripped, compound_i, 1)
        val rhs: ref char = trim_raw(std.string.substr(stripped, compound_i + 2, std.string.len_raw(stripped) - compound_i - 2))
        val rhs_expr_compound: ref char = lower_incdec_expr(ctx, rhs, indent, out).expr
        append_line(out, indent, trust @fmt("{s} {s}= {s}", {
            translate_expr_text(ctx, lhs),
            op,
            rhs_expr_compound
        }))
        return true
    }
    val assign_i: i64 = find_top_level_assign(stripped)
    if assign_i > 0 {
        val lhs: ref char = trim_raw(std.string.substr(stripped, 0, assign_i))
        val rhs: ref char = trim_raw(std.string.substr(stripped, assign_i + 1, std.string.len_raw(stripped) - assign_i - 1))
        val can_be_decl: bool = str_contains(lhs, " ")
            || std.string.rchar_starts_with(lhs, "struct ") || std.string.rchar_starts_with(lhs, "enum ")
        if can_be_decl {
            val decl: ref DeclInfo = parse_named_decl(lhs, "")
            if decl.its_ok && std.string.rchar_cmp(decl.name, "") != 0 && std.string.rchar_cmp(trim_raw(decl.type_src), "") != 0 {
                if is_array_type_name(decl.type_name) {
                    val alloc_expr: ref char = array_alloc_expr(decl.type_name)
                    val decayed_type: ref char = decay_array_type(decl.type_name)
                    remember_local_type(ctx, decl.name, decayed_type)
                    remember_local_array_type(ctx, decl.name, alloc_expr)
                    append_line(out, indent, trust @fmt("val {s}: {s} = @alloc({s})", {decl.name, render_binding_type(ctx, decl.name, decayed_type), alloc_expr}))
                    return true
                }
                if is_address_taken_name(ctx, decl.name) && !std.string.rchar_starts_with(decl.type_name, "ref ") {
                    val ref_type: ref char = trust @fmt("ref {s}", {decl.type_name})
                    remember_local_type(ctx, decl.name, ref_type)
                    append_line(out, indent, trust @fmt("val {s}: {s} = @alloc(@sizeof({s}))", {decl.name, render_binding_type(ctx, decl.name, ref_type), decl.type_name}))
                    val lowered_rhs_addr: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
                    val rhs_expr_addr: mut ref char = lowered_rhs_addr.expr
                    if std.string.rchar_cmp(trim_raw(rhs), "NULL") == 0 {
                        rhs_expr_addr = trust @fmt("0 as {s}", {decl.type_name})
                    }
                    append_line(out, indent, trust @fmt("@deref({s}) = {s}", {decl.name, rhs_expr_addr}))
                    return true
                }
                val has_incdec_rhs: bool = contains_incdec_ops(rhs)
                if has_incdec_rhs {
                    append_blank_line(out)
                    append_comment_line(out, indent, trust @fmt("{s} = {s}", {decl.name, rhs}))
                }
                val lowered_rhs: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
                val rhs_expr0: ref char = lowered_rhs.expr
                val rhs_expr: mut ref char = rhs_expr0
                if std.string.rchar_cmp(trim_raw(rhs), "NULL") == 0 {
                    rhs_expr = trust @fmt("0 as {s}", {decl.type_name})
                }
                remember_local_type(ctx, decl.name, decl.type_name)
                val rendered_type: ref char = render_binding_type(ctx, decl.name, decl.type_name)
                val ternary_src: ref char = unwrap_outer_parens(rhs_expr)
                val q_i: i64 = find_top_level_ternary(ternary_src)
                if q_i >= 0 {
                    val colon_i: i64 = find_matching_colon_for_ternary(ternary_src, q_i)
                    if colon_i > q_i {
                        mark_mutable_name(ctx, decl.name)
                        val cond: ref char = unwrap_outer_parens(trim_raw(std.string.substr(ternary_src, 0, q_i)))
                        val if_true: ref char = unwrap_outer_parens(trim_raw(std.string.substr(ternary_src, q_i + 1, colon_i - q_i - 1)))
                        val if_false: ref char = unwrap_outer_parens(trim_raw(std.string.substr(ternary_src, colon_i + 1, std.string.len_raw(ternary_src) - colon_i - 1)))
                        append_line(out, indent, trust @fmt("val {s}: {s} = {s}", {decl.name, render_mutable_type(decl.type_name), if_false}))
                        val if_line1: ref char = trust @fmt("if ({s}) ", {cond})
                        val if_line2: ref char = std.string.concat_raw(if_line1, "{ ")
                        val if_line3: ref char = trust @fmt("{s} = {s}", {decl.name, if_true})
                        val if_line4: ref char = std.string.concat_raw(if_line2, if_line3)
                        val if_line5: ref char = std.string.concat_raw(if_line4, " }")
                        append_line(out, indent, if_line5)
                        return true
                    }
                }
                val call_name: ref char = extract_call_name(rhs_expr)
                if std.string.rchar_cmp(call_name, "") != 0 && !std.string.rchar_starts_with(rhs_expr, "@") {
                    push_unique(ctx.called_names, call_name)
                }
                append_line(out, indent, trust @fmt("val {s}: {s} = {s}", {decl.name, rendered_type, rhs_expr}))
                if std.string.rchar_starts_with(decl.type_name, "ref ")
                    && std.string.rchar_starts_with(rhs_expr, "@alloc(") {
                    val struct_name: ref char = trust @ptradd(decl.type_name, 4)
                    match lookup_flex_field_name(ctx, struct_name) {
                        some flex_field => {
                            match lookup_flex_field_type(ctx, struct_name) {
                                some flex_type => {
                                    append_blank_line(out)
                                    append_line(out, indent, trust @fmt("{s}.{s} = @ptradd({s} as ref i8, @sizeof({s})) as {s}",
                                        {decl.name, flex_field as ref char, decl.name, struct_name, flex_type as ref char}))
                                }
                                none => {}
                            }
                        }
                        none => {}
                    }
                }
                if lowered_rhs.changed { append_blank_line(out) }
                return true
            }
        }
        val lhs_arrow: ref char = replace_arrow_access(lhs)
        val lhs_rewritten: ref char = rewrite_identifiers(translate_addr_deref_expr(ctx, lhs_arrow))
        val index_target: ref char = parse_index_target(lhs_rewritten)
        if std.string.rchar_cmp(index_target, "") != 0 {
            val index_expr: ref char = parse_index_expr(lhs_rewritten)
            val has_incdec_rhs2: bool = contains_incdec_ops(rhs)
            if has_incdec_rhs2 {
                append_blank_line(out)
                append_comment_line(out, indent, trust @fmt("{s} = {s}", {lhs_rewritten, rhs}))
            }
            val lowered_rhs2: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
            val rhs_expr2: ref char = lowered_rhs2.expr
            append_line(out, indent, trust @fmt("@store(@ptradd({s}, {s}), {s})", {index_target, index_expr, rhs_expr2}))
            if lowered_rhs2.changed { append_blank_line(out) }
            return true
        }
        val has_incdec_rhs3: bool = contains_incdec_ops(rhs)
        if has_incdec_rhs3 {
            append_blank_line(out)
            append_comment_line(out, indent, trust @fmt("{s} = {s}", {lhs_rewritten, rhs}))
        }
        val lowered_rhs3: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
        val rhs_expr3_0: ref char = lowered_rhs3.expr
        val rhs_expr3: mut ref char = rhs_expr3_0
        if std.string.rchar_cmp(trim_raw(rhs), "NULL") == 0 && is_ident_text(lhs_rewritten) {
            match lookup_local_type(ctx, lhs_rewritten) {
                some type_name => { rhs_expr3 = trust @fmt("0 as {s}", {type_name as ref char}) }
                none => {}
            }
        }
        append_line(out, indent, trust @fmt("{s} = {s}", {lhs_rewritten, rhs_expr3}))
        if lowered_rhs3.changed { append_blank_line(out) }
        return true
    }
    val can_be_bare_decl: bool = (str_contains(stripped, " ") || str_contains(stripped, "*")
        || std.string.rchar_starts_with(stripped, "struct ") || std.string.rchar_starts_with(stripped, "enum "))
        && !str_contains(stripped, "(")
    if can_be_bare_decl {
        val decl2: ref DeclInfo = parse_named_decl(stripped, "")
        if decl2.its_ok && std.string.rchar_cmp(decl2.name, "") != 0 && is_array_type_name(decl2.type_name) {
            val alloc_expr2: ref char = array_alloc_expr(decl2.type_name)
            val decayed_type2: ref char = decay_array_type(decl2.type_name)
            remember_local_type(ctx, decl2.name, decayed_type2)
            remember_local_array_type(ctx, decl2.name, alloc_expr2)
            append_line(out, indent, trust @fmt("val {s}: {s} = @alloc({s})", {decl2.name, render_binding_type(ctx, decl2.name, decayed_type2), alloc_expr2}))
            return true
        }
    }
    if std.string.rchar_starts_with(stripped, "for (") {
        return false
    }
    if contains_incdec_ops(stripped) {
        append_line(out, indent, translate_expr_text(ctx, stripped))
        return true
    }
    if str_contains(stripped, "(")
        && !std.string.rchar_starts_with(stripped, "if")
        && !std.string.rchar_starts_with(stripped, "for")
        && !std.string.rchar_starts_with(stripped, "while")
        && !std.string.rchar_starts_with(stripped, "switch") {
        val lowered_expr: ref LoweredExpr = lower_incdec_expr(ctx, stripped, indent, out)
        val expr: ref char = lowered_expr.expr
        val call_name: ref char = extract_call_name(expr)
        if std.string.rchar_cmp(call_name, "") != 0 && !std.string.rchar_starts_with(expr, "@") {
            push_unique(ctx.called_names, call_name)
        }
        append_line(out, indent, expr)
        return true
    }
    return false
}

fn append_open_block_line(sb: ref void, indent: i64, prefix: ref char) void = {
    val line: ref char = std.string.concat_raw(prefix, "{")
    append_line(sb, indent, line)
}

fn emit_known_extern(name: ref char, out: ref void) bool = {
    if std.string.rchar_cmp(name, "fprintf") == 0 {
        append_line(out, 0, "extern (C) fn fprintf(stream: ref void, fmt: ref char, ...) i32! = \"fprintf\"")
        return true
    }
    if std.string.rchar_cmp(name, "sprintf") == 0 {
        append_line(out, 0, "extern (C) fn sprintf(dst: ref char, fmt: ref char, ...) i32! = \"sprintf\"")
        return true
    }
    if std.string.rchar_cmp(name, "puts") == 0 {
        append_line(out, 0, "extern (C) fn puts(s: ref char) i32! = \"puts\"")
        return true
    }
    if std.string.rchar_cmp(name, "putchar") == 0 {
        append_line(out, 0, "extern (C) fn putchar(c: i32) i32! = \"putchar\"")
        return true
    }
    if std.string.rchar_cmp(name, "strlen") == 0 {
        append_line(out, 0, "extern (C) fn strlen(s: ref char) i64! = \"strlen\"")
        return true
    }
    if std.string.rchar_cmp(name, "malloc") == 0 {
        append_line(out, 0, "extern (C) fn malloc(size: usize) ref void! = \"malloc\"")
        return true
    }
    if std.string.rchar_cmp(name, "free") == 0 {
        append_line(out, 0, "extern (C) fn free(ptr: ref void) void! = \"free\"")
        return true
    }
    return false
}

fn append_synthesized_externs(ctx: ref TranslationCtx, out: ref void) void = {
    val emitted_any: mut bool = false
    for name in ctx.called_names {
        if list_contains(ctx.defined_names, name) { continue }
        if list_contains(ctx.extern_names, name) { continue }
        if emit_known_extern(name, out) {
            push_unique(ctx.extern_names, name)
            emitted_any = true
        }
    }
    if emitted_any {
        append_blank_line(out)
    }
}

fn file_exists(path: ref char) bool = {
    val file_opt = std.fs.open(path, "r")
    match file_opt {
        some f => {
            std.fs.close(f)
            return true
        }
        none => { return false }
    }
}

fn resolve_include_path(name: ref char, current_dir: ref char) option[ref char] = {
    if std.string.rchar_starts_with(name, "/") {
        if file_exists(name) { return some name }
        return none
    }
    val local = std.path.join(current_dir, name)
    if file_exists(local) { return some local }
    val cwd_candidate = std.path.join(".", name)
    if file_exists(cwd_candidate) { return some cwd_candidate }
    val usr_local = std.path.join("/usr/local/include", name)
    if file_exists(usr_local) { return some usr_local }
    val usr = std.path.join("/usr/include", name)
    if file_exists(usr) { return some usr }
    return none
}

fn keyword_ignored(word: ref char) bool = {
    if std.string.rchar_cmp(word, "const") == 0    { return true }
    if std.string.rchar_cmp(word, "volatile") == 0 { return true }
    if std.string.rchar_cmp(word, "register") == 0 { return true }
    if std.string.rchar_cmp(word, "static") == 0   { return true }
    if std.string.rchar_cmp(word, "extern") == 0   { return true }
    if std.string.rchar_cmp(word, "inline") == 0   { return true }
    if std.string.rchar_cmp(word, "typedef") == 0  { return true }
    if std.string.rchar_cmp(word, "signed") == 0   { return true }
    return false
}

fn normalize_type_phrase(text: ref char) ref char = {
    val flat: ref char = flatten_ws(text)
    val sb: ref void = std.string.StringBuilder.new()
    val len: i64 = std.string.len_raw(flat)
    val i: mut i64 = 0
    val first: mut bool = true
    for {
        if i >= len { break }
        for {
            if i >= len {
                break
            }
            val c: u8 = trust @load8(@ptradd(flat as ref void, i)) as u8
            if !is_space(c) { break }
            i++
        }
        if i >= len { break }
        val start: i64 = i
        for {
            if i >= len {
                break
            }
            val c: u8 = trust @load8(@ptradd(flat as ref void, i)) as u8
            if is_space(c) { break }
            i++
        }
        val word: ref char = std.string.substr(flat, start, i - start)
        if !keyword_ignored(word) {
            if !first { std.string.StringBuilder.append_char(sb, 32) }
            std.string.StringBuilder.append_cstr(sb, word)
            first = false
        }
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return trim_raw(std.string.cstr(built))
}

fn map_base_type(base: ref char) ref char = {
    if std.string.rchar_cmp(base, "") == 0                   { return "void" }
    if std.string.rchar_cmp(base, "void") == 0               { return "void" }
    if std.string.rchar_cmp(base, "char") == 0               { return "char" }
    if std.string.rchar_cmp(base, "short") == 0              { return "i16" }
    if std.string.rchar_cmp(base, "int") == 0                { return "i32" }
    if std.string.rchar_cmp(base, "long") == 0               { return "i64" }
    if std.string.rchar_cmp(base, "long long") == 0          { return "i64" }
    if std.string.rchar_cmp(base, "unsigned char") == 0      { return "u8" }
    if std.string.rchar_cmp(base, "unsigned short") == 0     { return "u16" }
    if std.string.rchar_cmp(base, "unsigned") == 0           { return "u32" }
    if std.string.rchar_cmp(base, "unsigned int") == 0       { return "u32" }
    if std.string.rchar_cmp(base, "unsigned long") == 0      { return "u64" }
    if std.string.rchar_cmp(base, "unsigned long long") == 0 { return "u64" }
    if std.string.rchar_cmp(base, "float") == 0              { return "f32" }
    if std.string.rchar_cmp(base, "double") == 0             { return "f64" }
    if std.string.rchar_cmp(base, "_Bool") == 0              { return "bool" }
    if std.string.rchar_cmp(base, "bool") == 0               { return "bool" }
    if std.string.rchar_cmp(base, "size_t") == 0             { return "usize" }
    if std.string.rchar_cmp(base, "ssize_t") == 0            { return "i64" }
    if std.string.rchar_cmp(base, "int8_t") == 0             { return "i8" }
    if std.string.rchar_cmp(base, "uint8_t") == 0            { return "u8" }
    if std.string.rchar_cmp(base, "int16_t") == 0            { return "i16" }
    if std.string.rchar_cmp(base, "uint16_t") == 0           { return "u16" }
    if std.string.rchar_cmp(base, "int32_t") == 0            { return "i32" }
    if std.string.rchar_cmp(base, "uint32_t") == 0           { return "u32" }
    if std.string.rchar_cmp(base, "int64_t") == 0            { return "i64" }
    if std.string.rchar_cmp(base, "uint64_t") == 0           { return "u64" }
    if std.string.rchar_cmp(base, "intptr_t") == 0           { return "i64" }
    if std.string.rchar_cmp(base, "uintptr_t") == 0          { return "usize" }
    if std.string.rchar_starts_with(base, "struct ") {
        return sanitize_identifier(trim_raw(std.string.substr(base, 7, std.string.len_raw(base) - 7)))
    }
    if std.string.rchar_starts_with(base, "enum ") {
        return "i32"
    }
    return sanitize_identifier(base)
}

fn translate_c_type(type_src: ref char, array_prefix: ref char) ref char = {
    val normalized: ref char = normalize_type_phrase(type_src)
    val len: i64 = std.string.len_raw(normalized)
    val no_stars_sb: ref void = std.string.StringBuilder.new()
    val star_count: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(normalized as ref void, i)) as u8
        if c == 42 {
            star_count++
        } else {
            std.string.StringBuilder.append_char(no_stars_sb, c)
        }
        i++
    }
    val no_stars_built: ref void = std.string.StringBuilder.build(no_stars_sb)
    std.string.StringBuilder.free(no_stars_sb)
    val base: ref char = trim_raw(std.string.cstr(no_stars_built))
    val mapped0: ref char = map_base_type(base)
    val mapped: mut ref char = mapped0
    val j: mut i64 = 0
    for {
        if j >= star_count { break }
        mapped = trust @fmt("ref {s}", {mapped})
        j++
    }
    if std.string.rchar_cmp(array_prefix, "") != 0 {
        mapped = trust @fmt("{s}{s}", {array_prefix, mapped})
    }
    return mapped
}

fn strip_initializer(text: ref char) ref char = {
    val len: i64 = std.string.len_raw(text)
    val i: mut i64 = 0
    val depth_paren: mut i64 = 0
    val depth_bracket: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == 40 { depth_paren++ }
        elif c == 41 && depth_paren > 0 { depth_paren-- }
        elif c == 91 { depth_bracket++ }
        elif c == 93 && depth_bracket > 0 { depth_bracket-- }
        elif c == 61 && depth_paren == 0 && depth_bracket == 0 {
            return trim_raw(std.string.substr(text, 0, i))
        }
        i++
    }
    return trim_raw(text)
}

fn parse_named_decl(text: ref char, fallback_name: ref char) ref DeclInfo = {
    val info: mut ref DeclInfo = @alloc(@sizeof(DeclInfo)) as ref DeclInfo
    info.its_ok    = false
    info.name      = fallback_name
    info.type_name = ""
    info.type_src  = ""
    val trimmed0: ref char = trim_raw(strip_initializer(text))
    val len0: i64 = std.string.len_raw(trimmed0)
    if len0 == 0 { return info }
    val array_prefix: mut ref char = ""
    val i: mut i64 = len0 - 1
    for {
        if i < 0 { break }
        val c: u8 = trust @load8(@ptradd(trimmed0 as ref void, i)) as u8
        if is_space(c) {
            i--
            continue
        }
        if c != 93 { break }
        val close_i: i64 = i
        val open_i: mut i64 = i - 1
        for {
            if open_i < 0 { break }
            val inner: u8 = trust @load8(@ptradd(trimmed0 as ref void, open_i)) as u8
            if inner == 91 { break }
            open_i--
        }
        if open_i < 0 { break }
        val array_len_txt: ref char = trim_raw(std.string.substr(trimmed0, open_i + 1, close_i - open_i - 1))
        array_prefix = trust @fmt("[{s}]{s}", {array_len_txt, array_prefix})
        i = open_i - 1
    }
    for {
        if i < 0 {
            break
        }
        val c: u8 = trust @load8(@ptradd(trimmed0 as ref void, i)) as u8
        if !is_space(c) { break }
        i--
    }
    val name_end: i64 = i
    for {
        if i < 0 {
            break
        }
        val c: u8 = trust @load8(@ptradd(trimmed0 as ref void, i)) as u8
        if !is_ident_part(c) { break }
        i--
    }
    val name_start: i64 = i + 1
    if name_end >= name_start {
        info.name = sanitize_identifier(std.string.substr(trimmed0, name_start, name_end - name_start + 1))
        info.type_src = trim_raw(std.string.substr(trimmed0, 0, name_start))
    } else {
        info.name = sanitize_identifier(fallback_name)
        info.type_src = trimmed0
    }
    info.type_name = translate_c_type(info.type_src, array_prefix)
    info.its_ok = std.string.rchar_cmp(info.type_name, "") != 0
    return info
}

fn split_top_level(text: ref char, delim: u8) list[ref char] = {
    val items: mut list[ref char] = []
    val len: i64 = std.string.len_raw(text)
    val start: mut i64 = 0
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    val i: mut i64 = 0
    for {
        if i > len { break }
        val at_end: bool = i == len
        val c: mut u8 = 0
        if !at_end {
            c = trust @load8(@ptradd(text as ref void, i)) as u8
            if in_string {
                if escaped {
                    escaped = false
                } elif c == 92 {
                    escaped = true
                } elif c == 34 {
                    in_string = false
                }
            } elif in_char {
                if escaped {
                    escaped = false
                } elif c == 92 {
                    escaped = true
                } elif c == 39 {
                    in_char = false
                }
            } else {
                if c == 34 {
                    in_string = true
                } elif c == 39 {
                    in_char = true
                } elif c == 40 { paren++ }
                elif c == 41 && paren > 0 { paren-- }
                elif c == 123 { brace++ }
                elif c == 125 && brace > 0 { brace-- }
                elif c == 91 { bracket++ }
                elif c == 93 && bracket > 0 { bracket-- }
            }
        }
        if at_end || (c == delim && !in_string && !in_char && paren == 0 && brace == 0 && bracket == 0) {
            @append(items, trim_raw(std.string.substr(text, start, i - start)))
            start = i + 1
        }
        i++
    }
    return items
}

fn extract_identifier_before(text: ref char, end_exclusive: i64) ref char = {
    val i: mut i64 = end_exclusive - 1
    for {
        if i < 0 {
            break
        }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if !is_space(c) && c != 59 {
            break
        }
        i--
    }
    val end_i: i64 = i
    for {
        if i < 0 {
            break
        }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if !is_ident_part(c) { break }
        i--
    }
    if end_i < i + 1 { return "" }
    return std.string.substr(text, i + 1, end_i - i)
}

fn next_significant_line(lines: list[ref char], start: i64) i64 = {
    val len: i64 = @len(lines) as i64
    val i: mut i64 = start
    for {
        if i >= len { break }
        val opt = @get(lines, i as usize)
        match opt {
            some line_val => {
                val trimmed: ref char = trim_raw(line_val as ref char)
                if std.string.rchar_cmp(trimmed, "") != 0 {
                    return i
                }
            }
            none => {}
        }
        i++
    }
    return -1
}

fn parse_include_name(line: ref char) ref char = {
    val q1: i64 = find_char(line, 34)
    if q1 >= 0 {
        val q2: mut i64 = q1 + 1
        val len: i64 = std.string.len_raw(line)
        for {
            if q2 >= len { break }
            val c: u8 = trust @load8(@ptradd(line as ref void, q2)) as u8
            if c == 34 { break }
            q2++
        }
        if q2 < len {
            return std.string.substr(line, q1 + 1, q2 - q1 - 1)
        }
    }
    val a1: i64 = find_char(line, 60)
    if a1 >= 0 {
        val a2: mut i64 = a1 + 1
        val len: i64 = std.string.len_raw(line)
        for {
            if a2 >= len { break }
            val c: u8 = trust @load8(@ptradd(line as ref void, a2)) as u8
            if c == 62 { break }
            a2++
        }
        if a2 < len {
            return std.string.substr(line, a1 + 1, a2 - a1 - 1)
        }
    }
    return ""
}

fn parse_macro_name(line: ref char, keyword: ref char) ref char = {
    val flat: ref char = flatten_ws(line)
    val prefix: ref char = trust @fmt("{s} ", {keyword})
    if !std.string.rchar_starts_with(flat, prefix) { return "" }
    return trim_raw(std.string.substr(flat, std.string.len_raw(prefix), std.string.len_raw(flat) - std.string.len_raw(prefix)))
}

fn detect_condition(line: ref char) i64 = {
    val flat: ref char = flatten_ws(line)
    if std.string.rchar_cmp(flat, "#ifdef _WIN32") == 0 { return COND_WIN_TRUE }
    if std.string.rchar_cmp(flat, "#if defined(_WIN32)") == 0 { return COND_WIN_TRUE }
    if std.string.rchar_cmp(flat, "#if defined( _WIN32 )") == 0 { return COND_WIN_TRUE }
    if std.string.rchar_cmp(flat, "#ifndef _WIN32") == 0 { return COND_WIN_FALSE }
    if std.string.rchar_cmp(flat, "#if !defined(_WIN32)") == 0 { return COND_WIN_FALSE }
    if std.string.rchar_cmp(flat, "#if ! defined(_WIN32)") == 0 { return COND_WIN_FALSE }
    return COND_NONE
}

fn is_header_guard(lines: list[ref char], line_index: i64, macro_name: ref char) bool = {
    if std.string.rchar_cmp(macro_name, "") == 0 { return false }
    val next_i: i64 = next_significant_line(lines, line_index + 1)
    if next_i < 0 { return false }
    val opt = @get(lines, next_i as usize)
    match opt {
        some next_line => {
            val def_name: ref char = parse_macro_name(next_line as ref char, "#define")
            return std.string.rchar_cmp(def_name, macro_name) == 0
        }
        none => { return false }
    }
}

fn append_builder(dst: ref void, src: ref void) void = {
    val built: ref void = std.string.StringBuilder.build(src)
    std.string.StringBuilder.append(dst, built)
}

fn translate_body_lines(lines: list[ref char], current_dir: ref char, start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val len: i64 = @len(lines) as i64
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                val line: ref char = line_val as ref char
                val trimmed: ref char = trim_raw(line)
                if std.string.rchar_cmp(trimmed, "") == 0 {
                    append_blank_line(out)
                    i++
                    continue
                }
                if std.string.rchar_starts_with(trimmed, "#else") {
                    return make_block_result(i + 1, STOP_ELSE, trimmed)
                }
                if std.string.rchar_starts_with(trimmed, "#endif") {
                    return make_block_result(i + 1, STOP_ENDIF, trimmed)
                }
                if std.string.rchar_starts_with(trimmed, "#elif") {
                    return make_block_result(i + 1, STOP_ELIF, trimmed)
                }
                if std.string.rchar_starts_with(trimmed, "#include") {
                    i++
                    continue
                }
                val ifndef_name: ref char = parse_macro_name(trimmed, "#ifndef")
                if is_header_guard(lines, i, ifndef_name) {
                    val define_i: i64 = next_significant_line(lines, i + 1)
                    val inner = translate_body_lines(lines, current_dir, define_i + 1, indent, out, ctx)
                    i = inner.next_index
                    continue
                }
                val cond: i64 = detect_condition(trimmed)
                if cond == COND_WIN_TRUE {
                    append_line(out, indent, "when windows {")
                    val then_result = translate_body_lines(lines, current_dir, i + 1, indent + 1, out, ctx)
                    if then_result.stop_kind == STOP_ELSE {
                        append_line(out, indent, "} otherwise {")
                        val else_result = translate_body_lines(lines, current_dir, then_result.next_index, indent + 1, out, ctx)
                        append_line(out, indent, "}")
                        i = else_result.next_index
                    } elif then_result.stop_kind == STOP_ELIF {
                        append_line(out, indent, "} otherwise {")
                        append_comment_line(out, indent + 1, then_result.stop_line)
                        val elif_result = translate_body_lines(lines, current_dir, then_result.next_index, indent + 1, out, ctx)
                        append_line(out, indent, "}")
                        i = elif_result.next_index
                    } else {
                        append_line(out, indent, "}")
                        i = then_result.next_index
                    }
                    continue
                }
                if cond == COND_WIN_FALSE {
                    val non_windows: ref void = std.string.StringBuilder.new()
                    val then_result = translate_body_lines(lines, current_dir, i + 1, indent + 1, non_windows, ctx)
                    append_line(out, indent, "when windows {")
                    if then_result.stop_kind == STOP_ELSE {
                        val else_result = translate_body_lines(lines, current_dir, then_result.next_index, indent + 1, out, ctx)
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = else_result.next_index
                    } elif then_result.stop_kind == STOP_ELIF {
                        append_comment_line(out, indent + 1, then_result.stop_line)
                        val elif_result = translate_body_lines(lines, current_dir, then_result.next_index, indent + 1, out, ctx)
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = elif_result.next_index
                    } else {
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = then_result.next_index
                    }
                    continue
                }
                val stmt_result: ref BlockResult = translate_statement_at(lines, current_dir, i, indent, out, ctx)
                i = stmt_result.next_index
            }
            none => { i++ }
        }
    }
    return make_block_result(i, STOP_EOF, "")
}

fn collect_struct(lines: list[ref char], start: i64) ref BlockResult = {
    val len: i64 = @len(lines) as i64
    val brace_depth: mut i64 = 0
    val started: mut bool = false
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                val line: ref char = line_val as ref char
                val l: i64 = std.string.len_raw(line)
                val j: mut i64 = 0
                for {
                    if j >= l { break }
                    val c: u8 = trust @load8(@ptradd(line as ref void, j)) as u8
                    if c == 123 {
                        brace_depth++
                        started = true
                    } elif c == 125 && brace_depth > 0 {
                        brace_depth--
                    } elif c == 59 && started && brace_depth == 0 {
                        return make_block_result(i + 1, STOP_EOF, "")
                    }
                    j++
                }
            }
            none => {}
        }
        i++
    }
    return make_block_result(i, STOP_EOF, "")
}

fn collect_function(lines: list[ref char], start: i64) ref BlockResult = {
    val len: i64 = @len(lines) as i64
    val paren_depth: mut i64 = 0
    val brace_depth: mut i64 = 0
    val seen_body: mut bool = false
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                val line: ref char = line_val as ref char
                val l: i64 = std.string.len_raw(line)
                val j: mut i64 = 0
                for {
                    if j >= l { break }
                    val c: u8 = trust @load8(@ptradd(line as ref void, j)) as u8
                    if c == 40 { paren_depth++ }
                    elif c == 41 && paren_depth > 0 { paren_depth-- }
                    elif c == 123 && paren_depth == 0 {
                        brace_depth++
                        seen_body = true
                    } elif c == 125 && brace_depth > 0 {
                        brace_depth--
                        if seen_body && brace_depth == 0 {
                            return make_block_result(i + 1, STOP_EOF, "")
                        }
                    } elif c == 59 && paren_depth == 0 && !seen_body {
                        return make_block_result(i + 1, STOP_EOF, "")
                    }
                    j++
                }
            }
            none => {}
        }
        i++
    }
    return make_block_result(i, STOP_EOF, "")
}

fn translate_struct_decl(text: ref char, indent: i64, out: ref void, ctx: ref TranslationCtx) bool = {
    val flat: ref char = flatten_ws(text)
    val open_i: i64 = find_char(flat, 123)
    val close_i: i64 = find_last_char(flat, 125)
    if open_i < 0 || close_i <= open_i { return false }
    val header: ref char = trim_raw(std.string.substr(flat, 0, open_i))
    val after: ref char = strip_trailing_semicolon(trim_raw(std.string.substr(flat, close_i + 1, std.string.len_raw(flat) - close_i - 1)))
    val before_body_name: mut ref char = ""
    if std.string.rchar_starts_with(header, "typedef struct") {
        val tail_len: i64 = std.string.len_raw(header) - 14
        if tail_len > 0 {
            before_body_name = trim_raw(std.string.substr(header, 14, tail_len))
        }
    } elif std.string.rchar_starts_with(header, "struct") {
        val tail_len: i64 = std.string.len_raw(header) - 6
        if tail_len > 0 {
            before_body_name = trim_raw(std.string.substr(header, 6, tail_len))
        }
    } else {
        return false
    }
    val alias0: ref char = extract_identifier_before(after, std.string.len_raw(after))
    val alias: mut ref char = alias0
    if std.string.rchar_cmp(alias, "") == 0 {
        alias = before_body_name
    }
    if std.string.rchar_cmp(alias, "") == 0 { return false }
    if list_contains(ctx.translated_type_names, alias) { return true }
    push_unique(ctx.translated_type_names, alias)
    val body: ref char = std.string.substr(flat, open_i + 1, close_i - open_i - 1)
    append_open_block_line(out, indent, trust @fmt("type {s} = ", {alias}))
    val fields = split_top_level(body, 59)
    for field in fields {
        val trimmed: ref char = trim_raw(field)
        if std.string.rchar_cmp(trimmed, "") == 0 { continue }
        if str_contains(trimmed, ",") {
            append_comment_line(out, indent + 1, trust @fmt("unsupported field declaration: {s};", {trimmed}))
            continue
        }
        val decl: ref DeclInfo = parse_named_decl(trimmed, "")
        if !decl.its_ok || std.string.rchar_cmp(decl.name, "") == 0 {
            append_comment_line(out, indent + 1, trust @fmt("unsupported field declaration: {s};", {trimmed}))
            continue
        }
        val field_type: mut ref char = decl.type_name
        if std.string.rchar_starts_with(field_type, "[]") {
            field_type = trust @fmt("ref {s}", {@ptradd(field_type, 2)})
            remember_flex_field(ctx, alias, decl.name, field_type)
        }
        append_line(out, indent + 1, trust @fmt("{s}: {s}", {decl.name, render_mutable_type(field_type)}))
    }
    append_line(out, indent, "}")
    append_blank_line(out)
    return true
}

fn translate_params(ctx: ref TranslationCtx, params_text: ref char) ref char = {
    val trimmed: ref char = trim_raw(params_text)
    if std.string.rchar_cmp(trimmed, "") == 0 { return "" }
    if std.string.rchar_cmp(trimmed, "void") == 0 { return "" }
    val params = split_top_level(trimmed, 44)
    val sb: ref void = std.string.StringBuilder.new()
    val arg_index: mut i64 = 0
    val first: mut bool = true
    for param in params {
        val p: ref char = trim_raw(param)
        if std.string.rchar_cmp(p, "") == 0 { continue }
        if std.string.rchar_cmp(p, "...") == 0 {
            if !first { std.string.StringBuilder.append_cstr(sb, ", ") }
            std.string.StringBuilder.append_cstr(sb, "...")
            first = false
            continue
        }
        val fallback: ref char = trust @fmt("arg{d}", {arg_index})
        if str_contains(p, "(*") {
            val pname: ref char = parse_function_pointer_param_name(p, fallback)
            push_unique(ctx.fnptr_names, pname)
            if !first { std.string.StringBuilder.append_cstr(sb, ", ") }
            std.string.StringBuilder.append_cstr(sb, trust @fmt("{s}: ref void", {pname}))
            first = false
            arg_index++
            continue
        }
        val decl: ref DeclInfo = parse_named_decl(p, fallback)
        if !decl.its_ok {
            if !first { std.string.StringBuilder.append_cstr(sb, ", ") }
            std.string.StringBuilder.append_cstr(sb, trust @fmt("{s}: void", {fallback}))
            first = false
            arg_index++
            continue
        }
        val param_type: mut ref char = decl.type_name
        if is_array_type_name(decl.type_name) {
            param_type = decay_array_type(decl.type_name)
        }
        remember_local_type(ctx, decl.name, param_type)
        val rendered_type: ref char = render_binding_type(ctx, decl.name, param_type)
        if !first { std.string.StringBuilder.append_cstr(sb, ", ") }
        std.string.StringBuilder.append_cstr(sb, trust @fmt("{s}: {s}", {decl.name, rendered_type}))
        first = false
        arg_index++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn translate_function_decl(text: ref char, current_dir: ref char, indent: i64, out: ref void, ctx: ref TranslationCtx) bool = {
    val has_body: bool = find_char(text, 123) >= 0
    val signature_src: mut ref char = ""
    val body_src: mut ref char = ""
    if has_body {
        val open_i: i64 = find_char(text, 123)
        val close_i: i64 = find_last_char(text, 125)
        if close_i <= open_i { return false }
        signature_src = trim_raw(std.string.substr(text, 0, open_i))
        body_src = std.string.substr(text, open_i + 1, close_i - open_i - 1)
    } else {
        val semi_i: i64 = find_last_char(text, 59)
        if semi_i < 0 { return false }
        signature_src = trim_raw(std.string.substr(text, 0, semi_i))
        body_src = ""
    }
    val signature: ref char = flatten_ws(signature_src)
    val open_paren: i64 = find_char(signature, 40)
    val close_paren: i64 = find_last_char(signature, 41)
    if open_paren < 0 || close_paren <= open_paren { return false }
    val head: ref char = trim_raw(std.string.substr(signature, 0, open_paren))
    val params_raw: ref char = trim_raw(std.string.substr(signature, open_paren + 1, close_paren - open_paren - 1))
    val name: ref char = sanitize_identifier(extract_identifier_before(head, std.string.len_raw(head)))
    if std.string.rchar_cmp(name, "") == 0 { return false }
    val head_len: i64 = std.string.len_raw(head)
    val name_len: i64 = std.string.len_raw(name)
    if head_len < name_len { return false }
    val return_src: ref char = trim_raw(std.string.substr(head, 0, head_len - name_len))
    val return_type: ref char = translate_c_type(return_src, "")
    clear_local_types(ctx)
    if has_body {
        val body_lines0 = split_lines(body_src)
        analyze_mutable_names(ctx, body_lines0, 0)
        analyze_address_taken_names(ctx, body_lines0, 0)
    }
    val params_text: ref char = translate_params(ctx, params_raw)
    val is_static: bool = str_contains(signature, "static ")
    val line: mut ref char = ""
    if has_body {
        push_unique(ctx.defined_names, name)
        val fn_kw: mut ref char = "pub fn"
        if is_static { fn_kw = "fn" }
        line = trust @fmt("{s} {s}({s}) {s}! = ", {fn_kw, name, params_text, return_type})
        append_open_block_line(out, indent, line)
        val body_lines = split_lines(body_src)
        translate_body_lines(body_lines, current_dir, 0, indent + 1, out, ctx)
        if std.string.rchar_cmp(name, "main") == 0
            && std.string.rchar_cmp(return_type, "i32") == 0
            && !body_has_explicit_return(body_lines) {
            append_blank_line(out)
            append_line(out, indent + 1, "return 0")
        }
        append_line(out, indent, "}")
        append_blank_line(out)
        return true
    }
    if is_static {
        append_comment_line(out, indent, trust @fmt("static prototype omitted: {s};", {signature}))
        return true
    }
    push_unique(ctx.extern_names, name)
    line = trust @fmt("extern (C) fn {s}({s}) {s}! = \"{s}\"", {name, params_text, return_type, name})
    append_line(out, indent, line)
    return true
}

fn translate_file(path: ref char, out: ref void, seen: mut list[ref char], ctx: ref TranslationCtx) bool = {
    if list_contains(seen, path) { return true }
    @append(seen, path)
    val content_opt = preprocess_source(path)
    match content_opt {
        none => {
            append_comment_line(out, 0, trust @fmt("failed to read include: {s}", {path}))
            return false
        }
        some content_val => {
            val content: ref char = content_val as ref char
            val lines = split_lines(content)
            val current_dir: ref char = std.path.dir(path)
            val result = translate_top_level(lines, current_dir, 0, 0, out, seen, ctx)
            if result.stop_kind != STOP_EOF {
                append_comment_line(out, 0, trust @fmt("unterminated preprocessor block in {s}", {path}))
            }
            return true
        }
    }
}

pub fn translate_top_level(
    lines: list[ref char],
    current_dir: ref char,
    start: i64,
    indent: i64,
    out: ref void,
    seen: mut list[ref char],
    ctx: ref TranslationCtx
) ref BlockResult = {
    val len: i64 = @len(lines) as i64
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                val line: ref char = line_val as ref char
                val trimmed: ref char = trim_raw(line)
                if std.string.rchar_cmp(trimmed, "") == 0 {
                    i++
                    continue
                }
                if std.string.rchar_starts_with(trimmed, "#else") {
                    return make_block_result(i + 1, STOP_ELSE, trimmed)
                }
                if std.string.rchar_starts_with(trimmed, "#endif") {
                    return make_block_result(i + 1, STOP_ENDIF, trimmed)
                }
                if std.string.rchar_starts_with(trimmed, "#elif") {
                    return make_block_result(i + 1, STOP_ELIF, trimmed)
                }
                if std.string.rchar_starts_with(trimmed, "#pragma once") {
                    i++
                    continue
                }
                if std.string.rchar_starts_with(trimmed, "#include") {
                    val include_name: ref char = parse_include_name(trimmed)
                    if std.string.rchar_cmp(include_name, "") == 0 {
                        append_comment_line(out, indent, trimmed)
                    } elif is_system_include(trimmed) {
                        i++
                        continue
                    } else {
                        val include_path_opt = resolve_include_path(include_name, current_dir)
                        match include_path_opt {
                            some include_path => {
                                translate_file(include_path as ref char, out, seen, ctx)
                            }
                            none => {
                                append_comment_line(out, indent, trust @fmt("unresolved include: {s}", {include_name}))
                            }
                        }
                    }
                    i++
                    continue
                }
                val ifndef_name: ref char = parse_macro_name(trimmed, "#ifndef")
                if is_header_guard(lines, i, ifndef_name) {
                    val define_i: i64 = next_significant_line(lines, i + 1)
                    val inner = translate_top_level(lines, current_dir, define_i + 1, indent, out, seen, ctx)
                    i = inner.next_index
                    continue
                }
                val cond: i64 = detect_condition(trimmed)
                if cond == COND_WIN_TRUE {
                    append_line(out, indent, "when windows {")
                    val then_result = translate_top_level(lines, current_dir, i + 1, indent + 1, out, seen, ctx)
                    if then_result.stop_kind == STOP_ELSE {
                        append_line(out, indent, "} otherwise {")
                        val else_result = translate_top_level(lines, current_dir, then_result.next_index, indent + 1, out, seen, ctx)
                        append_line(out, indent, "}")
                        i = else_result.next_index
                    } elif then_result.stop_kind == STOP_ELIF {
                        append_line(out, indent, "} otherwise {")
                        append_comment_line(out, indent + 1, then_result.stop_line)
                        val elif_result = translate_top_level(lines, current_dir, then_result.next_index, indent + 1, out, seen, ctx)
                        append_line(out, indent, "}")
                        i = elif_result.next_index
                    } else {
                        append_line(out, indent, "}")
                        i = then_result.next_index
                    }
                    continue
                }
                if cond == COND_WIN_FALSE {
                    val non_windows: ref void = std.string.StringBuilder.new()
                    val then_result = translate_top_level(lines, current_dir, i + 1, indent + 1, non_windows, seen, ctx)
                    append_line(out, indent, "when windows {")
                    if then_result.stop_kind == STOP_ELSE {
                        val else_result = translate_top_level(lines, current_dir, then_result.next_index, indent + 1, out, seen, ctx)
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = else_result.next_index
                    } elif then_result.stop_kind == STOP_ELIF {
                        append_comment_line(out, indent + 1, then_result.stop_line)
                        val elif_result = translate_top_level(lines, current_dir, then_result.next_index, indent + 1, out, seen, ctx)
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = elif_result.next_index
                    } else {
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = then_result.next_index
                    }
                    continue
                }
                if std.string.rchar_starts_with(trimmed, "#define")
                    || std.string.rchar_starts_with(trimmed, "#undef")
                    || std.string.rchar_starts_with(trimmed, "#pragma")
                    || std.string.rchar_starts_with(trimmed, "#error")
                    || std.string.rchar_starts_with(trimmed, "#if")
                    || std.string.rchar_starts_with(trimmed, "#ifndef")
                    || std.string.rchar_starts_with(trimmed, "#ifdef") {
                    append_comment_line(out, indent, trimmed)
                    i++
                    continue
                }
                val starts_struct_decl: bool = std.string.rchar_starts_with(trimmed, "typedef struct")
                    || std.string.rchar_starts_with(trimmed, "struct ")
                val struct_has_brace: mut bool = str_contains(trimmed, "{")
                if starts_struct_decl && !struct_has_brace {
                    val next_i_struct: i64 = next_significant_line(lines, i + 1)
                    if next_i_struct >= 0 {
                        val next_struct_opt = @get(lines, next_i_struct as usize)
                        match next_struct_opt {
                            some next_struct_line => {
                                val next_struct_trimmed: ref char = trim_raw(next_struct_line as ref char)
                                if std.string.rchar_cmp(next_struct_trimmed, "{") == 0 {
                                    struct_has_brace = true
                                }
                            }
                            none => {}
                        }
                    }
                }
                if starts_struct_decl && struct_has_brace {
                    val span = collect_struct(lines, i)
                    val full_text: ref char = join_lines(lines, i, span.next_index)
                    if !translate_struct_decl(full_text, indent, out, ctx) {
                        append_comment_line(out, indent, trust @fmt("unsupported struct declaration: {s}", {trimmed}))
                    }
                    i = span.next_index
                    continue
                }
                if str_contains(trimmed, "(")
                    && !std.string.rchar_starts_with(trimmed, "if")
                    && !std.string.rchar_starts_with(trimmed, "for")
                    && !std.string.rchar_starts_with(trimmed, "while")
                    && !std.string.rchar_starts_with(trimmed, "switch")
                    && !std.string.rchar_starts_with(trimmed, "return") {
                    val span2 = collect_function(lines, i)
                    val full_text2: ref char = join_lines(lines, i, span2.next_index)
                    if translate_function_decl(full_text2, current_dir, indent, out, ctx) {
                        i = span2.next_index
                        continue
                    }
                }
                append_comment_line(out, indent, trimmed)
                i++
            }
            none => { i++ }
        }
    }
    return make_block_result(i, STOP_EOF, "")
}

pub fn translate_c(input_path: ref char, output_path: ref char) i32 = {
    val body: ref void = std.string.StringBuilder.new()
    val seen: mut list[ref char] = []
    val ctx: ref TranslationCtx = new_translation_ctx()
    val its_ok: bool = translate_file(input_path, body, seen, ctx)
    if !its_ok {
        std.stdio.print("error: failed to translate '{s}'\n", {input_path})
        return 1
    }
    val out: ref void = std.string.StringBuilder.new()
    append_comment_line(out, 0, trust @fmt("Generated by spectre --translate-c from {s}", {input_path}))
    append_blank_line(out)
    append_synthesized_externs(ctx, out)
    append_builder(out, body)
    val built: ref void = std.string.StringBuilder.build(out)
    val out_dir: ref char = std.path.dir(output_path)
    if std.string.rchar_cmp(out_dir, "") != 0 && std.string.rchar_cmp(out_dir, ".") != 0 {
        std.os.exec(trust @fmt("mkdir -p {s}", {out_dir}))
    }
    val written: bool = std.fs.write_all(output_path, std.string.cstr(built))
    if !written {
        std.stdio.print("error: could not write '{s}'\n", {output_path})
        return 1
    }
    std.stdio.print("wrote {s}\n", {output_path})
    return 0
}
