fn remember_flex_field(ctx: ref TranslationCtx, struct_name: ref u8, field_name: ref u8, field_type: ref u8) void = {
    val len: i64 = @len(ctx.flex_struct_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(ctx.flex_struct_names, i as usize)
        val f_opt = @get(ctx.flex_field_names, i as usize)
        match s_opt {
            some s_name => {
                match f_opt {
                    some f_name => {
                        if string.rchar_cmp(s_name as ref u8, struct_name) == 0
                            && string.rchar_cmp(f_name as ref u8, field_name) == 0 {
                            @set(ctx.flex_field_types, i as usize, field_type)
                            return
                        }
                    }
                    none => {}
                }
            }
            none => {}
        }
        i++
    }
    @append(ctx.flex_struct_names, struct_name)
    @append(ctx.flex_field_names, field_name)
    @append(ctx.flex_field_types, field_type)
}

fn lookup_flex_field_name(ctx: ref TranslationCtx, struct_name: ref u8) option[ref u8] = {
    val len: i64 = @len(ctx.flex_struct_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(ctx.flex_struct_names, i as usize)
        match s_opt {
            some s_name => {
                if string.rchar_cmp(s_name as ref u8, struct_name) == 0 {
                    val f_opt = @get(ctx.flex_field_names, i as usize)
                    match f_opt {
                        some f_name => { return some f_name as ref u8 }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return none
}

fn lookup_flex_field_type(ctx: ref TranslationCtx, struct_name: ref u8) option[ref u8] = {
    val len: i64 = @len(ctx.flex_struct_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(ctx.flex_struct_names, i as usize)
        match s_opt {
            some s_name => {
                if string.rchar_cmp(s_name as ref u8, struct_name) == 0 {
                    val t_opt = @get(ctx.flex_field_types, i as usize)
                    match t_opt {
                        some t_name => { return some t_name as ref u8 }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return none
}

fn mark_mutable_name(ctx: ref TranslationCtx, name: ref u8) void = {
    if string.rchar_cmp(name, "") == 0 { return }
    push_unique(ctx.mutable_names, name)
}

fn mark_address_taken_name(ctx: ref TranslationCtx, name: ref u8) void = {
    if string.rchar_cmp(name, "") == 0 { return }
    push_unique(ctx.address_taken_names, name)
}

fn is_mutable_name(ctx: ref TranslationCtx, name: ref u8) bool = {
    return list_contains(ctx.mutable_names, name)
}

fn is_address_taken_name(ctx: ref TranslationCtx, name: ref u8) bool = {
    return list_contains(ctx.address_taken_names, name)
}

fn render_binding_type(ctx: ref TranslationCtx, name: ref u8, type_name: ref u8) ref u8 = {
    if !is_mutable_name(ctx, name) { return type_name }
    if string.rchar_starts_with(type_name, "mut ") { return type_name }
    return trust @fmt("mut {s}", {type_name})
}

fn render_mutable_type(type_name: ref u8) ref u8 = {
    if string.rchar_starts_with(type_name, "mut ") { return type_name }
    return trust @fmt("mut {s}", {type_name})
}

fn append_main_prelude_line(ctx: ref TranslationCtx, line: ref u8) void = {
    @append(ctx.main_prelude_lines, line)
}

fn append_main_prelude_builder(ctx: ref TranslationCtx, sb: ref void) void = {
    val built: ref void = string.StringBuilder.build(sb)
    val lines = trust split_lines(string.cstr(built))
    for line in lines {
        val trimmed: ref u8 = trim_raw(line)
        if string.rchar_cmp(trimmed, "") == 0 { continue }
        append_main_prelude_line(ctx, trimmed)
    }
}

fn is_array_type_name(type_name: ref u8) bool = {
    return string.rchar_starts_with(type_name, "[")
}

fn array_type_close_index(type_name: ref u8) i64 = {
    return find_char(type_name, 93 as u8)
}

fn array_type_len_expr(type_name: ref u8) ref u8 = {
    val close_i: i64 = array_type_close_index(type_name)
    if close_i <= 1 { return "" }
    return trust string.substr(type_name, 1, close_i - 1)
}

fn array_type_elem(type_name: ref u8) ref u8 = {
    val close_i: i64 = array_type_close_index(type_name)
    val len: i64 = string.len_raw(type_name)
    if close_i < 0 || close_i + 1 >= len { return "void" }
    return trust string.substr(type_name, close_i + 1, len - close_i - 1)
}

fn decay_array_type(type_name: ref u8) ref u8 = {
    return trust @fmt("ref {s}", {array_type_elem(type_name)})
}

fn array_alloc_expr(type_name: ref u8) ref u8 = {
    val len_expr: ref u8 = array_type_len_expr(type_name)
    val elem_type: ref u8 = array_type_elem(type_name)
    return trust @fmt("{s} * @sizeof({s})", {len_expr, elem_type})
}

fn is_string_literal_text(text: ref u8) bool = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    if len < 2 { return false }
    val first: u8 = trust @load8(trimmed as ref void) as u8
    val last: u8 = trust @load8(@ptradd(trimmed as ref void, len - 1)) as u8
    return first == 34 && last == 34
}

fn is_unsized_char_array(type_name: ref u8) bool = {
    return string.rchar_cmp(array_type_len_expr(type_name), "") == 0
        && string.rchar_cmp(array_type_elem(type_name), "u8") == 0
}

fn string_literal_storage_len(text: ref u8) i64 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    if len < 2 { return 0 }
    val i: mut i64 = 1
    val count: mut i64 = 0
    for {
        if i >= len - 1 { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c == 92 && i + 1 < len - 1 {
            val esc: u8 = trust @load8(@ptradd(trimmed as ref void, i + 1)) as u8
            if esc == 120 || esc == 88 {
                i += 2
                for {
                    if i >= len - 1 { break }
                    val hc: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                    val is_hex: bool = (hc >= 48 && hc <= 57) || (hc >= 65 && hc <= 70) || (hc >= 97 && hc <= 102)
                    if !is_hex { break }
                    i++
                }
            } elif esc >= 48 && esc <= 55 {
                i += 2
                val oct_count: mut i64 = 1
                for {
                    if i >= len - 1 || oct_count >= 3 { break }
                    val oc: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                    if !(oc >= 48 && oc <= 55) { break }
                    i++
                    oct_count++
                }
            } else {
                i += 2
            }
            count++
            continue
        }
        count++
        i++
    }
    return count + 1
}

fn is_brace_initializer_text(text: ref u8) bool = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    if len < 2 { return false }
    val first: u8 = trust @load8(trimmed as ref void) as u8
    val last: u8 = trust @load8(@ptradd(trimmed as ref void, len - 1)) as u8
    return first == 123 && last == 125
}

fn parse_brace_initializer_items(text: ref u8) list[ref u8] = {
    val trimmed: ref u8 = trim_raw(text)
    if !is_brace_initializer_text(trimmed) { return [] }
    val inner: ref u8 = trim_raw(trust string.substr(trimmed, 1, string.len_raw(trimmed) - 2))
    if string.rchar_cmp(inner, "") == 0 { return [] }
    val raw_items = split_top_level(inner, 44 as u8)
    val items: mut list[ref u8] = []
    for raw_item in raw_items {
        val item: ref u8 = trim_raw(raw_item)
        if string.rchar_cmp(item, "") == 0 { continue }
        @append(items, item)
    }
    return items
}

fn emit_array_initializer_stores(ctx: ref TranslationCtx, out: ref void, indent: i64, name: ref u8, items: list[ref u8]) void = {
    val init_len: i64 = @len(items) as i64
    val init_i: mut i64 = 0
    for {
        if init_i >= init_len { break }
        val item_opt = @get(items, init_i as usize)
        match item_opt {
            some item_val => {
                val lowered_item: ref LoweredExpr = lower_incdec_expr(ctx, item_val as ref u8, indent, out)
                val item_expr: ref u8 = lowered_item.expr
                val item_ptr: ref u8 = render_index_ptr_expr(ctx, name, trust @fmt("{d}", {init_i}))
                track_called_expr(ctx, item_expr)
                append_line(out, indent, trust @fmt("@store({s}, {s})", {item_ptr, item_expr}))
            }
            none => {}
        }
        init_i++
    }
}

fn zero_init_expr(type_name: ref u8) ref u8 = {
    if string.rchar_cmp(type_name, "f32") == 0 || string.rchar_cmp(type_name, "f64") == 0 {
        return "0.0"
    }
    if string.rchar_cmp(type_name, "bool") == 0 {
        return "false"
    }
    return trust @fmt("0 as {s}", {type_name})
}

fn extract_assignment_base(lhs: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(lhs)
    if string.rchar_cmp(trimmed, "") == 0 { return "" }
    val lhs_arrow: ref u8 = replace_arrow_access(trimmed)
    val dot_i: i64 = find_char(lhs_arrow, 46 as u8)
    if dot_i > 0 {
        val base: ref u8 = trim_raw(trust string.substr(lhs_arrow, 0, dot_i))
        if is_ident_text(base) { return rewrite_identifiers(base) }
        return ""
    }
    if str_contains(lhs_arrow, "[") { return "" }
    if is_ident_text(trimmed) { return rewrite_identifiers(trimmed) }
    return ""
}

fn find_top_level_else(text: ref u8) i64 = {
    val len: i64 = string.len_raw(text)
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if in_string {
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 34 {
                in_string = false
            }
            i++
            continue
        }
        if in_char {
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 39 {
                in_char = false
            }
            i++
            continue
        }
        if c == 34 {
            in_string = true
            i++
            continue
        }
        if c == 39 {
            in_char = true
            i++
            continue
        }
        if c == 40 { paren++ }
        elif c == 41 && paren > 0 { paren-- }
        elif c == 123 { brace++ }
        elif c == 125 && brace > 0 { brace-- }
        elif c == 91 { bracket++ }
        elif c == 93 && bracket > 0 { bracket-- }
        elif paren == 0 && brace == 0 && bracket == 0 && i + 4 <= len {
            val frag: ref u8 = trust string.substr(text, i, 4)
            if string.rchar_cmp(frag, "else") == 0 {
                val prev_ok: bool = i == 0 || !is_ident_part(trust @load8(@ptradd(text as ref void, i - 1)) as u8)
                val next_ok: bool = i + 4 >= len || !is_ident_part(trust @load8(@ptradd(text as ref void, i + 4)) as u8)
                if prev_ok && next_ok { return i }
            }
        }
        i++
    }
    return -1
}

fn analyze_mutations_in_statement(ctx: ref TranslationCtx, line: ref u8) void = {
    val stripped: ref u8 = strip_trailing_semicolon(trim_raw(line))
    if string.rchar_cmp(stripped, "") == 0 { return }
    if string.rchar_starts_with(stripped, "else") {
        val tail: ref u8 = trim_raw(trust string.substr(stripped, 4, string.len_raw(stripped) - 4))
        if string.rchar_cmp(tail, "") != 0 {
            analyze_mutations_in_statement(ctx, tail)
        }
        return
    }
    if starts_keyword_paren(stripped, "if") {
        val open_i: i64 = find_char(stripped, 40 as u8)
        val close_i: i64 = find_matching_delim(stripped, open_i, 40 as u8, 41 as u8)
        if open_i >= 0 && close_i > open_i {
            val tail: ref u8 = trim_raw(trust string.substr(stripped, close_i + 1, string.len_raw(stripped) - close_i - 1))
            if string.rchar_cmp(tail, "") != 0 {
                val else_i: i64 = find_top_level_else(tail)
                if else_i >= 0 {
                    val then_text: ref u8 = trim_raw(trust string.substr(tail, 0, else_i))
                    val else_text: ref u8 = trim_raw(trust string.substr(tail, else_i + 4, string.len_raw(tail) - else_i - 4))
                    if string.rchar_cmp(then_text, "") != 0 { analyze_mutations_in_statement(ctx, then_text) }
                    if string.rchar_cmp(else_text, "") != 0 { analyze_mutations_in_statement(ctx, else_text) }
                    return
                }
                analyze_mutations_in_statement(ctx, tail)
                return
            }
        }
    }
    val compound_i: i64 = find_top_level_compound_assign(stripped)
    if compound_i > 0 {
        mark_mutable_name(ctx, extract_assignment_base(trust string.substr(stripped, 0, compound_i)))
    }
    val assign_i: i64 = find_top_level_assign(stripped)
    if assign_i > 0 {
        val lhs: ref u8 = trim_raw(trust string.substr(stripped, 0, assign_i))
        val can_be_decl: bool = str_contains(lhs, " ") || str_contains(lhs, "*")
            || string.rchar_starts_with(lhs, "struct ") || string.rchar_starts_with(lhs, "enum ")
        if !can_be_decl {
            mark_mutable_name(ctx, extract_assignment_base(lhs))
        }
    }
    val len: i64 = string.len_raw(stripped)
    val i: mut i64 = 0
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(stripped as ref void, i)) as u8
        if in_string {
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 34 {
                in_string = false
            }
            i++
            continue
        }
        if in_char {
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 39 {
                in_char = false
            }
            i++
            continue
        }
        if c == 34 {
            in_string = true
            i++
            continue
        }
        if c == 39 {
            in_char = true
            i++
            continue
        }
        if is_ident_start(c) {
            val start_i: i64 = i
            i++
            for {
                if i >= len { break }
                val cc: u8 = trust @load8(@ptradd(stripped as ref void, i)) as u8
                if !is_ident_part(cc) { break }
                i++
            }
            val ident: ref u8 = trust string.substr(stripped, start_i, i - start_i)
            val j: mut i64 = i
            for {
                if j >= len { break }
                val ws: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                if !is_space(ws) { break }
                j++
            }
            if j + 1 < len {
                val c1: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                val c2: u8 = trust @load8(@ptradd(stripped as ref void, j + 1)) as u8
                if ((c1 == 43 && c2 == 43) || (c1 == 45 && c2 == 45)) {
                    mark_mutable_name(ctx, rewrite_identifiers(ident))
                }
            }
            continue
        }
        if i + 1 < len && ((c == 43 && (trust @load8(@ptradd(stripped as ref void, i + 1)) as u8) == 43)
            || (c == 45 && (trust @load8(@ptradd(stripped as ref void, i + 1)) as u8) == 45)) {
            val j: mut i64 = i + 2
            for {
                if j >= len { break }
                val ws: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                if !is_space(ws) { break }
                j++
            }
            if j < len {
                val first: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                if is_ident_start(first) {
                    val start_i2: i64 = j
                    j++
                    for {
                        if j >= len { break }
                        val cc2: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                        if !is_ident_part(cc2) { break }
                        j++
                    }
                    val ident2: ref u8 = trust string.substr(stripped, start_i2, j - start_i2)
                    mark_mutable_name(ctx, rewrite_identifiers(ident2))
                    i = j
                    continue
                }
            }
        }
        if c == 123 {
            val close_i: i64 = find_matching_delim(stripped, i, 123 as u8, 125 as u8)
            if close_i > i {
                val inner: ref u8 = trust string.substr(stripped, i + 1, close_i - i - 1)
                val statements = split_top_level(inner, 59 as u8)
                for stmt in statements {
                    analyze_mutations_in_statement(ctx, stmt)
                }
                i = close_i + 1
                continue
            }
        }
        i++
    }
}

fn emit_incdec_stmt(raw_name: ref u8, op: ref u8, indent: i64, out: ref void) void = {
    val name: ref u8 = rewrite_identifiers(raw_name)
    append_line(out, indent, trust @fmt("{s}{s}{s}", {name, op, op}))
}

fn fresh_union_name(ctx: mut ref TranslationCtx) ref u8 = {
    val union_name: ref u8 = trust @fmt("union{d}", {ctx.union_counter})
    ctx.union_counter = ctx.union_counter + 1
    return union_name
}

fn normalize_simple_incdec_stmt(text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    if len < 3 { return "" }
    val first: u8 = trust @load8(@ptradd(trimmed as ref void, 0)) as u8
    val second: u8 = trust @load8(@ptradd(trimmed as ref void, 1)) as u8
    if ((first == 43 && second == 43) || (first == 45 && second == 45)) {
        val ident: ref u8 = trim_raw(trust string.substr(trimmed, 2, len - 2))
        if is_ident_text(ident) {
            val op: mut ref u8 = "+"
            if first == 45 { op = "-" }
            return trust @fmt("{s}{s}{s}", {rewrite_identifiers(ident), op, op})
        }
    }
    val last2: u8 = trust @load8(@ptradd(trimmed as ref void, len - 2)) as u8
    val last1: u8 = trust @load8(@ptradd(trimmed as ref void, len - 1)) as u8
    if ((last2 == 43 && last1 == 43) || (last2 == 45 && last1 == 45)) {
        val ident2: ref u8 = trim_raw(trust string.substr(trimmed, 0, len - 2))
        if is_ident_text(ident2) {
            val op2: mut ref u8 = "+"
            if last2 == 45 { op2 = "-" }
            return trust @fmt("{s}{s}{s}", {rewrite_identifiers(ident2), op2, op2})
        }
    }
    return ""
}

fn lower_incdec_text(_: ref TranslationCtx, text: ref u8, indent: i64, out: ref void) ref LoweredExpr = {
    val trimmed: ref u8 = strip_trailing_semicolon(text)
    val len: i64 = string.len_raw(trimmed)
    val sb: ref void = string.StringBuilder.new()
    val changed: mut bool = false
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if in_string {
            string.StringBuilder.append_char(sb, c)
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 34 {
                in_string = false
            }
            i++
            continue
        }
        if in_char {
            string.StringBuilder.append_char(sb, c)
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 39 {
                in_char = false
            }
            i++
            continue
        }
        if c == 34 {
            in_string = true
            string.StringBuilder.append_char(sb, c)
            i++
            continue
        }
        if c == 39 {
            in_char = true
            string.StringBuilder.append_char(sb, c)
            i++
            continue
        }
        if i + 1 < len {
            val next: u8 = trust @load8(@ptradd(trimmed as ref void, i + 1)) as u8
            if ((c == 43 && next == 43) || (c == 45 && next == 45)) {
                val op: mut ref u8 = "+"
                if c == 45 { op = "-" }
                val j: mut i64 = i + 2
                for {
                    if j >= len { break }
                    val ws: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                    if !is_space(ws) { break }
                    j++
                }
                if j < len {
                    val first: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                    if is_ident_start(first) {
                        val start_name: i64 = j
                        j++
                        for {
                            if j >= len { break }
                            val cc: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                            if !is_ident_part(cc) { break }
                            j++
                        }
                        val ident: ref u8 = trust string.substr(trimmed, start_name, j - start_name)
                        emit_incdec_stmt(ident, op, indent, out)
                        string.StringBuilder.append_cstr(sb, rewrite_identifiers(ident))
                        changed = true
                        i = j
                        continue
                    }
                }
            }
        }
        if is_ident_start(c) {
            val start_name2: i64 = i
            i++
            for {
                if i >= len { break }
                val cc2: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                if !is_ident_part(cc2) { break }
                i++
            }
            val ident2: ref u8 = trust string.substr(trimmed, start_name2, i - start_name2)
            val j2: mut i64 = i
            for {
                if j2 >= len { break }
                val ws2: u8 = trust @load8(@ptradd(trimmed as ref void, j2)) as u8
                if !is_space(ws2) { break }
                j2++
            }
            if j2 + 1 < len {
                val c1: u8 = trust @load8(@ptradd(trimmed as ref void, j2)) as u8
                val c2: u8 = trust @load8(@ptradd(trimmed as ref void, j2 + 1)) as u8
                if ((c1 == 43 && c2 == 43) || (c1 == 45 && c2 == 45)) {
                    val op2: mut ref u8 = "+"
                    if c1 == 45 { op2 = "-" }
                    emit_incdec_stmt(ident2, op2, indent, out)
                    string.StringBuilder.append_cstr(sb, ident2)
                    changed = true
                    i = j2 + 2
                    continue
                }
            }
            string.StringBuilder.append_cstr(sb, ident2)
            continue
        }
        string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return make_lowered_expr(trust string.cstr(built), changed)
}

fn lower_incdec_expr(ctx: ref TranslationCtx, text: ref u8, indent: i64, out: ref void) ref LoweredExpr = {
    val lowered_text: ref LoweredExpr = lower_incdec_text(ctx, text, indent, out)
    return make_lowered_expr(translate_expr_text(ctx, lowered_text.expr), lowered_text.changed)
}

fn body_has_explicit_return(lines: list[ref u8]) bool = {
    for line in lines {
        val trimmed: ref u8 = trim_raw(line)
        if string.rchar_starts_with(trimmed, "return") { return true }
    }
    return false
}

fn contains_incdec_ops(text: ref u8) bool = {
    return str_contains(text, "++") || str_contains(text, "--")
}

fn analyze_address_taken_in_statement(ctx: ref TranslationCtx, line: ref u8) void = {
    val stripped: ref u8 = strip_trailing_semicolon(trim_raw(line))
    if string.rchar_cmp(stripped, "") == 0 { return }
    val len: i64 = string.len_raw(stripped)
    val i: mut i64 = 0
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(stripped as ref void, i)) as u8
        if in_string {
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 34 {
                in_string = false
            }
            i++
            continue
        }
        if in_char {
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 39 {
                in_char = false
            }
            i++
            continue
        }
        if c == 34 {
            in_string = true
            i++
            continue
        }
        if c == 39 {
            in_char = true
            i++
            continue
        }
        if c == 38 {
            val prev: mut u8 = 0
            val next: mut u8 = 0
            if i > 0 { prev = trust @load8(@ptradd(stripped as ref void, i - 1)) as u8 }
            if i + 1 < len { next = trust @load8(@ptradd(stripped as ref void, i + 1)) as u8 }
            if prev != 38 && next != 38 {
                val j: mut i64 = i + 1
                for {
                    if j >= len { break }
                    val ws: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                    if !is_space(ws) { break }
                    j++
                }
                if j < len {
                    val first: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                    if is_ident_start(first) {
                        val start_i: i64 = j
                        j++
                        for {
                            if j >= len { break }
                            val cc: u8 = trust @load8(@ptradd(stripped as ref void, j)) as u8
                            if !is_ident_part(cc) { break }
                            j++
                        }
                        mark_address_taken_name(ctx, rewrite_identifiers(trust string.substr(stripped, start_i, j - start_i)))
                        i = j
                        continue
                    }
                }
            }
        }
        i++
    }
}

fn analyze_mutable_names(ctx: ref TranslationCtx, lines: list[ref u8], start: i64) void = {
    val len: i64 = @len(lines) as i64
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => { analyze_mutations_in_statement(ctx, line_val as ref u8) }
            none => {}
        }
        i++
    }
}

fn analyze_address_taken_names(ctx: ref TranslationCtx, lines: list[ref u8], start: i64) void = {
    val len: i64 = @len(lines) as i64
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => { analyze_address_taken_in_statement(ctx, line_val as ref u8) }
            none => {}
        }
        i++
    }
}

fn is_system_include(line: ref u8) bool = {
    val open_i: i64 = find_char(line, 60 as u8)
    val close_i: i64 = find_char(line, 62 as u8)
    return open_i >= 0 && close_i > open_i
}

fn strip_trailing_semicolon(text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    if len <= 0 { return trimmed }
    val last: u8 = trust @load8(@ptradd(trimmed as ref void, len - 1)) as u8
    if last == 59 {
        return trim_raw(trust string.substr(trimmed, 0, len - 1))
    }
    return trimmed
}

fn find_matching_delim(text: ref u8, start: i64, open: u8, close: u8) i64 = {
    val len: i64 = string.len_raw(text)
    if start < 0 || start >= len { return -1 }
    val first: u8 = trust @load8(@ptradd(text as ref void, start)) as u8
    if first != open { return -1 }
    val depth: mut i64 = 0
    val i: mut i64 = start
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == open {
            depth++
        } elif c == close {
            depth--
            if depth == 0 { return i }
        }
        i++
    }
    return -1
}

fn strip_system_includes(text: ref u8) ref u8 = {
    val lines = split_lines(text)
    val sb: ref void = string.StringBuilder.new()
    val first: mut bool = true
    for line in lines {
        val trimmed: ref u8 = trim_raw(line)
        if string.rchar_starts_with(trimmed, "#include") && is_system_include(trimmed) {
            continue
        }
        if !first {
            string.StringBuilder.append_char(sb, 10)
        }
        string.StringBuilder.append_cstr(sb, line)
        first = false
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn preprocess_source(path: ref u8) option[ref u8]! = {
    val content_opt = fs.read_all(path)
    match content_opt {
        none => { return none }
        some content_val => {
            val original: ref u8 = content_val as ref u8
            val filtered: ref u8 = strip_system_includes(original)
            val current_dir: ref u8 = path.dir(path)
            val temp_path: ref u8 = path.join(current_dir, "__spectre_translate_tmp__.c")
            val wrote: bool = fs.write_all(temp_path, filtered)
            if !wrote {
                return some original
            }
            val cmd: ref u8 = @fmt("cc -E -P {s} 2>/dev/null || clang -E -P {s} 2>/dev/null", {temp_path, temp_path})
            val result = os.exec(cmd)
            fs.delete(temp_path)
            match result {
                ok out => {
                    val text: ref u8 = string.cstr(out)
                    if string.rchar_cmp(trim_raw(text), "") == 0 {
                        return some filtered
                    }
                    return some text
                }
                err _ => {
                    return some filtered
                }
            }
        }
    }
}

fn extract_call_name(text: ref u8) ref u8 = {
    val open_i: i64 = find_char(text, 40 as u8)
    if open_i <= 0 { return "" }
    return extract_identifier_before(text, open_i)
}

fn extract_call_args_text(text: ref u8) list[ref u8]! = {
    val open_i: i64 = find_char(text, 40 as u8)
    val close_i: i64 = find_matching_delim(text, open_i, 40 as u8, 41 as u8)
    if open_i <= 0 || close_i <= open_i { return [] }
    val args_raw: ref u8 = trim_raw(string.substr(text, open_i + 1, close_i - open_i - 1))
    if string.rchar_cmp(args_raw, "") == 0 { return [] }
    return split_top_level(args_raw, 44 as u8)
}

fn is_integer_literal_text(text: ref u8) bool = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    if len == 0 { return false }
    val i: mut i64 = 0
    val first: u8 = trust @load8(trimmed as ref void) as u8
    if first == 45 || first == 43 { i = 1 }
    if i >= len { return false }
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if !(c >= 48 && c <= 57) { return false }
        i++
    }
    return true
}

fn is_float_literal_text(text: ref u8) bool = {
    val trimmed: ref u8 = trim_raw(text)
    return str_contains(trimmed, ".") && !is_string_literal_text(trimmed)
}

fn infer_called_arg_type(ctx: ref TranslationCtx, text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    if string.rchar_cmp(trimmed, "NULL") == 0 || string.rchar_cmp(trimmed, "0") == 0 { return "ref void" }
    if string.rchar_starts_with(trimmed, "@addr(") { return "ref void" }
    if is_string_literal_text(trimmed) { return "ref u8" }
    if is_integer_literal_text(trimmed) { return "i32" }
    if is_float_literal_text(trimmed) { return "f64" }
    if is_ident_text(trimmed) {
        match lookup_local_type(ctx, trimmed) {
            some type_name => { return type_name as ref u8 }
            none => {}
        }
        return "ref void"
    }
    val index_target: ref u8 = parse_index_target(trimmed)
    if string.rchar_cmp(index_target, "") != 0 {
        val elem_type: ref u8 = lookup_index_element_type(ctx, index_target)
        if string.rchar_cmp(elem_type, "") != 0 { return elem_type }
    }
    return "ref void"
}

fn remember_called_signature(ctx: ref TranslationCtx, call_name: ref u8, args: list[ref u8]) void = {
    val sb: ref void = string.StringBuilder.new()
    val first: mut bool = true
    val len: i64 = @len(args) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val arg_opt = @get(args, i as usize)
        match arg_opt {
            some arg_val => {
                if !first { string.StringBuilder.append_cstr(sb, ", ") }
                val arg_type: ref u8 = infer_called_arg_type(ctx, arg_val as ref u8)
                string.StringBuilder.append_cstr(sb, trust @fmt("arg{d}: {s}", {i, arg_type}))
                first = false
            }
            none => {}
        }
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    val params_text: ref u8 = trust string.cstr(built)
    val sig_len: i64 = @len(ctx.called_sig_names) as i64
    val sig_i: mut i64 = 0
    for {
        if sig_i >= sig_len { break }
        val name_opt = @get(ctx.called_sig_names, sig_i as usize)
        match name_opt {
            some name_val => {
                if string.rchar_cmp(name_val as ref u8, call_name) == 0 {
                    val existing_opt = @get(ctx.called_sig_params, sig_i as usize)
                    match existing_opt {
                        some existing_val => {
                            if string.len_raw(existing_val as ref u8) < string.len_raw(params_text) {
                                @set(ctx.called_sig_params, sig_i as usize, params_text)
                            }
                        }
                        none => { @set(ctx.called_sig_params, sig_i as usize, params_text) }
                    }
                    return
                }
            }
            none => {}
        }
        sig_i++
    }
    @append(ctx.called_sig_names, call_name)
    @append(ctx.called_sig_params, params_text)
}

fn lookup_called_signature(ctx: ref TranslationCtx, call_name: ref u8) option[ref u8] = {
    val len: i64 = @len(ctx.called_sig_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val name_opt = @get(ctx.called_sig_names, i as usize)
        match name_opt {
            some name_val => {
                if string.rchar_cmp(name_val as ref u8, call_name) == 0 {
                    val params_opt = @get(ctx.called_sig_params, i as usize)
                    match params_opt {
                        some params_val => { return some params_val as ref u8 }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return none
}

fn track_called_expr(ctx: ref TranslationCtx, expr: ref u8) void = {
    val call_name: ref u8 = extract_call_name(expr)
    if string.rchar_cmp(call_name, "") != 0 && !string.rchar_starts_with(expr, "@") {
        push_unique(ctx.called_names, call_name)
        remember_called_signature(ctx, call_name, trust extract_call_args_text(expr))
    }
}

fn qualify_enum_constants(ctx: ref TranslationCtx, text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    val sb: ref void = string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if is_ident_start(c) {
            val start: i64 = i
            i++
            for {
                if i >= len { break }
                val cc: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                if !is_ident_part(cc) { break }
                i++
            }
            val ident: ref u8 = trust string.substr(trimmed, start, i - start)
            val prev_non_space: mut u8 = 0
            val j: mut i64 = start - 1
            for {
                if j < 0 { break }
                val pc: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                if !is_space(pc) {
                    prev_non_space = pc
                    break
                }
                j--
            }
            val sanitized_ident: ref u8 = sanitize_identifier(ident)
            if prev_non_space != 46 {
                match lookup_local_type(ctx, sanitized_ident) {
                    some _ => {}
                    none => {
                        match lookup_enum_constant_type(ctx, ident) {
                            some enum_type => {
                                string.StringBuilder.append_cstr(sb, trust @fmt("{s}.{s}", {enum_type as ref u8, sanitized_ident}))
                                continue
                            }
                            none => {}
                        }
                    }
                }
            }
            string.StringBuilder.append_cstr(sb, ident)
            continue
        }
        string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn rewrite_identifiers(text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    val sb: ref void = string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if is_ident_start(c) {
            val start: i64 = i
            i++
            for {
                if i >= len { break }
                val cc: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                if !is_ident_part(cc) { break }
                i++
            }
            val ident: ref u8 = trust string.substr(trimmed, start, i - start)
            val preceded_by_at: bool = start > 0
                && (trust @load8(@ptradd(trimmed as ref void, start - 1)) as u8) == 64
            if preceded_by_at && string.rchar_cmp(ident, "sizeof") == 0 {
                val j: mut i64 = i
                for {
                    if j >= len { break }
                    val ws: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                    if !is_space(ws) { break }
                    j++
                }
                if j < len && (trust @load8(@ptradd(trimmed as ref void, j)) as u8) == 40 {
                    val close_j: i64 = find_matching_delim(trimmed, j, 40 as u8, 41 as u8)
                    if close_j > j {
                        string.StringBuilder.append_cstr(sb, ident)
                        string.StringBuilder.append_cstr(sb, trust string.substr(trimmed, j, close_j - j + 1))
                        i = close_j + 1
                        continue
                    }
                }
            }
            if string.rchar_cmp(ident, "NULL") == 0 {
                string.StringBuilder.append_cstr(sb, "0")
                continue
            }
            string.StringBuilder.append_cstr(sb, sanitize_identifier(ident))
            continue
        }
        string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn replace_arrow_access(text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    val sb: ref void = string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c == 45 && i + 1 < len {
            val next: u8 = trust @load8(@ptradd(trimmed as ref void, i + 1)) as u8
            if next == 62 {
                string.StringBuilder.append_char(sb, 46)
                i += 2
                continue
            }
        }
        string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn is_probable_c_type(text: ref u8) bool = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    if len == 0 { return false }
    val first: u8 = trust @load8(@ptradd(trimmed as ref void, 0)) as u8
    if !is_ident_start(first) { return false }
    val saw_ident: mut bool = false
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if is_ident_part(c) {
            saw_ident = true
            i++
            continue
        }
        if is_space(c) || c == 42 {
            i++
            continue
        }
        return false
    }
    return saw_ident
}

fn is_known_c_type_name(ctx: ref TranslationCtx, text: ref u8) bool = {
    val trimmed: ref u8 = trim_raw(text)
    if string.rchar_cmp(trimmed, "") == 0 { return false }
    val no_stars_sb: ref void = string.StringBuilder.new()
    val len: i64 = string.len_raw(trimmed)
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c != 42 {
            string.StringBuilder.append_char(no_stars_sb, c)
        }
        i++
    }
    val no_stars_built: ref void = string.StringBuilder.build(no_stars_sb)
    string.StringBuilder.free(no_stars_sb)
    val base: ref u8 = trim_raw(trust string.cstr(no_stars_built))
    if string.rchar_cmp(base, "void") == 0               { return true }
    if string.rchar_cmp(base, "u8") == 0               { return true }
    if string.rchar_cmp(base, "short") == 0              { return true }
    if string.rchar_cmp(base, "int") == 0                { return true }
    if string.rchar_cmp(base, "long") == 0               { return true }
    if string.rchar_cmp(base, "long long") == 0          { return true }
    if string.rchar_cmp(base, "unsigned u8") == 0      { return true }
    if string.rchar_cmp(base, "unsigned short") == 0     { return true }
    if string.rchar_cmp(base, "unsigned") == 0           { return true }
    if string.rchar_cmp(base, "unsigned int") == 0       { return true }
    if string.rchar_cmp(base, "unsigned long") == 0      { return true }
    if string.rchar_cmp(base, "unsigned long long") == 0 { return true }
    if string.rchar_cmp(base, "float") == 0              { return true }
    if string.rchar_cmp(base, "double") == 0             { return true }
    if string.rchar_cmp(base, "_Bool") == 0              { return true }
    if string.rchar_cmp(base, "bool") == 0               { return true }
    if string.rchar_cmp(base, "size_t") == 0             { return true }
    if string.rchar_cmp(base, "ssize_t") == 0            { return true }
    if string.rchar_cmp(base, "int8_t") == 0             { return true }
    if string.rchar_cmp(base, "uint8_t") == 0            { return true }
    if string.rchar_cmp(base, "int16_t") == 0            { return true }
    if string.rchar_cmp(base, "uint16_t") == 0           { return true }
    if string.rchar_cmp(base, "int32_t") == 0            { return true }
    if string.rchar_cmp(base, "uint32_t") == 0           { return true }
    if string.rchar_cmp(base, "int64_t") == 0            { return true }
    if string.rchar_cmp(base, "uint64_t") == 0           { return true }
    if string.rchar_cmp(base, "intptr_t") == 0           { return true }
    if string.rchar_cmp(base, "uintptr_t") == 0          { return true }
    if string.rchar_starts_with(base, "struct ")         { return true }
    if string.rchar_starts_with(base, "enum ")           { return true }
    if string.rchar_starts_with(base, "union ")          { return true }
    return list_contains(ctx.translated_type_names, base)
}

fn is_ident_text(text: ref u8) bool = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    if len == 0 { return false }
    val first: u8 = trust @load8(@ptradd(trimmed as ref void, 0)) as u8
    if !is_ident_start(first) { return false }
    val i: mut i64 = 1
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if !is_ident_part(c) { return false }
        i++
    }
    return true
}

fn parse_index_target(text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val open_i: i64 = find_char(trimmed, 91 as u8)
    val close_i: i64 = find_last_char(trimmed, 93 as u8)
    if open_i <= 0 || close_i <= open_i { return "" }
    return trim_raw(trust string.substr(trimmed, 0, open_i))
}

fn parse_index_expr(text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val open_i: i64 = find_char(trimmed, 91 as u8)
    val close_i: i64 = find_last_char(trimmed, 93 as u8)
    if open_i <= 0 || close_i <= open_i { return "" }
    return trim_raw(trust string.substr(trimmed, open_i + 1, close_i - open_i - 1))
}

fn lookup_index_element_type(ctx: ref TranslationCtx, base: ref u8) ref u8 = {
    if !is_ident_text(base) { return "" }
    match lookup_local_type(ctx, base) {
        some type_name => {
            val t: ref u8 = trim_raw(type_name as ref u8)
            if string.rchar_starts_with(t, "ref ") {
                return trim_raw(trust string.substr(t, 4, string.len_raw(t) - 4))
            }
            if is_array_type_name(t) {
                return decay_array_type(t)
            }
        }
        none => {}
    }
    return ""
}

fn render_index_ptr_expr(ctx: ref TranslationCtx, base: ref u8, index_expr: ref u8) ref u8 = {
    val elem_type: ref u8 = lookup_index_element_type(ctx, base)
    if string.rchar_cmp(elem_type, "") == 0 {
        return trust @fmt("@ptradd({s}, {s})", {base, index_expr})
    }
    return trust @fmt("@ptradd({s}, ({s}) * @sizeof({s}))", {base, index_expr, elem_type})
}

fn replace_pointer_indexing(ctx: ref TranslationCtx, text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    val sb: ref void = string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if is_ident_start(c) {
            val start: i64 = i
            i++
            for {
                if i >= len { break }
                val cc: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                if !is_ident_part(cc) { break }
                i++
            }
            val chain_end: mut i64 = i
            for {
                if chain_end >= len { break }
                val dot: u8 = trust @load8(@ptradd(trimmed as ref void, chain_end)) as u8
                if dot != 46 || chain_end + 1 >= len { break }
                val next0: u8 = trust @load8(@ptradd(trimmed as ref void, chain_end + 1)) as u8
                if !is_ident_start(next0) { break }
                chain_end += 2
                for {
                    if chain_end >= len { break }
                    val cc_chain: u8 = trust @load8(@ptradd(trimmed as ref void, chain_end)) as u8
                    if !is_ident_part(cc_chain) { break }
                    chain_end++
                }
            }
            val ident: ref u8 = trust string.substr(trimmed, start, chain_end - start)
            i = chain_end
            if i < len {
                val next: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                if next == 91 {
                    val close_i: mut i64 = i + 1
                    val depth: mut i64 = 1
                    for {
                        if close_i >= len { break }
                        val bc: u8 = trust @load8(@ptradd(trimmed as ref void, close_i)) as u8
                        if bc == 91 { depth++ }
                        elif bc == 93 {
                            depth--
                            if depth == 0 { break }
                        }
                        close_i++
                    }
                    if close_i < len {
                        val inner: ref u8 = trim_raw(trust string.substr(trimmed, i + 1, close_i - i - 1))
                        val index_ptr: ref u8 = render_index_ptr_expr(ctx, ident, inner)
                        string.StringBuilder.append_cstr(sb, trust @fmt("@load({s})", {index_ptr}))
                        i = close_i + 1
                        continue
                    }
                }
            }
            string.StringBuilder.append_cstr(sb, ident)
            continue
        }
        string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn ensure_intrinsic_prefixes(text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    val names: list[ref u8] = ["load", "store", "ptradd", "sizeof", "alloc", "free"]
    val sb: ref void = string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val matched: mut bool = false
        for name in names {
            val nlen: i64 = string.len_raw(name)
            if i + nlen + 1 > len { continue }
            val frag: ref u8 = trust string.substr(trimmed, i, nlen)
            if string.rchar_cmp(frag, name) != 0 { continue }
            val prev_ok: bool = i == 0 || !is_ident_part(trust @load8(@ptradd(trimmed as ref void, i - 1)) as u8)
            val nextc: u8 = trust @load8(@ptradd(trimmed as ref void, i + nlen)) as u8
            val already_intrinsic: bool = i > 0 && (trust @load8(@ptradd(trimmed as ref void, i - 1)) as u8) == 64
            if prev_ok && !already_intrinsic && nextc == 40 {
                string.StringBuilder.append_char(sb, 64)
                string.StringBuilder.append_cstr(sb, name)
                i += nlen
                matched = true
                break
            }
        }
        if matched { continue }
        string.StringBuilder.append_char(sb, trust @load8(@ptradd(trimmed as ref void, i)) as u8)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn normalize_intrinsic_prefixes(text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    val names: list[ref u8] = ["load", "store", "ptradd", "sizeof", "alloc", "free"]
    val sb: ref void = string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c == 64 {
            val at_start: i64 = i
            for {
                if i < len && (trust @load8(@ptradd(trimmed as ref void, i)) as u8) == 64 {
                    i++
                    continue
                }
                break
            }
            val matched: mut bool = false
            for name in names {
                val nlen: i64 = string.len_raw(name)
                if i + nlen > len { continue }
                val frag: ref u8 = trust string.substr(trimmed, i, nlen)
                if string.rchar_cmp(frag, name) != 0 { continue }
                if i + nlen < len && (trust @load8(@ptradd(trimmed as ref void, i + nlen)) as u8) == 40 {
                    string.StringBuilder.append_char(sb, 64)
                    string.StringBuilder.append_cstr(sb, name)
                    i += nlen
                    matched = true
                    break
                }
            }
            if matched { continue }
            val j: mut i64 = at_start
            for {
                if j >= i { break }
                string.StringBuilder.append_char(sb, 64)
                j++
            }
            continue
        }
        string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn scan_deref_operand_end(text: ref u8, start: i64) i64 = {
    val len: i64 = string.len_raw(text)
    if start < 0 || start >= len { return start }
    val first: u8 = trust @load8(@ptradd(text as ref void, start)) as u8
    val i: mut i64 = start
    if is_ident_start(first) {
        i++
        for {
            if i >= len { break }
            val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
            if !is_ident_part(c) { break }
            i++
        }
    } elif first == 40 {
        val close_i: i64 = find_matching_delim(text, start, 40 as u8, 41 as u8)
        if close_i <= start { return start }
        i = close_i + 1
    } else {
        return start
    }
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == 91 {
            val close_b: i64 = find_matching_delim(text, i, 91 as u8, 93 as u8)
            if close_b <= i { break }
            i = close_b + 1
            continue
        }
        if c == 46 {
            val j: mut i64 = i + 1
            if j >= len { break }
            val first2: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
            if !is_ident_start(first2) { break }
            j++
            for {
                if j >= len { break }
                val cc: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
                if !is_ident_part(cc) { break }
                j++
            }
            i = j
            continue
        }
        if i + 1 < len {
            val c2: u8 = trust @load8(@ptradd(text as ref void, i + 1)) as u8
            if c == 45 && c2 == 62 {
                val j2: mut i64 = i + 2
                if j2 >= len { break }
                val first3: u8 = trust @load8(@ptradd(text as ref void, j2)) as u8
                if !is_ident_start(first3) { break }
                j2++
                for {
                    if j2 >= len { break }
                    val cc2: u8 = trust @load8(@ptradd(text as ref void, j2)) as u8
                    if !is_ident_part(cc2) { break }
                    j2++
                }
                i = j2
                continue
            }
            if ((c == 43 && c2 == 43) || (c == 45 && c2 == 45)) {
                i += 2
                continue
            }
        }
        break
    }
    return i
}

fn is_unary_deref_context(text: ref u8, star_i: i64) bool = {
    val j: mut i64 = star_i - 1
    for {
        if j < 0 { return true }
        val c: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
        if !is_space(c) { break }
        j--
    }
    if j < 0 { return true }
    val prev: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
    if prev == 40 || prev == 44 || prev == 61 || prev == 33 || prev == 126 || prev == 63 || prev == 58 {
        return true
    }
    if prev == 43 || prev == 45 || prev == 42 || prev == 47 || prev == 37 || prev == 38 || prev == 124 || prev == 94 {
        return true
    }
    if prev == 60 || prev == 62 || prev == 123 || prev == 91 {
        return true
    }
    if is_ident_part(prev) {
        val end_i: i64 = j
        for {
            if j < 0 { break }
            val c2: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
            if !is_ident_part(c2) { break }
            j--
        }
        val word: ref u8 = trust string.substr(text, j + 1, end_i - j)
        if string.rchar_cmp(word, "return") == 0 { return true }
        if string.rchar_cmp(word, "if") == 0 { return true }
        if string.rchar_cmp(word, "while") == 0 { return true }
        if string.rchar_cmp(word, "for") == 0 { return true }
        if string.rchar_cmp(word, "case") == 0 { return true }
        if string.rchar_cmp(word, "switch") == 0 { return true }
        if string.rchar_cmp(word, "sizeof") == 0 { return true }
    }
    return false
}

fn translate_addr_deref_expr(ctx: ref TranslationCtx, text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    val sb: ref void = string.StringBuilder.new()
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if in_string {
            string.StringBuilder.append_char(sb, c)
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 34 {
                in_string = false
            }
            i++
            continue
        }
        if in_char {
            string.StringBuilder.append_char(sb, c)
            if escaped {
                escaped = false
            } elif c == 92 {
                escaped = true
            } elif c == 39 {
                in_char = false
            }
            i++
            continue
        }
        if c == 34 {
            in_string = true
            string.StringBuilder.append_char(sb, c)
            i++
            continue
        }
        if c == 39 {
            in_char = true
            string.StringBuilder.append_char(sb, c)
            i++
            continue
        }
        if c == 40 {
            val close_group: i64 = find_matching_delim(trimmed, i, 40 as u8, 41 as u8)
            val j0: mut i64 = i + 1
            for {
                if j0 >= len { break }
                val ws0: u8 = trust @load8(@ptradd(trimmed as ref void, j0)) as u8
                if !is_space(ws0) { break }
                j0++
            }
            if j0 < len && (trust @load8(@ptradd(trimmed as ref void, j0)) as u8) == 42 && close_group > j0 {
                val inner_start: mut i64 = j0 + 1
                for {
                    if inner_start >= close_group { break }
                    val ws1: u8 = trust @load8(@ptradd(trimmed as ref void, inner_start)) as u8
                    if !is_space(ws1) { break }
                    inner_start++
                }
                val inner_text: ref u8 = trim_raw(trust string.substr(trimmed, inner_start, close_group - inner_start))
                val translated_inner: ref u8 = translate_addr_deref_expr(ctx, inner_text)
                val after_group: mut i64 = close_group + 1
                for {
                    if after_group >= len { break }
                    val ws2: u8 = trust @load8(@ptradd(trimmed as ref void, after_group)) as u8
                    if !is_space(ws2) { break }
                    after_group++
                }
                if after_group + 1 < len {
                    val p1: u8 = trust @load8(@ptradd(trimmed as ref void, after_group)) as u8
                    val p2: u8 = trust @load8(@ptradd(trimmed as ref void, after_group + 1)) as u8
                    if ((p1 == 43 && p2 == 43) || (p1 == 45 && p2 == 45)) {
                        string.StringBuilder.append_cstr(sb, trust @fmt("@deref({s}){c}{c}", {translated_inner, p1, p2}))
                        i = after_group + 2
                        continue
                    }
                }
                string.StringBuilder.append_cstr(sb, trust @fmt("@deref({s})", {translated_inner}))
                i = close_group + 1
                continue
            }
        }
        if c == 38 {
            val prev: mut u8 = 0
            val next: mut u8 = 0
            if i > 0 { prev = trust @load8(@ptradd(trimmed as ref void, i - 1)) as u8 }
            if i + 1 < len { next = trust @load8(@ptradd(trimmed as ref void, i + 1)) as u8 }
            if prev != 38 && next != 38 {
                val j: mut i64 = i + 1
                for {
                    if j >= len { break }
                    val ws: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                    if !is_space(ws) { break }
                    j++
                }
                if j < len {
                    val first: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                    if is_ident_start(first) {
                        val start_i: i64 = j
                        j++
                        for {
                            if j >= len { break }
                            val cc: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                            if !is_ident_part(cc) { break }
                            j++
                        }
                        string.StringBuilder.append_cstr(sb, rewrite_identifiers(trust string.substr(trimmed, start_i, j - start_i)))
                        i = j
                        continue
                    }
                }
            }
        }
        if c == 42 {
            if is_unary_deref_context(trimmed, i) {
                val j2: mut i64 = i + 1
                for {
                    if j2 >= len { break }
                    val ws2: u8 = trust @load8(@ptradd(trimmed as ref void, j2)) as u8
                    if !is_space(ws2) { break }
                    j2++
                }
                if j2 < len {
                    val operand_end: i64 = scan_deref_operand_end(trimmed, j2)
                    if operand_end > j2 {
                        val operand_text: ref u8 = translate_addr_deref_expr(ctx, trim_raw(trust string.substr(trimmed, j2, operand_end - j2)))
                        string.StringBuilder.append_cstr(sb, trust @fmt("@deref({s})", {operand_text}))
                        i = operand_end
                        continue
                    }
                }
            }
        }
        string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn is_printf_length_char(c: u8) bool = {
    return c == 104 || c == 108 || c == 122 || c == 116 || c == 106 || c == 76
}

fn map_printf_specifier(length_mod: ref u8, specifier: u8) ref u8 = {
    val is_size_mod: bool = string.rchar_cmp(length_mod, "z") == 0
        || string.rchar_cmp(length_mod, "t") == 0
        || string.rchar_cmp(length_mod, "j") == 0
    if is_size_mod && (specifier == 105 || specifier == 100 || specifier == 117) { return "d" }
    if is_size_mod && (specifier == 120 || specifier == 88 || specifier == 111) { return trust @fmt("{c}", {specifier}) }
    if specifier == 105 { return trust @fmt("{s}d", {length_mod}) }
    if specifier == 100 { return trust @fmt("{s}d", {length_mod}) }
    if specifier == 117 { return trust @fmt("{s}u", {length_mod}) }
    if specifier == 120 { return trust @fmt("{s}x", {length_mod}) }
    if specifier == 88 { return trust @fmt("{s}X", {length_mod}) }
    if specifier == 111 { return trust @fmt("{s}o", {length_mod}) }
    if specifier == 99 { return "c" }
    if specifier == 115 { return "s" }
    if specifier == 112 { return "p" }
    if specifier == 102 || specifier == 70 || specifier == 101 || specifier == 69 || specifier == 103 || specifier == 71 || specifier == 97 || specifier == 65 {
        return "f"
    }
    return trust @fmt("{c}", {specifier})
}

fn translate_printf_format(text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    if len < 2 { return trimmed }
    val first: u8 = trust @load8(@ptradd(trimmed as ref void, 0)) as u8
    val last: u8 = trust @load8(@ptradd(trimmed as ref void, len - 1)) as u8
    if first != 34 || last != 34 { return trimmed }
    val sb: ref void = string.StringBuilder.new()
    string.StringBuilder.append_char(sb, 34)
    val i: mut i64 = 1
    for {
        if i >= len - 1 { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c == 37 && i + 1 < len - 1 {
            val next: u8 = trust @load8(@ptradd(trimmed as ref void, i + 1)) as u8
            if next == 37 {
                string.StringBuilder.append_char(sb, 37)
                i += 2
                continue
            }
            val spec_i: mut i64 = i + 1
            for {
                if spec_i >= len - 1 { break }
                val flag: u8 = trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8
                if flag != 45 && flag != 43 && flag != 32 && flag != 35 && flag != 48 {
                    break
                }
                spec_i++
            }
            for {
                if spec_i >= len - 1 { break }
                val width: u8 = trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8
                if !((width >= 48 && width <= 57) || width == 42) { break }
                spec_i++
            }
            if spec_i < len - 1 && (trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8) == 46 {
                spec_i++
                for {
                    if spec_i >= len - 1 { break }
                    val prec: u8 = trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8
                    if !((prec >= 48 && prec <= 57) || prec == 42) { break }
                    spec_i++
                }
            }
            val length_sb: ref void = string.StringBuilder.new()
            for {
                if spec_i >= len - 1 { break }
                val lm: u8 = trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8
                if !is_printf_length_char(lm) { break }
                string.StringBuilder.append_char(length_sb, lm)
                spec_i++
            }
            if spec_i < len - 1 {
                val specifier: u8 = trust @load8(@ptradd(trimmed as ref void, spec_i)) as u8
                val length_built: ref void = string.StringBuilder.build(length_sb)
                string.StringBuilder.free(length_sb)
                val mapped: ref u8 = map_printf_specifier(trust string.cstr(length_built), specifier)
                string.StringBuilder.append_char(sb, 123)
                string.StringBuilder.append_cstr(sb, mapped)
                string.StringBuilder.append_char(sb, 125)
                i = spec_i + 1
                continue
            }
            string.StringBuilder.free(length_sb)
        }
        string.StringBuilder.append_char(sb, c)
        i++
    }
    string.StringBuilder.append_char(sb, 34)
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn translate_printf_call(ctx: ref TranslationCtx, args: list[ref u8]) ref u8 = {
    val fmt_opt = @get(args, 0)
    val fmt_expr: mut ref u8 = "\"\""
    match fmt_opt {
        some fmt_val => { fmt_expr = translate_printf_format(translate_expr_text(ctx, fmt_val as ref u8)) }
        none => {}
    }
    val sb: ref void = string.StringBuilder.new()
    string.StringBuilder.append_char(sb, 123)
    val first: mut bool = true
    val idx: mut i64 = 1
    val len: i64 = @len(args) as i64
    for {
        if idx >= len { break }
        val arg_opt = @get(args, idx as usize)
        match arg_opt {
            some arg_val => {
                if !first { string.StringBuilder.append_cstr(sb, ", ") }
                string.StringBuilder.append_cstr(sb, translate_expr_text(ctx, arg_val as ref u8))
                first = false
            }
            none => {}
        }
        idx++
    }
    string.StringBuilder.append_char(sb, 125)
    val args_built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust @fmt("@print({s}, {s})", {fmt_expr, string.cstr(args_built)})
}

fn translate_variadic_args(ctx: ref TranslationCtx, args: list[ref u8], start_index: i64) ref u8 = {
    val sb: ref void = string.StringBuilder.new()
    string.StringBuilder.append_char(sb, 123)
    val first: mut bool = true
    val idx: mut i64 = start_index
    val len: i64 = @len(args) as i64
    for {
        if idx >= len { break }
        val arg_opt = @get(args, idx as usize)
        match arg_opt {
            some arg_val => {
                if !first { string.StringBuilder.append_cstr(sb, ", ") }
                string.StringBuilder.append_cstr(sb, translate_expr_text(ctx, arg_val as ref u8))
                first = false
            }
            none => {}
        }
        idx++
    }
    string.StringBuilder.append_char(sb, 125)
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn translate_stream_fd_expr(ctx: ref TranslationCtx, text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    if string.rchar_cmp(trimmed, "stdin") == 0 { return "0" }
    if string.rchar_cmp(trimmed, "stdout") == 0 { return "1" }
    if string.rchar_cmp(trimmed, "stderr") == 0 { return "2" }
    return translate_expr_text(ctx, trimmed)
}

fn translate_fprintf_call(ctx: ref TranslationCtx, args: list[ref u8]) ref u8 = {
    val stream_opt = @get(args, 0)
    val fmt_opt = @get(args, 1)
    match stream_opt {
        none => { return "/* unsupported fprintf */" }
        some stream_val => {
            match fmt_opt {
                none => { return "/* unsupported fprintf */" }
                some fmt_val => {
                    val fd_expr: ref u8 = translate_stream_fd_expr(ctx, stream_val as ref u8)
                    val fmt_expr: ref u8 = translate_printf_format(translate_expr_text(ctx, fmt_val as ref u8))
                    val varargs: ref u8 = translate_variadic_args(ctx, args, 2)
                    return trust @fmt("@dprintf({s}, {s}, {s})", {fd_expr, fmt_expr, varargs})
                }
            }
        }
    }
}

fn transform_call_expr(ctx: ref TranslationCtx, text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val open_i: i64 = find_char(trimmed, 40 as u8)
    val close_i: i64 = find_matching_delim(trimmed, open_i, 40 as u8, 41 as u8)
    if open_i <= 0 || close_i <= open_i { return trimmed }
    val call_name: ref u8 = extract_identifier_before(trimmed, open_i)
    if string.rchar_cmp(call_name, "") == 0 { return trimmed }
    val call_start: i64 = open_i - string.len_raw(call_name)
    if call_start < 0 { return trimmed }
    val prefix_text: ref u8 = trim_raw(trust string.substr(trimmed, 0, call_start))
    if !(string.rchar_cmp(prefix_text, "") == 0 || string.rchar_cmp(prefix_text, "@") == 0) {
        return trimmed
    }
    if close_i != string.len_raw(trimmed) - 1 { return trimmed }
    val intrinsic_prefix: mut ref u8 = ""
    if string.rchar_starts_with(trimmed, "@") { intrinsic_prefix = "@" }
    val args_raw: ref u8 = trim_raw(trust string.substr(trimmed, open_i + 1, close_i - open_i - 1))
    val args = split_top_level(args_raw, 44 as u8)
    if string.rchar_cmp(call_name, "printf") == 0 {
        return translate_printf_call(ctx, args)
    }
    if string.rchar_cmp(call_name, "fprintf") == 0 {
        return translate_fprintf_call(ctx, args)
    }
    val sb: ref void = string.StringBuilder.new()
    val first: mut bool = true
    for arg in args {
        val arg_trimmed: ref u8 = trim_raw(arg)
        if !first { string.StringBuilder.append_cstr(sb, ", ") }
        if is_ident_text(arg_trimmed) && list_contains(ctx.defined_names, arg_trimmed) {
            string.StringBuilder.append_cstr(sb, trust @fmt("@addr({s})", {arg_trimmed}))
        } else {
            string.StringBuilder.append_cstr(sb, translate_expr_text(ctx, arg_trimmed))
        }
        first = false
    }
    val args_built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    val args_text: ref u8 = trust string.cstr(args_built)
    if string.rchar_cmp(call_name, "sizeof") == 0 {
        return trust @fmt("@sizeof({s})", {args_text})
    }
    if string.rchar_cmp(call_name, "malloc") == 0 {
        return trust @fmt("@alloc({s})", {args_text})
    }
    if list_contains(ctx.fnptr_names, call_name) {
        return trust @fmt("@call({s}, {s})", {call_name, args_text})
    }
    return trust @fmt("{s}{s}({s})", {intrinsic_prefix, call_name, args_text})
}

fn find_top_level_ternary(text: ref u8) i64 = {
    val len: i64 = string.len_raw(text)
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == 40 { paren++ }
        elif c == 41 && paren > 0 { paren-- }
        elif c == 123 { brace++ }
        elif c == 125 && brace > 0 { brace-- }
        elif c == 91 { bracket++ }
        elif c == 93 && bracket > 0 { bracket-- }
        elif c == 63 && paren == 0 && brace == 0 && bracket == 0 {
            return i
        }
        i++
    }
    return -1
}

fn find_matching_colon_for_ternary(text: ref u8, q_index: i64) i64 = {
    val len: i64 = string.len_raw(text)
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val ternary_depth: mut i64 = 0
    val i: mut i64 = q_index + 1
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == 40 { paren++ }
        elif c == 41 && paren > 0 { paren-- }
        elif c == 123 { brace++ }
        elif c == 125 && brace > 0 { brace-- }
        elif c == 91 { bracket++ }
        elif c == 93 && bracket > 0 { bracket-- }
        elif c == 63 && paren == 0 && brace == 0 && bracket == 0 {
            ternary_depth++
        } elif c == 58 && paren == 0 && brace == 0 && bracket == 0 {
            if ternary_depth == 0 { return i }
            ternary_depth--
        }
        i++
    }
    return -1
}

fn is_wrapped_in_parens(text: ref u8) bool = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    if len < 2 { return false }
    val first: u8 = trust @load8(@ptradd(trimmed as ref void, 0)) as u8
    val last: u8 = trust @load8(@ptradd(trimmed as ref void, len - 1)) as u8
    if first != 40 || last != 41 { return false }
    val depth: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c == 40 { depth++ }
        elif c == 41 {
            depth--
            if depth == 0 && i != len - 1 {
                return false
            }
        }
        i++
    }
    return depth == 0
}

fn unwrap_outer_parens(text: ref u8) ref u8 = {
    val current: mut ref u8 = trim_raw(text)
    for {
        if !is_wrapped_in_parens(current) { break }
        val len: i64 = string.len_raw(current)
        current = trim_raw(trust string.substr(current, 1, len - 2))
    }
    return current
}

fn collect_brace_block(lines: list[ref u8], start: i64) ref BlockResult = {
    val len: i64 = @len(lines) as i64
    val brace_depth: mut i64 = 0
    val seen_open: mut bool = false
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                val line: ref u8 = line_val as ref u8
                val llen: i64 = string.len_raw(line)
                val j: mut i64 = 0
                for {
                    if j >= llen { break }
                    val c: u8 = trust @load8(@ptradd(line as ref void, j)) as u8
                    if c == 123 {
                        brace_depth++
                        seen_open = true
                    } elif c == 125 && brace_depth > 0 {
                        brace_depth--
                        if seen_open && brace_depth == 0 {
                            return make_block_result(i + 1, STOP_EOF, "")
                        }
                    }
                    j++
                }
            }
            none => {}
        }
        i++
    }
    return make_block_result(i, STOP_EOF, "")
}

fn translate_for_loop(lines: list[ref u8], current_dir: ref u8, start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val line_opt = @get(lines, start as usize)
    match line_opt {
        none => { return make_block_result(start + 1, STOP_EOF, "") }
        some line_val => {
            val line: ref u8 = trim_raw(line_val as ref u8)
            val open_i: i64 = find_char(line, 40 as u8)
            val close_i: i64 = find_matching_delim(line, open_i, 40 as u8, 41 as u8)
            if open_i < 0 || close_i <= open_i {
                append_comment_line(out, indent, line)
                return make_block_result(start + 1, STOP_EOF, "")
            }
            val inside: ref u8 = trim_raw(trust string.substr(line, open_i + 1, close_i - open_i - 1))
            val tail: ref u8 = trim_raw(trust string.substr(line, close_i + 1, string.len_raw(line) - close_i - 1))
            val parts = split_top_level(inside, 59 as u8)
            val init: mut ref u8 = ""
            val cond: mut ref u8 = ""
            val postc: mut ref u8 = ""
            val p0 = @get(parts, 0)
            match p0 { some v => { init = trim_raw(v as ref u8) } none => {} }
            val p1 = @get(parts, 1)
            match p1 { some v => { cond = trim_raw(v as ref u8) } none => {} }
            val p2 = @get(parts, 2)
            match p2 { some v => { postc = trim_raw(v as ref u8) } none => {} }
            if string.rchar_cmp(init, "") != 0 {
                translate_inline_statement(ctx, init, indent, out)
            }
            append_line(out, indent, "for {")
            val body_indent: mut i64 = indent + 1
            val next_i: mut i64 = start + 1
            if string.rchar_cmp(cond, "") != 0 {
                val cond_out: ref void = string.StringBuilder.new()
                val cond_text: ref u8 = translate_condition_text(ctx, cond, indent + 1, cond_out)
                append_builder(out, cond_out)
                append_line(out, indent + 1, trust @fmt("if ({s}) {", {cond_text}))
                body_indent = indent + 2
            }
            if string.rchar_cmp(tail, "") != 0 {
                if string.rchar_starts_with(tail, "{") {
                    val body_span: ref BlockResult = translate_brace_block(lines, start, body_indent, out, ctx)
                    next_i = body_span.next_index
                } else {
                    translate_inline_statement(ctx, tail, body_indent, out)
                }
            } else {
                val next_body_i: i64 = next_significant_line(lines, start + 1)
                if next_body_i >= 0 {
                    val next_opt = @get(lines, next_body_i as usize)
                    match next_opt {
                        some next_line => {
                            val next_trimmed: ref u8 = trim_raw(next_line as ref u8)
                            if string.rchar_starts_with(next_trimmed, "{") {
                                val body_span2: ref BlockResult = translate_brace_block(lines, next_body_i, body_indent, out, ctx)
                                next_i = body_span2.next_index
                            } else {
                                val stmt_result: ref BlockResult = translate_statement_at(lines, current_dir, next_body_i, body_indent, out, ctx)
                                next_i = stmt_result.next_index
                            }
                        }
                        none => {}
                    }
                }
            }
            if string.rchar_cmp(postc, "") != 0 {
                translate_inline_statement(ctx, postc, body_indent, out)
            }
            if string.rchar_cmp(cond, "") != 0 {
                append_line(out, indent + 1, "} else {")
                append_line(out, indent + 2, "break")
                append_line(out, indent + 1, "}")
            }
            append_line(out, indent, "}")
            return make_block_result(next_i, STOP_EOF, "")
        }
    }
}

fn translate_while_loop(lines: list[ref u8], current_dir: ref u8, start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val line_opt = @get(lines, start as usize)
    match line_opt {
        none => { return make_block_result(start + 1, STOP_EOF, "") }
        some line_val => {
            val line: ref u8 = trim_raw(line_val as ref u8)
            val open_i: i64 = find_char(line, 40 as u8)
            val close_i: i64 = find_matching_delim(line, open_i, 40 as u8, 41 as u8)
            if open_i < 0 || close_i <= open_i {
                append_comment_line(out, indent, line)
                return make_block_result(start + 1, STOP_EOF, "")
            }
            val cond_src: ref u8 = trim_raw(trust string.substr(line, open_i + 1, close_i - open_i - 1))
            val tail: ref u8 = trim_raw(trust string.substr(line, close_i + 1, string.len_raw(line) - close_i - 1))
            val cond_out: ref void = string.StringBuilder.new()
            val cond_text: ref u8 = translate_condition_text(ctx, cond_src, indent + 1, cond_out)
            append_line(out, indent, "for {")
            append_builder(out, cond_out)
            append_line(out, indent + 1, trust @fmt("if ({s}) {", {cond_text}))
            val next_i: mut i64 = start + 1
            if string.rchar_cmp(tail, "") != 0 {
                if string.rchar_starts_with(tail, "{") {
                    val body_span: ref BlockResult = translate_brace_block(lines, start, indent + 2, out, ctx)
                    next_i = body_span.next_index
                } else {
                    translate_inline_statement(ctx, tail, indent + 2, out)
                }
            } else {
                val next_body_i: i64 = next_significant_line(lines, start + 1)
                if next_body_i >= 0 {
                    val next_opt = @get(lines, next_body_i as usize)
                    match next_opt {
                        some next_line => {
                            val next_trimmed: ref u8 = trim_raw(next_line as ref u8)
                            if string.rchar_starts_with(next_trimmed, "{") {
                                val body_span2: ref BlockResult = translate_brace_block(lines, next_body_i, indent + 2, out, ctx)
                                next_i = body_span2.next_index
                            } else {
                                val stmt_result: ref BlockResult = translate_statement_at(lines, current_dir, next_body_i, indent + 2, out, ctx)
                                next_i = stmt_result.next_index
                            }
                        }
                        none => {}
                    }
                }
            }
            append_line(out, indent + 1, "} else {")
            append_line(out, indent + 2, "break")
            append_line(out, indent + 1, "}")
            append_line(out, indent, "}")
            return make_block_result(next_i, STOP_EOF, "")
        }
    }
}

fn translate_brace_block(lines: list[ref u8], start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val span: ref BlockResult = collect_brace_block(lines, start)
    val full_text: ref u8 = join_lines(lines, start, span.next_index)
    val open_i: i64 = find_char(full_text, 123 as u8)
    val close_i: i64 = find_last_char(full_text, 125 as u8)
    if open_i < 0 || close_i <= open_i {
        append_comment_line(out, indent, trim_raw(full_text))
        return span
    }
    val body_text: ref u8 = trust string.substr(full_text, open_i + 1, close_i - open_i - 1)
    val body_lines = split_lines(body_text)
    translate_body_lines(body_lines, "", 0, indent, out, ctx)
    return span
}

fn translate_inline_statement(ctx: ref TranslationCtx, text: ref u8, indent: i64, out: ref void) void = {
    val trimmed: ref u8 = strip_trailing_semicolon(trim_raw(text))
    if string.rchar_cmp(trimmed, "") == 0 { return }
    if translate_body_statement(ctx, trimmed, indent, out) { return }
    append_comment_line(out, indent, trimmed)
}

fn translate_if_text(lines: list[ref u8], current_dir: ref u8, line_index: i64, if_text: ref u8, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val trimmed: ref u8 = trim_raw(if_text)
    val open_i: i64 = find_char(trimmed, 40 as u8)
    val close_i: i64 = find_matching_delim(trimmed, open_i, 40 as u8, 41 as u8)
    if open_i < 0 || close_i <= open_i {
        append_comment_line(out, indent, trimmed)
        return make_block_result(line_index + 1, STOP_EOF, "")
    }
    val cond_src: ref u8 = trim_raw(trust string.substr(trimmed, open_i + 1, close_i - open_i - 1))
    val cond_text: ref u8 = translate_condition_text(ctx, cond_src, indent, out)
    val tail: ref u8 = trim_raw(trust string.substr(trimmed, close_i + 1, string.len_raw(trimmed) - close_i - 1))
    append_line(out, indent, trust @fmt("if ({s}) {", {cond_text}))
    val next_i: mut i64 = line_index + 1
    if string.rchar_cmp(tail, "") != 0 {
        if string.rchar_starts_with(tail, "{") {
            val then_span: ref BlockResult = translate_brace_block(lines, line_index, indent + 1, out, ctx)
            next_i = then_span.next_index
        } else {
            translate_inline_statement(ctx, tail, indent + 1, out)
        }
    } else {
        val next_body_i: i64 = next_significant_line(lines, line_index + 1)
        if next_body_i >= 0 {
            val next_opt = @get(lines, next_body_i as usize)
            match next_opt {
                some next_line => {
                    val next_trimmed: ref u8 = trim_raw(next_line as ref u8)
                    if string.rchar_starts_with(next_trimmed, "{") {
                        val then_span2: ref BlockResult = translate_brace_block(lines, next_body_i, indent + 1, out, ctx)
                        next_i = then_span2.next_index
                    } else {
                        val stmt_result: ref BlockResult = translate_statement_at(lines, current_dir, next_body_i, indent + 1, out, ctx)
                        next_i = stmt_result.next_index
                    }
                }
                none => {}
            }
        }
    }
    val else_i: i64 = next_significant_line(lines, next_i)
    if else_i >= 0 {
        val else_opt = @get(lines, else_i as usize)
        match else_opt {
            some else_line => {
                val else_trimmed: ref u8 = trim_raw(else_line as ref u8)
                if string.rchar_starts_with(else_trimmed, "else") {
                    val else_tail: ref u8 = trim_raw(trust string.substr(else_trimmed, 4, string.len_raw(else_trimmed) - 4))
                    append_line(out, indent, "} else {")
                    if starts_keyword_paren(else_tail, "if") {
                        val nested_result: ref BlockResult = translate_if_text(lines, current_dir, else_i, else_tail, indent + 1, out, ctx)
                        append_line(out, indent, "}")
                        return make_block_result(nested_result.next_index, STOP_EOF, "")
                    }
                    if string.rchar_cmp(else_tail, "") != 0 {
                        if string.rchar_starts_with(else_tail, "{") {
                            val else_span: ref BlockResult = translate_brace_block(lines, else_i, indent + 1, out, ctx)
                            append_line(out, indent, "}")
                            return make_block_result(else_span.next_index, STOP_EOF, "")
                        }
                        translate_inline_statement(ctx, else_tail, indent + 1, out)
                        append_line(out, indent, "}")
                        return make_block_result(else_i + 1, STOP_EOF, "")
                    }
                    val else_body_i: i64 = next_significant_line(lines, else_i + 1)
                    if else_body_i >= 0 {
                        val else_body_opt = @get(lines, else_body_i as usize)
                        match else_body_opt {
                            some else_body_line => {
                                val else_body_trimmed: ref u8 = trim_raw(else_body_line as ref u8)
                                if string.rchar_starts_with(else_body_trimmed, "{") {
                                    val else_span2: ref BlockResult = translate_brace_block(lines, else_body_i, indent + 1, out, ctx)
                                    append_line(out, indent, "}")
                                    return make_block_result(else_span2.next_index, STOP_EOF, "")
                                }
                                val else_stmt_result: ref BlockResult = translate_statement_at(lines, current_dir, else_body_i, indent + 1, out, ctx)
                                append_line(out, indent, "}")
                                return make_block_result(else_stmt_result.next_index, STOP_EOF, "")
                            }
                            none => {}
                        }
                    }
                    append_line(out, indent, "}")
                    return make_block_result(else_i + 1, STOP_EOF, "")
                }
            }
            none => {}
        }
    }
    append_line(out, indent, "}")
    return make_block_result(next_i, STOP_EOF, "")
}

fn translate_if_statement(lines: list[ref u8], current_dir: ref u8, start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val line_opt = @get(lines, start as usize)
    match line_opt {
        some line_val => { return translate_if_text(lines, current_dir, start, trim_raw(line_val as ref u8), indent, out, ctx) }
        none => { return make_block_result(start + 1, STOP_EOF, "") }
    }
}

fn is_switch_break_line(text: ref u8) bool = {
    val trimmed: ref u8 = strip_trailing_semicolon(trim_raw(text))
    return string.rchar_cmp(trimmed, "break") == 0
}

fn render_switch_case_condition(ctx: ref TranslationCtx, switch_expr: ref u8, labels: list[ref u8]) ref u8 = {
    val sb: ref void = string.StringBuilder.new()
    val first: mut bool = true
    for label in labels {
        if !first { string.StringBuilder.append_cstr(sb, " || ") }
        string.StringBuilder.append_cstr(sb, trust @fmt("{s} == {s}", {switch_expr, translate_expr_text(ctx, label)}))
        first = false
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn translate_switch_statement(lines: list[ref u8], start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val line_opt = @get(lines, start as usize)
    match line_opt {
        none => { return make_block_result(start + 1, STOP_EOF, "") }
        some line_val => {
            val line: ref u8 = trim_raw(line_val as ref u8)
            val open_i: i64 = find_char(line, 40 as u8)
            val close_i: i64 = find_matching_delim(line, open_i, 40 as u8, 41 as u8)
            if open_i < 0 || close_i <= open_i {
                append_comment_line(out, indent, line)
                return make_block_result(start + 1, STOP_EOF, "")
            }
            val switch_expr: ref u8 = lower_incdec_expr(ctx, trim_raw(trust string.substr(line, open_i + 1, close_i - open_i - 1)), indent, out).expr
            val body_start: mut i64 = start
            val tail: ref u8 = trim_raw(trust string.substr(line, close_i + 1, string.len_raw(line) - close_i - 1))
            if !string.rchar_starts_with(tail, "{") {
                body_start = next_significant_line(lines, start + 1)
            }
            if body_start < 0 {
                append_comment_line(out, indent, line)
                return make_block_result(start + 1, STOP_EOF, "")
            }
            val span: ref BlockResult = collect_brace_block(lines, body_start)
            val full_text: ref u8 = join_lines(lines, body_start, span.next_index)
            val brace_i: i64 = find_char(full_text, 123 as u8)
            val close_b: i64 = find_last_char(full_text, 125 as u8)
            if brace_i < 0 || close_b <= brace_i {
                append_comment_line(out, indent, line)
                return span
            }
            val body_text: ref u8 = trust string.substr(full_text, brace_i + 1, close_b - brace_i - 1)
            val body_lines = split_lines(body_text)
            val cases: mut list[ref SwitchCase] = []
            val current: mut ref SwitchCase = 0 as ref SwitchCase
            for raw_line in body_lines {
                val trimmed: ref u8 = trim_raw(raw_line)
                if string.rchar_cmp(trimmed, "") == 0 {
                    if (current != 0 as ref SwitchCase) {
                        if ((@len(current.body_lines) as i64) > 0) {
                            @append(current.body_lines, raw_line)
                        }
                    }
                    continue
                }
                if string.rchar_starts_with(trimmed, "case ") {
                    val colon_i: i64 = find_char(trimmed, 58 as u8)
                    if colon_i > 5 {
                        val label: ref u8 = trim_raw(trust string.substr(trimmed, 5, colon_i - 5))
                        val tail2: ref u8 = trim_raw(trust string.substr(trimmed, colon_i + 1, string.len_raw(trimmed) - colon_i - 1))
                        if current != 0 as ref SwitchCase {
                            if !current.is_default && (@len(current.body_lines) as i64) == 0 {
                                @append(current.labels, label)
                                if string.rchar_cmp(tail2, "") != 0 && !is_switch_break_line(tail2) {
                                    @append(current.body_lines, tail2)
                                }
                                continue
                            }
                        }
                        if current != 0 as ref SwitchCase { @append(cases, current) }
                        current = make_switch_case()
                        @append(current.labels, label)
                        if string.rchar_cmp(tail2, "") != 0 && !is_switch_break_line(tail2) {
                            @append(current.body_lines, tail2)
                        }
                        continue
                    }
                }
                if string.rchar_starts_with(trimmed, "default:") {
                    val tail3: ref u8 = trim_raw(trust string.substr(trimmed, 8, string.len_raw(trimmed) - 8))
                    if current != 0 as ref SwitchCase { @append(cases, current) }
                    current = make_switch_case()
                    current.is_default = true
                    if string.rchar_cmp(tail3, "") != 0 && !is_switch_break_line(tail3) {
                        @append(current.body_lines, tail3)
                    }
                    continue
                }
                if current != 0 as ref SwitchCase {
                    if is_switch_break_line(trimmed) { continue }
                    @append(current.body_lines, raw_line)
                }
            }
            if current != 0 as ref SwitchCase { @append(cases, current) }
            val emitted_any: mut bool = false
            for case_item in cases {
                if case_item.is_default {
                    if emitted_any {
                        append_line(out, indent, "} else {")
                    } else {
                        append_line(out, indent, "if (true) {")
                    }
                } else {
                    val cond_text: ref u8 = render_switch_case_condition(ctx, switch_expr, case_item.labels)
                    if emitted_any {
                        append_line(out, indent, trust @fmt("} elif ({s}) {", {cond_text}))
                    } else {
                        append_line(out, indent, trust @fmt("if ({s}) {", {cond_text}))
                    }
                }
                translate_body_lines(case_item.body_lines, "", 0, indent + 1, out, ctx)
                emitted_any = true
            }
            if emitted_any {
                append_line(out, indent, "}")
            } else {
                append_comment_line(out, indent, line)
            }
            return span
        }
    }
}

fn translate_do_while_loop(lines: list[ref u8], start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val line_opt = @get(lines, start as usize)
    match line_opt {
        none => { return make_block_result(start + 1, STOP_EOF, "") }
        some line_val => {
            val line: ref u8 = trim_raw(line_val as ref u8)
            val body_start: mut i64 = start
            val tail_after_do: ref u8 = trim_raw(trust string.substr(line, 2, string.len_raw(line) - 2))
            if !string.rchar_starts_with(tail_after_do, "{") {
                body_start = next_significant_line(lines, start + 1)
            }
            if body_start < 0 {
                append_comment_line(out, indent, line)
                return make_block_result(start + 1, STOP_EOF, "")
            }
            val body_span: ref BlockResult = collect_brace_block(lines, body_start)
            val body_full: ref u8 = join_lines(lines, body_start, body_span.next_index)
            val brace_i: i64 = find_char(body_full, 123 as u8)
            val close_b: i64 = find_last_char(body_full, 125 as u8)
            if brace_i < 0 || close_b <= brace_i {
                append_comment_line(out, indent, line)
                return body_span
            }
            val while_line: mut ref u8 = trim_raw(trust string.substr(body_full, close_b + 1, string.len_raw(body_full) - close_b - 1))
            val next_i: mut i64 = body_span.next_index
            if !starts_keyword_paren(while_line, "while") {
                val while_i: i64 = next_significant_line(lines, body_span.next_index)
                if while_i < 0 {
                    append_comment_line(out, indent, line)
                    return body_span
                }
                val while_opt = @get(lines, while_i as usize)
                match while_opt {
                    some while_val => {
                        while_line = trim_raw(while_val as ref u8)
                        next_i = while_i + 1
                    }
                    none => {}
                }
            }
            val open_i: i64 = find_char(while_line, 40 as u8)
            val close_i: i64 = find_matching_delim(while_line, open_i, 40 as u8, 41 as u8)
            if open_i < 0 || close_i <= open_i {
                append_comment_line(out, indent, line)
                return make_block_result(next_i, STOP_EOF, "")
            }
            val cond_out: ref void = string.StringBuilder.new()
            val cond_text: ref u8 = translate_condition_text(ctx, trim_raw(trust string.substr(while_line, open_i + 1, close_i - open_i - 1)), indent + 1, cond_out)
            val body_text: ref u8 = trust string.substr(body_full, brace_i + 1, close_b - brace_i - 1)
            val body_lines = split_lines(body_text)
            append_line(out, indent, "for {")
            translate_body_lines(body_lines, "", 0, indent + 1, out, ctx)
            append_builder(out, cond_out)
            append_line(out, indent + 1, trust @fmt("if ({s}) {", {cond_text}))
            append_line(out, indent + 1, "} else {")
            append_line(out, indent + 2, "break")
            append_line(out, indent + 1, "}")
            append_line(out, indent, "}")
            return make_block_result(next_i, STOP_EOF, "")
        }
    }
}

fn translate_statement_at(lines: list[ref u8], current_dir: ref u8, start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val line_opt = @get(lines, start as usize)
    match line_opt {
        none => { return make_block_result(start + 1, STOP_EOF, "") }
        some line_val => {
            val trimmed: ref u8 = trim_raw(line_val as ref u8)
            if starts_keyword_paren(trimmed, "for") {
                return translate_for_loop(lines, current_dir, start, indent, out, ctx)
            }
            if starts_keyword_paren(trimmed, "while") {
                return translate_while_loop(lines, current_dir, start, indent, out, ctx)
            }
            if starts_keyword_paren(trimmed, "if") {
                return translate_if_statement(lines, current_dir, start, indent, out, ctx)
            }
            if starts_keyword_paren(trimmed, "switch") {
                return translate_switch_statement(lines, start, indent, out, ctx)
            }
            if starts_do_statement(trimmed) {
                return translate_do_while_loop(lines, start, indent, out, ctx)
            }
            if translate_body_statement(ctx, trimmed, indent, out) {
                return make_block_result(start + 1, STOP_EOF, "")
            }
            append_comment_line(out, indent, trimmed)
            return make_block_result(start + 1, STOP_EOF, "")
        }
    }
}

fn parse_function_pointer_param_name(text: ref u8, fallback_name: ref u8) ref u8 = {
    val open_i: i64 = find_char(text, 40 as u8)
    if open_i < 0 { return fallback_name }
    val star_i: mut i64 = open_i + 1
    val len: i64 = string.len_raw(text)
    for {
        if star_i >= len {
            break
        }
        val c: u8 = trust @load8(@ptradd(text as ref void, star_i)) as u8
        if c == 42 { break }
        if !is_space(c) { return fallback_name }
        star_i++
    }
    if star_i >= len { return fallback_name }
    val name_start: mut i64 = star_i + 1
    for {
        if name_start >= len {
            break
        }
        val c: u8 = trust @load8(@ptradd(text as ref void, name_start)) as u8
        if is_ident_start(c) { break }
        name_start++
    }
    if name_start >= len { return fallback_name }
    val name_end: mut i64 = name_start
    for {
        if name_end >= len {
            break
        }
        val c: u8 = trust @load8(@ptradd(text as ref void, name_end)) as u8
        if !is_ident_part(c) { break }
        name_end++
    }
    return sanitize_identifier(trust string.substr(text, name_start, name_end - name_start))
}

fn find_top_level_assign(text: ref u8) i64 = {
    val len: i64 = string.len_raw(text)
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == 40 { paren++ }
        elif c == 41 && paren > 0 { paren-- }
        elif c == 123 { brace++ }
        elif c == 125 && brace > 0 { brace-- }
        elif c == 91 { bracket++ }
        elif c == 93 && bracket > 0 { bracket-- }
        elif c == 61 && paren == 0 && brace == 0 && bracket == 0 {
            val prev: mut u8 = 0
            val next: mut u8 = 0
            if i > 0 { prev = trust @load8(@ptradd(text as ref void, i - 1)) as u8 }
            if i + 1 < len { next = trust @load8(@ptradd(text as ref void, i + 1)) as u8 }
            if prev != 61 && prev != 33 && prev != 60 && prev != 62
                && prev != 43 && prev != 45 && prev != 42 && prev != 47
                && prev != 37 && prev != 38 && prev != 124 && prev != 94
                && next != 61 {
                return i
            }
        }
        i++
    }
    return -1
}

fn find_top_level_compound_assign(text: ref u8) i64 = {
    val len: i64 = string.len_raw(text)
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i + 1 >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        val next: u8 = trust @load8(@ptradd(text as ref void, i + 1)) as u8
        if c == 40 { paren++ }
        elif c == 41 && paren > 0 { paren-- }
        elif c == 123 { brace++ }
        elif c == 125 && brace > 0 { brace-- }
        elif c == 91 { bracket++ }
        elif c == 93 && bracket > 0 { bracket-- }
        elif next == 61 && paren == 0 && brace == 0 && bracket == 0
            && (c == 43 || c == 45 || c == 42 || c == 47 || c == 37 || c == 38 || c == 124 || c == 94) {
            return i
        }
        i++
    }
    return -1
}

fn translate_designated_initializer(text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    if !string.rchar_starts_with(trimmed, "{") { return trimmed }
    if !str_contains(trimmed, ".") { return trimmed }
    val sb: ref void = string.StringBuilder.new()
    val len: i64 = string.len_raw(trimmed)
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if c == 46 && i + 1 < len {
            val next: u8 = trust @load8(@ptradd(trimmed as ref void, i + 1)) as u8
            if is_ident_start(next) {
                i++
                val start: i64 = i
                for {
                    if i >= len { break }
                    val cc: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                    if !is_ident_part(cc) { break }
                    i++
                }
                val field: ref u8 = trust string.substr(trimmed, start, i - start)
                string.StringBuilder.append_cstr(sb, field)
                for {
                    if i >= len {
                        break
                    }
                    val ws: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                    if !is_space(ws) { break }
                    i++
                }
                if i < len {
                    val eq: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
                    if eq == 61 {
                        string.StringBuilder.append_cstr(sb, ": ")
                        i++
                        continue
                    }
                }
                continue
            }
        }
        string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn translate_sizeof_expr(ctx: ref TranslationCtx, text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    val sb: ref void = string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        if i + 7 <= len {
            val maybe_kw: ref u8 = trust string.substr(trimmed, i, 6)
            if string.rchar_cmp(maybe_kw, "sizeof") == 0 {
                val after_kw: mut i64 = i + 6
                for {
                    if after_kw >= len {
                        break
                    }
                    val ws: u8 = trust @load8(@ptradd(trimmed as ref void, after_kw)) as u8
                    if !is_space(ws) { break }
                    after_kw++
                }
                if after_kw < len && (trust @load8(@ptradd(trimmed as ref void, after_kw)) as u8) == 40 {
                    val close_i: mut i64 = after_kw + 1
                    val depth: mut i64 = 1
                    for {
                        if close_i >= len { break }
                        val cc: u8 = trust @load8(@ptradd(trimmed as ref void, close_i)) as u8
                        if cc == 40 { depth++ }
                        elif cc == 41 {
                            depth--
                            if depth == 0 { break }
                        }
                        close_i++
                    }
                    if close_i < len {
                        val inner: ref u8 = trim_raw(trust string.substr(trimmed, after_kw + 1, close_i - after_kw - 1))
                        if is_ident_text(inner) {
                            match lookup_local_array_type(ctx, inner) {
                                some array_size_expr => {
                                    string.StringBuilder.append_cstr(sb, array_size_expr as ref u8)
                                    i = close_i + 1
                                    continue
                                }
                                none => {}
                            }
                        }
                        val index_target: ref u8 = parse_index_target(inner)
                        if string.rchar_cmp(index_target, "") != 0 {
                            val elem_type: ref u8 = lookup_index_element_type(ctx, index_target)
                            if string.rchar_cmp(elem_type, "") != 0 {
                                string.StringBuilder.append_cstr(sb, trust @fmt("@sizeof({s})", {elem_type}))
                                i = close_i + 1
                                continue
                            }
                        }
                        val mapped: ref u8 = translate_c_type_ctx(ctx, inner, "")
                        string.StringBuilder.append_cstr(sb, trust @fmt("@sizeof({s})", {mapped}))
                        i = close_i + 1
                        continue
                    }
                }
            }
        }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn scan_cast_operand_end(text: ref u8, start: i64) i64 = {
    val len: i64 = string.len_raw(text)
    if start < 0 || start >= len { return start }
    val first: u8 = trust @load8(@ptradd(text as ref void, start)) as u8
    if first >= 48 && first <= 57 {
        val i: mut i64 = start + 1
        for {
            if i >= len { break }
            val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
            if !is_ident_part(c) && c != 46 { break }
            i++
        }
        return i
    }
    val base_end: i64 = scan_deref_operand_end(text, start)
    if base_end <= start { return start }
    val j: mut i64 = base_end
    for {
        if j >= len { break }
        val ws: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
        if !is_space(ws) { break }
        j++
    }
    if j < len && (trust @load8(@ptradd(text as ref void, j)) as u8) == 40 {
        val call_close: i64 = find_matching_delim(text, j, 40 as u8, 41 as u8)
        if call_close > j { return call_close + 1 }
    }
    return base_end
}

fn translate_c_casts_in_expr(ctx: ref TranslationCtx, text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val len: i64 = string.len_raw(trimmed)
    val sb: ref void = string.StringBuilder.new()
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if in_string {
            string.StringBuilder.append_char(sb, c)
            if escaped { escaped = false }
            elif c == 92 { escaped = true }
            elif c == 34 { in_string = false }
            i++
            continue
        }
        if in_char {
            string.StringBuilder.append_char(sb, c)
            if escaped { escaped = false }
            elif c == 92 { escaped = true }
            elif c == 39 { in_char = false }
            i++
            continue
        }
        if c == 34 {
            in_string = true
            string.StringBuilder.append_char(sb, c)
            i++
            continue
        }
        if c == 39 {
            in_char = true
            string.StringBuilder.append_char(sb, c)
            i++
            continue
        }
        if c == 40 {
            val prev_is_ident: mut bool = false
            val j: mut i64 = i - 1
            for {
                if j < 0 { break }
                val pc: u8 = trust @load8(@ptradd(trimmed as ref void, j)) as u8
                if !is_space(pc) {
                    prev_is_ident = is_ident_part(pc)
                    break
                }
                j--
            }
            if !prev_is_ident {
                val close_i: i64 = find_matching_delim(trimmed, i, 40 as u8, 41 as u8)
                if close_i > i {
                    val inner: ref u8 = trim_raw(trust string.substr(trimmed, i + 1, close_i - i - 1))
                    if is_probable_c_type(inner) && is_known_c_type_name(ctx, normalize_type_phrase(inner)) {
                        val op_start: mut i64 = close_i + 1
                        for {
                            if op_start >= len { break }
                            val ws: u8 = trust @load8(@ptradd(trimmed as ref void, op_start)) as u8
                            if !is_space(ws) { break }
                            op_start++
                        }
                        if op_start < len {
                            val op_end: i64 = scan_cast_operand_end(trimmed, op_start)
                            if op_end > op_start {
                                val operand: ref u8 = trim_raw(trust string.substr(trimmed, op_start, op_end - op_start))
                                val mapped: ref u8 = translate_c_type_ctx(ctx, inner, "")
                                val translated_op: ref u8 = translate_expr_text(ctx, operand)
                                string.StringBuilder.append_cstr(sb, translated_op)
                                string.StringBuilder.append_cstr(sb, trust @fmt(" as {s}", {mapped}))
                                i = op_end
                                continue
                            }
                        }
                    }
                }
            }
        }
        string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trim_raw(trust string.cstr(built))
}

fn find_top_level_equality(text: ref u8) i64 = {
    val len: i64 = string.len_raw(text)
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i + 1 >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        val next: u8 = trust @load8(@ptradd(text as ref void, i + 1)) as u8
        if c == 40 { paren++ }
        elif c == 41 && paren > 0 { paren-- }
        elif c == 123 { brace++ }
        elif c == 125 && brace > 0 { brace-- }
        elif c == 91 { bracket++ }
        elif c == 93 && bracket > 0 { bracket-- }
        elif paren == 0 && brace == 0 && bracket == 0
            && ((c == 61 && next == 61) || (c == 33 && next == 61)) {
            return i
        }
        i++
    }
    return -1
}

fn rewrite_null_comparison(ctx: ref TranslationCtx, text: ref u8) option[ref u8] = {
    val trimmed: ref u8 = trim_raw(text)
    val cmp_i: i64 = find_top_level_equality(trimmed)
    if cmp_i < 0 { return none }
    val lhs_raw: ref u8 = trim_raw(trust string.substr(trimmed, 0, cmp_i))
    val rhs_raw: ref u8 = trim_raw(trust string.substr(trimmed, cmp_i + 2, string.len_raw(trimmed) - cmp_i - 2))
    val expr_side: mut ref u8 = ""
    if string.rchar_cmp(lhs_raw, "NULL") == 0 {
        expr_side = rhs_raw
    } elif string.rchar_cmp(rhs_raw, "NULL") == 0 {
        expr_side = lhs_raw
    } else {
        return none
    }
    val translated_expr: ref u8 = translate_expr_text(ctx, expr_side)
    val zero_expr: mut ref u8 = "0"
    if is_ident_text(translated_expr) {
        match lookup_local_type(ctx, translated_expr) {
            some type_name => { zero_expr = trust @fmt("0 as {s}", {type_name as ref u8}) }
            none => {}
        }
    }
    val op: u8 = trust @load8(@ptradd(trimmed as ref void, cmp_i)) as u8
    if op == 61 {
        return some trust @fmt("{s} == {s}", {translated_expr, zero_expr})
    }
    return some trust @fmt("{s} != {s}", {translated_expr, zero_expr})
}

fn emit_condition_assignment(ctx: ref TranslationCtx, lhs: ref u8, rhs: ref u8, indent: i64, out: ref void) ref u8 = {
    val lhs_arrow: ref u8 = replace_arrow_access(lhs)
    val lhs_rewritten: ref u8 = rewrite_identifiers(translate_addr_deref_expr(ctx, lhs_arrow))
    val lowered_rhs: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
    val rhs_expr0: ref u8 = lowered_rhs.expr
    val rhs_expr: mut ref u8 = rhs_expr0
    if string.rchar_cmp(trim_raw(rhs), "NULL") == 0 && is_ident_text(lhs_rewritten) {
        match lookup_local_type(ctx, lhs_rewritten) {
            some type_name => { rhs_expr = trust @fmt("0 as {s}", {type_name as ref u8}) }
            none => {}
        }
    }
    val index_target: ref u8 = parse_index_target(lhs_rewritten)
    if string.rchar_cmp(index_target, "") != 0 {
        val index_expr: ref u8 = parse_index_expr(lhs_rewritten)
        val index_ptr: ref u8 = render_index_ptr_expr(ctx, index_target, index_expr)
        track_called_expr(ctx, rhs_expr)
        append_line(out, indent, trust @fmt("@store({s}, {s})", {index_ptr, rhs_expr}))
        return trust @fmt("@load({s})", {index_ptr})
    }
    track_called_expr(ctx, rhs_expr)
    append_line(out, indent, trust @fmt("{s} = {s}", {lhs_rewritten, rhs_expr}))
    return lhs_rewritten
}

fn rewrite_condition_assignments(ctx: ref TranslationCtx, text: ref u8, indent: i64, out: ref void) ref u8 = {
    val trimmed: ref u8 = trim_raw(text)
    val inner: ref u8 = unwrap_outer_parens(trimmed)
    val cmp_i: i64 = find_top_level_equality(inner)
    if cmp_i >= 0 {
        val lhs: ref u8 = trim_raw(trust string.substr(inner, 0, cmp_i))
        val rhs: ref u8 = trim_raw(trust string.substr(inner, cmp_i + 2, string.len_raw(inner) - cmp_i - 2))
        val lhs_rewritten: ref u8 = rewrite_condition_assignments(ctx, lhs, indent, out)
        val rhs_rewritten: ref u8 = rewrite_condition_assignments(ctx, rhs, indent, out)
        val op: ref u8 = trust string.substr(inner, cmp_i, 2)
        return trust @fmt("{s} {s} {s}", {lhs_rewritten, op, rhs_rewritten})
    }
    val assign_i: i64 = find_top_level_assign(inner)
    if assign_i > 0 {
        val lhs_assign: ref u8 = trim_raw(trust string.substr(inner, 0, assign_i))
        val rhs_assign: ref u8 = trim_raw(trust string.substr(inner, assign_i + 1, string.len_raw(inner) - assign_i - 1))
        if !str_contains(lhs_assign, " ") {
            return emit_condition_assignment(ctx, lhs_assign, rhs_assign, indent, out)
        }
    }
    return trimmed
}

fn translate_expr_text(ctx: ref TranslationCtx, text: ref u8) ref u8 = {
    val no_semicolon: ref u8 = strip_trailing_semicolon(text)
    val with_init: ref u8 = translate_designated_initializer(no_semicolon)
    val with_sizeof: ref u8 = translate_sizeof_expr(ctx, with_init)
    val with_arrow: ref u8 = replace_arrow_access(with_sizeof)
    val with_qualified_enums: ref u8 = qualify_enum_constants(ctx, with_arrow)
    val with_rewritten: ref u8 = rewrite_identifiers(with_qualified_enums)
    val with_addr_deref: ref u8 = translate_addr_deref_expr(ctx, with_rewritten)
    val with_casts: ref u8 = translate_c_casts_in_expr(ctx, with_addr_deref)
    val with_indexing2: ref u8 = replace_pointer_indexing(ctx, with_casts)
    val with_intrinsics: ref u8 = ensure_intrinsic_prefixes(with_indexing2)
    val normalized_intrinsics: ref u8 = normalize_intrinsic_prefixes(with_intrinsics)
    if str_contains(normalized_intrinsics, "(") {
        return transform_call_expr(ctx, normalized_intrinsics)
    }
    return normalized_intrinsics
}

fn translate_condition_text(ctx: ref TranslationCtx, text: ref u8, indent: i64, out: ref void) ref u8 = {
    val condition_src: mut ref u8 = text
    if contains_incdec_ops(text) {
        val lowered_text: ref LoweredExpr = lower_incdec_text(ctx, text, indent, out)
        condition_src = lowered_text.expr
    }
    val rewritten_assigns: ref u8 = rewrite_condition_assignments(ctx, condition_src, indent, out)
    match rewrite_null_comparison(ctx, rewritten_assigns) {
        some translated => { return translated as ref u8 }
        none => {}
    }
    return translate_expr_text(ctx, rewritten_assigns)
}

fn translate_body_statement(ctx: ref TranslationCtx, line: ref u8, indent: i64, out: ref void) bool = {
    val stripped: ref u8 = strip_trailing_semicolon(line)
    if string.rchar_cmp(stripped, "") == 0 {
        append_blank_line(out)
        return true
    }
    val multi_decls = split_multi_decl(ctx, stripped)
    if ((@len(multi_decls) as i64) > 1) {
        for decl_text in multi_decls {
            translate_body_statement(ctx, decl_text, indent, out)
        }
        return true
    }
    if string.rchar_starts_with(stripped, "return") {
        val tail: ref u8 = trim_raw(trust string.substr(stripped, 6, string.len_raw(stripped) - 6))
        if string.rchar_cmp(tail, "") == 0 {
            append_line(out, indent, "return")
        } else {
            if contains_incdec_ops(tail) { append_blank_line(out) }
            val lowered_ret: ref LoweredExpr = lower_incdec_expr(ctx, tail, indent, out)
            if lowered_ret.changed { append_blank_line(out) }
            append_line(out, indent, trust @fmt("return {s}", {lowered_ret.expr}))
        }
        return true
    }
    val simple_incdec_stmt: ref u8 = normalize_simple_incdec_stmt(stripped)
    if string.rchar_cmp(simple_incdec_stmt, "") != 0 {
        append_line(out, indent, simple_incdec_stmt)
        return true
    }
    val compound_i: i64 = find_top_level_compound_assign(stripped)
    if compound_i > 0 {
        val lhs: ref u8 = trim_raw(trust string.substr(stripped, 0, compound_i))
        val op: ref u8 = trust string.substr(stripped, compound_i, 1)
        val rhs: ref u8 = trim_raw(trust string.substr(stripped, compound_i + 2, string.len_raw(stripped) - compound_i - 2))
        val rhs_expr_compound: ref u8 = lower_incdec_expr(ctx, rhs, indent, out).expr
        append_line(out, indent, trust @fmt("{s} {s}= {s}", {
            translate_expr_text(ctx, lhs),
            op,
            rhs_expr_compound
        }))
        return true
    }
    val assign_i: i64 = find_top_level_assign(stripped)
    if assign_i > 0 {
        val lhs: ref u8 = trim_raw(trust string.substr(stripped, 0, assign_i))
        val rhs: ref u8 = trim_raw(trust string.substr(stripped, assign_i + 1, string.len_raw(stripped) - assign_i - 1))
        val can_be_decl: bool = str_contains(lhs, " ")
            || string.rchar_starts_with(lhs, "struct ") || string.rchar_starts_with(lhs, "enum ")
        if can_be_decl {
            val decl: ref DeclInfo = parse_named_decl(ctx, lhs, "")
            if decl.its_ok && string.rchar_cmp(decl.name, "") != 0 && string.rchar_cmp(trim_raw(decl.type_src), "") != 0 {
                if is_array_type_name(decl.type_name) {
                    if is_unsized_char_array(decl.type_name) && is_string_literal_text(rhs) {
                        val decayed_type0: ref u8 = decay_array_type(decl.type_name)
                        val lowered_rhs0: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
                        val rhs_expr0: ref u8 = lowered_rhs0.expr
                        remember_local_type(ctx, decl.name, decayed_type0)
                        track_called_expr(ctx, rhs_expr0)
                        append_line(out, indent, trust @fmt("val {s}: {s} = {s}", {decl.name, render_binding_type(ctx, decl.name, decayed_type0), rhs_expr0}))
                        return true
                    }
                    val array_init_items = parse_brace_initializer_items(rhs)
                    val elem_type: ref u8 = array_type_elem(decl.type_name)
                    val alloc_expr: mut ref u8 = array_alloc_expr(decl.type_name)
                    if string.rchar_cmp(array_type_len_expr(decl.type_name), "") == 0 && (@len(array_init_items) as i64) > 0 {
                        alloc_expr = trust @fmt("{d} * @sizeof({s})", {@len(array_init_items) as i64, elem_type})
                    }
                    val decayed_type: ref u8 = decay_array_type(decl.type_name)
                    val is_char_array_literal: bool = string.rchar_cmp(array_type_elem(decl.type_name), "u8") == 0 && is_string_literal_text(rhs)
                    remember_local_type(ctx, decl.name, decayed_type)
                    remember_local_array_type(ctx, decl.name, alloc_expr)
                    append_line(out, indent, trust @fmt("val {s}: {s} = @alloc({s})", {decl.name, render_binding_type(ctx, decl.name, decayed_type), alloc_expr}))
                    if is_char_array_literal {
                        val lowered_rhs_char: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
                        val rhs_expr_char: ref u8 = lowered_rhs_char.expr
                        val copy_len: i64 = string_literal_storage_len(rhs)
                        append_line(out, indent, trust @fmt("@memset({s} as ref void, 0, {s})", {decl.name, alloc_expr}))
                        append_line(out, indent, trust @fmt("@memcpy({s} as ref void, {s} as ref void, {d} as usize)", {decl.name, rhs_expr_char, copy_len}))
                        track_called_expr(ctx, rhs_expr_char)
                    }
                    if ((@len(array_init_items) as i64) > 0) {
                        emit_array_initializer_stores(ctx, out, indent, decl.name, array_init_items)
                    }
                    return true
                }
                if is_address_taken_name(ctx, decl.name) && !string.rchar_starts_with(decl.type_name, "ref ") {
                    val ref_type: ref u8 = trust @fmt("ref {s}", {decl.type_name})
                    remember_local_type(ctx, decl.name, ref_type)
                    append_line(out, indent, trust @fmt("val {s}: {s} = @alloc(@sizeof({s}))", {decl.name, render_binding_type(ctx, decl.name, ref_type), decl.type_name}))
                    val lowered_rhs_addr: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
                    val rhs_expr_addr: mut ref u8 = lowered_rhs_addr.expr
                    if string.rchar_cmp(trim_raw(rhs), "NULL") == 0 {
                        rhs_expr_addr = trust @fmt("0 as {s}", {decl.type_name})
                    }
                    track_called_expr(ctx, rhs_expr_addr)
                    append_line(out, indent, trust @fmt("@deref({s}) = {s}", {decl.name, rhs_expr_addr}))
                    return true
                }
                val has_incdec_rhs: bool = contains_incdec_ops(rhs)
                if has_incdec_rhs {
                    append_blank_line(out)
                    append_comment_line(out, indent, trust @fmt("{s} = {s}", {decl.name, rhs}))
                }
                val lowered_rhs: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
                val rhs_expr0: ref u8 = lowered_rhs.expr
                val rhs_expr: mut ref u8 = rhs_expr0
                if string.rchar_cmp(trim_raw(rhs), "NULL") == 0 {
                    rhs_expr = trust @fmt("0 as {s}", {decl.type_name})
                }
                remember_local_type(ctx, decl.name, decl.type_name)
                val rendered_type: ref u8 = render_binding_type(ctx, decl.name, decl.type_name)
                val ternary_src: ref u8 = unwrap_outer_parens(rhs_expr)
                val q_i: i64 = find_top_level_ternary(ternary_src)
                if q_i >= 0 {
                    val colon_i: i64 = find_matching_colon_for_ternary(ternary_src, q_i)
                    if colon_i > q_i {
                        mark_mutable_name(ctx, decl.name)
                        val cond: ref u8 = unwrap_outer_parens(trim_raw(trust string.substr(ternary_src, 0, q_i)))
                        val if_true: ref u8 = unwrap_outer_parens(trim_raw(trust string.substr(ternary_src, q_i + 1, colon_i - q_i - 1)))
                        val if_false: ref u8 = unwrap_outer_parens(trim_raw(trust string.substr(ternary_src, colon_i + 1, string.len_raw(ternary_src) - colon_i - 1)))
                        append_line(out, indent, trust @fmt("val {s}: {s} = {s}", {decl.name, render_mutable_type(decl.type_name), if_false}))
                        val if_line1: ref u8 = trust @fmt("if ({s}) ", {cond})
                        val if_line2: ref u8 = trust string.concat_raw(if_line1, "{ ")
                        val if_line3: ref u8 = trust @fmt("{s} = {s}", {decl.name, if_true})
                        val if_line4: ref u8 = trust string.concat_raw(if_line2, if_line3)
                        val if_line5: ref u8 = trust string.concat_raw(if_line4, " }")
                        append_line(out, indent, if_line5)
                        return true
                    }
                }
                track_called_expr(ctx, rhs_expr)
                append_line(out, indent, trust @fmt("val {s}: {s} = {s}", {decl.name, rendered_type, rhs_expr}))
                if string.rchar_starts_with(decl.type_name, "ref ")
                    && string.rchar_starts_with(rhs_expr, "@alloc(") {
                    val struct_name: ref u8 = trust @ptradd(decl.type_name, 4)
                    match lookup_flex_field_name(ctx, struct_name) {
                        some flex_field => {
                            match lookup_flex_field_type(ctx, struct_name) {
                                some flex_type => {
                                    append_blank_line(out)
                                    append_line(out, indent, trust @fmt("{s}.{s} = @ptradd({s} as ref i8, @sizeof({s})) as {s}",
                                        {decl.name, flex_field as ref u8, decl.name, struct_name, flex_type as ref u8}))
                                }
                                none => {}
                            }
                        }
                        none => {}
                    }
                }
                if lowered_rhs.changed { append_blank_line(out) }
                return true
            }
        }
        val lhs_arrow: ref u8 = replace_arrow_access(lhs)
        val lhs_rewritten: ref u8 = rewrite_identifiers(translate_addr_deref_expr(ctx, lhs_arrow))
        val index_target: ref u8 = parse_index_target(lhs_rewritten)
        if string.rchar_cmp(index_target, "") != 0 {
            val index_expr: ref u8 = parse_index_expr(lhs_rewritten)
            val index_ptr: ref u8 = render_index_ptr_expr(ctx, index_target, index_expr)
            val has_incdec_rhs2: bool = contains_incdec_ops(rhs)
            if has_incdec_rhs2 {
                append_blank_line(out)
                append_comment_line(out, indent, trust @fmt("{s} = {s}", {lhs_rewritten, rhs}))
            }
            val lowered_rhs2: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
            val rhs_expr2: ref u8 = lowered_rhs2.expr
            track_called_expr(ctx, rhs_expr2)
            append_line(out, indent, trust @fmt("@store({s}, {s})", {index_ptr, rhs_expr2}))
            if lowered_rhs2.changed { append_blank_line(out) }
            return true
        }
        val has_incdec_rhs3: bool = contains_incdec_ops(rhs)
        if has_incdec_rhs3 {
            append_blank_line(out)
            append_comment_line(out, indent, trust @fmt("{s} = {s}", {lhs_rewritten, rhs}))
        }
        val lowered_rhs3: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
        val rhs_expr3_0: ref u8 = lowered_rhs3.expr
        val rhs_expr3: mut ref u8 = rhs_expr3_0
        if string.rchar_cmp(trim_raw(rhs), "NULL") == 0 && is_ident_text(lhs_rewritten) {
            match lookup_local_type(ctx, lhs_rewritten) {
                some type_name => { rhs_expr3 = trust @fmt("0 as {s}", {type_name as ref u8}) }
                none => {}
            }
        }
        track_called_expr(ctx, rhs_expr3)
        append_line(out, indent, trust @fmt("{s} = {s}", {lhs_rewritten, rhs_expr3}))
        if lowered_rhs3.changed { append_blank_line(out) }
        return true
    }
    val can_be_bare_decl: bool = (str_contains(stripped, " ") || str_contains(stripped, "*")
        || string.rchar_starts_with(stripped, "struct ") || string.rchar_starts_with(stripped, "enum "))
        && !str_contains(stripped, "(")
    if can_be_bare_decl {
        val decl2: ref DeclInfo = parse_named_decl(ctx, stripped, "")
        if decl2.its_ok && string.rchar_cmp(decl2.name, "") != 0 {
            if is_array_type_name(decl2.type_name) {
                val alloc_expr2: ref u8 = array_alloc_expr(decl2.type_name)
                val decayed_type2: ref u8 = decay_array_type(decl2.type_name)
                remember_local_type(ctx, decl2.name, decayed_type2)
                remember_local_array_type(ctx, decl2.name, alloc_expr2)
                append_line(out, indent, trust @fmt("val {s}: {s} = @alloc({s})", {decl2.name, render_binding_type(ctx, decl2.name, decayed_type2), alloc_expr2}))
                return true
            }
            if is_address_taken_name(ctx, decl2.name) && !string.rchar_starts_with(decl2.type_name, "ref ") {
                val ref_type2: ref u8 = trust @fmt("ref {s}", {decl2.type_name})
                remember_local_type(ctx, decl2.name, ref_type2)
                append_line(out, indent, trust @fmt("val {s}: {s} = @alloc(@sizeof({s}))", {decl2.name, render_binding_type(ctx, decl2.name, ref_type2), decl2.type_name}))
                return true
            }
            remember_local_type(ctx, decl2.name, decl2.type_name)
            append_line(out, indent, trust @fmt("val {s}: {s}", {decl2.name, render_binding_type(ctx, decl2.name, decl2.type_name)}))
            return true
        }
    }
    if starts_keyword_paren(stripped, "for") {
        return false
    }
    if starts_keyword_paren(stripped, "assert") {
        val open_i: i64 = find_char(stripped, 40 as u8)
        val close_i: i64 = find_matching_delim(stripped, open_i, 40 as u8, 41 as u8)
        if open_i >= 0 && close_i > open_i {
            val cond_text: ref u8 = trim_raw(trust string.substr(stripped, open_i + 1, close_i - open_i - 1))
            val lowered_cond: ref LoweredExpr = lower_incdec_expr(ctx, cond_text, indent, out)
            append_line(out, indent, trust @fmt("assert {s}", {lowered_cond.expr}))
            return true
        }
    }
    if contains_incdec_ops(stripped) {
        append_line(out, indent, translate_expr_text(ctx, stripped))
        return true
    }
    if str_contains(stripped, "(")
        && !string.rchar_starts_with(stripped, "if")
        && !string.rchar_starts_with(stripped, "for")
        && !string.rchar_starts_with(stripped, "while")
        && !string.rchar_starts_with(stripped, "switch") {
        val lowered_expr: ref LoweredExpr = lower_incdec_expr(ctx, stripped, indent, out)
        val expr: ref u8 = lowered_expr.expr
        track_called_expr(ctx, expr)
        append_line(out, indent, expr)
        return true
    }
    return false
}

fn append_open_block_line(sb: ref void, indent: i64, prefix: ref u8) void = {
    val line: ref u8 = trust string.concat_raw(prefix, "{")
    append_line(sb, indent, line)
}

fn emit_known_extern(name: ref u8, out: ref void) bool = {
    if string.rchar_cmp(name, "assert") == 0 {
        return true
    }
    if string.rchar_cmp(name, "assert_value") == 0 {
        return true
    }
    if string.rchar_cmp(name, "fprintf") == 0 {
        return true
    }
    if string.rchar_cmp(name, "sprintf") == 0 {
        append_line(out, 0, "extern (C) fn sprintf(dst: ref u8, fmt: ref u8, ...) i32! = \"sprintf\"")
        return true
    }
    if string.rchar_cmp(name, "puts") == 0 {
        append_line(out, 0, "extern (C) fn puts(s: ref u8) i32! = \"puts\"")
        return true
    }
    if string.rchar_cmp(name, "putchar") == 0 {
        append_line(out, 0, "extern (C) fn putchar(c: i32) i32! = \"putchar\"")
        return true
    }
    if string.rchar_cmp(name, "strlen") == 0 {
        append_line(out, 0, "extern (C) fn strlen(s: ref u8) i64! = \"strlen\"")
        return true
    }
    if string.rchar_cmp(name, "fgets") == 0 {
        append_line(out, 0, "extern (C) fn fgets(dst: ref u8, n: i32, stream: ref void) ref u8! = \"fgets\"")
        return true
    }
    if string.rchar_cmp(name, "malloc") == 0 {
        append_line(out, 0, "extern (C) fn malloc(size: usize) ref void! = \"malloc\"")
        return true
    }
    if string.rchar_cmp(name, "free") == 0 {
        append_line(out, 0, "extern (C) fn free(ptr: ref void) void! = \"free\"")
        return true
    }
    return false
}

fn emit_generic_extern(ctx: ref TranslationCtx, name: ref u8, out: ref void) bool = {
    val params_text: mut ref u8 = ""
    match lookup_called_signature(ctx, name) {
        some params_val => { params_text = params_val as ref u8 }
        none => {}
    }
    append_line(out, 0, trust @fmt("extern (C) fn {s}({s}) i32! = \"{s}\"", {name, params_text, name}))
    return true
}

fn append_synthesized_externs(ctx: ref TranslationCtx, out: ref void) void = {
    val emitted_any: mut bool = false
    for name in ctx.called_names {
        if list_contains(ctx.defined_names, name) { continue }
        if list_contains(ctx.extern_names, name) { continue }
        if emit_known_extern(name, out) || emit_generic_extern(ctx, name, out) {
            push_unique(ctx.extern_names, name)
            emitted_any = true
        }
    }
    if emitted_any {
        append_blank_line(out)
    }
}

fn file_exists(path: ref u8) bool = {
    val file_opt = trust fs.open(path, "r")
    match file_opt {
        some f => {
            trust fs.close(f)
            return true
        }
        none => { return false }
    }
}

fn resolve_include_path(name: ref u8, current_dir: ref u8) option[ref u8] = {
    if string.rchar_starts_with(name, "/") {
        if file_exists(name) { return some name }
        return none
    }
    val local = trust path.join(current_dir, name)
    if file_exists(local) { return some local }
    val cwd_candidate = trust path.join(".", name)
    if file_exists(cwd_candidate) { return some cwd_candidate }
    val usr_local = trust path.join("/usr/local/include", name)
    if file_exists(usr_local) { return some usr_local }
    val usr = trust path.join("/usr/include", name)
    if file_exists(usr) { return some usr }
    return none
}

fn keyword_ignored(word: ref u8) bool = {
    if string.rchar_cmp(word, "const") == 0       { return true }
    if string.rchar_cmp(word, "__const") == 0     { return true }
    if string.rchar_cmp(word, "__const__") == 0   { return true }
    if string.rchar_cmp(word, "volatile") == 0    { return true }
    if string.rchar_cmp(word, "__volatile__") == 0 { return true }
    if string.rchar_cmp(word, "restrict") == 0    { return true }
    if string.rchar_cmp(word, "__restrict") == 0  { return true }
    if string.rchar_cmp(word, "__restrict__") == 0 { return true }
    if string.rchar_cmp(word, "register") == 0    { return true }
    if string.rchar_cmp(word, "static") == 0      { return true }
    if string.rchar_cmp(word, "extern") == 0      { return true }
    if string.rchar_cmp(word, "inline") == 0      { return true }
    if string.rchar_cmp(word, "__inline") == 0    { return true }
    if string.rchar_cmp(word, "__inline__") == 0  { return true }
    if string.rchar_cmp(word, "typedef") == 0     { return true }
    if string.rchar_cmp(word, "signed") == 0      { return true }
    if string.rchar_cmp(word, "__signed__") == 0  { return true }
    if string.rchar_cmp(word, "__extension__") == 0 { return true }
    return false
}

fn normalize_type_phrase(text: ref u8) ref u8 = {
    val flat: ref u8 = flatten_ws(text)
    val sb: ref void = string.StringBuilder.new()
    val len: i64 = string.len_raw(flat)
    val i: mut i64 = 0
    val first: mut bool = true
    for {
        if i >= len { break }
        for {
            if i >= len {
                break
            }
            val c: u8 = trust @load8(@ptradd(flat as ref void, i)) as u8
            if !is_space(c) { break }
            i++
        }
        if i >= len { break }
        val c0: u8 = trust @load8(@ptradd(flat as ref void, i)) as u8
        if c0 == 42 {
            if !first { string.StringBuilder.append_char(sb, 32) }
            string.StringBuilder.append_char(sb, 42)
            first = false
            i++
            continue
        }
        val start: i64 = i
        for {
            if i >= len {
                break
            }
            val c: u8 = trust @load8(@ptradd(flat as ref void, i)) as u8
            if is_space(c) || c == 42 { break }
            i++
        }
        val word: ref u8 = trust string.substr(flat, start, i - start)
        if !keyword_ignored(word) {
            if !first { string.StringBuilder.append_char(sb, 32) }
            string.StringBuilder.append_cstr(sb, word)
            first = false
        }
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trim_raw(trust string.cstr(built))
}

fn map_base_type(base: ref u8) ref u8 = {
    if string.rchar_cmp(base, "") == 0                   { return "void" }
    if string.rchar_cmp(base, "void") == 0               { return "void" }
    if string.rchar_cmp(base, "u8") == 0               { return "u8" }
    if string.rchar_cmp(base, "short") == 0              { return "i16" }
    if string.rchar_cmp(base, "int") == 0                { return "i32" }
    if string.rchar_cmp(base, "long") == 0               { return "i64" }
    if string.rchar_cmp(base, "long long") == 0          { return "i64" }
    if string.rchar_cmp(base, "unsigned u8") == 0      { return "u8" }
    if string.rchar_cmp(base, "unsigned short") == 0     { return "u16" }
    if string.rchar_cmp(base, "unsigned") == 0           { return "u32" }
    if string.rchar_cmp(base, "unsigned int") == 0       { return "u32" }
    if string.rchar_cmp(base, "unsigned long") == 0         { return "u64" }
    if string.rchar_cmp(base, "unsigned long long") == 0   { return "u64" }
    if string.rchar_cmp(base, "long unsigned") == 0         { return "u64" }
    if string.rchar_cmp(base, "long unsigned int") == 0     { return "u64" }
    if string.rchar_cmp(base, "unsigned long int") == 0     { return "u64" }
    if string.rchar_cmp(base, "long long unsigned") == 0    { return "u64" }
    if string.rchar_cmp(base, "long long unsigned int") == 0 { return "u64" }
    if string.rchar_cmp(base, "unsigned long long int") == 0 { return "u64" }
    if string.rchar_cmp(base, "long int") == 0              { return "i64" }
    if string.rchar_cmp(base, "long long int") == 0         { return "i64" }
    if string.rchar_cmp(base, "signed long") == 0           { return "i64" }
    if string.rchar_cmp(base, "signed long int") == 0       { return "i64" }
    if string.rchar_cmp(base, "signed long long") == 0      { return "i64" }
    if string.rchar_cmp(base, "signed long long int") == 0  { return "i64" }
    if string.rchar_cmp(base, "short int") == 0             { return "i16" }
    if string.rchar_cmp(base, "signed short") == 0          { return "i16" }
    if string.rchar_cmp(base, "signed short int") == 0      { return "i16" }
    if string.rchar_cmp(base, "short unsigned int") == 0    { return "u16" }
    if string.rchar_cmp(base, "unsigned short int") == 0    { return "u16" }
    if string.rchar_cmp(base, "signed int") == 0            { return "i32" }
    if string.rchar_cmp(base, "signed") == 0                { return "i32" }
    if string.rchar_cmp(base, "signed u8") == 0           { return "i8" }
    if string.rchar_cmp(base, "float") == 0              { return "f32" }
    if string.rchar_cmp(base, "double") == 0             { return "f64" }
    if string.rchar_cmp(base, "_Bool") == 0              { return "bool" }
    if string.rchar_cmp(base, "bool") == 0               { return "bool" }
    if string.rchar_cmp(base, "size_t") == 0             { return "usize" }
    if string.rchar_cmp(base, "ssize_t") == 0            { return "i64" }
    if string.rchar_cmp(base, "int8_t") == 0             { return "i8" }
    if string.rchar_cmp(base, "uint8_t") == 0            { return "u8" }
    if string.rchar_cmp(base, "int16_t") == 0            { return "i16" }
    if string.rchar_cmp(base, "uint16_t") == 0           { return "u16" }
    if string.rchar_cmp(base, "int32_t") == 0            { return "i32" }
    if string.rchar_cmp(base, "uint32_t") == 0           { return "u32" }
    if string.rchar_cmp(base, "int64_t") == 0            { return "i64" }
    if string.rchar_cmp(base, "uint64_t") == 0           { return "u64" }
    if string.rchar_cmp(base, "intptr_t") == 0           { return "i64" }
    if string.rchar_cmp(base, "uintptr_t") == 0          { return "usize" }
    if string.rchar_starts_with(base, "struct ") {
        return sanitize_identifier(trim_raw(trust string.substr(base, 7, string.len_raw(base) - 7)))
    }
    if string.rchar_starts_with(base, "enum ") {
        return sanitize_identifier(trim_raw(trust string.substr(base, 5, string.len_raw(base) - 5)))
    }
    if string.rchar_starts_with(base, "union ") {
        return sanitize_identifier(trim_raw(trust string.substr(base, 6, string.len_raw(base) - 6)))
    }
    return sanitize_identifier(base)
}

fn translate_c_type(type_src: ref u8, array_prefix: ref u8) ref u8 = {
    val normalized: ref u8 = normalize_type_phrase(type_src)
    val len: i64 = string.len_raw(normalized)
    val no_stars_sb: ref void = string.StringBuilder.new()
    val star_count: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(normalized as ref void, i)) as u8
        if c == 42 {
            star_count++
        } else {
            string.StringBuilder.append_char(no_stars_sb, c)
        }
        i++
    }
    val no_stars_built: ref void = string.StringBuilder.build(no_stars_sb)
    string.StringBuilder.free(no_stars_sb)
    val base: ref u8 = trim_raw(trust string.cstr(no_stars_built))
    val mapped0: ref u8 = map_base_type(base)
    val mapped: mut ref u8 = mapped0
    val j: mut i64 = 0
    for {
        if j >= star_count { break }
        mapped = trust @fmt("ref {s}", {mapped})
        j++
    }
    if string.rchar_cmp(array_prefix, "") != 0 {
        mapped = trust @fmt("{s}{s}", {array_prefix, mapped})
    }
    return mapped
}

fn translate_c_type_ctx(ctx: ref TranslationCtx, type_src: ref u8, array_prefix: ref u8) ref u8 = {
    val normalized: ref u8 = normalize_type_phrase(type_src)
    if is_ident_text(normalized) {
        match lookup_typedef_alias(ctx, normalized) {
            some mapped => {
                if string.rchar_cmp(array_prefix, "") != 0 {
                    return trust @fmt("{s}{s}", {array_prefix, mapped as ref u8})
                }
                return mapped as ref u8
            }
            none => {}
        }
    }
    return translate_c_type(type_src, array_prefix)
}

fn strip_initializer(text: ref u8) ref u8 = {
    val len: i64 = string.len_raw(text)
    val i: mut i64 = 0
    val depth_paren: mut i64 = 0
    val depth_bracket: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == 40 { depth_paren++ }
        elif c == 41 && depth_paren > 0 { depth_paren-- }
        elif c == 91 { depth_bracket++ }
        elif c == 93 && depth_bracket > 0 { depth_bracket-- }
        elif c == 61 && depth_paren == 0 && depth_bracket == 0 {
            return trim_raw(trust string.substr(text, 0, i))
        }
        i++
    }
    return trim_raw(text)
}

fn parse_named_decl(ctx: ref TranslationCtx, text: ref u8, fallback_name: ref u8) ref DeclInfo = {
    val info: mut ref DeclInfo = @alloc(@sizeof(DeclInfo)) as ref DeclInfo
    info.its_ok    = false
    info.name      = fallback_name
    info.type_name = ""
    info.type_src  = ""
    val trimmed0: ref u8 = trim_raw(strip_initializer(text))
    val len0: i64 = string.len_raw(trimmed0)
    if len0 == 0 { return info }
    val array_prefix: mut ref u8 = ""
    val i: mut i64 = len0 - 1
    for {
        if i < 0 { break }
        val c: u8 = trust @load8(@ptradd(trimmed0 as ref void, i)) as u8
        if is_space(c) {
            i--
            continue
        }
        if c != 93 { break }
        val close_i: i64 = i
        val open_i: mut i64 = i - 1
        for {
            if open_i < 0 { break }
            val inner: u8 = trust @load8(@ptradd(trimmed0 as ref void, open_i)) as u8
            if inner == 91 { break }
            open_i--
        }
        if open_i < 0 { break }
        val array_len_txt: ref u8 = trim_raw(trust string.substr(trimmed0, open_i + 1, close_i - open_i - 1))
        val effective_len: mut ref u8 = array_len_txt
        if !is_integer_literal_text(array_len_txt) && !is_ident_text(array_len_txt) {
            effective_len = "32"
        }
        array_prefix = trust @fmt("[{s}]{s}", {effective_len, array_prefix})
        i = open_i - 1
    }
    for {
        if i < 0 {
            break
        }
        val c: u8 = trust @load8(@ptradd(trimmed0 as ref void, i)) as u8
        if !is_space(c) { break }
        i--
    }
    val name_end: i64 = i
    for {
        if i < 0 {
            break
        }
        val c: u8 = trust @load8(@ptradd(trimmed0 as ref void, i)) as u8
        if !is_ident_part(c) { break }
        i--
    }
    val name_start: i64 = i + 1
    if name_end >= name_start {
        info.name = sanitize_identifier(trust string.substr(trimmed0, name_start, name_end - name_start + 1))
        info.type_src = trim_raw(trust string.substr(trimmed0, 0, name_start))
    } else {
        info.name = sanitize_identifier(fallback_name)
        info.type_src = trimmed0
    }
    info.type_name = translate_c_type_ctx(ctx, info.type_src, array_prefix)
    info.its_ok = string.rchar_cmp(info.type_name, "") != 0
    return info
}

fn split_multi_decl(ctx: ref TranslationCtx, text: ref u8) list[ref u8] = {
    val trimmed: ref u8 = strip_trailing_semicolon(trim_raw(text))
    if str_contains(trimmed, "(") { return [] }
    val parts = split_top_level(trimmed, 44 as u8)
    if ((@len(parts) as i64) <= 1) { return [] }
    val first_opt = @get(parts, 0)
    match first_opt {
        some first_part => {
            val first_trimmed: ref u8 = trim_raw(first_part as ref u8)
            val first_decl: ref DeclInfo = parse_named_decl(ctx, first_trimmed, "")
            val first_type_src: ref u8 = trim_raw(first_decl.type_src)
            if !first_decl.its_ok || string.rchar_cmp(first_type_src, "") == 0 { return [] }
            val items: mut list[ref u8] = []
            @append(items, first_trimmed)
            val len: i64 = @len(parts) as i64
            val i: mut i64 = 1
            for {
                if i >= len { break }
                val part_opt = @get(parts, i as usize)
                match part_opt {
                    some part_val => {
                        val part_trimmed: ref u8 = trim_raw(part_val as ref u8)
                        if string.rchar_cmp(part_trimmed, "") != 0 {
                            @append(items, trust @fmt("{s} {s}", {first_type_src, part_trimmed}))
                        }
                    }
                    none => {}
                }
                i++
            }
            return items
        }
        none => { return [] }
    }
}

fn split_top_level(text: ref u8, delim: u8) list[ref u8] = {
    val items: mut list[ref u8] = []
    val len: i64 = string.len_raw(text)
    val start: mut i64 = 0
    val paren: mut i64 = 0
    val brace: mut i64 = 0
    val bracket: mut i64 = 0
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    val i: mut i64 = 0
    for {
        if i > len { break }
        val at_end: bool = i == len
        val c: mut u8 = 0
        if !at_end {
            c = trust @load8(@ptradd(text as ref void, i)) as u8
            if in_string {
                if escaped {
                    escaped = false
                } elif c == 92 {
                    escaped = true
                } elif c == 34 {
                    in_string = false
                }
            } elif in_char {
                if escaped {
                    escaped = false
                } elif c == 92 {
                    escaped = true
                } elif c == 39 {
                    in_char = false
                }
            } else {
                if c == 34 {
                    in_string = true
                } elif c == 39 {
                    in_char = true
                } elif c == 40 { paren++ }
                elif c == 41 && paren > 0 { paren-- }
                elif c == 123 { brace++ }
                elif c == 125 && brace > 0 { brace-- }
                elif c == 91 { bracket++ }
                elif c == 93 && bracket > 0 { bracket-- }
            }
        }
        if at_end || (c == delim && !in_string && !in_char && paren == 0 && brace == 0 && bracket == 0) {
            @append(items, trim_raw(trust string.substr(text, start, i - start)))
            start = i + 1
        }
        i++
    }
    return items
}

fn extract_identifier_before(text: ref u8, end_exclusive: i64) ref u8 = {
    val i: mut i64 = end_exclusive - 1
    for {
        if i < 0 {
            break
        }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if !is_space(c) && c != 59 {
            break
        }
        i--
    }
    val end_i: i64 = i
    for {
        if i < 0 {
            break
        }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if !is_ident_part(c) { break }
        i--
    }
    if end_i < i + 1 { return "" }
    return trust string.substr(text, i + 1, end_i - i)
}

fn next_significant_line(lines: list[ref u8], start: i64) i64 = {
    val len: i64 = @len(lines) as i64
    val i: mut i64 = start
    for {
        if i >= len { break }
        val opt = @get(lines, i as usize)
        match opt {
            some line_val => {
                val trimmed: ref u8 = trim_raw(line_val as ref u8)
                if string.rchar_cmp(trimmed, "") != 0 {
                    return i
                }
            }
            none => {}
        }
        i++
    }
    return -1
}

fn parse_include_name(line: ref u8) ref u8 = {
    val q1: i64 = find_char(line, 34 as u8)
    if q1 >= 0 {
        val q2: mut i64 = q1 + 1
        val len: i64 = string.len_raw(line)
        for {
            if q2 >= len { break }
            val c: u8 = trust @load8(@ptradd(line as ref void, q2)) as u8
            if c == 34 { break }
            q2++
        }
        if q2 < len {
            return trust string.substr(line, q1 + 1, q2 - q1 - 1)
        }
    }
    val a1: i64 = find_char(line, 60 as u8)
    if a1 >= 0 {
        val a2: mut i64 = a1 + 1
        val len: i64 = string.len_raw(line)
        for {
            if a2 >= len { break }
            val c: u8 = trust @load8(@ptradd(line as ref void, a2)) as u8
            if c == 62 { break }
            a2++
        }
        if a2 < len {
            return trust string.substr(line, a1 + 1, a2 - a1 - 1)
        }
    }
    return ""
}

fn parse_macro_name(line: ref u8, keyword: ref u8) ref u8 = {
    val flat: ref u8 = flatten_ws(line)
    val prefix: ref u8 = trust @fmt("{s} ", {keyword})
    if !string.rchar_starts_with(flat, prefix) { return "" }
    return trim_raw(trust string.substr(flat, string.len_raw(prefix), string.len_raw(flat) - string.len_raw(prefix)))
}

fn detect_condition(line: ref u8) i64 = {
    val flat: ref u8 = flatten_ws(line)
    if string.rchar_cmp(flat, "#ifdef _WIN32") == 0 { return COND_WIN_TRUE }
    if string.rchar_cmp(flat, "#if defined(_WIN32)") == 0 { return COND_WIN_TRUE }
    if string.rchar_cmp(flat, "#if defined( _WIN32 )") == 0 { return COND_WIN_TRUE }
    if string.rchar_cmp(flat, "#ifndef _WIN32") == 0 { return COND_WIN_FALSE }
    if string.rchar_cmp(flat, "#if !defined(_WIN32)") == 0 { return COND_WIN_FALSE }
    if string.rchar_cmp(flat, "#if ! defined(_WIN32)") == 0 { return COND_WIN_FALSE }
    return COND_NONE
}

fn is_header_guard(lines: list[ref u8], line_index: i64, macro_name: ref u8) bool = {
    if string.rchar_cmp(macro_name, "") == 0 { return false }
    val next_i: i64 = next_significant_line(lines, line_index + 1)
    if next_i < 0 { return false }
    val opt = @get(lines, next_i as usize)
    match opt {
        some next_line => {
            val def_name: ref u8 = parse_macro_name(next_line as ref u8, "#define")
            return string.rchar_cmp(def_name, macro_name) == 0
        }
        none => { return false }
    }
}

fn append_builder(dst: ref void, src: ref void) void = {
    val built: ref void = string.StringBuilder.build(src)
    string.StringBuilder.append(dst, built)
}

fn translate_body_lines(lines: list[ref u8], current_dir: ref u8, start: i64, indent: i64, out: ref void, ctx: ref TranslationCtx) ref BlockResult = {
    val len: i64 = @len(lines) as i64
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                val line: ref u8 = line_val as ref u8
                val trimmed: ref u8 = trim_raw(line)
                if string.rchar_cmp(trimmed, "") == 0 {
                    append_blank_line(out)
                    i++
                    continue
                }
                if string.rchar_starts_with(trimmed, "#else") {
                    return make_block_result(i + 1, STOP_ELSE, trimmed)
                }
                if string.rchar_starts_with(trimmed, "#endif") {
                    return make_block_result(i + 1, STOP_ENDIF, trimmed)
                }
                if string.rchar_starts_with(trimmed, "#elif") {
                    return make_block_result(i + 1, STOP_ELIF, trimmed)
                }
                if string.rchar_starts_with(trimmed, "#include") {
                    i++
                    continue
                }
                val ifndef_name: ref u8 = parse_macro_name(trimmed, "#ifndef")
                if is_header_guard(lines, i, ifndef_name) {
                    val define_i: i64 = next_significant_line(lines, i + 1)
                    val inner = translate_body_lines(lines, current_dir, define_i + 1, indent, out, ctx)
                    i = inner.next_index
                    continue
                }
                val cond: i64 = detect_condition(trimmed)
                if cond == COND_WIN_TRUE {
                    append_line(out, indent, "when windows {")
                    val then_result = translate_body_lines(lines, current_dir, i + 1, indent + 1, out, ctx)
                    if then_result.stop_kind == STOP_ELSE {
                        append_line(out, indent, "} otherwise {")
                        val else_result = translate_body_lines(lines, current_dir, then_result.next_index, indent + 1, out, ctx)
                        append_line(out, indent, "}")
                        i = else_result.next_index
                    } elif then_result.stop_kind == STOP_ELIF {
                        append_line(out, indent, "} otherwise {")
                        append_comment_line(out, indent + 1, then_result.stop_line)
                        val elif_result = translate_body_lines(lines, current_dir, then_result.next_index, indent + 1, out, ctx)
                        append_line(out, indent, "}")
                        i = elif_result.next_index
                    } else {
                        append_line(out, indent, "}")
                        i = then_result.next_index
                    }
                    continue
                }
                if cond == COND_WIN_FALSE {
                    val non_windows: ref void = string.StringBuilder.new()
                    val then_result = translate_body_lines(lines, current_dir, i + 1, indent + 1, non_windows, ctx)
                    append_line(out, indent, "when windows {")
                    if then_result.stop_kind == STOP_ELSE {
                        val else_result = translate_body_lines(lines, current_dir, then_result.next_index, indent + 1, out, ctx)
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = else_result.next_index
                    } elif then_result.stop_kind == STOP_ELIF {
                        append_comment_line(out, indent + 1, then_result.stop_line)
                        val elif_result = translate_body_lines(lines, current_dir, then_result.next_index, indent + 1, out, ctx)
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = elif_result.next_index
                    } else {
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = then_result.next_index
                    }
                    continue
                }
                val stmt_result: ref BlockResult = translate_statement_at(lines, current_dir, i, indent, out, ctx)
                i = stmt_result.next_index
            }
            none => { i++ }
        }
    }
    return make_block_result(i, STOP_EOF, "")
}

fn collect_struct(lines: list[ref u8], start: i64) ref BlockResult = {
    val len: i64 = @len(lines) as i64
    val brace_depth: mut i64 = 0
    val started: mut bool = false
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                val line: ref u8 = line_val as ref u8
                val l: i64 = string.len_raw(line)
                val j: mut i64 = 0
                for {
                    if j >= l { break }
                    val c: u8 = trust @load8(@ptradd(line as ref void, j)) as u8
                    if c == 123 {
                        brace_depth++
                        started = true
                    } elif c == 125 && brace_depth > 0 {
                        brace_depth--
                    } elif c == 59 && started && brace_depth == 0 {
                        return make_block_result(i + 1, STOP_EOF, "")
                    }
                    j++
                }
            }
            none => {}
        }
        i++
    }
    return make_block_result(i, STOP_EOF, "")
}

fn collect_function(lines: list[ref u8], start: i64) ref BlockResult = {
    val len: i64 = @len(lines) as i64
    val paren_depth: mut i64 = 0
    val brace_depth: mut i64 = 0
    val seen_body: mut bool = false
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                val line: ref u8 = line_val as ref u8
                val l: i64 = string.len_raw(line)
                val j: mut i64 = 0
                for {
                    if j >= l { break }
                    val c: u8 = trust @load8(@ptradd(line as ref void, j)) as u8
                    if c == 40 { paren_depth++ }
                    elif c == 41 && paren_depth > 0 { paren_depth-- }
                    elif c == 123 && paren_depth == 0 {
                        brace_depth++
                        seen_body = true
                    } elif c == 125 && brace_depth > 0 {
                        brace_depth--
                        if seen_body && brace_depth == 0 {
                            return make_block_result(i + 1, STOP_EOF, "")
                        }
                    } elif c == 59 && paren_depth == 0 && !seen_body {
                        return make_block_result(i + 1, STOP_EOF, "")
                    }
                    j++
                }
            }
            none => {}
        }
        i++
    }
    return make_block_result(i, STOP_EOF, "")
}

fn translate_struct_decl(text: ref u8, indent: i64, out: ref void, ctx: ref TranslationCtx) bool = {
    val flat: ref u8 = flatten_ws(text)
    val open_i: i64 = find_char(flat, 123 as u8)
    val close_i: i64 = find_last_char(flat, 125 as u8)
    if open_i < 0 || close_i <= open_i { return false }
    val header: ref u8 = trim_raw(trust string.substr(flat, 0, open_i))
    val after: ref u8 = strip_trailing_semicolon(trim_raw(trust string.substr(flat, close_i + 1, string.len_raw(flat) - close_i - 1)))
    val before_body_name: mut ref u8 = ""
    if string.rchar_starts_with(header, "typedef struct") {
        val tail_len: i64 = string.len_raw(header) - 14
        if tail_len > 0 {
            before_body_name = trim_raw(trust string.substr(header, 14, tail_len))
        }
    } elif string.rchar_starts_with(header, "struct") {
        val tail_len: i64 = string.len_raw(header) - 6
        if tail_len > 0 {
            before_body_name = trim_raw(trust string.substr(header, 6, tail_len))
        }
    } else {
        return false
    }
    val alias0: ref u8 = extract_identifier_before(after, string.len_raw(after))
    val alias: mut ref u8 = alias0
    if string.rchar_cmp(alias, "") == 0 {
        alias = before_body_name
    }
    if string.rchar_cmp(alias, "") == 0 { return false }
    if list_contains(ctx.translated_type_names, alias) { return true }
    push_unique(ctx.translated_type_names, alias)
    val body: ref u8 = trust string.substr(flat, open_i + 1, close_i - open_i - 1)
    val prelude_out: ref void = string.StringBuilder.new()
    val fields_out: ref void = string.StringBuilder.new()
    val fields = split_top_level(body, 59 as u8)
    for field in fields {
        val trimmed: ref u8 = trim_raw(field)
        if string.rchar_cmp(trimmed, "") == 0 { continue }
        match translate_anonymous_union_field(trimmed, indent, prelude_out, ctx) {
            some field_line => {
                append_line(fields_out, indent + 1, field_line as ref u8)
                continue
            }
            none => {}
        }
        val field_items = split_multi_decl(ctx, trimmed)
        val decl_items: mut list[ref u8] = []
        if ((@len(field_items) as i64) > 1) {
            decl_items = field_items
        } else {
            @append(decl_items, trimmed)
        }
        for decl_text in decl_items {
            val decl: ref DeclInfo = parse_named_decl(ctx, decl_text, "")
            if !decl.its_ok || string.rchar_cmp(decl.name, "") == 0 {
                append_comment_line(fields_out, indent + 1, trust @fmt("unsupported field declaration: {s};", {decl_text}))
                continue
            }
            val field_type: mut ref u8 = decl.type_name
            if string.rchar_starts_with(field_type, "[]") {
                field_type = trust @fmt("ref {s}", {@ptradd(field_type, 2)})
                remember_flex_field(ctx, alias, decl.name, field_type)
            }
            append_line(fields_out, indent + 1, trust @fmt("{s}: {s}", {decl.name, render_mutable_type(field_type)}))
        }
    }
    append_builder(out, prelude_out)
    append_open_block_line(out, indent, trust @fmt("extern type {s} = ", {alias}))
    append_builder(out, fields_out)
    append_line(out, indent, "}")
    append_blank_line(out)
    return true
}

fn translate_enum_decl(text: ref u8, indent: i64, out: ref void, ctx: ref TranslationCtx) bool = {
    val flat: ref u8 = flatten_ws(text)
    val open_i: i64 = find_char(flat, 123 as u8)
    val close_i: i64 = find_last_char(flat, 125 as u8)
    if open_i < 0 || close_i <= open_i { return false }
    val header: ref u8 = trim_raw(trust string.substr(flat, 0, open_i))
    val after: ref u8 = strip_trailing_semicolon(trim_raw(trust string.substr(flat, close_i + 1, string.len_raw(flat) - close_i - 1)))
    val before_body_name: mut ref u8 = ""
    if string.rchar_starts_with(header, "typedef enum") {
        val tail_len: i64 = string.len_raw(header) - 12
        if tail_len > 0 {
            before_body_name = trim_raw(trust string.substr(header, 12, tail_len))
        }
    } elif string.rchar_starts_with(header, "enum") {
        val tail_len: i64 = string.len_raw(header) - 4
        if tail_len > 0 {
            before_body_name = trim_raw(trust string.substr(header, 4, tail_len))
        }
    } else {
        return false
    }
    val alias0: ref u8 = extract_identifier_before(after, string.len_raw(after))
    val alias: mut ref u8 = alias0
    if string.rchar_cmp(alias, "") == 0 {
        alias = before_body_name
    }
    alias = sanitize_identifier(alias)
    val body: ref u8 = trust string.substr(flat, open_i + 1, close_i - open_i - 1)
    val items = split_top_level(body, 44 as u8)
    if string.rchar_cmp(alias, "") == 0 {
        val next_value: mut ref u8 = "0"
        for item in items {
            val trimmed: ref u8 = trim_raw(item)
            if string.rchar_cmp(trimmed, "") == 0 { continue }
            val assign_i: i64 = find_top_level_assign(trimmed)
            val name_src: mut ref u8 = trimmed
            val value_expr: mut ref u8 = next_value
            if assign_i > 0 {
                name_src = trim_raw(trust string.substr(trimmed, 0, assign_i))
                value_expr = translate_expr_text(ctx, trim_raw(trust string.substr(trimmed, assign_i + 1, string.len_raw(trimmed) - assign_i - 1)))
            }
            val member: ref u8 = sanitize_identifier(trim_raw(name_src))
            if string.rchar_cmp(member, "") == 0 { continue }
            append_line(out, indent, trust @fmt("val {s}: i32 = {s}", {member, value_expr}))
            next_value = trust @fmt("({s}) + 1", {value_expr})
        }
        append_blank_line(out)
        return true
    }
    if list_contains(ctx.translated_type_names, alias) { return true }
    push_unique(ctx.translated_type_names, alias)
    val members: mut list[ref u8] = []
    for item in items {
        val trimmed: ref u8 = trim_raw(item)
        if string.rchar_cmp(trimmed, "") == 0 { continue }
        val member: ref u8 = sanitize_identifier(trim_raw(strip_initializer(trimmed)))
        if string.rchar_cmp(member, "") == 0 { continue }
        @append(members, member)
    }
    append_open_block_line(out, indent, trust @fmt("pub enum {s} = ", {alias}))
    val member_count: i64 = @len(members) as i64
    val member_i: mut i64 = 0
    for {
        if member_i >= member_count { break }
        val member_opt = @get(members, member_i as usize)
        match member_opt {
            some member_val => {
                val member: ref u8 = member_val as ref u8
                remember_enum_constant(ctx, member, alias)
                if member_i + 1 < member_count {
                    append_line(out, indent + 1, trust @fmt("{s},", {member}))
                } else {
                    append_line(out, indent + 1, member)
                }
            }
            none => {}
        }
        member_i++
    }
    append_line(out, indent, "}")
    append_blank_line(out)
    return true
}

fn emit_union_type(alias: ref u8, body: ref u8, indent: i64, out: ref void, ctx: ref TranslationCtx) void = {
    append_open_block_line(out, indent, trust @fmt("pub union {s} = ", {alias}))
    val fields = split_top_level(body, 59 as u8)
    val first_variant: mut bool = true
    for field in fields {
        val trimmed: ref u8 = trim_raw(field)
        if string.rchar_cmp(trimmed, "") == 0 { continue }
        val field_items = split_multi_decl(ctx, trimmed)
        val decl_items: mut list[ref u8] = []
        if ((@len(field_items) as i64) > 1) {
            decl_items = field_items
        } else {
            @append(decl_items, trimmed)
        }
        for decl_text in decl_items {
            val decl: ref DeclInfo = parse_named_decl(ctx, decl_text, "")
            if !decl.its_ok || string.rchar_cmp(decl.name, "") == 0 { continue }
            val variant_name: ref u8 = sanitize_identifier(decl.name)
            val payload_type0: ref u8 = decl.type_name
            val payload_type: mut ref u8 = payload_type0
            if is_array_type_name(payload_type0) {
                payload_type = decay_array_type(payload_type0)
            }
            val line_text: mut ref u8 = ""
            if string.rchar_cmp(payload_type, "void") == 0 {
                line_text = trust @fmt("{s}()", {variant_name})
            } else {
                line_text = trust @fmt("{s}({s})", {variant_name, payload_type})
            }
            if first_variant {
                append_line(out, indent + 1, line_text)
                first_variant = false
            } else {
                append_line(out, indent + 1, trust @fmt("| {s}", {line_text}))
            }
        }
    }
    append_line(out, indent, "}")
    append_blank_line(out)
}

fn translate_anonymous_union_field(field_text: ref u8, indent: i64, out: ref void, ctx: ref TranslationCtx) option[ref u8] = {
    val trimmed: ref u8 = trim_raw(field_text)
    if !string.rchar_starts_with(trimmed, "union") { return none }
    val open_i: i64 = find_char(trimmed, 123 as u8)
    val close_i: i64 = find_last_char(trimmed, 125 as u8)
    if open_i < 0 || close_i <= open_i { return none }
    val header: ref u8 = trim_raw(trust string.substr(trimmed, 0, open_i))
    val after: ref u8 = trim_raw(trust string.substr(trimmed, close_i + 1, string.len_raw(trimmed) - close_i - 1))
    val header_tail: ref u8 = trim_raw(trust string.substr(header, 5, string.len_raw(header) - 5))
    if string.rchar_cmp(header_tail, "") != 0 { return none }
    val field_name: ref u8 = sanitize_identifier(extract_identifier_before(after, string.len_raw(after)))
    if string.rchar_cmp(field_name, "") == 0 { return none }
    val union_name: ref u8 = fresh_union_name(ctx)
    push_unique(ctx.translated_type_names, union_name)
    val union_body: ref u8 = trust string.substr(trimmed, open_i + 1, close_i - open_i - 1)
    emit_union_type(union_name, union_body, indent, out, ctx)
    return some trust @fmt("{s}: {s}", {field_name, render_mutable_type(union_name)})
}

fn translate_union_decl(text: ref u8, indent: i64, out: ref void, ctx: ref TranslationCtx) bool = {
    val flat: ref u8 = flatten_ws(text)
    val open_i: i64 = find_char(flat, 123 as u8)
    val close_i: i64 = find_last_char(flat, 125 as u8)
    if open_i < 0 || close_i <= open_i { return false }
    val header: ref u8 = trim_raw(trust string.substr(flat, 0, open_i))
    val after: ref u8 = strip_trailing_semicolon(trim_raw(trust string.substr(flat, close_i + 1, string.len_raw(flat) - close_i - 1)))
    val before_body_name: mut ref u8 = ""
    if string.rchar_starts_with(header, "typedef union") {
        val tail_len: i64 = string.len_raw(header) - 13
        if tail_len > 0 {
            before_body_name = trim_raw(trust string.substr(header, 13, tail_len))
        }
    } elif string.rchar_starts_with(header, "union") {
        val tail_len: i64 = string.len_raw(header) - 5
        if tail_len > 0 {
            before_body_name = trim_raw(trust string.substr(header, 5, tail_len))
        }
    } else {
        return false
    }
    val alias0: ref u8 = extract_identifier_before(after, string.len_raw(after))
    val alias: mut ref u8 = alias0
    if string.rchar_cmp(alias, "") == 0 {
        alias = before_body_name
    }
    alias = sanitize_identifier(alias)
    if string.rchar_cmp(alias, "") == 0 { return false }
    if list_contains(ctx.translated_type_names, alias) { return true }
    push_unique(ctx.translated_type_names, alias)
    val body: ref u8 = trust string.substr(flat, open_i + 1, close_i - open_i - 1)
    emit_union_type(alias, body, indent, out, ctx)
    return true
}

fn translate_params(ctx: ref TranslationCtx, params_text: ref u8) ref u8 = {
    val trimmed: ref u8 = trim_raw(params_text)
    if string.rchar_cmp(trimmed, "") == 0 { return "" }
    if string.rchar_cmp(trimmed, "void") == 0 { return "" }
    val params = split_top_level(trimmed, 44 as u8)
    val sb: ref void = string.StringBuilder.new()
    val arg_index: mut i64 = 0
    val first: mut bool = true
    for param in params {
        val p: ref u8 = trim_raw(param)
        if string.rchar_cmp(p, "") == 0 { continue }
        if string.rchar_cmp(p, "...") == 0 {
            if !first { string.StringBuilder.append_cstr(sb, ", ") }
            string.StringBuilder.append_cstr(sb, "...")
            first = false
            continue
        }
        val fallback: ref u8 = trust @fmt("arg{d}", {arg_index})
        if str_contains(p, "(*") {
            val pname: ref u8 = parse_function_pointer_param_name(p, fallback)
            push_unique(ctx.fnptr_names, pname)
            if !first { string.StringBuilder.append_cstr(sb, ", ") }
            string.StringBuilder.append_cstr(sb, trust @fmt("{s}: ref void", {pname}))
            first = false
            arg_index++
            continue
        }
        val decl: ref DeclInfo = parse_named_decl(ctx, p, fallback)
        if !decl.its_ok {
            if !first { string.StringBuilder.append_cstr(sb, ", ") }
            string.StringBuilder.append_cstr(sb, trust @fmt("{s}: void", {fallback}))
            first = false
            arg_index++
            continue
        }
        val param_type: mut ref u8 = decl.type_name
        if is_array_type_name(decl.type_name) {
            param_type = decay_array_type(decl.type_name)
        }
        remember_local_type(ctx, decl.name, param_type)
        val rendered_type: ref u8 = render_binding_type(ctx, decl.name, param_type)
        if !first { string.StringBuilder.append_cstr(sb, ", ") }
        string.StringBuilder.append_cstr(sb, trust @fmt("{s}: {s}", {decl.name, rendered_type}))
        first = false
        arg_index++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn extract_main_param_name(ctx: ref TranslationCtx, params_text: ref u8, index: i64) ref u8 = {
    val trimmed: ref u8 = trim_raw(params_text)
    if string.rchar_cmp(trimmed, "") == 0 || string.rchar_cmp(trimmed, "void") == 0 { return "" }
    val params = split_top_level(trimmed, 44 as u8)
    val param_opt = @get(params, index as usize)
    match param_opt {
        some param_val => {
            val fallback: ref u8 = trust @fmt("arg{d}", {index})
            val decl: ref DeclInfo = parse_named_decl(ctx, trim_raw(param_val as ref u8), fallback)
            if decl.its_ok { return decl.name }
            return sanitize_identifier(fallback)
        }
        none => { return "" }
    }
}

fn text_uses_ident(text: ref u8, name: ref u8) bool = {
    if string.rchar_cmp(name, "") == 0 { return false }
    val len: i64 = string.len_raw(text)
    val nlen: i64 = string.len_raw(name)
    if len == 0 || nlen == 0 || nlen > len { return false }
    val i: mut i64 = 0
    val in_string: mut bool = false
    val in_char: mut bool = false
    val escaped: mut bool = false
    val in_line_comment: mut bool = false
    val in_block_comment: mut bool = false
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        val next: mut u8 = 0
        if i + 1 < len {
            next = trust @load8(@ptradd(text as ref void, i + 1)) as u8
        }
        if in_line_comment {
            if c == 10 || c == 13 { in_line_comment = false }
            i++
            continue
        }
        if in_block_comment {
            if c == 42 && next == 47 {
                in_block_comment = false
                i += 2
                continue
            }
            i++
            continue
        }
        if in_string {
            if escaped { escaped = false }
            elif c == 92 { escaped = true }
            elif c == 34 { in_string = false }
            i++
            continue
        }
        if in_char {
            if escaped { escaped = false }
            elif c == 92 { escaped = true }
            elif c == 39 { in_char = false }
            i++
            continue
        }
        if c == 47 && next == 47 {
            in_line_comment = true
            i += 2
            continue
        }
        if c == 47 && next == 42 {
            in_block_comment = true
            i += 2
            continue
        }
        if c == 34 {
            in_string = true
            i++
            continue
        }
        if c == 39 {
            in_char = true
            i++
            continue
        }
        if i + nlen <= len {
            val candidate: ref u8 = trust string.substr(text, i, nlen)
            if string.rchar_cmp(candidate, name) == 0 {
                val prev_ok: bool = i == 0 || !is_ident_part(trust @load8(@ptradd(text as ref void, i - 1)) as u8)
                val next_ok: bool = i + nlen >= len || !is_ident_part(trust @load8(@ptradd(text as ref void, i + nlen)) as u8)
                if prev_ok && next_ok { return true }
            }
        }
        i++
    }
    return false
}

fn emit_main_args_prelude(ctx: ref TranslationCtx, params_text: ref u8, body_text: ref u8, indent: i64, out: ref void) bool = {
    val argc_name: ref u8 = extract_main_param_name(ctx, params_text, 0)
    val argv_name: ref u8 = extract_main_param_name(ctx, params_text, 1)
    val needs_argc: bool = text_uses_ident(body_text, "argc") || text_uses_ident(body_text, argc_name)
    val needs_argv: bool = text_uses_ident(body_text, "args") || text_uses_ident(body_text, argv_name)
    if !needs_argc && !needs_argv { return false }
    remember_local_type(ctx, "args", "list[ref u8]")
    append_line(out, indent, "val args: list[ref u8] = @args()")
    if needs_argc {
        remember_local_type(ctx, "argc", "usize")
        append_line(out, indent, "val argc: usize = @len(args)")
    }
    if string.rchar_cmp(argc_name, "") != 0 && string.rchar_cmp(argc_name, "argc") != 0 && text_uses_ident(body_text, argc_name) {
        remember_local_type(ctx, argc_name, "usize")
        append_line(out, indent, trust @fmt("val {s}: usize = @len(args)", {argc_name}))
    }
    if string.rchar_cmp(argv_name, "") != 0 && string.rchar_cmp(argv_name, "args") != 0 && text_uses_ident(body_text, argv_name) {
        remember_local_type(ctx, argv_name, "list[ref u8]")
        append_line(out, indent, trust @fmt("val {s}: list[ref u8] = args", {argv_name}))
    }
    return true
}

fn strip_gnu_attributes(text: ref u8) ref u8 = {
    val len: i64 = string.len_raw(text)
    val sb: ref void = string.StringBuilder.new()
    val i: mut i64 = 0
    for {
        if i >= len { break }
        if i + 13 <= len {
            val frag: ref u8 = trust string.substr(text, i, 13)
            if string.rchar_cmp(frag, "__attribute__") == 0 {
                val prev_ok: bool = i == 0 || !is_ident_part(trust @load8(@ptradd(text as ref void, i - 1)) as u8)
                val next_ok: bool = i + 13 >= len || !is_ident_part(trust @load8(@ptradd(text as ref void, i + 13)) as u8)
                if prev_ok && next_ok {
                    val j: mut i64 = i + 13
                    for {
                        if j >= len { break }
                        val ws: u8 = trust @load8(@ptradd(text as ref void, j)) as u8
                        if !is_space(ws) { break }
                        j++
                    }
                    if j < len && (trust @load8(@ptradd(text as ref void, j)) as u8) == 40 {
                        val close_j: i64 = find_matching_delim(text, j, 40 as u8, 41 as u8)
                        if close_j > j {
                            i = close_j + 1
                            continue
                        }
                    }
                    i = j
                    continue
                }
            }
        }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        string.StringBuilder.append_char(sb, c)
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trim_raw(trust string.cstr(built))
}

fn translate_function_decl(text: ref u8, current_dir: ref u8, indent: i64, out: ref void, ctx: ref TranslationCtx) bool = {
    val has_body: bool = find_char(text, 123 as u8) >= 0
    val signature_src: mut ref u8 = ""
    val body_src: mut ref u8 = ""
    if has_body {
        val open_i: i64 = find_char(text, 123 as u8)
        val close_i: i64 = find_last_char(text, 125 as u8)
        if close_i <= open_i { return false }
        signature_src = trim_raw(trust string.substr(text, 0, open_i))
        body_src = trust string.substr(text, open_i + 1, close_i - open_i - 1)
    } else {
        val semi_i: i64 = find_last_char(text, 59 as u8)
        if semi_i < 0 { return false }
        signature_src = trim_raw(trust string.substr(text, 0, semi_i))
        body_src = ""
    }
    val signature: ref u8 = flatten_ws(strip_gnu_attributes(signature_src))
    val open_paren: i64 = find_char(signature, 40 as u8)
    val close_paren: i64 = find_matching_delim(signature, open_paren, 40 as u8, 41 as u8)
    if open_paren < 0 || close_paren <= open_paren { return false }
    val head: ref u8 = trim_raw(trust string.substr(signature, 0, open_paren))
    val params_raw: ref u8 = trim_raw(trust string.substr(signature, open_paren + 1, close_paren - open_paren - 1))
    val name: ref u8 = sanitize_identifier(extract_identifier_before(head, string.len_raw(head)))
    if string.rchar_cmp(name, "") == 0 { return false }
    val head_len: i64 = string.len_raw(head)
    val name_len: i64 = string.len_raw(name)
    if head_len < name_len { return false }
    if head_len == name_len { return false }
    val return_src: ref u8 = trim_raw(trust string.substr(head, 0, head_len - name_len))
    val return_type: ref u8 = translate_c_type_ctx(ctx, return_src, "")
    clear_local_types(ctx)
    if has_body {
        val body_lines0 = split_lines(body_src)
        analyze_mutable_names(ctx, body_lines0, 0)
        analyze_address_taken_names(ctx, body_lines0, 0)
    }
    val is_main: bool = string.rchar_cmp(name, "main") == 0
    val params_text: mut ref u8 = ""
    if !is_main {
        params_text = translate_params(ctx, params_raw)
    }
    val is_static: bool = str_contains(signature, "static ")
    val line: mut ref u8 = ""
    if has_body {
        push_unique(ctx.defined_names, name)
        val fn_kw: mut ref u8 = "pub fn"
        if is_static { fn_kw = "fn" }
        line = trust @fmt("{s} {s}({s}) {s}! = ", {fn_kw, name, params_text, return_type})
        append_open_block_line(out, indent, line)
        if is_main {
            val body_lines = split_lines(body_src)
            emit_main_args_prelude(ctx, params_raw, body_src, indent + 1, out)
            if ((@len(ctx.main_prelude_lines) as i64) > 0) {
                append_blank_line(out)
            }
            for prelude_line in ctx.main_prelude_lines {
                append_line(out, indent + 1, prelude_line)
            }
            if ((@len(body_lines) as i64) > 0) {
                append_blank_line(out)
            }
            translate_body_lines(body_lines, current_dir, 0, indent + 1, out, ctx)
            if string.rchar_cmp(return_type, "i32") == 0
                && !body_has_explicit_return(body_lines) {
                append_blank_line(out)
                append_line(out, indent + 1, "return 0")
            }
        } else {
            val body_lines = split_lines(body_src)
            translate_body_lines(body_lines, current_dir, 0, indent + 1, out, ctx)
        }
        append_line(out, indent, "}")
        append_blank_line(out)
        return true
    }
    if is_static {
        append_comment_line(out, indent, trust @fmt("static prototype omitted: {s};", {signature}))
        return true
    }
    if list_contains(ctx.extern_names, name) { return true }
    push_unique(ctx.extern_names, name)
    line = trust @fmt("extern (C) fn {s}({s}) {s}! = \"{s}\"", {name, params_text, return_type, name})
    append_line(out, indent, line)
    return true
}

fn translate_top_level_decl(text: ref u8, indent: i64, out: ref void, ctx: ref TranslationCtx) bool = {
    val stripped: ref u8 = strip_trailing_semicolon(trim_raw(text))
    if string.rchar_cmp(stripped, "") == 0 { return false }
    val multi_decls = split_multi_decl(ctx, stripped)
    if ((@len(multi_decls) as i64) > 1) {
        val any_ok: mut bool = false
        for decl_text in multi_decls {
            if translate_top_level_decl(decl_text, indent, out, ctx) { any_ok = true }
        }
        return any_ok
    }
    if string.rchar_starts_with(stripped, "typedef ")
        && !string.rchar_starts_with(stripped, "typedef struct")
        && !string.rchar_starts_with(stripped, "typedef enum")
        && !string.rchar_starts_with(stripped, "typedef union")
        && !str_contains(stripped, "(") {
        val after_typedef: ref u8 = trim_raw(trust string.substr(stripped, 8, string.len_raw(stripped) - 8))
        val alias_decl: ref DeclInfo = parse_named_decl(ctx, after_typedef, "")
        if alias_decl.its_ok && string.rchar_cmp(alias_decl.name, "") != 0
            && string.rchar_cmp(alias_decl.type_name, alias_decl.name) != 0 {
            register_typedef_alias(ctx, alias_decl.name, alias_decl.type_name)
        }
        return true
    }
    val assign_i: i64 = find_top_level_assign(stripped)
    if assign_i > 0 {
        val lhs: ref u8 = trim_raw(trust string.substr(stripped, 0, assign_i))
        val rhs: ref u8 = trim_raw(trust string.substr(stripped, assign_i + 1, string.len_raw(stripped) - assign_i - 1))
        val can_be_decl: bool = str_contains(lhs, " ")
            || string.rchar_starts_with(lhs, "struct ")
            || string.rchar_starts_with(lhs, "enum ")
            || string.rchar_starts_with(lhs, "union ")
        if !can_be_decl { return false }
        val decl: ref DeclInfo = parse_named_decl(ctx, lhs, "")
        if !decl.its_ok || string.rchar_cmp(decl.name, "") == 0 || string.rchar_cmp(trim_raw(decl.type_src), "") == 0 {
            return false
        }
        if is_array_type_name(decl.type_name) {
            val array_init_items = parse_brace_initializer_items(rhs)
            val elem_type: ref u8 = array_type_elem(decl.type_name)
            val alloc_expr: mut ref u8 = array_alloc_expr(decl.type_name)
            if string.rchar_cmp(array_type_len_expr(decl.type_name), "") == 0 && (@len(array_init_items) as i64) > 0 {
                alloc_expr = trust @fmt("{d} * @sizeof({s})", {@len(array_init_items) as i64, elem_type})
            }
            val decayed_type: ref u8 = decay_array_type(decl.type_name)
            val is_char_array_literal: bool = string.rchar_cmp(elem_type, "u8") == 0 && is_string_literal_text(rhs)
            remember_global_type(ctx, decl.name, decayed_type)
            remember_global_array_type(ctx, decl.name, alloc_expr)
            append_line(out, indent, trust @fmt("val {s}: {s} = @alloc({s})", {decl.name, render_mutable_type(decayed_type), alloc_expr}))
            if is_char_array_literal {
                val prelude_sb: ref void = string.StringBuilder.new()
                val lowered_rhs_char: ref LoweredExpr = lower_incdec_expr(ctx, rhs, 0, prelude_sb)
                val rhs_expr_char: ref u8 = lowered_rhs_char.expr
                val copy_len: i64 = string_literal_storage_len(rhs)
                append_line(prelude_sb, 0, trust @fmt("@memset({s} as ref void, 0, {s})", {decl.name, alloc_expr}))
                append_line(prelude_sb, 0, trust @fmt("@memcpy({s} as ref void, {s} as ref void, {d} as usize)", {decl.name, rhs_expr_char, copy_len}))
                track_called_expr(ctx, rhs_expr_char)
                append_main_prelude_builder(ctx, prelude_sb)
            }
            if ((@len(array_init_items) as i64) > 0) {
                val prelude_sb2: ref void = string.StringBuilder.new()
                emit_array_initializer_stores(ctx, prelude_sb2, 0, decl.name, array_init_items)
                append_main_prelude_builder(ctx, prelude_sb2)
            }
            return true
        }
        remember_global_type(ctx, decl.name, decl.type_name)
        val lowered_rhs: ref LoweredExpr = lower_incdec_expr(ctx, rhs, indent, out)
        val rhs_expr: mut ref u8 = lowered_rhs.expr
        if string.rchar_cmp(trim_raw(rhs), "NULL") == 0 {
            rhs_expr = trust @fmt("0 as {s}", {decl.type_name})
        }
        track_called_expr(ctx, rhs_expr)
        append_line(out, indent, trust @fmt("val {s}: {s} = {s}", {decl.name, render_mutable_type(decl.type_name), rhs_expr}))
        return true
    }
    val can_be_bare_decl: bool = (str_contains(stripped, " ") || str_contains(stripped, "*")
        || string.rchar_starts_with(stripped, "struct ") || string.rchar_starts_with(stripped, "enum ")
        || string.rchar_starts_with(stripped, "union "))
        && !str_contains(stripped, "(")
    if can_be_bare_decl {
        val decl2: ref DeclInfo = parse_named_decl(ctx, stripped, "")
        if decl2.its_ok && string.rchar_cmp(decl2.name, "") != 0 {
            if is_array_type_name(decl2.type_name) {
                val alloc_expr2: ref u8 = array_alloc_expr(decl2.type_name)
                val decayed_type2: ref u8 = decay_array_type(decl2.type_name)
                remember_global_type(ctx, decl2.name, decayed_type2)
                remember_global_array_type(ctx, decl2.name, alloc_expr2)
                append_line(out, indent, trust @fmt("val {s}: {s} = @alloc({s})", {decl2.name, render_mutable_type(decayed_type2), alloc_expr2}))
                return true
            }
            remember_global_type(ctx, decl2.name, decl2.type_name)
            append_line(out, indent, trust @fmt("val {s}: {s} = {s}", {decl2.name, render_mutable_type(decl2.type_name), zero_init_expr(decl2.type_name)}))
            return true
        }
    }
    return false
}

fn translate_file(path: ref u8, out: ref void, seen: mut list[ref u8], ctx: ref TranslationCtx) bool = {
    if list_contains(seen, path) { return true }
    @append(seen, path)
    val content_opt = trust preprocess_source(path)
    match content_opt {
        none => {
            append_comment_line(out, 0, trust @fmt("failed to read include: {s}", {path}))
            return false
        }
        some content_val => {
            val content: ref u8 = content_val as ref u8
            val lines = split_lines(content)
            val current_dir: ref u8 = trust path.dir(path)
            val result = translate_top_level(lines, current_dir, 0, 0, out, seen, ctx)
            if result.stop_kind != STOP_EOF {
                append_comment_line(out, 0, trust @fmt("unterminated preprocessor block in {s}", {path}))
            }
            return true
        }
    }
}

pub fn translate_top_level(
    lines: list[ref u8],
    current_dir: ref u8,
    start: i64,
    indent: i64,
    out: ref void,
    seen: mut list[ref u8],
    ctx: ref TranslationCtx
) ref BlockResult = {
    val len: i64 = @len(lines) as i64
    val i: mut i64 = start
    for {
        if i >= len { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                val line: ref u8 = line_val as ref u8
                val trimmed: ref u8 = trim_raw(line)
                if string.rchar_cmp(trimmed, "") == 0 {
                    i++
                    continue
                }
                if string.rchar_starts_with(trimmed, "#else") {
                    return make_block_result(i + 1, STOP_ELSE, trimmed)
                }
                if string.rchar_starts_with(trimmed, "#endif") {
                    return make_block_result(i + 1, STOP_ENDIF, trimmed)
                }
                if string.rchar_starts_with(trimmed, "#elif") {
                    return make_block_result(i + 1, STOP_ELIF, trimmed)
                }
                if string.rchar_starts_with(trimmed, "#pragma once") {
                    i++
                    continue
                }
                if string.rchar_starts_with(trimmed, "#include") {
                    val include_name: ref u8 = parse_include_name(trimmed)
                    if string.rchar_cmp(include_name, "") == 0 {
                        append_comment_line(out, indent, trimmed)
                    } elif is_system_include(trimmed) {
                        i++
                        continue
                    } else {
                        val include_path_opt = resolve_include_path(include_name, current_dir)
                        match include_path_opt {
                            some include_path => {
                                translate_file(include_path as ref u8, out, seen, ctx)
                            }
                            none => {
                                append_comment_line(out, indent, trust @fmt("unresolved include: {s}", {include_name}))
                            }
                        }
                    }
                    i++
                    continue
                }
                val ifndef_name: ref u8 = parse_macro_name(trimmed, "#ifndef")
                if is_header_guard(lines, i, ifndef_name) {
                    val define_i: i64 = next_significant_line(lines, i + 1)
                    val inner = translate_top_level(lines, current_dir, define_i + 1, indent, out, seen, ctx)
                    i = inner.next_index
                    continue
                }
                val cond: i64 = detect_condition(trimmed)
                if cond == COND_WIN_TRUE {
                    append_line(out, indent, "when windows {")
                    val then_result = translate_top_level(lines, current_dir, i + 1, indent + 1, out, seen, ctx)
                    if then_result.stop_kind == STOP_ELSE {
                        append_line(out, indent, "} otherwise {")
                        val else_result = translate_top_level(lines, current_dir, then_result.next_index, indent + 1, out, seen, ctx)
                        append_line(out, indent, "}")
                        i = else_result.next_index
                    } elif then_result.stop_kind == STOP_ELIF {
                        append_line(out, indent, "} otherwise {")
                        append_comment_line(out, indent + 1, then_result.stop_line)
                        val elif_result = translate_top_level(lines, current_dir, then_result.next_index, indent + 1, out, seen, ctx)
                        append_line(out, indent, "}")
                        i = elif_result.next_index
                    } else {
                        append_line(out, indent, "}")
                        i = then_result.next_index
                    }
                    continue
                }
                if cond == COND_WIN_FALSE {
                    val non_windows: ref void = string.StringBuilder.new()
                    val then_result = translate_top_level(lines, current_dir, i + 1, indent + 1, non_windows, seen, ctx)
                    append_line(out, indent, "when windows {")
                    if then_result.stop_kind == STOP_ELSE {
                        val else_result = translate_top_level(lines, current_dir, then_result.next_index, indent + 1, out, seen, ctx)
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = else_result.next_index
                    } elif then_result.stop_kind == STOP_ELIF {
                        append_comment_line(out, indent + 1, then_result.stop_line)
                        val elif_result = translate_top_level(lines, current_dir, then_result.next_index, indent + 1, out, seen, ctx)
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = elif_result.next_index
                    } else {
                        append_line(out, indent, "} otherwise {")
                        append_builder(out, non_windows)
                        append_line(out, indent, "}")
                        i = then_result.next_index
                    }
                    continue
                }
                if string.rchar_starts_with(trimmed, "#define")
                    || string.rchar_starts_with(trimmed, "#undef")
                    || string.rchar_starts_with(trimmed, "#pragma")
                    || string.rchar_starts_with(trimmed, "#error")
                    || string.rchar_starts_with(trimmed, "#if")
                    || string.rchar_starts_with(trimmed, "#ifndef")
                    || string.rchar_starts_with(trimmed, "#ifdef") {
                    append_comment_line(out, indent, trimmed)
                    i++
                    continue
                }
                val starts_struct_decl: bool = string.rchar_starts_with(trimmed, "typedef struct")
                    || string.rchar_starts_with(trimmed, "struct ")
                val starts_enum_decl: bool = string.rchar_starts_with(trimmed, "typedef enum")
                    || string.rchar_starts_with(trimmed, "enum ")
                val starts_union_decl: bool = string.rchar_starts_with(trimmed, "typedef union")
                    || string.rchar_starts_with(trimmed, "union ")
                val type_decl_has_brace: mut bool = str_contains(trimmed, "{")
                if ((starts_struct_decl || starts_enum_decl || starts_union_decl) && !type_decl_has_brace) {
                    val next_i_struct: i64 = next_significant_line(lines, i + 1)
                    if next_i_struct >= 0 {
                        val next_struct_opt = @get(lines, next_i_struct as usize)
                        match next_struct_opt {
                            some next_struct_line => {
                                val next_struct_trimmed: ref u8 = trim_raw(next_struct_line as ref u8)
                                if string.rchar_cmp(next_struct_trimmed, "{") == 0 {
                                    type_decl_has_brace = true
                                }
                            }
                            none => {}
                        }
                    }
                }
                if starts_struct_decl && type_decl_has_brace {
                    val span = collect_struct(lines, i)
                    val full_text: ref u8 = join_lines(lines, i, span.next_index)
                    if !translate_struct_decl(full_text, indent, out, ctx) {
                        append_comment_line(out, indent, trust @fmt("unsupported struct declaration: {s}", {trimmed}))
                    }
                    i = span.next_index
                    continue
                }
                if starts_enum_decl && type_decl_has_brace {
                    val span_enum = collect_struct(lines, i)
                    val full_text_enum: ref u8 = join_lines(lines, i, span_enum.next_index)
                    if !translate_enum_decl(full_text_enum, indent, out, ctx) {
                        append_comment_line(out, indent, trust @fmt("unsupported enum declaration: {s}", {trimmed}))
                    }
                    i = span_enum.next_index
                    continue
                }
                if starts_union_decl && type_decl_has_brace {
                    val span_union = collect_struct(lines, i)
                    val full_text_union: ref u8 = join_lines(lines, i, span_union.next_index)
                    if !translate_union_decl(full_text_union, indent, out, ctx) {
                        append_comment_line(out, indent, trust @fmt("unsupported union declaration: {s}", {trimmed}))
                    }
                    i = span_union.next_index
                    continue
                }
                if str_contains(trimmed, "(")
                    && !string.rchar_starts_with(trimmed, "if")
                    && !string.rchar_starts_with(trimmed, "for")
                    && !string.rchar_starts_with(trimmed, "while")
                    && !string.rchar_starts_with(trimmed, "switch")
                    && !string.rchar_starts_with(trimmed, "return") {
                    val span2 = collect_function(lines, i)
                    val full_text2: ref u8 = join_lines(lines, i, span2.next_index)
                    if translate_function_decl(full_text2, current_dir, indent, out, ctx) {
                        i = span2.next_index
                        continue
                    }
                }
                if translate_top_level_decl(trimmed, indent, out, ctx) {
                    i++
                    continue
                }
                append_comment_line(out, indent, trimmed)
                i++
            }
            none => { i++ }
        }
    }
    return make_block_result(i, STOP_EOF, "")
}

pub fn translate_c(input_path: ref u8, output_path: ref u8) i32 = {
    val body: ref void = string.StringBuilder.new()
    val seen: mut list[ref u8] = []
    val ctx: ref TranslationCtx = new_translation_ctx()
    val its_ok: bool = translate_file(input_path, body, seen, ctx)
    if !its_ok {
        trust stdio.print("error: failed to translate '{s}'\n", {input_path})
        return 1
    }
    val out: ref void = string.StringBuilder.new()
    append_comment_line(out, 0, trust @fmt("Generated by spectre --translate-c from {s}", {input_path}))
    append_blank_line(out)
    append_synthesized_externs(ctx, out)
    append_builder(out, body)
    val built: ref void = string.StringBuilder.build(out)
    val out_dir: ref u8 = trust path.dir(output_path)
    if string.rchar_cmp(out_dir, "") != 0 && string.rchar_cmp(out_dir, ".") != 0 {
        trust os.exec(@fmt("mkdir -p {s}", {out_dir}))
    }
    val written: bool = trust fs.write_all(output_path, string.cstr(built))
    if !written {
        trust stdio.print("error: could not write '{s}'\n", {output_path})
        return 1
    }
    trust stdio.print("wrote {s}\n", {output_path})
    return 0
}
