val stdio = use("std/stdio")
val string = use("std/string")
val path = use("std/path")
val os = use("std/os")
val fs = use("std/fs")

pub val STOP_EOF       : i64 = 0
pub val STOP_ELSE      : i64 = 1
pub val STOP_ENDIF     : i64 = 2
pub val STOP_ELIF      : i64 = 3
pub val COND_NONE      : i64 = 0
pub val COND_WIN_TRUE  : i64 = 1
pub val COND_WIN_FALSE : i64 = 2

type BlockResult = {
    next_index: mut i64
    stop_kind:  mut i64
    stop_line:  mut ref u8
}

type DeclInfo = {
    its_ok:    mut bool
    name:      mut ref u8
    type_name: mut ref u8
    type_src:  mut ref u8
}

type LoweredExpr = {
    expr:    mut ref u8
    changed: mut bool
}

type SwitchCase = {
    labels: mut list[ref u8]
    body_lines: mut list[ref u8]
    is_default: mut bool
}

type TranslationCtx = {
    defined_names: mut list[ref u8]
    called_names:  mut list[ref u8]
    called_sig_names: mut list[ref u8]
    called_sig_params: mut list[ref u8]
    extern_names:  mut list[ref u8]
    fnptr_names:   mut list[ref u8]
    translated_type_names: mut list[ref u8]
    enum_constant_names: mut list[ref u8]
    enum_constant_types: mut list[ref u8]
    local_names:   mut list[ref u8]
    local_types:   mut list[ref u8]
    local_array_names: mut list[ref u8]
    local_array_types: mut list[ref u8]
    global_names: mut list[ref u8]
    global_types: mut list[ref u8]
    global_array_names: mut list[ref u8]
    global_array_types: mut list[ref u8]
    mutable_names: mut list[ref u8]
    address_taken_names: mut list[ref u8]
    flex_struct_names: mut list[ref u8]
    flex_field_names:  mut list[ref u8]
    flex_field_types:  mut list[ref u8]
    typedef_alias_names: mut list[ref u8]
    typedef_alias_types: mut list[ref u8]
    main_prelude_lines: mut list[ref u8]
    temp_counter:  mut i64
    union_counter: mut i64
}

fn make_block_result(next_index: i64, stop_kind: i64, stop_line: ref u8) ref BlockResult = {
    val result: mut ref BlockResult = @alloc(@sizeof(BlockResult)) as ref BlockResult
    result.next_index = next_index
    result.stop_kind  = stop_kind
    result.stop_line  = stop_line
    return result
}

fn new_translation_ctx() ref TranslationCtx = {
    val ctx: mut ref TranslationCtx = @alloc(@sizeof(TranslationCtx)) as ref TranslationCtx
    ctx.defined_names = []
    ctx.called_names  = []
    ctx.called_sig_names = []
    ctx.called_sig_params = []
    ctx.extern_names  = []
    ctx.fnptr_names   = []
    ctx.translated_type_names = []
    ctx.enum_constant_names = []
    ctx.enum_constant_types = []
    ctx.local_names   = []
    ctx.local_types   = []
    ctx.local_array_names = []
    ctx.local_array_types = []
    ctx.global_names = []
    ctx.global_types = []
    ctx.global_array_names = []
    ctx.global_array_types = []
    ctx.mutable_names = []
    ctx.address_taken_names = []
    ctx.flex_struct_names = []
    ctx.flex_field_names  = []
    ctx.flex_field_types  = []
    ctx.typedef_alias_names = []
    ctx.typedef_alias_types = []
    ctx.main_prelude_lines = []
    ctx.temp_counter = 0
    ctx.union_counter = 0
    return ctx
}

fn make_lowered_expr(expr: ref u8, changed: bool) ref LoweredExpr = {
    val lowered: mut ref LoweredExpr = @alloc(@sizeof(LoweredExpr)) as ref LoweredExpr
    lowered.expr = expr
    lowered.changed = changed
    return lowered
}

fn make_switch_case() ref SwitchCase = {
    val item: mut ref SwitchCase = @alloc(@sizeof(SwitchCase)) as ref SwitchCase
    item.labels = []
    item.body_lines = []
    item.is_default = false
    return item
}

fn is_space(c: u8) bool = {
    return c == 32 || c == 9 || c == 10 || c == 13
}

fn is_ident_start(c: u8) bool = {
    return (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95
}

fn is_ident_part(c: u8) bool = {
    return is_ident_start(c) || (c >= 48 && c <= 57)
}

fn sanitize_identifier(name: ref u8) ref u8 = {
    if string.rchar_cmp(name, "fn") == 0        { return "func" }
    if string.rchar_cmp(name, "val") == 0       { return "value" }
    if string.rchar_cmp(name, "mut") == 0       { return "mutable" }
    if string.rchar_cmp(name, "pub") == 0       { return "public" }
    if string.rchar_cmp(name, "type") == 0      { return "type_value" }
    if string.rchar_cmp(name, "pre") == 0       { return "precond" }
    if string.rchar_cmp(name, "post") == 0      { return "postcond" }
    if string.rchar_cmp(name, "return") == 0    { return "return_value" }
    if string.rchar_cmp(name, "if") == 0        { return "if_value" }
    if string.rchar_cmp(name, "else") == 0      { return "else_value" }
    if string.rchar_cmp(name, "elif") == 0      { return "elif_value" }
    if string.rchar_cmp(name, "trust") == 0     { return "trusted_value" }
    if string.rchar_cmp(name, "use") == 0       { return "used_value" }
    if string.rchar_cmp(name, "ref") == 0       { return "reference" }
    if string.rchar_cmp(name, "for") == 0       { return "loop_value" }
    if string.rchar_cmp(name, "in") == 0        { return "in_value" }
    if string.rchar_cmp(name, "some") == 0      { return "some_value" }
    if string.rchar_cmp(name, "none") == 0      { return "none_value" }
    if string.rchar_cmp(name, "ok") == 0        { return "ok_value" }
    if string.rchar_cmp(name, "err") == 0       { return "error_value" }
    if string.rchar_cmp(name, "match") == 0     { return "match_value" }
    if string.rchar_cmp(name, "true") == 0      { return "true_value" }
    if string.rchar_cmp(name, "false") == 0     { return "false_value" }
    if string.rchar_cmp(name, "defer") == 0     { return "deferred_value" }
    if string.rchar_cmp(name, "break") == 0     { return "break_value" }
    if string.rchar_cmp(name, "continue") == 0  { return "continue_value" }
    if string.rchar_cmp(name, "as") == 0        { return "as_value" }
    if string.rchar_cmp(name, "assert") == 0    { return "assert_value" }
    if string.rchar_cmp(name, "when") == 0      { return "when_value" }
    if string.rchar_cmp(name, "union") == 0     { return "union_value" }
    if string.rchar_cmp(name, "enum") == 0      { return "enum_value" }
    if string.rchar_cmp(name, "extern") == 0    { return "external_value" }
    if string.rchar_cmp(name, "link") == 0      { return "link_value" }
    if string.rchar_cmp(name, "guarded") == 0   { return "guarded_value" }
    if string.rchar_cmp(name, "not") == 0       { return "not_value" }
    if string.rchar_cmp(name, "test") == 0      { return "test_value" }
    if string.rchar_cmp(name, "guard") == 0     { return "guard_value" }
    if string.rchar_cmp(name, "invariant") == 0 { return "invariant_value" }
    return name
}

fn str_contains(haystack: ref u8, needle: ref u8) bool = {
    val hlen: i64 = string.len_raw(haystack)
    val nlen: i64 = string.len_raw(needle)
    if nlen == 0 { return true }
    if nlen > hlen { return false }
    val i: mut i64 = 0
    for {
        if i > hlen - nlen { break }
        val matched: mut bool = true
        val j: mut i64 = 0
        for {
            if j >= nlen { break }
            val a: u8 = trust @load8(@ptradd(haystack as ref void, i + j)) as u8
            val b: u8 = trust @load8(@ptradd(needle as ref void, j)) as u8
            if a != b {
                matched = false
                break
            }
            j++
        }
        if matched { return true }
        i++
    }
    return false
}

fn find_char(text: ref u8, target: u8) i64 = {
    val len: i64 = string.len_raw(text)
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == target { return i }
        i++
    }
    return -1
}

fn find_last_char(text: ref u8, target: u8) i64 = {
    val len: i64 = string.len_raw(text)
    val i: mut i64 = len - 1
    for {
        if i < 0 { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if c == target { return i }
        i--
    }
    return -1
}

fn trim_raw(text: ref u8) ref u8 = {
    val len: i64 = string.len_raw(text)
    if len == 0 { return "" }
    val start: mut i64 = 0
    for {
        if start >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, start)) as u8
        if !is_space(c) { break }
        start++
    }
    val end: mut i64 = len - 1
    for {
        if end < start { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, end)) as u8
        if !is_space(c) { break }
        end--
    }
    if end < start { return "" }
    return trust string.substr(text, start, end - start + 1)
}

fn flatten_ws(text: ref u8) ref u8 = {
    val sb: ref void = string.StringBuilder.new()
    val len: i64 = string.len_raw(text)
    val last_space: mut bool = true
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(text as ref void, i)) as u8
        if is_space(c) {
            if !last_space {
                string.StringBuilder.append_char(sb, 32)
                last_space = true
            }
        } else {
            string.StringBuilder.append_char(sb, c)
            last_space = false
        }
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust trim_raw(string.cstr(built))
}

fn starts_keyword_paren(text: ref u8, keyword: ref u8) bool = {
    val trimmed: ref u8 = trim_raw(text)
    val kw_len: i64 = string.len_raw(keyword)
    val len: i64 = string.len_raw(trimmed)
    if len <= kw_len { return false }
    if !string.rchar_starts_with(trimmed, keyword) { return false }
    val i: mut i64 = kw_len
    for {
        if i >= len { break }
        val c: u8 = trust @load8(@ptradd(trimmed as ref void, i)) as u8
        if !is_space(c) { break }
        i++
    }
    if i >= len { return false }
    return (trust @load8(@ptradd(trimmed as ref void, i)) as u8) == 40
}

fn starts_do_statement(text: ref u8) bool = {
    val trimmed: ref u8 = trim_raw(text)
    if !string.rchar_starts_with(trimmed, "do") { return false }
    val len: i64 = string.len_raw(trimmed)
    if len == 2 { return true }
    val next: u8 = trust @load8(@ptradd(trimmed as ref void, 2)) as u8
    return is_space(next) || next == 123
}

fn split_lines(text: ref u8) list[ref u8] = {
    val lines: mut list[ref u8] = []
    val len: i64 = string.len_raw(text)
    val start: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i > len { break }
        val at_end: bool = i == len
        val c: mut u8 = 0
        if !at_end {
            c = trust @load8(@ptradd(text as ref void, i)) as u8
        }
        if at_end || c == 10 {
            val line_len: i64 = i - start
            val trimmed_len: mut i64 = line_len
            if trimmed_len > 0 {
                val last: u8 = trust @load8(@ptradd(text as ref void, start + trimmed_len - 1)) as u8
                if last == 13 { trimmed_len-- }
            }
            @append(lines, trust string.substr(text, start, trimmed_len))
            start = i + 1
        }
        i++
    }
    return lines
}

fn join_lines(lines: list[ref u8], start: i64, end_exclusive: i64) ref u8 = {
    val sb: ref void = string.StringBuilder.new()
    val i: mut i64 = start
    for {
        if i >= end_exclusive { break }
        val line_opt = @get(lines, i as usize)
        match line_opt {
            some line_val => {
                string.StringBuilder.append_cstr(sb, line_val as ref u8)
                if i + 1 < end_exclusive {
                    string.StringBuilder.append_char(sb, 10)
                }
            }
            none => {}
        }
        i++
    }
    val built: ref void = string.StringBuilder.build(sb)
    string.StringBuilder.free(sb)
    return trust string.cstr(built)
}

fn push_indent(sb: ref void, indent: i64) void = {
    val i: mut i64 = 0
    for {
        if i >= indent { break }
        string.StringBuilder.append_cstr(sb, "    ")
        i++
    }
}

fn append_line(sb: ref void, indent: i64, line: ref u8) void = {
    push_indent(sb, indent)
    string.StringBuilder.append_cstr(sb, line)
    string.StringBuilder.append_char(sb, 10)
}

fn append_blank_line(sb: ref void) void = {
    string.StringBuilder.append_char(sb, 10)
}

fn append_comment_line(sb: ref void, indent: i64, line: ref u8) void = {
    val trimmed: ref u8 = trim_raw(line)
    if string.rchar_cmp(trimmed, "") == 0 {
        append_blank_line(sb)
        return
    }
    push_indent(sb, indent)
    string.StringBuilder.append_cstr(sb, "// ")
    string.StringBuilder.append_cstr(sb, trimmed)
    string.StringBuilder.append_char(sb, 10)
}

fn list_contains(items: list[ref u8], value: ref u8) bool = {
    for item in items {
        if string.rchar_cmp(item, value) == 0 { return true }
    }
    return false
}

fn push_unique(items: mut list[ref u8], value: ref u8) void = {
    if list_contains(items, value) { return }
    @append(items, value)
}

fn clear_local_types(ctx: mut ref TranslationCtx) void = {
    ctx.local_names = []
    ctx.local_types = []
    ctx.local_array_names = []
    ctx.local_array_types = []
    ctx.mutable_names = []
    ctx.address_taken_names = []
    ctx.temp_counter = 0
}

fn register_typedef_alias(ctx: ref TranslationCtx, alias_name: ref u8, spectre_type: ref u8) void = {
    val len: i64 = @len(ctx.typedef_alias_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val existing_opt = @get(ctx.typedef_alias_names, i as usize)
        match existing_opt {
            some existing_name => {
                if string.rchar_cmp(existing_name as ref u8, alias_name) == 0 {
                    @set(ctx.typedef_alias_types, i as usize, spectre_type)
                    return
                }
            }
            none => {}
        }
        i++
    }
    @append(ctx.typedef_alias_names, alias_name)
    @append(ctx.typedef_alias_types, spectre_type)
    push_unique(ctx.translated_type_names, alias_name)
}

fn lookup_typedef_alias(ctx: ref TranslationCtx, alias_name: ref u8) option[ref u8] = {
    val len: i64 = @len(ctx.typedef_alias_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val name_opt = @get(ctx.typedef_alias_names, i as usize)
        match name_opt {
            some name_val => {
                if string.rchar_cmp(name_val as ref u8, alias_name) == 0 {
                    val type_opt = @get(ctx.typedef_alias_types, i as usize)
                    match type_opt {
                        some type_val => { return some type_val as ref u8 }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return none
}

fn remember_local_type(ctx: ref TranslationCtx, name: ref u8, type_name: ref u8) void = {
    val len: i64 = @len(ctx.local_names) as i64
