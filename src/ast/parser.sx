fn kind_is_else(k: lexer.TokenKind) bool! = { match k { Else() => { return true } else => { return false } } }
fn kind_is_for(k: lexer.TokenKind) bool! = { match k { For() => { return true } else => { return false } } }
fn kind_is_in(k: lexer.TokenKind) bool! = { match k { In() => { return true } else => { return false } } }
fn kind_is_match(k: lexer.TokenKind) bool! = { match k { Match() => { return true } else => { return false } } }
fn kind_is_defer(k: lexer.TokenKind) bool! = { match k { Defer() => { return true } else => { return false } } }
fn kind_is_break(k: lexer.TokenKind) bool! = { match k { Break() => { return true } else => { return false } } }
fn kind_is_continue(k: lexer.TokenKind) bool! = { match k { Continue() => { return true } else => { return false } } }
fn kind_is_assert(k: lexer.TokenKind) bool! = { match k { Assert() => { return true } else => { return false } } }
fn kind_is_when(k: lexer.TokenKind) bool! = { match k { When() => { return true } else => { return false } } }
fn kind_is_union(k: lexer.TokenKind) bool! = { match k { Union() => { return true } else => { return false } } }
fn kind_is_enum(k: lexer.TokenKind) bool! = { match k { Enum() => { return true } else => { return false } } }
fn kind_is_extern(k: lexer.TokenKind) bool! = { match k { Extern() => { return true } else => { return false } } }
fn kind_is_link(k: lexer.TokenKind) bool! = { match k { Link() => { return true } else => { return false } } }
fn kind_is_guarded(k: lexer.TokenKind) bool! = { match k { Guarded() => { return true } else => { return false } } }
fn kind_is_not(k: lexer.TokenKind) bool! = { match k { Not() => { return true } else => { return false } } }
fn kind_is_ref(k: lexer.TokenKind) bool! = { match k { Ref() => { return true } else => { return false } } }
fn kind_is_use(k: lexer.TokenKind) bool! = { match k { Use() => { return true } else => { return false } } }
fn kind_is_test(k: lexer.TokenKind) bool! = { match k { Test() => { return true } else => { return false } } }
fn kind_is_guard(k: lexer.TokenKind) bool! = { match k { Guard() => { return true } else => { return false } } }
fn kind_is_eof(k: lexer.TokenKind) bool! = { match k { Eof() => { return true } else => { return false } } }
fn kind_is_ident(k: lexer.TokenKind) bool! = { match k { Ident _ => { return true } else => { return false } } }
fn kind_is_str(k: lexer.TokenKind) bool! = { match k { Str _ => { return true } else => { return false } } }
fn kind_is_int(k: lexer.TokenKind) bool! = { match k { Int _ => { return true } else => { return false } } }
fn kind_is_float(k: lexer.TokenKind) bool! = { match k { Float _ => { return true } else => { return false } } }
fn kind_is_char(k: lexer.TokenKind) bool! = { match k { CharLit _ => { return true } else => { return false } } }
fn kind_char_val(k: lexer.TokenKind) i64! = { match k { CharLit v => { return v } else => { return 0 } } }
fn kind_is_dotdotdot(k: lexer.TokenKind) bool! = { match k { DotDotDot() => { return true } else => { return false } } }

pub fn parse_type(p: ref Parser) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)

    if lexer.kind_is_lbracket(p_peek_kind(p)) {
        p_advance(p)
        if lexer.kind_is_rbracket(p_peek_kind(p)) {
            p_advance(p)
            val inner = parse_type(p)?
            val n: mut ref Node = make_node(TY_SLICE, line)
            node_store_slot[ref Node](@addr(n.d0), inner)
            return ok n
        }
        val sz: mut i64 = 0
        val sz_name: mut ref u8 = none
        if kind_is_int(p_peek_kind(p)) {
            val sz_text: ref u8 = p_advance_text(p)
            val sz_res = fmt.string_to_i64(sz_text)
            match sz_res {
                ok v  => { sz = v }
                err _ => { return err p_error(p, "invalid array size") }
            }
        } elif kind_is_ident(p_peek_kind(p)) {
            val sb: ref void = string.StringBuilder.new()
            string.StringBuilder.append_cstr(sb, p_advance_text(p))
            for {
                if !lexer.kind_is_dot(p_peek_kind(p)) { break }
                p_advance(p)
                val seg = p_expect_ident(p)?
                string.StringBuilder.append_char(sb, 46)
                string.StringBuilder.append_cstr(sb, seg)
            }
            val built: ref void = string.StringBuilder.build(sb)
            string.StringBuilder.free(sb)
            sz_name = string.cstr(built)
        } else {
            return err p_error(p, "expected integer size in fixed array type")
        }
        p_expect_rbracket(p)?
        val inner2 = parse_type(p)?
        val n2: mut ref Node = make_node(TY_FIXED_ARR, line)
        n2.d0 = sz
        node_store_slot[ref Node](@addr(n2.d1), inner2)
        node_store_slot[ref u8](@addr(n2.d2), sz_name)
        return ok n2
    }

    if kind_is_ref(p_peek_kind(p)) {
        p_advance(p)
        val inner3 = parse_type(p)?
        val n3: mut ref Node = make_node(TY_REF, line)
        node_store_slot[ref Node](@addr(n3.d0), inner3)
        return ok n3
    }

    if kind_is_mut(p_peek_kind(p)) {
        p_advance(p)
        val inner4 = parse_type(p)?
        val n4: mut ref Node = make_node(TY_MUT, line)
        node_store_slot[ref Node](@addr(n4.d0), inner4)
        return ok n4
    }

    if kind_is_fn(p_peek_kind(p)) {
        p_advance(p)
        p_expect_lparen(p)?
        val params: mut list[ref Node] = []
        for {
            if lexer.kind_is_rparen(p_peek_kind(p)) { break }
            val pt = parse_type(p)?
            @append(params, pt)
            if !p_eat_fn(p, lexer.kind_is_comma) { break }
        }
        p_expect_rparen(p)?
        val ret = parse_type(p)?
        val nfp: mut ref Node = make_node(TY_FNPTR, line)
        val plist: list[ref Node] = params
        node_store_slot[list[ref Node]](@addr(nfp.d0), plist)
        node_store_slot[ref Node](@addr(nfp.d1), ret)
        return ok nfp
    }

    if kind_is_ident(p_peek_kind(p)) {
        val name: ref u8 = p_advance_text(p)
        if str_eq(name, "void")    { return ok make_node(TY_VOID,    line) }
        if str_eq(name, "untyped") { return ok make_node(TY_UNTYPED, line) }
        if str_eq(name, "option") {
            p_expect_lbracket(p)?
            val inner5 = parse_type(p)?
            p_expect_rbracket(p)?
            val no: mut ref Node = make_node(TY_OPTION, line)
            node_store_slot[ref Node](@addr(no.d0), inner5)
            return ok no
        }
        if str_eq(name, "result") {
            p_expect_lbracket(p)?
            val ok_ty = parse_type(p)?
            p_expect_comma(p)?
            val err_ty = parse_type(p)?
            p_expect_rbracket(p)?
            val nr: mut ref Node = make_node(TY_RESULT, line)
            node_store_slot[ref Node](@addr(nr.d0), ok_ty)
            node_store_slot[ref Node](@addr(nr.d1), err_ty)
            return ok nr
        }
        if str_eq(name, "list") {
            p_expect_lbracket(p)?
            val inner6 = parse_type(p)?
            p_expect_rbracket(p)?
            val nl: mut ref Node = make_node(TY_LIST, line)
            node_store_slot[ref Node](@addr(nl.d0), inner6)
            return ok nl
        }
        val sb: ref void = string.StringBuilder.new()
        string.StringBuilder.append_cstr(sb, name)
        for {
            if !lexer.kind_is_dot(p_peek_kind(p)) { break }
            p_advance(p)
            val seg = p_expect_ident(p)?
            string.StringBuilder.append_char(sb, 46)
            string.StringBuilder.append_cstr(sb, seg)
        }
        val full_str: ref void = string.StringBuilder.build(sb)
        string.StringBuilder.free(sb)
        val full: ref u8 = string.cstr(full_str)
        val nn: mut ref Node = make_node(TY_NAMED, line)
        node_store_slot[ref u8](@addr(nn.d0), full)
        return ok nn
    }

    return err p_error(p, "expected type")
}

pub fn parse_expr(p: ref Parser) result[ref Node, ref u8]! = { return parse_or(p) }

fn parse_or(p: ref Parser) result[ref Node, ref u8]! = {
    val lhs = parse_and(p)?
    val res: mut ref Node = lhs
    for {
        if !lexer.kind_is_or(p_peek_kind(p)) { break }
        val line: i64 = p_line(p) p_advance(p)
        val rhs = parse_and(p)?
        res = make_binop(OP_OR, line, res, rhs)?
    }
    return ok res
}

fn parse_and(p: ref Parser) result[ref Node, ref u8]! = {
    val lhs = parse_cmp(p)?
    val res: mut ref Node = lhs
    for {
        if !lexer.kind_is_and(p_peek_kind(p)) { break }
        val line: i64 = p_line(p) p_advance(p)
        val rhs = parse_cmp(p)?
        res = make_binop(OP_AND, line, res, rhs)?
    }
    return ok res
}

fn parse_cmp(p: ref Parser) result[ref Node, ref u8]! = {
    val lhs = parse_bitor(p)?
    val res: mut ref Node = lhs
    for {
        val k: lexer.TokenKind = p_peek_kind(p)
        val op: mut i64 = 0
        if lexer.kind_is_eqeq(k)   { op = OP_EQ }
        elif lexer.kind_is_bangeq(k) { op = OP_NE }
        elif kind_is_lt(k)           { op = OP_LT }
        elif kind_is_gt(k)           { op = OP_GT }
        elif lexer.kind_is_lteq(k)   { op = OP_LE }
        elif lexer.kind_is_gteq(k)   { op = OP_GE }
        if op == 0 { break }
        val line: i64 = p_line(p) p_advance(p)
        val rhs = parse_bitor(p)?
        res = make_binop(op, line, res, rhs)?
    }
    return ok res
}

fn parse_bitor(p: ref Parser) result[ref Node, ref u8]! = {
    val lhs = parse_bitxor(p)?
    val res: mut ref Node = lhs
    for {
        if !kind_is_bitor(p_peek_kind(p)) { break }
        val line: i64 = p_line(p) p_advance(p)
        val rhs = parse_bitxor(p)?
        res = make_binop(OP_BOR, line, res, rhs)?
    }
    return ok res
}

fn parse_bitxor(p: ref Parser) result[ref Node, ref u8]! = {
    val lhs = parse_bitand(p)?
    val res: mut ref Node = lhs
    for {
        if !kind_is_bitxor(p_peek_kind(p)) { break }
        val line: i64 = p_line(p) p_advance(p)
        val rhs = parse_bitand(p)?
        res = make_binop(OP_BXOR, line, res, rhs)?
    }
    return ok res
}

fn parse_bitand(p: ref Parser) result[ref Node, ref u8]! = {
    val lhs = parse_shift(p)?
    val res: mut ref Node = lhs
    for {
        if !kind_is_bitand(p_peek_kind(p)) { break }
        val line: i64 = p_line(p) p_advance(p)
        val rhs = parse_shift(p)?
        res = make_binop(OP_BAND, line, res, rhs)?
    }
    return ok res
}

fn parse_shift(p: ref Parser) result[ref Node, ref u8]! = {
    val lhs = parse_add(p)?
    val res: mut ref Node = lhs
    for {
        val k: lexer.TokenKind = p_peek_kind(p)
        val op: mut i64 = 0
        if lexer.kind_is_shl(k) { op = OP_SHL }
        elif lexer.kind_is_shr(k) { op = OP_SHR }
        if op == 0 { break }
        val line: i64 = p_line(p) p_advance(p)
        val rhs = parse_add(p)?
        res = make_binop(op, line, res, rhs)?
    }
    return ok res
}

fn parse_add(p: ref Parser) result[ref Node, ref u8]! = {
    val lhs = parse_mul(p)?
    val res: mut ref Node = lhs
    for {
        val k: lexer.TokenKind = p_peek_kind(p)
        val op: mut i64 = 0
        if kind_is_plus(k)  { op = OP_ADD }
        elif kind_is_minus(k) { op = OP_SUB }
        if op == 0 { break }
        val line: i64 = p_line(p) p_advance(p)
        val rhs = parse_mul(p)?
        res = make_binop(op, line, res, rhs)?
    }
    return ok res
}

fn parse_mul(p: ref Parser) result[ref Node, ref u8]! = {
    val lhs = parse_unary(p)?
    val res: mut ref Node = lhs
    for {
        val k: lexer.TokenKind = p_peek_kind(p)
        val op: mut i64 = 0
        if kind_is_star(k)    { op = OP_MUL }
        elif kind_is_slash(k)   { op = OP_DIV }
        elif kind_is_percent(k) { op = OP_REM }
        if op == 0 { break }
        val line: i64 = p_line(p) p_advance(p)
        val rhs = parse_unary(p)?
        res = make_binop(op, line, res, rhs)?
    }
    return ok res
}

fn parse_unary(p: ref Parser) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)
    val k: lexer.TokenKind = p_peek_kind(p)
    if kind_is_bang(k) || kind_is_not(k) {
        p_advance(p)
        val inner = parse_unary(p)?
        return make_unop(UOP_NOT, line, inner)
    }
    if kind_is_minus(k) {
        p_advance(p)
        val inner2 = parse_unary(p)?
        return make_unop(UOP_NEG, line, inner2)
    }
    if kind_is_tilde(k) {
        p_advance(p)
        val inner3 = parse_unary(p)?
        return make_unop(UOP_BNOT, line, inner3)
    }
    if kind_is_trust(k) {
        p_advance(p)
        val inner4 = parse_unary(p)?
        val n4: mut ref Node = make_node(NK_TRUST, line)
        node_store_slot[ref Node](@addr(n4.d0), inner4)
        return ok n4
    }
    if kind_is_some(k) {
        p_advance(p)
        val inner5 = parse_unary(p)?
        val n5: mut ref Node = make_node(NK_SOME, line)
        node_store_slot[ref Node](@addr(n5.d0), inner5)
        return ok n5
    }
    if kind_is_ok(k) {
        p_advance(p)
        if lexer.kind_is_lparen(p_peek_kind(p)) && lexer.kind_is_rparen(p_peek2_kind(p)) {
            p_advance(p) p_advance(p)
            val n6: mut ref Node = make_node(NK_OK_VAL, line)
            n6.d0 = 0
            return ok n6
        }
        val inner6 = parse_unary(p)?
        val n6: mut ref Node = make_node(NK_OK_VAL, line)
        node_store_slot[ref Node](@addr(n6.d0), inner6)
        return ok n6
    }
    if kind_is_err(k) {
        p_advance(p)
        val inner7 = parse_unary(p)?
        val n7: mut ref Node = make_node(NK_ERR_VAL, line)
        node_store_slot[ref Node](@addr(n7.d0), inner7)
        return ok n7
    }
    return parse_postfix(p)
}

fn parse_postfix(p: ref Parser) result[ref Node, ref u8]! = {
    val base = parse_primary(p)?
    val res: mut ref Node = base
    for {
        val k: lexer.TokenKind = p_peek_kind(p)
        val line: i64 = p_line(p)
        if lexer.kind_is_dot(k) {
            p_advance(p)
            val field = p_expect_ident(p)?
            res = make_field(res, line, field)?
            continue
        }
        if lexer.kind_is_lparen(k) {
            p_advance(p)
            val args: mut list[ref Node] = []
            for {
                if lexer.kind_is_rparen(p_peek_kind(p)) { break }
                val arg = parse_expr(p)?
                @append(args, arg)
                if !p_eat_fn(p, lexer.kind_is_comma) { break }
            }
            p_expect_rparen(p)?
            res = make_call(res, line, args)?
            continue
        }
        if lexer.kind_is_question(k) {
            p_advance(p)
            val n3: mut ref Node = make_node(NK_TRY, line)
            node_store_slot[ref Node](@addr(n3.d0), res)
            res = n3
            continue
        }
        if kind_is_as(k) {
            p_advance(p)
            val ty = parse_type(p)?
            val n4: mut ref Node = make_node(NK_CAST, line)
            node_store_slot[ref Node](@addr(n4.d0), res)
            node_store_slot[ref Node](@addr(n4.d1), ty)
            res = n4
            continue
        }
        if lexer.kind_is_lbracket(k) {
            p_advance(p)
            val targs: mut list[ref Node] = []
            if lexer.kind_is_question(p_peek_kind(p)) {
                p_advance(p)
                val infer_marker: ref Node = make_node(TY_INFER, line)
                @append(targs, infer_marker)
            } else {
                for {
                    if lexer.kind_is_rbracket(p_peek_kind(p)) { break }
                    val ta = parse_type(p)?
                    @append(targs, ta)
                    if !p_eat_fn(p, lexer.kind_is_comma) { break }
                }
            }
            p_expect_rbracket(p)?
            val ng: mut ref Node = make_node(NK_GENERIC_INST, line)
            node_store_slot[ref Node](@addr(ng.d0), res)
            val tl: list[ref Node] = targs
            node_store_slot[list[ref Node]](@addr(ng.d1), tl)
            res = ng
            continue
        }
        break
    }
    return ok res
}

fn parse_primary(p: ref Parser) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)
    val k: lexer.TokenKind = p_peek_kind(p)

    if kind_is_int(k) {
        return make_int_lit(p_advance_text(p), line)
    }
    if kind_is_float(k) {
        return make_float_lit(p_advance_text(p), line)
    }
    if kind_is_str(k) {
        return make_str_lit(p_advance_text(p), line)
    }

    if kind_is_true(k)  { p_advance(p) val n4: mut ref Node = make_node(NK_BOOL, line) n4.d0 = 1 return ok n4 }
    if kind_is_false(k) { p_advance(p) val n5: mut ref Node = make_node(NK_BOOL, line) n5.d0 = 0 return ok n5 }
    if kind_is_none(k)  { p_advance(p) return ok make_node(NK_NONE, line) }
    if kind_is_char(k) {
        val char_val: i64 = kind_char_val(k)
        p_advance(p)
        val nc: mut ref Node = make_node(NK_CHAR_LIT, line)
        nc.d0 = char_val
        return ok nc
    }

    if lexer.kind_is_lparen(k) {
        p_advance(p)
        val inner = parse_expr(p)?
        p_expect_rparen(p)?
        return ok inner
    }

    if lexer.kind_is_lbrace(k) {
        p_advance(p)
        if kind_is_ident(p_peek_kind(p)) && lexer.kind_is_colon(p_peek2_kind(p)) {
            val fields: mut list[ref Node] = []
            for {
                if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
                val fname = p_expect_ident(p)?
                p_expect_colon(p)?
                val fval = parse_expr(p)?
                val pair = make_struct_field(fname, line, fval)?
                @append(fields, pair)
                p_eat_fn(p, lexer.kind_is_comma)
            }
            p_expect_rbrace(p)?
            val ns: mut ref Node = make_node(NK_STRUCT_LIT, line)
            val flist: list[ref Node] = fields
            node_store_slot[list[ref Node]](@addr(ns.d0), flist)
            return ok ns
        }
        val elems: mut list[ref Node] = []
        for {
            if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
            val e = parse_expr(p)?
            @append(elems, e)
            if !p_eat_fn(p, lexer.kind_is_comma) { break }
        }
        p_expect_rbrace(p)?
        val na: mut ref Node = make_node(NK_ARGS_PACK, line)
        val elist: list[ref Node] = elems
        node_store_slot[list[ref Node]](@addr(na.d0), elist)
        return ok na
    }

    if lexer.kind_is_lbracket(k) {
        p_advance(p)
        val elems2: mut list[ref Node] = []
        for {
            if lexer.kind_is_rbracket(p_peek_kind(p)) { break }
            val e2 = parse_expr(p)?
            @append(elems2, e2)
            if !p_eat_fn(p, lexer.kind_is_comma) { break }
        }
        p_expect_rbracket(p)?
        val nl: mut ref Node = make_node(NK_LIST_LIT, line)
        val elist2: list[ref Node] = elems2
        node_store_slot[list[ref Node]](@addr(nl.d0), elist2)
        return ok nl
    }

    if lexer.kind_is_at(k) {
        p_advance(p)
        val bname = p_expect_ident(p)?
        if str_eq(bname, "zeroed") {
            if !lexer.kind_is_lparen(p_peek_kind(p)) {
                val nz0: mut ref Node = make_node(NK_ZERO_INIT, line)
                node_store_slot[ref u8](@addr(nz0.d0), bname)
                return ok nz0
            }
        }
        p_expect_lparen(p)?
        if str_eq(bname, "zeroed") {
            p_expect_rparen(p)?
            val nz1: mut ref Node = make_node(NK_ZERO_INIT, line)
            node_store_slot[ref u8](@addr(nz1.d0), bname)
            return ok nz1
        }
        if str_eq(bname, "addr") {
            val inner2 = parse_expr(p)?
            p_expect_rparen(p)?
            val na2: mut ref Node = make_node(NK_ADDR, line)
            node_store_slot[ref Node](@addr(na2.d0), inner2)
            return ok na2
        }
        if str_eq(bname, "deref") {
            val inner3 = parse_expr(p)?
            p_expect_rparen(p)?
            val nd: mut ref Node = make_node(NK_DEREF, line)
            node_store_slot[ref Node](@addr(nd.d0), inner3)
            return ok nd
        }
        if str_eq(bname, "sizeof") {
            val ty = parse_type(p)?
            p_expect_rparen(p)?
            val nb: mut ref Node = make_node(NK_BUILTIN, line)
            node_store_slot[ref u8](@addr(nb.d0), bname)
            val targs: mut list[ref Node] = []
            @append(targs, ty)
            node_store_slot[list[ref Node]](@addr(nb.d1), targs)
            return ok nb
        }
        if str_eq(bname, "bitcast") {
            val source_expr = parse_expr(p)?
            p_expect_comma(p)?
            val target_ty = parse_type(p)?
            p_expect_rparen(p)?
            val nb: mut ref Node = make_node(NK_BUILTIN, line)
            node_store_slot[ref u8](@addr(nb.d0), bname)
            val bargs: mut list[ref Node] = []
            @append(bargs, target_ty)
            @append(bargs, source_expr)
            node_store_slot[list[ref Node]](@addr(nb.d1), bargs)
            return ok nb
        }
        val bargs: mut list[ref Node] = []
        for {
            if lexer.kind_is_rparen(p_peek_kind(p)) { break }
            val ba = parse_expr(p)?
            @append(bargs, ba)
            if !p_eat_fn(p, lexer.kind_is_comma) { break }
        }
        p_expect_rparen(p)?
        val nb: mut ref Node = make_node(NK_BUILTIN, line)
        node_store_slot[ref u8](@addr(nb.d0), bname)
        val blist: list[ref Node] = bargs
        node_store_slot[list[ref Node]](@addr(nb.d1), blist)
        return ok nb
    }

    if kind_is_ident(k) {
        val name: ref u8 = p_advance_text(p)
        if lexer.kind_is_lbrace(p_peek_kind(p)) && lexer.kind_is_rbrace(p_peek2_kind(p)) {
            p_advance(p) p_advance(p)
            val nz: mut ref Node = make_node(NK_ZERO_INIT, line)
            node_store_slot[ref u8](@addr(nz.d0), name)
            return ok nz
        }
        val ni: mut ref Node = make_node(NK_IDENT, line)
        node_store_slot[ref u8](@addr(ni.d0), name)
        return ok ni
    }

    return err p_error(p, "expected expression")
}

fn parse_contracts(p: ref Parser) result[list[ref Node], ref u8]! = {
    val contracts: mut list[ref Node] = []
    for {
        if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
        val line: i64 = p_line(p)
        val label: mut ref u8 = none
        if kind_is_ident(p_peek_kind(p)) && lexer.kind_is_colon(p_peek2_kind(p)) {
            label = p_advance_text(p)
            p_advance(p)
        }
        val expr = parse_expr(p)?
        val c: mut ref Node = make_node(NK_PRE, line)
        node_store_slot[ref u8](@addr(c.d0), label)
        node_store_slot[ref Node](@addr(c.d1), expr)
        @append(contracts, c)
    }
    return ok contracts
}

pub fn parse_stmt(p: mut ref Parser) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)
    val k: lexer.TokenKind = p_peek_kind(p)

    if kind_is_val(k) {
        p_advance(p)
        val name = p_expect_ident(p)?
        val mutable: mut i64 = 0
        val ty: mut ref Node = none
        if p_eat_fn(p, lexer.kind_is_colon) {
            if p_eat_fn(p, kind_is_mut) { mutable = 1 }
            ty = parse_type(p)?
        }
        p_expect_eq(p)?
        val expr = parse_expr(p)?
        val n: mut ref Node = make_node(NK_VAL, line)
        node_store_slot[ref u8](@addr(n.d0), name)
        n.d1 = mutable
        node_store_slot[ref Node](@addr(n.d2), ty)
        node_store_slot[ref Node](@addr(n.d3), expr)
        return ok n
    }

    if kind_is_return(k) {
        p_advance(p)
        val n2: mut ref Node = make_node(NK_RETURN, line)
        if !lexer.kind_is_rbrace(p_peek_kind(p)) && !kind_is_eof(p_peek_kind(p)) {
            val ret_expr = parse_expr(p)?
            node_store_slot[ref Node](@addr(n2.d0), ret_expr)
        }
        return ok n2
    }

    if kind_is_pre(k) {
        p_advance(p)
        p_expect_lbrace(p)?
        val cs = parse_contracts(p)?
        p_expect_rbrace(p)?
        val n3: mut ref Node = make_node(NK_PRE, line)
        val clist: list[ref Node] = cs
        node_store_slot[list[ref Node]](@addr(n3.d0), clist)
        return ok n3
    }

    if kind_is_post(k) {
        p_advance(p)
        p_expect_lbrace(p)?
        val cs2 = parse_contracts(p)?
        p_expect_rbrace(p)?
        val n4: mut ref Node = make_node(NK_POST, line)
        val clist2: list[ref Node] = cs2
        node_store_slot[list[ref Node]](@addr(n4.d0), clist2)
        return ok n4
    }

    if kind_is_guarded(k) {
        p_advance(p)
        val sub: lexer.TokenKind = p_peek_kind(p)
        if !kind_is_pre(sub) && !kind_is_post(sub) {
            return err p_error(p, "expected 'pre' or 'post' after 'guarded'")
        }
        val is_post: bool = kind_is_post(sub)
        p_advance(p)
        p_expect_lbrace(p)?
        val cs3 = parse_contracts(p)?
        p_expect_rbrace(p)?
        val nk5: mut i64 = NK_GUARDED_PRE
        if is_post { nk5 = NK_GUARDED_POST }
        val n5: mut ref Node = make_node(nk5, line)
        val clist3: list[ref Node] = cs3
        node_store_slot[list[ref Node]](@addr(n5.d0), clist3)
        return ok n5
    }

    if kind_is_guard(k) {
        p_advance(p)
        val has_paren_g: bool = p_eat_fn(p, lexer.kind_is_lparen)
        val gcond = parse_expr(p)?
        if has_paren_g { p_expect_rparen(p)? }
        if !kind_is_else(p_peek_kind(p)) {
            return err p_error(p, "expected 'else' after guard condition")
        }
        p_advance(p)
        p_expect_lbrace(p)?
        val gbody = parse_stmts(p)?
        p_expect_rbrace(p)?
        val ng: mut ref Node = make_node(NK_GUARD, line)
        node_store_slot[ref Node](@addr(ng.d0), gcond)
        val gbl: list[ref Node] = gbody
        node_store_slot[list[ref Node]](@addr(ng.d1), gbl)
        return ok ng
    }

    if kind_is_if(k) {
        p_advance(p)
        val has_paren: bool = p_eat_fn(p, lexer.kind_is_lparen)
        val cond = parse_expr(p)?
        if has_paren { p_expect_rparen(p)? }

        val peek_next_some: mut bool = false
        if lexer.kind_is_ident(p_peek_kind(p)) {
            val ptxt: ref u8 = lexer.tok_text(p.tokens, p.pos)
            if ptxt != none {
                if str_eq(ptxt, "is") {
                    if kind_is_some(p_peek2_kind(p)) {
                        peek_next_some = true
                    }
                }
            }
        }
        if peek_next_some {
            p_advance(p)  // consume "is"
            p_advance(p)  // consume "some"
            val is_bind = p_expect_ident(p)?
            p_expect_lbrace(p)?
            val is_some_stmts = parse_stmts(p)?
            p_expect_rbrace(p)?

            val is_sbl: list[ref Node] = is_some_stmts
            val is_some_body: mut ref Node = make_node(NK_MATCH_OPT, line)
            node_store_slot[list[ref Node]](@addr(is_some_body.d0), is_sbl)

            val is_elif_list: mut list[ref Node] = []
            for {
                if !kind_is_elif(p_peek_kind(p)) { break }
                val iel: i64 = p_line(p) p_advance(p)
                val iehp: bool = p_eat_fn(p, lexer.kind_is_lparen)
                val iecond = parse_expr(p)?
                if iehp { p_expect_rparen(p)? }
                p_expect_lbrace(p)?
                val iebody = parse_stmts(p)?
                p_expect_rbrace(p)?
                val iep: mut ref Node = make_node(NK_IF, iel)
                node_store_slot[ref Node](@addr(iep.d0), iecond)
                val iebl: list[ref Node] = iebody
                node_store_slot[list[ref Node]](@addr(iep.d1), iebl)
                @append(is_elif_list, iep)
            }
            val is_else_node: mut ref Node = none
            if p_eat_fn(p, kind_is_else) {
                p_expect_lbrace(p)?
                val ieb = parse_stmts(p)?
                p_expect_rbrace(p)?
                val iebl2: list[ref Node] = ieb
                val ien: mut ref Node = make_node(NK_IF, line)
                node_store_slot[list[ref Node]](@addr(ien.d0), iebl2)
                is_else_node = ien
            }

            val is_none_body: mut ref Node = none
            val is_elif_count: i64 = @len(is_elif_list) as i64
            if is_elif_count > 0 {
                val ife0_opt = @get(is_elif_list, 0 as usize)
                match ife0_opt {
                    some ife0 => {
                        val ife0n: ref Node = ife0 as ref Node
                        val irest: mut list[ref Node] = []
                        val iri: mut i64 = 1
                        for {
                            if iri >= is_elif_count { break }
                            val ire_opt = @get(is_elif_list, iri as usize)
                            match ire_opt {
                                some ire => { @append(irest, ire as ref Node) }
                                none => {}
                            }
                            iri++
                        }
                        val isyn: mut ref Node = make_node(NK_IF, ife0n.line)
                        isyn.d0 = ife0n.d0
                        isyn.d1 = ife0n.d1
                        val irestl: list[ref Node] = irest
                        node_store_slot[list[ref Node]](@addr(isyn.d2), irestl)
                        node_store_slot[ref Node](@addr(isyn.d3), is_else_node)
                        val instmts: mut list[ref Node] = []
                        @append(instmts, isyn)
                        val instl: list[ref Node] = instmts
                        val inc: mut ref Node = make_node(NK_MATCH_OPT, line)
                        node_store_slot[list[ref Node]](@addr(inc.d0), instl)
                        is_none_body = inc
                    }
                    none => {}
                }
            } elif is_else_node != none {
                is_none_body = is_else_node
            }

            val nmo: mut ref Node = make_node(NK_MATCH_OPT, line)
            node_store_slot[ref Node](@addr(nmo.d0), cond)
            node_store_slot[ref u8](@addr(nmo.d1), is_bind)
            node_store_slot[ref Node](@addr(nmo.d2), is_some_body)
            node_store_slot[ref Node](@addr(nmo.d3), is_none_body)
            return ok nmo
        }

        p_expect_lbrace(p)?
        val then_body = parse_stmts(p)?
        p_expect_rbrace(p)?
        val elif_list: mut list[ref Node] = []
        for {
            if !kind_is_elif(p_peek_kind(p)) { break }
            val el: i64 = p_line(p) p_advance(p)
            val ehp: bool = p_eat_fn(p, lexer.kind_is_lparen)
            val econd = parse_expr(p)?
            if ehp { p_expect_rparen(p)? }
            p_expect_lbrace(p)?
            val ebody = parse_stmts(p)?
            p_expect_rbrace(p)?
            val ep: mut ref Node = make_node(NK_IF, el)
            node_store_slot[ref Node](@addr(ep.d0), econd)
            val tb: list[ref Node] = ebody
            node_store_slot[list[ref Node]](@addr(ep.d1), tb)
            @append(elif_list, ep)
        }
        val else_body: mut ref Node = none
        if p_eat_fn(p, kind_is_else) {
            p_expect_lbrace(p)?
            val eb = parse_stmts(p)?
            p_expect_rbrace(p)?
            val ebl: list[ref Node] = eb
            val ebnode: mut ref Node = make_node(NK_IF, line)
            node_store_slot[list[ref Node]](@addr(ebnode.d0), ebl)
            else_body = ebnode
        }
        val nif: mut ref Node = make_node(NK_IF, line)
        node_store_slot[ref Node](@addr(nif.d0), cond)
        val tbl: list[ref Node] = then_body
        node_store_slot[list[ref Node]](@addr(nif.d1), tbl)
        val ell: list[ref Node] = elif_list
        node_store_slot[list[ref Node]](@addr(nif.d2), ell)
        node_store_slot[ref Node](@addr(nif.d3), else_body)
        return ok nif
    }

    if kind_is_for(k) {
        p_advance(p)
        if lexer.kind_is_lbrace(p_peek_kind(p)) {
            p_advance(p)
            val body = parse_stmts(p)?
            p_expect_rbrace(p)?
            val nf: mut ref Node = make_node(NK_FOR, line)
            val bl: list[ref Node] = body
            node_store_slot[list[ref Node]](@addr(nf.d4), bl)
            return ok nf
        }
        val has_paren2: bool = p_eat_fn(p, lexer.kind_is_lparen)
        val for_start: i64 = p.pos
        if kind_is_ident(p_peek_kind(p)) {
            val first_name = p_expect_ident(p)?
            if p_eat_fn(p, kind_is_in) {
                val iter = parse_expr(p)?
                if has_paren2 { p_expect_rparen(p)? }
                p_expect_lbrace(p)?
                val fi_body = parse_stmts(p)?
                p_expect_rbrace(p)?
                val nfi: mut ref Node = make_node(NK_FORIN, line)
                node_store_slot[ref u8](@addr(nfi.d0), first_name)
                node_store_slot[ref Node](@addr(nfi.d1), iter)
                val fibl: list[ref Node] = fi_body
                node_store_slot[list[ref Node]](@addr(nfi.d2), fibl)
                return ok nfi
            }
            if p_eat_fn(p, kind_is_eq) {
                val init_expr = parse_expr(p)?
                p_expect_semicolon(p)?
                val cond2 = parse_expr(p)?
                p_expect_semicolon(p)?
                val post_target = parse_expr(p)?
                val post_kind: lexer.TokenKind = p_peek_kind(p)
                val post_node: mut ref Node = none
                if lexer.kind_is_plusplus(post_kind) {
                    p_advance(p)
                    val pn: mut ref Node = make_node(NK_INCREMENT, line)
                    node_store_slot[ref Node](@addr(pn.d0), post_target)
                    post_node = pn
                } elif lexer.kind_is_minusminus(post_kind) {
                    p_advance(p)
                    val pn2: mut ref Node = make_node(NK_DECREMENT, line)
                    node_store_slot[ref Node](@addr(pn2.d0), post_target)
                    post_node = pn2
                } elif kind_is_pluseq(post_kind) {
                    p_advance(p)
                    val pv = parse_expr(p)?
                    val pn3: mut ref Node = make_node(NK_ADD_ASSIGN, line)
                    node_store_slot[ref Node](@addr(pn3.d0), post_target)
                    node_store_slot[ref Node](@addr(pn3.d1), pv)
                    post_node = pn3
                } elif kind_is_minuseq(post_kind) {
                    p_advance(p)
                    val pv2 = parse_expr(p)?
                    val pn4: mut ref Node = make_node(NK_SUB_ASSIGN, line)
                    node_store_slot[ref Node](@addr(pn4.d0), post_target)
                    node_store_slot[ref Node](@addr(pn4.d1), pv2)
                    post_node = pn4
                } else {
                    return err p_error(p, "expected '++', '--', '+=', or '-=' in for loop")
                }
                if has_paren2 { p_expect_rparen(p)? }
                p_expect_lbrace(p)?
                val for_body = parse_stmts(p)?
                p_expect_rbrace(p)?
                val nfor: mut ref Node = make_node(NK_FOR, line)
                node_store_slot[ref u8](@addr(nfor.d0), first_name)
                node_store_slot[ref Node](@addr(nfor.d1), init_expr)
                node_store_slot[ref Node](@addr(nfor.d2), cond2)
                node_store_slot[ref Node](@addr(nfor.d3), post_node)
                val fbl: list[ref Node] = for_body
                node_store_slot[list[ref Node]](@addr(nfor.d4), fbl)
                return ok nfor
            }
            p.pos = for_start
        }

        val cond_only = parse_expr(p)?
        if has_paren2 { p_expect_rparen(p)? }
        p_expect_lbrace(p)?
        val for_body = parse_stmts(p)?
        p_expect_rbrace(p)?
        val nfor2: mut ref Node = make_node(NK_FOR, line)
        node_store_slot[ref Node](@addr(nfor2.d2), cond_only)
        val fbl2: list[ref Node] = for_body
        node_store_slot[list[ref Node]](@addr(nfor2.d4), fbl2)
        return ok nfor2
    }

    if kind_is_defer(k) {
        p_advance(p)
        p_expect_lbrace(p)?
        val db = parse_stmts(p)?
        p_expect_rbrace(p)?
        val nd: mut ref Node = make_node(NK_DEFER, line)
        val dbl: list[ref Node] = db
        node_store_slot[list[ref Node]](@addr(nd.d0), dbl)
        return ok nd
    }

    if kind_is_break(k)    { p_advance(p) return ok make_node(NK_BREAK, line) }
    if kind_is_continue(k) { p_advance(p) return ok make_node(NK_CONTINUE, line) }

    if kind_is_assert(k) {
        p_advance(p)
        val ae = parse_expr(p)?
        val na: mut ref Node = make_node(NK_ASSERT, line)
        node_store_slot[ref Node](@addr(na.d0), ae)
        return ok na
    }

    if kind_is_when(k) {
        p_advance(p)
        val ident_text = p_expect_ident(p)?
        val next_k: lexer.TokenKind = p_peek_kind(p)

        if lexer.kind_is_bang(next_k) {
            p_advance(p)
            val next_k2: lexer.TokenKind = p_peek_kind(p)
            if kind_is_in(next_k2) {
                p_advance(p)
                p_expect_lparen(p)?
                val gtypes: mut list[ref Node] = []
                for {
                    if lexer.kind_is_rparen(p_peek_kind(p)) { break }
                    val gty = parse_type(p)?
                    @append(gtypes, gty)
                    if !p_eat_fn(p, lexer.kind_is_comma) { break }
                }
                p_expect_rparen(p)?
                p_expect_lbrace(p)?
                val gwb = parse_stmts(p)?
                p_expect_rbrace(p)?
                val gcond: mut ref Node = make_node(NK_GWHEN_COND, line)
                node_store_slot[ref u8](@addr(gcond.d0), ident_text)
                gcond.d1 = 3
                val gtl: list[ref Node] = gtypes
                node_store_slot[list[ref Node]](@addr(gcond.d2), gtl)
                val gconds: mut list[ref Node] = []
                @append(gconds, gcond)
                val gnw: mut ref Node = make_node(NK_GENERIC_WHEN, line)
                val gcl: list[ref Node] = gconds
                node_store_slot[list[ref Node]](@addr(gnw.d0), gcl)
                val gbl: list[ref Node] = gwb
                node_store_slot[list[ref Node]](@addr(gnw.d1), gbl)
                return ok gnw
            }
        }

        if kind_is_in(next_k) {
            p_advance(p)
            p_expect_lparen(p)?
            val gtypes: mut list[ref Node] = []
            for {
                if lexer.kind_is_rparen(p_peek_kind(p)) { break }
                val gty = parse_type(p)?
                @append(gtypes, gty)
                if !p_eat_fn(p, lexer.kind_is_comma) { break }
            }
            p_expect_rparen(p)?
            p_expect_lbrace(p)?
            val gwb = parse_stmts(p)?
            p_expect_rbrace(p)?
            val gcond: mut ref Node = make_node(NK_GWHEN_COND, line)
            node_store_slot[ref u8](@addr(gcond.d0), ident_text)
            gcond.d1 = 1
            val gtl: list[ref Node] = gtypes
            node_store_slot[list[ref Node]](@addr(gcond.d2), gtl)
            val gconds: mut list[ref Node] = []
            @append(gconds, gcond)
            val gnw: mut ref Node = make_node(NK_GENERIC_WHEN, line)
            val gcl: list[ref Node] = gconds
            node_store_slot[list[ref Node]](@addr(gnw.d0), gcl)
            val gbl: list[ref Node] = gwb
            node_store_slot[list[ref Node]](@addr(gnw.d1), gbl)
            return ok gnw
        }

        if kind_is_ident(next_k) {
            val next_txt: ref u8 = lexer.tok_text(p.tokens, p.pos)
            if str_eq(next_txt, "is") {
                val gconds2: mut list[ref Node] = []
                val cur_tparam: mut ref u8 = ident_text
                for {
                    p_advance(p)
                    val gty2 = parse_type(p)?
                    val gcond2: mut ref Node = make_node(NK_GWHEN_COND, line)
                    node_store_slot[ref u8](@addr(gcond2.d0), cur_tparam)
                    gcond2.d1 = 2
                    val stl: mut list[ref Node] = []
                    @append(stl, gty2)
                    val stl_ref: list[ref Node] = stl
                    node_store_slot[list[ref Node]](@addr(gcond2.d2), stl_ref)
                    @append(gconds2, gcond2)
                    if !lexer.kind_is_and(p_peek_kind(p)) { break }
                    p_advance(p)
                    if !kind_is_ident(p_peek_kind(p)) { break }
                    cur_tparam = p_advance_text(p)
                    if !kind_is_ident(p_peek_kind(p)) { break }
                    val nis_txt: ref u8 = lexer.tok_text(p.tokens, p.pos)
                    if !str_eq(nis_txt, "is") { break }
                }
                p_expect_lbrace(p)?
                val gwb2 = parse_stmts(p)?
                p_expect_rbrace(p)?
                val gnw2: mut ref Node = make_node(NK_GENERIC_WHEN, line)
                val gcl2: list[ref Node] = gconds2
                node_store_slot[list[ref Node]](@addr(gnw2.d0), gcl2)
                val gbl2: list[ref Node] = gwb2
                node_store_slot[list[ref Node]](@addr(gnw2.d1), gbl2)
                return ok gnw2
            }
        }

        if str_eq(ident_text, "_") {
            p_expect_lbrace(p)?
            val gwb3 = parse_stmts(p)?
            p_expect_rbrace(p)?
            val gwc: mut ref Node = make_node(NK_GWHEN_COND, line)
            gwc.d0 = 0
            gwc.d1 = 0
            gwc.d2 = 0
            val gwcs: mut list[ref Node] = []
            @append(gwcs, gwc)
            val gnw3: mut ref Node = make_node(NK_GENERIC_WHEN, line)
            val gwcl: list[ref Node] = gwcs
            node_store_slot[list[ref Node]](@addr(gnw3.d0), gwcl)
            val gwbl3: list[ref Node] = gwb3
            node_store_slot[list[ref Node]](@addr(gnw3.d1), gwbl3)
            return ok gnw3
        }

        val plat: ref u8 = ident_text
        p_expect_lbrace(p)?
        val wb = parse_stmts(p)?
        p_expect_rbrace(p)?
        val or_when_branches: mut list[ref Node] = []
        for {
            val k2: lexer.TokenKind = p_peek_kind(p)
            if !kind_is_ident(k2) { break }
            val txt: ref u8 = lexer.tok_text(p.tokens, p.pos)
            if !str_eq(txt, "or") { break }
            val k3: lexer.TokenKind = p_peek2_kind(p)
            if !kind_is_when(k3) { break }
            p_advance(p)
            p_advance(p)
            val ow_plat = p_expect_ident(p)?
            p_expect_lbrace(p)?
            val ow_body = parse_stmts(p)?
            p_expect_rbrace(p)?
            val ow_node: mut ref Node = make_node(NK_WHEN_STMT, line)
            node_store_slot[ref u8](@addr(ow_node.d0), ow_plat)
            val ow_bl: list[ref Node] = ow_body
            node_store_slot[list[ref Node]](@addr(ow_node.d1), ow_bl)
            @append(or_when_branches, ow_node)
        }
        val otherwise_stmts: mut list[ref Node] = []
        val k4: lexer.TokenKind = p_peek_kind(p)
        if kind_is_ident(k4) {
            val txt2: ref u8 = lexer.tok_text(p.tokens, p.pos)
            if str_eq(txt2, "otherwise") {
                p_advance(p)
                p_expect_lbrace(p)?
                val ow2 = parse_stmts(p)?
                p_expect_rbrace(p)?
                otherwise_stmts = ow2
            }
        }
        val nw: mut ref Node = make_node(NK_WHEN_STMT, line)
        node_store_slot[ref u8](@addr(nw.d0), plat)
        val wbl: list[ref Node] = wb
        node_store_slot[list[ref Node]](@addr(nw.d1), wbl)
        val owbl: list[ref Node] = or_when_branches
        node_store_slot[list[ref Node]](@addr(nw.d2), owbl)
        val owsl: list[ref Node] = otherwise_stmts
        node_store_slot[list[ref Node]](@addr(nw.d3), owsl)
        return ok nw
    }

    if kind_is_match(k) { return parse_match_stmt(p, line) }

    if kind_is_trust(k) && lexer.kind_is_lbrace(p_peek2_kind(p)) {
        p_advance(p)
        p_expect_lbrace(p)?
        val tb = parse_stmts(p)?
        p_expect_rbrace(p)?
        val ntb: mut ref Node = make_node(NK_TRUST_BLOCK, line)
        val tbl: list[ref Node] = tb
        node_store_slot[list[ref Node]](@addr(ntb.d0), tbl)
        return ok ntb
    }

    val expr3 = parse_expr(p)?
    if p_eat_fn(p, kind_is_eq) {
        val rhs = parse_expr(p)?
        val na2: mut ref Node = make_node(NK_ASSIGN, line)
        node_store_slot[ref Node](@addr(na2.d0), expr3)
        node_store_slot[ref Node](@addr(na2.d1), rhs)
        return ok na2
    }
    if p_eat_fn(p, lexer.kind_is_plusplus) {
        val ni: mut ref Node = make_node(NK_INCREMENT, line)
        node_store_slot[ref Node](@addr(ni.d0), expr3)
        return ok ni
    }
    if p_eat_fn(p, lexer.kind_is_minusminus) {
        val nd2: mut ref Node = make_node(NK_DECREMENT, line)
        node_store_slot[ref Node](@addr(nd2.d0), expr3)
        return ok nd2
    }
    if p_eat_fn(p, kind_is_pluseq) {
        val rv = parse_expr(p)?
        val naa: mut ref Node = make_node(NK_ADD_ASSIGN, line)
        node_store_slot[ref Node](@addr(naa.d0), expr3)
        node_store_slot[ref Node](@addr(naa.d1), rv)
        return ok naa
    }
    if p_eat_fn(p, kind_is_minuseq) {
        val rv2 = parse_expr(p)?
        val nsa: mut ref Node = make_node(NK_SUB_ASSIGN, line)
        node_store_slot[ref Node](@addr(nsa.d0), expr3)
        node_store_slot[ref Node](@addr(nsa.d1), rv2)
        return ok nsa
    }
    val nes: mut ref Node = make_node(NK_EXPR_STMT, line)
    node_store_slot[ref Node](@addr(nes.d0), expr3)
    return ok nes
}

fn parse_match_stmt(p: ref Parser, line: i64) result[ref Node, ref u8]! = {
    p_advance(p)
    val expr = parse_expr(p)?
    p_expect_lbrace(p)?

    if kind_is_ok(p_peek_kind(p)) || kind_is_err(p_peek_kind(p)) {
        val ok_bind: mut ref u8 = none
        val ok_body: mut ref Node = none
        val err_bind: mut ref u8 = none
        val err_body: mut ref Node = none
        for i = 0; i < 2; i++ {
            val ck: lexer.TokenKind = p_peek_kind(p)
            if kind_is_ok(ck) {
                p_advance(p)
                ok_bind = p_expect_ident(p)?
                p_expect_fatarrow(p)?
                p_expect_lbrace(p)?
                val ob = parse_stmts(p)?
                p_expect_rbrace(p)?
                val obl: list[ref Node] = ob
                val obn: mut ref Node = make_node(NK_MATCH_RES, line)
                node_store_slot[list[ref Node]](@addr(obn.d0), obl)
                ok_body = obn
            } elif kind_is_err(ck) {
                p_advance(p)
                err_bind = p_expect_ident(p)?
                p_expect_fatarrow(p)?
                p_expect_lbrace(p)?
                val eb = parse_stmts(p)?
                p_expect_rbrace(p)?
                val ebl: list[ref Node] = eb
                val ebn: mut ref Node = make_node(NK_MATCH_RES, line)
                node_store_slot[list[ref Node]](@addr(ebn.d0), ebl)
                err_body = ebn
            }
        }
        p_expect_rbrace(p)?
        val nm: mut ref Node = make_node(NK_MATCH_RES, line)
        node_store_slot[ref Node](@addr(nm.d0), expr)
        node_store_slot[ref u8](@addr(nm.d1), ok_bind)
        node_store_slot[ref Node](@addr(nm.d2), ok_body)
        node_store_slot[ref u8](@addr(nm.d3), err_bind)
        node_store_slot[ref Node](@addr(nm.d4), err_body)
        return ok nm
    }

    if kind_is_some(p_peek_kind(p)) || kind_is_none(p_peek_kind(p)) {
        val some_bind: mut ref u8 = none
        val some_body: mut ref Node = none
        val none_body: mut ref Node = none
        for i = 0; i < 2; i++ {
            val ck2: lexer.TokenKind = p_peek_kind(p)
            if kind_is_some(ck2) {
                p_advance(p)
                some_bind = p_expect_ident(p)?
                p_expect_fatarrow(p)?
                p_expect_lbrace(p)?
                val sb = parse_stmts(p)?
                p_expect_rbrace(p)?
                val sbl: list[ref Node] = sb
                val sbn: mut ref Node = make_node(NK_MATCH_OPT, line)
                node_store_slot[list[ref Node]](@addr(sbn.d0), sbl)
                some_body = sbn
            } elif kind_is_none(ck2) {
                p_advance(p)
                p_expect_fatarrow(p)?
                p_expect_lbrace(p)?
                val nb = parse_stmts(p)?
                p_expect_rbrace(p)?
                val nbl: list[ref Node] = nb
                val nbn: mut ref Node = make_node(NK_MATCH_OPT, line)
                node_store_slot[list[ref Node]](@addr(nbn.d0), nbl)
                none_body = nbn
            }
        }
        p_expect_rbrace(p)?
        val nmo: mut ref Node = make_node(NK_MATCH_OPT, line)
        node_store_slot[ref Node](@addr(nmo.d0), expr)
        node_store_slot[ref u8](@addr(nmo.d1), some_bind)
        node_store_slot[ref Node](@addr(nmo.d2), some_body)
        node_store_slot[ref Node](@addr(nmo.d3), none_body)
        return ok nmo
    }

    if kind_is_ident(p_peek_kind(p)) && lexer.kind_is_dot(p_peek2_kind(p)) {
        val arms: mut list[ref Node] = []
        for {
            if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
            val el: i64 = p_line(p)
            val enum_type_name = p_expect_ident(p)?
            p_expect_dot(p)?
            val variant = p_expect_ident(p)?
            p_expect_fatarrow(p)?
            p_expect_lbrace(p)?
            val ab = parse_stmts(p)?
            p_expect_rbrace(p)?
            val arm: mut ref Node = make_node(NK_MATCH_ENUM, el)
            node_store_slot[ref u8](@addr(arm.d0), variant)
            node_store_slot[ref u8](@addr(arm.d2), enum_type_name)
            val abl: list[ref Node] = ab
            node_store_slot[list[ref Node]](@addr(arm.d1), abl)
            @append(arms, arm)
        }
        p_expect_rbrace(p)?
        val nme: mut ref Node = make_node(NK_MATCH_ENUM, line)
        node_store_slot[ref Node](@addr(nme.d0), expr)
        val al: list[ref Node] = arms
        node_store_slot[list[ref Node]](@addr(nme.d1), al)
        return ok nme
    }

    if kind_is_str(p_peek_kind(p)) {
        val sarms: mut list[ref Node] = []
        val else_body: mut ref Node = none
        for {
            if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
            if kind_is_else(p_peek_kind(p)) {
                p_advance(p)
                p_expect_fatarrow(p)?
                p_expect_lbrace(p)?
                val eb2 = parse_stmts(p)?
                p_expect_rbrace(p)?
                val ebl2: list[ref Node] = eb2
                val ebn2: mut ref Node = make_node(NK_MATCH_STR, line)
                node_store_slot[list[ref Node]](@addr(ebn2.d0), ebl2)
                else_body = ebn2
                break
            }
            val sv: ref u8 = p_advance_text(p)
            p_expect_fatarrow(p)?
            p_expect_lbrace(p)?
            val sab = parse_stmts(p)?
            p_expect_rbrace(p)?
            val sarm: mut ref Node = make_node(NK_MATCH_STR, p_line(p))
            node_store_slot[ref u8](@addr(sarm.d0), sv)
            val sabl: list[ref Node] = sab
            node_store_slot[list[ref Node]](@addr(sarm.d1), sabl)
            @append(sarms, sarm)
        }
        p_expect_rbrace(p)?
        val nms: mut ref Node = make_node(NK_MATCH_STR, line)
        node_store_slot[ref Node](@addr(nms.d0), expr)
        val sal: list[ref Node] = sarms
        node_store_slot[list[ref Node]](@addr(nms.d1), sal)
        node_store_slot[ref Node](@addr(nms.d2), else_body)
        return ok nms
    }

    if kind_is_int(p_peek_kind(p)) || kind_is_float(p_peek_kind(p)) ||
       kind_is_true(p_peek_kind(p)) || kind_is_false(p_peek_kind(p)) ||
       (kind_is_minus(p_peek_kind(p)) && (kind_is_int(p_peek2_kind(p)) || kind_is_float(p_peek2_kind(p)))) {
        val varms: mut list[ref Node] = []
        val else_body: mut ref Node = none
        for {
            if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
            if kind_is_else(p_peek_kind(p)) {
                p_advance(p)
                p_expect_fatarrow(p)?
                p_expect_lbrace(p)?
                val eb3 = parse_stmts(p)?
                p_expect_rbrace(p)?
                val ebl3: list[ref Node] = eb3
                val ebn3: mut ref Node = make_node(NK_MATCH_VALUE, line)
                node_store_slot[list[ref Node]](@addr(ebn3.d0), ebl3)
                else_body = ebn3
                break
            }
            val pat = parse_expr(p)?
            p_expect_fatarrow(p)?
            p_expect_lbrace(p)?
            val vab = parse_stmts(p)?
            p_expect_rbrace(p)?
            val varm: mut ref Node = make_node(NK_MATCH_VALUE, pat.line)
            node_store_slot[ref Node](@addr(varm.d0), pat)
            val vabl: list[ref Node] = vab
            node_store_slot[list[ref Node]](@addr(varm.d1), vabl)
            @append(varms, varm)
        }
        p_expect_rbrace(p)?
        val nmv: mut ref Node = make_node(NK_MATCH_VALUE, line)
        node_store_slot[ref Node](@addr(nmv.d0), expr)
        val value: list[ref Node] = varms
        node_store_slot[list[ref Node]](@addr(nmv.d1), value)
        node_store_slot[ref Node](@addr(nmv.d2), else_body)
        return ok nmv
    }

    val uarms: mut list[ref Node] = []
    val u_else: mut ref Node = none
    val is_tagged_union_match: bool = kind_is_ident(p_peek_kind(p)) &&
        (kind_is_ident(p_peek2_kind(p)) || lexer.kind_is_lparen(p_peek2_kind(p)))

    if is_tagged_union_match {
        for {
            if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
            if kind_is_else(p_peek_kind(p)) {
                p_advance(p)
                p_expect_fatarrow(p)?
                p_expect_lbrace(p)?
                val ueb2 = parse_stmts(p)?
                p_expect_rbrace(p)?
                val uebl2: list[ref Node] = ueb2
                val uebn2: mut ref Node = make_node(NK_MATCH_TAGGED_UNION, line)
                node_store_slot[list[ref Node]](@addr(uebn2.d0), uebl2)
                u_else = uebn2
                break
            }
            val tline: i64 = p_line(p)
            val vname = p_expect_ident(p)?
            val bindings: mut list[ref u8] = []

            if lexer.kind_is_lparen(p_peek_kind(p)) {
                p_advance(p)
                p_expect_rparen(p)?
            } else {
                for {
                    if lexer.kind_is_fatarrow(p_peek_kind(p)) { break }
                    if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
                    val b = p_expect_ident(p)?
                    @append(bindings, b)
                    if !p_eat_fn(p, lexer.kind_is_comma) { break }
                }
            }
            p_expect_fatarrow(p)?
            p_expect_lbrace(p)?
            val tab = parse_stmts(p)?
            p_expect_rbrace(p)?
            val tarm: mut ref Node = make_node(NK_MATCH_TAGGED_UNION, tline)
            node_store_slot[ref u8](@addr(tarm.d0), vname)
            val bl: list[ref u8] = bindings
            node_store_slot[list[ref Node]](@addr(tarm.d1), bl)
            val tabl: list[ref Node] = tab
            node_store_slot[list[ref Node]](@addr(tarm.d2), tabl)
            @append(uarms, tarm)
        }
        p_expect_rbrace(p)?
        val ntmu: mut ref Node = make_node(NK_MATCH_TAGGED_UNION, line)
        node_store_slot[ref Node](@addr(ntmu.d0), expr)
        val tual: list[ref Node] = uarms
        node_store_slot[list[ref Node]](@addr(ntmu.d1), tual)
        node_store_slot[ref Node](@addr(ntmu.d2), u_else)
        return ok ntmu
    }

    for {
        if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
        if kind_is_else(p_peek_kind(p)) {
            p_advance(p)
            p_expect_fatarrow(p)?
            p_expect_lbrace(p)?
            val ueb = parse_stmts(p)?
            p_expect_rbrace(p)?
            val uebl: list[ref Node] = ueb
            val uebn: mut ref Node = make_node(NK_MATCH_UNION, line)
            node_store_slot[list[ref Node]](@addr(uebn.d0), uebl)
            u_else = uebn
            break
        }
        val uty = parse_type(p)?
        p_expect_fatarrow(p)?
        p_expect_lbrace(p)?
        val uab = parse_stmts(p)?
        p_expect_rbrace(p)?
        val uarm: mut ref Node = make_node(NK_MATCH_UNION, p_line(p))
        node_store_slot[ref Node](@addr(uarm.d0), uty)
        val uabl: list[ref Node] = uab
        node_store_slot[list[ref Node]](@addr(uarm.d1), uabl)
        @append(uarms, uarm)
    }

    p_expect_rbrace(p)?
    val nmu: mut ref Node = make_node(NK_MATCH_UNION, line)
    node_store_slot[ref Node](@addr(nmu.d0), expr)
    val ual: list[ref Node] = uarms
    node_store_slot[list[ref Node]](@addr(nmu.d1), ual)
    node_store_slot[ref Node](@addr(nmu.d2), u_else)
    return ok nmu
}

pub fn parse_stmts(p: ref Parser) result[list[ref Node], ref u8]! = {
    val stmts: mut list[ref Node] = []
    for {
        if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
        if kind_is_eof(p_peek_kind(p))          { break }
        val s = parse_stmt(p)?
        @append(stmts, s)
    }
    return ok stmts
}

fn parse_fn_item(p: ref Parser, public: i64) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)
    p_expect_kind(p, kind_is_fn, "fn")?
    val ns: mut ref u8 = none
    if lexer.kind_is_lparen(p_peek_kind(p)) {
        if kind_is_ident(p_peek2_kind(p)) && lexer.kind_is_rparen(p_peek3_kind(p)) {
            p_advance(p)
            ns = p_expect_ident(p)?
            p_expect_rparen(p)?
        }
    }
    val name = p_expect_ident(p)?
    val type_params: mut list[ref Node] = []
    if lexer.kind_is_lbracket(p_peek_kind(p)) {
        p_advance(p)
        for {
            if lexer.kind_is_rbracket(p_peek_kind(p)) { break }
            val tp_name = p_expect_ident(p)?
            val tp_constraint: mut ref Node = none
            if p_eat_fn(p, lexer.kind_is_colon) {
                tp_constraint = parse_type(p)?
            }
            val tp_node: mut ref Node = make_node(NK_VAL, line)
            node_store_slot[ref u8](@addr(tp_node.d0), tp_name)
            node_store_slot[ref Node](@addr(tp_node.d1), tp_constraint)
            @append(type_params, tp_node)
            if !p_eat_fn(p, lexer.kind_is_comma) { break }
        }
        p_expect_rbracket(p)?
    }
    p_expect_lparen(p)?
    val params: mut list[ref Node] = []
    for {
        if lexer.kind_is_rparen(p_peek_kind(p)) { break }
        val pname = p_expect_ident(p)?
        p_expect_colon(p)?
        val is_mut: bool = p_eat_fn(p, kind_is_mut)
        val pty = parse_type(p)?
        val actual_ty: mut ref Node = pty
        if ns != none && pty.kind == TY_NAMED {
            if str_eq(pty.d0 as ref u8, "self") {
                val rn: mut ref Node = make_node(TY_NAMED, line)
                node_store_slot[ref u8](@addr(rn.d0), ns)
                actual_ty = rn
            }
        }
        if is_mut {
            val mt: mut ref Node = make_node(TY_MUT, line)
            node_store_slot[ref Node](@addr(mt.d0), actual_ty)
            actual_ty = mt
        }
        val param: mut ref Node = make_node(NK_VAL, line)
        node_store_slot[ref u8](@addr(param.d0), pname)
        node_store_slot[ref Node](@addr(param.d1), actual_ty)
        @append(params, param)
        if !p_eat_fn(p, lexer.kind_is_comma) { break }
    }
    p_expect_rparen(p)?
    val ret_ty = parse_type(p)?
    val is_unsafe: mut i64 = 0
    if p_eat_fn(p, kind_is_bang) { is_unsafe = 1 }
    val body: mut list[ref Node] = []
    if p_eat_fn(p, kind_is_eq) {
        if p_eat_fn(p, kind_is_trust) { is_unsafe = 1 }
        p_expect_lbrace(p)?
        body = parse_stmts(p)?
        p_expect_rbrace(p)?
    }
    if @len(type_params) as i64 > 0 {
        val nfn: mut ref Node = make_node(NK_GENERIC_FN, line)
        nfn.d0 = public | (is_unsafe << 1)
        node_store_slot[ref u8](@addr(nfn.d1), ns)
        node_store_slot[ref u8](@addr(nfn.d2), name)
        val pl: list[ref Node] = params
        node_store_slot[list[ref Node]](@addr(nfn.d3), pl)
        node_store_slot[ref Node](@addr(nfn.d4), ret_ty)
        val bl: list[ref Node] = body
        node_store_slot[list[ref Node]](@addr(nfn.d5), bl)
        val tpl: list[ref Node] = type_params
        node_store_slot[list[ref Node]](@addr(nfn.d6), tpl)
        return ok nfn
    }
    val nfn: mut ref Node = make_node(NK_FN, line)
    nfn.d0 = public
    node_store_slot[ref u8](@addr(nfn.d1), ns)
    node_store_slot[ref u8](@addr(nfn.d2), name)
    val pl: list[ref Node] = params
    node_store_slot[list[ref Node]](@addr(nfn.d3), pl)
    node_store_slot[ref Node](@addr(nfn.d4), ret_ty)
    val bl: list[ref Node] = body
    node_store_slot[list[ref Node]](@addr(nfn.d5), bl)
    nfn.d6 = is_unsafe * FN_FLAG_UNSAFE
    return ok nfn
}

fn parse_type_def_item(p: ref Parser, public: i64, is_extern: i64) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)
    p_expect_kind(p, kind_is_type, "type")?
    val spec_name: mut ref u8 = none
    if lexer.kind_is_lparen(p_peek_kind(p)) {
        p_advance(p)
        spec_name = p_expect_ident(p)?
        p_expect_rparen(p)?
    }
    val name = p_expect_ident(p)?
    p_expect_eq(p)?
    p_expect_lbrace(p)?
    val fields: mut list[ref Node] = []
    val inv_exprs: mut list[ref Node] = []
    val has_invariant: mut bool = false
    for {
        if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
        if lexer.kind_is_invariant(p_peek_kind(p)) {
            if has_invariant {
                return err p_error(p, "duplicate invariant block in type definition")
            }
            has_invariant = true
            p_advance(p)
            p_expect_lbrace(p)?
            for {
                if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
                val iexpr = parse_expr(p)?
                @append(inv_exprs, iexpr)
            }
            p_expect_rbrace(p)?
            continue
        }
        val fname = p_expect_ident(p)?
        p_expect_colon(p)?
        val fmut: mut i64 = 0
        if p_eat_fn(p, kind_is_mut) { fmut = 1 }
        val fty = parse_type(p)?
        val fnode: mut ref Node = make_node(NK_VAL, line)
        node_store_slot[ref u8](@addr(fnode.d0), fname)
        fnode.d1 = fmut
        node_store_slot[ref Node](@addr(fnode.d2), fty)
        @append(fields, fnode)
        p_eat_fn(p, lexer.kind_is_comma)
    }
    p_expect_rbrace(p)?
    val nk: mut i64 = NK_TYPEDEF
    if is_extern == 1 { nk = NK_EXTERN_TYPE }
    val nt: mut ref Node = make_node(nk, line)
    nt.d0 = public
    node_store_slot[ref u8](@addr(nt.d1), name)
    val fl: list[ref Node] = fields
    node_store_slot[list[ref Node]](@addr(nt.d2), fl)
    if has_invariant {
        val il: list[ref Node] = inv_exprs
        node_store_slot[list[ref Node]](@addr(nt.d3), il)
    }
    node_store_slot[ref u8](@addr(nt.d4), spec_name)
    return ok nt
}

fn parse_spec_item(p: ref Parser, public: i64) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)
    p_expect_kind(p, lexer.kind_is_spec, "spec")?
    val name = p_expect_ident(p)?
    p_expect_eq(p)?
    p_expect_lbrace(p)?
    val methods: mut list[ref Node] = []
    for {
        if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
        val method_public: mut i64 = 0
        if p_eat_fn(p, kind_is_pub) { method_public = 1 }
        val method = parse_fn_item(p, method_public)?
        @append(methods, method)
    }
    p_expect_rbrace(p)?
    val ns: mut ref Node = make_node(NK_SPEC, line)
    ns.d0 = public
    node_store_slot[ref u8](@addr(ns.d1), name)
    val ml: list[ref Node] = methods
    node_store_slot[list[ref Node]](@addr(ns.d2), ml)
    return ok ns
}

fn parse_enum_def_item(p: ref Parser, public: i64) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)
    p_expect_kind(p, kind_is_enum, "enum")?
    val name = p_expect_ident(p)?
    p_expect_eq(p)?
    p_expect_lbrace(p)?
    val variants: mut list[ref u8] = []
    for {
        if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
        val v = p_expect_ident(p)?
        @append(variants, v)
        if !p_eat_fn(p, lexer.kind_is_comma) { break }
    }
    p_expect_rbrace(p)?
    val ne: mut ref Node = make_node(NK_ENUMDEF, line)
    ne.d0 = public
    node_store_slot[ref u8](@addr(ne.d1), name)
    val vl: list[ref u8] = variants
    node_store_slot[list[ref u8]](@addr(ne.d2), vl)
    return ok ne
}

fn parse_union_def_item(p: ref Parser, public: i64) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)
    p_expect_kind(p, kind_is_union, "union")?
    val name = p_expect_ident(p)?
    p_expect_eq(p)?
    p_expect_lbrace(p)?

    val is_tagged: bool = kind_is_ident(p_peek_kind(p)) && lexer.kind_is_lparen(p_peek2_kind(p))

    if is_tagged {
        val variants: mut list[ref Node] = []
        for {
            if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
            val vline: i64 = p_line(p)
            val vname = p_expect_ident(p)?
            p_expect_lparen(p)?
            val vtypes: mut list[ref Node] = []
            for {
                if lexer.kind_is_rparen(p_peek_kind(p)) { break }
                val vty = parse_type(p)?
                @append(vtypes, vty)
                if !p_eat_fn(p, lexer.kind_is_comma) { break }
            }
            p_expect_rparen(p)?
            val vnode: mut ref Node = make_node(NK_VAL, vline)
            node_store_slot[ref u8](@addr(vnode.d0), vname)
            val vtl: list[ref Node] = vtypes
            node_store_slot[list[ref Node]](@addr(vnode.d1), vtl)
            @append(variants, vnode)
            if !p_eat_fn(p, kind_is_bitor) { break }
        }
        p_expect_rbrace(p)?
        val ntu: mut ref Node = make_node(NK_TAGGED_UNIONDEF, line)
        ntu.d0 = public
        node_store_slot[ref u8](@addr(ntu.d1), name)
        val vl: list[ref Node] = variants
        node_store_slot[list[ref Node]](@addr(ntu.d2), vl)
        return ok ntu
    }

    val variants: mut list[ref Node] = []
    for {
        if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
        val vty = parse_type(p)?
        @append(variants, vty)
        if !p_eat_fn(p, kind_is_bitor) { break }
    }
    p_expect_rbrace(p)?
    val nu: mut ref Node = make_node(NK_UNIONDEF, line)
    nu.d0 = public
    node_store_slot[ref u8](@addr(nu.d1), name)
    val vl2: list[ref Node] = variants
    node_store_slot[list[ref Node]](@addr(nu.d2), vl2)
    return ok nu
}

fn parse_extern_fn_item(p: ref Parser, public: i64) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)
    p_expect_lparen(p)?
    val conv = p_expect_ident(p)?
    val use_header_decl: mut i64 = 0
    for {
        if lexer.kind_is_rparen(p_peek_kind(p)) { break }
        p_expect_comma(p)?
        val modifier = p_expect_ident(p)?
        if str_eq(modifier, "header") {
            use_header_decl = 1
        } else {
            return err @fmt("{s}:{lld}: unknown extern modifier '{s}'", {p.filename, p_line(p), modifier})
        }
    }
    p_expect_rparen(p)?
    p_expect_kind(p, kind_is_fn, "fn")?
    val name = p_expect_ident(p)?
    p_expect_lparen(p)?
    val params: mut list[ref Node] = []
    val is_variadic: mut i64 = 0
    for {
        if lexer.kind_is_rparen(p_peek_kind(p)) { break }
        if kind_is_dotdotdot(p_peek_kind(p)) { p_advance(p) is_variadic = 1 break }
        val pname = p_expect_ident(p)?
        p_expect_colon(p)?
        val pty = parse_type(p)?
        val param: mut ref Node = make_node(NK_VAL, line)
        node_store_slot[ref u8](@addr(param.d0), pname)
        node_store_slot[ref Node](@addr(param.d1), pty)
        @append(params, param)
        if !p_eat_fn(p, lexer.kind_is_comma) { break }
    }
    p_expect_rparen(p)?
    val ret_ty = parse_type(p)?
    val is_unsafe: mut i64 = 0
    if p_eat_fn(p, kind_is_bang) { is_unsafe = 1 }
    p_expect_eq(p)?
    val symbol = p_expect_string(p)?
    val nef: mut ref Node = make_node(NK_EXTERN_FN, line)
    nef.d0 = public
    node_store_slot[ref u8](@addr(nef.d1), name)
    node_store_slot[ref u8](@addr(nef.d2), symbol)
    node_store_slot[ref u8](@addr(nef.d3), conv)
    val pl: list[ref Node] = params
    node_store_slot[list[ref Node]](@addr(nef.d4), pl)
    node_store_slot[ref Node](@addr(nef.d5), ret_ty)
    nef.d6 = (is_unsafe * FN_FLAG_UNSAFE) | (is_variadic * EXTERN_FLAG_VARIADIC) | (use_header_decl * EXTERN_FLAG_HEADER)
    return ok nef
}

fn parse_extern_header_item(p: ref Parser) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)
    val header = p_expect_string(p)?
    val neh: mut ref Node = make_node(NK_EXTERN_HEADER, line)
    node_store_slot[ref u8](@addr(neh.d0), header)
    return ok neh
}

pub fn parse_item(p: ref Parser) result[ref Node, ref u8]! = {
    val line: i64 = p_line(p)
    val k: lexer.TokenKind = p_peek_kind(p)

    if kind_is_link(k) {
        p_advance(p)
        val lib = p_expect_string(p)?
        val nl: mut ref Node = make_node(NK_LINK, line)
        node_store_slot[ref u8](@addr(nl.d0), lib)
        return ok nl
    }

    if kind_is_test(k) {
        p_advance(p)
        p_expect_lbrace(p)?
        val tbody = parse_stmts(p)?
        p_expect_rbrace(p)?
        val nt: mut ref Node = make_node(NK_TEST, line)
        val tlist: list[ref Node] = tbody
        node_store_slot[list[ref Node]](@addr(nt.d0), tlist)
        return ok nt
    }

    if kind_is_when(k) {
        p_advance(p)
        val plat = p_expect_ident(p)?
        p_expect_lbrace(p)?
        val witems: mut list[ref Node] = []
        for {
            if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
            val wi = parse_item(p)?
            @append(witems, wi)
        }
        p_expect_rbrace(p)?
        val or_when_item_branches: mut list[ref Node] = []
        for {
            val k2: lexer.TokenKind = p_peek_kind(p)
            if !kind_is_ident(k2) { break }
            val txt: ref u8 = lexer.tok_text(p.tokens, p.pos)
            if !str_eq(txt, "or") { break }
            val k3: lexer.TokenKind = p_peek2_kind(p)
            if !kind_is_when(k3) { break }
            p_advance(p)
            p_advance(p)
            val ow_plat = p_expect_ident(p)?
            p_expect_lbrace(p)?
            val ow_items: mut list[ref Node] = []
            for {
                if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
                val owi = parse_item(p)?
                @append(ow_items, owi)
            }
            p_expect_rbrace(p)?
            val ow_node: mut ref Node = make_node(NK_WHEN_ITEMS, line)
            node_store_slot[ref u8](@addr(ow_node.d0), ow_plat)
            val ow_il: list[ref Node] = ow_items
            node_store_slot[list[ref Node]](@addr(ow_node.d1), ow_il)
            @append(or_when_item_branches, ow_node)
        }
        val otherwise_items: mut list[ref Node] = []
        val k4: lexer.TokenKind = p_peek_kind(p)
        if kind_is_ident(k4) {
            val txt2: ref u8 = lexer.tok_text(p.tokens, p.pos)
            if str_eq(txt2, "otherwise") {
                p_advance(p)
                p_expect_lbrace(p)?
                for {
                    if lexer.kind_is_rbrace(p_peek_kind(p)) { break }
                    val owi2 = parse_item(p)?
                    @append(otherwise_items, owi2)
                }
                p_expect_rbrace(p)?
            }
        }
        val nwi: mut ref Node = make_node(NK_WHEN_ITEMS, line)
        node_store_slot[ref u8](@addr(nwi.d0), plat)
        val wil: list[ref Node] = witems
        node_store_slot[list[ref Node]](@addr(nwi.d1), wil)
        val owil: list[ref Node] = or_when_item_branches
        node_store_slot[list[ref Node]](@addr(nwi.d2), owil)
        val owsl2: list[ref Node] = otherwise_items
        node_store_slot[list[ref Node]](@addr(nwi.d3), owsl2)
        return ok nwi
    }

    val public: mut i64 = 0
    if p_eat_fn(p, kind_is_pub) { public = 1 }
    val k2: lexer.TokenKind = p_peek_kind(p)

    if kind_is_extern(k2) {
        p_advance(p)
        if kind_is_str(p_peek_kind(p)) { return parse_extern_header_item(p) }
        if kind_is_type(p_peek_kind(p)) { return parse_type_def_item(p, public, 1) }
        return parse_extern_fn_item(p, public)
    }
    if lexer.kind_is_spec(k2) { return parse_spec_item(p, public) }
    if kind_is_fn(k2)    { return parse_fn_item(p, public) }
    if kind_is_type(k2)  { return parse_type_def_item(p, public, 0) }
    if kind_is_enum(k2)  { return parse_enum_def_item(p, public) }
    if kind_is_union(k2) { return parse_union_def_item(p, public) }

    if kind_is_val(k2) {
        p_advance(p)
        val vname = p_expect_ident(p)?
        val vmut: mut i64 = 0
        val vty: mut ref Node = none
        if p_eat_fn(p, lexer.kind_is_colon) {
            if p_eat_fn(p, kind_is_mut) { vmut = 1 }
            vty = parse_type(p)?
        }
        p_expect_eq(p)?
        if kind_is_use(p_peek_kind(p)) {
            p_advance(p)
            p_expect_lparen(p)?
            val path = p_expect_string(p)?
            p_expect_rparen(p)?
            val nu: mut ref Node = make_node(NK_USE, line)
            nu.d0 = public
            node_store_slot[ref u8](@addr(nu.d1), vname)
            node_store_slot[ref u8](@addr(nu.d2), path)
            return ok nu
        }
        val vexpr = parse_expr(p)?
        if vmut != 0 {
            val nv: mut ref Node = make_node(NK_VAL, line)
            node_store_slot[ref u8](@addr(nv.d0), vname)
            nv.d1 = 1
            node_store_slot[ref Node](@addr(nv.d2), vty)
            node_store_slot[ref Node](@addr(nv.d3), vexpr)
            return ok nv
        }
        val nc: mut ref Node = make_node(NK_CONST, line)
        nc.d0 = public
        node_store_slot[ref u8](@addr(nc.d1), vname)
        node_store_slot[ref Node](@addr(nc.d2), vexpr)
        return ok nc
    }

    return err p_error(p, "unexpected token at top level")
}

pub fn parse_module(tokens: list[ref lexer.Token], filename: ref u8) result[list[ref Node], ref u8]! = {
    val p: ref Parser = parser_new(tokens, filename)
    val items: mut list[ref Node] = []
    for {
        if kind_is_eof(p_peek_kind(p)) { break }
        val item = parse_item(p)?
        @append(items, item)
    }
    return ok items
}

fn parse_src(src: ref u8) result[list[ref Node], ref u8] = {
    val r = trust lexer.tokenize(src)
    match r {
        err e => { return err e }
        ok toks => { return trust parse_module(toks, "<test>") }
    }
}

fn parse_expr_src(src: ref u8) result[ref Node, ref u8] = {
    val r = trust lexer.tokenize(src)
    match r {
        err e => { return err e }
        ok toks => {
            val p: ref Parser = trust parser_new(toks, "<test>")
            return trust parse_expr(p)
        }
    }
}

test {
    @puts("parser 1")
    val r1 = parse_expr_src("42")
    match r1 {
        err e => {
            trust stdio.print("{s}", {e})
            assert false
        }
        ok n  => {
            assert n.kind == NK_INT_LIT
            assert string.rchar_cmp(int_lit_text(n), "42") == 0
        }
    }

    @puts("parser 2")
    val r2 = parse_expr_src("3.14")
    match r2 {
        err _ => { assert false }
        ok n  => { assert n.kind == NK_FLOAT_LIT }
    }

    @puts("parser 3")
    val r3 = parse_expr_src("\"hello\"")
    match r3 {
        err _ => { assert false }
        ok n  => {
            assert n.kind == NK_STR_LIT
            assert string.rchar_cmp(str_lit_text(n), "hello") == 0
        }
    }

    @puts("parser 4")
    val r4t = parse_expr_src("true")
    match r4t {
        err _ => { assert false }
        ok n  => {
            assert n.kind == NK_BOOL
            assert n.d0 == 1
        }
    }
    val r4f = parse_expr_src("false")
    match r4f {
        err _ => { assert false }
        ok n  => { assert n.kind == NK_BOOL assert n.d0 == 0 }
    }

    @puts("parser 5")
    val r5 = parse_expr_src("foo")
    match r5 {
        err _ => { assert false }
        ok n  => {
            assert n.kind == NK_IDENT
            assert string.rchar_cmp(n.d0 as ref u8, "foo") == 0
        }
    }

    @puts("parser 6")
    val r6 = parse_expr_src("1 + 2")
    match r6 {
        err _ => { assert false }
        ok n  => {
            assert n.kind == NK_BINOP
            assert binop_op(n) == OP_ADD
            val lhs: ref Node = binop_left(n)
            val rhs: ref Node = binop_right(n)
            assert lhs.kind == NK_INT_LIT
            assert rhs.kind == NK_INT_LIT
        }
    }

    @puts("parser 7")
    val r7 = parse_expr_src("a == b")
    match r7 {
        err _ => { assert false }
        ok n  => {
            assert n.kind == NK_BINOP
            assert binop_op(n) == OP_EQ
        }
    }

    @puts("parser 8")
    val r8 = parse_expr_src("-x")
    match r8 {
        err _ => { assert false }
        ok n  => {
            assert n.kind == NK_UNOP
            assert unop_op(n) == UOP_NEG
        }
    }

    @puts("parser 9")
    val r9 = parse_expr_src("!flag")
    match r9 {
        err _ => { assert false }
        ok n  => {
            assert n.kind == NK_UNOP
            assert unop_op(n) == UOP_NOT
        }
    }

    @puts("parser 10")
    val r10 = parse_expr_src("obj.field")
    match r10 {
        err _ => { assert false }
        ok n  => {
            assert n.kind == NK_FIELD
            val base: ref Node = field_base(n)
            assert base.kind == NK_IDENT
            assert string.rchar_cmp(field_name(n), "field") == 0
        }
    }

    @puts("parser 11")
    val r11 = parse_expr_src("foo(1, 2)")
    match r11 {
        err _ => { assert false }
        ok n  => { assert n.kind == NK_CALL }
    }

    @puts("parser 12")
    val r12 = parse_expr_src("x as i64")
    match r12 {
        err _ => { assert false }
        ok n  => { assert n.kind == NK_CAST }
    }

    @puts("parser 13")
    val r13 = parse_expr_src("[1, 2, 3]")
    match r13 {
        err _ => { assert false }
        ok n  => { assert n.kind == NK_LIST_LIT }
    }

    @puts("parser 14")
    val r14 = parse_expr_src("none")
    match r14 {
        err _ => { assert false }
        ok n  => { assert n.kind == NK_NONE }
    }

    @puts("parser 15")
    val r15 = parse_src("val x = 10")
    match r15 {
        err _ => { assert false }
        ok items => {
            assert @len(items) as i64 == 1
            val opt15 = @get(items, 0 as usize)
            match opt15 {
                none   => { assert false }
                some v => {
                    val item: ref Node = v as ref Node
                    assert item.kind == NK_CONST
                }
            }
        }
    }

    @puts("parser 16")
    val r16 = parse_src("fn add(a: i64, b: i64) i64! = { return a + b }")
    match r16 {
        err e => {
            trust stdio.print("{s}\n", {e})
            assert false
        }
        ok items => {
            assert @len(items) as i64 == 1
            val opt16 = @get(items, 0 as usize)
            match opt16 {
                none   => { assert false }
                some v => {
                    val item: ref Node = v as ref Node
                    assert item.kind == NK_FN
                    assert item.d0 == 0  // not public
                }
            }
        }
    }

    @puts("parser 17")
    val r17 = parse_src("pub fn greet() void! = { }")
    match r17 {
        err _ => { assert false }
        ok items => {
            val opt17 = @get(items, 0 as usize)
            match opt17 {
                none   => { assert false }
                some v => {
                    val item: ref Node = v as ref Node
                    assert item.kind == NK_FN
                    assert item.d0 == 1  // public
                }
            }
        }
    }

    @puts("parser 18")
    val r18 = parse_src("type Point = { x: i64, y: i64 }")
    match r18 {
        err _ => { assert false }
        ok items => {
            val opt18 = @get(items, 0 as usize)
            match opt18 {
                none   => { assert false }
                some v => {
                    val item: ref Node = v as ref Node
                    assert item.kind == NK_TYPEDEF
                }
            }
        }
    }

    @puts("parser 18b")
    val r18b = parse_src("type Token = { kind: mut i64 invariant { kind > 0 } }")
    match r18b {
        err e => {
            trust stdio.print("{s}\n", {e})
            assert false
        }
        ok items => {
            val opt18b = @get(items, 0 as usize)
            match opt18b {
                none => { assert false }
                some v => {
                    val item: ref Node = v as ref Node
                    assert item.kind == NK_TYPEDEF
                    assert item.d3 != 0
                    assert @len(item.d3 as list[ref Node]) as i64 == 1
                }
            }
        }
    }

    @puts("parser 18c")
    val r18c = parse_src("type Token = { kind: mut i64 } invariant { kind > 0 }")
    match r18c {
        ok _  => { assert false }
        err _ => { assert true }
    }

    @puts("parser 19")
    val r19 = parse_expr_src("2 + 3 * 4")
    match r19 {
        err _ => { assert false }
        ok n  => {
            assert n.kind == NK_BINOP
            assert binop_op(n) == OP_ADD
            val rhs: ref Node = binop_right(n)
            assert rhs.kind == NK_BINOP
            assert binop_op(rhs) == OP_MUL
        }
    }

    @puts("parser 20")
    val r20 = parse_src("fn (")
    match r20 {
        ok _  => { assert false }
        err _ => { assert true }
    }
}
