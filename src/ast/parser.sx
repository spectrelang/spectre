pub type Node = {
    kind: mut i64
    line: mut i64
    d0:   mut i64
    d1:   mut i64
    d2:   mut i64
    d3:   mut i64
    d4:   mut i64
    d5:   mut i64
    d6:   mut i64
}

pub fn make_node(kind: i64, line: i64) ref Node! = {
    val n: mut ref Node = @alloc(@sizeof(Node)) as ref Node
    n.kind = kind
    n.line = line
    n.d0 = 0
    n.d1 = 0
    n.d2 = 0
    n.d3 = 0
    n.d4 = 0
    n.d5 = 0
    n.d6 = 0
    return n
}

pub fn node_store_slot[T](slot: ref i64, value: T) void! = {
    @store(slot as ref void, value)
}

pub fn ptr_to_i64[T](p: T) i64! = {
    val i: mut i64 = 0
    @store(@addr(i) as ref void, p)
    return i
}

pub fn ptr_to_usize[T](p: T) usize! = {
    val u: mut usize = 0
    @store(@addr(u) as ref void, p)
    return u
}

fn make_binop(op: i64, line: i64, left: ref Node, right: ref Node) result[ref Node, ref u8]! = {
    val n: mut ref Node = make_node(NK_BINOP, line)
    n.d0 = op
    node_store_slot[ref Node](@addr(n.d1), left)
    node_store_slot[ref Node](@addr(n.d2), right)
    return ok n
}

pub fn binop_op(n: ref Node) i64 = { return n.d0 }
pub fn binop_left(n: ref Node) ref Node = { return n.d1 as ref Node }
pub fn binop_right(n: ref Node) ref Node = { return n.d2 as ref Node }
pub fn generic_fn_type_params(n: ref Node) list[ref Node] = { return n.d6 as list[ref Node] }
pub fn tparam_name(tp: ref Node) ref u8 = { return tp.d0 as ref u8 }
pub fn tparam_constraint(tp: ref Node) ref Node = { return tp.d1 as ref Node }
pub fn generic_fn_is_unsafe(n: ref Node) bool = { return (n.d0 & 2) != 0 }
pub fn generic_when_conditions(n: ref Node) list[ref Node] = { return n.d0 as list[ref Node] }
pub fn generic_when_body(n: ref Node) ref Node = { return n.d1 as ref Node }
pub fn generic_inst_base(n: ref Node) ref Node = { return n.d0 as ref Node }
pub fn generic_inst_type_args(n: ref Node) list[ref Node] = { return n.d1 as list[ref Node] }
pub fn gwhen_cond_tparam(n: ref Node) ref u8 = { return n.d0 as ref u8 }
pub fn gwhen_cond_kind(n: ref Node) i64 = { return n.d1 }
pub fn gwhen_cond_types(n: ref Node) list[ref Node] = { return n.d2 as list[ref Node] }

fn make_unop(op: i64, line: i64, inner: ref Node) result[ref Node, ref u8]! = {
    val n: mut ref Node = make_node(NK_UNOP, line)
    n.d0 = op
    node_store_slot[ref Node](@addr(n.d1), inner)
    return ok n
}

pub fn unop_op(n: ref Node) i64 = { return n.d0 }
pub fn unop_inner(n: ref Node) ref Node = { return n.d1 as ref Node }
pub fn fixed_arr_size(n: ref Node) i64 = { return n.d0 }
pub fn fixed_arr_inner(n: ref Node) ref Node = { return n.d1 as ref Node }
pub fn fixed_arr_size_name(n: ref Node) ref u8 = { return n.d2 as ref u8 }

pub fn fn_is_unsafe(n: ref Node) bool = {
    if n.kind == NK_GENERIC_FN {
        return ((n.d0 >> 1) & 1) != 0
    }
    return (n.d6 & FN_FLAG_UNSAFE) != 0
}

pub fn extern_fn_is_variadic(n: ref Node) bool = { return (n.d6 & EXTERN_FLAG_VARIADIC) != 0 }
pub fn extern_fn_uses_header(n: ref Node) bool = { return (n.d6 & EXTERN_FLAG_HEADER) != 0 }

fn make_field(base: ref Node, line: i64, name: ref u8) result[ref Node, ref u8]! = {
    val n: mut ref Node = make_node(NK_FIELD, line)
    node_store_slot[ref Node](@addr(n.d0), base)
    node_store_slot[ref u8](@addr(n.d1), name)
    return ok n
}

pub fn field_base(n: ref Node) ref Node = { return n.d0 as ref Node }
pub fn field_name(n: ref Node) ref u8 = { return n.d1 as ref u8 }

fn make_call(callee: ref Node, line: i64, args: list[ref Node]) result[ref Node, ref u8]! = {
    val n: mut ref Node = make_node(NK_CALL, line)
    node_store_slot[ref Node](@addr(n.d0), callee)
    node_store_slot[list[ref Node]](@addr(n.d1), args)
    return ok n
}

pub fn call_callee(n: ref Node) ref Node! = { return n.d0 as ref Node }
pub fn call_args(n: ref Node) list[ref Node]! = { return n.d1 as list[ref Node] }

fn make_struct_field(name: ref u8, line: i64, expr: ref Node) result[ref Node, ref u8]! = {
    val n: mut ref Node = make_node(NK_FIELD, line)
    node_store_slot[ref u8](@addr(n.d0), name)
    node_store_slot[ref Node](@addr(n.d1), expr)
    return ok n
}

pub fn match_opt_expr(n: ref Node) ref Node      = { return n.d0 as ref Node }
pub fn match_opt_some_bind(n: ref Node) ref u8   = { return n.d1 as ref u8 }
pub fn match_opt_some_body(n: ref Node) ref Node = { return n.d2 as ref Node }  // wrapper, .d0 = stmts list
pub fn match_opt_none_body(n: ref Node) ref Node = { return n.d3 as ref Node }  // wrapper, .d0 = stmts list

pub fn match_res_expr(n: ref Node) ref Node       = { return n.d0 as ref Node }
pub fn match_res_ok_bind(n: ref Node) ref u8      = { return n.d1 as ref u8 }
pub fn match_res_ok_body(n: ref Node) ref Node    = { return n.d2 as ref Node }  // wrapper, .d0 = stmts list
pub fn match_res_err_bind(n: ref Node) ref u8     = { return n.d3 as ref u8 }
pub fn match_res_err_body(n: ref Node) ref Node   = { return n.d4 as ref Node }  // wrapper, .d0 = stmts list

pub fn match_enum_expr(n: ref Node) ref Node               = { return n.d0 as ref Node }
pub fn match_enum_arms(n: ref Node) list[ref Node]         = { return n.d1 as list[ref Node] }
pub fn match_enum_arm_body(arm: ref Node) list[ref Node]   = { return arm.d1 as list[ref Node] }

pub fn match_value_expr(n: ref Node) ref Node              = { return n.d0 as ref Node }
pub fn match_value_arms(n: ref Node) list[ref Node]        = { return n.d1 as list[ref Node] }
pub fn match_value_else(n: ref Node) ref Node              = { return n.d2 as ref Node }  // wrapper, .d0 = stmts list
pub fn match_value_arm_pattern(arm: ref Node) ref Node     = { return arm.d0 as ref Node }
pub fn match_value_arm_body(arm: ref Node) list[ref Node]  = { return arm.d1 as list[ref Node] }

pub fn match_str_expr(n: ref Node) ref Node                = { return n.d0 as ref Node }
pub fn match_str_arms(n: ref Node) list[ref Node]          = { return n.d1 as list[ref Node] }
pub fn match_str_else(n: ref Node) ref Node                = { return n.d2 as ref Node }  // wrapper, .d0 = stmts list
pub fn match_str_arm_value(arm: ref Node) ref u8           = { return arm.d0 as ref u8 }
pub fn match_str_arm_body(arm: ref Node) list[ref Node]    = { return arm.d1 as list[ref Node] }

pub fn match_union_expr(n: ref Node) ref Node              = { return n.d0 as ref Node }
pub fn match_union_arms(n: ref Node) list[ref Node]        = { return n.d1 as list[ref Node] }
pub fn match_union_else(n: ref Node) ref Node              = { return n.d2 as ref Node }  // wrapper, .d0 = stmts list
pub fn match_union_arm_type(arm: ref Node) ref Node        = { return arm.d0 as ref Node }
pub fn match_union_arm_body(arm: ref Node) list[ref Node]  = { return arm.d1 as list[ref Node] }

pub fn match_tagged_union_expr(n: ref Node) ref Node           = { return n.d0 as ref Node }
pub fn match_tagged_union_arms(n: ref Node) list[ref Node]     = { return n.d1 as list[ref Node] }
pub fn match_tagged_union_else(n: ref Node) ref Node           = { return n.d2 as ref Node }  // wrapper, .d0 = stmts list
pub fn match_tagged_union_arm_variant(arm: ref Node) ref u8!   = { return arm.d0 as ref u8 }
pub fn match_tagged_union_arm_bindings(arm: ref Node) list[ref u8]! = { return arm.d1 as list[ref u8] }
pub fn match_tagged_union_arm_body(arm: ref Node) list[ref Node]!   = { return arm.d2 as list[ref Node] }

fn make_int_lit(text: ref u8, line: i64) result[ref Node, ref u8]! = {
    val n: mut ref Node = make_node(NK_INT_LIT, line)
    node_store_slot[ref u8](@addr(n.d0), text)
    return ok n
}

pub fn int_lit_text(n: ref Node) ref u8 = { return n.d0 as ref u8 }

fn make_float_lit(text: ref u8, line: i64) result[ref Node, ref u8]! = {
    val n: mut ref Node = make_node(NK_FLOAT_LIT, line)
    node_store_slot[ref u8](@addr(n.d0), text)
    return ok n
}

pub fn float_lit_text(n: ref Node) ref u8 = { return n.d0 as ref u8 }

fn make_str_lit(text: ref u8, line: i64) result[ref Node, ref u8]! = {
    val n: mut ref Node = make_node(NK_STR_LIT, line)
    node_store_slot[ref u8](@addr(n.d0), text)
    return ok n
}

pub fn str_lit_text(n: ref Node) ref u8 = { return n.d0 as ref u8 }

fn str_eq(a: ref u8, b: ref u8) bool! = {
    return string.rchar_cmp(a, b) == 0
}

type Parser = {
    tokens:   mut list[ref lexer.Token]
    pos:      mut i64
    filename: mut ref u8
}

pub fn parser_new(tokens: list[ref lexer.Token], filename: ref u8) ref Parser! = {
    val p: mut ref Parser = @alloc(@sizeof(Parser)) as ref Parser
    p.tokens   = tokens
    p.pos      = 0
    p.filename = filename
    return p
}

fn p_peek_kind(p: ref Parser) lexer.TokenKind! = {
    return lexer.tok_kind(p.tokens, p.pos)
}

fn p_peek2_kind(p: ref Parser) lexer.TokenKind! = {
    return lexer.tok_kind(p.tokens, p.pos + 1)
}

fn p_peek3_kind(p: ref Parser) lexer.TokenKind! = {
    return lexer.tok_kind(p.tokens, p.pos + 2)
}

fn p_peek_line(p: ref Parser) i64! = {
    val opt = @get(p.tokens, p.pos as usize)
    match opt {
        some t => { return (t as ref lexer.Token).line }
        none   => { return 0 }
    }
}

fn p_advance(p: mut ref Parser) lexer.TokenKind! = {
    val k: lexer.TokenKind = p_peek_kind(p)
    if p.pos + 1 < @len(p.tokens) as i64 { p.pos = p.pos + 1 }
    return k
}

fn p_advance_text(p: mut ref Parser) ref u8! = {
    val txt: ref u8 = lexer.tok_text(p.tokens, p.pos)
    if p.pos + 1 < @len(p.tokens) as i64 { p.pos = p.pos + 1 }
    return txt
}

fn p_line(p: ref Parser) i64! = { return p_peek_line(p) }

fn p_error(p: ref Parser, msg: ref u8) ref u8! = {
    val line: i64 = p_peek_line(p)
    val buf: ref u8 = @alloc(512) as ref u8
    @snprintf(buf, 512, "{s}:{lld}: {s}", {p.filename, line, msg})
    return buf
}

fn p_eat_fn(p: ref Parser, is_kind: fn(lexer.TokenKind) bool) bool! = {
    if is_kind(p_peek_kind(p)) { p_advance(p) return true }
    return false
}

fn p_expect_kind(p: ref Parser, is_kind: fn(lexer.TokenKind) bool, name: ref u8) result[ref u8, ref u8]! = {
    if is_kind(p_peek_kind(p)) {
        val txt: ref u8 = lexer.tok_text(p.tokens, p.pos)
        p_advance(p)
        return ok txt
    }
    val msg: ref u8 = @alloc(128) as ref u8
    @snprintf(msg, 128, "expected {s}", {name})
    return err p_error(p, msg)
}

fn p_expect_ident(p: ref Parser) result[ref u8, ref u8]! = {
    match p_peek_kind(p) {
        Ident _ => {
            val txt: ref u8 = lexer.tok_text(p.tokens, p.pos)
            p_advance(p)
            return ok txt
        }
        else => { return err p_error(p, "expected identifier") }
    }
}

fn p_expect_string(p: ref Parser) result[ref u8, ref u8]! = {
    match p_peek_kind(p) {
        Str _ => {
            val txt: ref u8 = lexer.tok_text(p.tokens, p.pos)
            p_advance(p)
            return ok txt
        }
        else => { return err p_error(p, "expected string literal") }
    }
}

fn p_expect_lbrace(p: ref Parser)   result[ref u8, ref u8]! = { return p_expect_kind(p, lexer.kind_is_lbrace,   "'{'" ) }
fn p_expect_rbrace(p: ref Parser)   result[ref u8, ref u8]! = { return p_expect_kind(p, lexer.kind_is_rbrace,   "'}'" ) }
fn p_expect_lparen(p: ref Parser)   result[ref u8, ref u8]! = { return p_expect_kind(p, lexer.kind_is_lparen,   "'('" ) }
fn p_expect_rparen(p: ref Parser)   result[ref u8, ref u8]! = { return p_expect_kind(p, lexer.kind_is_rparen,   "')'" ) }
fn p_expect_lbracket(p: ref Parser) result[ref u8, ref u8]! = { return p_expect_kind(p, lexer.kind_is_lbracket, "'['" ) }
fn p_expect_rbracket(p: ref Parser) result[ref u8, ref u8]! = { return p_expect_kind(p, lexer.kind_is_rbracket, "']'" ) }
fn p_expect_colon(p: ref Parser)    result[ref u8, ref u8]! = { return p_expect_kind(p, lexer.kind_is_colon,    "':'" ) }
fn p_expect_comma(p: ref Parser)    result[ref u8, ref u8]! = { return p_expect_kind(p, lexer.kind_is_comma,    "','" ) }
fn p_expect_eq(p: ref Parser)       result[ref u8, ref u8]! = { return p_expect_kind(p, kind_is_eq,       "'='" ) }
fn p_expect_fatarrow(p: ref Parser) result[ref u8, ref u8]! = { return p_expect_kind(p, lexer.kind_is_fatarrow, "'=>'") }
fn p_expect_semicolon(p: ref Parser) result[ref u8, ref u8]! = { return p_expect_kind(p, kind_is_semicolon, "';'") }
fn p_expect_dot(p: ref Parser)      result[ref u8, ref u8]! = { return p_expect_kind(p, lexer.kind_is_dot,      "'.'" ) }

fn kind_is_eq(k: lexer.TokenKind) bool! = { match k { Eq() => { return true } else => { return false } } }
fn kind_is_semicolon(k: lexer.TokenKind) bool! = { match k { Semicolon() => { return true } else => { return false } } }
fn kind_is_pluseq(k: lexer.TokenKind) bool! = { match k { PlusEq() => { return true } else => { return false } } }
fn kind_is_minuseq(k: lexer.TokenKind) bool! = { match k { MinusEq() => { return true } else => { return false } } }
fn kind_is_bang(k: lexer.TokenKind) bool! = { match k { Bang() => { return true } else => { return false } } }
fn kind_is_minus(k: lexer.TokenKind) bool! = { match k { Minus() => { return true } else => { return false } } }
fn kind_is_tilde(k: lexer.TokenKind) bool! = { match k { Tilde() => { return true } else => { return false } } }
fn kind_is_star(k: lexer.TokenKind) bool! = { match k { Star() => { return true } else => { return false } } }
fn kind_is_slash(k: lexer.TokenKind) bool! = { match k { Slash() => { return true } else => { return false } } }
fn kind_is_percent(k: lexer.TokenKind) bool! = { match k { Percent() => { return true } else => { return false } } }
fn kind_is_plus(k: lexer.TokenKind) bool! = { match k { Plus() => { return true } else => { return false } } }
fn kind_is_lt(k: lexer.TokenKind) bool! = { match k { Lt() => { return true } else => { return false } } }
fn kind_is_gt(k: lexer.TokenKind) bool! = { match k { Gt() => { return true } else => { return false } } }
fn kind_is_bitand(k: lexer.TokenKind) bool! = { match k { BitAnd() => { return true } else => { return false } } }
fn kind_is_bitor(k: lexer.TokenKind) bool! = { match k { BitOr() => { return true } else => { return false } } }
fn kind_is_bitxor(k: lexer.TokenKind) bool! = { match k { BitXor() => { return true } else => { return false } } }
fn kind_is_as(k: lexer.TokenKind) bool! = { match k { As() => { return true } else => { return false } } }
fn kind_is_trust(k: lexer.TokenKind) bool! = { match k { Trust() => { return true } else => { return false } } }
fn kind_is_some(k: lexer.TokenKind) bool! = { match k { Some() => { return true } else => { return false } } }
fn kind_is_none(k: lexer.TokenKind) bool! = { match k { None() => { return true } else => { return false } } }
fn kind_is_ok(k: lexer.TokenKind) bool! = { match k { Ok() => { return true } else => { return false } } }
fn kind_is_err(k: lexer.TokenKind) bool! = { match k { Err() => { return true } else => { return false } } }
fn kind_is_true(k: lexer.TokenKind) bool! = { match k { True() => { return true } else => { return false } } }
fn kind_is_false(k: lexer.TokenKind) bool! = { match k { False() => { return true } else => { return false } } }
fn kind_is_fn(k: lexer.TokenKind) bool! = { match k { Fn() => { return true } else => { return false } } }
fn kind_is_val(k: lexer.TokenKind) bool! = { match k { Val() => { return true } else => { return false } } }
fn kind_is_mut(k: lexer.TokenKind) bool! = { match k { Mut() => { return true } else => { return false } } }
fn kind_is_pub(k: lexer.TokenKind) bool! = { match k { Pub() => { return true } else => { return false } } }
fn kind_is_type(k: lexer.TokenKind) bool! = { match k { Type() => { return true } else => { return false } } }
fn kind_is_pre(k: lexer.TokenKind) bool! = { match k { Pre() => { return true } else => { return false } } }
fn kind_is_post(k: lexer.TokenKind) bool! = { match k { Post() => { return true } else => { return false } } }
fn kind_is_return(k: lexer.TokenKind) bool! = { match k { Return() => { return true } else => { return false } } }
