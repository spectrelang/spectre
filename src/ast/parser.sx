pub val NK_USE               : i64 = 2
pub val NK_TYPEDEF           : i64 = 3
pub val NK_ENUMDEF           : i64 = 4
pub val NK_UNIONDEF          : i64 = 5
pub val NK_CONST             : i64 = 6
