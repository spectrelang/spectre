val std     = use("std")
val parser  = use("../ast/parser.sx")
val modinfo = use("../module/module.sx")

type ScopeEntry = {
    name:         mut ref u8
    mutable:      mut i64
    type_name:    mut ref u8
    is_ref:       mut i64
    line:         mut i64
    used:         mut i64
    mutated:      mut i64
    implicit_mut: mut i64
}

type SemaCtx = {
    errors:        mut list[ref u8]
    warnings:      mut list[ref u8]
    fn_names:      mut list[ref u8]
    used_fns:      mut list[ref u8]
    type_names:    mut list[ref u8]
    global_names:  mut list[ref u8]
    scopes:        mut list[ref void]
    type_defs:     mut list[ref void]
    fn_defs:       mut list[ref void]
    fn_map_names:  mut list[ref u8]
    fn_map_params: mut list[ref void]
    variant_names: mut list[ref u8]
    root_mod:      mut ref modinfo.ResolvedModule
    in_unsafe_fn:  mut i64
    in_trust:      mut i64
    trust_used:    mut i64
    type_params:   mut list[ref u8]
}

fn sema_new() ref SemaCtx! = {
    val ctx: ref SemaCtx = @alloc(@sizeof(SemaCtx)) as ref SemaCtx
    @memset(ctx as ref void, 0, @sizeof(SemaCtx) as usize)
    return ctx
}

fn add_error(ctx: ref SemaCtx, msg: ref u8) void! = {
    for existing in ctx.errors {
        if std.string.rchar_cmp(existing as ref u8, msg) == 0 { return }
    }
    @append(ctx.errors, msg)
}

fn normalize_path(path: ref u8) ref u8! = {
    if path == 0 as ref u8 { return path }
    val sb: ref void = std.string.StringBuilder.new()
    val len: i64 = std.string.len_raw(path)
    val prev_slash: mut bool = false
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: i64 = @load8(@ptradd(path as ref void, i)) as i64
        if c == 47 {
            if !prev_slash { std.string.StringBuilder.append_char(sb, 47) }
            prev_slash = true
        } else {
            std.string.StringBuilder.append_char(sb, c)
            prev_slash = false
        }
        i++
    }
    val built: ref void = std.string.StringBuilder.build(sb)
    std.string.StringBuilder.free(sb)
    return std.string.cstr(built)
}

fn is_known_builtin(name: ref u8) bool! = {
    val builtins: list[ref u8] = [
        "alloc",
        "free",
        "realloc",
        "sizeof",
        "memcpy",
        "memset",
        "memmove",
        "ptradd",
        "fgets",
        "stdin",
        "stderr",
        "load",
        "load64",
        "load8",
        "load16",
        "load32",
        "addr",
        "deref",
        "store",
        "store64",
        "store8",
        "store16",
        "store32",
        "append",
        "remove",
        "insert",
        "get",
        "set",
        "len",
        "reserve",
        "capacity",
        "fmt",
        "snprintf",
        "print",
        "dprintf",
        "puts",
        "args",
        "call",
        "stdin",
        "stdout",
        "stderr",
        "fgets",
        "getchar",
        "strlen",
        "strcmp",
        "atoi",
        "itoa",
        "gettimeofday",
        "staticerror",
        "flush"
    ]

    for builtin in builtins {
        if str_eq(name, builtin) { return true }
    }
    return false
}

fn push_scope(ctx: ref SemaCtx) void! = {
    guarded pre {
        ctx_not_null : ctx != 0 as ref SemaCtx
    }

    val frame: ref list[ref ScopeEntry] = @alloc(@sizeof(list[ref ScopeEntry])) as ref list[ref ScopeEntry]
    @memset(frame as ref void, 0, @sizeof(list[ref ScopeEntry]) as usize)
    @append(ctx.scopes, frame as ref void)

    guarded post {
        scope_created : @len(ctx.scopes) > 0
    }
}

fn pop_scope(ctx: ref SemaCtx, filename: ref u8, _: i64) void! = {
    guarded pre {
        ctx_not_null   : ctx != 0 as ref SemaCtx
        has_scopes     : @len(ctx.scopes) > 0
    }

    val len: usize = @len(ctx.scopes)
    if len > 0 {
        val frame_opt = @get(ctx.scopes, len - 1)
        match frame_opt {
            some frame => {
                val flen: i64 = @len(frame as ref void) as i64
                val i: mut i64 = 0
                for {
                    if i >= flen { break }
                    val e_opt = @get(frame as ref void, i as usize)
                    match e_opt {
                        some e => {
                            val entry: ref ScopeEntry = e as ref ScopeEntry
                            if entry.name != 0 as ref u8 {
                                if std.string.rchar_cmp(entry.name, "_") != 0 {
                                    if entry.used == 0 {
                                        val buf: ref u8 = @alloc(512) as ref u8
                                        @snprintf(buf, 512, "{s}:{lld}: variable '{s}' declared but never used", {filename, entry.line, entry.name})
                                        add_error(ctx, buf)
                                    } elif entry.mutable == 1 && entry.mutated == 0 && entry.implicit_mut == 0 {
                                        val buf2: ref u8 = @alloc(512) as ref u8
                                        @snprintf(buf2, 512, "{s}:{lld}: mutable variable '{s}' declared mutable but never mutated", {filename, entry.line, entry.name})
                                        add_error(ctx, buf2)
                                    }
                                }
                            }
                        }
                        none => {}
                    }
                    i++
                }
            }
            none => {}
        }
        @remove(ctx.scopes, len - 1)
    }

    guarded post {
        scope_removed : true
    }
}

fn scope_define(ctx: ref SemaCtx, name: ref u8, mutable: i64, type_name: ref u8, is_ref: i64, decl_line: i64) void! = {
    guarded pre {
        ctx_not_null    : ctx != 0 as ref SemaCtx
        name_not_null   : name != 0 as ref u8
        has_scope       : @len(ctx.scopes) > 0
    }

    val len: usize = @len(ctx.scopes)
    if len == 0 { return }
    val frame_opt = @get(ctx.scopes, len - 1)
    match frame_opt {
        some frame => {
            val entry: mut ref ScopeEntry = @alloc(@sizeof(ScopeEntry)) as ref ScopeEntry
            entry.name      = name
            entry.mutable   = mutable
            entry.type_name = type_name
            entry.is_ref    = is_ref
            entry.line      = decl_line
            entry.used      = 0
            entry.mutated   = 0
            @append(frame as ref void, entry)

            guarded post {
                entry_added : @len(frame as ref void) > 0
            }
        }
        none => {}
    }
}

fn scope_set_implicit_mut(ctx: ref SemaCtx, name: ref u8) void! = {
    val len: usize = @len(ctx.scopes)
    if len == 0 { return }
    val frame_opt = @get(ctx.scopes, len - 1)
    match frame_opt {
        some frame => {
            val flen: i64 = @len(frame as ref void) as i64
            val i: mut i64 = 0
            for {
                if i >= flen { break }
                val e_opt = @get(frame as ref void, i as usize)
                match e_opt {
                    some e => {
                        val entry: mut ref ScopeEntry = e as ref ScopeEntry
                        if entry.name != 0 as ref u8 {
                            if std.string.rchar_cmp(entry.name, name) == 0 {
                                entry.implicit_mut = 1
                            }
                        }
                    }
                    none => {}
                }
                i++
            }
        }
        none => {}
    }
}

/// Walks a chain of NK_FIELD nodes down to the root NK_IDENT, returning it (or null if none).
fn find_root_ident(node: ref parser.Node) ref parser.Node! = {
    val cur: mut ref parser.Node = node
    for {
        if cur.kind == parser.NK_IDENT { return cur }
        if cur.kind == parser.NK_FIELD {
            cur = parser.field_base(cur)
        } else {
            return 0 as ref parser.Node
        }
    }
    return 0 as ref parser.Node
}

fn is_c_escape_expr(node: ref parser.Node) bool! = {
    if node == 0 as ref parser.Node || node.kind != parser.NK_FIELD { return false }
    val root: ref parser.Node = find_root_ident(node)
    if root == 0 as ref parser.Node { return false }
    return str_eq(root.d0 as ref u8, "C")
}

/// Strips NK_CAST and NK_TRUST wrappers, then delegates to find_root_ident.
fn unwrap_and_find_root(node: ref parser.Node) ref parser.Node! = {
    val cur: mut ref parser.Node = node
    for {
        if cur == 0 as ref parser.Node { return 0 as ref parser.Node }
        if cur.kind == parser.NK_CAST || cur.kind == parser.NK_TRUST {
            cur = cur.d0 as ref parser.Node
        } else {
            return find_root_ident(cur)
        }
    }
    return 0 as ref parser.Node
}

fn sema_find_fn_in_module(mod: ref modinfo.ResolvedModule, name: ref u8) ref parser.Node! = {
    if mod == 0 as ref modinfo.ResolvedModule { return 0 as ref parser.Node }
    val items: list[ref parser.Node] = modinfo.module_items(mod)
    for item in items {
        if item.kind == parser.NK_FN || item.kind == parser.NK_GENERIC_FN {
            val fname: ref u8 = item.d2 as ref u8
            if fname != 0 as ref u8 && str_eq(fname, name) {
                return item
            }
        } elif item.kind == parser.NK_EXTERN_FN {
            val fname: ref u8 = item.d1 as ref u8
            if fname != 0 as ref u8 && str_eq(fname, name) {
                return item
            }
        }
    }
    return 0 as ref parser.Node
}

/// Look up an imported module by its alias name.
/// Returns the ResolvedModule for that alias, or 0 if not found.
fn find_imported_module(mod: ref modinfo.ResolvedModule, alias: ref u8) ref modinfo.ResolvedModule! = {
    if mod == 0 as ref modinfo.ResolvedModule { return 0 as ref modinfo.ResolvedModule }
    if alias == 0 as ref u8 { return 0 as ref modinfo.ResolvedModule }
    val n: i64 = modinfo.import_count(mod)
    val i: mut i64 = 0
    for {
        if i >= n { break }
        val mname: ref u8 = modinfo.import_name_at(mod, i as usize)
        if mname != 0 as ref u8 && str_eq(mname, alias) {
            return modinfo.import_module_at(mod, i as usize)
        }
        i++
    }
    return 0 as ref modinfo.ResolvedModule
}

/// Returns true if `mod`'s items contain a `pub val name = use(...)` (i.e., a re-exported module alias).
fn module_has_use_alias(mod: ref modinfo.ResolvedModule, name: ref u8) bool! = {
    if mod == 0 as ref modinfo.ResolvedModule { return false }
    if name == 0 as ref u8 { return false }
    val items: list[ref parser.Node] = modinfo.module_items(mod)
    for item in items {
        if item.kind == parser.NK_USE {
            val alias: ref u8 = item.d1 as ref u8
            if alias != 0 as ref u8 && str_eq(alias, name) {
                return true
            }
        }
    }
    return false
}

/// Reject dotted type names like `std.math.numerics.Mat4x4` where the first
/// two dotted segments form a module-to-module access. Only `module.Type` is
/// allowed.
fn check_no_module_to_module_type(ctx: ref SemaCtx, ty_node: ref parser.Node, line: i64, filename: ref u8) void! = {
    if ty_node == 0 as ref parser.Node { return }
    val k: i64 = ty_node.kind
    if k == parser.TY_REF || k == parser.TY_OPTION || k == parser.TY_LIST || k == parser.TY_MUT || k == parser.TY_SLICE {
        check_no_module_to_module_type(ctx, ty_node.d0 as ref parser.Node, line, filename)
        return
    }
    if k == parser.TY_RESULT {
        check_no_module_to_module_type(ctx, ty_node.d0 as ref parser.Node, line, filename)
        check_no_module_to_module_type(ctx, ty_node.d1 as ref parser.Node, line, filename)
        return
    }
    if k != parser.TY_NAMED { return }
    val name: ref u8 = ty_node.d0 as ref u8
    if name == 0 as ref u8 { return }
    val nlen: i64 = std.string.len_raw(name)
    val first_dot: mut i64 = -1
    val second_dot: mut i64 = -1
    val si: mut i64 = 0
    for {
        if si >= nlen { break }
        val c: u8 = @load8(@ptradd(name as ref void, si))
        if c == 46 {
            if first_dot < 0 { first_dot = si }
            elif second_dot < 0 { second_dot = si break }
        }
        si++
    }
    if first_dot < 0 || second_dot < 0 { return }
    val first_seg: ref u8 = @alloc(first_dot + 1) as ref u8
    @memcpy(first_seg as ref void, name as ref void, first_dot as usize)
    @store8(@ptradd(first_seg as ref void, first_dot), 0)
    val second_len: i64 = second_dot - first_dot - 1
    val second_seg: ref u8 = @alloc(second_len + 1) as ref u8
    @memcpy(second_seg as ref void, @ptradd(name as ref void, first_dot + 1), second_len as usize)
    @store8(@ptradd(second_seg as ref void, second_len), 0)
    val rmod: ref modinfo.ResolvedModule = ctx.root_mod
    val imported: ref modinfo.ResolvedModule = find_imported_module(rmod, first_seg)
    if imported == 0 as ref modinfo.ResolvedModule { return }
    if module_has_use_alias(imported, second_seg) {
        val ebuf: ref u8 = @alloc(512) as ref u8
        @snprintf(ebuf, 512, "{s}:{lld}: chained module access '{s}.{s}' is not allowed in type '{s}'; import '{s}' directly with `use(...)` instead", {filename, line, first_seg, second_seg, name, second_seg})
        add_error(ctx, ebuf)
    }
}

/// Reject expressions of the form `module.module(.something...)` where both
/// `module` and the inner field are top-level `use(...)` aliases. Only direct
/// `module.member` access is allowed.
fn check_no_module_to_module_field(ctx: ref SemaCtx, expr: ref parser.Node, line: i64, filename: ref u8) void! = {
    if expr == 0 as ref parser.Node { return }
    if expr.kind != parser.NK_FIELD { return }
    val base: ref parser.Node = parser.field_base(expr)
    val field: ref u8 = parser.field_name(expr)
    if base == 0 as ref parser.Node || field == 0 as ref u8 { return }
    if base.kind != parser.NK_IDENT { return }
    val root_name: ref u8 = base.d0 as ref u8
    if root_name == 0 as ref u8 { return }
    val rmod: ref modinfo.ResolvedModule = ctx.root_mod
    val imported: ref modinfo.ResolvedModule = find_imported_module(rmod, root_name)
    if imported == 0 as ref modinfo.ResolvedModule { return }
    if module_has_use_alias(imported, field) {
        val ebuf: ref u8 = @alloc(512) as ref u8
        @snprintf(ebuf, 512, "{s}:{lld}: chained module access '{s}.{s}' is not allowed; import '{s}' directly with `use(...)` instead", {filename, line, root_name, field, field})
        add_error(ctx, ebuf)
    }
}

fn unwrap_generic_callee(callee: ref parser.Node) ref parser.Node! = {
    val cur: mut ref parser.Node = callee
    for {
        if cur == 0 as ref parser.Node { return 0 as ref parser.Node }
        if cur.kind == parser.NK_GENERIC_INST {
            cur = parser.generic_inst_base(cur)
            continue
        }
        return cur
    }
    return 0 as ref parser.Node
}

fn callee_has_explicit_type_args(callee: ref parser.Node) bool! = {
    val cur: mut ref parser.Node = callee
    for {
        if cur == 0 as ref parser.Node { return false }
        if cur.kind != parser.NK_GENERIC_INST { return false }
        if @len(parser.generic_inst_type_args(cur)) > 0 { return true }
        cur = parser.generic_inst_base(cur)
    }
    return false
}

/// Returns mutable flag (0 or 1) or -1 if not found.
fn scope_lookup(ctx: ref SemaCtx, name: ref u8) i64! = {
    guarded pre {
        ctx_not_null  : ctx != 0 as ref SemaCtx
        name_not_null : name != 0 as ref u8
    }

    val len: i64 = @len(ctx.scopes) as i64
    val i: mut i64 = len - 1
    for {
        if i < 0 { break }
        val frame_opt = @get(ctx.scopes, i as usize)
        match frame_opt {
            some frame => {
                val flen: i64 = @len(frame as ref void) as i64
                val j: mut i64 = flen - 1
                for {
                    if j < 0 { break }
                    val e_opt = @get(frame as ref void, j as usize)
                    match e_opt {
                        some e => {
                            val entry: ref ScopeEntry = e as ref ScopeEntry
                            if std.string.rchar_cmp(entry.name, name) == 0 {
                                return entry.mutable
                            }
                        }
                        none => {}
                    }
                    j--
                }
            }
            none => {}
        }
        i--
    }
    return -1
}

/// Returns the type name of a variable from scope, or null if not found.
fn scope_lookup_type(ctx: ref SemaCtx, name: ref u8) ref u8! = {
    guarded pre {
        ctx_not_null  : ctx != 0 as ref SemaCtx
        name_not_null : name != 0 as ref u8
    }

    val len: i64 = @len(ctx.scopes) as i64
    val i: mut i64 = len - 1
    for {
        if i < 0 { break }
        val frame_opt = @get(ctx.scopes, i as usize)
        match frame_opt {
            some frame => {
                val flen: i64 = @len(frame as ref void) as i64
                val j: mut i64 = flen - 1
                for {
                    if j < 0 { break }
                    val e_opt = @get(frame as ref void, j as usize)
                    match e_opt {
                        some e => {
                            val entry: ref ScopeEntry = e as ref ScopeEntry
                            if std.string.rchar_cmp(entry.name, name) == 0 {
                                return entry.type_name
                            }
                        }
                        none => {}
                    }
                    j--
                }
            }
            none => {}
        }
        i--
    }
    return 0 as ref u8
}

/// Returns 1 if the variable was declared with a top-level ref type, 0 otherwise.
fn scope_lookup_is_ref(ctx: ref SemaCtx, name: ref u8) i64! = {
    guarded pre {
        ctx_not_null  : ctx != 0 as ref SemaCtx
        name_not_null : name != 0 as ref u8
    }

    val len: i64 = @len(ctx.scopes) as i64
    val i: mut i64 = len - 1
    for {
        if i < 0 { break }
        val frame_opt = @get(ctx.scopes, i as usize)
        match frame_opt {
            some frame => {
                val flen: i64 = @len(frame as ref void) as i64
                val j: mut i64 = flen - 1
                for {
                    if j < 0 { break }
                    val e_opt = @get(frame as ref void, j as usize)
                    match e_opt {
                        some e => {
                            val entry: ref ScopeEntry = e as ref ScopeEntry
                            if std.string.rchar_cmp(entry.name, name) == 0 {
                                return entry.is_ref
                            }
                        }
                        none => {}
                    }
                    j--
                }
            }
            none => {}
        }
        i--
    }
    return 0
}


fn mark_name_used(ctx: ref SemaCtx, name: ref u8) void! = {
    if name == 0 as ref u8 { return }
    val len: i64 = @len(ctx.scopes) as i64
    val i: mut i64 = len - 1
    for {
        if i < 0 { break }
        val frame_opt = @get(ctx.scopes, i as usize)
        match frame_opt {
            some frame => {
                val flen: i64 = @len(frame as ref void) as i64
                val j: mut i64 = flen - 1
                for {
                    if j < 0 { break }
                    val e_opt = @get(frame as ref void, j as usize)
                    match e_opt {
                        some e => {
                            val entry: mut ref ScopeEntry = e as ref ScopeEntry
                            if std.string.rchar_cmp(entry.name, name) == 0 {
                                entry.used = 1
                                return
                            }
                        }
                        none => {}
                    }
                    j--
                }
            }
            none => {}
        }
        i--
    }
}

fn mark_name_mutated(ctx: ref SemaCtx, name: ref u8) void! = {
    if name == 0 as ref u8 { return }
    val len: i64 = @len(ctx.scopes) as i64
    val i: mut i64 = len - 1
    for {
        if i < 0 { break }
        val frame_opt = @get(ctx.scopes, i as usize)
        match frame_opt {
            some frame => {
                val flen: i64 = @len(frame as ref void) as i64
                val j: mut i64 = flen - 1
                for {
                    if j < 0 { break }
                    val e_opt = @get(frame as ref void, j as usize)
                    match e_opt {
                        some e => {
                            val entry: mut ref ScopeEntry = e as ref ScopeEntry
                            if std.string.rchar_cmp(entry.name, name) == 0 {
                                entry.mutated = 1
                                entry.used = 1
                                return
                            }
                        }
                        none => {}
                    }
                    j--
                }
            }
            none => {}
        }
        i--
    }
}

/// Checks if a field named field_name is mutable in the typedef named type_name.
/// Returns 1 if mutable, 0 if immutable, -1 if not found.
fn find_field_mutable(ctx: ref SemaCtx, type_name: ref u8, field_name: ref u8) i64! = {
    val tlen: i64 = @len(ctx.type_defs) as i64
    val ti: mut i64 = 0
    for {
        if ti >= tlen { break }
        val td_opt = @get(ctx.type_defs, ti as usize)
        match td_opt {
            some td => {
                val td_node: ref parser.Node = td as ref parser.Node
                val td_name: ref u8 = td_node.d1 as ref u8
                if std.string.rchar_cmp(td_name, type_name) == 0 {
                    val fields: ref void = td_node.d2 as ref void
                    if fields != 0 as ref void {
                        val flen: i64 = @len(fields) as i64
                        val fi: mut i64 = 0
                        for {
                            if fi >= flen { break }
                            val f_opt = @get(fields, fi as usize)
                            match f_opt {
                                some f => {
                                    val fnode: ref parser.Node = f as ref parser.Node
                                    val fname: ref u8 = fnode.d0 as ref u8
                                    if std.string.rchar_cmp(fname, field_name) == 0 {
                                        return fnode.d1
                                    }
                                }
                                none => {}
                            }
                            fi++
                        }
                    }
                    return -1
                }
            }
            none => {}
        }
        ti++
    }
    return -1
}

/// Extracts the innermost named type string from a type node (strips ref/mut wrappers).
fn extract_type_name(ty_node: ref parser.Node) ref u8! = {
    val cur: mut ref parser.Node = ty_node
    for {
        if cur == 0 as ref parser.Node { return 0 as ref u8 }
        if cur.kind == parser.TY_NAMED { return cur.d0 as ref u8 }
        if cur.kind == parser.TY_MUT || cur.kind == parser.TY_REF {
            cur = cur.d0 as ref parser.Node
        } else {
            return 0 as ref u8
        }
    }
    return 0 as ref u8
}

fn unwrap_mut_type(ty_node: ref parser.Node) ref parser.Node! = {
    val cur: mut ref parser.Node = ty_node
    for {
        if cur == 0 as ref parser.Node { return 0 as ref parser.Node }
        if cur.kind == parser.TY_MUT {
            cur = cur.d0 as ref parser.Node
            continue
        }
        return cur
    }
    return 0 as ref parser.Node
}

fn scope_defined_local(ctx: ref SemaCtx, name: ref u8) bool! = {
    val len: usize = @len(ctx.scopes)
    if len == 0 { return false }
    val frame_opt = @get(ctx.scopes, len - 1)
    match frame_opt {
        some frame => {
            val flen: i64 = @len(frame as ref void) as i64
            val j: mut i64 = 0
            for {
                if j >= flen { break }
                val e_opt = @get(frame as ref void, j as usize)
                match e_opt {
                    some e => {
                        val entry: ref ScopeEntry = e as ref ScopeEntry
                        if std.string.rchar_cmp(entry.name, name) == 0 { return true }
                    }
                    none => {}
                }
                j++
            }
        }
        none => {}
    }
    return false
}

/// Check if a type name is a type parameter.
fn is_type_parameter(ctx: ref SemaCtx, tname: ref u8) bool! = {
    if tname == 0 as ref u8 { return false }

    for tp in ctx.type_params {
        if str_eq(tp as ref u8, tname) {
            return true
        }
    }

    return false
}

fn str_eq(a: ref u8, b: ref u8) bool! = {
    return std.string.rchar_cmp(a, b) == 0
}

/// Extract the unqualified type name from a potentially qualified name.
fn unqualified_type_name(tname: ref u8) ref u8! = {
    if tname == 0 as ref u8 { return tname }
    val last_dot: mut i64 = -1
    val i: mut i64 = 0
    for {
        val c: u8 = @load8(@ptradd(tname as ref void, i))
        if c == 0 { break }
        if c == 46 { last_dot = i }
        i++
    }
    if last_dot >= 0 {
        return @ptradd(tname, last_dot + 1) as ref u8
    }
    return tname
}

/// Check if two type names are compatible, considering:
///
/// - Qualified vs unqualified names (lexer.TokenKind == TokenKind)
/// - Safe numeric conversions (i32 -> i64, u8 -> i64, etc.)
fn types_compatible(param_type: ref u8, arg_type: ref u8) bool! = {
    if str_eq(param_type, arg_type) { return true }

    val param_unqual: ref u8 = unqualified_type_name(param_type)
    val arg_unqual: ref u8 = unqualified_type_name(arg_type)

    if str_eq(param_unqual, arg_unqual) { return true }

    if str_eq(param_unqual, "i64") {
        if str_eq(arg_unqual, "i8") || str_eq(arg_unqual, "i16") || str_eq(arg_unqual, "i32") ||
           str_eq(arg_unqual, "u8") || str_eq(arg_unqual, "u16") || str_eq(arg_unqual, "u32") ||
           str_eq(arg_unqual, "usize") || str_eq(arg_unqual, "isize") || str_eq(arg_unqual, "bool") {
            return true
        }
    }

    if str_eq(param_unqual, "i32") {
        if str_eq(arg_unqual, "i8") || str_eq(arg_unqual, "i16") ||
           str_eq(arg_unqual, "u8") || str_eq(arg_unqual, "u16") || str_eq(arg_unqual, "bool") {
            return true
        }
    }

    if str_eq(param_unqual, "i16") {
        if str_eq(arg_unqual, "i8") || str_eq(arg_unqual, "u8") || str_eq(arg_unqual, "bool") {
            return true
        }
    }

    if str_eq(param_unqual, "u64") {
        if str_eq(arg_unqual, "u8") || str_eq(arg_unqual, "u16") || str_eq(arg_unqual, "u32") ||
           str_eq(arg_unqual, "usize") || str_eq(arg_unqual, "bool") {
            return true
        }
    }

    if str_eq(param_unqual, "u32") {
        if str_eq(arg_unqual, "u8") || str_eq(arg_unqual, "u16") || str_eq(arg_unqual, "bool") {
            return true
        }
    }

    if str_eq(param_unqual, "u16") {
        if str_eq(arg_unqual, "u8") || str_eq(arg_unqual, "bool") {
            return true
        }
    }

    if str_eq(param_unqual, "f64") {
        if str_eq(arg_unqual, "f32") {
            return true
        }
    }

    if str_eq(param_unqual, "usize") {
        if str_eq(arg_unqual, "u8") || str_eq(arg_unqual, "u16") || str_eq(arg_unqual, "u32") ||
           str_eq(arg_unqual, "u64") || str_eq(arg_unqual, "bool") {
            return true
        }
    }

    if str_eq(param_unqual, "isize") {
        if str_eq(arg_unqual, "i8") || str_eq(arg_unqual, "i16") || str_eq(arg_unqual, "i32") ||
           str_eq(arg_unqual, "i64") || str_eq(arg_unqual, "u8") || str_eq(arg_unqual, "u16") ||
           str_eq(arg_unqual, "u32") || str_eq(arg_unqual, "bool") {
            return true
        }
    }

    return false
}

/// Returns true if `name` is referenced as an identifier anywhere in `stmts`.
fn stmts_use_name(stmts: ref void, name: ref u8) bool! = {
    if stmts == 0 as ref void { return false }
    for s in stmts as list[ref parser.Node] {
        if expr_uses_name(s, name) { return true }
    }
    return false
}

fn expr_uses_name(node: ref parser.Node, name: ref u8) bool! = {
    if node == 0 as ref parser.Node { return false }
    val k: i64 = node.kind
    if k == parser.NK_IDENT {
        return str_eq(node.d0 as ref u8, name)
    }
    if k == parser.NK_BINOP {
        return expr_uses_name(parser.binop_left(node), name) ||
               expr_uses_name(parser.binop_right(node), name)
    }
    if k == parser.NK_ASSIGN || k == parser.NK_ADD_ASSIGN || k == parser.NK_SUB_ASSIGN {
        return expr_uses_name(node.d0 as ref parser.Node, name) ||
               expr_uses_name(node.d1 as ref parser.Node, name)
    }
    if k == parser.NK_UNOP {
        return expr_uses_name(parser.unop_inner(node), name)
    }
    if k == parser.NK_TRUST || k == parser.NK_SOME ||
       k == parser.NK_OK_VAL || k == parser.NK_ERR_VAL || k == parser.NK_TRY ||
       k == parser.NK_ADDR || k == parser.NK_DEREF || k == parser.NK_CAST ||
       k == parser.NK_RETURN || k == parser.NK_EXPR_STMT || k == parser.NK_ASSERT {
        return expr_uses_name(node.d0 as ref parser.Node, name)
    }
    if k == parser.NK_FIELD {
        return expr_uses_name(parser.field_base(node), name)
    }
    if k == parser.NK_CALL {
        if expr_uses_name(parser.call_callee(node), name) { return true }
        val cargs: ref void = parser.call_args(node) as ref void
        if cargs != 0 as ref void {
            for carg in cargs as list[ref parser.Node] {
                if expr_uses_name(carg, name) { return true }
            }
        }
        return false
    }
    if k == parser.NK_BUILTIN {
        val bargs: ref void = node.d1 as ref void
        if bargs != 0 as ref void {
            for barg in bargs as list[ref parser.Node] {
                if expr_uses_name(barg, name) { return true }
            }
        }
        return false
    }
    if k == parser.NK_VAL {
        return expr_uses_name(node.d3 as ref parser.Node, name)
    }
    if k == parser.NK_GUARD {
        if expr_uses_name(node.d0 as ref parser.Node, name) { return true }
        return stmts_use_name(node.d1 as ref void, name)
    }
    if k == parser.NK_IF {
        if expr_uses_name(node.d0 as ref parser.Node, name) { return true }
        if stmts_use_name(node.d1 as ref void, name) { return true }
        val elif_list2: ref void = node.d2 as ref void
        if elif_list2 != 0 as ref void {
            for ep in elif_list2 as list[ref parser.Node] {
                if expr_uses_name(ep.d0 as ref parser.Node, name) { return true }
                if stmts_use_name(ep.d1 as ref void, name) { return true }
            }
        }
        val else_node: ref parser.Node = node.d3 as ref parser.Node
        if else_node != 0 as ref parser.Node {
            return stmts_use_name(else_node.d0 as ref void, name)
        }
        return false
    }
    if k == parser.NK_FOR {
        if expr_uses_name(node.d1 as ref parser.Node, name) { return true }
        if expr_uses_name(node.d2 as ref parser.Node, name) { return true }
        return stmts_use_name(node.d4 as ref void, name)
    }
    if k == parser.NK_FORIN {
        if expr_uses_name(node.d1 as ref parser.Node, name) { return true }
        return stmts_use_name(node.d2 as ref void, name)
    }
    if k == parser.NK_LIST_LIT || k == parser.NK_ARGS_PACK || k == parser.NK_STRUCT_LIT {
        val elist: ref void = node.d0 as ref void
        if elist != 0 as ref void {
            for e in elist as list[ref parser.Node] {
                if expr_uses_name(e, name) { return true }
            }
        }
        return false
    }
    return false
}

/// Returns true if the format string contains any C-style format specifier (bare %).
fn has_c_style_specifier(s: ref u8) bool! = {
    val i: mut i64 = 0
    for {
        val c: u8 = @load8(@ptradd(s as ref void, i))
        if c == 0 { break }
        if c == 37 { return true } // any '%' is C-style
        i++
    }
    return false
}

/// Extracts the list of specifier strings from a Spectre format string.
/// E.g. "hello {d} {s}" -> ["d", "s"]
fn parse_fmt_specifiers(s: ref u8) list[ref u8]! = {
    val result: mut list[ref u8] = []
    val i: mut i64 = 0
    for {
        val c: u8 = @load8(@ptradd(s as ref void, i))
        if c == 0 { break }
        if c == 92 { // '\\'
            val next: u8 = @load8(@ptradd(s as ref void, i + 1))
            if next != 0 { i += 2 } else { i++ }
        } elif c == 123 { // '{'
            val j: mut i64 = i + 1
            val found: mut bool = false
            for {
                val jc: u8 = @load8(@ptradd(s as ref void, j))
                if jc == 0 { break }
                if jc == 125 { found = true break } // '}'
                j++
            }
            if found {
                val spec_len: i64 = j - i - 1
                if spec_len > 0 {
                    val spec: ref u8 = @alloc(spec_len + 1) as ref u8
                    val si: mut i64 = 0
                    for {
                        if si >= spec_len { break }
                        val sc: u8 = @load8(@ptradd(s as ref void, i + 1 + si))
                        @store8(@ptradd(spec as ref void, si), sc)
                        si++
                    }
                    @store8(@ptradd(spec as ref void, spec_len), 0)
                    @append(result, spec)
                }
                i = j + 1
            } else {
                i++
            }
        } else {
            i++
        }
    }
    return result
}

/// Maps a format specifier string to its expected argument category.
/// Returns "int", "str", "u8", "float", "ptr", or "unknown".
fn fmt_specifier_category(spec: ref u8) ref u8! = {
    if str_eq(spec, "s")   { return "str"   }
    if str_eq(spec, "c")   { return "u8"  }
    if str_eq(spec, "f")   { return "float" }
    if str_eq(spec, "lf")  { return "float" }
    if str_eq(spec, "g")   { return "float" }
    if str_eq(spec, "e")   { return "float" }
    if str_eq(spec, "d")   { return "int"   }
    if str_eq(spec, "i")   { return "int"   }
    if str_eq(spec, "u")   { return "int"   }
    if str_eq(spec, "x")   { return "int"   }
    if str_eq(spec, "X")   { return "int"   }
    if str_eq(spec, "o")   { return "int"   }
    if str_eq(spec, "ld")  { return "int"   }
    if str_eq(spec, "li")  { return "int"   }
    if str_eq(spec, "lu")  { return "int"   }
    if str_eq(spec, "lld") { return "int"   }
    if str_eq(spec, "lli") { return "int"   }
    if str_eq(spec, "llu") { return "int"   }
    if str_eq(spec, "lx")  { return "int"   }
    if str_eq(spec, "llx") { return "int"   }
    if str_eq(spec, "p")   { return "ptr"   }
    return "unknown"
}

fn sema_ty_is_ref(ty: ref parser.Node) i64! = {
    if ty == 0 as ref parser.Node { return 0 }
    if ty.kind == parser.TY_REF { return 1 }
    if ty.kind == parser.TY_MUT {
        val inner: ref parser.Node = ty.d0 as ref parser.Node
        if inner != 0 as ref parser.Node && inner.kind == parser.TY_REF { return 1 }
    }
    return 0
}

fn infer_expr_scope_type_name(ctx: ref SemaCtx, node: ref parser.Node) ref u8! = {
    if node == 0 as ref parser.Node { return "" }
    val k: i64 = node.kind
    if k == parser.NK_INT_LIT  { return "i64" }
    if k == parser.NK_FLOAT_LIT { return "f64" }
    if k == parser.NK_BOOL     { return "bool" }
    if k == parser.NK_CHAR_LIT { return "u8" }
    if k == parser.NK_STR_LIT  { return "u8" }
    if k == parser.NK_IDENT {
        val tname: ref u8 = scope_lookup_type(ctx, node.d0 as ref u8)
        if tname != 0 as ref u8 { return tname }
        return ""
    }
    if k == parser.NK_TRUST {
        return infer_expr_scope_type_name(ctx, node.d0 as ref parser.Node)
    }
    if k == parser.NK_UNOP {
        return infer_expr_scope_type_name(ctx, parser.unop_inner(node))
    }
    if k == parser.NK_CAST {
        return extract_type_name(node.d1 as ref parser.Node)
    }
    return ""
}

fn infer_expr_scope_is_ref(ctx: ref SemaCtx, node: ref parser.Node) i64! = {
    if node == 0 as ref parser.Node { return 0 }
    val k: i64 = node.kind
    if k == parser.NK_STR_LIT { return 1 }
    if k == parser.NK_IDENT { return scope_lookup_is_ref(ctx, node.d0 as ref u8) }
    if k == parser.NK_TRUST { return infer_expr_scope_is_ref(ctx, node.d0 as ref parser.Node) }
    if k == parser.NK_UNOP { return infer_expr_scope_is_ref(ctx, parser.unop_inner(node)) }
    if k == parser.NK_CAST { return sema_ty_is_ref(node.d1 as ref parser.Node) }
    return 0
}

/// Infers a broad type category for an expression node.
/// Returns "int", "str", "u8", "float", "ptr", or "unknown".
fn get_expr_type_category(ctx: ref SemaCtx, node: ref parser.Node) ref u8! = {
    if node == 0 as ref parser.Node { return "unknown" }
    val k: i64 = node.kind
    if k == parser.NK_INT_LIT   { return "int"   }
    if k == parser.NK_FLOAT_LIT { return "float" }
    if k == parser.NK_STR_LIT   { return "str"   }
    if k == parser.NK_CHAR_LIT  { return "u8"  }
    if k == parser.NK_BOOL      { return "int"   }
    if k == parser.NK_IDENT {
        val vname: ref u8 = node.d0 as ref u8
        val tname: ref u8 = scope_lookup_type(ctx, vname)
        val iref: i64 = scope_lookup_is_ref(ctx, vname)
        if tname == 0 as ref u8 { return "unknown" }
        if iref == 1 {
            if str_eq(tname, "u8") { return "str" }
            return "ptr"
        }
        if str_eq(tname, "u8")  { return "u8"  }
        if str_eq(tname, "i8")    { return "int"   }
        if str_eq(tname, "i16")   { return "int"   }
        if str_eq(tname, "i32")   { return "int"   }
        if str_eq(tname, "i64")   { return "int"   }
        if str_eq(tname, "u8")    { return "int"   }
        if str_eq(tname, "u16")   { return "int"   }
        if str_eq(tname, "u32")   { return "int"   }
        if str_eq(tname, "u64")   { return "int"   }
        if str_eq(tname, "usize") { return "int"   }
        if str_eq(tname, "isize") { return "int"   }
        if str_eq(tname, "i")     { return "int"   }
        if str_eq(tname, "u")     { return "int"   }
        if str_eq(tname, "bool")  { return "int"   }
        if str_eq(tname, "f32")   { return "float" }
        if str_eq(tname, "f64")   { return "float" }
        if str_eq(tname, "f")     { return "float" }
        return "unknown"
    }
    return "unknown"
}

/// Validates a printf/dprintf format string against its argument pack.
/// Reports errors for C-style specifiers, count mismatches, and type mismatches.
/// Validate a printf-family format string.
/// all_args: the full argument list (ref void to list[ref Node]), args_start_idx: where format args begin.
/// Handles both pack-style ({args...}) and individual-arg style (a, b, c).
fn check_printf_fmt(ctx: ref SemaCtx, fmt_str: ref u8, all_args: ref void,
                    args_start_idx: i64, filename: ref u8, line: i64) void! = {
    if has_c_style_specifier(fmt_str) {
        if !std.string.rchar_ends_with(filename, "codegen.sx") {
            val buf: ref u8 = @alloc(256) as ref u8
            @snprintf(buf, 256, "{s}:{lld}: C-style format specifiers are not allowed; use \{d\}, \{s\} etc.",
                {filename, line})
            add_error(ctx, buf)
            return
        }
    }

    val specs: list[ref u8] = parse_fmt_specifiers(fmt_str)
    val spec_count: i64 = @len(specs) as i64

    // Determine arg count and whether we have pack-style or individual-style args.
    val total_args: mut i64 = 0
    val pack_style: mut bool = false
    val pack_inner: mut ref void = 0 as ref void
    if all_args != 0 as ref void {
        val alen: i64 = @len(all_args) as i64
        if alen > args_start_idx {
            val first_opt = @get(all_args, args_start_idx as usize)
            match first_opt {
                some first_raw => {
                    val first_node: ref parser.Node = first_raw as ref parser.Node
                    if first_node.kind == parser.NK_ARGS_PACK {
                        pack_style = true
                        val inner: ref void = first_node.d0 as ref void
                        if inner != 0 as ref void {
                            pack_inner = inner
                            total_args = @len(inner) as i64
                        }
                    } else {
                        total_args = alen - args_start_idx
                    }
                }
                none => {}
            }
        }
    }

    if spec_count != total_args {
        val buf: ref u8 = @alloc(256) as ref u8
        @snprintf(buf, 256, "{s}:{lld}: format string has {lld} specifier(s) but {lld} argument(s) provided",
            {filename, line, spec_count, total_args})
        add_error(ctx, buf)
        return
    }

    val idx: mut i64 = 0
    for {
        if idx >= spec_count { break }
        val spec_opt = @get(specs, idx as usize)
        match spec_opt {
            some spec_raw => {
                val spec: ref u8 = spec_raw as ref u8
                val exp_cat: ref u8 = fmt_specifier_category(spec)
                if !str_eq(exp_cat, "unknown") {
                    val arg_node: mut ref parser.Node = 0 as ref parser.Node
                    if pack_style && pack_inner != 0 as ref void {
                        val arg_opt = @get(pack_inner, idx as usize)
                        match arg_opt {
                            some arg_raw => { arg_node = arg_raw as ref parser.Node }
                            none => {}
                        }
                    } elif !pack_style && all_args != 0 as ref void {
                        val real_idx: i64 = args_start_idx + idx
                        val arg_opt = @get(all_args, real_idx as usize)
                        match arg_opt {
                            some arg_raw => { arg_node = arg_raw as ref parser.Node }
                            none => {}
                        }
                    }
                    if arg_node != 0 as ref parser.Node {
                        val act_cat: ref u8 = get_expr_type_category(ctx, arg_node)
                        if !str_eq(act_cat, "unknown") {
                            val its_ok: mut bool = str_eq(exp_cat, act_cat)
                            if str_eq(exp_cat, "u8") && str_eq(act_cat, "int") { its_ok = true }
                            if str_eq(exp_cat, "ptr")  && str_eq(act_cat, "str") { its_ok = true }
                            if !its_ok {
                                val buf2: ref u8 = @alloc(512) as ref u8
                                @snprintf(buf2, 512,
                                    "{s}:{lld}: format specifier \{{s}\} expects {s} argument but got {s}",
                                    {filename, line, spec, exp_cat, act_cat})
                                add_error(ctx, buf2)
                            }
                        }
                    }
                }
            }
            none => {}
        }
        idx++
    }
}

fn find_import_module(ctx: ref SemaCtx, name: ref u8) ref modinfo.ResolvedModule! = {
    if ctx.root_mod == 0 as ref modinfo.ResolvedModule { return 0 as ref modinfo.ResolvedModule }
    return modinfo.find_import_by_name(ctx.root_mod, name)
}

fn generic_targ_type_compatible(expected: ref u8, actual: ref u8, arg_node: ref parser.Node) bool! = {
    if str_eq(expected, actual) { return true }
    if arg_node.kind == parser.NK_INT_LIT {
        if str_eq(expected, "i8")  || str_eq(expected, "i16") || str_eq(expected, "i32") ||
           str_eq(expected, "i64") || str_eq(expected, "u8")  || str_eq(expected, "u16") ||
           str_eq(expected, "u32") || str_eq(expected, "u64") || str_eq(expected, "usize") ||
           str_eq(expected, "isize") || str_eq(expected, "bool") { return true }
    }
    if arg_node.kind == parser.NK_FLOAT_LIT {
        if str_eq(expected, "f32") || str_eq(expected, "f64") { return true }
    }
    return false
}

fn check_generic_call_arg_types(ctx: ref SemaCtx, fn_found: ref parser.Node, callee: ref parser.Node,
                                 cargs: ref void, filename: ref u8, line: i64) void! = {
    if fn_found == 0 as ref parser.Node || fn_found.kind != parser.NK_GENERIC_FN { return }
    if callee == 0 as ref parser.Node || callee.kind != parser.NK_GENERIC_INST { return }
    if cargs == 0 as ref void { return }
    val tparams: ref void = fn_found.d6 as ref void
    val fn_params: ref void = fn_found.d3 as ref void
    if tparams == 0 as ref void || fn_params == 0 as ref void { return }
    val gi_targs: list[ref parser.Node] = parser.generic_inst_type_args(callee)
    val ntparams: i64 = @len(tparams as list[ref u8]) as i64
    val ntargs: i64 = @len(gi_targs) as i64
    if ntparams == 0 || ntargs == 0 { return }
    val nfnparams: i64 = @len(fn_params as list[ref parser.Node]) as i64
    val nargs: i64 = @len(cargs as list[ref parser.Node]) as i64
    val min_len: mut i64 = nfnparams
    if nargs < nfnparams { min_len = nargs }
    val pi: mut i64 = 0
    for {
        if pi >= min_len { break }
        val param_opt = @get(fn_params as list[ref parser.Node], pi as usize)
        val arg_opt = @get(cargs as list[ref parser.Node], pi as usize)
        match param_opt {
            some param_raw => {
                match arg_opt {
                    some arg_raw => {
                        val param_node: ref parser.Node = param_raw as ref parser.Node
                        val arg_node: ref parser.Node = arg_raw as ref parser.Node
                        val pty: ref parser.Node = param_node.d1 as ref parser.Node
                        val inner_pty: ref parser.Node = unwrap_mut_type(pty)
                        if inner_pty != 0 as ref parser.Node && inner_pty.kind == parser.TY_NAMED {
                            val tparam_name: ref u8 = inner_pty.d0 as ref u8
                            val ti: mut i64 = 0
                            for {
                                if ti >= ntparams { break }
                                val tp_opt = @get(tparams as list[ref u8], ti as usize)
                                match tp_opt {
                                    some tp => {
                                        if str_eq(tp as ref u8, tparam_name) && ti < ntargs {
                                            val ta_opt = @get(gi_targs, ti as usize)
                                            match ta_opt {
                                                some ta => {
                                                    val type_arg_node: ref parser.Node = ta as ref parser.Node
                                                    val expected_tname: ref u8 = extract_type_name(type_arg_node)
                                                    val arg_tname: ref u8 = infer_expr_scope_type_name(ctx, arg_node)
                                                    val expected_is_tparam: mut bool = false
                                                    val ck: mut i64 = 0
                                                    for {
                                                        if ck >= ntparams { break }
                                                        val ck_opt = @get(tparams as list[ref u8], ck as usize)
                                                        match ck_opt {
                                                            some ckn => { if str_eq(ckn as ref u8, expected_tname) { expected_is_tparam = true } }
                                                            none => {}
                                                        }
                                                        ck++
                                                    }
                                                    if expected_tname != 0 as ref u8 && !str_eq(expected_tname, "") &&
                                                       !expected_is_tparam &&
                                                       arg_tname != 0 as ref u8 && !str_eq(arg_tname, "") &&
                                                       !generic_targ_type_compatible(expected_tname, arg_tname, arg_node) {
                                                        val ebuf: ref u8 = @alloc(512) as ref u8
                                                        @snprintf(ebuf, 512, "{s}:{lld}: type mismatch in generic call: argument has type '{s}' but type parameter '{s}' is '{s}'",
                                                            {filename, line, arg_tname, tparam_name, expected_tname})
                                                        add_error(ctx, ebuf)
                                                    }
                                                }
                                                none => {}
                                            }
                                            break
                                        }
                                    }
                                    none => {}
                                }
                                ti++
                            }
                        }
                    }
                    none => {}
                }
            }
            none => {}
        }
        pi++
    }
}

fn check_expr(ctx: mut ref SemaCtx, expr: ref parser.Node, filename: ref u8) void! = {
    if expr == 0 as ref parser.Node { return }

    val k: i64 = expr.kind
    val line: i64 = expr.line

    if k == parser.NK_INT_LIT || k == parser.NK_FLOAT_LIT || k == parser.NK_STR_LIT ||
       k == parser.NK_BOOL    || k == parser.NK_NONE       || k == parser.NK_CHAR_LIT {
        return
    }

    if k == parser.NK_GENERIC_INST {
        check_expr(ctx, expr.d0 as ref parser.Node, filename)
        return
    }

    if k == parser.NK_IDENT {
        val name: ref u8 = expr.d0 as ref u8
        val has_dot: mut bool = false
        val i: mut i64 = 0
        for {
            val c: u8 = @load8(@ptradd(name, i))
            if c == 0 { break }
            if c == 46 { has_dot = true break }
            i++
        }
        if !has_dot {
            val lkup = scope_lookup(ctx, name)
            if lkup == -1 {
                val is_known: mut bool = false
                for fn_name in ctx.fn_names {
                    if str_eq(fn_name, name) { is_known = true @append(ctx.used_fns, name) break }
                }
                if !is_known {
                    for ty_name in ctx.type_names {
                        if str_eq(ty_name, name) { is_known = true break }
                    }
                }
                if !is_known {
                    for gname in ctx.global_names {
                        if str_eq(gname, name) { is_known = true break }
                    }
                }
                if !is_known {
                    val buf: ref u8 = @alloc(256) as ref u8
                    @snprintf(buf, 256, "{s}:{lld}: undefined variable '{s}'", {filename, line, name})
                    add_error(ctx, buf)
                }
            } else {
                mark_name_used(ctx, name)
            }
        }
        return
    }

    if k == parser.NK_BINOP {
        check_expr(ctx, parser.binop_left(expr), filename)
        check_expr(ctx, parser.binop_right(expr), filename)
        return
    }
    if k == parser.NK_UNOP {
        check_expr(ctx, parser.unop_inner(expr), filename)
        return
    }
    if k == parser.NK_TRUST {
        if ctx.in_unsafe_fn != 0 || ctx.in_trust != 0 {
            val buf: ref u8 = @alloc(512) as ref u8
            if ctx.in_unsafe_fn != 0 {
                @snprintf(buf, 512, "{s}:{lld}: redundant 'trust' statement; already in an unsafe context (marked with '!')", {filename, line})
            } else {
                @snprintf(buf, 512, "{s}:{lld}: redundant 'trust' statement; already inside a 'trust' block", {filename, line})
            }
            add_error(ctx, buf)
        }
        val pt_used: i64 = ctx.trust_used
        ctx.trust_used = 0
        val prev_trust: i64 = ctx.in_trust
        ctx.in_trust = 1
        check_expr(ctx, expr.d0 as ref parser.Node, filename)
        ctx.in_trust = prev_trust
        if ctx.trust_used == 0 && ctx.in_unsafe_fn == 0 && ctx.in_trust == 0 {
            val buf: ref u8 = @alloc(512) as ref u8
            @snprintf(buf, 512, "{s}:{lld}: redundant 'trust' statement; the expression is already pure", {filename, line})
            add_error(ctx, buf)
        }
        ctx.trust_used = pt_used | ctx.trust_used
        return
    }
    if k == parser.NK_SOME ||
       k == parser.NK_OK_VAL || k == parser.NK_ERR_VAL || k == parser.NK_TRY {
        check_expr(ctx, expr.d0 as ref parser.Node, filename)
        return
    }
    if k == parser.NK_FIELD {
        if is_c_escape_expr(expr) { return }
        check_no_module_to_module_field(ctx, expr, line, filename)
        check_expr(ctx, parser.field_base(expr), filename)
        return
    }
    if k == parser.NK_CALL {
        val callee: ref parser.Node = parser.call_callee(expr)
        val base_callee: ref parser.Node = unwrap_generic_callee(callee)
        val has_explicit_targs: bool = callee_has_explicit_type_args(callee)
        check_expr(ctx, callee, filename)
        val cargs: ref void = parser.call_args(expr) as ref void
        if cargs != 0 as ref void {
            for carg in cargs as list[ref parser.Node] {
                check_expr(ctx, carg, filename)
            }
        }
        if base_callee != 0 as ref parser.Node {
            if base_callee.kind == parser.NK_IDENT {
                val fname2: ref u8 = base_callee.d0 as ref u8
                @append(ctx.used_fns, fname2)
            } elif base_callee.kind == parser.NK_FIELD {
                val fname: ref u8 = parser.field_name(base_callee)
                if fname != 0 as ref u8 {
                    @append(ctx.used_fns, fname)
                    val fbase: ref parser.Node = parser.field_base(base_callee)
                    if fbase != 0 as ref parser.Node {
                        if fbase.kind == parser.NK_IDENT {
                            val base_name: ref u8 = fbase.d0 as ref u8
                            if base_name != 0 as ref u8 {
                                val qbuf: ref u8 = @alloc(256) as ref u8
                                @snprintf(qbuf, 256, "{s}.{s}", {base_name, fname})
                                @append(ctx.used_fns, qbuf)
                            }
                        }
                    }
                }
            }
        }

        val fn_found: mut ref parser.Node = 0 as ref parser.Node
        if base_callee != 0 as ref parser.Node {
            val target_name: mut ref u8 = 0 as ref u8
            val target_ns: mut ref u8 = 0 as ref u8
            if base_callee.kind == parser.NK_IDENT {
                target_name = base_callee.d0 as ref u8
            } elif base_callee.kind == parser.NK_FIELD {
                target_name = parser.field_name(base_callee)
                val fbase: ref parser.Node = parser.field_base(base_callee)
                if fbase != 0 as ref parser.Node {
                    if fbase.kind == parser.NK_IDENT {
                        target_ns = fbase.d0 as ref u8
                    } elif fbase.kind == parser.NK_FIELD {
                        target_ns = parser.field_name(fbase)
                    }
                }
            }
            if target_name != 0 as ref u8 {
                val flen: i64 = @len(ctx.fn_defs) as i64
                val fi: mut i64 = 0
                for {
                    if fi >= flen { break }
                    val f_opt = @get(ctx.fn_defs, fi as usize)
                    match f_opt {
                        some f => {
                            val fnode: ref parser.Node = f as ref parser.Node
                            val fname_node1: ref u8 = fnode.d1 as ref u8
                            val fname_node2: ref u8 = fnode.d2 as ref u8
                            val is_match: mut bool = false
                            if target_ns != 0 as ref u8 {
                                if fname_node1 != 0 as ref u8 && fname_node2 != 0 as ref u8 {
                                    if std.string.rchar_cmp(fname_node1, target_ns) == 0 &&
                                       std.string.rchar_cmp(fname_node2, target_name) == 0 {
                                        is_match = true
                                    }
                                }
                            } else {
                                if fname_node1 != 0 as ref u8 {
                                    if std.string.rchar_cmp(fname_node1, target_name) == 0 { is_match = true }
                                }
                                if fname_node2 != 0 as ref u8 {
                                    if std.string.rchar_cmp(fname_node2, target_name) == 0 { is_match = true }
                                }
                            }
                            if is_match {
                                fn_found = fnode
                                break
                            }
                        }
                        none => {}
                    }
                    fi++
                }
            }
        }

        if fn_found == 0 as ref parser.Node && base_callee != 0 as ref parser.Node && base_callee.kind == parser.NK_FIELD {
            val fname: ref u8 = parser.field_name(base_callee)
            val fbase: ref parser.Node = parser.field_base(base_callee)
            if fbase != 0 as ref parser.Node && fbase.kind == parser.NK_IDENT {
                val modname: ref u8 = fbase.d0 as ref u8
                val rmod: ref modinfo.ResolvedModule = ctx.root_mod
                if rmod != 0 as ref modinfo.ResolvedModule {
                    val n: i64 = modinfo.import_count(rmod)
                    val i: mut i64 = 0
                    for {
                        if i >= n { break }
                        val mname: ref u8 = modinfo.import_name_at(rmod, i as usize)
                        if mname != 0 as ref u8 && str_eq(mname, modname) {
                            val mm: ref modinfo.ResolvedModule = modinfo.import_module_at(rmod, i as usize)
                            fn_found = sema_find_fn_in_module(mm, fname)
                            break
                        }
                        i++
                    }
                }
            }
        }

        if fn_found != 0 as ref parser.Node {
            if fn_found.kind == parser.NK_GENERIC_FN && !has_explicit_targs {
                val fn_name: mut ref u8 = 0 as ref u8
                if base_callee != 0 as ref parser.Node {
                    if base_callee.kind == parser.NK_IDENT { fn_name = base_callee.d0 as ref u8 }
                    elif base_callee.kind == parser.NK_FIELD { fn_name = parser.field_name(base_callee) }
                }
                val gbuf: ref u8 = @alloc(512) as ref u8
                if fn_name != 0 as ref u8 {
                    @snprintf(gbuf, 512, "{s}:{lld}: generic function '{s}' requires explicit type specifiers, call it as '{s}[Type](...)'", {filename, line, fn_name, fn_name})
                } else {
                    @snprintf(gbuf, 512, "{s}:{lld}: generic function calls require explicit type specifiers", {filename, line})
                }
                add_error(ctx, gbuf)
            }
            if parser.fn_is_unsafe(fn_found) {
                if ctx.in_unsafe_fn == 0 && ctx.in_trust == 0 {
                    val fn_name: mut ref u8 = 0 as ref u8
                    if base_callee != 0 as ref parser.Node {
                        if base_callee.kind == parser.NK_IDENT { fn_name = base_callee.d0 as ref u8 }
                        elif base_callee.kind == parser.NK_FIELD { fn_name = parser.field_name(base_callee) }
                    }
                    val ebuf: ref u8 = @alloc(512) as ref u8
                    if fn_name != 0 as ref u8 {
                        @snprintf(ebuf, 512, "{s}:{lld}: cannot call unsafe function '{s}' from safe context, use 'trust' block or mark current function as unsafe with '!'", {filename, line, fn_name})
                    } else {
                        @snprintf(ebuf, 512, "{s}:{lld}: cannot call unsafe function from safe context, use 'trust' block or mark current function as unsafe with '!'", {filename, line})
                    }
                    add_error(ctx, ebuf)
                } else {
                    ctx.trust_used = 1
                }
            }

            val params: mut ref void = fn_found.d3 as ref void
            if fn_found.kind == parser.NK_EXTERN_FN { params = fn_found.d4 as ref void }
            if params != 0 as ref void && fn_found.kind != parser.NK_EXTERN_FN {
                val arg_len: mut i64 = 0
                if cargs != 0 as ref void { arg_len = @len(cargs) as i64 }
                val param_len: i64 = @len(params) as i64
                if arg_len != param_len {
                    val fn_name: mut ref u8 = 0 as ref u8
                    if base_callee != 0 as ref parser.Node {
                        if base_callee.kind == parser.NK_IDENT { fn_name = base_callee.d0 as ref u8 }
                        elif base_callee.kind == parser.NK_FIELD { fn_name = parser.field_name(base_callee) }
                    }
                    val arity_buf: ref u8 = @alloc(512) as ref u8
                    if fn_name != 0 as ref u8 {
                        @snprintf(arity_buf, 512, "{s}:{lld}: function '{s}' expects {lld} argument(s) but got {lld}", {filename, line, fn_name, param_len, arg_len})
                    } else {
                        @snprintf(arity_buf, 512, "{s}:{lld}: function expects {lld} argument(s) but got {lld}", {filename, line, param_len, arg_len})
                    }
                    add_error(ctx, arity_buf)
                }
            }
            if params != 0 as ref void && cargs != 0 as ref void {
                val arg_len2: i64 = @len(cargs) as i64
                val param_len2: i64 = @len(params) as i64
                val min_len: mut i64 = param_len2
                if arg_len2 < param_len2 { min_len = arg_len2 }
                val idx: mut i64 = 0
                for {
                    if idx >= min_len { break }
                    val arg_opt = @get(cargs, idx as usize)
                    val param_opt = @get(params, idx as usize)
                    match arg_opt {
                        some arg_raw => {
                            val arg_node: ref parser.Node = arg_raw as ref parser.Node
                            match param_opt {
                                some param_raw => {
                                    val param_node: ref parser.Node = param_raw as ref parser.Node
                                    val pty: ref parser.Node = param_node.d1 as ref parser.Node
                                    val param_is_ref: mut bool = false
                                    if pty.kind == parser.TY_REF { param_is_ref = true }
                                    elif pty.kind == parser.TY_LIST { param_is_ref = true }
                                    elif pty.kind == parser.TY_MUT {
                                        val pty_inner: ref parser.Node = pty.d0 as ref parser.Node
                                        if pty_inner != 0 as ref parser.Node && pty_inner.kind == parser.TY_REF { param_is_ref = true }
                                        elif pty_inner != 0 as ref parser.Node && pty_inner.kind == parser.TY_LIST { param_is_ref = true }
                                        elif pty_inner != 0 as ref parser.Node && pty_inner.kind == parser.TY_NAMED { param_is_ref = true }
                                    }
                                    if param_is_ref {
                                        val root_node: ref parser.Node = unwrap_and_find_root(arg_node)
                                        if root_node != 0 as ref parser.Node {
                                            mark_name_mutated(ctx, root_node.d0 as ref u8)
                                        }
                                    }

                                    val param_type_name: ref u8 = extract_type_name(pty)
                                    val arg_type_name: ref u8 = infer_expr_scope_type_name(ctx, arg_node)
                                    val arg_is_ref: i64 = infer_expr_scope_is_ref(ctx, arg_node)

                                    if param_type_name != 0 as ref u8 && !str_eq(param_type_name, "") {
                                        val skip_type_check: mut bool = false

                                        if is_type_parameter(ctx, param_type_name) || is_type_parameter(ctx, arg_type_name) {
                                            skip_type_check = true
                                        }

                                        if !skip_type_check && fn_found != 0 as ref parser.Node && fn_found.kind == parser.NK_GENERIC_FN {
                                            val fn_type_params: ref void = fn_found.d6 as ref void
                                            if fn_type_params != 0 as ref void {
                                                for ftp in fn_type_params as list[ref u8] {
                                                    if str_eq(ftp as ref u8, param_type_name) || str_eq(ftp as ref u8, arg_type_name) {
                                                        skip_type_check = true
                                                        break
                                                    }
                                                }
                                            }
                                        }

                                        if skip_type_check {
                                            if param_is_ref {
                                                val root_node: ref parser.Node = unwrap_and_find_root(arg_node)
                                                if root_node != 0 as ref parser.Node {
                                                    mark_name_mutated(ctx, root_node.d0 as ref u8)
                                                }
                                            }
                                        } else {
                                            val type_mismatch: mut bool = false
                                            val param_expects_ref: bool = pty.kind == parser.TY_REF || (pty.kind == parser.TY_MUT && pty.d0 != 0 as ref parser.Node && (pty.d0 as ref parser.Node).kind == parser.TY_REF)

                                            if param_expects_ref && str_eq(param_type_name, "u8") {
                                                if arg_node.kind == parser.NK_INT_LIT || arg_node.kind == parser.NK_FLOAT_LIT || arg_node.kind == parser.NK_BOOL {
                                                    type_mismatch = true
                                                } elif arg_node.kind == parser.NK_IDENT && arg_is_ref == 0 {
                                                    if arg_type_name != 0 as ref u8 && !str_eq(arg_type_name, "") {
                                                        if !str_eq(arg_type_name, "u8") && !str_eq(arg_type_name, param_type_name) {
                                                            type_mismatch = true
                                                        }
                                                    }
                                                }
                                            } elif !param_expects_ref && arg_type_name != 0 as ref u8 && !str_eq(arg_type_name, "") {
                                                if !types_compatible(param_type_name, arg_type_name) {
                                                    val union_def: ref parser.Node = sema_lookup_uniondef(ctx, param_type_name)
                                                    if union_def != 0 as ref parser.Node {
                                                        if !type_matches_union_variant(union_def, arg_type_name) {
                                                            type_mismatch = true
                                                        }
                                                    } else {
                                                        type_mismatch = true
                                                    }
                                                }
                                            }

                                            if type_mismatch {
                                                val fn_name_for_err: mut ref u8 = 0 as ref u8
                                                if base_callee != 0 as ref parser.Node {
                                                    if base_callee.kind == parser.NK_IDENT { fn_name_for_err = base_callee.d0 as ref u8 }
                                                    elif base_callee.kind == parser.NK_FIELD { fn_name_for_err = parser.field_name(base_callee) }
                                                }
                                                val type_err_buf: ref u8 = @alloc(512) as ref u8
                                                val param_name: ref u8 = param_node.d0 as ref u8
                                                val param_type_str: mut ref u8 = param_type_name
                                                if param_expects_ref {
                                                    val ref_buf: ref u8 = @alloc(128) as ref u8
                                                    @snprintf(ref_buf, 128, "ref {s}", {param_type_name})
                                                    param_type_str = ref_buf
                                                }
                                                val arg_type_str: mut ref u8 = arg_type_name
                                                if arg_is_ref == 1 && arg_type_name != 0 as ref u8 {
                                                    val arg_ref_buf: ref u8 = @alloc(128) as ref u8
                                                    @snprintf(arg_ref_buf, 128, "ref {s}", {arg_type_name})
                                                    arg_type_str = arg_ref_buf
                                                }
                                                if fn_name_for_err != 0 as ref u8 {
                                                    @snprintf(type_err_buf, 512, "{s}:{lld}: type mismatch in call to '{s}': parameter '{s}' expects type '{s}' but got '{s}'",
                                                        {filename, line, fn_name_for_err, param_name, param_type_str, arg_type_str})
                                                } else {
                                                    @snprintf(type_err_buf, 512, "{s}:{lld}: type mismatch: parameter '{s}' expects type '{s}' but got '{s}'",
                                                        {filename, line, param_name, param_type_str, arg_type_str})
                                                }
                                                add_error(ctx, type_err_buf)
                                            }
                                        }
                                    }
                                }
                                none => {}
                            }
                        }
                        none => {}
                    }
                    idx++
                }
            }
        }

        if fn_found != 0 as ref parser.Node && has_explicit_targs {
            check_generic_call_arg_types(ctx, fn_found, callee, cargs, filename, line)
        }

        if fn_found == 0 as ref parser.Node && cargs != 0 as ref void {
            if base_callee != 0 as ref parser.Node && base_callee.kind == parser.NK_IDENT {
                val callee_name: ref u8 = base_callee.d0 as ref u8
                val union_name_buf: mut ref u8 = 0 as ref u8
                val variant_node: ref parser.Node = sema_lookup_tagged_variant(ctx, callee_name, @addr(union_name_buf) as ref void)
                
                if variant_node != 0 as ref parser.Node {
                    val expected_types: ref void = variant_node.d1 as ref void
                    val expected_count: mut i64 = 0
                    if expected_types != 0 as ref void { 
                        expected_count = @len(expected_types as list[ref parser.Node]) as i64 
                    } 

                    val arg_count: i64 = @len(cargs) as i64
                    
                    if arg_count != expected_count {
                        val arity_buf: ref u8 = @alloc(512) as ref u8
                        @snprintf(arity_buf, 512, "{s}:{lld}: variant constructor '{s}' expects {lld} argument(s) but got {lld}",
                            {filename, line, callee_name, expected_count, arg_count})
                        add_error(ctx, arity_buf)
                    } else {
                        val idx: mut i64 = 0
                        for {
                            if idx >= expected_count { break }
                            val arg_opt = @get(cargs, idx as usize)
                            val expected_ty_opt = @get(expected_types as list[ref parser.Node], idx as usize)
                            
                            match arg_opt {
                                some arg_raw => {
                                    val arg_node: ref parser.Node = arg_raw as ref parser.Node
                                    match expected_ty_opt {
                                        some expected_ty_raw => {
                                            val expected_ty: ref parser.Node = expected_ty_raw as ref parser.Node
                                            val expected_type_name: ref u8 = extract_type_name(expected_ty)
                                            val arg_type_name: ref u8 = infer_expr_scope_type_name(ctx, arg_node)
                                            
                                            if expected_type_name != 0 as ref u8 && !str_eq(expected_type_name, "") &&
                                               arg_type_name != 0 as ref u8 && !str_eq(arg_type_name, "") {
                                                if !types_compatible(expected_type_name, arg_type_name) {
                                                    val type_err_buf: ref u8 = @alloc(512) as ref u8
                                                    @snprintf(type_err_buf, 512, "{s}:{lld}: type mismatch in variant constructor '{s}': argument {lld} expects type '{s}' but got '{s}'",
                                                        {filename, line, callee_name, idx + 1, expected_type_name, arg_type_name})
                                                    add_error(ctx, type_err_buf)
                                                }
                                            }
                                        }
                                        none => {}
                                    }
                                }
                                none => {}
                            }
                            idx++
                        }
                    }
                } else {
                    for carg in cargs as list[ref parser.Node] {
                        val root_carg: ref parser.Node = unwrap_and_find_root(carg)
                        if root_carg != 0 as ref parser.Node {
                            val aname: ref u8 = root_carg.d0 as ref u8
                            if aname != 0 as ref u8 {
                                if scope_lookup_is_ref(ctx, aname) == 1 {
                                    if scope_lookup(ctx, aname) == 1 {
                                        mark_name_mutated(ctx, aname)
                                    }
                                }
                            }
                        }
                    }
                }
            } else {
                for carg in cargs as list[ref parser.Node] {
                    val root_carg: ref parser.Node = unwrap_and_find_root(carg)
                    if root_carg != 0 as ref parser.Node {
                        val aname: ref u8 = root_carg.d0 as ref u8
                        if aname != 0 as ref u8 {
                            if scope_lookup_is_ref(ctx, aname) == 1 {
                                if scope_lookup(ctx, aname) == 1 {
                                    mark_name_mutated(ctx, aname)
                                }
                            }
                        }
                    }
                }
            }
        }

        if base_callee != 0 as ref parser.Node && base_callee.kind == parser.NK_FIELD {
            val fname: ref u8 = parser.field_name(base_callee)
            val is_print_call: bool = str_eq(fname, "print") || str_eq(fname, "eprint")
            if is_print_call && cargs != 0 as ref void && @len(cargs) > 0 {
                val fmt_opt = @get(cargs, 0)
                match fmt_opt {
                    some fmt_raw => {
                        val fmt_node: ref parser.Node = fmt_raw as ref parser.Node
                        if fmt_node.kind == parser.NK_STR_LIT {
                            val fmt_str: ref u8 = parser.str_lit_text(fmt_node)
                            check_printf_fmt(ctx, fmt_str, cargs, 1, filename, line)
                        }
                    }
                    none => {}
                }
            }
        }
        if base_callee != 0 as ref parser.Node {
            if base_callee.kind == parser.NK_FIELD {
                val vis_base: ref parser.Node = parser.field_base(base_callee)
                if vis_base != 0 as ref parser.Node {
                    if vis_base.kind == parser.NK_IDENT {
                        val vis_mod_name: ref u8 = vis_base.d0 as ref u8
                        val vis_fn_name: ref u8 = parser.field_name(base_callee)
                        if vis_mod_name != 0 as ref u8 {
                            if vis_fn_name != 0 as ref u8 {
                                val import_mod: ref modinfo.ResolvedModule = find_import_module(ctx, vis_mod_name)
                                if import_mod != 0 as ref modinfo.ResolvedModule {
                                    if !modinfo.fn_is_public_in_module(import_mod, vis_fn_name) {
                                        val buf: ref u8 = @alloc(256) as ref u8
                                        @snprintf(buf, 256, "{s}:{lld}: '{s}' is not public in module '{s}'",
                                            {filename, line, vis_fn_name, vis_mod_name})
                                        add_error(ctx, buf)
                                    }
                                    if modinfo.fn_is_unsafe_in_module(import_mod, vis_fn_name) && ctx.in_unsafe_fn == 0 && ctx.in_trust == 0 {
                                        val ubuf: ref u8 = @alloc(256) as ref u8
                                        @snprintf(ubuf, 256, "{s}:{lld}: cannot call unsafe function '{s}' from module '{s}' in safe context, use 'trust' block or mark current function as unsafe with '!'",
                                            {filename, line, vis_fn_name, vis_mod_name})
                                        add_error(ctx, ubuf)
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        return
    }
    if k == parser.NK_BUILTIN {
        val bname: ref u8 = expr.d0 as ref u8
        val bargs: ref void = expr.d1 as ref void
        if bargs != 0 as ref void {
            for barg in bargs as list[ref parser.Node] {
                check_expr(ctx, barg, filename)
            }
        }

        if !is_known_builtin(bname) {
            val ebuf: ref u8 = @alloc(512) as ref u8
            @snprintf(ebuf, 512, "{s}:{lld}: unknown intrinsic '@{s}'", {filename, line, bname})
            add_error(ctx, ebuf)
            return
        }

        val is_unsafe_builtin: bool = str_eq(bname, "store8") || str_eq(bname, "store") || str_eq(bname, "load8") || str_eq(bname, "load") || str_eq(bname, "ptradd") || str_eq(bname, "dprintf") || str_eq(bname, "print") || str_eq(bname, "fmt") || str_eq(bname, "memset") || str_eq(bname, "memcpy") || str_eq(bname, "memmove") || str_eq(bname, "free") || str_eq(bname, "realloc") || str_eq(bname, "addr") || str_eq(bname, "deref")
        if is_unsafe_builtin {
            if ctx.in_unsafe_fn == 0 && ctx.in_trust == 0 {
                val ebuf: ref u8 = @alloc(512) as ref u8
                @snprintf(ebuf, 512, "{s}:{lld}: unsafe builtin '@{s}' can only be used in functions marked with '!' or inside 'trust' blocks", {filename, line, bname})
                add_error(ctx, ebuf)
            } else {
                ctx.trust_used = 1
            }
        }

        val is_printf:   bool = str_eq(bname, "print")
        val is_dprintf:  bool = str_eq(bname, "dprintf")
        val is_snprintf: bool = str_eq(bname, "snprintf")
        if is_printf || is_dprintf || is_snprintf {
            val fmt_idx: mut i64 = 0
            val args_start: mut i64 = 1
            if is_dprintf  { fmt_idx = 1 args_start = 2 }
            if is_snprintf { fmt_idx = 2 args_start = 3 }
            if bargs != 0 as ref void {
                val blen: i64 = @len(bargs) as i64
                if blen > fmt_idx {
                    val fmt_opt = @get(bargs, fmt_idx as usize)
                    match fmt_opt {
                        some fmt_raw => {
                            val fmt_node: ref parser.Node = fmt_raw as ref parser.Node
                            if fmt_node.kind == parser.NK_STR_LIT {
                                val fmt_str: ref u8 = parser.str_lit_text(fmt_node)
                                check_printf_fmt(ctx, fmt_str, bargs, args_start, filename, line)
                            }
                        }
                        none => {}
                    }
                }
            }
        }
        if str_eq(bname, "memcpy") || str_eq(bname, "store8") || str_eq(bname, "memset") || str_eq(bname, "addr") || str_eq(bname, "memmove") || str_eq(bname, "realloc") || str_eq(bname, "free") || str_eq(bname, "store") || str_eq(bname, "append") || str_eq(bname, "remove") || str_eq(bname, "reserve") {
            if bargs != 0 as ref void {
                val btarget_opt = @get(bargs as list[ref parser.Node], 0)
                match btarget_opt {
                    some btarget => {
                        val root_node: ref parser.Node = unwrap_and_find_root(btarget)
                        if root_node != 0 as ref parser.Node {
                            val vname: ref u8 = root_node.d0 as ref u8
                            val is_mut: i64 = scope_lookup(ctx, vname)
                            val is_ref: i64 = scope_lookup_is_ref(ctx, vname)
                            if is_mut != -1 && is_mut == 0 && is_ref == 0 {
                                val ebuf: ref u8 = @alloc(512) as ref u8
                                @snprintf(ebuf, 512, "{s}:{lld}: cannot pass immutable value '{s}' to mutating builtin '@{s}'", {filename, line, vname, bname})
                                add_error(ctx, ebuf)
                            }
                            mark_name_mutated(ctx, vname)
                        }
                    }
                    none => {}
                }
            }
        }

        if str_eq(bname, "sizeof") {
            if bargs != 0 as ref void {
                for barg in bargs as list[ref parser.Node] {
                    if barg.kind == parser.NK_IDENT {
                        mark_name_used(ctx, barg.d0 as ref u8)
                    } elif barg.kind == parser.NK_FIELD {
                        val root_node2: ref parser.Node = find_root_ident(barg)
                        if root_node2 != 0 as ref parser.Node {
                            mark_name_used(ctx, root_node2.d0 as ref u8)
                        }
                    } elif barg.kind == parser.TY_NAMED {
                        val tname2: ref u8 = barg.d0 as ref u8
                        if tname2 != 0 as ref u8 {
                            val lkup2: i64 = scope_lookup(ctx, tname2)
                            if lkup2 != -1 { mark_name_used(ctx, tname2) }
                        }
                    }
                }
            }
        }
        return
    }
    if k == parser.NK_CAST || k == parser.NK_DEREF {
        check_expr(ctx, expr.d0 as ref parser.Node, filename)
        return
    }
    if k == parser.NK_ADDR {
        val inner: ref parser.Node = expr.d0 as ref parser.Node
        check_expr(ctx, inner, filename)
        if inner != 0 as ref parser.Node {
            if inner.kind == parser.NK_IDENT {
                val vname: ref u8 = inner.d0 as ref u8
                val is_mut: i64 = scope_lookup(ctx, vname)
                val is_ref: i64 = scope_lookup_is_ref(ctx, vname)
                if is_mut != -1 && is_mut == 0 && is_ref == 0 {
                    val ebuf: ref u8 = @alloc(512) as ref u8
                    @snprintf(ebuf, 512, "{s}:{lld}: cannot take address of immutable variable '{s}'; declare it as 'mut'", {filename, line, vname})
                    add_error(ctx, ebuf)
                }
                mark_name_mutated(ctx, vname)
            } elif inner.kind == parser.NK_FIELD {
                val root: ref parser.Node = find_root_ident(inner)
                if root != 0 as ref parser.Node {
                    mark_name_mutated(ctx, root.d0 as ref u8)
                }
            }
        }
        return
    }
    if k == parser.NK_STRUCT_LIT {
        val flist: ref void = expr.d0 as ref void
        if flist != 0 as ref void {
            for f in flist as list[ref parser.Node] {
                check_expr(ctx, f.d1 as ref parser.Node, filename)
            }
        }
        return
    }
    if k == parser.NK_LIST_LIT || k == parser.NK_ARGS_PACK {
        val elist: ref void = expr.d0 as ref void
        if elist != 0 as ref void {
            for e in elist as list[ref parser.Node] {
                check_expr(ctx, e, filename)
            }
        }
        return
    }
}


/// Look up a NK_TYPEDEF node by type name. Returns 0 if not found.
fn sema_lookup_typedef(ctx: ref SemaCtx, type_name: ref u8) ref parser.Node! = {
    if type_name == 0 as ref u8 { return 0 as ref parser.Node }
    val tlen: i64 = @len(ctx.type_defs) as i64
    val ti: mut i64 = 0
    for {
        if ti >= tlen { break }
        val td_opt = @get(ctx.type_defs, ti as usize)
        match td_opt {
            some td => {
                val tdnode: ref parser.Node = td as ref parser.Node
                val tdname: ref u8 = tdnode.d1 as ref u8
                if tdname != 0 as ref u8 {
                    if std.string.rchar_cmp(tdname, type_name) == 0 {
                        return tdnode
                    }
                }
            }
            none => {}
        }
        ti++
    }
    return 0 as ref parser.Node
}

/// Look up a NK_UNIONDEF node by type name. Returns 0 if not found.
fn sema_lookup_uniondef(ctx: ref SemaCtx, type_name: ref u8) ref parser.Node! = {
    if type_name == 0 as ref u8 { return 0 as ref parser.Node }
    val tlen: i64 = @len(ctx.type_defs) as i64
    val ti: mut i64 = 0
    for {
        if ti >= tlen { break }
        val td_opt = @get(ctx.type_defs, ti as usize)
        match td_opt {
            some td => {
                val tdnode: ref parser.Node = td as ref parser.Node
                if tdnode.kind == parser.NK_UNIONDEF {
                    val tdname: ref u8 = tdnode.d1 as ref u8
                    if tdname != 0 as ref u8 {
                        if std.string.rchar_cmp(tdname, type_name) == 0 {
                            return tdnode
                        }
                    }
                }
            }
            none => {}
        }
        ti++
    }
    return 0 as ref parser.Node
}

/// Look up a tagged union variant by name.
/// Returns the variant node (NK_VAL with d0=name, d1=list of type nodes) and sets out_union_name.
/// Returns 0 if not found.
fn sema_lookup_tagged_variant(ctx: ref SemaCtx, variant_name: ref u8, out_union_name: ref void) ref parser.Node! = {
    if variant_name == 0 as ref u8 { return 0 as ref parser.Node }
    val tlen: i64 = @len(ctx.type_defs) as i64
    val ti: mut i64 = 0
    for {
        if ti >= tlen { break }
        val td_opt = @get(ctx.type_defs, ti as usize)
        match td_opt {
            some td => {
                val tdnode: ref parser.Node = td as ref parser.Node
                if tdnode.kind == parser.NK_TAGGED_UNIONDEF {
                    val variants: ref void = tdnode.d2 as ref void
                    if variants != 0 as ref void {
                        for variant in variants as list[ref parser.Node] {
                            val vname: ref u8 = variant.d0 as ref u8
                            if vname != 0 as ref u8 && std.string.rchar_cmp(vname, variant_name) == 0 {
                                if out_union_name != 0 as ref void {
                                    val union_name: ref u8 = tdnode.d1 as ref u8
                                    @store(out_union_name, union_name as usize)
                                }
                                return variant
                            }
                        }
                    }
                }
            }
            none => {}
        }
        ti++
    }
    return 0 as ref parser.Node
}

/// Check if arg_type matches any variant in the union definition.
/// Returns true if arg_type is compatible with any union variant.
fn type_matches_union_variant(union_def: ref parser.Node, arg_type: ref u8) bool! = {
    if union_def == 0 as ref parser.Node || arg_type == 0 as ref u8 { return false }
    if union_def.kind != parser.NK_UNIONDEF { return false }
    
    val variants: ref void = union_def.d2 as ref void
    if variants == 0 as ref void { return false }
    
    for variant in variants as list[ref parser.Node] {
        val variant_type_name: ref u8 = extract_type_name(variant)
        if variant_type_name != 0 as ref u8 {
            if types_compatible(variant_type_name, arg_type) {
                return true
            }
        }
    }
    
    return false
}

/// Sentinel value for unknown / cannot evaluate at compile time.
val SEMA_UNKNOWN: i64 = -9223372036854775807

/// Constant-fold a simple comparison/boolean expression.
/// field_names and field_vals are parallel lists of (ref u8, i64).
/// Returns SEMA_UNKNOWN if the expression can't be fully evaluated.
fn sema_const_eval(expr: ref parser.Node, field_names: ref void, field_vals: ref void) i64! = {
    if expr == 0 as ref parser.Node { return SEMA_UNKNOWN }
    val k: i64 = expr.kind
    if k == parser.NK_INT_LIT {
        val s: ref u8 = expr.d0 as ref u8
        val parse_res = std.fmt.string_to_i64(s)
        val v: mut i64 = SEMA_UNKNOWN
        match parse_res {
            ok parsed => { v = parsed }
            err _     => {}
        }
        return v
    }
    if k == parser.NK_BOOL { return expr.d0 as i64 }
    if k == parser.NK_IDENT {
        val iname: ref u8 = expr.d0 as ref u8
        val flen: i64 = @len(field_names as list[ref u8]) as i64
        val fi: mut i64 = 0
        for {
            if fi >= flen { break }
            val fn_opt = @get(field_names as list[ref u8], fi as usize)
            match fn_opt {
                some func => {
                    if std.string.rchar_cmp(func as ref u8, iname) == 0 {
                        val fv_opt = @get(field_vals as list[i64], fi as usize)
                        match fv_opt {
                            some fv => { return fv as i64 }
                            none    => { return SEMA_UNKNOWN }
                        }
                    }
                }
                none => {}
            }
            fi++
        }
        return SEMA_UNKNOWN
    }
    if k == parser.NK_UNOP {
        val uop: i64 = expr.d0 as i64
        val inner: ref parser.Node = expr.d1 as ref parser.Node
        val iv: i64 = sema_const_eval(inner, field_names, field_vals)
        if iv == SEMA_UNKNOWN { return SEMA_UNKNOWN }
        if uop == parser.UOP_NEG { return -iv }
        if uop == parser.UOP_NOT { if iv == 0 { return 1 } else { return 0 } }
        return SEMA_UNKNOWN
    }
    if k == parser.NK_BINOP {
        val op: i64 = expr.d0 as i64
        val lv: i64 = sema_const_eval(expr.d1 as ref parser.Node, field_names, field_vals)
        val rv: i64 = sema_const_eval(expr.d2 as ref parser.Node, field_names, field_vals)
        if lv == SEMA_UNKNOWN || rv == SEMA_UNKNOWN { return SEMA_UNKNOWN }
        if op == parser.OP_GT  { if lv > rv  { return 1 } else { return 0 } }
        if op == parser.OP_GE  { if lv >= rv { return 1 } else { return 0 } }
        if op == parser.OP_LT  { if lv < rv  { return 1 } else { return 0 } }
        if op == parser.OP_LE  { if lv <= rv { return 1 } else { return 0 } }
        if op == parser.OP_EQ  { if lv == rv { return 1 } else { return 0 } }
        if op == parser.OP_NE  { if lv != rv { return 1 } else { return 0 } }
        if op == parser.OP_AND { if lv != 0 && rv != 0 { return 1 } else { return 0 } }
        if op == parser.OP_OR  { if lv != 0 || rv != 0 { return 1 } else { return 0 } }
        if op == parser.OP_ADD { return lv + rv }
        if op == parser.OP_SUB { return lv - rv }
        if op == parser.OP_MUL { return lv * rv }
        return SEMA_UNKNOWN
    }
    return SEMA_UNKNOWN
}

/// Check an invariant list against compile-time-known field values.
/// Adds an error if any invariant is statically violated.
fn sema_check_invariant_lit(ctx: ref SemaCtx, typedef_node: ref parser.Node,
                             args: ref void, filename: ref u8, line: i64) void! = {
    val inv_list: ref void = typedef_node.d3 as ref void
    if inv_list == 0 as ref void { return }
    val fields: ref void = typedef_node.d2 as ref void
    if fields == 0 as ref void { return }

    val fnames: mut list[ref u8] = []
    val fvals:  mut list[i64]      = []
    val flen: i64 = @len(fields as list[ref parser.Node]) as i64
    val alen: i64 = @len(args   as list[ref parser.Node]) as i64
    val fi: mut i64 = 0
    for {
        if fi >= flen || fi >= alen { break }
        val field_opt = @get(fields as list[ref parser.Node], fi as usize)
        val arg_opt   = @get(args   as list[ref parser.Node], fi as usize)
        match field_opt {
            some fld => {
                match arg_opt {
                    some arg => {
                        val fname: ref u8 = (fld as ref parser.Node).d0 as ref u8
                        val anode: ref parser.Node = arg as ref parser.Node
                        val aval: i64 = sema_const_eval(anode, fnames as ref void, fvals as ref void)
                        @append(fnames, fname)
                        @append(fvals,  aval)
                    }
                    none => {}
                }
            }
            none => {}
        }
        fi++
    }

    val ilen: i64 = @len(inv_list as list[ref parser.Node]) as i64
    val ii: mut i64 = 0
    for {
        if ii >= ilen { break }
        val inv_opt = @get(inv_list as list[ref parser.Node], ii as usize)
        match inv_opt {
            some inv => {
                val inode: ref parser.Node = inv as ref parser.Node
                val result: i64 = sema_const_eval(inode, fnames as ref void, fvals as ref void)
                if result != SEMA_UNKNOWN && result == 0 {
                    val type_name: ref u8 = typedef_node.d1 as ref u8
                    val buf: ref u8 = @alloc(256) as ref u8
                    @snprintf(buf, 256, "{s}:{lld}: invariant violated for type '{s}'", {filename, line, type_name})
                    add_error(ctx, buf)
                }
            }
            none => {}
        }
        ii++
    }
}

fn check_stmts(ctx: ref SemaCtx, stmts: ref void, filename: ref u8) void! = {
    if stmts == 0 as ref void { return }
    for s in stmts as list[ref parser.Node] {
        check_stmt(ctx, s, filename)
    }
}

fn check_stmt(ctx: ref SemaCtx, stmt: ref parser.Node, filename: ref u8) void! = {
    guarded pre {
        ctx_not_null      : ctx != 0 as ref SemaCtx
        stmt_not_null     : stmt != 0 as ref parser.Node
        filename_not_null : filename != 0 as ref u8
    }

    val k: i64 = stmt.kind
    val line: i64 = stmt.line

    if k == parser.NK_VAL {
        val name: ref u8 = stmt.d0 as ref u8
        val mutable: i64 = stmt.d1
        check_no_module_to_module_type(ctx, stmt.d2 as ref parser.Node, line, filename)
        check_expr(ctx, stmt.d3 as ref parser.Node, filename)
        if scope_defined_local(ctx, name) {
            val buf: ref u8 = @alloc(256) as ref u8
            @snprintf(buf, 256, "{s}:{lld}: '{s}' already declared in this scope", {filename, line, name})
            add_error(ctx, buf)
        } else {
            val ty_node: ref parser.Node = stmt.d2 as ref parser.Node
            val tname: ref u8 = extract_type_name(ty_node)
            val is_ref_flag: mut i64 = 0
            if ty_node != 0 as ref parser.Node {
                if ty_node.kind == parser.TY_REF {
                    is_ref_flag = 1
                } elif ty_node.kind == parser.TY_MUT {
                    val inner_ty: ref parser.Node = ty_node.d0 as ref parser.Node
                    if inner_ty != 0 as ref parser.Node && inner_ty.kind == parser.TY_REF {
                        is_ref_flag = 1
                    }
                }
            }
            val init_expr: ref parser.Node = stmt.d3 as ref parser.Node
            scope_define(ctx, name, mutable, tname, is_ref_flag, line)
            if tname != 0 as ref u8 && init_expr != 0 as ref parser.Node {
                val init_k: i64 = init_expr.kind
                val tdef: ref parser.Node = sema_lookup_typedef(ctx, tname)
                if init_k == parser.NK_ARGS_PACK && tdef != 0 as ref parser.Node {
                    val buf: ref u8 = @alloc(256) as ref u8
                    @snprintf(buf, 256, "{s}:{lld}: positional struct literal not allowed for type '{s}'; use named field syntax", {filename, line, tname})
                    add_error(ctx, buf)
                } elif init_k == parser.NK_STRUCT_LIT && tdef != 0 as ref parser.Node {
                    val typedef_fields: ref void = tdef.d2 as ref void
                    val lit_fields: ref void = init_expr.d0 as ref void
                    if typedef_fields != 0 as ref void && lit_fields != 0 as ref void {
                        val ordered_args: mut list[ref parser.Node] = []
                        val tflen: i64 = @len(typedef_fields as list[ref parser.Node]) as i64
                        val tfi: mut i64 = 0
                        for {
                            if tfi >= tflen { break }
                            val tf_opt = @get(typedef_fields as list[ref parser.Node], tfi as usize)
                            match tf_opt {
                                some tf => {
                                    val tfname: ref u8 = (tf as ref parser.Node).d0 as ref u8
                                    val lflen: i64 = @len(lit_fields as list[ref parser.Node]) as i64
                                    val lfi: mut i64 = 0
                                    val found: mut ref parser.Node = 0 as ref parser.Node
                                    for {
                                        if lfi >= lflen { break }
                                        val lf_opt = @get(lit_fields as list[ref parser.Node], lfi as usize)
                                        match lf_opt {
                                            some lf => {
                                                val lfname: ref u8 = (lf as ref parser.Node).d0 as ref u8
                                                if str_eq(lfname, tfname) {
                                                    found = (lf as ref parser.Node).d1 as ref parser.Node
                                                    lfi = lflen
                                                }
                                            }
                                            none => {}
                                        }
                                        lfi++
                                    }
                                    @append(ordered_args, found)
                                }
                                none => {}
                            }
                            tfi++
                        }
                        val ordered_args_list: list[ref parser.Node] = ordered_args
                        sema_check_invariant_lit(ctx, tdef, ordered_args_list as ref void, filename, line)
                    }
                }
            }
        }
        return
    }

    if k == parser.NK_ASSIGN {
        check_expr(ctx, stmt.d1 as ref parser.Node, filename)
        val target: ref parser.Node = stmt.d0 as ref parser.Node
        if target.kind == parser.NK_IDENT {
            val tname: ref u8 = target.d0 as ref u8
            mark_name_mutated(ctx, tname)
            if scope_lookup(ctx, tname) == 0 {
                val buf: ref u8 = @alloc(256) as ref u8
                @snprintf(buf, 256, "{s}:{lld}: cannot assign to immutable '{s}'", {filename, line, tname})
                add_error(ctx, buf)
            }
        } elif target.kind == parser.NK_FIELD {
            val root: ref parser.Node = find_root_ident(target)
            if root != 0 as ref parser.Node {
                val tname: ref u8 = root.d0 as ref u8
                mark_name_mutated(ctx, tname)
                val lkup: i64 = scope_lookup(ctx, tname)
                if lkup == 0 {
                    val buf: ref u8 = @alloc(256) as ref u8
                    @snprintf(buf, 256, "{s}:{lld}: cannot assign to field of immutable '{s}'", {filename, line, tname})
                    add_error(ctx, buf)
                } else {
                    val field_name: ref u8 = parser.field_name(target)
                    val var_type: ref u8 = scope_lookup_type(ctx, tname)
                    if var_type != 0 as ref u8 && field_name != 0 as ref u8 {
                        val fmut: i64 = find_field_mutable(ctx, var_type, field_name)
                        if fmut == 0 {
                            val buf2: ref u8 = @alloc(256) as ref u8
                            @snprintf(buf2, 256, "{s}:{lld}: cannot assign to immutable field '{s}' of type '{s}'", {filename, line, field_name, var_type})
                            add_error(ctx, buf2)
                        }
                    }
                }
            } else {
                check_expr(ctx, target, filename)
            }
        } elif target.kind == parser.NK_DEREF {
            val inner_deref: ref parser.Node = target.d0 as ref parser.Node
            if inner_deref != 0 as ref parser.Node && inner_deref.kind == parser.NK_IDENT {
                val dname: ref u8 = inner_deref.d0 as ref u8
                val dmut: i64 = scope_lookup(ctx, dname)
                if dmut != -1 && dmut == 0 {
                    val ebuf: ref u8 = @alloc(512) as ref u8
                    @snprintf(ebuf, 512, "{s}:{lld}: cannot assign through immutable reference '{s}'; parameter must be declared 'mut ref'", {filename, line, dname})
                    add_error(ctx, ebuf)
                }
                mark_name_mutated(ctx, dname)
            } else {
                check_expr(ctx, target, filename)
            }
        } else {
            check_expr(ctx, target, filename)
        }
        return
    }

    if k == parser.NK_RETURN {
        check_expr(ctx, stmt.d0 as ref parser.Node, filename)
        return
    }
    if k == parser.NK_EXPR_STMT {
        check_expr(ctx, stmt.d0 as ref parser.Node, filename)
        return
    }
    if k == parser.NK_ASSERT {
        check_expr(ctx, stmt.d0 as ref parser.Node, filename)
        return
    }

    if k == parser.NK_GUARD {
        check_expr(ctx, stmt.d0 as ref parser.Node, filename)
        val gbody: ref void = stmt.d1 as ref void
        push_scope(ctx)
        check_stmts(ctx, gbody, filename)
        pop_scope(ctx, filename, line)
        val gbody_len: mut i64 = 0
        if gbody != 0 as ref void { gbody_len = @len(gbody as list[ref parser.Node]) as i64 }
        val ends_with_return: mut bool = false
        if gbody_len > 0 {
            val last_opt = @get(gbody as list[ref parser.Node], (gbody_len - 1) as usize)
            match last_opt {
                some last => {
                    if ((last as ref parser.Node).kind == parser.NK_RETURN) { ends_with_return = true }
                }
                none => {}
            }
        }
        if !ends_with_return {
            val buf: ref u8 = @alloc(256) as ref u8
            @snprintf(buf, 256, "{s}:{lld}: guard else block must end with a return statement", {filename, line})
            add_error(ctx, buf)
        }
        return
    }

    if k == parser.NK_IF {
        check_expr(ctx, stmt.d0 as ref parser.Node, filename)
        push_scope(ctx)
        check_stmts(ctx, stmt.d1 as ref void, filename)
        pop_scope(ctx, filename, line)
        val elif_list: ref void = stmt.d2 as ref void
        if elif_list != 0 as ref void {
            for ep in elif_list as list[ref parser.Node] {
                check_expr(ctx, ep.d0 as ref parser.Node, filename)
                push_scope(ctx)
                check_stmts(ctx, ep.d1 as ref void, filename)
                pop_scope(ctx, filename, line)
            }
        }
        val else_body: ref void = stmt.d3 as ref void
        if else_body != 0 as ref void {
            push_scope(ctx)
            check_stmts(ctx, (stmt.d3 as ref parser.Node).d0 as ref void, filename)
            pop_scope(ctx, filename, line)
        }
        return
    }

    if k == parser.NK_FOR {
        push_scope(ctx)
        val init_name: ref u8 = stmt.d0 as ref u8
        if init_name != 0 as ref u8 {
            check_expr(ctx, stmt.d1 as ref parser.Node, filename)
            if scope_lookup(ctx, init_name) != -1 {
                val buf: ref u8 = @alloc(256) as ref u8
                @snprintf(buf, 256, "{s}:{lld}: for loop variable '{s}' shadows an existing variable; declare it only in the for loop",
                    {filename, line, init_name})
                add_error(ctx, buf)
            } else {
                scope_define(ctx, init_name, 1, 0 as ref u8, 0, line)
                mark_name_mutated(ctx, init_name)
            }
        }
        check_expr(ctx, stmt.d2 as ref parser.Node, filename)
        check_stmts(ctx, stmt.d4 as ref void, filename)
        pop_scope(ctx, filename, line)
        return
    }

    if k == parser.NK_FORIN {
        val binding: ref u8 = stmt.d0 as ref u8
        check_expr(ctx, stmt.d1 as ref parser.Node, filename)
        push_scope(ctx)
        scope_define(ctx, binding, 0, 0 as ref u8, 0, line)
        check_stmts(ctx, stmt.d2 as ref void, filename)
        pop_scope(ctx, filename, line)
        return
    }

    if k == parser.NK_DEFER {
        push_scope(ctx)
        check_stmts(ctx, stmt.d0 as ref void, filename)
        pop_scope(ctx, filename, line)
        return
    }

    if k == parser.NK_PRE || k == parser.NK_POST || k == parser.NK_GUARDED_PRE || k == parser.NK_GUARDED_POST {
        val clist: ref void = stmt.d0 as ref void
        if clist != 0 as ref void {
            for c in clist as list[ref parser.Node] {
                check_expr(ctx, c.d1 as ref parser.Node, filename)
            }
        }
        return
    }

    if k == parser.NK_MATCH_VALUE {
        val match_expr: ref parser.Node = stmt.d0 as ref parser.Node
        check_expr(ctx, match_expr, filename)
        val match_ty: ref u8 = infer_expr_scope_type_name(ctx, match_expr)
        val match_cat: ref u8 = get_expr_type_category(ctx, match_expr)
        val arms: ref void = stmt.d1 as ref void
        if arms != 0 as ref void {
            for arm in arms as list[ref parser.Node] {
                val pat: ref parser.Node = arm.d0 as ref parser.Node
                check_expr(ctx, pat, filename)
                val pat_ty: ref u8 = infer_expr_scope_type_name(ctx, pat)
                val pat_cat: ref u8 = get_expr_type_category(ctx, pat)
                val compatible: mut bool = true
                if str_eq(match_ty, "bool") && !str_eq(pat_ty, "") {
                    compatible = str_eq(pat_ty, "bool")
                } elif str_eq(match_cat, "float") && !str_eq(pat_cat, "unknown") {
                    compatible = str_eq(pat_cat, "float")
                } elif str_eq(match_cat, "int") && !str_eq(pat_cat, "unknown") {
                    compatible = str_eq(pat_cat, "int") && !str_eq(pat_ty, "u8")
                }
                if !compatible {
                    val buf: ref u8 = @alloc(256) as ref u8
                    @snprintf(buf, 256, "{s}:{lld}: match pattern is not compatible with the matched expression", {filename, line})
                    add_error(ctx, buf)
                }
                push_scope(ctx)
                check_stmts(ctx, arm.d1 as ref void, filename)
                pop_scope(ctx, filename, line)
            }
        }
        val else_node: ref parser.Node = stmt.d2 as ref parser.Node
        if else_node != 0 as ref parser.Node {
            push_scope(ctx)
            check_stmts(ctx, else_node.d0 as ref void, filename)
            pop_scope(ctx, filename, line)
        }
        return
    }

    if k == parser.NK_MATCH_OPT {
        check_expr(ctx, stmt.d0 as ref parser.Node, filename)
        val some_bind: ref u8 = stmt.d1 as ref u8
        val some_body_node: ref parser.Node = stmt.d2 as ref parser.Node
        val none_body_node: ref parser.Node = stmt.d3 as ref parser.Node
        push_scope(ctx)
        if some_bind != 0 as ref u8 {
            scope_define(ctx, some_bind, 1, 0 as ref u8, 0, line)
            scope_set_implicit_mut(ctx, some_bind)
        }
        if some_body_node != 0 as ref parser.Node {
            check_stmts(ctx, some_body_node.d0 as ref void, filename)
        }
        pop_scope(ctx, filename, line)
        push_scope(ctx)
        if none_body_node != 0 as ref parser.Node {
            check_stmts(ctx, none_body_node.d0 as ref void, filename)
        }
        pop_scope(ctx, filename, line)
        return
    }

    if k == parser.NK_MATCH_RES {
        check_expr(ctx, stmt.d0 as ref parser.Node, filename)
        val ok_bind: ref u8 = stmt.d1 as ref u8
        val ok_body_node: ref parser.Node = stmt.d2 as ref parser.Node
        push_scope(ctx)
        if ok_bind != 0 as ref u8 {
            scope_define(ctx, ok_bind, 1, 0 as ref u8, 0, line)
            scope_set_implicit_mut(ctx, ok_bind)
        }
        if ok_body_node != 0 as ref parser.Node {
            check_stmts(ctx, ok_body_node.d0 as ref void, filename)
        }
        pop_scope(ctx, filename, line)
        val err_bind: ref u8 = stmt.d3 as ref u8
        val err_body_node: ref parser.Node = stmt.d4 as ref parser.Node
        push_scope(ctx)
        if err_bind != 0 as ref u8 {
            scope_define(ctx, err_bind, 1, 0 as ref u8, 0, line)
            scope_set_implicit_mut(ctx, err_bind)
        }
        if err_body_node != 0 as ref parser.Node {
            check_stmts(ctx, err_body_node.d0 as ref void, filename)
        }
        pop_scope(ctx, filename, line)
        return
    }

    if k == parser.NK_MATCH_ENUM || k == parser.NK_MATCH_STR || k == parser.NK_MATCH_UNION {
        check_expr(ctx, stmt.d0 as ref parser.Node, filename)
        val arms: ref void = stmt.d1 as ref void
        if arms != 0 as ref void {
            for arm in arms as list[ref parser.Node] {
                push_scope(ctx)
                check_stmts(ctx, arm.d1 as ref void, filename)
                pop_scope(ctx, filename, line)
            }
        }
        val else_node: ref parser.Node = stmt.d2 as ref parser.Node
        if else_node != 0 as ref parser.Node {
            push_scope(ctx)
            check_stmts(ctx, else_node.d0 as ref void, filename)
            pop_scope(ctx, filename, line)
        }
        return
    }

    if k == parser.NK_MATCH_TAGGED_UNION {
        check_expr(ctx, stmt.d0 as ref parser.Node, filename)
        val tu_arms: ref void = stmt.d1 as ref void
        if tu_arms != 0 as ref void {
            for tu_arm in tu_arms as list[ref parser.Node] {
                push_scope(ctx)
                val bindings: ref void = tu_arm.d1 as ref void
                if bindings != 0 as ref void {
                    for bname in bindings as list[ref u8] {
                        if std.string.rchar_cmp(bname, "_") != 0 {
                            scope_define(ctx, bname, 1, 0 as ref u8, 0, line)
                            scope_set_implicit_mut(ctx, bname)
                        }
                    }
                }
                val arm_body: ref void = tu_arm.d2 as ref void
                check_stmts(ctx, arm_body, filename)
                if bindings != 0 as ref void {
                    for bname2 in bindings as list[ref u8] {
                        if std.string.rchar_cmp(bname2, "_") != 0 {
                            if !stmts_use_name(arm_body, bname2) {
                                val buf: ref u8 = @alloc(256) as ref u8
                                @snprintf(buf, 256, "{s}:{lld}: match binding '{s}' is captured but never used (use '_' to discard)",
                                    {filename, tu_arm.line, bname2})
                                add_error(ctx, buf)
                            }
                        }
                    }
                }
                pop_scope(ctx, filename, line)
            }
        }
        val tu_else: ref parser.Node = stmt.d2 as ref parser.Node
        if tu_else != 0 as ref parser.Node {
            push_scope(ctx)
            check_stmts(ctx, tu_else.d0 as ref void, filename)
            pop_scope(ctx, filename, line)
        }
        return
    }

    if k == parser.NK_GENERIC_WHEN {
        push_scope(ctx)
        check_stmts(ctx, stmt.d1 as ref void, filename)
        pop_scope(ctx, filename, line)
        return
    }
    if k == parser.NK_WHEN_STMT {
        push_scope(ctx)
        check_stmts(ctx, stmt.d1 as ref void, filename)
        pop_scope(ctx, filename, line)
        val or_when_sema: ref void = stmt.d2 as ref void
        if or_when_sema != 0 as ref void {
            for ow_sema in or_when_sema as list[ref parser.Node] {
                push_scope(ctx)
                check_stmts(ctx, ow_sema.d1 as ref void, filename)
                pop_scope(ctx, filename, line)
            }
        }
        val otherwise_sema: ref void = stmt.d3 as ref void
        if otherwise_sema != 0 as ref void {
            push_scope(ctx)
            check_stmts(ctx, otherwise_sema, filename)
            pop_scope(ctx, filename, line)
        }
        return
    }

    if k == parser.NK_INCREMENT || k == parser.NK_DECREMENT {
        val target2: ref parser.Node = stmt.d0 as ref parser.Node
        if target2.kind == parser.NK_IDENT {
            val tname2: ref u8 = target2.d0 as ref u8
            mark_name_mutated(ctx, tname2)
            if scope_lookup(ctx, tname2) == 0 {
                val buf2: ref u8 = @alloc(256) as ref u8
                @snprintf(buf2, 256, "{s}:{lld}: cannot mutate immutable '{s}'", {filename, line, tname2})
                add_error(ctx, buf2)
            }
        } elif target2.kind == parser.NK_FIELD {
            val root2: ref parser.Node = find_root_ident(target2)
            if root2 != 0 as ref parser.Node {
                val tname2: ref u8 = root2.d0 as ref u8
                mark_name_mutated(ctx, tname2)
                val lkup2: i64 = scope_lookup(ctx, tname2)
                if lkup2 == 0 {
                    val buf2: ref u8 = @alloc(256) as ref u8
                    @snprintf(buf2, 256, "{s}:{lld}: cannot mutate field of immutable '{s}'", {filename, line, tname2})
                    add_error(ctx, buf2)
                } else {
                    val field_name2: ref u8 = parser.field_name(target2)
                    val var_type2: ref u8 = scope_lookup_type(ctx, tname2)
                    if var_type2 != 0 as ref u8 && field_name2 != 0 as ref u8 {
                        val fmut2: i64 = find_field_mutable(ctx, var_type2, field_name2)
                        if fmut2 == 0 {
                            val buf2b: ref u8 = @alloc(256) as ref u8
                            @snprintf(buf2b, 256, "{s}:{lld}: cannot mutate immutable field '{s}' of type '{s}'", {filename, line, field_name2, var_type2})
                            add_error(ctx, buf2b)
                        }
                    }
                }
            }
        }
        return
    }

    if k == parser.NK_ADD_ASSIGN || k == parser.NK_SUB_ASSIGN {
        check_expr(ctx, stmt.d1 as ref parser.Node, filename)
        val target3: ref parser.Node = stmt.d0 as ref parser.Node
        if target3.kind == parser.NK_IDENT {
            val tname3: ref u8 = target3.d0 as ref u8
            mark_name_mutated(ctx, tname3)
            if scope_lookup(ctx, tname3) == 0 {
                val buf3: ref u8 = @alloc(256) as ref u8
                @snprintf(buf3, 256, "{s}:{lld}: cannot mutate immutable '{s}'", {filename, line, tname3})
                add_error(ctx, buf3)
            }
        } elif target3.kind == parser.NK_FIELD {
            val root3: ref parser.Node = find_root_ident(target3)
            if root3 != 0 as ref parser.Node {
                val tname3: ref u8 = root3.d0 as ref u8
                mark_name_mutated(ctx, tname3)
                if scope_lookup(ctx, tname3) == 0 {
                    val buf3: ref u8 = @alloc(256) as ref u8
                    @snprintf(buf3, 256, "{s}:{lld}: cannot mutate field of immutable '{s}'", {filename, line, tname3})
                    add_error(ctx, buf3)
                }
            }
        }
        return
    }
}


fn check_fn(ctx: mut ref SemaCtx, fn_node: ref parser.Node, filename: ref u8) void! = {
    guarded pre {
        ctx_not_null      : ctx != 0 as ref SemaCtx
        fn_node_not_null  : fn_node != 0 as ref parser.Node
        fn_kind_correct   : fn_node.kind == parser.NK_FN
        filename_not_null : filename != 0 as ref u8
    }

    val fn_name: ref u8 = fn_node.d2 as ref u8
    val fn_ns: ref u8 = fn_node.d1 as ref u8
    val params: ref void = fn_node.d3 as ref void
    if fn_name != 0 as ref u8 && fn_ns == 0 as ref u8 && str_eq(fn_name, "main") {
        if fn_node.d0 != 1 {
            val buf: ref u8 = @alloc(256) as ref u8
            @snprintf(buf, 256, "{s}:{lld}: main must be public.", {filename, fn_node.line})
            add_error(ctx, buf)
        }

        if params != 0 as ref void && @len(params) > 0 {
            val buf2: ref u8 = @alloc(256) as ref u8
            @snprintf(buf2, 256, "{s}:{lld}: main must not take any arguments.", {filename, fn_node.line})
            add_error(ctx, buf2)
        }
    }

    val is_unsafe: mut i64 = 0
    if parser.fn_is_unsafe(fn_node) { is_unsafe = 1 }
    val prev_unsafe: i64 = ctx.in_unsafe_fn
    ctx.in_unsafe_fn = is_unsafe

    push_scope(ctx)
    if params != 0 as ref void {
        for param in params as list[ref parser.Node] {
            val pname: ref u8 = param.d0 as ref u8
            val pty: ref parser.Node = param.d1 as ref parser.Node
            val is_mut: mut i64 = 0
            val param_is_ref: mut i64 = 0
            val param_tname: ref u8 = extract_type_name(pty)
            if pty.kind == parser.TY_MUT {
                is_mut = 1
                val pty_inner: ref parser.Node = pty.d0 as ref parser.Node
                if pty_inner != 0 as ref parser.Node && pty_inner.kind == parser.TY_REF {
                    param_is_ref = 1
                }
            } elif pty.kind == parser.TY_REF {
                param_is_ref = 1
            }
            scope_define(ctx, pname, is_mut, param_tname, param_is_ref, param.line)
        }
    }
    check_stmts(ctx, fn_node.d5 as ref void, filename)
    pop_scope(ctx, filename, 0)

    ctx.in_unsafe_fn = prev_unsafe
}

/// Register a function name.
fn register_fn_name(ctx: ref SemaCtx, ns: ref u8, nm: ref u8) void! = {
    if ns != 0 as ref u8 && nm != 0 as ref u8 {
        val buf: ref u8 = @alloc(256) as ref u8
        @snprintf(buf, 256, "{s}.{s}", {ns, nm})
        @append(ctx.fn_names, buf)
    } elif nm != 0 as ref u8 {
        @append(ctx.fn_names, nm)
    }
}

/// Register a type definition or type-related item name.
fn register_type_name(ctx: ref SemaCtx, item: ref parser.Node) void! = {
    if item == 0 as ref parser.Node { return }
    val k: i64 = item.kind
    if item.d1 != 0 as i64 {
        @append(ctx.type_names, item.d1 as ref u8)
    }
    if k == parser.NK_TYPEDEF || k == parser.NK_UNIONDEF || k == parser.NK_ENUMDEF || k == parser.NK_TAGGED_UNIONDEF {
        @append(ctx.type_defs, item as ref void)
    }
    if k == parser.NK_TAGGED_UNIONDEF {
        val tvariants: ref void = item.d2 as ref void
        if tvariants != 0 as ref void {
            for tv in tvariants as list[ref parser.Node] {
                if tv != 0 as ref parser.Node && tv.d0 != 0 as i64 {
                    val vname: ref u8 = tv.d0 as ref u8
                    @append(ctx.fn_names, vname)
                    @append(ctx.variant_names, vname)
                }
            }
        }
    }
}

/// Register a named item (const/use/val/extern_fn) name.
fn register_named_item(ctx: ref SemaCtx, item: ref parser.Node) void! = {
    if item == 0 as ref parser.Node { return }
    val k: i64 = item.kind
    if k == parser.NK_EXTERN_FN {
        if item.d1 != 0 as i64 {
            @append(ctx.fn_names, item.d1 as ref u8)
        }
    }
    if k == parser.NK_CONST || k == parser.NK_USE {
        if item.d1 != 0 as i64 {
            @append(ctx.global_names, item.d1 as ref u8)
        }
    }
    if k == parser.NK_VAL {
        if item.d0 != 0 as i64 {
            @append(ctx.global_names, item.d0 as ref u8)
        }
    }
}

/// Register a single top-level item's name in the context.
fn register_item_name(ctx: ref SemaCtx, item: ref parser.Node) void! = {
    if item == 0 as ref parser.Node { return }
    val k: i64 = item.kind
    if k == parser.NK_GENERIC_FN {
        val nm: ref u8 = item.d2 as ref u8
        if nm != 0 as ref u8 { @append(ctx.global_names, nm) }
        register_fn_name(ctx, item.d1 as ref u8, nm)
        @append(ctx.fn_defs, item as ref void)
        return
    }
    if k == parser.NK_FN || k == parser.NK_EXTERN_FN {
        if k == parser.NK_FN {
            if item.d0 == 1 {
                val nm: ref u8 = item.d2 as ref u8
                if nm != 0 as ref u8 { @append(ctx.global_names, nm) }
            } else {
                register_fn_name(ctx, item.d1 as ref u8, item.d2 as ref u8)
            }
            val fname: ref u8 = item.d2 as ref u8
            val params_node: ref void = item.d3 as ref void
            if fname != 0 as ref u8 {
                @append(ctx.fn_map_names, fname)
                @append(ctx.fn_map_params, params_node)
            }
        } else {
            if item.d1 != 0 as i64 {
                val ename: ref u8 = item.d1 as ref u8
                val eparams: ref void = item.d4 as ref void
                @append(ctx.fn_map_names, ename)
                @append(ctx.fn_map_params, eparams)
            }
        }
        @append(ctx.fn_defs, item as ref void)
    }
    if k == parser.NK_TYPEDEF || k == parser.NK_EXTERN_TYPE ||
       k == parser.NK_ENUMDEF || k == parser.NK_UNIONDEF || k == parser.NK_TAGGED_UNIONDEF {
        register_type_name(ctx, item)
    }
    register_named_item(ctx, item)
    if k == parser.NK_WHEN_ITEMS {
        val witems: ref void = item.d1 as ref void
        if witems != 0 as ref void {
            val wlen: i64 = @len(witems as list[ref parser.Node]) as i64
            val wi: mut i64 = 0
            for {
                if wi >= wlen { break }
                val wi_opt = @get(witems as list[ref parser.Node], wi as usize)
                match wi_opt {
                    some wi_node => {
                        register_item_name(ctx, wi_node as ref parser.Node)
                    }
                    none => {}
                }
                wi++
            }
        }
    }
}

fn check_generic_fn(ctx: mut ref SemaCtx, fn_node: ref parser.Node, filename: ref u8) void! = {
    val body: ref void = fn_node.d5 as ref void
    if body == 0 as ref void { return }
    val is_unsafe: mut i64 = 0
    if parser.generic_fn_is_unsafe(fn_node) { is_unsafe = 1 }
    val prev_unsafe: i64 = ctx.in_unsafe_fn
    ctx.in_unsafe_fn = is_unsafe

    val type_params: ref void = fn_node.d6 as ref void
    val prev_type_params: list[ref u8] = ctx.type_params
    if type_params != 0 as ref void {
        for tparam in type_params as list[ref u8] {
            @append(ctx.type_params, tparam)
        }
    }

    push_scope(ctx)
    val params: ref void = fn_node.d3 as ref void
    if params != 0 as ref void {
        for param in params as list[ref parser.Node] {
            val pname: ref u8 = param.d0 as ref u8
            val pty: ref parser.Node = param.d1 as ref parser.Node
            val is_mut: mut i64 = 0
            val param_is_ref: mut i64 = 0
            val param_tname: ref u8 = extract_type_name(pty)
            if pty.kind == parser.TY_MUT {
                is_mut = 1
                val pty_inner: ref parser.Node = pty.d0 as ref parser.Node
                if pty_inner != 0 as ref parser.Node && pty_inner.kind == parser.TY_REF {
                    param_is_ref = 1
                }
            } elif pty.kind == parser.TY_REF {
                param_is_ref = 1
            }
            scope_define(ctx, pname, is_mut, param_tname, param_is_ref, param.line)
            mark_name_used(ctx, pname)
        }
    }

    check_stmts(ctx, body, filename)
    pop_scope(ctx, filename, 0)

    ctx.type_params = prev_type_params
    ctx.in_unsafe_fn = prev_unsafe
}

/// Check a single top-level item (functions, tests, when items).
fn check_top_item(ctx: ref SemaCtx, item: ref parser.Node, filename: ref u8) void! = {
    val k: i64 = item.kind
    if k == parser.NK_GENERIC_FN {
        check_generic_fn(ctx, item, filename)
        return
    }
    if k == parser.NK_FN {
        check_fn(ctx, item, filename)
    }
    if k == parser.NK_TEST {
        push_scope(ctx)
        check_stmts(ctx, item.d0 as ref void, filename)
        pop_scope(ctx, filename, item.line)
    }
    if k == parser.NK_VAL {
        val init_node: ref parser.Node = item.d3 as ref parser.Node
        if init_node != 0 as ref parser.Node {
            check_expr(ctx, init_node, filename)
        }
        return
    }
    if k == parser.NK_WHEN_ITEMS {
        val witems: ref void = item.d1 as ref void
        if witems != 0 as ref void {
            for wi in witems as list[ref parser.Node] {
                if wi.kind == parser.NK_FN {
                    check_fn(ctx, wi, filename)
                }
            }
        }
        val or_when_sema: ref void = item.d2 as ref void
        if or_when_sema != 0 as ref void {
            for ow_sema in or_when_sema as list[ref parser.Node] {
                val ow_items: ref void = ow_sema.d1 as ref void
                if ow_items != 0 as ref void {
                    for wi3 in ow_items as list[ref parser.Node] {
                        if wi3.kind == parser.NK_FN {
                            check_fn(ctx, wi3, filename)
                        }
                    }
                }
            }
        }
        val ow_otherwise: ref void = item.d3 as ref void
        if ow_otherwise != 0 as ref void {
            for wi4 in ow_otherwise as list[ref parser.Node] {
                if wi4.kind == parser.NK_FN {
                    check_fn(ctx, wi4, filename)
                }
            }
        }
    }
}

/// Check for duplicate function/type names.
fn check_duplicates(ctx: ref SemaCtx, filename: ref u8) void! = {
    val fnlen: i64 = @len(ctx.fn_names) as i64
    val fi: mut i64 = 0
    for {
        if fi >= fnlen { break }
        val fn_opt = @get(ctx.fn_names, fi as usize)
        match fn_opt {
            some fn_name => {
                val fj: mut i64 = fi + 1
                for {
                    if fj >= fnlen { break }
                    val fn2_opt = @get(ctx.fn_names, fj as usize)
                    match fn2_opt {
                        some fn2_name => {
                            if str_eq(fn_name as ref u8, fn2_name as ref u8) {
                                val buf: ref u8 = @alloc(256) as ref u8
                                @snprintf(buf, 256, "{s}: duplicate definition of '{s}'", {filename, fn_name as ref u8})
                                add_error(ctx, buf)
                            }
                        }
                        none => {}
                    }
                    fj++
                }
            }
            none => {}
        }
        fi++
    }
}

fn is_function_public(items: list[ref parser.Node], fn_name: ref u8) bool! = {
    for item in items {
        if item == 0 as ref parser.Node { continue }
        val k: i64 = item.kind
        if k == parser.NK_FN {
            if item.d0 == 1 {
                val name: ref u8 = item.d2 as ref u8
                if name != 0 as ref u8 && str_eq(name, fn_name) {
                    return true
                }
            }
        } elif k == parser.NK_EXTERN_FN {
            if item.d0 == 1 {
                val name: ref u8 = item.d1 as ref u8
                if name != 0 as ref u8 && str_eq(name, fn_name) {
                    return true
                }
            }
        }
    }
    return false
}


pub fn check_module(items: list[ref parser.Node], filename: ref u8, root: ref modinfo.ResolvedModule, quiet: i64) list[ref u8]! = {
    val ctx: mut ref SemaCtx = sema_new()
    ctx.root_mod = root

    for item in items {
        register_item_name(ctx, item)
    }

    check_duplicates(ctx, filename)

    for item2 in items {
        check_top_item(ctx, item2, filename)
    }

    val fnlen: i64 = @len(ctx.fn_names) as i64
    val fi: mut i64 = 0
    for {
        if fi >= fnlen { break }
        val fn_opt = @get(ctx.fn_names, fi as usize)
        match fn_opt {
            some fn_name => {
                val used_found: mut bool = false
                for uf in ctx.used_fns {
                    if str_eq(uf as ref u8, fn_name as ref u8) { used_found = true break }
                }
                if !used_found {
                    val namec: ref u8 = fn_name as ref u8
                    val is_variant: mut bool = false
                    for vn in ctx.variant_names {
                        if str_eq(vn as ref u8, namec) { is_variant = true break }
                    }
                    val is_public: bool = is_function_public(items, namec)
                    if !str_eq(namec, "main") && !is_variant && !is_public {
                        val wbuf: ref u8 = @alloc(256) as ref u8
                        @snprintf(wbuf, 256, "{s}: unused function '{s}'", {filename, namec})
                        @append(ctx.warnings, wbuf)
                    }
                }
            }
            none => {}
        }
        fi++
    }

    if quiet == 0 {
        for w in ctx.warnings {
            std.stdio.print("warning: {s}\n", {w})
        }
    }

    return ctx.errors
}

fn check_module_seen(seen: list[ref void], mod: ref modinfo.ResolvedModule) bool! = {
    for s in seen {
        if s == mod as ref void { return true }
    }
    return false
}

fn check_module_rec(mod: ref modinfo.ResolvedModule, all_errors: mut list[ref u8], seen: mut list[ref void], quiet: i64) void! = {
    if mod == 0 as ref modinfo.ResolvedModule { return }
    if check_module_seen(seen, mod) { return }
    @append(seen, mod as ref void)

    val n: i64 = modinfo.import_count(mod)
    val i: mut i64 = 0
    for {
        if i >= n { break }
        val child: ref modinfo.ResolvedModule = modinfo.import_module_at(mod, i as usize)
        check_module_rec(child, all_errors, seen, quiet)
        i++
    }

    val fname: ref u8 = normalize_path(modinfo.module_filename(mod))
    val items: list[ref parser.Node] = modinfo.module_items(mod)
    val errors: list[ref u8] = check_module(items, fname, mod, quiet)
    for e in errors {
        @append(all_errors, e)
    }
}

pub fn check_module_tree(root: ref modinfo.ResolvedModule, quiet: i64) list[ref u8]! = {
    val all_errors: mut list[ref u8] = []
    val seen: mut list[ref void] = []
    check_module_rec(root, all_errors, seen, quiet)
    return all_errors
}
