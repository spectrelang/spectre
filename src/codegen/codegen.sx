val str         = use("std/string")
val fmt         = use("std/fmt")
val os          = use("std/os")
val stdio       = use("std/stdio")
val reflection  = use("std/reflection")
val collections = use("std/collections")
val parser      = use("../ast/parser.sx")
val module      = use("../module/module.sx")

/// Codegen context
pub type CgCtx = {
    sb: mut ref void
    mono_sb: mut ref void
    tmp: mut i64
    lbl: mut i64
    fn_name: mut ref u8
    current_fn_ret_qtype: mut ref u8
    current_fn_ret_union: mut ref u8
    current_fn_ret_ty: mut ref void
    expected_ty: mut ref void
    strs: mut list[ref u8]
    str_cnt: mut i64
    tdefs: mut list[ref void]
    edefs: mut list[ref void]
    dvars: mut list[ref u8]
    dqtypes: mut list[ref u8]
    snames: mut list[ref u8]
    sfields: mut list[ref void]
    lnames: mut list[ref u8]
    ltypes: mut list[ref u8]
    unames: mut list[ref u8]
    uvariants:mut list[ref void]
    fn_names: mut list[ref u8]
    fn_params: mut list[ref void]
    fn_rets: mut list[ref void]
    ext_names: mut list[ref u8]
    ext_syms: mut list[ref u8]
    ext_rets: mut list[ref void]
    tv_names: mut list[ref u8]
    tv_owners: mut list[ref u8]
    tv_tags: mut list[i64]
    tv_fields: mut list[ref void]
    break_lbl: mut i64
    cont_lbl: mut i64
    mc_names: mut list[ref u8]
    mc_vals: mut list[ref u8]
    mc_index: mut ref void
    fn_name_index: mut ref void
    defer_stack: mut list[ref void]
    local_src_names: mut list[ref u8]
    local_qbe_names: mut list[ref u8]
    local_slot_names: mut list[ref u8]
    local_ref_types: mut list[ref u8]
    global_src_names: mut list[ref u8]
    global_labels: mut list[ref u8]
    global_qtypes: mut list[ref u8]
    global_anns: mut list[ref u8]
    used_prefixes: mut list[ref u8]
    current_module_prefix: mut ref u8
    emitted_labels: mut list[ref u8]
    emitted_shims: mut list[ref u8]
    release_mode: mut bool
    src_target: mut ref u8
    inv_tnames:     mut list[ref u8]
    inv_tlists:     mut list[ref void]
    inv_cur_pnames: mut list[ref u8]
    inv_cur_ptypes: mut list[ref u8]
    gfn_names:      mut list[ref u8]
    gfn_nodes:      mut list[ref void]
    gfn_prefixes:   mut list[ref u8]
    gsubst_names:   mut list[ref u8]
    gsubst_tnodes:  mut list[ref void]
    current_filename: mut ref u8
}

fn cg_new() ref CgCtx! = {
    val ctx: mut ref CgCtx = @alloc(@sizeof(CgCtx)) as ref CgCtx
    ctx.sb = str.StringBuilder.new()
    ctx.mono_sb = str.StringBuilder.new()
    ctx.tmp = 0
    ctx.lbl = 0
    ctx.fn_name = 0 as ref u8
    ctx.current_fn_ret_qtype = "l"
    ctx.current_fn_ret_union = ""
    ctx.current_fn_ret_ty = 0 as ref void
    ctx.expected_ty = 0 as ref void
    ctx.strs = []
    ctx.str_cnt = 0
    ctx.tdefs = []
    ctx.edefs = []
    ctx.dvars = []
    ctx.dqtypes = []
    ctx.snames = []
    ctx.sfields = []
    ctx.lnames = []
    ctx.ltypes = []
    ctx.unames = []
    ctx.uvariants = []
    ctx.fn_names = []
    ctx.fn_params = []
    ctx.fn_rets = []
    ctx.ext_names = []
    ctx.ext_syms = []
    ctx.ext_rets = []
    ctx.tv_names = []
    ctx.tv_owners = []
    ctx.tv_tags = []
    ctx.tv_fields = []
    ctx.break_lbl = -1
    ctx.cont_lbl = -1
    ctx.mc_names = []
    ctx.mc_vals = []
    ctx.mc_index = collections.IndexMap.new(64 as usize)
    ctx.fn_name_index = collections.IndexMap.new(256 as usize)
    ctx.defer_stack = []
    ctx.local_src_names = []
    ctx.local_qbe_names = []
    ctx.local_slot_names = []
    ctx.local_ref_types = []
    ctx.global_src_names = []
    ctx.global_labels = []
    ctx.global_qtypes = []
    ctx.global_anns = []
    ctx.used_prefixes = []
    ctx.current_module_prefix = ""
    ctx.emitted_labels = []
    ctx.emitted_shims = []
    ctx.release_mode = false
    ctx.src_target = ""
    ctx.inv_tnames = []
    ctx.inv_tlists = []
    ctx.inv_cur_pnames = []
    ctx.inv_cur_ptypes = []
    ctx.gfn_names = []
    ctx.gfn_nodes = []
    ctx.gfn_prefixes = []
    ctx.gsubst_names = []
    ctx.gsubst_tnodes = []
    ctx.current_filename = ""
    return ctx
}

fn cg_sb(ctx: ref CgCtx)      ref void! = { return ctx.sb as ref void }
fn cg_tmp(ctx: ref CgCtx)     i64!      = { return ctx.tmp as i64}
fn cg_lbl(ctx: ref CgCtx)     i64!      = { return ctx.lbl as i64 }
fn cg_fn_name(ctx: ref CgCtx) ref u8! = { return ctx.fn_name as ref u8 }
fn cg_strs(ctx: ref CgCtx)    ref void! = { return ctx.strs as ref void }
fn cg_str_cnt(ctx: ref CgCtx) i64!      = { return ctx.str_cnt as i64 }

fn cg_set_tmp(ctx: mut ref CgCtx, v: i64) void! = {
    ctx.tmp = v
}
fn cg_set_lbl(ctx: mut ref CgCtx, v: i64) void! = {
    ctx.lbl = v
}
fn cg_set_fn_name(ctx: mut ref CgCtx, v: ref u8) void! = {
    ctx.fn_name = v
}
fn cg_set_str_cnt(ctx: mut ref CgCtx, v: i64) void! = {
    ctx.str_cnt = v
}

fn cg_emit_label_if_new(ctx: ref CgCtx, label: ref u8) bool! = {
    val elen: i64 = @len(ctx.emitted_labels as list[ref u8]) as i64
    val ei: mut i64 = 0
    for {
        if ei >= elen { break }
        val e_opt = @get(ctx.emitted_labels as list[ref u8], ei as usize)
        match e_opt {
            some e => {
                if str.rchar_cmp(e as ref u8, label) == 0 {
                    return false
                }
            }
            none => {}
        }
        ei++
    }
    @append(ctx.emitted_labels as list[ref u8], label)
    return true
}

fn cg_dvars(ctx: ref CgCtx) ref void! = { return ctx.dvars as ref void }
fn cg_snames(ctx: ref CgCtx) ref void! = { return ctx.snames as ref void }
fn cg_global_src_names(ctx: ref CgCtx) ref void! = { return ctx.global_src_names as ref void }
fn cg_global_labels(ctx: ref CgCtx)    ref void! = { return ctx.global_labels as ref void }
fn cg_global_qtypes(ctx: ref CgCtx)    ref void! = { return ctx.global_qtypes as ref void }
fn cg_global_anns(ctx: ref CgCtx)      ref void! = { return ctx.global_anns as ref void }

fn cg_mark_prefix_used(ctx: ref CgCtx, prefix: ref u8) void! = {
    val nlen: i64 = @len(ctx.used_prefixes as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.used_prefixes as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, prefix) == 0 {
                    return
                }
            }
            none => {}
        }
        ni++
    }
    @append(ctx.used_prefixes as list[ref u8], prefix)
}

fn cg_is_prefix_used(ctx: ref CgCtx, prefix: ref u8) bool! = {
    val nlen: i64 = @len(ctx.used_prefixes as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.used_prefixes as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, prefix) == 0 {
                    return true
                }
            }
            none => {}
        }
        ni++
    }
    return false
}

/// Returns true if the given when-clause name matches the specified platform.
/// When src_target is "" the real host platform is used.
/// Handles group aliases: "posix" matches linux/darwin/*bsd/haiku/android/redox.
pub fn platform_matches_with_target(name: ref u8, src_target: ref u8) bool! = {
    val cur: mut ref u8 = reflection.current_platform_name()
    if str.rchar_cmp(src_target, "") != 0 { cur = src_target }
    if str.rchar_cmp(name, cur) == 0 { return true }
    if str.rchar_cmp(name, "posix") == 0 {
        if str.rchar_cmp(cur, "linux")        == 0 { return true }
        if str.rchar_cmp(cur, "darwin")       == 0 { return true }
        if str.rchar_cmp(cur, "freebsd")      == 0 { return true }
        if str.rchar_cmp(cur, "openbsd")      == 0 { return true }
        if str.rchar_cmp(cur, "netbsd")       == 0 { return true }
        if str.rchar_cmp(cur, "dragonflybsd") == 0 { return true }
        if str.rchar_cmp(cur, "haiku")        == 0 { return true }
        if str.rchar_cmp(cur, "android")      == 0 { return true }
        if str.rchar_cmp(cur, "redox")        == 0 { return true }
    }
    return false
}

/// Returns true if the given when-clause name matches the host platform (no override).
pub fn platform_matches(name: ref u8) bool! = {
    return platform_matches_with_target(name, "")
}

/// Returns true if the given when-clause name matches considering ctx.src_target.
fn cg_platform_matches(ctx: ref CgCtx, name: ref u8) bool! = {
    return platform_matches_with_target(name, ctx.src_target)
}

/// Register a generic function node for later monomorphization.
fn register_generic_fn(ctx: ref CgCtx, name: ref u8, node: ref parser.Node, prefix: ref u8) void! = {
    @append(ctx.gfn_names, name)
    @append(ctx.gfn_nodes as list[ref void], node as ref void)
    @append(ctx.gfn_prefixes, prefix)
}

/// Look up a generic function node by base name. Returns null if not found.
fn lookup_generic_fn(ctx: ref CgCtx, name: ref u8) ref parser.Node! = {
    val nlen: i64 = @len(ctx.gfn_names) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.gfn_names, ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, name) == 0 {
                    val nd_opt = @get(ctx.gfn_nodes as list[ref void], ni as usize)
                    match nd_opt {
                        some nd => { return nd as ref parser.Node }
                        none   => { return 0 as ref parser.Node }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref parser.Node
}

/// Look up a generic function's module prefix by base name.
fn lookup_generic_fn_prefix(ctx: ref CgCtx, name: ref u8) ref u8! = {
    val nlen: i64 = @len(ctx.gfn_names) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.gfn_names, ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, name) == 0 {
                    val p_opt = @get(ctx.gfn_prefixes, ni as usize)
                    match p_opt {
                        some p => { return p as ref u8 }
                        none   => { return "" }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return ""
}

/// Push a type substitution (type_param_name -> concrete type node).
fn gsubst_push(ctx: ref CgCtx, name: ref u8, ty: ref parser.Node) void! = {
    @append(ctx.gsubst_names, name)
    @append(ctx.gsubst_tnodes as list[ref void], ty as ref void)
}

/// Resolve a type node through current generic substitutions.
fn gsubst_resolve(ctx: ref CgCtx, ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return ty }
    if ty.kind != parser.TY_NAMED { return ty }
    val name: ref u8 = ty.d0 as ref u8
    val nlen: i64 = @len(ctx.gsubst_names) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.gsubst_names, ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, name) == 0 {
                    val t_opt = @get(ctx.gsubst_tnodes as list[ref void], ni as usize)
                    match t_opt {
                        some t => { return t as ref parser.Node }
                        none   => { return ty }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return ty
}

/// Resolve a generic type parameter name to its concrete substituted type name.
fn gsubst_resolve_name(ctx: ref CgCtx, name: ref u8) ref u8! = {
    val nlen: i64 = @len(ctx.gsubst_names) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.gsubst_names, ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, name) == 0 {
                    val t_opt = @get(ctx.gsubst_tnodes as list[ref void], ni as usize)
                    match t_opt {
                        some t => {
                            val resolved: ref parser.Node = t as ref parser.Node
                            return type_node_to_mangled_ident(resolved)
                        }
                        none => { return "" }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return ""
}

fn cg_clone_node(node: ref parser.Node) ref parser.Node! = {
    if node == 0 as ref parser.Node { return 0 as ref parser.Node }
    val out: mut ref parser.Node = parser.make_node(node.kind, node.line)
    out.d0 = node.d0
    out.d1 = node.d1
    out.d2 = node.d2
    out.d3 = node.d3
    out.d4 = node.d4
    out.d5 = node.d5
    out.d6 = node.d6
    return out
}

fn cg_clone_char_list(xs: list[ref u8]) list[ref u8]! = {
    val out: mut list[ref u8] = []
    val len: i64 = @len(xs) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val x_opt = @get(xs, i as usize)
        match x_opt {
            some x => { @append(out, x as ref u8) }
            none => {}
        }
        i++
    }
    return out
}

fn cg_clone_void_list(xs: list[ref void]) list[ref void]! = {
    val out: mut list[ref void] = []
    val len: i64 = @len(xs) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val x_opt = @get(xs, i as usize)
        match x_opt {
            some x => { @append(out, x as ref void) }
            none => {}
        }
        i++
    }
    return out
}

fn cg_concrete_ty(ctx: ref CgCtx, ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return 0 as ref parser.Node }
    val k: i64 = ty.kind
    if k == parser.TY_NAMED { return gsubst_resolve(ctx, ty) }
    if k == parser.TY_MUT || k == parser.TY_REF || k == parser.TY_OPTION ||
       k == parser.TY_LIST || k == parser.TY_RESULT || k == parser.TY_SLICE {
        val inner: ref parser.Node = ty.d0 as ref parser.Node
        val resolved_inner: ref parser.Node = cg_concrete_ty(ctx, inner)
        if resolved_inner == inner { return ty }
        val out: mut ref parser.Node = cg_clone_node(ty)
        out.d0 = resolved_inner as i64
        return out
    }
    if k == parser.TY_FIXED_ARR {
        val inner2: ref parser.Node = ty.d1 as ref parser.Node
        val resolved_inner2: ref parser.Node = cg_concrete_ty(ctx, inner2)
        if resolved_inner2 == inner2 { return ty }
        val out2: mut ref parser.Node = cg_clone_node(ty)
        out2.d1 = resolved_inner2 as i64
        return out2
    }
    return ty
}

/// Extract the list element type node from a type. Unwraps mut wrappers.
fn cg_unwrap_list_elem_ty(ctx: ref CgCtx, ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return 0 as ref parser.Node }
    val resolved: ref parser.Node = cg_concrete_ty(ctx, ty)
    val k: i64 = resolved.kind
    if k == parser.TY_LIST { return resolved.d0 as ref parser.Node }
    if k == parser.TY_MUT { return cg_unwrap_list_elem_ty(ctx, resolved.d0 as ref parser.Node) }
    return 0 as ref parser.Node
}

fn cg_struct_fields_for_type(ctx: ref CgCtx, ty: ref parser.Node) ref void! = {
    val resolved: ref parser.Node = cg_concrete_ty(ctx, ty)
    if resolved == 0 as ref parser.Node { return 0 as ref void }
    val k: i64 = resolved.kind
    if k == parser.TY_MUT || k == parser.TY_REF {
        return cg_struct_fields_for_type(ctx, resolved.d0 as ref parser.Node)
    }
    if k == parser.TY_NAMED {
        return cg_lookup_struct(ctx, resolved.d0 as ref u8)
    }
    return 0 as ref void
}

fn cg_alloc_size_for_type(ctx: ref CgCtx, ty: ref parser.Node) i64! = {
    val resolved: ref parser.Node = cg_concrete_ty(ctx, ty)
    if resolved == 0 as ref parser.Node { return 0 }
    val k: i64 = resolved.kind
    if k == parser.TY_MUT {
        return cg_alloc_size_for_type(ctx, resolved.d0 as ref parser.Node)
    }
    if k == parser.TY_NAMED {
        val tname: ref u8 = resolved.d0 as ref u8
        val union_vars: ref void = cg_lookup_union_suffix(ctx, tname)
        if union_vars != 0 as ref void { return 16 }
        val struct_fields: ref void = cg_lookup_struct(ctx, tname)
        if struct_fields != 0 as ref void { return struct_size(ctx, struct_fields) }
    }
    return type_size(resolved)
}

fn cg_literal_matches_struct_fields(ctx: ref CgCtx, lit_fields: ref void, struct_fields: ref void) bool! = {
    if lit_fields == 0 as ref void || struct_fields == 0 as ref void { return false }
    val lflen: i64 = @len(lit_fields as list[ref void]) as i64
    val li: mut i64 = 0
    for {
        if li >= lflen { break }
        val lf_opt = @get(lit_fields as list[ref void], li as usize)
        match lf_opt {
            some lf => {
                val lf_name: ref u8 = (lf as ref parser.Node).d0 as ref u8
                if field_offset(ctx, struct_fields, lf_name) < 0 {
                    return false
                }
            }
            none => {}
        }
        li++
    }
    return true
}

fn cg_literal_exact_struct_match(ctx: ref CgCtx, lit_fields: ref void, struct_fields: ref void) bool! = {
    if lit_fields == 0 as ref void || struct_fields == 0 as ref void { return false }
    if @len(lit_fields as list[ref void]) as i64 != @len(struct_fields as list[ref void]) as i64 {
        return false
    }
    return cg_literal_matches_struct_fields(ctx, lit_fields, struct_fields)
}

fn cg_find_struct_fields_for_literal(ctx: ref CgCtx, lit_fields: ref void) ref void! = {
    if lit_fields == 0 as ref void { return 0 as ref void }
    val sfields_list: ref void = cg_sfields(ctx)
    val slen: i64 = @len(sfields_list as list[ref void]) as i64
    val match_fields: mut ref void = 0 as ref void
    val matches: mut i64 = 0
    val si: mut i64 = 0
    for {
        if si >= slen { break }
        val sf_opt = @get(sfields_list as list[ref void], si as usize)
        match sf_opt {
            some sf => {
                val sfields: ref void = sf as ref void
                if cg_literal_exact_struct_match(ctx, lit_fields, sfields) {
                    match_fields = sfields
                    matches++
                    if matches > 1 { break }
                }
            }
            none => {}
        }
        si++
    }
    if matches == 1 { return match_fields }

    match_fields = 0 as ref void
    matches = 0
    si = 0
    for {
        if si >= slen { break }
        val sf_opt = @get(sfields_list as list[ref void], si as usize)
        match sf_opt {
            some sf => {
                val sfields: ref void = sf as ref void
                if cg_literal_matches_struct_fields(ctx, lit_fields, sfields) {
                    match_fields = sfields
                    matches++
                    if matches > 1 { return 0 as ref void }
                }
            }
            none => {}
        }
        si++
    }
    if matches == 1 { return match_fields }
    return 0 as ref void
}

/// Serialize a type node to a canonical string for constraint matching.
fn type_node_to_str(ty: ref parser.Node) ref u8! = {
    if ty == 0 as ref parser.Node { return "void" }
    val k: i64 = ty.kind
    if k == parser.TY_NAMED { return ty.d0 as ref u8 }
    if k == parser.TY_REF {
        val inner: ref u8 = type_node_to_str(ty.d0 as ref parser.Node)
        val buf: ref u8 = @alloc(256) as ref u8
        @snprintf(buf, 256, "ref {s}", {inner})
        return buf
    }
    if k == parser.TY_MUT {
        val inner: ref u8 = type_node_to_str(ty.d0 as ref parser.Node)
        val buf: ref u8 = @alloc(256) as ref u8
        @snprintf(buf, 256, "mut {s}", {inner})
        return buf
    }
    if k == parser.TY_VOID { return "void" }
    return "unknown"
}

/// Serialize a type node to a mangled identifier string for function naming.
fn sanitize_mangle_atom(name: ref u8) ref u8! = {
    val nlen: i64 = str.len_raw(name)
    val out: ref u8 = @alloc(nlen * 2 + 1) as ref u8
    val si: mut i64 = 0
    val oi: mut i64 = 0
    for {
        if si >= nlen { break }
        val ch: u8 = @load8(@ptradd(name as ref void, si))
        if ch == 46 {
            @store8(@ptradd(out as ref void, oi), 95)
            @store8(@ptradd(out as ref void, oi + 1), 95)
            oi += 2
        } else {
            @store8(@ptradd(out as ref void, oi), ch)
            oi++
        }
        si++
    }
    @store8(@ptradd(out as ref void, oi), 0)
    return out
}

fn type_node_to_mangle(ty: ref parser.Node) ref u8! = {
    if ty == 0 as ref parser.Node { return "void" }
    val k: i64 = ty.kind
    if k == parser.TY_NAMED { return sanitize_mangle_atom(ty.d0 as ref u8) }
    if k == parser.TY_REF {
        val inner: ref u8 = type_node_to_mangle(ty.d0 as ref parser.Node)
        val buf: ref u8 = @alloc(256) as ref u8
        @snprintf(buf, 256, "ref_{s}", {inner})
        return buf
    }
    if k == parser.TY_MUT {
        val inner: ref u8 = type_node_to_mangle(ty.d0 as ref parser.Node)
        val buf: ref u8 = @alloc(256) as ref u8
        @snprintf(buf, 256, "mut_{s}", {inner})
        return buf
    }
    if k == parser.TY_VOID { return "void" }
    return "unknown"
}

fn type_node_to_mangled_ident(ty: ref parser.Node) ref u8! = {
    if ty == 0 as ref parser.Node { return "" }
    val k: i64 = ty.kind
    if k == parser.TY_NAMED { return sanitize_mangle_atom(ty.d0 as ref u8) }
    if k == parser.TY_REF || k == parser.TY_MUT {
        return type_node_to_mangled_ident(ty.d0 as ref parser.Node)
    }
    if k == parser.TY_VOID { return "void" }
    return type_node_to_mangle(ty)
}

/// Check whether a NK_GENERIC_WHEN node's conditions match current substitutions.
fn gwhen_matches_gsubst(ctx: ref CgCtx, when_node: ref parser.Node) bool! = {
    val conds: ref void = when_node.d0 as ref void
    if conds == 0 as ref void { return true }
    val clen: i64 = @len(conds as list[ref parser.Node]) as i64
    val ci: mut i64 = 0
    for {
        if ci >= clen { break }
        val c_opt = @get(conds as list[ref parser.Node], ci as usize)
        match c_opt {
            some c => {
                val cond: ref parser.Node = c as ref parser.Node
                val ckind: i64 = cond.d1
                if ckind == 0 {
                    ci++
                    continue
                }
                val tparam: ref u8 = cond.d0 as ref u8
                val dummy: mut ref parser.Node = parser.make_node(parser.TY_NAMED, 0)
                dummy.d0 = tparam as i64
                val resolved: ref parser.Node = gsubst_resolve(ctx, dummy)
                if resolved == dummy {
                    ci++
                    continue
                }
                val concrete_str: ref u8 = type_node_to_str(resolved)
                val ctypes: ref void = cond.d2 as ref void
                if ckind == 1 {
                    val matched: mut bool = false
                    if ctypes != 0 as ref void {
                        val tlen: i64 = @len(ctypes as list[ref parser.Node]) as i64
                        val ti: mut i64 = 0
                        for {
                            if ti >= tlen { break }
                            val t_opt = @get(ctypes as list[ref parser.Node], ti as usize)
                            match t_opt {
                                some t => {
                                    val resolved_t: ref parser.Node = gsubst_resolve(ctx, t as ref parser.Node)
                                    val ts: ref u8 = type_node_to_str(resolved_t)
                                    if str.rchar_cmp(concrete_str, ts) == 0 { matched = true }
                                }
                                none => {}
                            }
                            ti++
                        }
                    }
                    if !matched { return false }
                } elif ckind == 2 {
                    val matched2: mut bool = false
                    if ctypes != 0 as ref void {
                        val t_opt = @get(ctypes as list[ref parser.Node], 0)
                        match t_opt {
                            some t => {
                                val resolved_t2: ref parser.Node = gsubst_resolve(ctx, t as ref parser.Node)
                                val ts: ref u8 = type_node_to_str(resolved_t2)
                                if str.rchar_cmp(concrete_str, ts) == 0 { matched2 = true }
                            }
                            none => {}
                        }
                    }
                    if !matched2 { return false }
                } elif ckind == 3 {
                    val matched3: mut bool = false
                    if ctypes != 0 as ref void {
                        val tlen3: i64 = @len(ctypes as list[ref parser.Node]) as i64
                        val ti3: mut i64 = 0
                        for {
                            if ti3 >= tlen3 { break }
                            val t_opt3 = @get(ctypes as list[ref parser.Node], ti3 as usize)
                            match t_opt3 {
                                some t3 => {
                                    val resolved_t3: ref parser.Node = gsubst_resolve(ctx, t3 as ref parser.Node)
                                    val ts3: ref u8 = type_node_to_str(resolved_t3)
                                    if str.rchar_cmp(concrete_str, ts3) == 0 { matched3 = true }
                                }
                                none => {}
                            }
                            ti3++
                        }
                    }
                    if matched3 { return false }
                }
            }
            none => {}
        }
        ci++
    }
    return true
}

/// Find the first matching NK_GENERIC_WHEN branch body in a function body, given current substitutions.
/// Returns the body stmts (as ref parser.Node = list) or null if none found.
fn find_matching_gwhen_body(ctx: ref CgCtx, fn_body: ref parser.Node) ref parser.Node! = {
    if fn_body == 0 as ref parser.Node { return 0 as ref parser.Node }
    val blen: i64 = @len(fn_body) as i64
    val bi: mut i64 = 0
    for {
        if bi >= blen { break }
        val s_opt = @get(fn_body, bi as usize)
        match s_opt {
            some s => {
                val sn: ref parser.Node = s as ref parser.Node
                if sn.kind == parser.NK_GENERIC_WHEN {
                    if gwhen_matches_gsubst(ctx, sn) {
                        return sn.d1 as ref parser.Node
                    }
                }
            }
            none => {}
        }
        bi++
    }
    return 0 as ref parser.Node
}

/// Substitute TY_NAMED type params in a param node's type, returning new param node.
fn make_concrete_param(ctx: ref CgCtx, param: ref parser.Node) ref parser.Node! = {
    val pname: ref u8 = param.d0 as ref u8
    val pty: ref parser.Node = param.d1 as ref parser.Node
    val resolved: ref parser.Node = gsubst_resolve(ctx, pty)
    val np: mut ref parser.Node = parser.make_node(parser.NK_VAL, param.line)
    np.d0 = pname as i64
    np.d1 = resolved as i64
    return np
}

/// Monomorphize a generic function and emit it. Returns the base mangled name (without sx__ prefix).
fn monomorphize_generic_fn(ctx: mut ref CgCtx, gfn_node: ref parser.Node, _: ref u8,
                            type_args: list[ref parser.Node]) ref u8! = {
    val fn_name: ref u8 = gfn_node.d2 as ref u8
    val tparams: ref void = gfn_node.d6 as ref void
    val suffix: ref u8 = @alloc(512) as ref u8
    val spos: mut i64 = 0
    val nargs: i64 = @len(type_args) as i64
    val ai: mut i64 = 0
    for {
        if ai >= nargs { break }
        val ta_opt = @get(type_args, ai as usize)
        match ta_opt {
            some ta => {
                val mangle: ref u8 = type_node_to_mangle(ta as ref parser.Node)
                val sep: ref u8 = "__"
                val seplen: i64 = 2
                val mlen: i64 = str.len_raw(mangle)
                @memcpy(@ptradd(suffix as ref void, spos), sep as ref void, seplen as usize)
                spos = spos + seplen
                @memcpy(@ptradd(suffix as ref void, spos), mangle as ref void, mlen as usize)
                spos = spos + mlen
            }
            none => {}
        }
        ai++
    }
    @store8(@ptradd(suffix as ref void, spos), 0)

    val mono_base: ref u8 = @alloc(1024) as ref u8
    @snprintf(mono_base, 1024, "{s}__GENMONO{s}", {fn_name, suffix})
    @free(suffix)

    val old_gsubst_names: mut list[ref u8] = []
    for n in ctx.gsubst_names { @append(old_gsubst_names, n) }
    val old_gsubst_tnodes: mut list[ref void] = []
    for t in ctx.gsubst_tnodes { @append(old_gsubst_tnodes, t) }
    ctx.gsubst_names = []
    ctx.gsubst_tnodes = []

    if tparams != 0 as ref void {
        val nparms: i64 = @len(tparams as list[ref u8]) as i64
        val pi: mut i64 = 0
        for {
            if pi >= nparms { break }
            val pn_opt = @get(tparams as list[ref u8], pi as usize)
            val ta_opt = @get(type_args, pi as usize)
            match pn_opt {
                some pn => {
                    match ta_opt {
                        some ta => {
                            gsubst_push(ctx, pn as ref u8, ta as ref parser.Node)
                        }
                        none => {}
                    }
                }
                none => {}
            }
            pi++
        }
    }

    val orig_params: ref void = gfn_node.d3 as ref void
    val new_params: mut list[ref parser.Node] = []
    if orig_params != 0 as ref void {
        for param in orig_params as list[ref parser.Node] {
            @append(new_params, make_concrete_param(ctx, param))
        }
    }

    val orig_ret: ref parser.Node = gfn_node.d4 as ref parser.Node
    val new_ret: ref parser.Node = gsubst_resolve(ctx, orig_ret)
    val fn_body: ref parser.Node = gfn_node.d5 as ref parser.Node
    val branch_body: ref parser.Node = find_matching_gwhen_body(ctx, fn_body)
    val final_body: mut ref parser.Node = branch_body
    if final_body == 0 as ref parser.Node {
        final_body = fn_body
    }

    if final_body != 0 as ref parser.Node {
        val syn: mut ref parser.Node = parser.make_node(parser.NK_FN, gfn_node.line)
        syn.d0 = 0
        syn.d1 = 0 as i64
        syn.d2 = mono_base as i64
        val pl: list[ref parser.Node] = new_params
        syn.d3 = pl as i64
        syn.d4 = new_ret as i64
        syn.d5 = final_body as i64
        syn.d6 = 0

        val saved_sb = ctx.sb
        val saved_tmp = ctx.tmp
        val saved_lbl = ctx.lbl
        val saved_fn_name = ctx.fn_name
        val saved_ret_qtype = ctx.current_fn_ret_qtype
        val saved_ret_union = ctx.current_fn_ret_union
        val saved_ret_ty = ctx.current_fn_ret_ty
        val saved_expected_ty = ctx.expected_ty
        val saved_local_src_names = cg_clone_char_list(ctx.local_src_names)
        val saved_local_qbe_names = cg_clone_char_list(ctx.local_qbe_names)
        val saved_local_slot_names = cg_clone_char_list(ctx.local_slot_names)
        val saved_local_ref_types = cg_clone_char_list(ctx.local_ref_types)
        val saved_lnames = cg_clone_char_list(ctx.lnames)
        val saved_ltypes = cg_clone_char_list(ctx.ltypes)
        val saved_dvars = cg_clone_char_list(ctx.dvars)
        val saved_dqtypes = cg_clone_char_list(ctx.dqtypes)
        val saved_defer_stack = cg_clone_void_list(ctx.defer_stack)

        val temp_mono_sb: ref void = str.StringBuilder.new()
        ctx.sb = temp_mono_sb
        gen_fn_prefixed(ctx, syn, "")

        ctx.sb = saved_sb
        ctx.tmp = saved_tmp
        ctx.lbl = saved_lbl
        ctx.fn_name = saved_fn_name
        ctx.current_fn_ret_qtype = saved_ret_qtype
        ctx.current_fn_ret_union = saved_ret_union
        ctx.current_fn_ret_ty = saved_ret_ty
        ctx.expected_ty = saved_expected_ty
        ctx.local_src_names = saved_local_src_names
        ctx.local_qbe_names = saved_local_qbe_names
        ctx.local_slot_names = saved_local_slot_names
        ctx.local_ref_types = saved_local_ref_types
        ctx.lnames = saved_lnames
        ctx.ltypes = saved_ltypes
        ctx.dvars = saved_dvars
        ctx.dqtypes = saved_dqtypes
        ctx.defer_stack = saved_defer_stack
        val temp_built: ref void = str.StringBuilder.build(temp_mono_sb)
        str.StringBuilder.append_cstr(ctx.mono_sb, str.cstr(temp_built))
        str.StringBuilder.free(temp_mono_sb)
    }

    ctx.gsubst_names = old_gsubst_names
    ctx.gsubst_tnodes = old_gsubst_tnodes

    return mono_base
}

/// Extract the base name from a possibly-qualified callee (NK_IDENT or NK_FIELD).
fn generic_callee_base_name(node: ref parser.Node) ref u8! = {
    val k: i64 = node.kind
    if k == parser.NK_IDENT { return node.d0 as ref u8 }
    if k == parser.NK_FIELD { return parser.field_name(node) }
    return "unknown"
}

fn cg_is_c_escape_expr(node: ref parser.Node) bool! = {
    if node == 0 as ref parser.Node || node.kind != parser.NK_FIELD { return false }
    val cur: mut ref parser.Node = node
    for {
        if cur == 0 as ref parser.Node { return false }
        if cur.kind == parser.NK_IDENT {
            return str.rchar_cmp(cur.d0 as ref u8, "C") == 0
        }
        if cur.kind != parser.NK_FIELD { return false }
        cur = parser.field_base(cur)
    }
    return false
}

fn cg_raw_c_name(node: ref parser.Node) ref u8! = {
    if node == 0 as ref parser.Node { return "" }
    if node.kind == parser.NK_IDENT {
        val name: ref u8 = node.d0 as ref u8
        if str.rchar_cmp(name, "C") == 0 { return "" }
        return name
    }
    if node.kind == parser.NK_FIELD {
        val base_raw: ref u8 = cg_raw_c_name(parser.field_base(node))
        val fname: ref u8 = parser.field_name(node)
        if str.rchar_cmp(base_raw, "") == 0 { return fname }
        val buf: ref u8 = @alloc(512) as ref u8
        @snprintf(buf, 512, "{s}.{s}", {base_raw, fname})
        return buf
    }
    return ""
}

/// Extract the module prefix from a mangled function name.
/// E.g. "std__stdio__puts" with bare name "puts" -> "std__stdio"
pub fn extract_prefix_from_mangled(mangled: ref u8, bare_name: ref u8) ref u8! = {
    val mlen: i64 = str.len_raw(mangled)
    val blen: i64 = str.len_raw(bare_name)
    if mlen <= blen + 2 {
        return ""
    }
    val prefix_len: i64 = mlen - blen - 2
    val prefix: ref u8 = @alloc(prefix_len + 1) as ref u8
    @memcpy(prefix as ref void, mangled as ref void, prefix_len as usize)
    @store8(@ptradd(prefix as ref void, prefix_len), 0)
    return prefix
}

fn cg_register_global(ctx: ref CgCtx, src_name: ref u8, label: ref u8, qtype: ref u8, ann: ref u8) void! = {
    @append(cg_global_src_names(ctx) as list[ref u8], src_name)
    @append(cg_global_labels(ctx)    as list[ref u8], label)
    @append(cg_global_qtypes(ctx)    as list[ref u8], qtype)
    @append(cg_global_anns(ctx)      as list[ref u8], ann)
}

/// Look up a global by source name. Returns ("", "") if not found.
fn cg_lookup_global(ctx: ref CgCtx, src_name: ref u8, out_label: ref u8, out_qtype: ref u8, out_ann: ref u8) bool! = {
    val names: ref void = cg_global_src_names(ctx)
    val len: i64 = @len(names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val n_opt = @get(names, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, src_name) == 0 {
                    val lbl_opt = @get(cg_global_labels(ctx) as list[ref u8], i as usize)
                    val qty_opt = @get(cg_global_qtypes(ctx) as list[ref u8], i as usize)
                    match lbl_opt {
                        some lbl => {
                            @memcpy(out_label, lbl as ref u8, str.len_raw(lbl as ref u8) + 1)
                        }
                        none => {}
                    }
                    match qty_opt {
                        some qty => {
                            @memcpy(out_qtype, qty as ref u8, str.len_raw(qty as ref u8) + 1)
                        }
                        none => {}
                    }
                    val ann_opt = @get(cg_global_anns(ctx) as list[ref u8], i as usize)
                    match ann_opt {
                        some ann => {
                            @memcpy(out_ann, ann as ref u8, str.len_raw(ann as ref u8) + 1)
                        }
                        none => {}
                    }
                    return true
                }
            }
            none => {}
        }
        i++
    }
    return false
}

fn cg_sfields(ctx: ref CgCtx) list[ref void]! = { return ctx.sfields }
fn cg_unames(ctx: ref CgCtx) ref void! = { return ctx.unames as ref void }
fn cg_uvariants(ctx: ref CgCtx) ref void! = { return ctx.uvariants as ref void }
fn cg_fn_names(ctx: ref CgCtx) ref void! = { return ctx.fn_names as ref void }
fn cg_fn_params(ctx: ref CgCtx) ref void! = { return ctx.fn_params as ref void }
fn cg_fn_rets(ctx: ref CgCtx) ref void! = { return ctx.fn_rets as ref void }
fn cg_extern_names(ctx: ref CgCtx) ref void! = { return ctx.ext_names as ref void }
fn cg_extern_syms(ctx: ref CgCtx) ref void! = { return ctx.ext_syms as ref void }
fn cg_ext_rets(ctx: ref CgCtx) ref void! = { return ctx.ext_rets as ref void }
fn cg_tv_names(ctx: ref CgCtx) ref void! = { return ctx.tv_names as ref void }
fn cg_tv_owners(ctx: ref CgCtx) ref void! = { return ctx.tv_owners as ref void }
fn cg_tv_tags(ctx: ref CgCtx) ref void! = { return ctx.tv_tags as ref void }
fn cg_tv_fields(ctx: ref CgCtx) ref void! = { return ctx.tv_fields as ref void }
fn cg_break_lbl(ctx: ref CgCtx) i64! = { return ctx.break_lbl }
fn cg_cont_lbl(ctx: ref CgCtx) i64! = { return ctx.cont_lbl }
fn cg_set_break_lbl(ctx: mut ref CgCtx, v: i64) void! = { ctx.break_lbl = v }
fn cg_set_cont_lbl(ctx: mut ref CgCtx, v: i64) void! = { ctx.cont_lbl = v }
fn cg_defer_stack(ctx: ref CgCtx) ref void! = { return ctx.defer_stack as ref void }

fn cg_defer_push(ctx: ref CgCtx, body: ref parser.Node) void! = {
    val stack: ref void = cg_defer_stack(ctx)
    @append(stack as list[ref void], body as ref void)
}

fn cg_defer_clear(ctx: mut ref CgCtx) void! = {
    ctx.defer_stack = []
}

/// Emit all deferred statements in LIFO order.
fn cg_emit_defers(ctx: ref CgCtx) void! = {
    val stack: ref void = cg_defer_stack(ctx)
    val n: i64 = @len(stack as list[ref void]) as i64
    val i: mut i64 = n - 1
    for {
        if i < 0 { break }
        val d_opt = @get(stack as list[ref void], i as usize)
        match d_opt {
            some d => { gen_stmts(ctx, d as ref parser.Node) }
            none   => {}
        }
        i--
    }
}

fn cg_mc_names(ctx: ref CgCtx) ref void! = { return ctx.mc_names as ref void }
fn cg_mc_vals(ctx: ref CgCtx) ref void! = { return ctx.mc_vals as ref void }

fn cg_register_module_const(ctx: ref CgCtx, name: ref u8, val_str: ref u8) void! = {
    @append(cg_mc_names(ctx) as list[ref u8], name)
    @append(cg_mc_vals(ctx)  as list[ref u8], val_str)
    if !collections.IndexMap.contains(ctx.mc_index, name) {
        collections.IndexMap.set(ctx.mc_index, name, val_str as usize)
    }
}

/// Look up a module-level constant value by name. Returns "" if not found.
fn cg_const_val(ctx: ref CgCtx, name: ref u8) ref u8! = {
    match collections.IndexMap.get(ctx.mc_index, name) {
        some v => { return v as ref u8 }
        none   => { return "" }
    }
}

fn cg_is_int_const_val(cval: ref u8) bool! = {
    if cval == 0 as ref u8 || str.rchar_cmp(cval, "") == 0 { return false }
    if rchar_starts_with(cval, "d_") || rchar_starts_with(cval, "s_") { return false }
    return true
}

fn cg_fixed_arr_size_text(_: ref CgCtx, ty: ref parser.Node) ref u8! = {
    if ty == 0 as ref parser.Node || ty.kind != parser.TY_FIXED_ARR { return "0" }
    val sz_name: ref u8 = parser.fixed_arr_size_name(ty)
    if sz_name != 0 as ref u8 && str.rchar_cmp(sz_name, "") != 0 { return sz_name }
    val buf: ref u8 = @alloc(64) as ref u8
    @snprintf(buf, 64, "{lld}", {parser.fixed_arr_size(ty)})
    return buf
}

fn cg_fixed_arr_size_val(ctx: ref CgCtx, ty: ref parser.Node) i64! = {
    if ty == 0 as ref parser.Node || ty.kind != parser.TY_FIXED_ARR { return 0 }
    val sz_name: ref u8 = parser.fixed_arr_size_name(ty)
    if sz_name == 0 as ref u8 || str.rchar_cmp(sz_name, "") == 0 {
        return parser.fixed_arr_size(ty)
    }
    val exact: ref u8 = cg_const_val(ctx, sz_name)
    val ctext: mut ref u8 = exact
    if str.rchar_cmp(ctext, "") == 0 {
        val slen: i64 = str.len_raw(sz_name)
        val mapped: ref u8 = @alloc(slen * 2 + 1) as ref u8
        val si: mut i64 = 0
        val mi: mut i64 = 0
        for {
            if si >= slen { break }
            val ch: u8 = @load8(@ptradd(sz_name as ref void, si))
            if ch == 46 {
                @store8(@ptradd(mapped as ref void, mi), 95)
                @store8(@ptradd(mapped as ref void, mi + 1), 95)
                mi += 2
            } else {
                @store8(@ptradd(mapped as ref void, mi), ch)
                mi++
            }
            si++
        }
        @store8(@ptradd(mapped as ref void, mi), 0)
        ctext = cg_const_val(ctx, mapped)
    }
    if str.rchar_cmp(ctext, "") == 0 { return 0 }
    val parsed = fmt.string_to_i64(ctext)
    match parsed {
        ok v  => { return v }
        err _ => { return 0 }
    }
}

fn cg_type_size(ctx: ref CgCtx, ty: ref parser.Node) i64! = {
    if ty == 0 as ref parser.Node { return 8 }
    val k: i64 = ty.kind
    if k == parser.TY_FIXED_ARR {
        val count: i64 = cg_fixed_arr_size_val(ctx, ty)
        val elem_size: i64 = cg_type_size(ctx, parser.fixed_arr_inner(ty))
        return count * elem_size
    }
    if k == parser.TY_MUT { return cg_type_size(ctx, ty.d0 as ref parser.Node) }
    return type_size(ty)
}

fn ann_fixed_arr_close_index(ann: ref u8) i64! = {
    val len: i64 = str.len_raw(ann)
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = @load8(@ptradd(ann as ref void, i))
        if c == 93 { return i }
        i++
    }
    return -1
}

fn ann_fixed_arr_len_text(ann: ref u8) ref u8! = {
    val close_i: i64 = ann_fixed_arr_close_index(ann)
    if close_i <= 1 { return "" }
    return str.substr(ann, 1, close_i - 1)
}

fn ann_fixed_arr_inner(ann: ref u8) ref u8! = {
    val close_i: i64 = ann_fixed_arr_close_index(ann)
    val len: i64 = str.len_raw(ann)
    if close_i < 0 || close_i + 1 >= len { return "" }
    return str.substr(ann, close_i + 1, len - close_i - 1)
}

fn cg_ann_fixed_arr_len_val(ctx: ref CgCtx, ann: ref u8) i64! = {
    val ltxt: ref u8 = ann_fixed_arr_len_text(ann)
    if str.rchar_cmp(ltxt, "") == 0 { return 0 }
    val parsed = fmt.string_to_i64(ltxt)
    match parsed {
        ok v => { return v }
        err _ => {
            val ctext: ref u8 = cg_const_val(ctx, ltxt)
            if str.rchar_cmp(ctext, "") == 0 { return 0 }
            val parsed2 = fmt.string_to_i64(ctext)
            match parsed2 {
                ok v2 => { return v2 }
                err _ => { return 0 }
            }
        }
    }
}

fn cg_ann_size(ctx: ref CgCtx, ann: ref u8) i64! = {
    if str.rchar_cmp(ann, "") == 0 { return 8 }
    if rchar_starts_with(ann, "[") {
        val count: i64 = cg_ann_fixed_arr_len_val(ctx, ann)
        val inner: ref u8 = ann_fixed_arr_inner(ann)
        return count * cg_ann_size(ctx, inner)
    }
    if str.rchar_cmp(ann, "i8") == 0 || str.rchar_cmp(ann, "u8") == 0 || str.rchar_cmp(ann, "bool") == 0 || str.rchar_cmp(ann, "u8") == 0 { return 1 }
    if str.rchar_cmp(ann, "i16") == 0 || str.rchar_cmp(ann, "u16") == 0 { return 2 }
    if str.rchar_cmp(ann, "i32") == 0 || str.rchar_cmp(ann, "u32") == 0 || str.rchar_cmp(ann, "f32") == 0 { return 4 }
    if str.rchar_cmp(ann, "void") == 0 { return 0 }
    return 8
}

fn cg_ann_load_instr(ann: ref u8) ref u8! = {
    if str.rchar_cmp(ann, "f64") == 0 { return "loadd" }
    if str.rchar_cmp(ann, "f32") == 0 { return "loads" }
    if str.rchar_cmp(ann, "i32") == 0 { return "loadsw" }
    if str.rchar_cmp(ann, "u32") == 0 { return "loaduw" }
    if str.rchar_cmp(ann, "i16") == 0 { return "loadsh" }
    if str.rchar_cmp(ann, "u16") == 0 { return "loaduh" }
    if str.rchar_cmp(ann, "i8") == 0 { return "loadsb" }
    if str.rchar_cmp(ann, "u8") == 0 || str.rchar_cmp(ann, "bool") == 0 || str.rchar_cmp(ann, "u8") == 0 { return "loadub" }
    return "loadl"
}

fn cg_ann_qtype(ann: ref u8) ref u8! = {
    if str.rchar_cmp(ann, "f64") == 0 { return "d" }
    if str.rchar_cmp(ann, "f32") == 0 { return "s" }
    if str.rchar_cmp(ann, "i32") == 0 || str.rchar_cmp(ann, "u32") == 0 || str.rchar_cmp(ann, "i16") == 0 || str.rchar_cmp(ann, "u16") == 0 || str.rchar_cmp(ann, "i8") == 0 || str.rchar_cmp(ann, "u8") == 0 || str.rchar_cmp(ann, "bool") == 0 || str.rchar_cmp(ann, "u8") == 0 { return "w" }
    return "l"
}

fn cg_ann_word_extend_instr(ann: ref u8) ref u8! = {
    if str.rchar_cmp(ann, "u32") == 0 || str.rchar_cmp(ann, "u16") == 0 || str.rchar_cmp(ann, "u8") == 0 || str.rchar_cmp(ann, "bool") == 0 || str.rchar_cmp(ann, "u8") == 0 { return "extuw" }
    return "extsw"
}

fn cg_normalize_qtype(qtype: ref u8) ref u8! = {
    if qtype == 0 as ref u8 { return "" }
    val qv: i64 = qtype as i64
    if qv == 119 { return "w" }
    if qv == 108 { return "l" }
    if qv == 115 { return "s" }
    if qv == 100 { return "d" }
    if qv == 97  { return "a" }
    return qtype
}

fn cg_coerce_qtype(ctx: ref CgCtx, value: ref u8, src_qtype: ref u8, dst_qtype: ref u8) ref u8! = {
    val src_qtype_n: ref u8 = cg_normalize_qtype(src_qtype)
    val dst_qtype_n: ref u8 = cg_normalize_qtype(dst_qtype)
    if str.rchar_cmp(src_qtype_n, dst_qtype_n) == 0 { return value }
    if str.rchar_cmp(src_qtype_n, "w") == 0 && str.rchar_cmp(dst_qtype_n, "l") == 0 {
        val conv_tmp: i64 = fresh_tmp(ctx)
        val conv_buf: ref u8 = @alloc(64) as ref u8
        @snprintf(conv_buf, 64, "    %%t{lld} =l extsw {s}\n", {conv_tmp, value})
        emit(ctx, conv_buf)
        @free(conv_buf)
        val conv_res: ref u8 = @alloc(32) as ref u8
        @snprintf(conv_res, 32, "%%t{lld}", {conv_tmp})
        return conv_res
    }
    if str.rchar_cmp(src_qtype_n, "s") == 0 && str.rchar_cmp(dst_qtype_n, "d") == 0 {
        val conv_tmp: i64 = fresh_tmp(ctx)
        val conv_buf: ref u8 = @alloc(64) as ref u8
        @snprintf(conv_buf, 64, "    %%t{lld} =d exts {s}\n", {conv_tmp, value})
        emit(ctx, conv_buf)
        @free(conv_buf)
        val conv_res: ref u8 = @alloc(32) as ref u8
        @snprintf(conv_res, 32, "%%t{lld}", {conv_tmp})
        return conv_res
    }
    if str.rchar_cmp(src_qtype_n, "d") == 0 && str.rchar_cmp(dst_qtype_n, "s") == 0 {
        val conv_tmp: i64 = fresh_tmp(ctx)
        val conv_buf: ref u8 = @alloc(64) as ref u8
        @snprintf(conv_buf, 64, "    %%t{lld} =s truncd {s}\n", {conv_tmp, value})
        emit(ctx, conv_buf)
        @free(conv_buf)
        val conv_res: ref u8 = @alloc(32) as ref u8
        @snprintf(conv_res, 32, "%%t{lld}", {conv_tmp})
        return conv_res
    }
    return value
}

fn cg_ann_after_get_indices(ann: ref u8, dims: i64) ref u8! = {
    val cur: mut ref u8 = ann
    val di: mut i64 = 0
    for {
        if di >= dims { break }
        if !rchar_starts_with(cur, "[") { return "" }
        cur = ann_fixed_arr_inner(cur)
        di++
    }
    return cur
}

/// Returns true if name is a registered function.
fn cg_is_fn(ctx: ref CgCtx, name: ref u8) bool! = {
    val names: ref void = cg_fn_names(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, name) == 0 { return true }
            }
            none => {}
        }
        ni++
    }
    return false
}

/// Returns the mangled function name for a bare name, or 0 if not found.
///
/// Tries exact match first, then suffix match (e.g. "hash_string" -> "collections__hash_string").
fn cg_resolve_fn_name(ctx: ref CgCtx, name: ref u8) ref u8! = {
    val names: ref void = cg_fn_names(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val namelen: i64 = str.len_raw(name)
    val suffix: ref u8 = @alloc(namelen + 3) as ref u8
    @snprintf(suffix, namelen + 3, "__{s}", {name})
    val ni: mut i64 = 0
    val found: mut ref u8 = 0 as ref u8
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                val candidate: ref u8 = n as ref u8
                if str.rchar_cmp(candidate, name) == 0 {
                    @free(suffix)
                    cg_mark_prefix_used(ctx, "")
                    return candidate
                }
                val clen: i64 = str.len_raw(candidate)
                val slen: i64 = namelen + 2
                if clen > slen {
                    val tail: ref u8 = @ptradd(candidate, clen - slen) as ref u8
                    if str.rchar_cmp(tail, suffix) == 0 {
                        found = candidate
                    }
                }
            }
            none => {}
        }
        ni++
    }
    @free(suffix)
    if found != 0 as ref u8 {
        val prefix: ref u8 = extract_prefix_from_mangled(found, name)

        val plen: i64 = str.len_raw(prefix)
        val pi: mut i64 = 0
        for {
            if pi >= plen { break }
            val c1: u8 = @load8(@ptradd(prefix as ref void, pi))
            if pi + 1 < plen {
                val c2: u8 = @load8(@ptradd(prefix as ref void, pi + 1))
                if c1 == 95 && c2 == 95 {
                    val sub_prefix: ref u8 = @alloc(pi + 1) as ref u8
                    @memcpy(sub_prefix as ref void, prefix as ref void, pi as usize)
                    @store8(@ptradd(sub_prefix as ref void, pi), 0)
                    cg_mark_prefix_used(ctx, sub_prefix)
                    pi++
                }
            }
            pi++
        }

        cg_mark_prefix_used(ctx, prefix)
    }
    return found
}

/// Register a function's mangled name and its param list for call-site type checking.
fn cg_register_fn(ctx: ref CgCtx, mangled: ref u8, params: ref void, ret_ty: ref void) void! = {
    @append(ctx.fn_names, mangled)
    @append(ctx.fn_params as list[ref void], params)
    @append(ctx.fn_rets as list[ref void], ret_ty)
}

/// Look up param list for a mangled function name. Returns 0 if not found.
fn cg_lookup_fn_params(ctx: ref CgCtx, mangled: ref u8) ref void! = {
    val names: ref void = cg_fn_names(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, mangled) == 0 {
                    val p_opt = @get(cg_fn_params(ctx) as list[ref void], ni as usize)
                    match p_opt {
                        some p => { return p as ref void }
                        none   => { return 0 as ref void }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref void
}

/// Find a mangled function name whose suffix matches the given bare name.
/// E.g. bare name "kind_is_eq" matches mangled "parser__kind_is_eq".
/// Returns the mangled name, or empty string if not found.
fn resolve_fn_mangled(ctx: ref CgCtx, bare_name: ref u8) ref u8! = {
    val names: ref void = cg_fn_names(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                val mangled: ref u8 = n as ref u8
                val mlen: i64 = str.len_raw(mangled)
                val blen: i64 = str.len_raw(bare_name)
                if mlen > blen {
                    val suffix_pos: i64 = mlen - blen
                    if suffix_pos > 0 {
                        val sc: u8 = @load8(@ptradd(mangled as ref void, suffix_pos - 1))
                        if sc == 95 {
                            val rest: ref u8 = @ptradd(mangled as ref void, suffix_pos) as ref u8
                            if str.rchar_cmp(rest, bare_name) == 0 {
                                return mangled
                            }
                        }
                    }
                } elif mlen == blen {
                    if str.rchar_cmp(mangled, bare_name) == 0 {
                        return mangled
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return ""
}

/// Look up the return type for a mangled function name. Returns 0 if not found.
fn cg_lookup_fn_ret(ctx: ref CgCtx, mangled: ref u8) ref void! = {
    val names: ref void = cg_fn_names(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, mangled) == 0 {
                    val r_opt = @get(cg_fn_rets(ctx) as list[ref void], ni as usize)
                    match r_opt {
                        some r => { return r as ref void }
                        none   => { return 0 as ref void }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref void
}

/// Look up the return TypeExpr for a function by its simple (unmangled) name.
/// Uses suffix matching (same as cg_resolve_fn_name).
/// Returns 0 as ref parser.Node if not found.
fn cg_lookup_fn_ret_type_expr(ctx: ref CgCtx, name: ref u8) ref parser.Node! = {
    val names: ref void = cg_fn_names(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val namelen: i64 = str.len_raw(name)
    val suffix: ref u8 = @alloc(namelen + 3) as ref u8
    @snprintf(suffix, namelen + 3, "__{s}", {name})
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                val candidate: ref u8 = n as ref u8
                if str.rchar_cmp(candidate, name) == 0 {
                    val r_opt = @get(cg_fn_rets(ctx) as list[ref void], ni as usize)
                    match r_opt {
                        some r => {
			                @free(suffix)
			                return r as ref parser.Node
			            }
                        none => {}
                    }
                }
                val clen: i64 = str.len_raw(candidate)
                val slen: i64 = namelen + 2
                if clen > slen {
                    val tail: ref u8 = @ptradd(candidate, clen - slen) as ref u8
                    if str.rchar_cmp(tail, suffix) == 0 {
                        val r_opt = @get(cg_fn_rets(ctx) as list[ref void], ni as usize)
                        match r_opt {
                            some r => {
			    	@free(suffix)
				return r as ref parser.Node
			    }
                            none => {}
                        }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    @free(suffix)
    return 0 as ref parser.Node
}

/// Register an extern function: maps its declared name to its C symbol and stores return type.
fn cg_register_extern(ctx: ref CgCtx, name: ref u8, symbol: ref u8, ret_ty: ref void) void! = {
    @append(cg_extern_names(ctx) as list[ref u8], name)
    @append(cg_extern_syms(ctx)  as list[ref u8], symbol)
    @append(cg_ext_rets(ctx)     as list[ref void], ret_ty)
}

/// Look up the C symbol for an extern function name. Returns 0 if not found.
/// Tries exact match first, then suffix match (e.g. "std__os__exit" -> "exit").
fn cg_lookup_extern_symbol(ctx: ref CgCtx, name: ref u8) ref u8! = {
    val names: ref void = cg_extern_names(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, name) == 0 {
                    val s_opt = @get(cg_extern_syms(ctx) as list[ref u8], ni as usize)
                    match s_opt {
                        some s => { return s as ref u8 }
                        none   => { return 0 as ref u8 }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    val namelen: i64 = str.len_raw(name)
    val ni2: mut i64 = 0
    for {
        if ni2 >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni2 as usize)
        match n_opt {
            some n => {
                val candidate: ref u8 = n as ref u8
                val clen: i64 = str.len_raw(candidate)
                if namelen > clen {
                    val suffix_pos: i64 = namelen - clen
                    if suffix_pos > 0 {
                        val sc: u8 = @load8(@ptradd(name as ref void, suffix_pos - 1))
                        if sc == 95 {
                            val rest: ref u8 = @ptradd(name as ref void, suffix_pos) as ref u8
                            if str.rchar_cmp(rest, candidate) == 0 {
                                val s_opt = @get(cg_extern_syms(ctx) as list[ref u8], ni2 as usize)
                                match s_opt {
                                    some s => { return s as ref u8 }
                                    none => {}
                                }
                            }
                        }
                    }
                }
            }
            none => {}
        }
        ni2++
    }
    return 0 as ref u8
}

/// Look up the return type for an extern function name. Returns 0 if not found.
/// Tries exact match first, then suffix match.
fn cg_lookup_ext_ret(ctx: ref CgCtx, name: ref u8) ref void! = {
    val names: ref void = cg_extern_names(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, name) == 0 {
                    val r_opt = @get(cg_ext_rets(ctx) as list[ref void], ni as usize)
                    match r_opt {
                        some r => { return r as ref void }
                        none   => { return 0 as ref void }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    val namelen: i64 = str.len_raw(name)
    val ni2: mut i64 = 0
    for {
        if ni2 >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni2 as usize)
        match n_opt {
            some n => {
                val candidate: ref u8 = n as ref u8
                val clen: i64 = str.len_raw(candidate)
                if namelen > clen {
                    val suffix_pos: i64 = namelen - clen
                    if suffix_pos > 0 {
                        val sc: u8 = @load8(@ptradd(name as ref void, suffix_pos - 1))
                        if sc == 95 {
                            val rest: ref u8 = @ptradd(name as ref void, suffix_pos) as ref u8
                            if str.rchar_cmp(rest, candidate) == 0 {
                                val r_opt = @get(cg_ext_rets(ctx) as list[ref void], ni2 as usize)
                                match r_opt {
                                    some r => { return r as ref void }
                                    none => {}
                                }
                            }
                        }
                    }
                }
            }
            none => {}
        }
        ni2++
    }
    return 0 as ref void
}

/// Register a tagged union variant: variant_name -> (union_name, tag_index, field_type_node).
fn cg_register_tv(ctx: ref CgCtx, vname: ref u8, owner: ref u8, tag: i64, field_ty: ref void) void! = {
    @append(cg_tv_names(ctx)  as list[ref u8],  vname)
    @append(cg_tv_owners(ctx) as list[ref u8],  owner)
    @append(cg_tv_tags(ctx)   as list[i64],     tag)
    @append(cg_tv_fields(ctx) as list[ref void],field_ty)
}

/// Look up a tagged union variant by name.
/// Returns the tag index, or -1 if not found.
/// Sets out_owner and out_field_ty if found (pass as ref void pointers to ref u8 / ref void).
fn cg_lookup_tv(ctx: ref CgCtx, vname: ref u8, out_owner: ref void, out_field_ty: ref void) i64! = {
    val names: ref void = cg_tv_names(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, vname) == 0 {
                    val tag_opt = @get(cg_tv_tags(ctx) as list[i64], ni as usize)
                    val owner_opt = @get(cg_tv_owners(ctx) as list[ref u8], ni as usize)
                    val field_opt = @get(cg_tv_fields(ctx) as list[ref void], ni as usize)
                    match tag_opt {
                        some tag => {
                            match owner_opt {
                                some owner => {
                                    @store(out_owner, owner as usize)
                                }
                                none => {}
                            }
                            match field_opt {
                                some field => {
                                    @store(out_field_ty, field as usize)
                                }
                                none => {}
                            }
                            return tag as i64
                        }
                        none => {}
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return -1
}

/// Register a struct type's field list by name.
fn cg_register_struct(ctx: ref CgCtx, type_name: ref u8, fields: ref void) void! = {
    @append(cg_snames(ctx) as list[ref u8], type_name)
    @append(cg_sfields(ctx) as list[ref void], fields)
}

/// Look up the field list for a struct type name. Returns 0 if not found.
fn cg_lookup_struct(ctx: ref CgCtx, type_name: ref u8) ref void! = {
    val names: ref void = cg_snames(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, type_name) == 0 {
                    val f_opt = @get(cg_sfields(ctx) as list[ref void], ni as usize)
                    match f_opt {
                        some f => { return f as ref void }
                        none   => { return 0 as ref void }
                    }
                }
            }
            none => {}
        }
        ni++
    }

    val tlen: i64 = str.len_raw(type_name)
    val dot_pos: mut i64 = tlen - 1

    for {
        if dot_pos < 0 { break }
        val ch: u8 = @load8(@ptradd(type_name as ref void, dot_pos))
        if ch == 46 { break }
        dot_pos--
    }

    if dot_pos >= 0 {
        val bare: ref u8 = @ptradd(type_name as ref void, dot_pos + 1) as ref u8
        val ni2: mut i64 = 0
        for {
            if ni2 >= nlen { break }
            val n_opt2 = @get(names as list[ref u8], ni2 as usize)
            match n_opt2 {
                some n2 => {
                    if str.rchar_cmp(n2 as ref u8, bare) == 0 {
                        val f_opt2 = @get(cg_sfields(ctx) as list[ref void], ni2 as usize)
                        match f_opt2 {
                            some f2 => { return f2 as ref void }
                            none    => { return 0 as ref void }
                        }
                    }
                }
                none => {}
            }
            ni2++
        }
    }
    return 0 as ref void
}

/// Register an invariant expression list for a type name.
fn cg_register_invariant(ctx: ref CgCtx, type_name: ref u8, inv_list: ref void) void! = {
    @append(ctx.inv_tnames as list[ref u8], type_name)
    @append(ctx.inv_tlists as list[ref void], inv_list)
}

/// Look up the invariant expression list for a type name. Returns 0 if not found.
fn cg_lookup_invariant(ctx: ref CgCtx, type_name: ref u8) ref void! = {
    val nlen: i64 = @len(ctx.inv_tnames as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.inv_tnames as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, type_name) == 0 {
                    val il_opt = @get(ctx.inv_tlists as list[ref void], ni as usize)
                    match il_opt {
                        some il => { return il as ref void }
                        none    => { return 0 as ref void }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref void
}

/// Emit runtime invariant checks for all mut-T params in the current function.
/// No-ops in release mode.
fn cg_emit_invariant_checks(ctx: ref CgCtx) void! = {
    if ctx.release_mode { return }
    val plen: i64 = @len(ctx.inv_cur_pnames as list[ref u8]) as i64
    if plen == 0 { return }
    val pi: mut i64 = 0
    for {
        if pi >= plen { break }
        val pn_opt = @get(ctx.inv_cur_pnames as list[ref u8], pi as usize)
        val pt_opt = @get(ctx.inv_cur_ptypes as list[ref u8], pi as usize)
        match pn_opt {
            some pn => {
                match pt_opt {
                    some pt => {
                        val param_name: ref u8 = pn as ref u8
                        val type_name:  ref u8 = pt as ref u8
                        val inv_list: ref void = cg_lookup_invariant(ctx, type_name)
                        val fields:   ref void = cg_lookup_struct(ctx, type_name)
                        if inv_list != 0 as ref void && fields != 0 as ref void {
                            val flen: i64 = @len(fields as list[ref void]) as i64
                            val fi: mut i64 = 0
                            for {
                                if fi >= flen { break }
                                val f_opt = @get(fields as list[ref void], fi as usize)
                                match f_opt {
                                    some f => {
                                        val fnode: ref parser.Node = f as ref parser.Node
                                        val fname: ref u8 = fnode.d0 as ref u8
                                        val fty:   ref parser.Node = fnode.d2 as ref parser.Node
                                        val fqt:   ref u8 = qbe_type_of(fty)
                                        val foff:  i64 = field_offset(ctx, fields, fname)
                                        if str.rchar_cmp(fqt, "l") == 0 {
                                            val addr_tmp: i64 = fresh_tmp(ctx)
                                            val val_tmp:  i64 = fresh_tmp(ctx)
                                            val lbuf: ref u8 = @alloc(256) as ref u8
                                            @snprintf(lbuf, 256,
                                                "    %%t{lld} =l add %%{s}, {lld}\n    %%t{lld} =l loadl %%t{lld}\n",
                                                {addr_tmp, param_name, foff, val_tmp, addr_tmp})
                                            emit(ctx, lbuf)
                                            @free(lbuf)
                                            val tmp_str: ref u8 = @alloc(32) as ref u8
                                            @snprintf(tmp_str, 32, "{lld}", {val_tmp})
                                            cg_register_local_var(ctx, fname, tmp_str)
                                            cg_register_local_type(ctx, fname, "i64")
                                        } elif str.rchar_cmp(fqt, "w") == 0 {
                                            val addr_tmp: i64 = fresh_tmp(ctx)
                                            val w_tmp:    i64 = fresh_tmp(ctx)
                                            val val_tmp:  i64 = fresh_tmp(ctx)
                                            val lbuf: ref u8 = @alloc(256) as ref u8
                                            @snprintf(lbuf, 256,
                                                "    %%t{lld} =l add %%{s}, {lld}\n    %%t{lld} =w loadw %%t{lld}\n    %%t{lld} =l extsw %%t{lld}\n",
                                                {addr_tmp, param_name, foff, w_tmp, addr_tmp, val_tmp, w_tmp})
                                            emit(ctx, lbuf)
                                            @free(lbuf)
                                            val tmp_str: ref u8 = @alloc(32) as ref u8
                                            @snprintf(tmp_str, 32, "{lld}", {val_tmp})
                                            cg_register_local_var(ctx, fname, tmp_str)
                                            cg_register_local_type(ctx, fname, "i64")
                                        }
                                    }
                                    none => {}
                                }
                                fi++
                            }
                            val ilen: i64 = @len(inv_list as list[ref parser.Node]) as i64
                            val ii: mut i64 = 0
                            for {
                                if ii >= ilen { break }
                                val inv_opt = @get(inv_list as list[ref parser.Node], ii as usize)
                                match inv_opt {
                                    some inv => {
                                        val inv_node: ref parser.Node = inv as ref parser.Node
                                        val cv:       ref u8 = gen_expr(ctx, inv_node)
                                        val ok_lbl:   i64 = fresh_lbl(ctx)
                                        val fail_lbl: i64 = fresh_lbl(ctx)
                                        val fn_name:  ref u8 = cg_fn_name(ctx)
                                        val jbuf: ref u8 = @alloc(128) as ref u8
                                        @snprintf(jbuf, 128,
                                            "    jnz {s}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
                                            {cv, ok_lbl, fail_lbl, fail_lbl})
                                        emit(ctx, jbuf)
                                        @free(jbuf)
                                        val msg_buf: ref u8 = @alloc(512) as ref u8
                                        @snprintf(msg_buf, 512,
                                            "spectre: invariant violated for type '{s}' in '{s}'\n",
                                            {type_name, fn_name})
                                        val msg_idx: i64 = intern_string(ctx, msg_buf)
                                        @free(msg_buf)
                                        val msg_tmp: i64 = fresh_tmp(ctx)
                                        val call_buf: ref u8 = @alloc(256) as ref u8
                                        @snprintf(call_buf, 256,
                                            "    %%t{lld} =l copy $__str{lld}\n    call $dprintf(w 2, l %%t{lld})\n    call $fflush(l 0)\n    call $exit(l 1)\n    hlt\n@lbl{lld}\n",
                                            {msg_tmp, msg_idx, msg_tmp, ok_lbl})
                                        emit(ctx, call_buf)
                                        @free(call_buf)
                                    }
                                    none => {}
                                }
                                ii++
                            }
                        }
                    }
                    none => {}
                }
            }
            none => {}
        }
        pi++
    }
}

/// Register a union type's variant type-name list.
fn cg_register_union(ctx: ref CgCtx, union_name: ref u8, variants: ref void) void! = {
    @append(cg_unames(ctx) as list[ref u8], union_name)
    @append(cg_uvariants(ctx) as list[ref void], variants)
}

/// Look up the variant list for a union type. Returns 0 if not found.
fn cg_lookup_union(ctx: ref CgCtx, union_name: ref u8) ref void! = {
    val names: ref void = cg_unames(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, union_name) == 0 {
                    val v_opt = @get(cg_uvariants(ctx) as list[ref void], ni as usize)
                    match v_opt {
                        some v => { return v as ref void }
                        none   => { return 0 as ref void }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref void
}

/// Check if a type name matches any registered union (tries exact match and suffix match for mangled names).
fn is_union_type_name(ctx: ref CgCtx, type_name: ref u8) bool! = {
    if cg_lookup_union_suffix(ctx, type_name) != 0 as ref void {
        return true
    }
    val names: ref void = cg_unames(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val tlen: i64 = str.len_raw(type_name)
    val suffix_len: i64 = tlen + 2
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                val candidate: ref u8 = n as ref u8
                val clen: i64 = str.len_raw(candidate)
                if clen > suffix_len {
                    val tail: ref u8 = @ptradd(candidate, clen - suffix_len) as ref u8
                    val c1: u8 = @load8(@ptradd(tail as ref void, 0))
                    val c2: u8 = @load8(@ptradd(tail as ref void, 1))
                    if c1 == 95 && c2 == 95 {
                        val rest: ref u8 = @ptradd(tail as ref void, 2) as ref u8
                        if str.rchar_cmp(rest, type_name) == 0 {
                            return true
                        }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return false
}

/// Compute the total byte size of a struct with the given fields.
fn struct_size(ctx: ref CgCtx, fields: ref void) i64! = {
    val flen: i64 = @len(fields as list[ref void]) as i64
    val has_fa: bool = fields_have_fixed_arr(fields)
    val offset: mut i64 = 0
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fty: ref parser.Node = fnode.d2 as ref parser.Node
                if has_fa {
                    val align: i64 = type_align(fty)
                    offset = align_to(offset, align)
                }
                val fsize: mut i64 = type_size(fty)
                if fty != 0 as ref parser.Node && fty.kind == parser.TY_NAMED {
                    val tname: ref u8 = fty.d0 as ref u8
                    val union_check: ref void = cg_lookup_union_suffix(ctx, tname)
                    if union_check != 0 as ref void {
                        fsize = 16
                    } else {
                        val struct_fields: ref void = cg_lookup_struct(ctx, tname)
                        if struct_fields != 0 as ref void {
                            fsize = struct_size(ctx, struct_fields)
                        }
                    }
                }
                if has_fa {
                    offset = offset + fsize
                } else {
                    val aligned_size: i64 = align_to(fsize, 8)
                    offset = offset + aligned_size
                }
            }
            none => {}
        }
        fi++
    }
    return offset
}

fn field_offset(ctx: ref CgCtx, fields: ref void, field_name: ref u8) i64! = {
    val flen: i64 = @len(fields as list[ref void]) as i64
    val has_fa: bool = fields_have_fixed_arr(fields)
    val offset: mut i64 = 0
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fname: ref u8 = fnode.d0 as ref u8
                val fty: ref parser.Node = fnode.d2 as ref parser.Node
                if has_fa {
                    val align: i64 = type_align(fty)
                    offset = align_to(offset, align)
                }
                if str.rchar_cmp(fname, field_name) == 0 { return offset }
                val fsize: mut i64 = type_size(fty)
                if fty != 0 as ref parser.Node && fty.kind == parser.TY_NAMED {
                    val tname: ref u8 = fty.d0 as ref u8
                    val union_check: ref void = cg_lookup_union_suffix(ctx, tname)
                    if union_check != 0 as ref void {
                        fsize = 16
                    } else {
                        val struct_fields2: ref void = cg_lookup_struct(ctx, tname)
                        if struct_fields2 != 0 as ref void {
                            fsize = struct_size(ctx, struct_fields2)
                        }
                    }
                }
                if has_fa {
                    offset = offset + fsize
                } else {
                    val aligned_size: i64 = align_to(fsize, 8)
                    offset = offset + aligned_size
                }
            }
            none => {}
        }
        fi++
    }
    return -1
}

/// Look up the type name of a field in a struct by name. Returns "" if not found.
fn field_type_name(_: ref CgCtx, fields: ref void, field_name: ref u8) ref u8! = {
    val flen: i64 = @len(fields as list[ref void]) as i64
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fname: ref u8 = fnode.d0 as ref u8
                if str.rchar_cmp(fname, field_name) == 0 {
                    val fty: ref parser.Node = fnode.d2 as ref parser.Node
                    if fty != 0 as ref parser.Node {
                        return unwrap_type_name(fty)
                    }
                }
            }
            none => {}
        }
        fi++
    }
    return ""
}

/// Compute the cumulative offset for a nested field access chain (e.g., o.inner.len).
/// Returns -1 if the type cannot be resolved.
fn nested_field_offset(ctx: ref CgCtx, node: ref parser.Node, field_name: ref u8) i64! = {
    if node == 0 as ref parser.Node { return -1 }
    if node.kind == parser.NK_IDENT {
        val bname: ref u8 = node.d0 as ref u8
        val tname: mut ref u8 = cg_local_type(ctx, bname)
        if str.rchar_cmp(tname, "") == 0 {
            tname = infer_type_annotation(ctx, node)
        }
        val lookup_tname: ref u8 = cg_ann_deref(tname)
        if str.rchar_cmp(lookup_tname, "") != 0 {
            val flds: ref void = cg_lookup_struct(ctx, lookup_tname)
            if flds != 0 as ref void {
                val off: i64 = field_offset(ctx, flds, field_name)
                if off >= 0 { return off }
            }
        }
        return -1
    }
    if node.kind == parser.NK_FIELD {
        val inner_base: ref parser.Node = parser.field_base(node)
        val inner_name: ref u8 = parser.field_name(node)
        val inner_off: i64 = nested_field_offset(ctx, inner_base, inner_name)
        if inner_off < 0 { return -1 }
        val inner_type: mut ref u8 = ""
        if inner_base.kind == parser.NK_IDENT {
            val bname2: ref u8 = inner_base.d0 as ref parser.Node.d0 as ref u8
            val btname: mut ref u8 = cg_local_type(ctx, bname2)
            if str.rchar_cmp(btname, "") == 0 {
                btname = infer_type_annotation(ctx, inner_base)
            }
            val blookup: ref u8 = cg_ann_deref(btname)
            if str.rchar_cmp(blookup, "") != 0 {
                val bflds: ref void = cg_lookup_struct(ctx, blookup)
                if bflds != 0 as ref void {
                    inner_type = field_type_name(ctx, bflds, inner_name)
                }
            }
        }
        if str.rchar_cmp(inner_type, "") == 0 {
            inner_type = infer_type_annotation(ctx, node)
        }
        val lookup_inner: ref u8 = cg_ann_deref(inner_type)
        if str.rchar_cmp(lookup_inner, "") != 0 {
            val inner_flds: ref void = cg_lookup_struct(ctx, lookup_inner)
            if inner_flds != 0 as ref void {
                val final_off: i64 = field_offset(ctx, inner_flds, field_name)
                if final_off >= 0 { return inner_off + final_off }
            }
        }
        return -1
    }
    return -1
}

fn cg_dvars_clear(ctx: mut ref CgCtx) void! = {
    ctx.dvars = []
    ctx.dqtypes = []
    ctx.local_ref_types = []
    ctx.lnames = []
    ctx.ltypes = []
    ctx.local_src_names = []
    ctx.local_qbe_names = []
    ctx.local_slot_names = []
    cg_defer_clear(ctx)
    cg_set_tmp(ctx, 0)
}

fn cg_register_local_type(ctx: ref CgCtx, name: ref u8, type_name: ref u8) void! = {
    @append(ctx.lnames as list[ref u8], name)
    @append(ctx.ltypes as list[ref u8], type_name)
}

/// Register a local variable as having a reference/pointer type
fn cg_register_local_ref_type(ctx: ref CgCtx, name: ref u8) void! = {
    @append(ctx.local_ref_types as list[ref u8], name)
}

/// Check if a local variable has a reference/pointer type
fn cg_is_local_ref_type(ctx: ref CgCtx, name: ref u8) bool! = {
    val nlen: i64 = @len(ctx.local_ref_types as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.local_ref_types as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, name) == 0 { return true }
            }
            none => {}
        }
        ni++
    }
    return false
}

fn cg_local_type(ctx: ref CgCtx, name: ref u8) ref u8! = {
    val nlen: i64 = @len(ctx.lnames as list[ref u8]) as i64
    val ni: mut i64 = nlen - 1
    for {
        if ni < 0 { break }
        val n_opt = @get(ctx.lnames as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, name) == 0 {
                    val t_opt = @get(ctx.ltypes as list[ref u8], ni as usize)
                    match t_opt {
                        some t => { return t as ref u8 }
                        none   => { return "" }
                    }
                }
            }
            none => {}
        }
        ni--
    }
    return ""
}

/// Generate a struct literal inline within a parent allocation (e.g., union payload).
/// base_offset is the starting offset within the parent allocation.
fn gen_struct_lit_inline(ctx: ref CgCtx, struct_node: ref parser.Node, parent_ptr: i64, base_offset: i64, fields: ref void) void! = {
    val sfields_node: ref void = fields
    val lit_fields: ref void = struct_node.d0 as ref void

    if lit_fields == 0 as ref void { return }

    val lit_flen: i64 = @len(lit_fields as list[ref void]) as i64
    val li: mut i64 = 0
    for {
        if li >= lit_flen { break }
        val lf_opt = @get(lit_fields as list[ref void], li as usize)
        match lf_opt {
            some lf => {
                val lf_node: ref parser.Node = lf as ref parser.Node
                val lf_name: ref u8 = lf_node.d0 as ref u8
                val lf_expr: ref parser.Node = lf_node.d1 as ref parser.Node
                val off: i64 = field_offset(ctx, sfields_node, lf_name)
                if off >= 0 {
                    val actual_off: i64 = base_offset + off
                    val fptr: i64 = fresh_tmp(ctx)
                    val fbuf: ref u8 = @alloc(128) as ref u8
                    val fval: ref u8 = gen_expr(ctx, lf_expr)
                    val lit_store_op: mut ref u8 = "storel"
                    val sflen2: i64 = @len(sfields_node as list[ref void]) as i64
                    val sfi2: mut i64 = 0
                    for {
                        if sfi2 >= sflen2 { break }
                        val sf2_opt = @get(sfields_node as list[ref void], sfi2 as usize)
                        match sf2_opt {
                            some sf2 => {
                                val sf2n: ref parser.Node = sf2 as ref parser.Node
                                val sf2name: ref u8 = sf2n.d0 as ref u8
                                if str.rchar_cmp(sf2name, lf_name) == 0 {
                                    val sf2ty: ref parser.Node = sf2n.d2 as ref parser.Node
                                    val sf2qt: ref u8 = qbe_type_of(sf2ty)
                                    if str.rchar_cmp(sf2qt, "w") == 0 { lit_store_op = "storew" }
                                    elif str.rchar_cmp(sf2qt, "s") == 0 { lit_store_op = "stores" }
                                    elif str.rchar_cmp(sf2qt, "d") == 0 { lit_store_op = "stored" }
                                    sfi2 = sflen2
                                }
                            }
                            none => {}
                        }
                        sfi2++
                    }
                    @snprintf(fbuf, 128, "    %%t{lld} =l add %%t{lld}, {lld}\n    {s} {s}, %%t{lld}\n",
                        {fptr, parent_ptr, actual_off, lit_store_op, fval, fptr})
                    emit(ctx, fbuf)
                    @free(fbuf)
                }
            }
            none => {}
        }
        li++
    }
}

fn cg_dvars_add(ctx: ref CgCtx, name: ref u8, qtype: ref u8) void! = {
    @append(cg_dvars(ctx) as list[ref u8], name)
    @append(ctx.dqtypes as list[ref u8], qtype)
}

/// Get the QBE type for a variable (from dvars or inferred from local type)
fn cg_var_qbe_type(ctx: ref CgCtx, name: ref u8) ref u8! = {
    val dv: ref void = cg_dvars(ctx)
    val dlen: i64 = @len(dv as list[ref u8]) as i64
    val di: mut i64 = 0
    for {
        if di >= dlen { break }
        val d_opt = @get(dv as list[ref u8], di as usize)
        match d_opt {
            some d => {
                if str.rchar_cmp(d as ref u8, name) == 0 {
                    val q_opt = @get(ctx.dqtypes as list[ref u8], di as usize)
                    match q_opt {
                        some q => { return q as ref u8 }
                        none   => { return "l" }
                    }
                }
            }
            none => {}
        }
        di++
    }

    val ltype: ref u8 = cg_local_type(ctx, name)
    if str.rchar_cmp(ltype, "f64") == 0 {
        return "d"
    } elif str.rchar_cmp(ltype, "f32") == 0 {
        return "s"
    } elif is_word_type_name(ltype) {
        return "w"
    }
    return "l"

}

/// Register a local variable: map source name to QBE temporary name
fn cg_register_local_var(ctx: ref CgCtx, src_name: ref u8, qbe_name: ref u8) void! = {
    @append(ctx.local_src_names as list[ref u8], src_name)
    @append(ctx.local_qbe_names as list[ref u8], qbe_name)
}

/// Mark a variable as a slot (mutable, needs load/store)
fn cg_mark_as_slot(ctx: ref CgCtx, src_name: ref u8) void! = {
    @append(ctx.local_slot_names as list[ref u8], src_name)
}

/// Check if a variable is a slot (mutable)
fn cg_is_slot(ctx: ref CgCtx, src_name: ref u8) bool! = {
    val nlen: i64 = @len(ctx.local_slot_names as list[ref u8]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.local_slot_names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, src_name) == 0 {
                    return true
                }
            }
            none => {}
        }
        ni++
    }
    return false
}

/// Look up the QBE temporary name for a source variable name. Returns "" if not found.
/// Handles shadowing.
fn cg_lookup_local_var(ctx: ref CgCtx, src_name: ref u8) ref u8! = {
    val nlen: i64 = @len(ctx.local_src_names as list[ref u8]) as i64
    val ni: mut i64 = nlen - 1
    for {
        if ni < 0 { break }
        val n_opt = @get(ctx.local_src_names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref u8, src_name) == 0 {
                    val q_opt = @get(ctx.local_qbe_names as list[ref u8], ni as usize)
                    match q_opt {
                        some q => { return q as ref u8 }
                        none   => { return "" }
                    }
                }
            }
            none => {}
        }
        ni--
    }
    return ""
}

/// Convert a stored local QBE name into a usable operand reference.
/// Stored names may be raw QBE values ("%t42", "$foo") or legacy temp ids ("42").
fn cg_qbe_value_ref(qbe_name: ref u8) ref u8! = {
    if str.rchar_cmp(qbe_name, "") == 0 { return "" }
    val first: u8 = @load8(qbe_name as ref void) as u8
    val qlen: i64 = str.len_raw(qbe_name)
    val out: ref u8 = @alloc(qlen + 4) as ref u8
    if first == 37 || first == 36 {
        @memcpy(out as ref void, qbe_name as ref void, qlen + 1)
        return out
    }
    @snprintf(out, qlen + 4, "%%t{s}", {qbe_name})
    return out
}

fn cg_ann_deref(ann: ref u8) ref u8! = {
    if ann == 0 as ref u8 { return "" }
    if rchar_starts_with(ann, "mut ref ") { return @ptradd(ann, 8) as ref u8 }
    if rchar_starts_with(ann, "ref ") { return @ptradd(ann, 4) as ref u8 }
    return ann
}

fn cg_ann_is_indirect_value(ctx: ref CgCtx, ann: ref u8) bool! = {
    if str.rchar_cmp(ann, "") == 0 { return false }
    if rchar_starts_with(ann, "mut ref ") { return true }
    if rchar_starts_with(ann, "ref ") { return true }
    if rchar_starts_with(ann, "list[") { return true }
    if rchar_starts_with(ann, "slice[") { return true }
    if rchar_starts_with(ann, "option[") { return true }
    if rchar_starts_with(ann, "result[") { return true }
    if @load8(ann as ref void) as i64 == 91 { return true }
    if cg_lookup_struct(ctx, ann) != 0 as ref void { return true }
    if cg_lookup_union_suffix(ctx, ann) != 0 as ref void { return true }
    return false
}

/// Returns an empty ref u8, i.e. "" if not direct, else the qbe type ("w" or "l")
fn cg_direct_type(ctx: ref CgCtx, name: ref u8) ref u8! = {
    val dv: ref void = cg_dvars(ctx)
    val dlen: i64 = @len(dv as list[ref u8]) as i64
    val di: mut i64 = 0
    for {
        if di >= dlen { break }
        val d_opt = @get(dv as list[ref u8], di as usize)
        match d_opt {
            some d => {
                if str.rchar_cmp(d as ref u8, name) == 0 {
                    val q_opt = @get(ctx.dqtypes as list[ref u8], di as usize)
                    match q_opt {
                        some q => { return q as ref u8 }
                        none   => { return "l" }
                    }
                }
            }
            none => {}
        }
        di++
    }
    return ""
}

fn fresh_tmp(ctx: ref CgCtx) i64! = {
    val n: i64 = cg_tmp(ctx)
    cg_set_tmp(ctx, n + 1)
    return n
}

fn fresh_lbl(ctx: ref CgCtx) i64! = {
    val n: i64 = cg_lbl(ctx)
    cg_set_lbl(ctx, n + 1)
    return n
}

fn emit(ctx: ref CgCtx, s: ref u8) void! = {
    str.StringBuilder.append_cstr(cg_sb(ctx), s)
}

fn emitln(ctx: ref CgCtx, s: ref u8) void! = {
    str.StringBuilder.append_cstr(cg_sb(ctx), s)
    str.StringBuilder.append_char(cg_sb(ctx), 10)
}

fn emit_fmt(ctx: ref CgCtx, fmt: ref u8, args: untyped) void! = {
    val buf: ref u8 = @alloc(1024) as ref u8
    @snprintf(buf, 1024, fmt, args)
    emit(ctx, buf)
    @free(buf)
}

/// Returns true if the type name maps to QBE word type (w).
fn is_word_type_name(name: ref u8) bool! = {
    if str.rchar_cmp(name, "u8")   == 0 { return true }
    if str.rchar_cmp(name, "i8")   == 0 { return true }
    if str.rchar_cmp(name, "u16")  == 0 { return true }
    if str.rchar_cmp(name, "i16")  == 0 { return true }
    if str.rchar_cmp(name, "u32")  == 0 { return true }
    if str.rchar_cmp(name, "i32")  == 0 { return true }
    if str.rchar_cmp(name, "bool") == 0 { return true }
    if str.rchar_cmp(name, "u8") == 0 { return true }
    return false
}

fn is_float_type_name(name: ref u8) bool! = {
    if str.rchar_cmp(name, "f32") == 0 { return true }
    if str.rchar_cmp(name, "f64") == 0 { return true }
    return false
}

fn qbe_type_of(ty: ref parser.Node) ref u8! = {
    if ty == 0 as ref parser.Node { return "l" }
    val k: i64 = ty.kind
    if k == parser.TY_VOID    { return "w" }
    if k == parser.TY_MUT     { return qbe_type_of(ty.d0 as ref parser.Node) }
    if k == parser.TY_REF     { return "l" }
    if k == parser.TY_OPTION  { return "l" }
    if k == parser.TY_LIST    { return "l" }
    if k == parser.TY_RESULT  { return "l" }
    if k == parser.TY_SLICE   { return "l" }
    if k == parser.TY_FNPTR   { return "l" }
    if k == parser.TY_FIXED_ARR { return "a" }
    if k == parser.TY_NAMED {
        val name: ref u8 = ty.d0 as ref u8
        if str.rchar_cmp(name, "i32") == 0 || str.rchar_cmp(name, "u32") == 0 { return "w" }
        if str.rchar_cmp(name, "i8")  == 0 || str.rchar_cmp(name, "u8")  == 0 { return "w" }
        if str.rchar_cmp(name, "i16") == 0 || str.rchar_cmp(name, "u16") == 0 { return "w" }
        if str.rchar_cmp(name, "bool") == 0 { return "w" }
        if str.rchar_cmp(name, "f32") == 0 { return "s" }
        if str.rchar_cmp(name, "f64") == 0 { return "d" }
        if str.rchar_cmp(name, "u8") == 0 { return "w" }
        return "l"
    }
    return "l"
}

/// Returns true if the type is a reference/pointer type (TY_REF or TY_MUT with ref inside).
fn is_ref_type(ty: ref parser.Node) bool! = {
    if ty == 0 as ref parser.Node { return false }
    val k: i64 = ty.kind
    if k == parser.TY_REF { return true }
    if k == parser.TY_MUT { return is_ref_type(ty.d0 as ref parser.Node) }
    return false
}

/// Infer the result type from a list of statements (used for match body type inference).
/// Looks for the last expression statement's type.
fn infer_stmts_result_type(ctx: ref CgCtx, stmts: ref void) ref u8! = {
    if stmts == 0 as ref void { return "" }
    val slen: i64 = @len(stmts as list[ref void]) as i64
    if slen == 0 { return "" }
    val last_opt = @get(stmts as list[ref void], (slen - 1) as usize)
    match last_opt {
        some last => {
            val stmt: ref parser.Node = last as ref parser.Node
            return infer_stmt_result_type(ctx, stmt)
        }
        none => { return "" }
    }
}

/// Infer the result type from a single statement.
fn infer_stmt_result_type(ctx: ref CgCtx, stmt: ref parser.Node) ref u8! = {
    if stmt == 0 as ref parser.Node { return "" }
    val k: i64 = stmt.kind
    if k == parser.NK_EXPR_STMT {
        val expr: ref parser.Node = stmt.d0 as ref parser.Node
        return infer_type_annotation(ctx, expr)
    }
    if k == parser.NK_RETURN {
        val expr: ref parser.Node = stmt.d0 as ref parser.Node
        if expr != 0 as ref parser.Node {
            return infer_type_annotation(ctx, expr)
        }
    }
    return ""
}

/// Infer the type annotation string for an expression.
/// Handles: Ident (local vars, params, globals), Cast, Call (function return type).
fn infer_type_annotation(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    if expr == 0 as ref parser.Node { return "" }
    val k: i64 = expr.kind

    if k == parser.NK_INT_LIT { return "i64" }
    if k == parser.NK_FLOAT_LIT {
        if ctx.expected_ty != 0 as ref void {
            val eqt: ref u8 = qbe_type_of(ctx.expected_ty as ref parser.Node)
            if str.rchar_cmp(eqt, "s") == 0 { return "f32" }
        }
        return "f64"
    }
    if k == parser.NK_BOOL { return "bool" }
    if k == parser.NK_CHAR_LIT { return "u8" }
    if k == parser.NK_STR_LIT { return "ref u8" }

    if k == parser.NK_IDENT {
        val name: ref u8 = expr.d0 as ref u8
        val lt: ref u8 = cg_local_type(ctx, name)
        if str.rchar_cmp(lt, "") != 0 { return lt }
        val fparams: ref void = cg_lookup_fn_params(ctx, ctx.fn_name)
        if fparams != 0 as ref void {
            val plen: i64 = @len(fparams as list[ref parser.Node]) as i64
            val pi: mut i64 = 0
            for {
                if pi >= plen { break }
                val p_opt = @get(fparams as list[ref parser.Node], pi as usize)
                match p_opt {
                    some p => {
                        val pname: ref u8 = (p as ref parser.Node).d0 as ref u8
                        val pty: ref parser.Node = (p as ref parser.Node).d1 as ref parser.Node
                        if str.rchar_cmp(pname, name) == 0 {
                            return unwrap_type_name(pty)
                        }
                    }
                    none => {}
                }
                pi++
            }
        }
        return ""
    }

    if k == parser.NK_CAST {
        val cast_ty: ref parser.Node = expr.d1 as ref parser.Node
        return type_expr_to_annotation(ctx, cast_ty)
    }

    if k == parser.NK_FIELD {
        val base_expr: ref parser.Node = parser.field_base(expr)
        val field_name: ref u8 = parser.field_name(expr)
        val base_ann: ref u8 = infer_type_annotation(ctx, base_expr)
        val lookup_type: ref u8 = cg_ann_deref(base_ann)
        if str.rchar_cmp(lookup_type, "") != 0 {
            val fields: ref void = cg_lookup_struct(ctx, lookup_type)
            if fields != 0 as ref void {
                val flen: i64 = @len(fields as list[ref void]) as i64
                val fi: mut i64 = 0
                for {
                    if fi >= flen { break }
                    val f_opt = @get(fields as list[ref void], fi as usize)
                    match f_opt {
                        some f => {
                            val fnode: ref parser.Node = f as ref parser.Node
                            val fname: ref u8 = fnode.d0 as ref u8
                            if str.rchar_cmp(fname, field_name) == 0 {
                                return type_expr_to_annotation(ctx, fnode.d2 as ref parser.Node)
                            }
                        }
                        none => {}
                    }
                    fi++
                }
            }
        }
        if base_expr != 0 as ref parser.Node && base_expr.kind == parser.NK_IDENT {
            val base_name_f: ref u8 = base_expr.d0 as ref u8
            val mod_key: ref u8 = @alloc(512) as ref u8
            @snprintf(mod_key, 512, "{s}__{s}", {base_name_f, field_name})
            val mod_cval: ref u8 = cg_const_val(ctx, mod_key)
            @free(mod_key)
            if str.rchar_cmp(mod_cval, "") != 0 {
                if rchar_starts_with(mod_cval, "d_") { return "f64" }
                if rchar_starts_with(mod_cval, "s_") { return "f32" }
                return "i64"
            }
        }
        return ""
    }

    if k == parser.NK_CALL {
        val callee: ref parser.Node = parser.call_callee(expr)
        if callee != 0 as ref parser.Node && callee.kind == parser.NK_IDENT {
            val callee_name: ref u8 = callee.d0 as ref u8
            val ext_ret_expr: ref void = cg_lookup_ext_ret(ctx, callee_name)
            if ext_ret_expr != 0 as ref void {
                return type_expr_to_annotation(ctx, ext_ret_expr as ref parser.Node)
            }
            val ret_expr: ref parser.Node = cg_lookup_fn_ret_type_expr(ctx, callee_name)
            if ret_expr != 0 as ref parser.Node {
                val ann = type_expr_to_annotation(ctx, ret_expr)
                return ann
            }
            val resolved_name: ref u8 = cg_resolve_fn_name(ctx, callee_name)
            if resolved_name != 0 as ref u8 {
                val ret_expr2: ref void = cg_lookup_fn_ret(ctx, resolved_name)
                if ret_expr2 != 0 as ref void {
                    return type_expr_to_annotation(ctx, ret_expr2 as ref parser.Node)
                }
            }
        }
    }

    if k == parser.NK_TRUST {
        val trust_inner: ref parser.Node = expr.d0 as ref parser.Node
        if trust_inner != 0 as ref parser.Node {
            return infer_type_annotation(ctx, trust_inner)
        }
        return ""
    }

    if k == parser.NK_UNOP {
        return infer_type_annotation(ctx, parser.unop_inner(expr))
    }

    if k == parser.NK_DEREF {
        val inner_expr: ref parser.Node = expr.d0 as ref parser.Node
        val inner_ann: ref u8 = infer_type_annotation(ctx, inner_expr)
        if rchar_starts_with(inner_ann, "mut ref ") {
            return @ptradd(inner_ann, 8) as ref u8
        }
        if rchar_starts_with(inner_ann, "ref ") {
            return @ptradd(inner_ann, 4) as ref u8
        }
        return inner_ann
    }

    if k == parser.NK_TRY {
        val try_inner: ref parser.Node = expr.d0 as ref parser.Node
        if try_inner != 0 as ref parser.Node {
            val inner_ann: ref u8 = infer_type_annotation(ctx, try_inner)
            if str.rchar_cmp(inner_ann, "") != 0 {
                val ok_buf: ref u8 = @alloc(256) as ref u8
                val err_buf: ref u8 = @alloc(256) as ref u8
                parse_result_types(inner_ann, ok_buf, err_buf)
                if @load8(ok_buf) != 0 as u8 {
                    @free(err_buf)
                    return ok_buf
                }
                @free(ok_buf)
                @free(err_buf)
            }
        }
        return ""
    }

    if k == parser.NK_MATCH_OPT {
        val some_body: ref parser.Node = parser.match_opt_some_body(expr)
        if some_body != 0 as ref parser.Node {
            val some_stmts: ref void = some_body.d0 as ref void
            val t: ref u8 = infer_stmts_result_type(ctx, some_stmts)
            if str.rchar_cmp(t, "") != 0 { return t }
        }
        val none_body: ref parser.Node = parser.match_opt_none_body(expr)
        if none_body != 0 as ref parser.Node {
            val none_stmts: ref void = none_body.d0 as ref void
            val t2: ref u8 = infer_stmts_result_type(ctx, none_stmts)
            if str.rchar_cmp(t2, "") != 0 { return t2 }
        }
        return ""
    }

    if k == parser.NK_BINOP {
        val lhs: ref parser.Node = parser.binop_left(expr)
        val rhs: ref parser.Node = parser.binop_right(expr)
        val lhs_ann: ref u8 = infer_type_annotation(ctx, lhs)
        val rhs_ann: ref u8 = infer_type_annotation(ctx, rhs)
        
        if str.rchar_cmp(lhs_ann, "f64") == 0 || str.rchar_cmp(rhs_ann, "f64") == 0 {
            return "f64"
        }
        if str.rchar_cmp(lhs_ann, "f32") == 0 || str.rchar_cmp(rhs_ann, "f32") == 0 {
            return "f32"
        }
        
        val op: i64 = parser.binop_op(expr)
        if op == parser.OP_EQ || op == parser.OP_NE || op == parser.OP_LT ||
           op == parser.OP_GT || op == parser.OP_LE || op == parser.OP_GE {
            return "bool"
        }
        
        if op == parser.OP_AND || op == parser.OP_OR {
            return "bool"
        }
        
        return "i64"
    }

    if k == parser.NK_BUILTIN {
        val bname_ann: ref u8 = expr.d0 as ref u8
        if str.rchar_cmp(bname_ann, "get") == 0 {
            val bargs_ann: ref void = expr.d1 as ref void
            if bargs_ann != 0 as ref void {
                val blen: i64 = @len(bargs_ann as list[ref parser.Node]) as i64
                val a0_opt = @get(bargs_ann as list[ref parser.Node], 0 as usize)
                match a0_opt {
                    some a0 => {
                        val base_ann: ref u8 = infer_type_annotation(ctx, a0 as ref parser.Node)
                        if rchar_starts_with(base_ann, "list[") {
                            val la_len: i64 = str.len_raw(base_ann)
                            val elem_t: ref u8 = str.substr(base_ann, 5, la_len - 6)
                            val opt_a: ref u8 = @alloc(256) as ref u8
                            @snprintf(opt_a, 256, "option[{s}]", {elem_t})
                            return opt_a
                        }
                        if rchar_starts_with(base_ann, "[") && blen > 1 {
                            val elem_t2: ref u8 = cg_ann_after_get_indices(base_ann, blen - 1)
                            if str.rchar_cmp(elem_t2, "") != 0 {
                                val opt_a2: ref u8 = @alloc(256) as ref u8
                                @snprintf(opt_a2, 256, "option[{s}]", {elem_t2})
                                return opt_a2
                            }
                        }
                    }
                    none => {}
                }
            }
        }
    }

    return ""
}

fn gen_variadic_arg(ctx: ref CgCtx, node: ref parser.Node) ref u8! = {
    val qtype: mut ref u8 = expr_qbe_type(ctx, node)
    val value: mut ref u8 = gen_expr(ctx, node)

    if str.rchar_cmp(qtype, "w") == 0 {
        val ann: ref u8 = infer_type_annotation(ctx, node)
        val instr: mut ref u8 = "extsw"
        if str.rchar_cmp(ann, "u8") == 0
        || str.rchar_cmp(ann, "u16") == 0
        || str.rchar_cmp(ann, "u32") == 0
        || str.rchar_cmp(ann, "bool") == 0
        || str.rchar_cmp(ann, "u8") == 0 {
            instr = "extuw"
        }

        val promoted_tmp: i64 = fresh_tmp(ctx)
        val promoted_buf: ref u8 = @alloc(128) as ref u8
        @snprintf(promoted_buf, 128, "    %%t{lld} =l {s} {s}\n", {promoted_tmp, instr, value})
        emit(ctx, promoted_buf)
        @free(promoted_buf)

        val promoted_val: ref u8 = @alloc(16) as ref u8
        @snprintf(promoted_val, 16, "%%t{lld}", {promoted_tmp})
        value = promoted_val
        qtype = "l"
    } elif str.rchar_cmp(qtype, "s") == 0 {
        val promoted_tmp2: i64 = fresh_tmp(ctx)
        val promoted_buf2: ref u8 = @alloc(128) as ref u8
        @snprintf(promoted_buf2, 128, "    %%t{lld} =d exts {s}\n", {promoted_tmp2, value})
        emit(ctx, promoted_buf2)
        @free(promoted_buf2)

        val promoted_val2: ref u8 = @alloc(16) as ref u8
        @snprintf(promoted_val2, 16, "%%t{lld}", {promoted_tmp2})
        value = promoted_val2
        qtype = "d"
    }

    val arg_buf: ref u8 = @alloc(64) as ref u8
    @snprintf(arg_buf, 64, "{s} {s}", {qtype, value})
    return arg_buf
}

/// Check if a raw u8 pointer starts with a raw prefix.
fn rchar_starts_with(src: ref u8, prefix: ref u8) bool! = {
    val slen: i64 = str.len_raw(src)
    val plen: i64 = str.len_raw(prefix)
    if plen > slen { return false }
    val pi: mut i64 = 0
    for {
        if pi >= plen { break }
        if @load8(@ptradd(src, pi)) != @load8(@ptradd(prefix, pi)) { return false }
        pi++
    }
    return true
}

/// Extract the inner type from a "option[T]" annotation str. Returns "" if not an option.
fn parse_option_inner(ann: ref u8) ref u8! = {
    if !rchar_starts_with(ann, "option[") { return "" }
    val alen: i64 = str.len_raw(ann)
    if @load8(@ptradd(ann, alen - 1)) != 93 { return "" }  // not ']'
    val inner = str.substr(ann, 7, alen - 8)
    return inner
}

/// Extract the ok and err types from a "result[T, E]" annotation str. Returns 0 for each part if not a result.
/// Caller provides two 256-byte buffers for the results.
fn parse_result_types(ann: ref u8, ok_buf: ref u8, err_buf: ref u8) void! = {
    if !rchar_starts_with(ann, "result[") {
        @store8(ok_buf, 0)
        @store8(err_buf, 0)
        return
    }
    val alen: i64 = str.len_raw(ann)
    if @load8(@ptradd(ann, alen - 1)) != 93 {  // not ']'
        @store8(ok_buf, 0)
        @store8(err_buf, 0)
        return
    }
    val inner_start: i64 = 7
    val inner_end: i64 = alen - 1
    val depth: mut i64 = 0
    val split_pos: mut i64 = -1
    val i: mut i64 = inner_start
    for {
        if i >= inner_end { break }
        val c: i64 = @load8(@ptradd(ann, i))
        if c == 91 { depth = depth + 1 }       // '['
        elif c == 93 { depth = depth - 1 }     // ']'
        elif c == 44 && depth == 0 {            // ','
            split_pos = i
            break
        }
        i++
    }
    if split_pos < 0 {
        @store8(ok_buf, 0)
        @store8(err_buf, 0)
        return
    }
    val ok_len: i64 = split_pos - inner_start
    val err_len: i64 = inner_end - split_pos - 1
    val j: mut i64 = 0
    for {
        if j >= ok_len { break }
        @store8(@ptradd(ok_buf, j), @load8(@ptradd(ann, inner_start + j)))
        j++
    }
    @store8(@ptradd(ok_buf, ok_len), 0)
    val err_start: i64 = split_pos + 1
    val k: mut i64 = 0
    for {
        if k >= err_len { break }
        @store8(@ptradd(err_buf, k), @load8(@ptradd(ann, err_start + k)))
        k++
    }
    @store8(@ptradd(err_buf, err_len), 0)
}

/// Convert a TypeExpr AST node to its annotation str.
/// Handles all type kinds: NAMED, REF, MUT, RESULT, OPTION, LIST, SLICE, FIXED_ARR, FNPTR.
fn type_expr_to_annotation(ctx: ref CgCtx, ty: ref parser.Node) ref u8! = {
    if ty == 0 as ref parser.Node { return "" }
    val k: i64 = ty.kind

    if k == parser.TY_NAMED { return ty.d0 as ref u8 }
    if k == parser.TY_REF {
        val inner = type_expr_to_annotation(ctx, ty.d0 as ref parser.Node)
        val buf: ref u8 = @alloc(512) as ref u8
        @snprintf(buf, 512, "ref {s}", {inner})
        return buf
    }
    if k == parser.TY_MUT { return type_expr_to_annotation(ctx, ty.d0 as ref parser.Node) }

    if k == parser.TY_RESULT {
        val ok_ty = ty.d0 as ref parser.Node
        val err_ty = ty.d1 as ref parser.Node
        val ok_s = type_expr_to_annotation(ctx, ok_ty)
        val err_s = type_expr_to_annotation(ctx, err_ty)
        val buf: ref u8 = @alloc(512) as ref u8
        @snprintf(buf, 512, "result[{s}, {s}]", {ok_s, err_s})
        return buf
    }

    if k == parser.TY_OPTION {
        val inner = type_expr_to_annotation(ctx, ty.d0 as ref parser.Node)
        val buf: ref u8 = @alloc(512) as ref u8
        @snprintf(buf, 512, "option[{s}]", {inner})
        return buf
    }

    if k == parser.TY_LIST {
        val inner = type_expr_to_annotation(ctx, ty.d0 as ref parser.Node)
        val buf: ref u8 = @alloc(512) as ref u8
        @snprintf(buf, 512, "list[{s}]", {inner})
        return buf
    }

    if k == parser.TY_SLICE {
        val inner = type_expr_to_annotation(ctx, ty.d0 as ref parser.Node)
        val buf: ref u8 = @alloc(512) as ref u8
        @snprintf(buf, 512, "slice[{s}]", {inner})
        return buf
    }

    if k == parser.TY_FIXED_ARR {
        val count_text: ref u8 = cg_fixed_arr_size_text(ctx, ty)
        val inner = type_expr_to_annotation(ctx, ty.d1 as ref parser.Node)
        val buf: ref u8 = @alloc(512) as ref u8
        @snprintf(buf, 512, "[{s}]{s}", {count_text, inner})
        return buf
    }

    if k == parser.TY_FNPTR {
        return "fn"
    }

    return ""
}

/// Unwrap a type node to get the base named type, stripping ref/mut wrappers.
/// Returns "" if not a named type. Kept for backward compatibility.
fn unwrap_type_name(ty: ref parser.Node) ref u8! = {
    if ty == 0 as ref parser.Node { return "" }
    val k: i64 = ty.kind
    if k == parser.TY_REF { return unwrap_type_name(ty.d0 as ref parser.Node) }
    if k == parser.TY_MUT { return unwrap_type_name(ty.d0 as ref parser.Node) }
    if k == parser.TY_NAMED { return ty.d0 as ref u8 }
    return ""
}

/// Check if a type is a tagged union. Returns the union name if it is, "" otherwise.
fn is_union_type(ctx: ref CgCtx, ty: ref parser.Node) ref u8! = {
    if ty == 0 as ref parser.Node { return "" }
    val k: i64 = ty.kind
    if k == parser.TY_NAMED {
        val name: ref u8 = ty.d0 as ref u8
        val union_vars: ref void = cg_lookup_union_suffix(ctx, name)

        if union_vars != 0 as ref void {
            return name
        }

        val names: ref void = cg_unames(ctx)
        val nlen: i64 = @len(names as list[ref u8]) as i64
        val tlen: i64 = str.len_raw(name)
        val suffix_len: i64 = tlen + 2
        val ni: mut i64 = 0

        for {
            if ni >= nlen { break }
            val n_opt = @get(names as list[ref u8], ni as usize)
            match n_opt {
                some n => {
                    val candidate: ref u8 = n as ref u8
                    val clen: i64 = str.len_raw(candidate)
                    if clen > suffix_len {
                        val tail: ref u8 = @ptradd(candidate, clen - suffix_len) as ref u8
                        val c1: u8 = @load8(@ptradd(tail as ref void, 0))
                        val c2: u8 = @load8(@ptradd(tail as ref void, 1))
                        if c1 == 95 && c2 == 95 {
                            val rest: ref u8 = @ptradd(tail as ref void, 2) as ref u8
                            if str.rchar_cmp(rest, name) == 0 {
                                return name
                            }
                        }
                    }
                }
                none => {}
            }
            ni++
        }
    }
    return ""
}

fn type_size(ty: ref parser.Node) i64! = {
    if ty == 0 as ref parser.Node { return 8 }
    val k: i64 = ty.kind
    if k == parser.TY_VOID    { return 0 }
    if k == parser.TY_MUT     { return type_size(ty.d0 as ref parser.Node) }
    if k == parser.TY_REF     { return 8 }
    if k == parser.TY_LIST    { return 24 }
    if k == parser.TY_OPTION  { return 8 }
    if k == parser.TY_RESULT  { return 16 }
    if k == parser.TY_SLICE   { return 16 }
    if k == parser.TY_FNPTR   { return 8 }
    if k == parser.TY_NAMED {
        val tname: ref u8 = ty.d0 as ref u8
        if str.rchar_cmp(tname, "i8")   == 0 { return 1 }
        if str.rchar_cmp(tname, "u8")   == 0 { return 1 }
        if str.rchar_cmp(tname, "u8") == 0 { return 1 }
        if str.rchar_cmp(tname, "i16")  == 0 { return 2 }
        if str.rchar_cmp(tname, "u16")  == 0 { return 2 }
        if str.rchar_cmp(tname, "i32")  == 0 { return 4 }
        if str.rchar_cmp(tname, "u32")  == 0 { return 4 }
        if str.rchar_cmp(tname, "f32")  == 0 { return 4 }
        if str.rchar_cmp(tname, "i64")  == 0 { return 8 }
        if str.rchar_cmp(tname, "u64")  == 0 { return 8 }
        if str.rchar_cmp(tname, "f64")  == 0 { return 8 }
        if str.rchar_cmp(tname, "bool") == 0 { return 4 }
        if str.rchar_cmp(tname, "isize") == 0 { return 8 }
        if str.rchar_cmp(tname, "usize") == 0 { return 8 }
        if str.rchar_cmp(tname, "void") == 0 { return 0 }
        return 8
    }
    if k == parser.TY_FIXED_ARR {
        val count: i64 = parser.fixed_arr_size(ty)
        val elem_size: i64 = type_size(ty.d1 as ref parser.Node)
        return count * elem_size
    }
    if k == parser.TY_LIST { return 24 }
    return 8
}

fn type_align(ty: ref parser.Node) i64! = {
    if ty == 0 as ref parser.Node { return 8 }
    val k: i64 = ty.kind
    if k == parser.TY_MUT { return type_align(ty.d0 as ref parser.Node) }
    if k == parser.TY_NAMED {
        val tname: ref u8 = ty.d0 as ref u8
        if str.rchar_cmp(tname, "i8")   == 0 { return 1 }
        if str.rchar_cmp(tname, "u8")   == 0 { return 1 }
        if str.rchar_cmp(tname, "u8") == 0 { return 1 }
        if str.rchar_cmp(tname, "i16")  == 0 { return 2 }
        if str.rchar_cmp(tname, "u16")  == 0 { return 2 }
        if str.rchar_cmp(tname, "i32")  == 0 { return 4 }
        if str.rchar_cmp(tname, "u32")  == 0 { return 4 }
        if str.rchar_cmp(tname, "f32")  == 0 { return 4 }
        return 8
    }
    if k == parser.TY_FIXED_ARR { return type_align(ty.d1 as ref parser.Node) }
    return 8
}

fn align_to(n: i64, align: i64) i64! = {
    if align <= 1 { return n }
    return (n + align - 1) / align * align
}

fn fields_have_fixed_arr(fields: ref void) bool! = {
    val flen: i64 = @len(fields as list[ref void]) as i64
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fty: ref parser.Node = fnode.d2 as ref parser.Node
                if fty != 0 as ref parser.Node {
                    if fty.kind == parser.TY_FIXED_ARR { return true }
                }
            }
            none => {}
        }
        fi++
    }
    return false
}

/// Rewrite format string: {d} -> %d, {s} -> %s, etc.
/// Handles \{ and \} as escape sequences for literal { and }
fn rewrite_fmt(s: ref u8) ref u8! = {
    val slen: i64 = str.len_raw(s)
    val out: ref u8 = @alloc(slen * 2 + 1) as ref u8
    val oi: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= slen { break }
        val c: u8 = @load8(@ptradd(s as ref void, i))

        if c == 92 { // '\\'
            if i + 1 < slen {
                val next: u8 = @load8(@ptradd(s as ref void, i + 1))
                if next == 123 || next == 125 { // '{' or '}'
                    @store8(@ptradd(out as ref void, oi), next)
                    oi++
                    i += 2
                } else {
                    @store8(@ptradd(out as ref void, oi), c)
                    oi++
                    i++
                }
            } else {
                @store8(@ptradd(out as ref void, oi), c)
                oi++
                i++
            }
        } elif c == 123 { // '{'
            val j: mut i64 = i + 1
            val found: mut bool = false
            for {
                if j >= slen { break }
                val ic: u8 = @load8(@ptradd(s as ref void, j))
                if ic == 125 { found = true break } // '}'
                j++
            }
            if found {
                @store8(@ptradd(out as ref void, oi), 37) // '%'
                oi++
                val k: mut i64 = i + 1
                for {
                    if k >= j { break }
                    val sc: u8 = @load8(@ptradd(s as ref void, k))
                    @store8(@ptradd(out as ref void, oi), sc)
                    oi++
                    k++
                }
                i = j + 1
            } else {
                @store8(@ptradd(out as ref void, oi), c)
                oi++
                i++
            }
        } else {
            @store8(@ptradd(out as ref void, oi), c)
            oi++
            i++
        }
    }
    @store8(@ptradd(out as ref void, oi), 0)
    return out
}

/// Intern a string literal without format rewriting, return its global label index.
fn intern_string(ctx: ref CgCtx, s: ref u8) i64! = {
    val strs: ref void = cg_strs(ctx)
    val len: i64 = @len(strs) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(strs, i as usize)
        match s_opt {
            some existing => {
                if str.rchar_cmp(existing as ref u8, s) == 0 { return i }
            }
            none => {}
        }
        i++
    }
    val slen: i64 = str.len_raw(s)
    val scopy: ref u8 = @alloc(slen + 1) as ref u8
    @memcpy(scopy as ref void, s as ref void, slen + 1)
    @append(strs, scopy)
    val idx: i64 = cg_str_cnt(ctx)
    cg_set_str_cnt(ctx, idx + 1)
    return idx
}

/// Intern a format string with rewriting ({d} → %d), return its global label index.
fn intern_format_string(ctx: ref CgCtx, s: ref u8) i64! = {
    val rewritten: ref u8 = rewrite_fmt(s)
    val strs: ref void = cg_strs(ctx)
    val len: i64 = @len(strs) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(strs, i as usize)
        match s_opt {
            some existing => {
                if str.rchar_cmp(existing as ref u8, rewritten) == 0 { return i }
            }
            none => {}
        }
        i++
    }
    @append(strs, rewritten)
    val idx: i64 = cg_str_cnt(ctx)
    cg_set_str_cnt(ctx, idx + 1)
    return idx
}

/// Emit all interned string data sections.
fn emit_string_data(ctx: ref CgCtx) void! = {
    val strs: ref void = cg_strs(ctx)
    val len: i64 = @len(strs) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(strs, i as usize)
        match s_opt {
            some s => {
                emit_fmt(ctx, "data $__str%lld = { b \"", {i})
                // emit each byte, escaping special chars
                val sptr: ref u8 = s as ref u8
                val j: mut i64 = 0
                for {
                    val c: u8 = @load8(@ptradd(sptr, j))
                    if c == 0 { break }
                    if c == 10 {
                        emit(ctx, "\\n")
                    } elif c == 9 {
                        emit(ctx, "\\t")
                    } elif c == 34 {
                        emit(ctx, "\\\"")
                    } elif c == 92 {
                        emit(ctx, "\\\\")
                    } else {
                        val cb: ref u8 = @alloc(2) as ref u8
                        @store8(cb, c)
                        @store8(@ptradd(cb, 1), 0)
                        emit(ctx, cb)
                        @free(cb)
                    }
                    j++
                }
                emitln(ctx, "\", b 0 }")
            }
            none => {}
        }
        i++
    }
}

/// Generate an integer literal with a specific QBE type (w or l).
fn gen_int_lit_as(ctx: ref CgCtx, text: ref u8, qbe_type: ref u8) ref u8! = {
    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref u8 = @alloc(64) as ref u8
    val emit_text: mut ref u8 = text

    if @load8(text as ref void) == 48 && @load8(@ptradd(text as ref void, 1)) == 120 {
        val hex_start: ref u8 = @ptradd(text as ref void, 2) as ref u8
        val val_: mut i64 = 0
        val hi: mut i64 = 0
        for {
            val hc: i64 = @load8(@ptradd(hex_start as ref void, hi)) as i64
            if hc == 0 { break }
            val digit: mut i64 = hc - 48
            if hc >= 97 { digit = hc - 87 }
            elif hc >= 65 { digit = hc - 55 }
            val_ = val_ * 16 + digit
            hi++
        }
        val dec_buf: ref u8 = @alloc(32) as ref u8
        @snprintf(dec_buf, 32, "{lld}", {val_})
        emit_text = dec_buf
    }
    @snprintf(buf, 64, "    %%t{lld} ={s} copy {s}\n", {tmp, qbe_type, emit_text})
    emit(ctx, buf)
    @free(buf)
    val res: ref u8 = @alloc(16) as ref u8
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn normalize_static_int_text(text: ref u8) ref u8! = {
    if text == 0 as ref u8 { return "0" }
    val start: mut ref u8 = text
    val sign: mut i64 = 1
    if @load8(start as ref void) == 45 {
        sign = -1
        start = @ptradd(start as ref void, 1) as ref u8
    }
    if @load8(start as ref void) == 48 {
        val next: i64 = @load8(@ptradd(start as ref void, 1)) as i64
        if next == 120 || next == 88 {
            val hex_start: ref u8 = @ptradd(start as ref void, 2) as ref u8
            val val_: mut i64 = 0
            val hi: mut i64 = 0
            for {
                val hc: i64 = @load8(@ptradd(hex_start as ref void, hi)) as i64
                if hc == 0 { break }
                val digit: mut i64 = hc - 48
                if hc >= 97 { digit = hc - 87 }
                elif hc >= 65 { digit = hc - 55 }
                val_ = val_ * 16 + digit
                hi++
            }
            if sign < 0 { val_ = 0 - val_ }
            val dec_buf: ref u8 = @alloc(32) as ref u8
            @snprintf(dec_buf, 32, "{lld}", {val_})
            return dec_buf
        }
    }
    return text
}

fn static_global_init_value(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    if expr == 0 as ref parser.Node { return "0" }
    val k: i64 = expr.kind
    if k == parser.NK_INT_LIT {
        return normalize_static_int_text(parser.int_lit_text(expr))
    }
    if k == parser.NK_BOOL {
        val bv: i64 = expr.d0 as i64
        if bv != 0 { return "1" }
        return "0"
    }
    if k == parser.NK_CHAR_LIT {
        val cv: i64 = expr.d0 as i64
        val cv_buf: ref u8 = @alloc(32) as ref u8
        @snprintf(cv_buf, 32, "{lld}", {cv})
        return cv_buf
    }
    if k == parser.NK_IDENT {
        val cval: ref u8 = cg_const_val(ctx, expr.d0 as ref u8)
        if str.rchar_cmp(cval, "") != 0 {
            return normalize_static_int_text(cval)
        }
    }
    if k == parser.NK_UNOP {
        val uop: i64 = parser.unop_op(expr)
        val inner: ref parser.Node = parser.unop_inner(expr)
        if uop == parser.UOP_NEG && inner != 0 as ref parser.Node {
            if inner.kind == parser.NK_INT_LIT {
                val inner_val: ref u8 = normalize_static_int_text(parser.int_lit_text(inner))
                val neg_buf: ref u8 = @alloc(64) as ref u8
                @snprintf(neg_buf, 64, "-{s}", {inner_val})
                return neg_buf
            }
        }
    }
    if k == parser.NK_STR_LIT {
        val s: ref u8 = parser.str_lit_text(expr)
        val idx: i64 = intern_string(ctx, s)
        val sbuf: ref u8 = @alloc(64) as ref u8
        @snprintf(sbuf, 64, "$__str{lld}", {idx})
        return sbuf
    }
    return ""
}

fn global_fixed_arr_type_qbe(ty: ref parser.Node) ref u8! = {
    if ty == 0 as ref parser.Node { return "l" }
    val k: i64 = ty.kind
    if k == parser.TY_MUT { return global_fixed_arr_type_qbe(ty.d0 as ref parser.Node) }
    if k == parser.TY_FIXED_ARR { return global_fixed_arr_type_qbe(ty.d1 as ref parser.Node) }
    if k == parser.TY_NAMED {
        val name: ref u8 = ty.d0 as ref u8
        if str.rchar_cmp(name, "i8") == 0 || str.rchar_cmp(name, "u8") == 0 || str.rchar_cmp(name, "u8") == 0 {
            return "b"
        }
        if str.rchar_cmp(name, "i16") == 0 || str.rchar_cmp(name, "u16") == 0 {
            return "h"
        }
        if str.rchar_cmp(name, "i32") == 0 || str.rchar_cmp(name, "u32") == 0 || str.rchar_cmp(name, "bool") == 0 {
            return "w"
        }
        if str.rchar_cmp(name, "f32") == 0 { return "s" }
        if str.rchar_cmp(name, "f64") == 0 { return "d" }
        return "l"
    }
    return "l"
}

fn static_global_init_value_typed(ctx: ref CgCtx, ty: ref parser.Node, expr: ref parser.Node) ref u8! = {
    if expr != 0 as ref parser.Node && ty != 0 as ref parser.Node {
        val tk: i64 = ty.kind
        if tk == parser.TY_MUT {
            return static_global_init_value_typed(ctx, ty.d0 as ref parser.Node, expr)
        }
        if tk == parser.TY_NAMED {
            val tname: ref u8 = ty.d0 as ref u8
            if expr.kind == parser.NK_FLOAT_LIT {
                val ftext: ref u8 = parser.float_lit_text(expr)
                val fval: ref u8 = @alloc(128) as ref u8
                if str.rchar_cmp(tname, "f32") == 0 {
                    @snprintf(fval, 128, "s_{s}", {ftext})
                    return fval
                }
                if str.rchar_cmp(tname, "f64") == 0 {
                    @snprintf(fval, 128, "d_{s}", {ftext})
                    return fval
                }
            }
            if expr.kind == parser.NK_UNOP {
                val uop: i64 = parser.unop_op(expr)
                val inner: ref parser.Node = parser.unop_inner(expr)
                if uop == parser.UOP_NEG && inner != 0 as ref parser.Node && inner.kind == parser.NK_FLOAT_LIT {
                    val ftext2: ref u8 = parser.float_lit_text(inner)
                    val fval2: ref u8 = @alloc(128) as ref u8
                    if str.rchar_cmp(tname, "f32") == 0 {
                        @snprintf(fval2, 128, "s_-{s}", {ftext2})
                        return fval2
                    }
                    if str.rchar_cmp(tname, "f64") == 0 {
                        @snprintf(fval2, 128, "d_-{s}", {ftext2})
                        return fval2
                    }
                }
            }
        }
    }
    return static_global_init_value(ctx, expr)
}

fn append_global_fixed_arr_zero_entries(ctx: ref CgCtx, ty: ref parser.Node, out: ref void) void! = {
    if ty == 0 as ref parser.Node { return }
    val k: i64 = ty.kind
    if k == parser.TY_MUT {
        append_global_fixed_arr_zero_entries(ctx, ty.d0 as ref parser.Node, out)
        return
    }
    if k == parser.TY_FIXED_ARR {
        val count: i64 = cg_fixed_arr_size_val(ctx, ty)
        val inner: ref parser.Node = ty.d1 as ref parser.Node
        val i: mut i64 = 0
        for {
            if i >= count { break }
            append_global_fixed_arr_zero_entries(ctx, inner, out)
            i++
        }
        return
    }
    val qt: ref u8 = global_fixed_arr_type_qbe(ty)
    val zero_val: mut ref u8 = "0"
    if str.rchar_cmp(qt, "s") == 0 { zero_val = "s_0.0" }
    elif str.rchar_cmp(qt, "d") == 0 { zero_val = "d_0.0" }
    val entry: ref u8 = @alloc(64) as ref u8
    @snprintf(entry, 64, "{s} {s}", {qt, zero_val})
    @append(out as list[ref u8], entry)
}

fn collect_global_fixed_arr_entries(ctx: ref CgCtx, ty: ref parser.Node, expr: ref parser.Node, out: ref void) bool! = {
    if ty == 0 as ref parser.Node { return false }
    val k: i64 = ty.kind
    if k == parser.TY_MUT {
        return collect_global_fixed_arr_entries(ctx, ty.d0 as ref parser.Node, expr, out)
    }
    if k == parser.TY_FIXED_ARR {
        val count: i64 = cg_fixed_arr_size_val(ctx, ty)
        val inner: ref parser.Node = ty.d1 as ref parser.Node
        if expr == 0 as ref parser.Node || expr.kind == parser.NK_ZERO_INIT {
            val zi: mut i64 = 0
            for {
                if zi >= count { break }
                append_global_fixed_arr_zero_entries(ctx, inner, out)
                zi++
            }
            return true
        }
        if expr.kind != parser.NK_LIST_LIT { return false }
        val elems: ref void = expr.d0 as ref void
        val elen: i64 = @len(elems as list[ref parser.Node]) as i64
        if elen != count { return false }
        val ei: mut i64 = 0
        for {
            if ei >= count { break }
            val elem_opt = @get(elems as list[ref parser.Node], ei as usize)
            match elem_opt {
                some elem => {
                    if !collect_global_fixed_arr_entries(ctx, inner, elem as ref parser.Node, out) { return false }
                }
                none => { return false }
            }
            ei++
        }
        return true
    }
    val init_val: ref u8 = static_global_init_value_typed(ctx, ty, expr)
    if str.rchar_cmp(init_val, "") == 0 { return false }
    val qt2: ref u8 = global_fixed_arr_type_qbe(ty)
    val entry2: ref u8 = @alloc(160) as ref u8
    @snprintf(entry2, 160, "{s} {s}", {qt2, init_val})
    @append(out as list[ref u8], entry2)
    return true
}

fn emit_global_fixed_arr_literal(ctx: ref CgCtx, glabel: ref u8, gty: ref parser.Node, gexpr: ref parser.Node) bool! = {
    if gty == 0 as ref parser.Node { return false }
    val real_ty: ref parser.Node = cg_concrete_ty(ctx, gty)
    if real_ty == 0 as ref parser.Node { return false }
    val rk: i64 = real_ty.kind
    if rk != parser.TY_FIXED_ARR && rk != parser.TY_MUT { return false }
    val entries: mut list[ref u8] = []
    if !collect_global_fixed_arr_entries(ctx, real_ty, gexpr, entries as ref void) { return false }
    emit_fmt(ctx, "data $%s = { ", {glabel})
    val elen: i64 = @len(entries as list[ref u8]) as i64
    if elen == 0 {
        emit(ctx, "z 0")
    } else {
        val ei: mut i64 = 0
        for {
            if ei >= elen { break }
            if ei != 0 { emit(ctx, ", ") }
            val e_opt = @get(entries as list[ref u8], ei as usize)
            match e_opt {
                some e => { emit(ctx, e as ref u8) }
                none => {}
            }
            ei++
        }
    }
    emit(ctx, " }\n")
    return true
}

fn is_fixed_arr_type(ty: ref parser.Node) bool! = {
    if ty == 0 as ref parser.Node { return false }
    val k: i64 = ty.kind
    if k == parser.TY_FIXED_ARR { return true }
    if k == parser.TY_MUT { return is_fixed_arr_type(ty.d0 as ref parser.Node) }
    return false
}

fn emit_global_list_literal(ctx: ref CgCtx, glabel: ref u8, gexpr: ref parser.Node) bool! = {
    if gexpr == 0 as ref parser.Node || gexpr.kind != parser.NK_LIST_LIT { return false }
    val elems: ref void = gexpr.d0 as ref void
    val elen: mut i64 = 0
    if elems != 0 as ref void { elen = @len(elems as list[ref parser.Node]) as i64 }

    val init_vals: mut list[ref u8] = []
    val ei: mut i64 = 0
    for {
        if ei >= elen { break }
        val elem_opt = @get(elems as list[ref parser.Node], ei as usize)
        match elem_opt {
            some elem => {
                val init_val: ref u8 = static_global_init_value(ctx, elem as ref parser.Node)
                if str.rchar_cmp(init_val, "") == 0 { return false }
                @append(init_vals, init_val)
            }
            none => {}
        }
        ei++
    }

    val data_label: ref u8 = @alloc(576) as ref u8
    val hdr_label: ref u8 = @alloc(576) as ref u8
    @snprintf(data_label, 576, "{s}__data", {glabel})
    @snprintf(hdr_label, 576, "{s}__hdr", {glabel})

    val buf: ref u8 = @alloc(1024) as ref u8
    @snprintf(buf, 1024, "data ${s} = \\{ ", {data_label})
    emit(ctx, buf)

    if elen == 0 {
        emit(ctx, "l 0")
    } else {
        val vi: mut i64 = 0
        for {
            if vi >= elen { break }
            if vi != 0 { emit(ctx, ", ") }
            val val_opt = @get(init_vals as list[ref u8], vi as usize)
            match val_opt {
                some init_val => {
                    @snprintf(buf, 1024, "l {s}", {init_val as ref u8})
                    emit(ctx, buf)
                }
                none => {}
            }
            vi++
        }
    }
    emit(ctx, " }\n")

    val cap: mut i64 = elen
    if cap == 0 { cap = 1 }
    @snprintf(buf, 1024, "data ${s} = \\{ l ${s}, l {lld}, l {lld} \\}\n", {hdr_label, data_label, elen, cap})
    emit(ctx, buf)
    @snprintf(buf, 1024, "data ${s} = \\{ l ${s} \\}\n", {glabel, hdr_label})
    emit(ctx, buf)
    @free(buf)
    return true
}

fn emit_global_val(ctx: ref CgCtx, mod_prefix: ref u8, node: ref parser.Node) void! = {
    val gname: ref u8 = node.d0 as ref u8
    val gty_node: ref parser.Node = node.d2 as ref parser.Node
    val gexpr: ref parser.Node = node.d3 as ref parser.Node

    val gqtype: mut ref u8 = "l"
    if gty_node != 0 as ref parser.Node {
        if is_fixed_arr_type(gty_node) {
            gqtype = "l"
        } else {
            gqtype = qbe_type_of(gty_node)
        }
    } elif gexpr != 0 as ref parser.Node {
        if gexpr.kind == parser.NK_BOOL || gexpr.kind == parser.NK_CHAR_LIT { gqtype = "w" }
    }

    val gann: mut ref u8 = ""
    if gty_node != 0 as ref parser.Node {
        gann = type_expr_to_annotation(ctx, gty_node)
    } elif gexpr != 0 as ref parser.Node {
        gann = infer_type_annotation(ctx, gexpr)
    }

    val ginit: mut ref u8 = "0"
    if gexpr != 0 as ref parser.Node {
        val static_init: ref u8 = static_global_init_value(ctx, gexpr)
        if str.rchar_cmp(static_init, "") != 0 { ginit = static_init }
    }

    val glabel: ref u8 = @alloc(512) as ref u8
    if str.rchar_cmp(mod_prefix, "") == 0 {
        @snprintf(glabel, 512, "{s}", {gname})
    } else {
        @snprintf(glabel, 512, "{s}__{s}", {mod_prefix, gname})
    }

    if !emit_global_fixed_arr_literal(ctx, glabel, gty_node, gexpr) && !emit_global_list_literal(ctx, glabel, gexpr) {
        val data_buf: ref u8 = @alloc(256) as ref u8
        @snprintf(data_buf, 256, "data ${s} = \{ {s} {s} \}\n", {glabel, gqtype, ginit})
        emit(ctx, data_buf)
        @free(data_buf)
    }
    cg_register_global(ctx, gname, glabel, gqtype, gann)
}

/// Generate an expression, with integer literals using the specified QBE type.
fn gen_expr_with_type(ctx: ref CgCtx, expr: ref parser.Node, target_type: ref u8) ref u8! = {
    if expr == 0 as ref parser.Node { return "0" }
    val k: i64 = expr.kind
    if k == parser.NK_INT_LIT {
        val text: ref u8 = parser.int_lit_text(expr)
        return gen_int_lit_as(ctx, text, target_type)
    }
    if k == parser.NK_IDENT {
        val cval: ref u8 = cg_const_val(ctx, expr.d0 as ref u8)
        if cg_is_int_const_val(cval) && (str.rchar_cmp(target_type, "w") == 0 || str.rchar_cmp(target_type, "l") == 0) {
            val tmp: i64 = fresh_tmp(ctx)
            val buf: ref u8 = @alloc(64) as ref u8
            @snprintf(buf, 64, "    %%t{lld} ={s} copy {s}\n", {tmp, target_type, cval})
            emit(ctx, buf)
            @free(buf)
            val res: ref u8 = @alloc(16) as ref u8
            @snprintf(res, 16, "%%t{lld}", {tmp})
            return res
        }
    }
    if k == parser.NK_FLOAT_LIT {
        val text: ref u8 = parser.float_lit_text(expr)
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref u8 = @alloc(64) as ref u8
        if str.rchar_cmp(target_type, "s") == 0 {
            @snprintf(buf, 64, "    %%t{lld} =s copy s_{s}\n", {tmp, text})
        } elif str.rchar_cmp(target_type, "d") == 0 {
            @snprintf(buf, 64, "    %%t{lld} =d copy d_{s}\n", {tmp, text})
        } else {
            @free(buf)
            return gen_expr(ctx, expr)
        }
        emit(ctx, buf)
        @free(buf)
        val res: ref u8 = @alloc(16) as ref u8
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }
    return gen_expr(ctx, expr)
}

fn gen_expr_expected(ctx: mut ref CgCtx, expr: ref parser.Node, expected_ty: ref parser.Node) ref u8! = {
    val old_expected: ref parser.Node = ctx.expected_ty as ref parser.Node
    ctx.expected_ty = expected_ty as ref void
    val res: ref u8 = gen_expr(ctx, expr)
    ctx.expected_ty = old_expected as ref void
    return res
}

fn gen_expr(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    if expr == 0 as ref parser.Node { return "0" }

    val k: i64 = expr.kind

    if k == parser.NK_INT_LIT {
        val text: ref u8 = parser.int_lit_text(expr)
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref u8 = @alloc(64) as ref u8
        val emit_text: mut ref u8 = text

        if @load8(text as ref void) == 48 && @load8(@ptradd(text as ref void, 1)) == 120 {
            val hex_start: ref u8 = @ptradd(text as ref void, 2) as ref u8
            val val_: mut i64 = 0
            val hi: mut i64 = 0
            for {
                val hc: i64 = @load8(@ptradd(hex_start as ref void, hi)) as i64
                if hc == 0 { break }
                val digit: mut i64 = hc - 48
                if hc >= 97 { digit = hc - 87 }
                elif hc >= 65 { digit = hc - 55 }
                val_ = val_ * 16 + digit
                hi++
            }
            val dec_buf: ref u8 = @alloc(32) as ref u8
            @snprintf(dec_buf, 32, "{lld}", {val_})
            emit_text = dec_buf
        }
        @snprintf(buf, 64, "    %%t{lld} =l copy {s}\n", {tmp, emit_text})
        emit(ctx, buf)
        @free(buf)
        val res: ref u8 = @alloc(16) as ref u8
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }

    if k == parser.NK_FLOAT_LIT {
        val text2: ref u8 = parser.float_lit_text(expr)
        val tmp2: i64 = fresh_tmp(ctx)
        val buf2: ref u8 = @alloc(64) as ref u8
        val expected_qt: mut ref u8 = "d"
        if ctx.expected_ty != 0 as ref void {
            val eqt: ref u8 = qbe_type_of(ctx.expected_ty as ref parser.Node)
            if str.rchar_cmp(eqt, "s") == 0 { expected_qt = "s" }
        }
        if str.rchar_cmp(expected_qt, "s") == 0 {
            @snprintf(buf2, 64, "    %%t{lld} =s copy s_{s}\n", {tmp2, text2})
        } else {
            @snprintf(buf2, 64, "    %%t{lld} =d copy d_{s}\n", {tmp2, text2})
        }
        emit(ctx, buf2)
        @free(buf2)
        val res2: ref u8 = @alloc(16) as ref u8
        @snprintf(res2, 16, "%%t{lld}", {tmp2})
        return res2
    }

    if k == parser.NK_STR_LIT {
        val s: ref u8 = parser.str_lit_text(expr)
        val idx: i64 = intern_string(ctx, s)
        val tmp3: i64 = fresh_tmp(ctx)
        val buf3: ref u8 = @alloc(64) as ref u8
        @snprintf(buf3, 64, "    %%t{lld} =l copy $__str{lld}\n", {tmp3, idx})
        emit(ctx, buf3)
        @free(buf3)
        val res3: ref u8 = @alloc(16) as ref u8
        @snprintf(res3, 16, "%%t{lld}", {tmp3})
        return res3
    }

    if k == parser.NK_BOOL {
        val v: i64 = expr.d0 as i64
        val tmp4: i64 = fresh_tmp(ctx)
        val buf4: ref u8 = @alloc(64) as ref u8
        @snprintf(buf4, 64, "    %%t{lld} =l copy {lld}\n", {tmp4, v})
        emit(ctx, buf4)
        @free(buf4)
        val res4: ref u8 = @alloc(16) as ref u8
        @snprintf(res4, 16, "%%t{lld}", {tmp4})
        return res4
    }

    if k == parser.NK_CHAR_LIT {
        val cv: i64 = expr.d0 as i64
        val tmp_c: i64 = fresh_tmp(ctx)
        val buf_c: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_c, 64, "    %%t{lld} =l copy {lld}\n", {tmp_c, cv})
        emit(ctx, buf_c)
        @free(buf_c)
        val res_c: ref u8 = @alloc(16) as ref u8
        @snprintf(res_c, 16, "%%t{lld}", {tmp_c})
        return res_c
    }

    if k == parser.NK_NONE {
        val tmp5: i64 = fresh_tmp(ctx)
        val buf5: ref u8 = @alloc(64) as ref u8
        @snprintf(buf5, 64, "    %%t{lld} =l copy 0\n", {tmp5})
        emit(ctx, buf5)
        @free(buf5)
        val res5: ref u8 = @alloc(16) as ref u8
        @snprintf(res5, 16, "%%t{lld}", {tmp5})
        return res5
    }

    if k == parser.NK_IDENT {
        val name: ref u8 = expr.d0 as ref u8
        val cval: ref u8 = cg_const_val(ctx, name)
        if str.rchar_cmp(cval, "") != 0 {
            val tmp6: i64 = fresh_tmp(ctx)
            val buf6: ref u8 = @alloc(128) as ref u8
            val expected_qt2: mut ref u8 = ""
            if ctx.expected_ty != 0 as ref void {
                expected_qt2 = qbe_type_of(ctx.expected_ty as ref parser.Node)
            }
            if rchar_starts_with(cval, "d_") || rchar_starts_with(cval, "s_") {
                val ftext: ref u8 = @ptradd(cval as ref void, 2) as ref u8
                val emit_qt: mut ref u8 = "d"
                if rchar_starts_with(cval, "s_") { emit_qt = "s" }
                if str.rchar_cmp(expected_qt2, "s") == 0 { emit_qt = "s" }
                elif str.rchar_cmp(expected_qt2, "d") == 0 { emit_qt = "d" }
                @snprintf(buf6, 128, "    %%t{lld} ={s} copy {s}_{s}\n", {tmp6, emit_qt, emit_qt, ftext})
            } else {
                @snprintf(buf6, 128, "    %%t{lld} =l copy {s}\n", {tmp6, cval})
            }
            emit(ctx, buf6)
            @free(buf6)
            val res6: ref u8 = @alloc(16) as ref u8
            @snprintf(res6, 16, "%%t{lld}", {tmp6})
            return res6
        } else {
            val qbe_var: ref u8 = cg_lookup_local_var(ctx, name)
            if str.rchar_cmp(qbe_var, "") != 0 {
                if cg_is_slot(ctx, name) {
                    val tmp_load: i64 = fresh_tmp(ctx)
                    val buf_load: ref u8 = @alloc(128) as ref u8

                    val slot_ref: ref u8 = cg_qbe_value_ref(qbe_var)

                    val is_ref_load: bool = cg_is_local_ref_type(ctx, name)
                    if is_ref_load {
                        @snprintf(buf_load, 128, "    %%t{lld} =l loadl {s}\n", {tmp_load, slot_ref})
                    } else {
                        val qtype: ref u8 = cg_var_qbe_type(ctx, name)
                        if str.rchar_cmp(qtype, "w") == 0 {
                            val w_tmp_load: i64 = fresh_tmp(ctx)
                            val buf_w_load: ref u8 = @alloc(128) as ref u8
                            @snprintf(buf_w_load, 128, "    %%t{lld} =w loadw {s}\n", {w_tmp_load, slot_ref})
                            emit(ctx, buf_w_load)
                            @free(buf_w_load)
                            @snprintf(buf_load, 128, "    %%t{lld} =l extsw %%t{lld}\n", {tmp_load, w_tmp_load})
                        } elif str.rchar_cmp(qtype, "s") == 0 {
                            @snprintf(buf_load, 128, "    %%t{lld} =s loads {s}\n", {tmp_load, slot_ref})
                        } elif str.rchar_cmp(qtype, "d") == 0 {
                            @snprintf(buf_load, 128, "    %%t{lld} =d loadd {s}\n", {tmp_load, slot_ref})
                        } else {
                            @snprintf(buf_load, 128, "    %%t{lld} =l loadl {s}\n", {tmp_load, slot_ref})
                        }
                    }
                    emit(ctx, buf_load)
                    @free(buf_load)
                    @free(slot_ref)
                    val res_load: ref u8 = @alloc(16) as ref u8
                    @snprintf(res_load, 16, "%%t{lld}", {tmp_load})
                    return res_load
                } else {
                    return cg_qbe_value_ref(qbe_var)
                }
            }

            val dqt: ref u8 = cg_direct_type(ctx, name)
            if str.rchar_cmp(dqt, "") != 0 {
                val res_direct: ref u8 = @alloc(32) as ref u8
                @snprintf(res_direct, 32, "%%{s}", {name})
                return res_direct
            } else {
                val tmp6b: i64 = fresh_tmp(ctx)
                val buf6b: ref u8 = @alloc(128) as ref u8
                val ltype: ref u8 = cg_local_type(ctx, name)
                val fn_check: ref void = cg_lookup_fn_params(ctx, name)
                if fn_check != 0 as ref void {
                    @snprintf(buf6b, 128, "    %%t{lld} =l copy ${s}\n", {tmp6b, name})
                } else {
                    val resolved_name: ref u8 = resolve_fn_mangled(ctx, name)
                    if str.rchar_cmp(resolved_name, "") != 0 {
                        @snprintf(buf6b, 128, "    %%t{lld} =l copy ${s}\n", {tmp6b, resolved_name})
                    } elif str.rchar_cmp(ltype, "f64") == 0 {
                        @snprintf(buf6b, 128, "    %%t{lld} =d loadd %%{s}\n", {tmp6b, name})
                    } elif str.rchar_cmp(ltype, "f32") == 0 {
                        @snprintf(buf6b, 128, "    %%t{lld} =s loads %%{s}\n", {tmp6b, name})
                    } elif is_word_type_name(ltype) {
                        val w_tmp6: i64 = fresh_tmp(ctx)
                        val buf6c: ref u8 = @alloc(128) as ref u8
                        @snprintf(buf6c, 128, "    %%t{lld} =w loadw %%{s}\n", {w_tmp6, name})
                        emit(ctx, buf6c)
                        @free(buf6c)
                        @snprintf(buf6b, 128, "    %%t{lld} =l extsw %%t{lld}\n", {tmp6b, w_tmp6})
                    } else {
                        @snprintf(buf6b, 128, "    %%t{lld} =l loadl %%{s}\n", {tmp6b, name})
                    }
                }
                emit(ctx, buf6b)
                @free(buf6b)
                val res6b: ref u8 = @alloc(16) as ref u8
                @snprintf(res6b, 16, "%%t{lld}", {tmp6b})
                return res6b
            }
        }
    }

    if k == parser.NK_TRUST {
        return gen_expr(ctx, expr.d0 as ref parser.Node)
    }

    if k == parser.NK_SOME {
        val inner: ref u8 = gen_expr(ctx, expr.d0 as ref parser.Node)
        val inner_ann_some: ref u8 = infer_type_annotation(ctx, expr.d0 as ref parser.Node)
        if str.rchar_cmp(inner_ann_some, "f64") == 0 || str.rchar_cmp(inner_ann_some, "f32") == 0 {
            val box_tmp: i64 = fresh_tmp(ctx)
            val some_tmp: i64 = fresh_tmp(ctx)
            val box_buf: ref u8 = @alloc(192) as ref u8
            if str.rchar_cmp(inner_ann_some, "f64") == 0 {
                @snprintf(box_buf, 192, "    %%t{lld} =l alloc8 8\n    stored {s}, %%t{lld}\n    %%t{lld} =l add %%t{lld}, 1\n",
                    {box_tmp, inner, box_tmp, some_tmp, box_tmp})
            } else {
                @snprintf(box_buf, 192, "    %%t{lld} =l alloc8 8\n    stores {s}, %%t{lld}\n    %%t{lld} =l add %%t{lld}, 1\n",
                    {box_tmp, inner, box_tmp, some_tmp, box_tmp})
            }
            emit(ctx, box_buf)
            @free(box_buf)
            val boxed_res: ref u8 = @alloc(16) as ref u8
            @snprintf(boxed_res, 16, "%%t{lld}", {some_tmp})
            return boxed_res
        }
        val inner_node: ref parser.Node = expr.d0 as ref parser.Node
        val needs_extend: mut bool = false
        if inner_node != 0 as ref parser.Node && inner_node.kind == parser.NK_CALL {
            val callee_node: ref parser.Node = inner_node.d0 as ref parser.Node
            val callee_name: ref u8 = resolve_callee_name(ctx, callee_node)
            val resolved: ref u8 = cg_resolve_fn_name(ctx, callee_name)
            val ext_sym: ref u8 = cg_lookup_extern_symbol(ctx, callee_name)
            val use_ext: bool = resolved == 0 as ref u8 && ext_sym != 0 as ref u8
            if use_ext {
                val ret_ty: ref void = cg_lookup_ext_ret(ctx, callee_name)
                if ret_ty != 0 as ref void {
                    val ret_qtype: ref u8 = qbe_type_of(ret_ty as ref parser.Node)
                    if str.rchar_cmp(ret_qtype, "w") == 0 || str.rchar_cmp(ret_qtype, "s") == 0 {
                        needs_extend = true
                    }
                }
            }
        }

        val tmp_some: i64 = fresh_tmp(ctx)
        val buf_some: ref u8 = @alloc(128) as ref u8
        if needs_extend != 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(64) as ref u8
            @snprintf(ext_buf, 64, "    %%t{lld} =l extuw {s}\n", {ext_tmp, inner})
            emit(ctx, ext_buf)
            @free(ext_buf)
            @snprintf(buf_some, 128, "    %%t{lld} =l add %%t{lld}, 1\n", {tmp_some, ext_tmp})
        } else {
            @snprintf(buf_some, 64, "    %%t{lld} =l add {s}, 1\n", {tmp_some, inner})
        }
        emit(ctx, buf_some)
        @free(buf_some)
        val res7: ref u8 = @alloc(16) as ref u8
        @snprintf(res7, 16, "%%t{lld}", {tmp_some})
        return res7
    }

    if k == parser.NK_OK_VAL {
        val ptr_ok: i64 = fresh_tmp(ctx)
        val buf_ok: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_ok, 64, "    %%t{lld} =l call $malloc(l 16)\n    storel 0, %%t{lld}\n", {ptr_ok, ptr_ok})
        emit(ctx, buf_ok)
        @free(buf_ok)
        if expr.d0 != 0 {
            val inner_ok_expr: ref parser.Node = expr.d0 as ref parser.Node
            val inner_ok: ref u8 = gen_expr(ctx, inner_ok_expr)
            val off_ok: i64 = fresh_tmp(ctx)
            val vbuf_ok: ref u8 = @alloc(128) as ref u8
            val store_op_ok: mut ref u8 = ""
            if expr_is_float(ctx, inner_ok_expr) { store_op_ok = "stored" } else { store_op_ok = "storel" }
            @snprintf(vbuf_ok, 128, "    %%t{lld} =l add %%t{lld}, 8\n    {s} {s}, %%t{lld}\n",
                {off_ok, ptr_ok, store_op_ok, inner_ok, off_ok})
            emit(ctx, vbuf_ok)
            @free(vbuf_ok)
        }
        val res_ok: ref u8 = @alloc(16) as ref u8
        @snprintf(res_ok, 16, "%%t{lld}", {ptr_ok})
        return res_ok
    }

    if k == parser.NK_ERR_VAL {
        // result err: [tag=1:l][value:l]
        val inner2: ref u8 = gen_expr(ctx, expr.d0 as ref parser.Node)
        val ptr3: i64 = fresh_tmp(ctx)
        val buf10: ref u8 = @alloc(64) as ref u8
        @snprintf(buf10, 64, "    %%t{lld} =l call $malloc(l 16)\n    storel 1, %%t{lld}\n", {ptr3, ptr3})
        emit(ctx, buf10)
        @free(buf10)
        val off2: i64 = fresh_tmp(ctx)
        val buf11: ref u8 = @alloc(128) as ref u8
        @snprintf(buf11, 128, "    %%t{lld} =l add %%t{lld}, 8\n    storel {s}, %%t{lld}\n",
            {off2, ptr3, inner2, off2})
        emit(ctx, buf11)
        @free(buf11)
        val res8: ref u8 = @alloc(16) as ref u8
        @snprintf(res8, 16, "%%t{lld}", {ptr3})
        return res8
    }

    if k == parser.NK_BINOP {
        return gen_binop(ctx, expr)
    }

    if k == parser.NK_UNOP {
        return gen_unop(ctx, expr)
    }

    if k == parser.NK_FIELD {
        return gen_field(ctx, expr)
    }

    if k == parser.NK_CALL {
        return gen_call(ctx, expr)
    }

    if k == parser.NK_BUILTIN {
        return gen_builtin(ctx, expr)
    }

    if k == parser.NK_CAST {
        val inner_expr: ref parser.Node = expr.d0 as ref parser.Node
        val inner3: ref u8 = gen_expr(ctx, inner_expr)
        val ty: ref parser.Node = expr.d1 as ref parser.Node
        val qt: ref u8 = qbe_type_of(ty)
        val src_qt: ref u8 = expr_qbe_type(ctx, inner_expr)

        val needs_conversion: mut bool = false
        val conv_instr: mut ref u8 = "copy"

        if str.rchar_cmp(src_qt, "d") == 0 && str.rchar_cmp(qt, "l") == 0 {
            needs_conversion = true
            conv_instr = "dtosi"
        } elif str.rchar_cmp(src_qt, "d") == 0 && str.rchar_cmp(qt, "w") == 0 {
            needs_conversion = true
            conv_instr = "dtosi"
        } elif str.rchar_cmp(src_qt, "s") == 0 && str.rchar_cmp(qt, "l") == 0 {
            val tmp_conv_d: i64 = fresh_tmp(ctx)
            val buf_conv_d: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_conv_d, 128, "    %%t{lld} =d exts {s}\n", {tmp_conv_d, inner3})
            emit(ctx, buf_conv_d)
            @free(buf_conv_d)
            val tmp_conv_i: i64 = fresh_tmp(ctx)
            val buf_conv_i: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_conv_i, 128, "    %%t{lld} =l dtosi %%t{lld}\n", {tmp_conv_i, tmp_conv_d})
            emit(ctx, buf_conv_i)
            @free(buf_conv_i)
            val res_conv: ref u8 = @alloc(16) as ref u8
            @snprintf(res_conv, 16, "%%t{lld}", {tmp_conv_i})
            return res_conv
        } elif str.rchar_cmp(src_qt, "s") == 0 && str.rchar_cmp(qt, "w") == 0 {
            val tmp_conv_d: i64 = fresh_tmp(ctx)
            val buf_conv_d: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_conv_d, 128, "    %%t{lld} =d exts {s}\n", {tmp_conv_d, inner3})
            emit(ctx, buf_conv_d)
            @free(buf_conv_d)
            val tmp_conv_i: i64 = fresh_tmp(ctx)
            val buf_conv_i: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_conv_i, 128, "    %%t{lld} =w dtosi %%t{lld}\n", {tmp_conv_i, tmp_conv_d})
            emit(ctx, buf_conv_i)
            @free(buf_conv_i)
            val res_conv: ref u8 = @alloc(16) as ref u8
            @snprintf(res_conv, 16, "%%t{lld}", {tmp_conv_i})
            return res_conv
        } elif str.rchar_cmp(src_qt, "d") == 0 && str.rchar_cmp(qt, "s") == 0 {
            val tmp_conv: i64 = fresh_tmp(ctx)
            val buf_conv: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_conv, 128, "    %%t{lld} =s truncd {s}\n", {tmp_conv, inner3})
            emit(ctx, buf_conv)
            @free(buf_conv)
            val res_conv: ref u8 = @alloc(16) as ref u8
            @snprintf(res_conv, 16, "%%t{lld}", {tmp_conv})
            return res_conv
        } elif str.rchar_cmp(src_qt, "s") == 0 && str.rchar_cmp(qt, "d") == 0 {
            val tmp_conv: i64 = fresh_tmp(ctx)
            val buf_conv: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_conv, 128, "    %%t{lld} =d exts {s}\n", {tmp_conv, inner3})
            emit(ctx, buf_conv)
            @free(buf_conv)
            val res_conv: ref u8 = @alloc(16) as ref u8
            @snprintf(res_conv, 16, "%%t{lld}", {tmp_conv})
            return res_conv
        } elif str.rchar_cmp(src_qt, "l") == 0 && str.rchar_cmp(qt, "d") == 0 {
            needs_conversion = true
            conv_instr = "sltof"
        } elif str.rchar_cmp(src_qt, "l") == 0 && str.rchar_cmp(qt, "s") == 0 {
            val tmp_conv_d: i64 = fresh_tmp(ctx)
            val buf_conv_d: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_conv_d, 128, "    %%t{lld} =d sltof {s}\n", {tmp_conv_d, inner3})
            emit(ctx, buf_conv_d)
            @free(buf_conv_d)
            val tmp_conv_s: i64 = fresh_tmp(ctx)
            val buf_conv_s: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_conv_s, 128, "    %%t{lld} =s truncd %%t{lld}\n", {tmp_conv_s, tmp_conv_d})
            emit(ctx, buf_conv_s)
            @free(buf_conv_s)
            val res_conv: ref u8 = @alloc(16) as ref u8
            @snprintf(res_conv, 16, "%%t{lld}", {tmp_conv_s})
            return res_conv
        } elif str.rchar_cmp(src_qt, "w") == 0 && str.rchar_cmp(qt, "l") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(ext_buf, 128, "    %%t{lld} =l extsw {s}\n", {ext_tmp, inner3})
            emit(ctx, ext_buf)
            @free(ext_buf)
            val res_conv: ref u8 = @alloc(16) as ref u8
            @snprintf(res_conv, 16, "%%t{lld}", {ext_tmp})
            return res_conv
        } elif str.rchar_cmp(src_qt, "w") == 0 && str.rchar_cmp(qt, "d") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(ext_buf, 128, "    %%t{lld} =l extsw {s}\n", {ext_tmp, inner3})
            emit(ctx, ext_buf)
            @free(ext_buf)
            val tmp_conv: i64 = fresh_tmp(ctx)
            val buf_conv: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_conv, 128, "    %%t{lld} =d sltof %%t{lld}\n", {tmp_conv, ext_tmp})
            emit(ctx, buf_conv)
            @free(buf_conv)
            val res_conv: ref u8 = @alloc(16) as ref u8
            @snprintf(res_conv, 16, "%%t{lld}", {tmp_conv})
            return res_conv
        } elif str.rchar_cmp(src_qt, "w") == 0 && str.rchar_cmp(qt, "s") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(ext_buf, 128, "    %%t{lld} =l extsw {s}\n", {ext_tmp, inner3})
            emit(ctx, ext_buf)
            @free(ext_buf)
            val tmp_conv_d: i64 = fresh_tmp(ctx)
            val buf_conv_d: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_conv_d, 128, "    %%t{lld} =d sltof %%t{lld}\n", {tmp_conv_d, ext_tmp})
            emit(ctx, buf_conv_d)
            @free(buf_conv_d)
            val tmp_conv_s: i64 = fresh_tmp(ctx)
            val buf_conv_s: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_conv_s, 128, "    %%t{lld} =s truncd %%t{lld}\n", {tmp_conv_s, tmp_conv_d})
            emit(ctx, buf_conv_s)
            @free(buf_conv_s)
            val res_conv: ref u8 = @alloc(16) as ref u8
            @snprintf(res_conv, 16, "%%t{lld}", {tmp_conv_s})
            return res_conv
        }

        if str.rchar_cmp(qt, "w") == 0 && !needs_conversion {
            return inner3
        }

        val tmp7: i64 = fresh_tmp(ctx)
        val buf12: ref u8 = @alloc(128) as ref u8
        if needs_conversion {
            @snprintf(buf12, 128, "    %%t{lld} ={s} {s} {s}\n", {tmp7, qt, conv_instr, inner3})
        } else {
            @snprintf(buf12, 128, "    %%t{lld} ={s} copy {s}\n", {tmp7, qt, inner3})
        }
        emit(ctx, buf12)
        @free(buf12)
        val res9: ref u8 = @alloc(16) as ref u8
        @snprintf(res9, 16, "%%t{lld}", {tmp7})
        return res9
    }

    if k == parser.NK_ADDR {
        val inner4: ref parser.Node = expr.d0 as ref parser.Node
        if inner4.kind == parser.NK_IDENT {
            val iname: ref u8 = inner4.d0 as ref u8
            val resolved_fn: ref u8 = cg_resolve_fn_name(ctx, iname)
            if resolved_fn != 0 as ref u8 {
                val res_fn: ref u8 = @alloc(256) as ref u8
                @snprintf(res_fn, 256, "${s}", {resolved_fn})
                return res_fn
            }
            val qbe_var_addr: ref u8 = cg_lookup_local_var(ctx, iname)
            if str.rchar_cmp(qbe_var_addr, "") != 0 {
                if cg_is_slot(ctx, iname) {
                    val local_type_addr: ref u8 = cg_local_type(ctx, iname)
                    val slot_is_indirect_addr: mut bool = false
                    if !rchar_starts_with(local_type_addr, "ref ") &&
                       !rchar_starts_with(local_type_addr, "mut ref ") {
                        if rchar_starts_with(local_type_addr, "list[") ||
                           rchar_starts_with(local_type_addr, "slice[") ||
                           rchar_starts_with(local_type_addr, "result[") ||
                           rchar_starts_with(local_type_addr, "[") {
                            slot_is_indirect_addr = true
                        } elif str.rchar_cmp(local_type_addr, "") != 0 {
                            if cg_lookup_struct(ctx, local_type_addr) != 0 as ref void {
                                slot_is_indirect_addr = true
                            } elif cg_lookup_union_suffix(ctx, local_type_addr) != 0 as ref void {
                                slot_is_indirect_addr = true
                            }
                        }
                    }
                    if slot_is_indirect_addr {
                        return gen_list_ptr(ctx, inner4)
                    }
                    val slot_ref_addr: ref u8 = cg_qbe_value_ref(qbe_var_addr)
                    return slot_ref_addr
                }
                val vqtype4: ref u8 = cg_var_qbe_type(ctx, iname)
                val slot_tmp4: i64 = fresh_tmp(ctx)
                val store_op4: mut ref u8 = "storel"
                val alloc_op4: mut ref u8 = "alloc8"
                val alloc_sz4: mut i64 = 8
                if str.rchar_cmp(vqtype4, "w") == 0 {
                    store_op4 = "storew"
                    alloc_op4 = "alloc4"
                    alloc_sz4 = 4
                } elif str.rchar_cmp(vqtype4, "s") == 0 {
                    store_op4 = "stores"
                    alloc_op4 = "alloc4"
                    alloc_sz4 = 4
                } elif str.rchar_cmp(vqtype4, "d") == 0 {
                    store_op4 = "stored"
                }
                val val_ref4: ref u8 = cg_qbe_value_ref(qbe_var_addr)
                val spill_buf4: ref u8 = @alloc(128) as ref u8
                @snprintf(spill_buf4, 128, "    %%t{lld} =l {s} {lld}\n    {s} {s}, %%t{lld}\n",
                    {slot_tmp4, alloc_op4, alloc_sz4, store_op4, val_ref4, slot_tmp4})
                emit(ctx, spill_buf4)
                @free(spill_buf4)
                @free(val_ref4)
                val res10: ref u8 = @alloc(32) as ref u8
                @snprintf(res10, 32, "%%t{lld}", {slot_tmp4})
                return res10
            }
            val res10: ref u8 = @alloc(32) as ref u8
            @snprintf(res10, 32, "%%{s}", {iname})
            return res10
        }
        if inner4.kind == parser.NK_FIELD {
            return gen_list_ptr(ctx, inner4)
        }
        return gen_expr(ctx, inner4)
    }

    if k == parser.NK_DEREF {
        val inner5: ref u8 = gen_expr(ctx, expr.d0 as ref parser.Node)
        val tmp8: i64 = fresh_tmp(ctx)
        val buf13: ref u8 = @alloc(128) as ref u8
        @snprintf(buf13, 128, "    %%t{lld} =l loadl {s}\n", {tmp8, inner5})
        emit(ctx, buf13)
        @free(buf13)
        val res11: ref u8 = @alloc(16) as ref u8
        @snprintf(res11, 16, "%%t{lld}", {tmp8})
        return res11
    }

    if k == parser.NK_ARGS_PACK {
        // args pack — return the list pointer; caller handles unpacking
        val elist: ref void = expr.d0 as ref void
        val elen: i64 = @len(elist) as i64
        if elen == 0 { return "0" }
        // just return the first element for single-arg packs
        val e_opt = @get(elist, 0)
        match e_opt {
            some e => { return gen_expr(ctx, e as ref parser.Node) }
            none => { return "0" }
        }
    }

    if k == parser.NK_LIST_LIT {
        return gen_list_lit(ctx, expr)
    }

    if k == parser.NK_STRUCT_LIT {
        return gen_struct_lit(ctx, expr)
    }

    if k == parser.NK_ZERO_INIT {
        val tmp9: i64 = fresh_tmp(ctx)
        val buf14: ref u8 = @alloc(64) as ref u8
        @snprintf(buf14, 64, "    %%t{lld} =l alloc8 64\n    call $memset(l %%t{lld}, w 0, l 64)\n", {tmp9, tmp9})
        emit(ctx, buf14)
        @free(buf14)
        val res12: ref u8 = @alloc(16) as ref u8
        @snprintf(res12, 16, "%%t{lld}", {tmp9})
        return res12
    }

    if k == parser.NK_TRY {
        return gen_try(ctx, expr)
    }

    // fallback
    val tmp10: i64 = fresh_tmp(ctx)
    val buf15: ref u8 = @alloc(64) as ref u8
    @snprintf(buf15, 64, "    %%t{lld} =l copy 0\n", {tmp10})
    emit(ctx, buf15)
    @free(buf15)
    val res13: ref u8 = @alloc(16) as ref u8
    @snprintf(res13, 16, "%%t{lld}", {tmp10})
    return res13
}

/// Check if an expression is float-typed by examining its structure
fn expr_is_float(ctx: ref CgCtx, expr: ref parser.Node) bool! = {
    if expr == 0 as ref parser.Node { return false }
    val k: i64 = expr.kind
    if k == parser.NK_FLOAT_LIT { return true }
    if k == parser.NK_IDENT {
        val name: ref u8 = expr.d0 as ref u8
        val qtype: ref u8 = cg_direct_type(ctx, name)
        if str.rchar_cmp(qtype, "d") == 0 || str.rchar_cmp(qtype, "s") == 0 {
            return true
        }
        val ltype: ref u8 = cg_local_type(ctx, name)
        if str.rchar_cmp(ltype, "f64") == 0 || str.rchar_cmp(ltype, "f32") == 0 {
            return true
        }
        val cval: ref u8 = cg_const_val(ctx, name)
        if rchar_starts_with(cval, "d_") || rchar_starts_with(cval, "s_") {
            return true
        }
        return false
    }
    if k == parser.NK_FIELD {
        val ann: ref u8 = infer_type_annotation(ctx, expr)
        if str.rchar_cmp(ann, "f64") == 0 || str.rchar_cmp(ann, "f32") == 0 {
            return true
        }
        return false
    }
    if k == parser.NK_CALL || k == parser.NK_CAST || k == parser.NK_TRUST {
        val qtype: ref u8 = expr_qbe_type(ctx, expr)
        return str.rchar_cmp(qtype, "d") == 0 || str.rchar_cmp(qtype, "s") == 0
    }
    if k == parser.NK_BINOP {
        val lhs_float: bool = expr_is_float(ctx, parser.binop_left(expr))
        val rhs_float: bool = expr_is_float(ctx, parser.binop_right(expr))
        return lhs_float || rhs_float
    }
    if k == parser.NK_UNOP {
        return expr_is_float(ctx, parser.unop_inner(expr))
    }
    return false
}

/// Infer the QBE type of an expression.
fn expr_qbe_type(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    if expr == 0 as ref parser.Node { return "l" }

    val k: i64 = expr.kind

    if k == parser.NK_INT_LIT || k == parser.NK_STR_LIT || k == parser.NK_NONE {
        return "l"
    }
    if k == parser.NK_FLOAT_LIT {
        if ctx.expected_ty != 0 as ref void {
            val expected_qt: ref u8 = qbe_type_of(ctx.expected_ty as ref parser.Node)
            if str.rchar_cmp(expected_qt, "s") == 0 { return "s" }
        }
        return "d"
    }
    if k == parser.NK_BOOL || k == parser.NK_CHAR_LIT {
        return "w"
    }

    if k == parser.NK_IDENT {
        val name: ref u8 = expr.d0 as ref u8
        val cval_ident: ref u8 = cg_const_val(ctx, name)
        if str.rchar_cmp(cval_ident, "") != 0 {
            if rchar_starts_with(cval_ident, "s_") { return "s" }
            if rchar_starts_with(cval_ident, "d_") {
                if ctx.expected_ty != 0 as ref void {
                    val expected_qt_ident: ref u8 = qbe_type_of(ctx.expected_ty as ref parser.Node)
                    if str.rchar_cmp(expected_qt_ident, "s") == 0 { return "s" }
                }
                return "d"
            }
            return "l"
        }
        val dqt_opt: ref u8 = cg_direct_type(ctx, name)
        if str.rchar_cmp(dqt_opt, "") != 0 { return dqt_opt }

        val ltype: ref u8 = cg_local_type(ctx, name)
        if str.rchar_cmp(ltype, "") != 0 {
            if cg_is_local_ref_type(ctx, name) { return "l" }
            if is_word_type_name(ltype) { return "w" }
            if str.rchar_cmp(ltype, "f64") == 0 { return "d" }
            if str.rchar_cmp(ltype, "f32") == 0 { return "s" }
            return "l"
        }
        return "l"
    }

    if k == parser.NK_FIELD {
        val ann: ref u8 = infer_type_annotation(ctx, expr)
        if str.rchar_cmp(ann, "f64") == 0 { return "d" }
        if str.rchar_cmp(ann, "f32") == 0 { return "s" }
        if is_word_type_name(ann) { return "w" }
        return "l"
    }

    if k == parser.NK_TRUST {
        return expr_qbe_type(ctx, expr.d0 as ref parser.Node)
    }

    if k == parser.NK_CALL {
        val callee_node: ref parser.Node = parser.call_callee(expr)
        val callee_name: ref u8 = resolve_callee_name(ctx, callee_node)
        val ext_ret_ty_node: ref void = cg_lookup_ext_ret(ctx, callee_name)
        if ext_ret_ty_node != 0 as ref void {
            return qbe_type_of(ext_ret_ty_node as ref parser.Node)
        }

        val fn_ret_ty_node: ref void = cg_lookup_fn_ret(ctx, callee_name)
        if fn_ret_ty_node != 0 as ref void {
            val ret_type: ref u8 = qbe_type_of(fn_ret_ty_node as ref parser.Node)
            return ret_type
        }

        val resolved_name: ref u8 = cg_resolve_fn_name(ctx, callee_name)
        if resolved_name != 0 as ref u8 {
            val fn_ret_ty_node2: ref void = cg_lookup_fn_ret(ctx, resolved_name)
            if fn_ret_ty_node2 != 0 as ref void {
                val ret_type2: ref u8 = qbe_type_of(fn_ret_ty_node2 as ref parser.Node)
                return ret_type2
            }
        }

        val fn_ret_ty_node3: ref parser.Node = cg_lookup_fn_ret_type_expr(ctx, callee_name)
        if fn_ret_ty_node3 != 0 as ref parser.Node {
            return qbe_type_of(fn_ret_ty_node3)
        }

        return "l"
    }

    if k == parser.NK_CAST {
        val cast_ty_node: ref parser.Node = expr.d1 as ref parser.Node
        return qbe_type_of(cast_ty_node)
    }

    if k == parser.NK_BINOP {
        val lhs_qbt = expr_qbe_type(ctx, parser.binop_left(expr))
        val rhs_qbt = expr_qbe_type(ctx, parser.binop_right(expr))
        if str.rchar_cmp(lhs_qbt, "d") == 0 || str.rchar_cmp(lhs_qbt, "s") == 0 ||
           str.rchar_cmp(rhs_qbt, "d") == 0 || str.rchar_cmp(rhs_qbt, "s") == 0 {
            return "d"
        }
        if str.rchar_cmp(lhs_qbt, "l") == 0 || str.rchar_cmp(rhs_qbt, "l") == 0 {
             val op: i64 = parser.binop_op(expr)
             if op == parser.OP_EQ || op == parser.OP_NE || op == parser.OP_LT ||
                op == parser.OP_GT || op == parser.OP_LE || op == parser.OP_GE ||
                op == parser.OP_AND || op == parser.OP_OR {
                 return "w"
             }
             return "l"
        }
        return "w"
    }

    if k == parser.NK_UNOP {
        val op_qbt = expr_qbe_type(ctx, parser.unop_inner(expr))
        val op: i64 = parser.unop_op(expr)
        if op == parser.UOP_NEG { return op_qbt }
        if op == parser.UOP_NOT { return "w" }
        if op == parser.UOP_BNOT { return op_qbt }
        return "l"
    }

    return "l"
}

fn expr_is_result(expr: ref parser.Node) bool! = {
    if expr == 0 as ref parser.Node { return false }
    val k: i64 = expr.kind
    if k == parser.NK_OK_VAL || k == parser.NK_ERR_VAL { return true }
    return false
}

fn gen_binop(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    val op: i64 = expr.d0 as i64
    val lhs_expr: ref parser.Node = expr.d1 as ref parser.Node
    val rhs_expr: ref parser.Node = expr.d2 as ref parser.Node

    if op == parser.OP_AND || op == parser.OP_OR {
        val lhs: ref u8 = gen_expr(ctx, lhs_expr)
        val rhs_lbl: i64 = fresh_lbl(ctx)
        val done_lbl: i64 = fresh_lbl(ctx)
        val slot: i64 = fresh_tmp(ctx)

        val sb: ref u8 = @alloc(128) as ref u8
        @snprintf(sb, 128, "    %%t{lld} =l alloc4 1\n", {slot})
        emit(ctx, sb) @free(sb)

        val s0: ref u8 = @alloc(128) as ref u8
        @snprintf(s0, 128, "    storew {s}, %%t{lld}\n", {lhs, slot})
        emit(ctx, s0) @free(s0)

        val jb: ref u8 = @alloc(128) as ref u8
        if op == parser.OP_AND {
            @snprintf(jb, 128, "    jnz {s}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n", {lhs, rhs_lbl, done_lbl, rhs_lbl})
        } else {
            @snprintf(jb, 128, "    jnz {s}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n", {lhs, done_lbl, rhs_lbl, rhs_lbl})
        }
        emit(ctx, jb) @free(jb)

        val rhs: ref u8 = gen_expr(ctx, rhs_expr)
        val sr: ref u8 = @alloc(128) as ref u8
        @snprintf(sr, 128, "    storew {s}, %%t{lld}\n    jmp @lbl{lld}\n@lbl{lld}\n", {rhs, slot, done_lbl, done_lbl})
        emit(ctx, sr) @free(sr)

        val result: i64 = fresh_tmp(ctx)
        val lb: ref u8 = @alloc(64) as ref u8
        @snprintf(lb, 64, "    %%t{lld} =w loadw %%t{lld}\n", {result, slot})
        emit(ctx, lb) @free(lb)

        val res: ref u8 = @alloc(16) as ref u8
        @snprintf(res, 16, "%%t{lld}", {result})
        return res
    }

    val lhs_is_result: bool = expr_is_result(lhs_expr)
    val rhs_is_result: bool = expr_is_result(rhs_expr)

    if ((lhs_is_result || rhs_is_result) && (op == parser.OP_EQ || op == parser.OP_NE)) {
        val lhs: ref u8 = gen_expr(ctx, lhs_expr)
        val rhs: ref u8 = gen_expr(ctx, rhs_expr)
        val l_tag: i64 = fresh_tmp(ctx)
        val r_tag: i64 = fresh_tmp(ctx)
        val tag_buf: ref u8 = @alloc(128) as ref u8
        @snprintf(tag_buf, 128, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l loadl {s}\n", {l_tag, lhs, r_tag, rhs})
        emit(ctx, tag_buf)
        @free(tag_buf)

        val tags_eq: i64 = fresh_tmp(ctx)
        val tags_buf: ref u8 = @alloc(128) as ref u8
        @snprintf(tags_buf, 128, "    %%t{lld} =w ceql %%t{lld}, %%t{lld}\n", {tags_eq, l_tag, r_tag})
        emit(ctx, tags_buf)
        @free(tags_buf)

        val l_val_ptr: i64 = fresh_tmp(ctx)
        val r_val_ptr: i64 = fresh_tmp(ctx)
        val ptr_buf: ref u8 = @alloc(128) as ref u8
        @snprintf(ptr_buf, 128, "    %%t{lld} =l add {s}, 8\n    %%t{lld} =l add {s}, 8\n", {l_val_ptr, lhs, r_val_ptr, rhs})
        emit(ctx, ptr_buf)
        @free(ptr_buf)

        val result_literal: mut ref parser.Node = 0 as ref parser.Node
        if lhs_is_result { result_literal = lhs_expr } else { result_literal = rhs_expr }
        val payload_expr: ref parser.Node = result_literal.d0 as ref parser.Node
        val payload_is_float: bool = expr_is_float(ctx, payload_expr)

        val vals_eq: i64 = fresh_tmp(ctx)
        if payload_is_float {
            val l_val: i64 = fresh_tmp(ctx)
            val r_val: i64 = fresh_tmp(ctx)
            val load_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(load_buf, 128, "    %%t{lld} =d loadd %%t{lld}\n    %%t{lld} =d loadd %%t{lld}\n", {l_val, l_val_ptr, r_val, r_val_ptr})
            emit(ctx, load_buf)
            @free(load_buf)
            val cmp_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(cmp_buf, 128, "    %%t{lld} =w ceqd %%t{lld}, %%t{lld}\n", {vals_eq, l_val, r_val})
            emit(ctx, cmp_buf)
            @free(cmp_buf)
        } else {
            val l_val: i64 = fresh_tmp(ctx)
            val r_val: i64 = fresh_tmp(ctx)
            val load_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(load_buf, 128, "    %%t{lld} =l loadl %%t{lld}\n    %%t{lld} =l loadl %%t{lld}\n", {l_val, l_val_ptr, r_val, r_val_ptr})
            emit(ctx, load_buf)
            @free(load_buf)
            val cmp_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(cmp_buf, 128, "    %%t{lld} =w ceql %%t{lld}, %%t{lld}\n", {vals_eq, l_val, r_val})
            emit(ctx, cmp_buf)
            @free(cmp_buf)
        }

        val both: i64 = fresh_tmp(ctx)
        val and_buf: ref u8 = @alloc(128) as ref u8
        @snprintf(and_buf, 128, "    %%t{lld} =w and %%t{lld}, %%t{lld}\n", {both, tags_eq, vals_eq})
        emit(ctx, and_buf)
        @free(and_buf)

        val result: i64 = fresh_tmp(ctx)
        val res_buf: ref u8 = @alloc(128) as ref u8
        if op == parser.OP_NE {
            @snprintf(res_buf, 128, "    %%t{lld} =w ceqw %%t{lld}, 0\n", {result, both})
        } else {
            @snprintf(res_buf, 128, "    %%t{lld} =w copy %%t{lld}\n", {result, both})
        }
        emit(ctx, res_buf)
        @free(res_buf)

        val res: ref u8 = @alloc(16) as ref u8
        @snprintf(res, 16, "%%t{lld}", {result})
        return res
    }

    val is_float: bool = expr_is_float(ctx, lhs_expr) || expr_is_float(ctx, rhs_expr)
    val lhs_qbt: ref u8 = expr_qbe_type(ctx, lhs_expr)
    val rhs_qbt: ref u8 = expr_qbe_type(ctx, rhs_expr)
    val lhs_const_val: mut ref u8 = ""
    val rhs_const_val: mut ref u8 = ""
    if lhs_expr.kind == parser.NK_IDENT {
        lhs_const_val = cg_const_val(ctx, lhs_expr.d0 as ref u8)
    }
    if rhs_expr.kind == parser.NK_IDENT {
        rhs_const_val = cg_const_val(ctx, rhs_expr.d0 as ref u8)
    }
    val lhs_is_word: mut bool = str.rchar_cmp(lhs_qbt, "w") == 0
    val rhs_is_word: mut bool = str.rchar_cmp(rhs_qbt, "w") == 0
    if !lhs_is_word && lhs_expr.kind == parser.NK_CALL {
        val lhs_cn: ref parser.Node = parser.call_callee(lhs_expr)
        val lhs_cname: ref u8 = resolve_callee_name(ctx, lhs_cn)
        val lhs_ret: ref parser.Node = cg_lookup_fn_ret_type_expr(ctx, lhs_cname)
        if lhs_ret != 0 as ref parser.Node && str.rchar_cmp(qbe_type_of(lhs_ret), "w") == 0 {
            lhs_is_word = true
        }
    }
    if !rhs_is_word && rhs_expr.kind == parser.NK_CALL {
        val rhs_cn: ref parser.Node = parser.call_callee(rhs_expr)
        val rhs_cname: ref u8 = resolve_callee_name(ctx, rhs_cn)
        val rhs_ret: ref parser.Node = cg_lookup_fn_ret_type_expr(ctx, rhs_cname)
        if rhs_ret != 0 as ref parser.Node && str.rchar_cmp(qbe_type_of(rhs_ret), "w") == 0 {
            rhs_is_word = true
        }
    }
    val lhs_is_int_lit: bool = lhs_expr.kind == parser.NK_INT_LIT || (lhs_expr.kind == parser.NK_IDENT && cg_is_int_const_val(lhs_const_val))
    val rhs_is_int_lit: bool = rhs_expr.kind == parser.NK_INT_LIT || (rhs_expr.kind == parser.NK_IDENT && cg_is_int_const_val(rhs_const_val))
    val is_comparison: bool = op == parser.OP_EQ || op == parser.OP_NE || op == parser.OP_LT ||
                              op == parser.OP_GT || op == parser.OP_LE || op == parser.OP_GE
    val target_type: mut ref u8 = "l"

    if !is_float && is_comparison {
        if ((lhs_is_word && rhs_is_int_lit) || (rhs_is_word && lhs_is_int_lit)) {
            target_type = "w"
        }
    }

    val lhs: ref u8 = gen_expr_with_type(ctx, lhs_expr, target_type)
    val rhs: ref u8 = gen_expr_with_type(ctx, rhs_expr, target_type)
    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref u8 = @alloc(256) as ref u8
    val lhs_l: mut ref u8 = lhs
    val rhs_l: mut ref u8 = rhs
    val both_word: bool = (lhs_is_word && rhs_is_word) ||
                          (lhs_is_word && rhs_is_int_lit) ||
                          (rhs_is_word && lhs_is_int_lit)

    if op == parser.OP_EQ || op == parser.OP_NE || op == parser.OP_LT ||
       op == parser.OP_GT || op == parser.OP_LE || op == parser.OP_GE {
        if !both_word {
            if str.rchar_cmp(lhs_qbt, "w") == 0 {
                val ext_tmp: i64 = fresh_tmp(ctx)
                val ext_buf: ref u8 = @alloc(128) as ref u8
                @snprintf(ext_buf, 128, "    %%t{lld} =l extsw {s}\n", {ext_tmp, lhs_l})
                emit(ctx, ext_buf)
                @free(ext_buf)
                lhs_l = @alloc(16) as ref u8
                @snprintf(lhs_l, 16, "%%t{lld}", {ext_tmp})
            }
            if str.rchar_cmp(rhs_qbt, "w") == 0 {
                val ext_tmp: i64 = fresh_tmp(ctx)
                val ext_buf: ref u8 = @alloc(128) as ref u8
                @snprintf(ext_buf, 128, "    %%t{lld} =l extsw {s}\n", {ext_tmp, rhs_l})
                emit(ctx, ext_buf)
                @free(ext_buf)
                rhs_l = @alloc(16) as ref u8
                @snprintf(rhs_l, 16, "%%t{lld}", {ext_tmp})
            }
        }
    }

    if is_float {
        if str.rchar_cmp(lhs_qbt, "s") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(ext_buf, 128, "    %%t{lld} =d exts {s}\n", {ext_tmp, lhs_l})
            emit(ctx, ext_buf)
            @free(ext_buf)
            lhs_l = @alloc(16) as ref u8
            @snprintf(lhs_l, 16, "%%t{lld}", {ext_tmp})
        }
        if str.rchar_cmp(rhs_qbt, "s") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(ext_buf, 128, "    %%t{lld} =d exts {s}\n", {ext_tmp, rhs_l})
            emit(ctx, ext_buf)
            @free(ext_buf)
            rhs_l = @alloc(16) as ref u8
            @snprintf(rhs_l, 16, "%%t{lld}", {ext_tmp})
        }
    }

    if op == parser.OP_BAND || op == parser.OP_BOR || op == parser.OP_BXOR ||
       op == parser.OP_SHL || op == parser.OP_SHR ||
       op == parser.OP_ADD || op == parser.OP_SUB || op == parser.OP_MUL ||
       op == parser.OP_DIV || op == parser.OP_REM {
        if str.rchar_cmp(lhs_qbt, "w") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(ext_buf, 128, "    %%t{lld} =l extsw {s}\n", {ext_tmp, lhs_l})
            emit(ctx, ext_buf)
            @free(ext_buf)
            lhs_l = @alloc(16) as ref u8
            @snprintf(lhs_l, 16, "%%t{lld}", {ext_tmp})
        }
        if str.rchar_cmp(rhs_qbt, "w") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(ext_buf, 128, "    %%t{lld} =l extsw {s}\n", {ext_tmp, rhs_l})
            emit(ctx, ext_buf)
            @free(ext_buf)
            rhs_l = @alloc(16) as ref u8
            @snprintf(rhs_l, 16, "%%t{lld}", {ext_tmp})
        }
    }

    if is_float {
        if op == parser.OP_ADD  { @snprintf(buf, 256, "    %%t{lld} =d add {s}, {s}\n",  {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_SUB { @snprintf(buf, 256, "    %%t{lld} =d sub {s}, {s}\n",  {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_MUL { @snprintf(buf, 256, "    %%t{lld} =d mul {s}, {s}\n",  {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_DIV { @snprintf(buf, 256, "    %%t{lld} =d div {s}, {s}\n",  {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_REM { @snprintf(buf, 256, "    %%t{lld} =d rem {s}, {s}\n",  {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_EQ  { @snprintf(buf, 256, "    %%t{lld} =w ceqd {s}, {s}\n", {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_NE  { @snprintf(buf, 256, "    %%t{lld} =w cned {s}, {s}\n", {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_LT  { @snprintf(buf, 256, "    %%t{lld} =w cltd {s}, {s}\n", {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_GT  { @snprintf(buf, 256, "    %%t{lld} =w cgtd {s}, {s}\n", {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_LE  { @snprintf(buf, 256, "    %%t{lld} =w cled {s}, {s}\n", {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_GE  { @snprintf(buf, 256, "    %%t{lld} =w cged {s}, {s}\n", {tmp, lhs_l, rhs_l}) }
        else { @snprintf(buf, 256, "    %%t{lld} =l copy 0\n", {tmp}) }
    } else {
        if op == parser.OP_ADD  { @snprintf(buf, 256, "    %%t{lld} =l add {s}, {s}\n",  {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_SUB { @snprintf(buf, 256, "    %%t{lld} =l sub {s}, {s}\n",  {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_MUL { @snprintf(buf, 256, "    %%t{lld} =l mul {s}, {s}\n",  {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_DIV { @snprintf(buf, 256, "    %%t{lld} =l div {s}, {s}\n",  {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_REM { @snprintf(buf, 256, "    %%t{lld} =l rem {s}, {s}\n",  {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_EQ  {
            if both_word {
                @snprintf(buf, 256, "    %%t{lld} =w ceqw {s}, {s}\n", {tmp, lhs, rhs})
            } else {
                @snprintf(buf, 256, "    %%t{lld} =w ceql {s}, {s}\n", {tmp, lhs_l, rhs_l})
            }
        }
        elif op == parser.OP_NE  {
            if both_word {
                @snprintf(buf, 256, "    %%t{lld} =w cnew {s}, {s}\n", {tmp, lhs, rhs})
            } else {
                @snprintf(buf, 256, "    %%t{lld} =w cnel {s}, {s}\n", {tmp, lhs_l, rhs_l})
            }
        }
        elif op == parser.OP_LT  {
            if both_word {
                @snprintf(buf, 256, "    %%t{lld} =w csltw {s}, {s}\n", {tmp, lhs, rhs})
            } else {
                @snprintf(buf, 256, "    %%t{lld} =w csltl {s}, {s}\n", {tmp, lhs_l, rhs_l})
            }
        }
        elif op == parser.OP_GT  {
            if both_word {
                @snprintf(buf, 256, "    %%t{lld} =w csgtw {s}, {s}\n", {tmp, lhs, rhs})
            } else {
                @snprintf(buf, 256, "    %%t{lld} =w csgtl {s}, {s}\n", {tmp, lhs_l, rhs_l})
            }
        }
        elif op == parser.OP_LE  {
            if both_word {
                @snprintf(buf, 256, "    %%t{lld} =w cslew {s}, {s}\n", {tmp, lhs, rhs})
            } else {
                @snprintf(buf, 256, "    %%t{lld} =w cslel {s}, {s}\n", {tmp, lhs_l, rhs_l})
            }
        }
        elif op == parser.OP_GE  {
            val lt: i64 = fresh_tmp(ctx)
            if both_word {
                @snprintf(buf, 256, "    %%t{lld} =w csltw {s}, {s}\n    %%t{lld} =w ceqw %%t{lld}, 0\n", {lt, lhs, rhs, tmp, lt})
            } else {
                @snprintf(buf, 256, "    %%t{lld} =w csltl {s}, {s}\n    %%t{lld} =w ceqw %%t{lld}, 0\n", {lt, lhs_l, rhs_l, tmp, lt})
            }
        }
        elif op == parser.OP_BAND { @snprintf(buf, 256, "    %%t{lld} =l and {s}, {s}\n", {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_BOR  { @snprintf(buf, 256, "    %%t{lld} =l or {s}, {s}\n",  {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_BXOR { @snprintf(buf, 256, "    %%t{lld} =l xor {s}, {s}\n", {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_SHL  { @snprintf(buf, 256, "    %%t{lld} =l shl {s}, {s}\n", {tmp, lhs_l, rhs_l}) }
        elif op == parser.OP_SHR  { @snprintf(buf, 256, "    %%t{lld} =l shr {s}, {s}\n", {tmp, lhs_l, rhs_l}) }
        else { @snprintf(buf, 256, "    %%t{lld} =l copy 0\n", {tmp}) }
    }

    emit(ctx, buf)
    @free(buf)
    val res: ref u8 = @alloc(16) as ref u8
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn gen_unop(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    val op: i64 = expr.d0 as i64
    val inner_expr: ref parser.Node = expr.d1 as ref parser.Node
    val inner: ref u8 = gen_expr(ctx, inner_expr)
    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref u8 = @alloc(128) as ref u8
    val is_float: bool = expr_is_float(ctx, inner_expr)
    val inner_qt: ref u8 = expr_qbe_type(ctx, inner_expr)

    if op == parser.UOP_NOT {
        @snprintf(buf, 128, "    %%t{lld} =w ceqw {s}, 0\n", {tmp, inner})
    } elif op == parser.UOP_NEG {
        if is_float {
            val neg_qt: mut ref u8 = "d"
            if str.rchar_cmp(inner_qt, "s") == 0 { neg_qt = "s" }
            @snprintf(buf, 128, "    %%t{lld} ={s} sub {s}_0, {s}\n", {tmp, neg_qt, neg_qt, inner})
        } else {
            @snprintf(buf, 128, "    %%t{lld} =l neg {s}\n", {tmp, inner})
        }
    } elif op == parser.UOP_BNOT {
        if str.rchar_cmp(inner_qt, "w") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(64) as ref u8
            @snprintf(ext_buf, 64, "    %%t{lld} =l extsw {s}\n", {ext_tmp, inner})
            emit(ctx, ext_buf)
            @free(ext_buf)
            @snprintf(buf, 128, "    %%t{lld} =l xor %%t{lld}, -1\n", {tmp, ext_tmp})
        } else {
            @snprintf(buf, 128, "    %%t{lld} =l xor {s}, -1\n", {tmp, inner})
        }
    } else {
        @snprintf(buf, 128, "    %%t{lld} =l copy 0\n", {tmp})
    }
    emit(ctx, buf)
    @free(buf)
    val res: ref u8 = @alloc(16) as ref u8
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn field_load_instr_for(ty: ref parser.Node) ref u8! = {
    if ty == 0 as ref parser.Node { return "loadl" }
    val k: i64 = ty.kind
    if k == parser.TY_MUT { return field_load_instr_for(ty.d0 as ref parser.Node) }
    if k == parser.TY_NAMED {
        val name: ref u8 = ty.d0 as ref u8
        if str.rchar_cmp(name, "f64")  == 0 { return "loadd" }
        if str.rchar_cmp(name, "f32")  == 0 { return "loads" }
        if str.rchar_cmp(name, "i32")  == 0 { return "loadsw" }
        if str.rchar_cmp(name, "u32")  == 0 { return "loaduw" }
        if str.rchar_cmp(name, "i16")  == 0 { return "loadsh" }
        if str.rchar_cmp(name, "u16")  == 0 { return "loaduh" }
        if str.rchar_cmp(name, "i8")   == 0 { return "loadsb" }
        if str.rchar_cmp(name, "u8")   == 0 { return "loadub" }
        if str.rchar_cmp(name, "bool") == 0 { return "loadub" }
        if str.rchar_cmp(name, "u8") == 0 { return "loadub" }
    }
    return "loadl"
}

fn gen_field(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    val base_expr: ref parser.Node = expr.d0 as ref parser.Node
    val field_name: ref u8 = expr.d1 as ref u8
    if cg_is_c_escape_expr(expr) {
        val raw_name: ref u8 = cg_raw_c_name(expr)
        val tmp_raw: i64 = fresh_tmp(ctx)
        val raw_buf: ref u8 = @alloc(256) as ref u8
        @snprintf(raw_buf, 256, "    %%t{lld} =l copy ${s}\n", {tmp_raw, raw_name})
        emit(ctx, raw_buf)
        @free(raw_buf)
        val raw_res: ref u8 = @alloc(16) as ref u8
        @snprintf(raw_res, 16, "%%t{lld}", {tmp_raw})
        return raw_res
    }
    val offset: mut i64 = 0

    if base_expr.kind == parser.NK_IDENT {
        val base_name: ref u8 = base_expr.d0 as ref u8
        val resolved_base_name: ref u8 = gsubst_resolve_name(ctx, base_name)
        val base_name2: mut ref u8 = base_name
        if str.rchar_cmp(resolved_base_name, "") != 0 {
            base_name2 = resolved_base_name
        }
        val dqt_check: ref u8 = cg_direct_type(ctx, base_name2)
        val local_type: ref u8 = cg_local_type(ctx, base_name2)
        val local_var: ref u8 = cg_lookup_local_var(ctx, base_name2)
        val is_local: bool = str.rchar_cmp(dqt_check, "") != 0 || str.rchar_cmp(local_type, "") != 0 || str.rchar_cmp(local_var, "") != 0

        if !is_local {
            val tmp: i64 = fresh_tmp(ctx)
            val buf: ref u8 = @alloc(256) as ref u8
            val enum_key: ref u8 = @alloc(512) as ref u8
            @snprintf(enum_key, 512, "{s}__{s}", {base_name2, field_name})
            val const_val: ref u8 = cg_const_val(ctx, enum_key)
            @free(enum_key)
            if str.rchar_cmp(const_val, "") != 0 {
                if rchar_starts_with(const_val, "d_") || rchar_starts_with(const_val, "s_") {
                    val ftext: ref u8 = @ptradd(const_val as ref void, 2) as ref u8
                    val emit_qt: mut ref u8 = "d"
                    if rchar_starts_with(const_val, "s_") { emit_qt = "s" }
                    if ctx.expected_ty != 0 as ref void {
                        val expected_qt_field: ref u8 = qbe_type_of(ctx.expected_ty as ref parser.Node)
                        if str.rchar_cmp(expected_qt_field, "s") == 0 { emit_qt = "s" }
                        elif str.rchar_cmp(expected_qt_field, "d") == 0 { emit_qt = "d" }
                    }
                    @snprintf(buf, 256, "    %%t{lld} ={s} copy {s}_{s}\n", {tmp, emit_qt, emit_qt, ftext})
                } else {
                    @snprintf(buf, 256, "    %%t{lld} =l copy {s}\n", {tmp, const_val})
                }
            } else {
                val qbe_key: ref u8 = @alloc(512) as ref u8
                @snprintf(qbe_key, 512, "{s}__{s}", {base_name2, field_name})
                val is_fn: bool = cg_is_fn(ctx, qbe_key)
                @free(qbe_key)
                if is_fn {
                    @snprintf(buf, 256, "    %%t{lld} =l copy ${s}__{s}\n", {tmp, base_name2, field_name})
                } else {
                    @snprintf(buf, 256, "    %%t{lld} =l loadl ${s}__{s}\n", {tmp, base_name2, field_name})
                }
            }
            emit(ctx, buf)
            @free(buf)
            val res: ref u8 = @alloc(16) as ref u8
            @snprintf(res, 16, "%%t{lld}", {tmp})
            return res
        }

        if str.rchar_cmp(local_type, "") != 0 {
            val lookup_type: ref u8 = cg_ann_deref(local_type)
            val fields: ref void = cg_lookup_struct(ctx, lookup_type)
            if fields != 0 as ref void {
                val off: i64 = field_offset(ctx, fields, field_name)
                if off >= 0 { offset = off }
            }
        } else {
            val inferred: ref u8 = infer_type_annotation(ctx, base_expr)
            if str.rchar_cmp(inferred, "") != 0 {
                val lookup_type: ref u8 = cg_ann_deref(inferred)
                val fields: ref void = cg_lookup_struct(ctx, lookup_type)
                if fields != 0 as ref void {
                    val off: i64 = field_offset(ctx, fields, field_name)
                    if off >= 0 { offset = off }
                }
            }
        }
    }

    val base: mut ref u8 = 0 as ref u8
    val base_is_ref: mut bool = false
    if base_expr.kind == parser.NK_IDENT {
        val base_name2: mut ref u8 = base_expr.d0 as ref u8
        val resolved_base_name2: ref u8 = gsubst_resolve_name(ctx, base_name2)
        if str.rchar_cmp(resolved_base_name2, "") != 0 {
            base_name2 = resolved_base_name2
        }
        val dqt: ref u8 = cg_direct_type(ctx, base_name2)
        if str.rchar_cmp(dqt, "") != 0 {
            val direct_buf: ref u8 = @alloc(32) as ref u8
            @snprintf(direct_buf, 32, "%%{s}", {base_name2})
            base = direct_buf
        } else {
            val local_type_base: ref u8 = cg_local_type(ctx, base_name2)
            if cg_is_local_ref_type(ctx, base_name2) {
                base_is_ref = true
            }
            if !base_is_ref && cg_ann_is_indirect_value(ctx, local_type_base) {
                base_is_ref = true
            }
            if cg_is_slot(ctx, base_name2) && !base_is_ref {
                if cg_is_local_ref_type(ctx, base_name2) {
                base_is_ref = true
                } else {
                    val inferred_type: ref u8 = infer_type_annotation(ctx, base_expr)
                    val lookup_inferred_type: ref u8 = cg_ann_deref(inferred_type)
                    if str.rchar_cmp(inferred_type, "") != 0 && str.rchar_cmp(lookup_inferred_type, inferred_type) != 0 {
                        base_is_ref = true
                    }
                }
            }
        }
    } elif base_expr.kind == parser.NK_CAST {
        val cast_ty: ref parser.Node = base_expr.d1 as ref parser.Node
        if is_ref_type(cast_ty) {
            base_is_ref = true
        }
        val cast_type_name: ref u8 = unwrap_type_name(cast_ty)
        if str.rchar_cmp(cast_type_name, "") != 0 {
            val fields: ref void = cg_lookup_struct(ctx, cast_type_name)
            if fields != 0 as ref void {
                val off: i64 = field_offset(ctx, fields, field_name)
                if off >= 0 { offset = off }
            }
        }
    } elif base_expr.kind == parser.NK_DEREF {
        base_is_ref = true
        val inner: ref parser.Node = base_expr.d0 as ref parser.Node
        if inner.kind == parser.NK_IDENT {
            val inner_name: ref u8 = inner.d0 as ref u8
            val inner_type: ref u8 = cg_local_type(ctx, inner_name)
            if str.rchar_cmp(inner_type, "") != 0 && rchar_starts_with(inner_type, "ref ") {
                val deref_type: ref u8 = @ptradd(inner_type, 4) as ref u8
                val fields: ref void = cg_lookup_struct(ctx, deref_type)
                if fields != 0 as ref void {
                    val off: i64 = field_offset(ctx, fields, field_name)
                    if off >= 0 { offset = off }
                }
            }
        }
    }
    if base == 0 as ref u8 {
        if base_expr.kind == parser.NK_DEREF {
            val inner: ref parser.Node = base_expr.d0 as ref parser.Node
            base = gen_expr(ctx, inner)
        } else {
            base = gen_expr(ctx, base_expr)
        }
        if base_expr.kind == parser.NK_IDENT {
            val base_name3: ref u8 = base_expr.d0 as ref u8
            if cg_is_local_ref_type(ctx, base_name3) {
                base_is_ref = true
            }
        }
    }

    val field_is_fa: mut bool = false
    val field_is_union: mut bool = false
    val field_is_list: mut bool = false
    val field_is_multi_word_struct: mut bool = false
    val field_load_instr: mut ref u8 = "loadl"
    if base_expr.kind == parser.NK_IDENT {
        val base_name3: ref u8 = base_expr.d0 as ref u8
        val local_type2: ref u8 = cg_local_type(ctx, base_name3)
        val lookup_type2: mut ref u8 = cg_ann_deref(local_type2)
        if str.rchar_cmp(local_type2, "") == 0 {
            val inferred: ref u8 = infer_type_annotation(ctx, base_expr)
            if str.rchar_cmp(inferred, "") != 0 {
                lookup_type2 = cg_ann_deref(inferred)
            }
        }

	if str.rchar_cmp(lookup_type2, "") != 0 {
            val fields2: ref void = cg_lookup_struct(ctx, lookup_type2)
            if fields2 != 0 as ref void {
                val sflen3: i64 = @len(fields2 as list[ref void]) as i64
                val sfi3: mut i64 = 0
                for {
                    if sfi3 >= sflen3 { break }
                    val sf3_opt = @get(fields2 as list[ref void], sfi3 as usize)
                    match sf3_opt {
                        some sf3 => {
                            val sfn3: ref parser.Node = sf3 as ref parser.Node
                            val sfname3: ref u8 = sfn3.d0 as ref u8
                            if str.rchar_cmp(sfname3, field_name) == 0 {
                                val sfty3: ref parser.Node = sfn3.d2 as ref parser.Node
                                if sfty3 != 0 as ref parser.Node {
                                    if sfty3.kind == parser.TY_FIXED_ARR {
                                        field_is_fa = true
                                    } elif sfty3.kind == parser.TY_LIST {
                                        field_is_list = true
                                    } elif sfty3.kind == parser.TY_NAMED {
                                        val type_name: ref u8 = sfty3.d0 as ref u8
                                        if is_union_type_name(ctx, type_name) {
                                            field_is_union = true
                                        } else {
                                            val sfields: ref void = cg_lookup_struct(ctx, type_name)
                                            if sfields != 0 as ref void {
                                                val sz: i64 = struct_size(ctx, sfields)
                                                if sz > 8 {
                                                    field_is_multi_word_struct = true
                                                }
                                            }
                                        }
                                    }
                                    field_load_instr = field_load_instr_for(sfty3)
                                }
                                sfi3 = sflen3 // break
                            }
                        }
                        none => {}
                    }
                    sfi3++
                }
            }
        }
    } elif base_expr.kind == parser.NK_CAST {
        val cast_ty: ref parser.Node = base_expr.d1 as ref parser.Node
        val type_name: ref u8 = unwrap_type_name(cast_ty)
        if str.rchar_cmp(type_name, "") != 0 {
            val fields2: ref void = cg_lookup_struct(ctx, type_name)
            if fields2 != 0 as ref void {
                val sflen3: i64 = @len(fields2 as list[ref void]) as i64
                val sfi3: mut i64 = 0
                for {
                    if sfi3 >= sflen3 { break }
                    val sf3_opt = @get(fields2 as list[ref void], sfi3 as usize)
                    match sf3_opt {
                        some sf3 => {
                            val sfn3: ref parser.Node = sf3 as ref parser.Node
                            val sfname3: ref u8 = sfn3.d0 as ref u8
                            if str.rchar_cmp(sfname3, field_name) == 0 {
                                val sfty3: ref parser.Node = sfn3.d2 as ref parser.Node
                                if sfty3 != 0 as ref parser.Node {
                                    if sfty3.kind == parser.TY_FIXED_ARR {
                                        field_is_fa = true
                                    } elif sfty3.kind == parser.TY_LIST {
                                        field_is_list = true
                                    } elif sfty3.kind == parser.TY_NAMED {
                                        val ftype_name: ref u8 = sfty3.d0 as ref u8
                                        if is_union_type_name(ctx, ftype_name) {
                                            field_is_union = true
                                        } else {
                                            val sfields: ref void = cg_lookup_struct(ctx, ftype_name)
                                            if sfields != 0 as ref void {
                                                val sz: i64 = struct_size(ctx, sfields)
                                                if sz > 8 {
                                                    field_is_multi_word_struct = true
                                                }
                                            }
                                        }
                                    }
                                    field_load_instr = field_load_instr_for(sfty3)
                                }
                                sfi3 = sflen3 // break
                            }
                        }
                        none => {}
                    }
                    sfi3++
                }
            }
        }
    } elif base_expr.kind == parser.NK_FIELD {
        val noff: i64 = nested_field_offset(ctx, base_expr, field_name)
        if noff >= 0 { offset = noff }
        val inner_type3: ref u8 = infer_type_annotation(ctx, base_expr)
        val lookup_inner3: ref u8 = cg_ann_deref(inner_type3)
        if str.rchar_cmp(lookup_inner3, "") != 0 {
            val iflds3: ref void = cg_lookup_struct(ctx, lookup_inner3)
            if iflds3 != 0 as ref void {
                val sflen4: i64 = @len(iflds3 as list[ref void]) as i64
                val sfi4: mut i64 = 0
                for {
                    if sfi4 >= sflen4 { break }
                    val sf4_opt = @get(iflds3 as list[ref void], sfi4 as usize)
                    match sf4_opt {
                        some sf4 => {
                            val sfn4: ref parser.Node = sf4 as ref parser.Node
                            val sfname4: ref u8 = sfn4.d0 as ref u8
                            if str.rchar_cmp(sfname4, field_name) == 0 {
                                val sfty4: ref parser.Node = sfn4.d2 as ref parser.Node
                                if sfty4 != 0 as ref parser.Node {
                                    if sfty4.kind == parser.TY_FIXED_ARR {
                                        field_is_fa = true
                                    } elif sfty4.kind == parser.TY_LIST {
                                        field_is_list = true
                                    } elif sfty4.kind == parser.TY_NAMED {
                                        val ftype_name: ref u8 = sfty4.d0 as ref u8
                                        if is_union_type_name(ctx, ftype_name) {
                                            field_is_union = true
                                        } else {
                                            val sfields: ref void = cg_lookup_struct(ctx, ftype_name)
                                            if sfields != 0 as ref void {
                                                val sz: i64 = struct_size(ctx, sfields)
                                                if sz > 8 {
                                                    field_is_multi_word_struct = true
                                                }
                                            }
                                        }
                                    }
                                    field_load_instr = field_load_instr_for(sfty4)
                                }
                                sfi4 = sflen4
                            }
                        }
                        none => {}
                    }
                    sfi4++
                }
            }
        }
    }
    if str.rchar_cmp(field_load_instr, "loadl") == 0 {
        val field_ann: ref u8 = infer_type_annotation(ctx, expr)
        if str.rchar_cmp(field_ann, "f64") == 0 { field_load_instr = "loadd" }
        elif str.rchar_cmp(field_ann, "f32") == 0 { field_load_instr = "loads" }
    }

    val tmp: i64 = fresh_tmp(ctx)
    val tmp_qt: mut ref u8 = "l"
    if str.rchar_cmp(field_load_instr, "loadd") == 0 { tmp_qt = "d" }
    elif str.rchar_cmp(field_load_instr, "loads") == 0 { tmp_qt = "s" }
    val buf: ref u8 = @alloc(256) as ref u8

    if base_is_ref {
        if field_is_fa || field_is_union || field_is_list || field_is_multi_word_struct {
            if offset == 0 {
                @snprintf(buf, 256, "    %%t{lld} =l add {s}, 0\n", {tmp, base})
            } else {
                @snprintf(buf, 256, "    %%t{lld} =l add {s}, {lld}\n", {tmp, base, offset})
            }
        } else {
            if offset == 0 {
                @snprintf(buf, 256, "    %%t{lld} ={s} {s} {s}\n", {tmp, tmp_qt, field_load_instr, base})
            } else {
                val ptr_tmp: i64 = fresh_tmp(ctx)
                val buf2: ref u8 = @alloc(128) as ref u8
                @snprintf(buf2, 128, "    %%t{lld} =l add {s}, {lld}\n", {ptr_tmp, base, offset})
                emit(ctx, buf2)
                @free(buf2)
                val ptr_str: ref u8 = @alloc(16) as ref u8
                @snprintf(ptr_str, 16, "%%t{lld}", {ptr_tmp})
                @snprintf(buf, 256, "    %%t{lld} ={s} {s} {s}\n", {tmp, tmp_qt, field_load_instr, ptr_str})
                @free(ptr_str)
            }
        }
    } elif field_is_fa || field_is_union || field_is_list || field_is_multi_word_struct {
        if offset == 0 {
            @snprintf(buf, 256, "    %%t{lld} =l add {s}, 0\n", {tmp, base})
        } else {
            @snprintf(buf, 256, "    %%t{lld} =l add {s}, {lld}\n", {tmp, base, offset})
        }
    } elif offset == 0 {
        @snprintf(buf, 256, "    %%t{lld} ={s} {s} {s}\n", {tmp, tmp_qt, field_load_instr, base})
    } else {
        val ptr_tmp: i64 = fresh_tmp(ctx)
        val buf2: ref u8 = @alloc(128) as ref u8
        @snprintf(buf2, 128, "    %%t{lld} =l add {s}, {lld}\n", {ptr_tmp, base, offset})
        emit(ctx, buf2)
        @free(buf2)
        val ptr_str: ref u8 = @alloc(16) as ref u8
        @snprintf(ptr_str, 16, "%%t{lld}", {ptr_tmp})
        @snprintf(buf, 256, "    %%t{lld} ={s} {s} {s}\n", {tmp, tmp_qt, field_load_instr, ptr_str})
        @free(ptr_str)
    }
    emit(ctx, buf)
    @free(buf)
    val res: ref u8 = @alloc(16) as ref u8
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

/// Returns the address of a field (or list variable) without loading its value.
/// Used by list builtins (@append, @len, @get, etc.) that need the list header address.
fn gen_list_ptr(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    if expr == 0 as ref parser.Node { return "0" }
    if expr.kind == parser.NK_FIELD {
        val base_expr: ref parser.Node = parser.field_base(expr)
        val field_name: ref u8 = parser.field_name(expr)
        val offset: mut i64 = 0
        if base_expr.kind == parser.NK_IDENT {
            val base_name: ref u8 = base_expr.d0 as ref u8
            val local_type: ref u8 = cg_local_type(ctx, base_name)
            if str.rchar_cmp(local_type, "") != 0 {
                val fields: ref void = cg_lookup_struct(ctx, local_type)
                if fields != 0 as ref void {
                    val off: i64 = field_offset(ctx, fields, field_name)
                    if off >= 0 { offset = off }
                }
            }
        }
        val base: mut ref u8 = 0 as ref u8
        if base_expr.kind == parser.NK_IDENT {
            val base_name2: ref u8 = base_expr.d0 as ref u8
            val dqt: ref u8 = cg_direct_type(ctx, base_name2)
            if str.rchar_cmp(dqt, "") != 0 {
                val direct_buf: ref u8 = @alloc(32) as ref u8
                @snprintf(direct_buf, 32, "%%{s}", {base_name2})
                base = direct_buf
            }
        }
        if base == 0 as ref u8 {
            base = gen_expr(ctx, base_expr)
        }
        if offset == 0 {
            return base
        }
        val ptr_tmp: i64 = fresh_tmp(ctx)
        val buf: ref u8 = @alloc(128) as ref u8
        @snprintf(buf, 128, "    %%t{lld} =l add {s}, {lld}\n", {ptr_tmp, base, offset})
        emit(ctx, buf)
        @free(buf)
        val res: ref u8 = @alloc(16) as ref u8
        @snprintf(res, 16, "%%t{lld}", {ptr_tmp})
        return res
    }
    if expr.kind == parser.NK_IDENT {
        val vname: ref u8 = expr.d0 as ref u8
        val qbe_var: ref u8 = cg_lookup_local_var(ctx, vname)
        if str.rchar_cmp(qbe_var, "") != 0 && cg_is_slot(ctx, vname) {
            val slot_addr: ref u8 = cg_qbe_value_ref(qbe_var)
            val list_ptr_tmp: i64 = fresh_tmp(ctx)
            val load_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(load_buf, 128, "    %%t{lld} =l loadl {s}\n", {list_ptr_tmp, slot_addr})
            emit(ctx, load_buf)
            @free(load_buf)
            @free(slot_addr)

            val res: ref u8 = @alloc(16) as ref u8
            @snprintf(res, 16, "%%t{lld}", {list_ptr_tmp})
            return res
        }
        val dqt: ref u8 = cg_direct_type(ctx, vname)
        if str.rchar_cmp(dqt, "") != 0 {
            val res2: ref u8 = @alloc(32) as ref u8
            @snprintf(res2, 32, "%%{s}", {vname})
            return res2
        }
    }
    return gen_expr(ctx, expr)
}

fn gen_store_field_value(ctx: ref CgCtx, target: ref parser.Node, val_tmp2: ref u8, val_qtype: ref u8) void! = {
    val val_qtype_n: ref u8 = cg_normalize_qtype(val_qtype)
    val ftarget: ref parser.Node = parser.field_base(target)
    val fname: ref u8 = parser.field_name(target)
    val foffset: mut i64 = 0
    val field_is_union: mut bool = false

    if ftarget.kind == parser.NK_IDENT {
        val bname: ref u8 = ftarget.d0 as ref u8
        val tname2: ref u8 = cg_local_type(ctx, bname)
        val lookup_tname: ref u8 = cg_ann_deref(tname2)

        if str.rchar_cmp(lookup_tname, "") != 0 {
            val flds2: ref void = cg_lookup_struct(ctx, lookup_tname)
            if flds2 != 0 as ref void {
                val off2: i64 = field_offset(ctx, flds2, fname)
                if off2 >= 0 { foffset = off2 }

                val sflen: i64 = @len(flds2 as list[ref void]) as i64
                val sfi: mut i64 = 0
                for {
                    if sfi >= sflen { break }
                    val sf_opt = @get(flds2 as list[ref void], sfi as usize)
                    match sf_opt {
                        some sf => {
                            val sfn: ref parser.Node = sf as ref parser.Node
                            val sfname: ref u8 = sfn.d0 as ref u8
                            if str.rchar_cmp(sfname, fname) == 0 {
                                val sfty: ref parser.Node = sfn.d2 as ref parser.Node
                                if sfty != 0 as ref parser.Node && sfty.kind == parser.TY_NAMED {
                                    val ftype_name: ref u8 = sfty.d0 as ref u8
                                    val union_check: ref void = cg_lookup_union_suffix(ctx, ftype_name)
                                    if union_check != 0 as ref void {
                                        field_is_union = true
                                    }
                                }
                                sfi = sflen
                            }
                        }
                        none => {}
                    }
                    sfi++
                }
            }
        }
    } elif ftarget.kind == parser.NK_FIELD {
        val noff: i64 = nested_field_offset(ctx, ftarget, fname)
        if noff >= 0 { foffset = noff }
    }

    val base: ref u8 = gen_expr(ctx, ftarget)

    if field_is_union {
        val fptr: i64 = fresh_tmp(ctx)
        if foffset == 0 {
            val buf3u: ref u8 = @alloc(128) as ref u8
            @snprintf(buf3u, 128, "    call $memcpy(l {s}, l {s}, l 16)\n", {base, val_tmp2})
            emit(ctx, buf3u)
            @free(buf3u)
        } else {
            val buf3ub: ref u8 = @alloc(128) as ref u8
            @snprintf(buf3ub, 128, "    %%t{lld} =l add {s}, {lld}\n", {fptr, base, foffset})
            emit(ctx, buf3ub)
            @free(buf3ub)
            val buf3u: ref u8 = @alloc(128) as ref u8
            @snprintf(buf3u, 128, "    call $memcpy(l %%t{lld}, l {s}, l 16)\n", {fptr, val_tmp2})
            emit(ctx, buf3u)
            @free(buf3u)
        }
    } else {
        val field_is_list: mut bool = false
        val field_size_write: mut i64 = 8
        val field_store_op: mut ref u8 = "storel"

        if ftarget.kind == parser.NK_IDENT {
            val bname2: ref u8 = ftarget.d0 as ref u8
            val tname3: ref u8 = cg_local_type(ctx, bname2)
            val lookup3: ref u8 = cg_ann_deref(tname3)
            if str.rchar_cmp(lookup3, "") != 0 {
                val flds3: ref void = cg_lookup_struct(ctx, lookup3)
                if flds3 != 0 as ref void {
                    val sf3len: i64 = @len(flds3 as list[ref void]) as i64
                    val sf3i: mut i64 = 0
                    for {
                        if sf3i >= sf3len { break }
                        val sf3_opt = @get(flds3 as list[ref void], sf3i as usize)
                        match sf3_opt {
                            some sf3 => {
                                val sf3n: ref parser.Node = sf3 as ref parser.Node
                                val sf3name: ref u8 = sf3n.d0 as ref u8
                                if str.rchar_cmp(sf3name, fname) == 0 {
                                    val sf3ty: ref parser.Node = sf3n.d2 as ref parser.Node
                                    if sf3ty != 0 as ref parser.Node {
                                        if sf3ty.kind == parser.TY_LIST {
                                            field_is_list = true
                                        } else {
                                            if sf3ty.kind == parser.TY_NAMED {
                                                val ftnm: ref u8 = sf3ty.d0 as ref u8
                                                val sflds: ref void = cg_lookup_struct(ctx, ftnm)
                                                if sflds != 0 as ref void {
                                                    field_size_write = struct_size(ctx, sflds)
                                                }
                                            }
                                            val sf3qt: ref u8 = qbe_type_of(sf3ty)
                                            if str.rchar_cmp(sf3qt, "w") == 0 { field_store_op = "storew" }
                                            elif str.rchar_cmp(sf3qt, "s") == 0 { field_store_op = "stores" }
                                            elif str.rchar_cmp(sf3qt, "d") == 0 { field_store_op = "stored" }
                                        }
                                    }
                                    sf3i = sf3len
                                }
                            }
                            none => {}
                        }
                        sf3i++
                    }
                }
            }
        }

        val val_to_store: mut ref u8 = val_tmp2
        if str.rchar_cmp(field_store_op, "storel") == 0 && str.rchar_cmp(val_qtype_n, "w") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(ext_buf, 128, "    %%t{lld} =l extsw {s}\n", {ext_tmp, val_tmp2})
            emit(ctx, ext_buf)
            @free(ext_buf)
            val ext_res: ref u8 = @alloc(16) as ref u8
            @snprintf(ext_res, 16, "%%t{lld}", {ext_tmp})
            val_to_store = ext_res
        } elif str.rchar_cmp(field_store_op, "stores") == 0 || str.rchar_cmp(field_store_op, "stored") == 0 {
            val dst_qtype: mut ref u8 = "d"
            if str.rchar_cmp(field_store_op, "stores") == 0 { dst_qtype = "s" }
            val_to_store = cg_coerce_qtype(ctx, val_tmp2, val_qtype_n, dst_qtype)
        }

        val buf3: ref u8 = @alloc(128) as ref u8
        if field_is_list {
            if foffset == 0 {
                @snprintf(buf3, 128, "    call $memcpy(l {s}, l {s}, l 24)\n", {base, val_to_store})
            } else {
                val fptr: i64 = fresh_tmp(ctx)
                val buf3b: ref u8 = @alloc(128) as ref u8
                @snprintf(buf3b, 128, "    %%t{lld} =l add {s}, {lld}\n", {fptr, base, foffset})
                emit(ctx, buf3b)
                @free(buf3b)
                @snprintf(buf3, 128, "    call $memcpy(l %%t{lld}, l {s}, l 24)\n", {fptr, val_to_store})
            }
        } elif field_size_write > 8 {
            if foffset == 0 {
                @snprintf(buf3, 128, "    call $memcpy(l {s}, l {s}, l {lld})\n", {base, val_to_store, field_size_write})
            } else {
                val fptr: i64 = fresh_tmp(ctx)
                val buf3b: ref u8 = @alloc(128) as ref u8
                @snprintf(buf3b, 128, "    %%t{lld} =l add {s}, {lld}\n", {fptr, base, foffset})
                emit(ctx, buf3b)
                @free(buf3b)
                @snprintf(buf3, 128, "    call $memcpy(l %%t{lld}, l {s}, l {lld})\n", {fptr, val_to_store, field_size_write})
            }
        } elif foffset == 0 {
            @snprintf(buf3, 128, "    {s} {s}, {s}\n", {field_store_op, val_to_store, base})
        } else {
            val fptr: i64 = fresh_tmp(ctx)
            val buf3b: ref u8 = @alloc(128) as ref u8
            @snprintf(buf3b, 128, "    %%t{lld} =l add {s}, {lld}\n", {fptr, base, foffset})
            emit(ctx, buf3b)
            @free(buf3b)
            @snprintf(buf3, 128, "    {s} {s}, %%t{lld}\n", {field_store_op, val_to_store, fptr})
        }
        emit(ctx, buf3)
        @free(buf3)
    }
}

fn gen_call(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    val callee_node: ref parser.Node = expr.d0 as ref parser.Node
    val args_list: ref void = expr.d1 as ref void

    if callee_node.kind == parser.NK_GENERIC_INST {
        val gi_base: ref parser.Node = parser.generic_inst_base(callee_node)
        val gi_targs: list[ref parser.Node] = parser.generic_inst_type_args(callee_node)
        val base_name: ref u8 = generic_callee_base_name(gi_base)
        val arg_tmps_g: mut list[ref u8] = []
        val arg_qts_g: mut list[ref u8] = []
        if args_list != 0 as ref void {
            val glen: i64 = @len(args_list as list[ref parser.Node]) as i64
            val gai: mut i64 = 0
            for {
                if gai >= glen { break }
                val ga_opt = @get(args_list as list[ref parser.Node], gai as usize)
                match ga_opt {
                    some ga => {
                        val gak: i64 = (ga as ref parser.Node).kind
                        if gak == parser.NK_ARGS_PACK {
                            val pack: ref void = (ga as ref parser.Node).d0 as ref void
                            val plen: i64 = @len(pack) as i64
                            val gpi: mut i64 = 0
                            for {
                                if gpi >= plen { break }
                                val gpe_opt = @get(pack, gpi as usize)
                                match gpe_opt {
                                    some gpe => {
                                        val gpe_node: ref parser.Node = gpe as ref parser.Node
                                        val gpt: ref u8 = gen_expr(ctx, gpe_node)
                                        @append(arg_tmps_g, gpt)
                                        @append(arg_qts_g, expr_qbe_type(ctx, gpe_node))
                                    }
                                    none => {}
                                }
                                gpi++
                            }
                        } else {
                            val ga_node: ref parser.Node = ga as ref parser.Node
                            val gat: ref u8 = gen_expr(ctx, ga_node)
                            @append(arg_tmps_g, gat)
                            @append(arg_qts_g, expr_qbe_type(ctx, ga_node))
                        }
                    }
                    none => {}
                }
                gai++
            }
        }
        val gfn_node: ref parser.Node = lookup_generic_fn(ctx, base_name)
        val mono_base: mut ref u8 = 0 as ref u8
        if gfn_node != 0 as ref parser.Node {
            val gfn_prefix: ref u8 = lookup_generic_fn_prefix(ctx, base_name)
            val resolved_targs: mut list[ref parser.Node] = []
            for ta in gi_targs { @append(resolved_targs, cg_concrete_ty(ctx, ta as ref parser.Node)) }
            mono_base = monomorphize_generic_fn(ctx, gfn_node, gfn_prefix, resolved_targs)
        }
        if mono_base == 0 as ref u8 {
            mono_base = base_name
        }
        val gtmp: i64 = fresh_tmp(ctx)
        val gfn_params_list: ref void = cg_lookup_fn_params(ctx, mono_base)
        val gret_node: ref void = cg_lookup_fn_ret(ctx, mono_base)
        val gret_qt: mut ref u8 = "l"
        if gret_node != 0 as ref void {
            gret_qt = qbe_type_of(gret_node as ref parser.Node)
        }
        val gcall_buf: ref u8 = @alloc(2048) as ref u8
        val gcall_pos: mut i64 = 0
        val ghdr: ref u8 = @alloc(256) as ref u8
        @snprintf(ghdr, 256, "    %%t{lld} ={s} call ${s}(", {gtmp, gret_qt, mono_base})
        val ghdr_len: i64 = str.len_raw(ghdr)
        @memcpy(@ptradd(gcall_buf as ref void, gcall_pos), ghdr as ref void, ghdr_len as usize)
        gcall_pos = gcall_pos + ghdr_len
        @free(ghdr)
        val gtlen: i64 = @len(arg_tmps_g) as i64
        val gti: mut i64 = 0
        for {
            if gti >= gtlen { break }
            val gt_opt = @get(arg_tmps_g, gti as usize)
            match gt_opt {
                some gt => {
                    val garg_qt: mut ref u8 = "l"
                    val gsrc_qt: mut ref u8 = "l"
                    if gfn_params_list != 0 as ref void {
                        val gplen: i64 = @len(gfn_params_list as list[ref void]) as i64
                        if gti < gplen {
                            val gp_opt = @get(gfn_params_list as list[ref void], gti as usize)
                            match gp_opt {
                                some gp => {
                                    val gp_node: ref parser.Node = gp as ref parser.Node
                                    if gp_node != 0 as ref parser.Node {
                                        val gp_ty: ref parser.Node = gp_node.d1 as ref parser.Node
                                        if gp_ty != 0 as ref parser.Node {
                                            garg_qt = qbe_type_of(gp_ty)
                                        }
                                    }
                                }
                                none => {}
                            }
                        }
                    }
                    val gqt_opt = @get(arg_qts_g, gti as usize)
                    match gqt_opt {
                        some gq => { gsrc_qt = gq as ref u8 }
                        none => {}
                    }
                    val gt_arg: ref u8 = cg_coerce_qtype(ctx, gt as ref u8, gsrc_qt, garg_qt)
                    val gtbuf: ref u8 = @alloc(128) as ref u8
                    if gti > 0 {
                        @memcpy(@ptradd(gcall_buf as ref void, gcall_pos), ", " as ref void, 2)
                        gcall_pos = gcall_pos + 2
                    }
                    @snprintf(gtbuf, 128, "{s} {s}", {garg_qt, gt_arg})
                    val gtbuf_len: i64 = str.len_raw(gtbuf)
                    @memcpy(@ptradd(gcall_buf as ref void, gcall_pos), gtbuf as ref void, gtbuf_len as usize)
                    gcall_pos = gcall_pos + gtbuf_len
                    @free(gtbuf)
                }
                none => {}
            }
            gti++
        }
        @store8(@ptradd(gcall_buf as ref void, gcall_pos), 41)
        gcall_pos++
        @store8(@ptradd(gcall_buf as ref void, gcall_pos), 10)
        gcall_pos++
        @store8(@ptradd(gcall_buf as ref void, gcall_pos), 0)
        emitln(ctx, gcall_buf)
        @free(gcall_buf)
        val gres: ref u8 = @alloc(16) as ref u8
        @snprintf(gres, 16, "%%t{lld}", {gtmp})
        return gres
    }

    val callee_raw: ref u8 = resolve_callee_name(ctx, callee_node)
    val callee_name: ref u8 = @alloc(256) as ref u8

    @snprintf(callee_name, 256, "{s}", {callee_raw})

    val tv_owner_slot: ref void = @alloc(8)
    val tv_field_slot: ref void = @alloc(8)

    @store(tv_owner_slot, 0)
    @store(tv_field_slot, 0)

    val tv_tag: i64 = cg_lookup_tv(ctx, callee_name, tv_owner_slot, tv_field_slot)

    if tv_tag < 0 {
        val sep_pos: mut i64 = -1
        val scan_i: mut i64 = 0
        for {
            val sc: u8 = @load8(@ptradd(callee_name as ref void, scan_i))
            if sc == 0 { break }
            val sc2: u8 = @load8(@ptradd(callee_name as ref void, scan_i + 1))
            if sc == 95 && sc2 == 95 { sep_pos = scan_i } // '__'
            scan_i++
        }
        if sep_pos >= 0 {
            val bare_name: ref u8 = @ptradd(callee_name as ref void, sep_pos + 2) as ref u8
            @store(tv_owner_slot, 0)
            @store(tv_field_slot, 0)
            val tv_tag2: i64 = cg_lookup_tv(ctx, bare_name, tv_owner_slot, tv_field_slot)
            if tv_tag2 >= 0 {
                val field_ty_list2: ref void = @load(tv_field_slot) as ref void

                val payload_size2: mut i64 = 0
                if field_ty_list2 != 0 as ref void {
                    val ftlen2: i64 = @len(field_ty_list2 as list[ref parser.Node]) as i64
                    val fti2: mut i64 = 0
                    for {
                        if fti2 >= ftlen2 { break }
                        val ft_opt2 = @get(field_ty_list2 as list[ref parser.Node], fti2 as usize)
                        match ft_opt2 {
                            some ft2 => {
                                val ft_node2: ref parser.Node = ft2 as ref parser.Node
                                val fsize2: mut i64 = type_size(ft_node2)
                                if ft_node2 != 0 as ref parser.Node && ft_node2.kind == parser.TY_NAMED {
                                    val tname2: ref u8 = ft_node2.d0 as ref u8
                                    val union_check2: ref void = cg_lookup_union_suffix(ctx, tname2)
                                    if union_check2 != 0 as ref void {
                                        fsize2 = 16
                                    } else {
                                        val struct_fields2: ref void = cg_lookup_struct(ctx, tname2)
                                        if struct_fields2 != 0 as ref void {
                                            fsize2 = struct_size(ctx, struct_fields2)
                                        }
                                    }
                                }
                                if fsize2 == 0 {
                                    payload_size2 = payload_size2 + 8
                                } else {
                                    payload_size2 = payload_size2 + align_to(fsize2, 8)
                                }
                            }
                            none => {
                                payload_size2 = payload_size2 + 8
                            }
                        }
                        fti2++
                    }
                } else {
                }

                val alloc_size2: i64 = 8 + payload_size2
                val actual_alloc_size2: mut i64 = alloc_size2
                if actual_alloc_size2 < 16 {
                    actual_alloc_size2 = 16
                }
                val ptr2: i64 = fresh_tmp(ctx)
                val pbuf2: ref u8 = @alloc(64) as ref u8
                @snprintf(pbuf2, 64, "    %%t{lld} =l alloc8 {lld}\n    storel {lld}, %%t{lld}\n",
                    {ptr2, actual_alloc_size2, tv_tag2, ptr2})
                emit(ctx, pbuf2)
                @free(pbuf2)
                if args_list != 0 as ref void {
                    val flen2: i64 = @len(args_list) as i64
                    val fi2: mut i64 = 0
                    for {
                        if fi2 >= flen2 { break }
                        val fa2_opt = @get(args_list, fi2 as usize)
                        match fa2_opt {
                            some fa2 => {
                                val fa2_node: ref parser.Node = fa2 as ref parser.Node
                                val offset2: i64 = 8 + fi2 * 8

                                if fa2_node.kind == parser.NK_STRUCT_LIT {
                                    if field_ty_list2 != 0 as ref void {
                                        val ft_opt2 = @get(field_ty_list2 as list[ref parser.Node], fi2 as usize)
                                        match ft_opt2 {
                                            some ft2 => {
                                                val ft_node2: ref parser.Node = ft2 as ref parser.Node
                                                if ft_node2.kind == parser.TY_NAMED {
                                                    val st_name2: ref u8 = ft_node2.d0 as ref u8
                                                    val st_fields2: ref void = cg_lookup_struct(ctx, st_name2)
                                                    if st_fields2 != 0 as ref void {
                                                        gen_struct_lit_inline(ctx, fa2_node, ptr2, 8, st_fields2)
                                                    }
                                                }
                                            }
                                            none => {}
                                        }
                                    }
                                } else {
                                    val field_val2: ref u8 = gen_expr(ctx, fa2_node)
                                    val fptr2: i64 = fresh_tmp(ctx)
                                    val fbuf2: ref u8 = @alloc(128) as ref u8
                                    @snprintf(fbuf2, 128, "    %%t{lld} =l add %%t{lld}, {lld}\n    storel {s}, %%t{lld}\n",
                                        {fptr2, ptr2, offset2, field_val2, fptr2})
                                    emit(ctx, fbuf2)
                                    @free(fbuf2)
                                }
                            }
                            none => {}
                        }
                        fi2++
                    }
                }
                @free(tv_owner_slot)
                @free(tv_field_slot)
                val tv_res2: ref u8 = @alloc(16) as ref u8
                @snprintf(tv_res2, 16, "%%t{lld}", {ptr2})
                return tv_res2
            }
        }
    }

    if tv_tag >= 0 {
        val field_ty_list: ref void = @load(tv_field_slot) as ref void
        val n_args: mut i64 = 0
        if args_list != 0 as ref void { n_args = @len(args_list) as i64 }

        val payload_size: mut i64 = 0
        if field_ty_list != 0 as ref void {
            val ftlen: i64 = @len(field_ty_list as list[ref parser.Node]) as i64
            val fti: mut i64 = 0
            for {
                if fti >= ftlen { break }
                val ft_opt = @get(field_ty_list as list[ref parser.Node], fti as usize)
                match ft_opt {
                    some ft => {
                        val ft_node: ref parser.Node = ft as ref parser.Node
                        val fsize: mut i64 = type_size(ft_node)
                        if ft_node != 0 as ref parser.Node && ft_node.kind == parser.TY_NAMED {
                            val tname: ref u8 = ft_node.d0 as ref u8
                            val union_check: ref void = cg_lookup_union_suffix(ctx, tname)
                            if union_check != 0 as ref void {
                                fsize = 16
                            } else {
                                val struct_fields: ref void = cg_lookup_struct(ctx, tname)
                                if struct_fields != 0 as ref void {
                                    fsize = struct_size(ctx, struct_fields)
                                }
                            }
                        }
                        if fsize == 0 {
                            payload_size = payload_size + 8
                        } else {
                            payload_size = payload_size + align_to(fsize, 8)
                        }
                    }
                    none => {
                        payload_size = payload_size + 8
                    }
                }
                fti++
            }
        } else {
            payload_size = n_args * 8
        }

        val alloc_size: i64 = 8 + payload_size
        val actual_alloc_size: mut i64 = alloc_size
        if actual_alloc_size < 16 {
            actual_alloc_size = 16
        }
        val ptr: i64 = fresh_tmp(ctx)
        val pbuf: ref u8 = @alloc(64) as ref u8
        @snprintf(pbuf, 64, "    %%t{lld} =l alloc8 {lld}\n    storel {lld}, %%t{lld}\n",
            {ptr, actual_alloc_size, tv_tag, ptr})
        emit(ctx, pbuf)
        @free(pbuf)
        if args_list != 0 as ref void {
            val flen: i64 = @len(args_list) as i64
            val fi: mut i64 = 0
            for {
                if fi >= flen { break }
                val fa_opt = @get(args_list, fi as usize)
                match fa_opt {
                    some fa => {
                        val fa_node: ref parser.Node = fa as ref parser.Node
                        val offset: i64 = 8 + fi * 8

                        if fa_node.kind == parser.NK_STRUCT_LIT {
                            if field_ty_list != 0 as ref void {
                                val ft_opt = @get(field_ty_list as list[ref parser.Node], fi as usize)
                                match ft_opt {
                                    some ft => {
                                        val ft_node: ref parser.Node = ft as ref parser.Node
                                        if ft_node.kind == parser.TY_NAMED {
                                            val st_name: ref u8 = ft_node.d0 as ref u8
                                            val st_fields: ref void = cg_lookup_struct(ctx, st_name)
                                            if st_fields != 0 as ref void {
                                                gen_struct_lit_inline(ctx, fa_node, ptr, 8, st_fields)
                                            }
                                        }
                                    }
                                    none => {}
                                }
                            }
                        } else {
                            val field_val: ref u8 = gen_expr(ctx, fa_node)
                            val fptr: i64 = fresh_tmp(ctx)
                            val fbuf: ref u8 = @alloc(128) as ref u8
                            @snprintf(fbuf, 128, "    %%t{lld} =l add %%t{lld}, {lld}\n    storel {s}, %%t{lld}\n",
                                {fptr, ptr, offset, field_val, fptr})
                            emit(ctx, fbuf)
                            @free(fbuf)
                        }
                    }
                    none => {}
                }
                fi++
            }
        }
        @free(tv_owner_slot)
        @free(tv_field_slot)
        val tv_res: ref u8 = @alloc(16) as ref u8
        @snprintf(tv_res, 16, "%%t{lld}", {ptr})
        return tv_res
    }
    @free(tv_owner_slot)
    @free(tv_field_slot)

    val is_print: bool = str.rchar_cmp(callee_name, "print") == 0
        || str.ends_with(str.from(callee_name), str.from("__print"))
        || str.ends_with(str.from(callee_name), str.from("__eprint"))

    if is_print && args_list != 0 as ref void {
        val alen_p: i64 = @len(args_list) as i64
        if alen_p > 0 {
            val first_arg_opt = @get(args_list, 0)
            match first_arg_opt {
                some first_arg => {
                    val first_node: ref parser.Node = first_arg as ref parser.Node
                    if first_node.kind == parser.NK_STR_LIT {
                        val fmt_str: ref u8 = parser.str_lit_text(first_node)
                        val fmt_idx: i64 = intern_format_string(ctx, fmt_str)
                        val fmt_tmp: i64 = fresh_tmp(ctx)
                        val fmt_buf: ref u8 = @alloc(64) as ref u8
                        @snprintf(fmt_buf, 64, "    %%t{lld} =l copy $__str{lld}\n", {fmt_tmp, fmt_idx})
                        emit(ctx, fmt_buf)
                        @free(fmt_buf)

                        val variadic_args: mut list[ref u8] = []
                        val ai_p: mut i64 = 1
                        for {
                            if ai_p >= alen_p { break }
                            val arg_opt_p = @get(args_list, ai_p as usize)
                            match arg_opt_p {
                                some arg_p => {
                                    val arg_node_p: ref parser.Node = arg_p as ref parser.Node
                                    if arg_node_p.kind == parser.NK_ARGS_PACK {
                                        val pack_p: ref void = arg_node_p.d0 as ref void
                                        val plen_p: i64 = @len(pack_p) as i64
                                        val pi_p: mut i64 = 0
                                        for {
                                            if pi_p >= plen_p { break }
                                            val pe_opt_p = @get(pack_p, pi_p as usize)
                                            match pe_opt_p {
                                                some pe_p => {
                                                    val pe_node_p: ref parser.Node = pe_p as ref parser.Node
                                                    val pbuf_p: ref u8 = gen_variadic_arg(ctx, pe_node_p)
                                                    @append(variadic_args, pbuf_p)
                                                }
                                                none => {}
                                            }
                                            pi_p++
                                        }
                                    } else {
                                        val abuf_p: ref u8 = gen_variadic_arg(ctx, arg_node_p)
                                        @append(variadic_args, abuf_p)
                                    }
                                }
                                none => {}
                            }
                            ai_p++
                        }

                        val result_tmp: i64 = fresh_tmp(ctx)
                        val call_buf_p: ref u8 = @alloc(4096) as ref u8
                        val vlen: i64 = @len(variadic_args) as i64
                        if vlen == 0 {
                            @snprintf(call_buf_p, 4096, "    %%t{lld} =l call $printf(l %%t{lld}, ..., l 0)\n", {result_tmp, fmt_tmp})
                        } else {
                            val call_pos_p: mut i64 = 0
                            val hdr_p: ref u8 = @alloc(256) as ref u8
                            @snprintf(hdr_p, 256, "    %%t{lld} =l call $printf(l %%t{lld}, ...", {result_tmp, fmt_tmp})
                            val hdr_len_p: i64 = str.len_raw(hdr_p)
                            @memcpy(@ptradd(call_buf_p as ref void, call_pos_p), hdr_p as ref void, hdr_len_p)
                            call_pos_p = call_pos_p + hdr_len_p
                            @free(hdr_p)

                            val vi: mut i64 = 0
                            for {
                                if vi >= vlen { break }
                                val v_opt = @get(variadic_args, vi as usize)
                                match v_opt {
                                    some v => {
                                        val vstr: ref u8 = v as ref u8
                                        val vlen2: i64 = str.len_raw(vstr)
                                        @memcpy(@ptradd(call_buf_p as ref void, call_pos_p), ", " as ref void, 2)
                                        call_pos_p = call_pos_p + 2
                                        @memcpy(@ptradd(call_buf_p as ref void, call_pos_p), vstr as ref void, vlen2)
                                        call_pos_p = call_pos_p + vlen2
                                    }
                                    none => {}
                                }
                                vi++
                            }
                            @store8(@ptradd(call_buf_p as ref void, call_pos_p), 41) // ')'
                            call_pos_p++
                            @store8(@ptradd(call_buf_p as ref void, call_pos_p), 10) // '\n'
                            call_pos_p++
                            @store8(@ptradd(call_buf_p as ref void, call_pos_p), 0)
                        }
                        emit(ctx, call_buf_p)
                        @free(call_buf_p)

                        val res_p: ref u8 = @alloc(16) as ref u8
                        @snprintf(res_p, 16, "%%t{lld}", {result_tmp})
                        return res_p
                    }
                }
                none => {}
            }
        }
    }

    val arg_tmps: mut list[ref u8] = []
    val arg_qts: mut list[ref u8] = []

    if args_list != 0 as ref void {
        val alen: i64 = @len(args_list) as i64
        val ai: mut i64 = 0
        for {
            if ai >= alen { break }
            val arg_opt = @get(args_list, ai as usize)
            match arg_opt {
                some arg => {
                    val arg_node: ref parser.Node = arg as ref parser.Node
                    val ak: i64 = arg_node.kind
                    if ak == parser.NK_ARGS_PACK {
                        val pack: ref void = arg_node.d0 as ref void
                        val plen: i64 = @len(pack) as i64
                        val pi: mut i64 = 0
                        for {
                            if pi >= plen { break }
                            val pe_opt = @get(pack, pi as usize)
                            match pe_opt {
                                some pe => {
                                    val pe_node: ref parser.Node = pe as ref parser.Node
                                    val pt: ref u8 = gen_expr(ctx, pe_node)
                                    @append(arg_tmps, pt)
                                    @append(arg_qts, expr_qbe_type(ctx, pe_node))
                                }
                                none => {}
                            }
                            pi++
                        }
                    } else {
                        val at: ref u8 = gen_expr(ctx, arg_node)
                        @append(arg_tmps, at)
                        @append(arg_qts, expr_qbe_type(ctx, arg_node))
                    }
                }
                none => {}
            }
            ai++
        }
    }

    val tmp: mut i64 = fresh_tmp(ctx)
    val resolved_callee: ref u8 = cg_resolve_fn_name(ctx, callee_name)
    val ext_sym2: ref u8 = cg_lookup_extern_symbol(ctx, callee_name)
    val effective_callee: mut ref u8 = ""
    if resolved_callee != 0 as ref u8 {
        effective_callee = resolved_callee
    } elif ext_sym2 != 0 as ref u8 {
        effective_callee = ext_sym2
    } else {
        effective_callee = callee_name
    }
    val fn_params_list: ref void = cg_lookup_fn_params(ctx, effective_callee)
    if fn_params_list != 0 as ref void {
        val plen: i64 = @len(fn_params_list) as i64
        val tlen0: i64 = @len(arg_tmps) as i64
        val wi: mut i64 = 0
        for {
            if wi >= plen { break }
            if wi >= tlen0 { break }
            val p_opt = @get(fn_params_list, wi as usize)
            match p_opt {
                some p => {
                    val param_node: ref parser.Node = p as ref parser.Node
                    val pty: ref parser.Node = param_node.d1 as ref parser.Node
                    if pty != 0 as ref parser.Node && pty.kind == parser.TY_NAMED {
                        val ptype_name: ref u8 = pty.d0 as ref u8
                        val union_vars: ref void = cg_lookup_union_suffix(ctx, ptype_name)
                        if union_vars != 0 as ref void {
                            val at_opt = @get(arg_tmps, wi as usize)
                            match at_opt {
                                some at => {
                                    val arg_val: ref u8 = at as ref u8
                                    val should_wrap: mut bool = true
                                    if @load8(arg_val) as i64 == 37 {
                                        val second: i64 = @load8(@ptradd(arg_val, 1)) as i64
                                        if second == 116 {
                                            should_wrap = false
                                        }
                                    }

                                    if should_wrap {
                                        val box_ptr: i64 = fresh_tmp(ctx)
                                        val payload_ptr: i64 = fresh_tmp(ctx)
                                        val bbuf: ref u8 = @alloc(256) as ref u8
                                        @snprintf(bbuf, 256,
                                            "    %%t{lld} =l call $malloc(l 16)\n    storew 0, %%t{lld}\n    %%t{lld} =l add %%t{lld}, 8\n    storel {s}, %%t{lld}\n",
                                            {box_ptr, box_ptr, payload_ptr, box_ptr, arg_val, payload_ptr})
                                        emit(ctx, bbuf)
                                        @free(bbuf)
                                        val wrapped: ref u8 = @alloc(16) as ref u8
                                        @snprintf(wrapped, 16, "%%t{lld}", {box_ptr})
                                        val new_tmps: mut list[ref u8] = []
                                        val tlen_r: i64 = @len(arg_tmps) as i64
                                        val ri: mut i64 = 0
                                        for {
                                            if ri >= tlen_r { break }
                                            val r_opt = @get(arg_tmps, ri as usize)
                                            match r_opt {
                                                some r => {
                                                    if ri == wi {
                                                        @append(new_tmps, wrapped)
                                                    } else {
                                                        @append(new_tmps, r as ref u8)
                                                    }
                                                }
                                                none => {}
                                            }
                                            ri++
                                        }
                                        arg_tmps = new_tmps
                                    }
                                }
                                none => {}
                            }
                        }
                    }
                }
                none => {}
            }
            wi++
        }
    }

    val call_buf: ref u8 = @alloc(8192) as ref u8
    val call_pos: mut i64 = 0
    val hdr: ref u8 = @alloc(256) as ref u8
    val using_ext: bool = ext_sym2 != 0 as ref u8 && effective_callee == ext_sym2
    val is_fn_ptr: bool = resolved_callee == 0 as ref u8
        && !using_ext
        && callee_node.kind == parser.NK_IDENT

    val ret_qtype: mut ref u8 = "l"
    val ret_union_name: mut ref u8 = ""
    if using_ext {
        val ret_ty: ref void = cg_lookup_ext_ret(ctx, callee_raw)
        if ret_ty != 0 as ref void {
            ret_qtype = qbe_type_of(ret_ty as ref parser.Node)
            ret_union_name = is_union_type(ctx, ret_ty as ref parser.Node)
        }
    } else {
        val lookup_name: mut ref u8 = callee_name
        if resolved_callee != 0 as ref u8 {
            lookup_name = resolved_callee
        }
        val ret_ty: ref void = cg_lookup_fn_ret(ctx, lookup_name)
        if ret_ty != 0 as ref void {
            ret_qtype = qbe_type_of(ret_ty as ref parser.Node)
            ret_union_name = is_union_type(ctx, ret_ty as ref parser.Node)
        }
    }

    val returns_union: bool = str.rchar_cmp(ret_union_name, "") != 0
    val ret_buf_tmp: mut i64 = -1

    if returns_union {
        ret_buf_tmp = fresh_tmp(ctx)
        val alloc_buf: ref u8 = @alloc(64) as ref u8
        @snprintf(alloc_buf, 64, "    %%t{lld} =l alloc8 16\n", {ret_buf_tmp})
        emit(ctx, alloc_buf)
        @free(alloc_buf)
    }

    if is_fn_ptr {
        val dqt: ref u8 = cg_direct_type(ctx, callee_name)
        if str.rchar_cmp(dqt, "") != 0 {
            @snprintf(hdr, 256, "    %%t{lld} ={s} call %%{s}(", {tmp, ret_qtype, callee_name})
        } else {
            val ptr_tmp: i64 = fresh_tmp(ctx)
            val load_buf: ref u8 = @alloc(64) as ref u8
            @snprintf(load_buf, 64, "    %%t{lld} =l loadl %%{s}\n", {ptr_tmp, callee_name})
            emit(ctx, load_buf)
            @free(load_buf)
            @snprintf(hdr, 256, "    %%t{lld} ={s} call %%t{lld}(", {tmp, ret_qtype, ptr_tmp})
        }
    } else {
        @snprintf(hdr, 256, "    %%t{lld} ={s} call ${s}(", {tmp, ret_qtype, effective_callee})
    }
    val hdr_len: i64 = str.len_raw(hdr)
    @memcpy(@ptradd(call_buf as ref void, call_pos), hdr as ref void, hdr_len)
    call_pos = call_pos + hdr_len
    @free(hdr)

    val tlen: i64 = @len(arg_tmps) as i64

    // If returning a union, add the return buffer as the first argument
    if returns_union {
        val ret_arg: ref u8 = @alloc(32) as ref u8
        @snprintf(ret_arg, 32, "l %%t{lld}", {ret_buf_tmp})
        val ret_arg_len: i64 = str.len_raw(ret_arg)
        @memcpy(@ptradd(call_buf as ref void, call_pos), ret_arg as ref void, ret_arg_len)
        call_pos = call_pos + ret_arg_len
        @free(ret_arg)
        if tlen > 0 {
            @memcpy(@ptradd(call_buf as ref void, call_pos), ", " as ref void, 2)
            call_pos = call_pos + 2
        }
    }

    val ti: mut i64 = 0
    for {
        if ti >= tlen { break }
        val t_opt = @get(arg_tmps, ti as usize)
        match t_opt {
            some t => {
                val tbuf: ref u8 = @alloc(64) as ref u8
                val src_qtype: mut ref u8 = "l"
                if ti > 0 {
                    @memcpy(@ptradd(call_buf as ref void, call_pos), ", " as ref void, 2)
                    call_pos = call_pos + 2
                }

                val arg_qtype: mut ref u8 = "l"
                if fn_params_list != 0 as ref void {
                    val params_len: i64 = @len(fn_params_list as list[ref void]) as i64
                    if ti < params_len {
                        val param_opt = @get(fn_params_list as list[ref void], ti as usize)
                        match param_opt {
                            some param => {
                                val param_node: ref parser.Node = param as ref parser.Node
                                if param_node != 0 as ref parser.Node {
                                    val param_ty: ref parser.Node = param_node.d1 as ref parser.Node
                                    if param_ty != 0 as ref parser.Node {
                                        arg_qtype = qbe_type_of(param_ty)
                                    }
                                }
                            }
                            none => {}
                        }
                    }
                }
                val src_qt_opt = @get(arg_qts, ti as usize)
                match src_qt_opt {
                    some sq => { src_qtype = sq as ref u8 }
                    none => {}
                }
                val call_arg: ref u8 = cg_coerce_qtype(ctx, t as ref u8, src_qtype, arg_qtype)
                @snprintf(tbuf, 64, "{s} {s}", {arg_qtype, call_arg})
                val tlen2: i64 = str.len_raw(tbuf)
                @memcpy(@ptradd(call_buf as ref void, call_pos), tbuf as ref void, tlen2)
                call_pos = call_pos + tlen2
                @free(tbuf)
            }
            none => {}
        }
        ti++
    }
    @store8(@ptradd(call_buf as ref void, call_pos), 41) // ')'
    call_pos = call_pos + 1
    @store8(@ptradd(call_buf as ref void, call_pos), 0)
    emitln(ctx, call_buf)

    if using_ext {
        val ret_ty2: ref void = cg_lookup_ext_ret(ctx, callee_raw)
        if ret_ty2 != 0 as ref void {
            val ret_qtype2: ref u8 = qbe_type_of(ret_ty2 as ref parser.Node)
            if str.rchar_cmp(ret_qtype2, "w") == 0 {
                val ext_tmp: i64 = fresh_tmp(ctx)
                val ext_buf: ref u8 = @alloc(64) as ref u8
                @snprintf(ext_buf, 64, "    %%t{lld} =l extsw %%t{lld}\n", {ext_tmp, tmp})
                emit(ctx, ext_buf)
                @free(ext_buf)
                tmp = ext_tmp
            }
        }
    }

    // If the function returns a union, return the buffer pointer instead of the call result
    val result_tmp: mut i64 = tmp
    if returns_union {
        result_tmp = ret_buf_tmp
    }

    val res: ref u8 = @alloc(16) as ref u8
    @snprintf(res, 16, "%%t{lld}", {result_tmp})
    return res
}

fn resolve_callee_name(ctx: ref CgCtx, node: ref parser.Node) ref u8! = {
    val k: i64 = node.kind as i64
    if k == parser.NK_IDENT {
        val name: ref u8 = node.d0 as ref u8
        val resolved_name: ref u8 = gsubst_resolve_name(ctx, name)
        if str.rchar_cmp(resolved_name, "") != 0 {
            return resolved_name
        }
        return name
    }
    if k == parser.NK_FIELD {
        if cg_is_c_escape_expr(node) {
            return cg_raw_c_name(node)
        }
        val base: ref u8 = resolve_callee_name(ctx, parser.field_base(node))
        val field: ref u8 = parser.field_name(node)
        val buf: ref u8 = @alloc(256) as ref u8
        @snprintf(buf, 256, "{s}__{s}", {base, field})
        return buf
    }
    return "unknown"
}

fn get_arg(ctx: ref CgCtx, args: ref void, i: i64) ref u8! = {
    val opt = @get(args, i as usize)
    match opt {
        some a => { return gen_expr(ctx, a as ref parser.Node) }
        none => { return "0" }
    }
}

/// Like get_arg but for format strings - interns with format rewriting.
fn get_format_arg(ctx: ref CgCtx, args: ref void, i: i64) ref u8! = {
    val opt = @get(args, i as usize)
    match opt {
        some a => {
            val node: ref parser.Node = a as ref parser.Node
            if node.kind == parser.NK_STR_LIT {
                val s: ref u8 = parser.str_lit_text(node)
                val idx: i64 = intern_format_string(ctx, s)
                val tmp: i64 = fresh_tmp(ctx)
                val buf: ref u8 = @alloc(64) as ref u8
                @snprintf(buf, 64, "    %%t{lld} =l copy $__str{lld}\n", {tmp, idx})
                emit(ctx, buf)
                @free(buf)
                val res: ref u8 = @alloc(16) as ref u8
                @snprintf(res, 16, "%%t{lld}", {tmp})
                return res
            } else {
                return gen_expr(ctx, node)
            }
        }
        none => { return "0" }
    }
}

/// Like get_arg but returns the address of the list header (for list builtins).
fn get_list_arg(ctx: ref CgCtx, args: ref void, i: i64) ref u8! = {
    val opt = @get(args, i as usize)
    match opt {
        some a => { return gen_list_ptr(ctx, a as ref parser.Node) }
        none => { return "0" }
    }
}

/// Returns the QBE type ("d", "s", or "l") for an expression node without generating code.
fn expr_qtype(ctx: ref CgCtx, node: ref parser.Node) ref u8! = {
    if node == 0 as ref parser.Node { return "l" }
    val k: i64 = node.kind
    if k == parser.NK_FLOAT_LIT {
        if ctx.expected_ty != 0 as ref void {
            val expected_qt: ref u8 = qbe_type_of(ctx.expected_ty as ref parser.Node)
            if str.rchar_cmp(expected_qt, "s") == 0 { return "s" }
        }
        return "d"
    }
    if k == parser.NK_INT_LIT { return "l" }
    if k == parser.NK_IDENT {
        val vname: ref u8 = node.d0 as ref u8
        val dqt: ref u8 = cg_direct_type(ctx, vname)
        if str.rchar_cmp(dqt, "") != 0 { return dqt }
        val ltype: ref u8 = cg_local_type(ctx, vname)
        if str.rchar_cmp(ltype, "f64") == 0 { return "d" }
        if str.rchar_cmp(ltype, "f32") == 0 { return "s" }
        if str.rchar_cmp(ltype, "i32") == 0 { return "w" }
        if str.rchar_cmp(ltype, "u32") == 0 { return "w" }
        if str.rchar_cmp(ltype, "bool") == 0 { return "w" }
    }
    if k == parser.NK_CAST {
        val ty: ref parser.Node = node.d1 as ref parser.Node
        return qbe_type_of(ty)
    }
    return "l"
}

fn gen_builtin(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    val name: ref u8 = expr.d0 as ref u8
    val args: ref void = expr.d1 as ref void

    if str.rchar_cmp(name, "staticerror") == 0 {
        val msg: mut ref u8 = ""
        if args != 0 as ref void {
            val arg0_opt = @get(args, 0)
            match arg0_opt {
                some arg0 => {
                    val arg_node: ref parser.Node = arg0 as ref parser.Node
                    if arg_node.kind == parser.NK_STR_LIT {
                        msg = arg_node.d0 as ref u8
                    }
                }
                none => {}
            }
        }
        val line: i64 = expr.line
        val filename: ref u8 = ctx.current_filename
        if str.rchar_cmp(filename, "") == 0 {
            stdio.eprint("error: line {lld}: {s}\n", {line, msg})
        } else {
            stdio.eprint("error: {s}:{lld}: {s}\n", {filename, line, msg})
        }
        os.exit(1)
    }

    val tmp: mut i64 = fresh_tmp(ctx)
    val buf: ref u8 = @alloc(512) as ref u8

    if str.rchar_cmp(name, "alloc") == 0 {
        val sz: ref u8 = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    %%t{lld} =l call $malloc(l {s})\n", {tmp, sz})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "free") == 0 {
        val ptr: ref u8 = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    call $free(l {s})\n    %%t{lld} =l copy 0\n", {ptr, tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "realloc") == 0 {
        val ptr2: ref u8 = get_arg(ctx, args, 0)
        val sz2: ref u8 = get_arg(ctx, args, 1)
        @snprintf(buf, 512, "    %%t{lld} =l call $realloc(l {s}, l {s})\n", {tmp, ptr2, sz2})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "memcpy") == 0 {
        val dst: ref u8 = get_arg(ctx, args, 0)
        val src: ref u8 = get_arg(ctx, args, 1)
        val len: ref u8 = get_arg(ctx, args, 2)
        @snprintf(buf, 512, "    call $memcpy(l {s}, l {s}, l {s})\n    %%t{lld} =l copy 0\n", {dst, src, len, tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "memset") == 0 {
        val dst2: ref u8 = get_arg(ctx, args, 0)
        val val2: ref u8 = get_arg(ctx, args, 1)
        val len2: ref u8 = get_arg(ctx, args, 2)
        @snprintf(buf, 512, "    call $memset(l {s}, w {s}, l {s})\n    %%t{lld} =l copy 0\n", {dst2, val2, len2, tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "load") == 0 {
        val ptr3: ref u8 = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    %%t{lld} =l loadl {s}\n", {tmp, ptr3})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "store") == 0 {
        val ptr4: ref u8 = get_arg(ctx, args, 0)
        val val3_node_opt = @get(args, 1)
        val val3: ref u8 = get_arg(ctx, args, 1)
        val val3_qtype: mut ref u8 = "l"

        match val3_node_opt {
            some vn => {
                val3_qtype = expr_qbe_type(ctx, vn as ref parser.Node)
            }
            none => {}
        }

        if str.rchar_cmp(val3_qtype, "w") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(ext_buf, 128, "    %%t{lld} =l extsw {s}\n", {ext_tmp, val3})
            emit(ctx, ext_buf)
            @free(ext_buf)
            @snprintf(buf, 512, "    storel %%t{lld}, {s}\n    %%t{lld} =l copy 0\n", {ext_tmp, ptr4, tmp})
        } else {
            @snprintf(buf, 512, "    storel {s}, {s}\n    %%t{lld} =l copy 0\n", {val3, ptr4, tmp})
        }
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "load8") == 0 {
        val ptr5: ref u8 = get_arg(ctx, args, 0)
        val w_tmp: i64 = fresh_tmp(ctx)
        val wbuf: ref u8 = @alloc(64) as ref u8
        @snprintf(wbuf, 64, "    %%t{lld} =w loadub {s}\n", {w_tmp, ptr5})
        emit(ctx, wbuf)
        @free(wbuf)
        @snprintf(buf, 512, "    %%t{lld} =l extsw %%t{lld}\n", {tmp, w_tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "store8") == 0 {
        val ptr6: ref u8 = get_arg(ctx, args, 0)
        val val4: ref u8 = get_arg(ctx, args, 1)
        @snprintf(buf, 512, "    storeb {s}, {s}\n    %%t{lld} =l copy 0\n", {val4, ptr6, tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "ptradd") == 0 {
        val ptr7: ref u8 = get_arg(ctx, args, 0)
        val off: ref u8 = get_arg(ctx, args, 1)
        @snprintf(buf, 512, "    %%t{lld} =l add {s}, {s}\n", {tmp, ptr7, off})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "puts") == 0 {
        val s: ref u8 = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    %%t{lld} =w call $puts(l {s})\n", {tmp, s})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "flush") == 0 {
        @snprintf(buf, 512, "    %%t{lld} =w call $fflush(l 0)\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "print") == 0 {
        val fmt: ref u8 = get_format_arg(ctx, args, 0)
        val call_buf2: ref u8 = @alloc(4096) as ref u8
        val call_pos2: mut i64 = 0
        val hdr2: ref u8 = @alloc(256) as ref u8
        @snprintf(hdr2, 256, "    %%t{lld} =w call $printf(l {s}, ...", {tmp, fmt})
        val hdr2_len: i64 = str.len_raw(hdr2 as ref u8)
        @memcpy(@ptradd(call_buf2 as ref void, call_pos2), hdr2 as ref void, hdr2_len)
        call_pos2 = call_pos2 + hdr2_len
        @free(hdr2)
        if args != 0 as ref void {
            val alen2: i64 = @len(args) as i64
            if alen2 > 1 {
                val pack_opt = @get(args, 1)
                match pack_opt {
                    some pack_node => {
                        val pn: ref parser.Node = pack_node as ref parser.Node
                        if pn.kind == parser.NK_ARGS_PACK {
                            val pack: ref void = pn.d0 as ref void
                            val plen2: i64 = @len(pack) as i64
                            val pi2: mut i64 = 0
                            for {
                                if pi2 >= plen2 { break }
                                val pe_opt = @get(pack, pi2 as usize)
                                match pe_opt {
                                    some pe => {
                                        val pe_node: ref parser.Node = pe as ref parser.Node
                                        val pvarg: ref u8 = gen_variadic_arg(ctx, pe_node)
                                        val pbuf2: ref u8 = @alloc(64) as ref u8
                                        @snprintf(pbuf2, 64, ", {s}", {pvarg})
                                        val pbuf2_len: i64 = str.len_raw(pbuf2)
                                        @memcpy(@ptradd(call_buf2 as ref void, call_pos2), pbuf2 as ref void, pbuf2_len)
                                        call_pos2 = call_pos2 + pbuf2_len
                                        @free(pvarg)
                                        @free(pbuf2)
                                    }
                                    none => {}
                                }
                                pi2++
                            }
                        }
                    }
                    none => {}
                }
            }
        }
        @store8(@ptradd(call_buf2 as ref void, call_pos2), 41) // ')'
        call_pos2++
        @store8(@ptradd(call_buf2 as ref void, call_pos2), 10) // '\n'
        call_pos2++
        @store8(@ptradd(call_buf2 as ref void, call_pos2), 0)
        emit(ctx, call_buf2)
    } elif str.rchar_cmp(name, "snprintf") == 0 {
        val sbuf: ref u8 = get_arg(ctx, args, 0)
        val ssz: ref u8 = get_arg(ctx, args, 1)
        val sfmt: ref u8 = get_format_arg(ctx, args, 2)
        val scall_sb: ref void = str.StringBuilder.new()
        val shdr: ref u8 = @alloc(256) as ref u8
        @snprintf(shdr, 256, "    %%t{lld} =w call $snprintf(l {s}, l {s}, l {s}, ...", {tmp, sbuf, ssz, sfmt})
        str.StringBuilder.append_cstr(scall_sb, shdr)
        @free(shdr)
        if args != 0 as ref void {
            val salen: i64 = @len(args) as i64
            if salen > 3 {
                val spack_opt = @get(args, 3)
                match spack_opt {
                    some spack_node => {
                        val spn: ref parser.Node = spack_node as ref parser.Node
                         if spn.kind == parser.NK_ARGS_PACK {
                            val spack: ref void = spn.d0 as ref void
                            val splen: i64 = @len(spack) as i64
                            val spi: mut i64 = 0
                            for {
                                if spi >= splen { break }
                                val spe_opt = @get(spack, spi as usize)
                                match spe_opt {
                                    some spe => {
                                        val spe_node: ref parser.Node = spe as ref parser.Node
                                        val svarg: ref u8 = gen_variadic_arg(ctx, spe_node)
                                        val spbuf: ref u8 = @alloc(64) as ref u8
                                        @snprintf(spbuf, 64, ", {s}", {svarg})
                                        str.StringBuilder.append_cstr(scall_sb, spbuf)
                                        @free(spbuf)
                                        @free(svarg)
                                    }
                                    none => {}
                                }
                                spi++
                            }
                        } else {
                            // Single non-pack argument (e.g. untyped parameter passthrough)
                            val svarg2: ref u8 = gen_variadic_arg(ctx, spn)
                            val spbuf2: ref u8 = @alloc(64) as ref u8
                            @snprintf(spbuf2, 64, ", {s}", {svarg2})
                            str.StringBuilder.append_cstr(scall_sb, spbuf2)
                            @free(spbuf2)
                            @free(svarg2)
                        }
                    }
                    none => {}
                }
            }
        }
        str.StringBuilder.append_cstr(scall_sb, ")\n")
        val scall_line: ref void = str.StringBuilder.build(scall_sb)
        str.StringBuilder.free(scall_sb)
        emit(ctx, str.cstr(scall_line))
        val sext_tmp: i64 = fresh_tmp(ctx)
        val sext_buf: ref u8 = @alloc(64) as ref u8
        @snprintf(sext_buf, 64, "    %%t{lld} =l extsw %%t{lld}\n", {sext_tmp, tmp})
        emit(ctx, sext_buf)
        @free(sext_buf)
        @free(buf)
        val sres: ref u8 = @alloc(16) as ref u8
        @snprintf(sres, 16, "%%t{lld}", {sext_tmp})
        return sres
    } elif str.rchar_cmp(name, "strlen") == 0 {
        val s2: ref u8 = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    %%t{lld} =l call $strlen(l {s})\n", {tmp, s2})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "strcmp") == 0 {
        val a: ref u8 = get_arg(ctx, args, 0)
        val b: ref u8 = get_arg(ctx, args, 1)
        @snprintf(buf, 512, "    %%t{lld} =l call $strcmp(l {s}, l {s})\n", {tmp, a, b})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "atoi") == 0 {
        val s3: ref u8 = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    %%t{lld} =l call $atoi(l {s})\n", {tmp, s3})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "append") == 0 {
        val lst: ref u8 = get_list_arg(ctx, args, 0)
        val val5_node_opt = @get(args, 1)
        val val5_qtype: mut ref u8 = "l"
        val val5: ref u8 = get_arg(ctx, args, 1)
        match val5_node_opt {
            some vn => {
                val5_qtype = expr_qtype(ctx, vn as ref parser.Node)
            }
            none => {}
        }

        val len_slot: i64 = fresh_tmp(ctx)
        val cap_slot: i64 = fresh_tmp(ctx)
        val buf_app1: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_app1, 256, "    %%t{lld} =l add {s}, 8\n    %%t{lld} =l add {s}, 16\n", {len_slot, lst, cap_slot, lst})
        emit(ctx, buf_app1)
        @free(buf_app1)

        val len_val: i64 = fresh_tmp(ctx)
        val cap_val: i64 = fresh_tmp(ctx)
        val buf_app2: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_app2, 256, "    %%t{lld} =l loadl %%t{lld}\n    %%t{lld} =l loadl %%t{lld}\n", {len_val, len_slot, cap_val, cap_slot})
        emit(ctx, buf_app2)
        @free(buf_app2)

        val need_grow: i64 = fresh_tmp(ctx)
        val grow_lbl: i64 = fresh_lbl(ctx)
        val no_grow_lbl: i64 = fresh_lbl(ctx)
        val lt: i64 = fresh_tmp(ctx)
        val buf_app3: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_app3, 256, "    %%t{lld} =w csltl %%t{lld}, %%t{lld}\n    %%t{lld} =w ceqw %%t{lld}, 0\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n", {lt, len_val, cap_val, need_grow, lt, need_grow, grow_lbl, no_grow_lbl})
        emit(ctx, buf_app3)
        @free(buf_app3)

        val buf_app4: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_app4, 64, "@lbl{lld}\n", {grow_lbl})
        emit(ctx, buf_app4)
        @free(buf_app4)

        val new_cap_tmp: i64 = fresh_tmp(ctx)
        val new_cap: i64 = fresh_tmp(ctx)
        val buf_app5: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_app5, 256, "    %%t{lld} =l mul %%t{lld}, 2\n    %%t{lld} =l add %%t{lld}, 1\n", {new_cap_tmp, cap_val, new_cap, new_cap_tmp})
        emit(ctx, buf_app5)
        @free(buf_app5)

        val old_buf: i64 = fresh_tmp(ctx)
        val new_buf: i64 = fresh_tmp(ctx)
        val new_cap_bytes: i64 = fresh_tmp(ctx)
        val buf_app6: ref u8 = @alloc(512) as ref u8
        @snprintf(buf_app6, 512, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l mul %%t{lld}, 8\n    %%t{lld} =l call $realloc(l %%t{lld}, l %%t{lld})\n    storel %%t{lld}, {s}\n    storel %%t{lld}, %%t{lld}\n    jmp @lbl{lld}\n",
            {old_buf, lst, new_cap_bytes, new_cap, new_buf, old_buf, new_cap_bytes, new_buf, lst, new_cap, cap_slot, no_grow_lbl})
        emit(ctx, buf_app6)
        @free(buf_app6)

        val buf_app7: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_app7, 64, "@lbl{lld}\n", {no_grow_lbl})
        emit(ctx, buf_app7)
        @free(buf_app7)

        val buf_tmp: i64 = fresh_tmp(ctx)
        val off: i64 = fresh_tmp(ctx)
        val elem_ptr: i64 = fresh_tmp(ctx)
        val buf_app8a: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_app8a, 256, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l mul %%t{lld}, 8\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n",
            {buf_tmp, lst, off, len_val, elem_ptr, buf_tmp, off})
        emit(ctx, buf_app8a)
        @free(buf_app8a)
        val store_val: mut ref u8 = val5
        if str.rchar_cmp(val5_qtype, "w") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref u8 = @alloc(64) as ref u8
            val first_ch: i64 = @load8(@ptradd(val5 as ref void, 0)) as i64
            if ((first_ch >= 48 && first_ch <= 57) || first_ch == 45) {
                @snprintf(ext_buf, 64, "    %%t{lld} =l copy {s}\n", {ext_tmp, val5})
            } else {
                @snprintf(ext_buf, 64, "    %%t{lld} =l extsw {s}\n", {ext_tmp, val5})
            }
            emit(ctx, ext_buf)
            @free(ext_buf)
            val sv: ref u8 = @alloc(16) as ref u8
            @snprintf(sv, 16, "%%t{lld}", {ext_tmp})
            store_val = sv
        } elif str.rchar_cmp(val5_qtype, "d") == 0 {
            val cast_app: i64 = fresh_tmp(ctx)
            val cast_app_buf: ref u8 = @alloc(64) as ref u8
            @snprintf(cast_app_buf, 64, "    %%t{lld} =l cast {s}\n", {cast_app, val5})
            emit(ctx, cast_app_buf)
            @free(cast_app_buf)
            val sv2: ref u8 = @alloc(16) as ref u8
            @snprintf(sv2, 16, "%%t{lld}", {cast_app})
            store_val = sv2
        }
        val buf_app8b: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_app8b, 64, "    storel {s}, %%t{lld}\n", {store_val, elem_ptr})
        emit(ctx, buf_app8b)
        @free(buf_app8b)

        val new_len: i64 = fresh_tmp(ctx)
        val buf_app9: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_app9, 256, "    %%t{lld} =l add %%t{lld}, 1\n    storel %%t{lld}, %%t{lld}\n", {new_len, len_val, new_len, len_slot})
        emit(ctx, buf_app9)
        @free(buf_app9)

        @snprintf(buf, 512, "    %%t{lld} =l copy 0\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "sizeof") == 0 {
        val arg_node_opt = @get(args, 0)
        val sizeof_val: mut i64 = 0
        match arg_node_opt {
            some arg_node => {
                val arg_nd: ref parser.Node = arg_node as ref parser.Node
                val arg_k: i64 = arg_nd.kind
                if arg_k == parser.NK_IDENT {
                    val vname: ref u8 = arg_nd.d0 as ref u8
                    val flds: ref void = cg_lookup_struct(ctx, vname)
                    if flds != 0 as ref void {
                        sizeof_val = struct_size(ctx, flds)
                    } else {
                        val ltype: ref u8 = cg_local_type(ctx, vname)
                        if str.rchar_cmp(ltype, "") != 0 {
                            val fake_ty: mut ref parser.Node = 0 as ref parser.Node
                            if str.rchar_cmp(ltype, "i8") == 0 || str.rchar_cmp(ltype, "u8") == 0 || str.rchar_cmp(ltype, "u8") == 0 {
                                fake_ty = parser.make_node(parser.TY_NAMED, 0)
                                fake_ty.d0 = ltype as i64
                                sizeof_val = type_size(fake_ty)
                            } elif str.rchar_cmp(ltype, "i16") == 0 || str.rchar_cmp(ltype, "u16") == 0 {
                                fake_ty = parser.make_node(parser.TY_NAMED, 0)
                                fake_ty.d0 = ltype as i64
                                sizeof_val = type_size(fake_ty)
                            } elif str.rchar_cmp(ltype, "i32") == 0 || str.rchar_cmp(ltype, "u32") == 0 || str.rchar_cmp(ltype, "f32") == 0 {
                                fake_ty = parser.make_node(parser.TY_NAMED, 0)
                                fake_ty.d0 = ltype as i64
                                sizeof_val = type_size(fake_ty)
                            } elif str.rchar_cmp(ltype, "i64") == 0 || str.rchar_cmp(ltype, "u64") == 0 || str.rchar_cmp(ltype, "f64") == 0 {
                                sizeof_val = 8
                            } elif str.rchar_cmp(ltype, "bool") == 0 {
                                sizeof_val = 4
                            } else {
                                val flds2: ref void = cg_lookup_struct(ctx, ltype)
                                if flds2 != 0 as ref void {
                                    sizeof_val = struct_size(ctx, flds2)
                                } else {
                                    sizeof_val = 8
                                }
                            }
                        } else {
                            sizeof_val = 8
                        }
                    }
                } elif arg_k == parser.NK_CAST {
                    val ty: ref parser.Node = arg_nd.d1 as ref parser.Node
                    sizeof_val = type_size(ty)
                } elif arg_k == parser.TY_NAMED {
                    val tname: ref u8 = arg_nd.d0 as ref u8
                    val flds: ref void = cg_lookup_struct(ctx, tname)
                    if flds != 0 as ref void {
                        sizeof_val = struct_size(ctx, flds)
                    } else {
                        sizeof_val = type_size(arg_nd)
                    }
                } elif arg_k == parser.TY_LIST || arg_k == parser.TY_REF ||
                       arg_k == parser.TY_MUT || arg_k == parser.TY_OPTION || arg_k == parser.TY_RESULT ||
                       arg_k == parser.TY_SLICE || arg_k == parser.TY_FIXED_ARR || arg_k == parser.TY_FNPTR ||
                       arg_k == parser.TY_VOID {
                    sizeof_val = type_size(arg_nd)
                } else {
                    sizeof_val = 8
                }
            }
            none => {
                sizeof_val = 0
            }
        }
        @snprintf(buf, 512, "    %%t{lld} =l copy {lld}\n", {tmp, sizeof_val})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "len") == 0 {
        val lst2: ref u8 = get_list_arg(ctx, args, 0)
        val len_slot: i64 = fresh_tmp(ctx)
        val len_val: i64 = fresh_tmp(ctx)
        @snprintf(buf, 512, "    %%t{lld} =l add {s}, 8\n    %%t{lld} =l loadl %%t{lld}\n", {len_slot, lst2, len_val, len_slot})
        emit(ctx, buf)
        tmp = len_val
    } elif str.rchar_cmp(name, "get") == 0 {
        val arg0_opt = @get(args as list[ref parser.Node], 0 as usize)
        val base_ann: mut ref u8 = ""
        match arg0_opt {
            some a0 => { base_ann = infer_type_annotation(ctx, a0 as ref parser.Node) }
            none => {}
        }

        if rchar_starts_with(base_ann, "[") {
            val arg_count: i64 = @len(args as list[ref parser.Node]) as i64
            val result_slot: i64 = fresh_tmp(ctx)
            val none_lbl: i64 = fresh_lbl(ctx)
            val end_lbl: i64 = fresh_lbl(ctx)
            val base_ptr_name: mut ref u8 = get_arg(ctx, args, 0)
            val cur_ann: mut ref u8 = base_ann
            val ai: mut i64 = 1

            val init_buf: ref u8 = @alloc(64) as ref u8
            @snprintf(init_buf, 64, "    %%t{lld} =l alloc8 8\n", {result_slot})
            emit(ctx, init_buf)
            @free(init_buf)

            for {
                if ai >= arg_count { break }
                if !rchar_starts_with(cur_ann, "[") {
                    val fail_buf: ref u8 = @alloc(64) as ref u8
                    @snprintf(fail_buf, 64, "    jmp @lbl{lld}\n", {none_lbl})
                    emit(ctx, fail_buf)
                    @free(fail_buf)
                    break
                }
                val idx_i_raw: ref u8 = get_arg(ctx, args, ai)
                val idx_i_node_opt = @get(args as list[ref parser.Node], ai as usize)
                val idx_i_qt: mut ref u8 = "l"
                match idx_i_node_opt {
                    some idx_node => {
                        idx_i_qt = expr_qtype(ctx, idx_node as ref parser.Node)
                    }
                    none => {}
                }
                val idx_i: ref u8 = cg_coerce_qtype(ctx, idx_i_raw, idx_i_qt, "l")
                val len_i: i64 = cg_ann_fixed_arr_len_val(ctx, cur_ann)
                val next_ann: ref u8 = ann_fixed_arr_inner(cur_ann)
                val elem_sz: i64 = cg_ann_size(ctx, next_ann)
                val ok_tmp: i64 = fresh_tmp(ctx)
                val ok_lbl: i64 = fresh_lbl(ctx)
                val step_ptr: i64 = fresh_tmp(ctx)
                val step_off: i64 = fresh_tmp(ctx)
                val dim_buf: ref u8 = @alloc(384) as ref u8
                @snprintf(dim_buf, 384,
                    "    %%t{lld} =w csltl {s}, {lld}\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n    %%t{lld} =l mul {s}, {lld}\n    %%t{lld} =l add {s}, %%t{lld}\n",
                    {ok_tmp, idx_i, len_i, ok_tmp, ok_lbl, none_lbl, ok_lbl, step_off, idx_i, elem_sz, step_ptr, base_ptr_name, step_off})
                emit(ctx, dim_buf)
                @free(dim_buf)
                val step_name: ref u8 = @alloc(16) as ref u8
                @snprintf(step_name, 16, "%%t{lld}", {step_ptr})
                base_ptr_name = step_name
                cur_ann = next_ann
                ai++
            }

            if rchar_starts_with(cur_ann, "[") {
                val some_ptr: i64 = fresh_tmp(ctx)
                val some_buf: ref u8 = @alloc(128) as ref u8
                @snprintf(some_buf, 128, "    %%t{lld} =l add {s}, 1\n    storel %%t{lld}, %%t{lld}\n    jmp @lbl{lld}\n",
                    {some_ptr, base_ptr_name, some_ptr, result_slot, end_lbl})
                emit(ctx, some_buf)
                @free(some_buf)
            } else {
                val load_tmp: i64 = fresh_tmp(ctx)
                val load_instr: ref u8 = cg_ann_load_instr(cur_ann)
                val qtype_get: ref u8 = cg_ann_qtype(cur_ann)
                val done_buf: ref u8 = @alloc(512) as ref u8
                if str.rchar_cmp(qtype_get, "d") == 0 || str.rchar_cmp(qtype_get, "s") == 0 {
                    val box_tmp: i64 = fresh_tmp(ctx)
                    val some_tmp: i64 = fresh_tmp(ctx)
                    if str.rchar_cmp(qtype_get, "d") == 0 {
                        @snprintf(done_buf, 512,
                            "    %%t{lld} =d {s} {s}\n    %%t{lld} =l alloc8 8\n    stored %%t{lld}, %%t{lld}\n    %%t{lld} =l add %%t{lld}, 1\n    storel %%t{lld}, %%t{lld}\n    jmp @lbl{lld}\n",
                            {load_tmp, load_instr, base_ptr_name, box_tmp, load_tmp, box_tmp, some_tmp, box_tmp, some_tmp, result_slot, end_lbl})
                    } else {
                        @snprintf(done_buf, 512,
                            "    %%t{lld} =s {s} {s}\n    %%t{lld} =l alloc8 8\n    stores %%t{lld}, %%t{lld}\n    %%t{lld} =l add %%t{lld}, 1\n    storel %%t{lld}, %%t{lld}\n    jmp @lbl{lld}\n",
                            {load_tmp, load_instr, base_ptr_name, box_tmp, load_tmp, box_tmp, some_tmp, box_tmp, some_tmp, result_slot, end_lbl})
                    }
                } elif str.rchar_cmp(qtype_get, "w") == 0 {
                    val ext_tmp: i64 = fresh_tmp(ctx)
                    val some_tmp2: i64 = fresh_tmp(ctx)
                    val ext_instr: ref u8 = cg_ann_word_extend_instr(cur_ann)
                    @snprintf(done_buf, 512,
                        "    %%t{lld} =w {s} {s}\n    %%t{lld} =l {s} %%t{lld}\n    %%t{lld} =l add %%t{lld}, 1\n    storel %%t{lld}, %%t{lld}\n    jmp @lbl{lld}\n",
                        {load_tmp, load_instr, base_ptr_name, ext_tmp, ext_instr, load_tmp, some_tmp2, ext_tmp, some_tmp2, result_slot, end_lbl})
                } else {
                    val some_tmp3: i64 = fresh_tmp(ctx)
                    @snprintf(done_buf, 512,
                        "    %%t{lld} =l {s} {s}\n    %%t{lld} =l add %%t{lld}, 1\n    storel %%t{lld}, %%t{lld}\n    jmp @lbl{lld}\n",
                        {load_tmp, load_instr, base_ptr_name, some_tmp3, load_tmp, some_tmp3, result_slot, end_lbl})
                }
                emit(ctx, done_buf)
                @free(done_buf)
            }

            val none_buf: ref u8 = @alloc(128) as ref u8
            @snprintf(none_buf, 128, "@lbl{lld}\n    storel 0, %%t{lld}\n@lbl{lld}\n    %%t{lld} =l loadl %%t{lld}\n",
                {none_lbl, result_slot, end_lbl, tmp, result_slot})
            emit(ctx, none_buf)
            @free(none_buf)
        } else {
            val lst3: ref u8 = get_list_arg(ctx, args, 0)
            val idx: ref u8 = get_arg(ctx, args, 1)
            val elem_ann_list: mut ref u8 = ""
            if rchar_starts_with(base_ann, "list[") {
                val ba_len: i64 = str.len_raw(base_ann)
                elem_ann_list = str.substr(base_ann, 5, ba_len - 6)
            }

            val len_slot: i64 = fresh_tmp(ctx)
            val len_val: i64 = fresh_tmp(ctx)
            val buf_get1: ref u8 = @alloc(256) as ref u8
            @snprintf(buf_get1, 256, "    %%t{lld} =l add {s}, 8\n    %%t{lld} =l loadl %%t{lld}\n", {len_slot, lst3, len_val, len_slot})
            emit(ctx, buf_get1)
            @free(buf_get1)

            val in_bounds: i64 = fresh_tmp(ctx)
            val some_lbl: i64 = fresh_lbl(ctx)
            val none_lbl: i64 = fresh_lbl(ctx)
            val end_lbl: i64 = fresh_lbl(ctx)
            val result_slot: i64 = fresh_tmp(ctx)

            val buf_get2: ref u8 = @alloc(256) as ref u8
            @snprintf(buf_get2, 256, "    %%t{lld} =l alloc8 8\n    %%t{lld} =w csltl {s}, %%t{lld}\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n",
                {result_slot, in_bounds, idx, len_val, in_bounds, some_lbl, none_lbl})
            emit(ctx, buf_get2)
            @free(buf_get2)

            val buf_get3: ref u8 = @alloc(64) as ref u8
            @snprintf(buf_get3, 64, "@lbl{lld}\n", {some_lbl})
            emit(ctx, buf_get3)
            @free(buf_get3)

            val buf_get_tmp: i64 = fresh_tmp(ctx)
            val off: i64 = fresh_tmp(ctx)
            val elem_ptr: i64 = fresh_tmp(ctx)
            val elem_val: i64 = fresh_tmp(ctx)

            val buf_get4: ref u8 = @alloc(768) as ref u8
            if str.rchar_cmp(elem_ann_list, "f64") == 0 || str.rchar_cmp(elem_ann_list, "f32") == 0 {
                val box_tmp2: i64 = fresh_tmp(ctx)
                val some_val2: i64 = fresh_tmp(ctx)
                val load_instr2: ref u8 = cg_ann_load_instr(elem_ann_list)
                if str.rchar_cmp(elem_ann_list, "f64") == 0 {
                    @snprintf(buf_get4, 768, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l mul {s}, 8\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n    %%t{lld} =d {s} %%t{lld}\n    %%t{lld} =l alloc8 8\n    stored %%t{lld}, %%t{lld}\n    %%t{lld} =l add %%t{lld}, 1\n    storel %%t{lld}, %%t{lld}\n    jmp @lbl{lld}\n",
                        {buf_get_tmp, lst3, off, idx, elem_ptr, buf_get_tmp, off, elem_val, load_instr2, elem_ptr, box_tmp2, elem_val, box_tmp2, some_val2, box_tmp2, some_val2, result_slot, end_lbl})
                } else {
                    @snprintf(buf_get4, 768, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l mul {s}, 8\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n    %%t{lld} =s {s} %%t{lld}\n    %%t{lld} =l alloc8 8\n    stores %%t{lld}, %%t{lld}\n    %%t{lld} =l add %%t{lld}, 1\n    storel %%t{lld}, %%t{lld}\n    jmp @lbl{lld}\n",
                        {buf_get_tmp, lst3, off, idx, elem_ptr, buf_get_tmp, off, elem_val, load_instr2, elem_ptr, box_tmp2, elem_val, box_tmp2, some_val2, box_tmp2, some_val2, result_slot, end_lbl})
                }
            } else {
                val some_val: i64 = fresh_tmp(ctx)
                @snprintf(buf_get4, 768, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l mul {s}, 8\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n    %%t{lld} =l loadl %%t{lld}\n    %%t{lld} =l add %%t{lld}, 1\n    storel %%t{lld}, %%t{lld}\n    jmp @lbl{lld}\n",
                    {buf_get_tmp, lst3, off, idx, elem_ptr, buf_get_tmp, off, elem_val, elem_ptr, some_val, elem_val, some_val, result_slot, end_lbl})
            }
            emit(ctx, buf_get4)
            @free(buf_get4)

            val buf_get5: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_get5, 128, "@lbl{lld}\n    storel 0, %%t{lld}\n    jmp @lbl{lld}\n", {none_lbl, result_slot, end_lbl})
            emit(ctx, buf_get5)
            @free(buf_get5)

            val buf_get6: ref u8 = @alloc(128) as ref u8
            @snprintf(buf_get6, 128, "@lbl{lld}\n    %%t{lld} =l loadl %%t{lld}\n", {end_lbl, tmp, result_slot})
            emit(ctx, buf_get6)
            @free(buf_get6)
        }
    } elif str.rchar_cmp(name, "set") == 0 {
        val lst_s: ref u8 = get_list_arg(ctx, args, 0)
        val idx_s: ref u8 = get_arg(ctx, args, 1)
        val val_s_node_opt = @get(args, 2)
        val val_s_qtype: mut ref u8 = "l"
        val val_s: ref u8 = get_arg(ctx, args, 2)
        match val_s_node_opt {
            some vn_s => {
                val_s_qtype = expr_qtype(ctx, vn_s as ref parser.Node)
            }
            none => {}
        }
        val data_s: i64 = fresh_tmp(ctx)
        val off_s: i64 = fresh_tmp(ctx)
        val eptr_s: i64 = fresh_tmp(ctx)
        val set_b1: ref u8 = @alloc(256) as ref u8
        @snprintf(set_b1, 256, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l mul {s}, 8\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n",
            {data_s, lst_s, off_s, idx_s, eptr_s, data_s, off_s})
        emit(ctx, set_b1)
        @free(set_b1)
        val sv_s: mut ref u8 = val_s
        if str.rchar_cmp(val_s_qtype, "w") == 0 {
            val ext_s: i64 = fresh_tmp(ctx)
            val ext_b: ref u8 = @alloc(64) as ref u8
            val fc_s: i64 = @load8(@ptradd(val_s as ref void, 0)) as i64
            if ((fc_s >= 48 && fc_s <= 57) || fc_s == 45) {
                @snprintf(ext_b, 64, "    %%t{lld} =l copy {s}\n", {ext_s, val_s})
            } else {
                @snprintf(ext_b, 64, "    %%t{lld} =l extsw {s}\n", {ext_s, val_s})
            }
            emit(ctx, ext_b)
            @free(ext_b)
            val sv_s2: ref u8 = @alloc(16) as ref u8
            @snprintf(sv_s2, 16, "%%t{lld}", {ext_s})
            sv_s = sv_s2
        } elif str.rchar_cmp(val_s_qtype, "d") == 0 {
            val cast_s: i64 = fresh_tmp(ctx)
            val cast_b: ref u8 = @alloc(64) as ref u8
            @snprintf(cast_b, 64, "    %%t{lld} =l cast {s}\n", {cast_s, val_s})
            emit(ctx, cast_b)
            @free(cast_b)
            val sv_s3: ref u8 = @alloc(16) as ref u8
            @snprintf(sv_s3, 16, "%%t{lld}", {cast_s})
            sv_s = sv_s3
        }
        val set_b2: ref u8 = @alloc(64) as ref u8
        @snprintf(set_b2, 64, "    storel {s}, %%t{lld}\n", {sv_s, eptr_s})
        emit(ctx, set_b2)
        @free(set_b2)
        @snprintf(buf, 512, "    %%t{lld} =l copy 0\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "remove") == 0 {
        val lst4: ref u8 = get_list_arg(ctx, args, 0)
        val idx2: ref u8 = get_arg(ctx, args, 1)

        val len_slot: i64 = fresh_tmp(ctx)
        val len_val: i64 = fresh_tmp(ctx)
        val buf_rem1: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_rem1, 256, "    %%t{lld} =l add {s}, 8\n    %%t{lld} =l loadl %%t{lld}\n", {len_slot, lst4, len_val, len_slot})
        emit(ctx, buf_rem1)
        @free(buf_rem1)

        val buf_tmp: i64 = fresh_tmp(ctx)
        val off: i64 = fresh_tmp(ctx)
        val elem_ptr: i64 = fresh_tmp(ctx)
        val elem_val: i64 = fresh_tmp(ctx)
        val buf_rem2: ref u8 = @alloc(512) as ref u8
        @snprintf(buf_rem2, 512, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l mul {s}, 8\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n    %%t{lld} =l loadl %%t{lld}\n",
            {buf_tmp, lst4, off, idx2, elem_ptr, buf_tmp, off, elem_val, elem_ptr})
        emit(ctx, buf_rem2)
        @free(buf_rem2)

        val shift_loop: i64 = fresh_lbl(ctx)
        val shift_body: i64 = fresh_lbl(ctx)
        val shift_end: i64 = fresh_lbl(ctx)
        val shift_idx: i64 = fresh_tmp(ctx)

        val buf_rem3: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_rem3, 256, "    %%t{lld} =l copy {s}\n    jmp @lbl{lld}\n", {shift_idx, idx2, shift_loop})
        emit(ctx, buf_rem3)
        @free(buf_rem3)

        val buf_rem4: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_rem4, 64, "@lbl{lld}\n", {shift_loop})
        emit(ctx, buf_rem4)
        @free(buf_rem4)

        val one_past_end: i64 = fresh_tmp(ctx)
        val should_shift: i64 = fresh_tmp(ctx)
        val buf_rem5: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_rem5, 256, "    %%t{lld} =l sub %%t{lld}, 1\n    %%t{lld} =w csltl %%t{lld}, %%t{lld}\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n",
            {one_past_end, len_val, should_shift, shift_idx, one_past_end, should_shift, shift_body, shift_end})
        emit(ctx, buf_rem5)
        @free(buf_rem5)

        val buf_rem6: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_rem6, 64, "@lbl{lld}\n", {shift_body})
        emit(ctx, buf_rem6)
        @free(buf_rem6)

        val src_off_tmp: i64 = fresh_tmp(ctx)
        val src_off: i64 = fresh_tmp(ctx)
        val dst_off: i64 = fresh_tmp(ctx)
        val buf_tmp2: i64 = fresh_tmp(ctx)
        val src_ptr: i64 = fresh_tmp(ctx)
        val dst_ptr: i64 = fresh_tmp(ctx)
        val src_val: i64 = fresh_tmp(ctx)
        val buf_rem7: ref u8 = @alloc(512) as ref u8
        @snprintf(buf_rem7, 512, "    %%t{lld} =l add %%t{lld}, 1\n    %%t{lld} =l mul %%t{lld}, 8\n    %%t{lld} =l mul %%t{lld}, 8\n    %%t{lld} =l loadl {s}\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n    %%t{lld} =l loadl %%t{lld}\n    storel %%t{lld}, %%t{lld}\n",
            {src_off_tmp, shift_idx, src_off, src_off_tmp, dst_off, shift_idx, buf_tmp2, lst4, src_ptr, buf_tmp2, src_off, dst_ptr, buf_tmp2, dst_off, src_val, src_ptr, src_val, dst_ptr})
        emit(ctx, buf_rem7)
        @free(buf_rem7)

        val shift_idx_new: i64 = fresh_tmp(ctx)
        val buf_rem8: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_rem8, 256, "    %%t{lld} =l add %%t{lld}, 1\n    %%t{lld} =l copy %%t{lld}\n    jmp @lbl{lld}\n",
            {shift_idx_new, shift_idx, shift_idx, shift_idx_new, shift_loop})
        emit(ctx, buf_rem8)
        @free(buf_rem8)

        val buf_rem9: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_rem9, 64, "@lbl{lld}\n", {shift_end})
        emit(ctx, buf_rem9)
        @free(buf_rem9)

        val new_len: i64 = fresh_tmp(ctx)
        val buf_rem10: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_rem10, 256, "    %%t{lld} =l sub %%t{lld}, 1\n    storel %%t{lld}, %%t{lld}\n", {new_len, len_val, new_len, len_slot})
        emit(ctx, buf_rem10)
        @free(buf_rem10)

        tmp = elem_val
    } elif str.rchar_cmp(name, "insert") == 0 {
        val lst_ins: ref u8 = get_list_arg(ctx, args, 0)
        val idx_ins: ref u8 = get_arg(ctx, args, 1)
        val val_ins: ref u8 = get_arg(ctx, args, 2)

        val len_slot: i64 = fresh_tmp(ctx)
        val cap_slot: i64 = fresh_tmp(ctx)
        val len_val: i64 = fresh_tmp(ctx)
        val cap_val: i64 = fresh_tmp(ctx)
        val buf_ins1: ref u8 = @alloc(512) as ref u8
        @snprintf(buf_ins1, 512, "    %%t{lld} =l add {s}, 8\n    %%t{lld} =l add {s}, 16\n    %%t{lld} =l loadl %%t{lld}\n    %%t{lld} =l loadl %%t{lld}\n",
            {len_slot, lst_ins, cap_slot, lst_ins, len_val, len_slot, cap_val, cap_slot})
        emit(ctx, buf_ins1)
        @free(buf_ins1)

        val need_grow: i64 = fresh_tmp(ctx)
        val grow_lbl: i64 = fresh_lbl(ctx)
        val no_grow_lbl: i64 = fresh_lbl(ctx)
        val lt: i64 = fresh_tmp(ctx)
        val buf_ins2: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_ins2, 256, "    %%t{lld} =w csltl %%t{lld}, %%t{lld}\n    %%t{lld} =w ceqw %%t{lld}, 0\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n", {lt, len_val, cap_val, need_grow, lt, need_grow, grow_lbl, no_grow_lbl})
        emit(ctx, buf_ins2)
        @free(buf_ins2)

        val buf_ins3: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_ins3, 64, "@lbl{lld}\n", {grow_lbl})
        emit(ctx, buf_ins3)
        @free(buf_ins3)

        val new_cap: i64 = fresh_tmp(ctx)
        val new_cap2: i64 = fresh_tmp(ctx)
        val buf_ins4: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_ins4, 256, "    %%t{lld} =l mul %%t{lld}, 2\n    %%t{lld} =l add %%t{lld}, 1\n", {new_cap, cap_val, new_cap2, new_cap})
        emit(ctx, buf_ins4)
        @free(buf_ins4)

        val old_buf: i64 = fresh_tmp(ctx)
        val new_buf: i64 = fresh_tmp(ctx)
        val new_cap2_bytes: i64 = fresh_tmp(ctx)
        val buf_ins5: ref u8 = @alloc(512) as ref u8
        @snprintf(buf_ins5, 512, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l mul %%t{lld}, 8\n    %%t{lld} =l call $realloc(l %%t{lld}, l %%t{lld})\n    storel %%t{lld}, {s}\n    storel %%t{lld}, %%t{lld}\n    jmp @lbl{lld}\n",
            {old_buf, lst_ins, new_cap2_bytes, new_cap2, new_buf, old_buf, new_cap2_bytes, new_buf, lst_ins, new_cap2, cap_slot, no_grow_lbl})
        emit(ctx, buf_ins5)
        @free(buf_ins5)

        val buf_ins6: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_ins6, 64, "@lbl{lld}\n", {no_grow_lbl})
        emit(ctx, buf_ins6)
        @free(buf_ins6)

        val shift_loop: i64 = fresh_lbl(ctx)
        val shift_body: i64 = fresh_lbl(ctx)
        val shift_end: i64 = fresh_lbl(ctx)
        val shift_idx: i64 = fresh_tmp(ctx)

        val buf_ins7: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_ins7, 256, "    %%t{lld} =l sub %%t{lld}, 1\n    jmp @lbl{lld}\n", {shift_idx, len_val, shift_loop})
        emit(ctx, buf_ins7)
        @free(buf_ins7)

        val buf_ins8: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_ins8, 64, "@lbl{lld}\n", {shift_loop})
        emit(ctx, buf_ins8)
        @free(buf_ins8)

        val should_shift: i64 = fresh_tmp(ctx)
        val buf_ins9: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_ins9, 256, "    %%t{lld} =w cslel {s}, %%t{lld}\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n",
            {should_shift, idx_ins, shift_idx, should_shift, shift_body, shift_end})
        emit(ctx, buf_ins9)
        @free(buf_ins9)

        val buf_ins10: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_ins10, 64, "@lbl{lld}\n", {shift_body})
        emit(ctx, buf_ins10)
        @free(buf_ins10)

        val src_off: i64 = fresh_tmp(ctx)
        val dst_off_tmp: i64 = fresh_tmp(ctx)
        val dst_off: i64 = fresh_tmp(ctx)
        val src_ptr: i64 = fresh_tmp(ctx)
        val dst_ptr: i64 = fresh_tmp(ctx)
        val src_val: i64 = fresh_tmp(ctx)
        val buf2: i64 = fresh_tmp(ctx)
        val buf_ins11: ref u8 = @alloc(512) as ref u8
        @snprintf(buf_ins11, 512, "    %%t{lld} =l mul %%t{lld}, 8\n    %%t{lld} =l add %%t{lld}, 1\n    %%t{lld} =l mul %%t{lld}, 8\n    %%t{lld} =l loadl {s}\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n    %%t{lld} =l loadl %%t{lld}\n    storel %%t{lld}, %%t{lld}\n",
            {src_off, shift_idx, dst_off_tmp, shift_idx, dst_off, dst_off_tmp, buf2, lst_ins, src_ptr, buf2, src_off, dst_ptr, buf2, dst_off, src_val, src_ptr, src_val, dst_ptr})
        emit(ctx, buf_ins11)
        @free(buf_ins11)

        val shift_idx_new: i64 = fresh_tmp(ctx)
        val buf_ins12: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_ins12, 256, "    %%t{lld} =l sub %%t{lld}, 1\n    %%t{lld} =l copy %%t{lld}\n    jmp @lbl{lld}\n",
            {shift_idx_new, shift_idx, shift_idx, shift_idx_new, shift_loop})
        emit(ctx, buf_ins12)
        @free(buf_ins12)

        val buf_ins13: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_ins13, 64, "@lbl{lld}\n", {shift_end})
        emit(ctx, buf_ins13)
        @free(buf_ins13)

        val buf3: i64 = fresh_tmp(ctx)
        val elem_off: i64 = fresh_tmp(ctx)
        val elem_ptr: i64 = fresh_tmp(ctx)
        val buf_ins14: ref u8 = @alloc(512) as ref u8
        @snprintf(buf_ins14, 512, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l mul {s}, 8\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n    storel {s}, %%t{lld}\n",
            {buf3, lst_ins, elem_off, idx_ins, elem_ptr, buf3, elem_off, val_ins, elem_ptr})
        emit(ctx, buf_ins14)
        @free(buf_ins14)

        val new_len: i64 = fresh_tmp(ctx)
        val buf_ins15: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_ins15, 256, "    %%t{lld} =l add %%t{lld}, 1\n    storel %%t{lld}, %%t{lld}\n", {new_len, len_val, new_len, len_slot})
        emit(ctx, buf_ins15)
        @free(buf_ins15)

        @snprintf(buf, 512, "    %%t{lld} =l copy 0\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "reserve") == 0 {
        val lst5: ref u8 = get_list_arg(ctx, args, 0)
        val cap: ref u8 = get_arg(ctx, args, 1)

        val cap_slot: i64 = fresh_tmp(ctx)
        val cur_cap: i64 = fresh_tmp(ctx)
        val buf_res1: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_res1, 256, "    %%t{lld} =l add {s}, 16\n    %%t{lld} =l loadl %%t{lld}\n", {cap_slot, lst5, cur_cap, cap_slot})
        emit(ctx, buf_res1)
        @free(buf_res1)

        val need_grow: i64 = fresh_tmp(ctx)
        val grow_lbl: i64 = fresh_lbl(ctx)
        val end_lbl: i64 = fresh_lbl(ctx)
        val buf_res2: ref u8 = @alloc(256) as ref u8
        @snprintf(buf_res2, 256, "    %%t{lld} =w csgtl {s}, %%t{lld}\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n",
            {need_grow, cap, cur_cap, need_grow, grow_lbl, end_lbl})
        emit(ctx, buf_res2)
        @free(buf_res2)

        val buf_res3: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_res3, 64, "@lbl{lld}\n", {grow_lbl})
        emit(ctx, buf_res3)
        @free(buf_res3)

        val old_buf: i64 = fresh_tmp(ctx)
        val new_buf: i64 = fresh_tmp(ctx)
        val new_bytes: i64 = fresh_tmp(ctx)
        val buf_res4: ref u8 = @alloc(512) as ref u8
        @snprintf(buf_res4, 512, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l mul {s}, 8\n    %%t{lld} =l call $realloc(l %%t{lld}, l %%t{lld})\n    storel %%t{lld}, {s}\n    storel {s}, %%t{lld}\n",
            {old_buf, lst5, new_bytes, cap, new_buf, old_buf, new_bytes, new_buf, lst5, cap, cap_slot})
        emit(ctx, buf_res4)
        @free(buf_res4)

        val buf_res5: ref u8 = @alloc(64) as ref u8
        @snprintf(buf_res5, 64, "@lbl{lld}\n", {end_lbl})
        emit(ctx, buf_res5)
        @free(buf_res5)

        @snprintf(buf, 512, "    %%t{lld} =l copy 0\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "capacity") == 0 {
        val lst6: ref u8 = get_list_arg(ctx, args, 0)
        val cap_slot: i64 = fresh_tmp(ctx)
        val cap_val: i64 = fresh_tmp(ctx)
        @snprintf(buf, 512, "    %%t{lld} =l add {s}, 16\n    %%t{lld} =l loadl %%t{lld}\n", {cap_slot, lst6, cap_val, cap_slot})
        emit(ctx, buf)
        tmp = cap_val
    } elif str.rchar_cmp(name, "fmt") == 0 {
        val fmt2: ref u8 = get_format_arg(ctx, args, 0)
        val fmt_buf: i64 = fresh_tmp(ctx)
        val fmt_written_w: i64 = fresh_tmp(ctx)
        val fmt_written: i64 = fresh_tmp(ctx)
        val fmt_copy_size: i64 = fresh_tmp(ctx)
        val fmt_copy: i64 = fresh_tmp(ctx)
        val fmt_nul: i64 = fresh_tmp(ctx)
        val fmt_hdr: ref u8 = @alloc(256) as ref u8
        @snprintf(fmt_hdr, 256, "    %%t{lld} =l call $malloc(l 4096)\n", {fmt_buf})
        emit(ctx, fmt_hdr)
        @free(fmt_hdr)
        val fmt_call_sb: ref void = str.StringBuilder.new()
        val snp_hdr: ref u8 = @alloc(256) as ref u8
        @snprintf(snp_hdr, 256, "    %%t{lld} =w call $snprintf(l %%t{lld}, l 4096, l {s}", {fmt_written_w, fmt_buf, fmt2})
        str.StringBuilder.append_cstr(fmt_call_sb, snp_hdr)
        @free(snp_hdr)

        if args != 0 as ref void {
            val falen: i64 = @len(args) as i64
            if falen > 1 {
                val fpack_opt = @get(args, 1)
                match fpack_opt {
                    some fpack_node => {
                        val fpn: ref parser.Node = fpack_node as ref parser.Node
                        if fpn.kind == parser.NK_ARGS_PACK {
                            val fpack: ref void = fpn.d0 as ref void
                            val fplen: i64 = @len(fpack) as i64
                            if fplen > 0 {
                                str.StringBuilder.append_cstr(fmt_call_sb, ", ...")
                                val fpi: mut i64 = 0
                                for {
                                    if fpi >= fplen { break }
                                    val fpe_opt = @get(fpack, fpi as usize)
                                    match fpe_opt {
                                        some fpe => {
                                            val fpe_node: ref parser.Node = fpe as ref parser.Node
                                            val fpqt: ref u8 = expr_qtype(ctx, fpe_node)
                                            val fpv: ref u8 = gen_expr(ctx, fpe_node)
                                            val fpbuf: ref u8 = @alloc(64) as ref u8
                                            @snprintf(fpbuf, 64, ", {s} {s}", {fpqt, fpv})
                                            str.StringBuilder.append_cstr(fmt_call_sb, fpbuf)
                                            @free(fpbuf)
                                        }
                                        none => {}
                                    }
                                    fpi++
                                }
                            }
                        }
                    }
                    none => {}
                }
            }
        }
        str.StringBuilder.append_cstr(fmt_call_sb, ")\n")
        val fmt_call_line: ref void = str.StringBuilder.build(fmt_call_sb)
        str.StringBuilder.free(fmt_call_sb)
        emit(ctx, str.cstr(fmt_call_line))
        // extsw, malloc copy, memcpy, nul-terminate, free buf
        val tail_buf: ref u8 = @alloc(512) as ref u8
        @snprintf(tail_buf, 512, "    %%t{lld} =l extsw %%t{lld}\n    %%t{lld} =l add %%t{lld}, 1\n    %%t{lld} =l call $malloc(l %%t{lld})\n    call $memcpy(l %%t{lld}, l %%t{lld}, l %%t{lld})\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n    storeb 0, %%t{lld}\n    call $free(l %%t{lld})\n",
            {fmt_written, fmt_written_w,
             fmt_copy_size, fmt_written,
             fmt_copy, fmt_copy_size,
             fmt_copy, fmt_buf, fmt_written,
             fmt_nul, fmt_copy, fmt_written,
             fmt_nul,
             fmt_buf})
        emit(ctx, tail_buf)
        @free(tail_buf)
        @snprintf(buf, 512, "    %%t{lld} =l copy %%t{lld}\n", {tmp, fmt_copy})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "args") == 0 {
        @snprintf(buf, 512, "    %%t{lld} =l call $__sx_get_args()\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "stdin") == 0 {
        @snprintf(buf, 512, "    %%t{lld} =l call $sx_stdin()\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "stdout") == 0 {
        @snprintf(buf, 512, "    %%t{lld} =l call $sx_stdout()\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "stderr") == 0 {
        @snprintf(buf, 512, "    %%t{lld} =l call $sx_stderr()\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "call") == 0 {
        val fn_ptr: ref u8 = get_arg(ctx, args, 0)
        val call_sb2: ref void = str.StringBuilder.new()
        val hdr3_buf: ref u8 = @alloc(512) as ref u8
        @snprintf(hdr3_buf, 512, "    %%t{lld} =l call {s}(", {tmp, fn_ptr})
        str.StringBuilder.append_cstr(call_sb2, hdr3_buf)
        @free(hdr3_buf)
        if args != 0 as ref void {
            val alen3: i64 = @len(args) as i64
            val ai3: mut i64 = 1
            val first3: mut bool = true
            for {
                if ai3 >= alen3 { break }
                val a3_opt = @get(args, ai3 as usize)
                match a3_opt {
                    some a3 => {
                        val a3_node: ref parser.Node = a3 as ref parser.Node
                        val at3: ref u8 = gen_expr(ctx, a3_node)
                        if !first3 { str.StringBuilder.append_cstr(call_sb2, ", ") }
                        val qtype3: ref u8 = expr_qtype(ctx, a3_node)
                        val tbuf4: ref u8 = @alloc(64) as ref u8
                        @snprintf(tbuf4, 64, "{s} {s}", {qtype3, at3})
                        str.StringBuilder.append_cstr(call_sb2, tbuf4)
                        @free(tbuf4)
                        first3 = false
                    }
                    none => {}
                }
                ai3++
            }
        }
        str.StringBuilder.append_cstr(call_sb2, ")\n")
        val call_line3: ref void = str.StringBuilder.build(call_sb2)
        str.StringBuilder.free(call_sb2)
        emit(ctx, str.cstr(call_line3))
    } else {
        val call_sb: ref void = str.StringBuilder.new()
        val hdr2_buf: ref u8 = @alloc(512) as ref u8
        @snprintf(hdr2_buf, 512, "    %%t{lld} =l call ${s}(", {tmp, name})
        str.StringBuilder.append_cstr(call_sb, hdr2_buf)
        @free(hdr2_buf)
        if args != 0 as ref void {
            val alen: i64 = @len(args) as i64
            val ai: mut i64 = 0
            val arg_nodes: mut list[ref parser.Node] = []
            val arg_tmps2: mut list[ref u8] = []
            for {
                if ai >= alen { break }
                val a_opt = @get(args, ai as usize)
                match a_opt {
                    some a => {
                        val a_node: ref parser.Node = a as ref parser.Node
                        val ak: i64 = a_node.kind
                        if ak == parser.NK_ARGS_PACK {
                            val pack: ref void = a_node.d0 as ref void
                            val plen: i64 = @len(pack) as i64
                            val pi: mut i64 = 0
                            for {
                                if pi >= plen { break }
                                val pe_opt = @get(pack, pi as usize)
                                match pe_opt {
                                    some pe => {
                                        val pe_node: ref parser.Node = pe as ref parser.Node
                                        val at: ref u8 = gen_expr(ctx, pe_node)
                                        @append(arg_nodes, pe_node)
                                        @append(arg_tmps2, at)
                                    }
                                    none => {}
                                }
                                pi++
                            }
                        } else {
                            val at: ref u8 = gen_expr(ctx, a_node)
                            @append(arg_nodes, a_node)
                            @append(arg_tmps2, at)
                        }
                    }
                    none => {}
                }
                ai++
            }
            val tlen3: i64 = @len(arg_tmps2) as i64
            val ti3: mut i64 = 0
            for {
                if ti3 >= tlen3 { break }
                val t3_opt = @get(arg_tmps2, ti3 as usize)
                val n_opt = @get(arg_nodes, ti3 as usize)
                match t3_opt {
                    some t3 => {
                        if ti3 > 0 { str.StringBuilder.append_cstr(call_sb, ", ") }
                        val qtype: mut ref u8 = "l"
                        match n_opt {
                            some n => {
                                val qt: ref u8 = expr_qtype(ctx, n as ref parser.Node)
                                if str.rchar_cmp(qt, "") != 0 {
                                    qtype = qt
                                }
                            }
                            none => {}
                        }
                        val tbuf3: ref u8 = @alloc(64) as ref u8
                        @snprintf(tbuf3, 64, "{s} {s}", {qtype, t3 as ref u8})
                        str.StringBuilder.append_cstr(call_sb, tbuf3)
                        @free(tbuf3)
                    }
                    none => {}
                }
                ti3++
            }
        }
        str.StringBuilder.append_cstr(call_sb, ")")
        val call_line2: ref void = str.StringBuilder.build(call_sb)
        str.StringBuilder.free(call_sb)
        emitln(ctx, str.cstr(call_line2))
    }

    @free(buf)
    val res: ref u8 = @alloc(16) as ref u8
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn gen_fixed_arr_lit(ctx: ref CgCtx, expr: ref parser.Node, ty: ref parser.Node) ref u8! = {
    if expr == 0 as ref parser.Node || ty == 0 as ref parser.Node || ty.kind != parser.TY_FIXED_ARR {
        return "0"
    }

    val total_size: i64 = cg_type_size(ctx, ty)
    val elem_ty: ref parser.Node = parser.fixed_arr_inner(ty)
    val elem_size: i64 = cg_type_size(ctx, elem_ty)
    val tmp: i64 = fresh_tmp(ctx)
    val alloc_buf: ref u8 = @alloc(128) as ref u8
    @snprintf(alloc_buf, 128, "    %%t{lld} =l call $malloc(l {lld})\n", {tmp, total_size})
    emit(ctx, alloc_buf)
    @free(alloc_buf)

    val zero_buf: ref u8 = @alloc(128) as ref u8
    @snprintf(zero_buf, 128, "    call $memset(l %%t{lld}, w 0, l {lld})\n", {tmp, total_size})
    emit(ctx, zero_buf)
    @free(zero_buf)

    if expr.kind == parser.NK_ZERO_INIT {
        val zero_res: ref u8 = @alloc(16) as ref u8
        @snprintf(zero_res, 16, "%%t{lld}", {tmp})
        return zero_res
    }

    if expr.kind == parser.NK_LIST_LIT {
        val elems: ref void = expr.d0 as ref void
        val elen: mut i64 = 0
        if elems != 0 as ref void { elen = @len(elems) as i64 }

        val ei: mut i64 = 0
        for {
            if ei >= elen { break }
            val e_opt = @get(elems, ei as usize)
            match e_opt {
                some e => {
                    val e_node: ref parser.Node = e as ref parser.Node
                    val off: i64 = ei * elem_size
                    val elem_is_fa: bool = elem_ty != 0 as ref parser.Node && elem_ty.kind == parser.TY_FIXED_ARR
                    if elem_is_fa {
                        val off_tmp: i64 = fresh_tmp(ctx)
                        val off_buf: ref u8 = @alloc(256) as ref u8
                        @snprintf(off_buf, 256, "    %%t{lld} =l add %%t{lld}, {lld}\n", {off_tmp, tmp, off})
                        emit(ctx, off_buf)
                        @free(off_buf)

                        val is_zero: bool = e_node.kind == parser.NK_INT_LIT && str.rchar_cmp(parser.int_lit_text(e_node), "0") == 0
                        if is_zero {
                            val memset_buf: ref u8 = @alloc(128) as ref u8
                            @snprintf(memset_buf, 128, "    call $memset(l %%t{lld}, w 0, l {lld})\n", {off_tmp, elem_size})
                            emit(ctx, memset_buf)
                            @free(memset_buf)
                        } else {
                            val eval: ref u8 = gen_fixed_arr_lit(ctx, e_node, elem_ty)
                            val memcpy_buf: ref u8 = @alloc(128) as ref u8
                            @snprintf(memcpy_buf, 128, "    call $memcpy(l %%t{lld}, l {s}, l {lld})\n", {off_tmp, eval, elem_size})
                            emit(ctx, memcpy_buf)
                            @free(memcpy_buf)
                        }
                    } else {
                        val eval2: ref u8 = gen_expr(ctx, e_node)
                        val store_op: mut ref u8 = "storel"
                        val qt: ref u8 = qbe_type_of(elem_ty)
                        if str.rchar_cmp(qt, "d") == 0 { store_op = "stored" }
                        elif str.rchar_cmp(qt, "s") == 0 { store_op = "stores" }
                        elif str.rchar_cmp(qt, "w") == 0 { store_op = "storew" }

                        val store_buf: ref u8 = @alloc(256) as ref u8
                        if off == 0 {
                            @snprintf(store_buf, 256, "    {s} {s}, %%t{lld}\n", {store_op, eval2, tmp})
                        } else {
                            val off_tmp2: i64 = fresh_tmp(ctx)
                            @snprintf(store_buf, 256, "    %%t{lld} =l add %%t{lld}, {lld}\n    {s} {s}, %%t{lld}\n",
                                {off_tmp2, tmp, off, store_op, eval2, off_tmp2})
                        }
                        emit(ctx, store_buf)
                        @free(store_buf)
                    }
                }
                none => {}
            }
            ei++
        }
    }

    val res: ref u8 = @alloc(16) as ref u8
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn gen_list_lit(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    val elems: ref void = expr.d0 as ref void
    val elen: mut i64 = 0
    if elems != 0 as ref void { elen = @len(elems) as i64 }
    val elem_ty: ref parser.Node = cg_unwrap_list_elem_ty(ctx, ctx.expected_ty as ref parser.Node)

    val cap: mut i64 = 1
    if elen > 0 { cap = elen }

    val hdr_ptr: i64 = fresh_tmp(ctx)
    val buf_ptr: i64 = fresh_tmp(ctx)
    val buf1: ref u8 = @alloc(128) as ref u8
    @snprintf(buf1, 128, "    %%t{lld} =l call $malloc(l 24)\n", {hdr_ptr})
    emit(ctx, buf1)
    @free(buf1)

    val buf2: ref u8 = @alloc(128) as ref u8
    @snprintf(buf2, 128, "    %%t{lld} =l call $malloc(l {lld})\n", {buf_ptr, cap * 8})
    emit(ctx, buf2)
    @free(buf2)

    val buf3: ref u8 = @alloc(128) as ref u8
    @snprintf(buf3, 128, "    storel %%t{lld}, %%t{lld}\n", {buf_ptr, hdr_ptr})
    emit(ctx, buf3)
    @free(buf3)

    val len_slot: i64 = fresh_tmp(ctx)
    val cap_slot: i64 = fresh_tmp(ctx)
    val buf4: ref u8 = @alloc(128) as ref u8
    @snprintf(buf4, 128, "    %%t{lld} =l add %%t{lld}, 8\n", {len_slot, hdr_ptr})
    emit(ctx, buf4)
    @free(buf4)

    val buf5: ref u8 = @alloc(128) as ref u8
    @snprintf(buf5, 128, "    %%t{lld} =l add %%t{lld}, 16\n", {cap_slot, hdr_ptr})
    emit(ctx, buf5)
    @free(buf5)

    val buf6: ref u8 = @alloc(128) as ref u8
    @snprintf(buf6, 128, "    storel {lld}, %%t{lld}\n", {elen, len_slot})
    emit(ctx, buf6)
    @free(buf6)

    val buf7: ref u8 = @alloc(128) as ref u8
    @snprintf(buf7, 128, "    storel {lld}, %%t{lld}\n", {cap, cap_slot})
    emit(ctx, buf7)
    @free(buf7)

    if elems != 0 as ref void {
        val ei: mut i64 = 0
        for {
            if ei >= elen { break }
            val e_opt = @get(elems, ei as usize)
            if e_opt is some e {
                val val_tmp: ref u8 = gen_expr_expected(ctx, e as ref parser.Node, elem_ty)
                val off: i64 = fresh_tmp(ctx)
                val elem_ptr: i64 = fresh_tmp(ctx)
                val buf8: ref u8 = @alloc(128) as ref u8

                @snprintf(buf8, 128, "    %%t{lld} =l mul {lld}, 8\n", {off, ei})
                emit(ctx, buf8)
                @free(buf8)
                val buf9: ref u8 = @alloc(128) as ref u8
                @snprintf(buf9, 128, "    %%t{lld} =l add %%t{lld}, %%t{lld}\n", {elem_ptr, buf_ptr, off})
                emit(ctx, buf9)
                @free(buf9)
                val buf10: ref u8 = @alloc(128) as ref u8
                @snprintf(buf10, 128, "    storel {s}, %%t{lld}\n", {val_tmp, elem_ptr})
                emit(ctx, buf10)
                @free(buf10)
            }

            ei++
        }
    }

    val res: ref u8 = @alloc(16) as ref u8
    @snprintf(res, 16, "%%t{lld}", {hdr_ptr})
    return res
}

fn gen_struct_lit(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    val fields: ref void = expr.d0 as ref void
    val flen: mut i64 = 0
    if fields != 0 as ref void { flen = @len(fields) as i64 }

    val struct_fields: mut ref void = 0 as ref void
    val expected_ty: ref parser.Node = ctx.expected_ty as ref parser.Node
    if expected_ty != 0 as ref parser.Node {
        struct_fields = cg_struct_fields_for_type(ctx, expected_ty)
    }
    if struct_fields == 0 as ref void {
        struct_fields = cg_find_struct_fields_for_literal(ctx, fields)
    }

    // Compute the total allocation size using struct_size which correctly
    // accounts for tagged unions (16 bytes) and other named types.
    val size: mut i64 = flen * 8
    if expected_ty != 0 as ref parser.Node {
        val expected_size: i64 = cg_alloc_size_for_type(ctx, expected_ty)
        if expected_size > 0 { size = expected_size }
    } elif struct_fields != 0 as ref void {
        size = struct_size(ctx, struct_fields)
    }
    if flen < 1 && size < 8 { size = 8 }

    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref u8 = @alloc(128) as ref u8
    @snprintf(buf, 128, "    %%t{lld} =l call $malloc(l {lld})\n", {tmp, size})
    emit(ctx, buf)
    @free(buf)
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields, fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fname: ref u8 = fnode.d0 as ref u8
                val fexpr_node: ref parser.Node = fnode.d1 as ref parser.Node
                val off: mut i64 = fi * 8
                val fty_node: mut ref parser.Node = 0 as ref parser.Node
                if struct_fields != 0 as ref void {
                    val real_off: i64 = field_offset(ctx, struct_fields, fname)
                    if real_off >= 0 { off = real_off }
                    val sflen2: i64 = @len(struct_fields as list[ref void]) as i64
                    val sfi2: mut i64 = 0
                    for {
                        if sfi2 >= sflen2 { break }
                        val sf2_opt = @get(struct_fields as list[ref void], sfi2 as usize)
                        match sf2_opt {
                            some sf2 => {
                                val sfn2: ref parser.Node = sf2 as ref parser.Node
                                val sfname2: ref u8 = sfn2.d0 as ref u8
                                if str.rchar_cmp(sfname2, fname) == 0 {
                                    fty_node = sfn2.d2 as ref parser.Node
                                    sfi2 = sflen2 // break
                                }
                            }
                            none => {}
                        }
                        sfi2++
                    }
                }
                val is_fa: mut bool = false
                if fty_node != 0 as ref parser.Node {
                    if fty_node.kind == parser.TY_FIXED_ARR {
                        is_fa = true
                    }
                }
                if is_fa {
                    val fa_size: i64 = type_size(fty_node)
                    val off_tmp2: i64 = fresh_tmp(ctx)
                    val fbuf2: ref u8 = @alloc(256) as ref u8
                    @snprintf(fbuf2, 256, "    %%t{lld} =l add %%t{lld}, {lld}\n", {off_tmp2, tmp, off})
                    emit(ctx, fbuf2)
                    @free(fbuf2)
                    val is_zero: bool = fexpr_node.kind == parser.NK_INT_LIT && str.rchar_cmp(parser.int_lit_text(fexpr_node), "0") == 0
                    if is_zero {
                        val fbuf3: ref u8 = @alloc(128) as ref u8
                        @snprintf(fbuf3, 128, "    call $memset(l %%t{lld}, w 0, l {lld})\n", {off_tmp2, fa_size})
                        emit(ctx, fbuf3)
                        @free(fbuf3)
                    } else {
                        val fval2: ref u8 = gen_expr_expected(ctx, fexpr_node, fty_node)
                        val fbuf3: ref u8 = @alloc(128) as ref u8
                        @snprintf(fbuf3, 128, "    call $memcpy(l %%t{lld}, l {s}, l {lld})\n", {off_tmp2, fval2, fa_size})
                        emit(ctx, fbuf3)
                        @free(fbuf3)
                    }
                } else {
                    val fval: ref u8 = gen_expr_expected(ctx, fexpr_node, fty_node)
                    val fbuf: ref u8 = @alloc(128) as ref u8
                    val off_tmp: i64 = fresh_tmp(ctx)

                    val store_op: mut ref u8 = "storel"
                    if fty_node != 0 as ref parser.Node {
                        val qt: ref u8 = qbe_type_of(fty_node)
                        if str.rchar_cmp(qt, "d") == 0 { store_op = "stored" }
                        elif str.rchar_cmp(qt, "s") == 0 { store_op = "stores" }
                        elif str.rchar_cmp(qt, "w") == 0 { store_op = "storew" }
                    }

                    if off == 0 {
                        @snprintf(fbuf, 128, "    {s} {s}, %%t{lld}\n", {store_op, fval, tmp})
                    } else {
                        @snprintf(fbuf, 128, "    %%t{lld} =l add %%t{lld}, {lld}\n    {s} {s}, %%t{lld}\n",
                            {off_tmp, tmp, off, store_op, fval, off_tmp})
                    }
                    emit(ctx, fbuf)
                    @free(fbuf)
                }
            }
            none => {}
        }
        fi++
    }
    val res: ref u8 = @alloc(16) as ref u8
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn gen_try(ctx: ref CgCtx, expr: ref parser.Node) ref u8! = {
    // expr? — if tag==0 (ok), unwrap value; if tag==1 (err), return result as-is
    val inner_node: ref parser.Node = expr.d0 as ref parser.Node
    val inner: ref u8 = gen_expr(ctx, inner_node)
    val tag_tmp: i64 = fresh_tmp(ctx)
    val ok_lbl: i64 = fresh_lbl(ctx)
    val err_lbl: i64 = fresh_lbl(ctx)
    val is_ok: i64 = fresh_tmp(ctx)
    val buf: ref u8 = @alloc(256) as ref u8
    @snprintf(buf, 256,
        "    %%t{lld} =l loadl {s}\n    %%t{lld} =w ceql %%t{lld}, 0\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
        {tag_tmp, inner, is_ok, tag_tmp, is_ok, ok_lbl, err_lbl, err_lbl})
    emit(ctx, buf)
    @free(buf)

    // err branch: return the result as-is
    val rbuf: ref u8 = @alloc(64) as ref u8
    @snprintf(rbuf, 64, "    ret {s}\n@lbl{lld}\n", {inner, ok_lbl})
    emit(ctx, rbuf)
    @free(rbuf)

    // ok branch: load value at offset 8
    val off_tmp: i64 = fresh_tmp(ctx)
    val val_tmp: i64 = fresh_tmp(ctx)
    val vbuf: ref u8 = @alloc(128) as ref u8
    @snprintf(vbuf, 128, "    %%t{lld} =l add {s}, 8\n    %%t{lld} =l loadl %%t{lld}\n",
        {off_tmp, inner, val_tmp, off_tmp})
    emit(ctx, vbuf)
    @free(vbuf)
    val res: ref u8 = @alloc(16) as ref u8
    @snprintf(res, 16, "%%t{lld}", {val_tmp})
    return res
}

/// Returns true if the last statement in a list is a terminator (return/break/continue).
fn stmts_terminated(stmts: ref parser.Node) bool! = {
    if stmts == 0 as ref parser.Node { return false }
    val len: i64 = @len(stmts) as i64
    if len == 0 { return false }
    val last_opt = @get(stmts, (len - 1) as usize)
    match last_opt {
        some last => {
            val s: ref parser.Node = last as ref parser.Node
            val k: i64 = s.kind
            if k == parser.NK_RETURN  { return true }
            if k == parser.NK_BREAK   { return true }
            if k == parser.NK_CONTINUE { return true }
            return false
        }
        none => { return false }
    }
}

/// Returns true if the active branch of a NK_WHEN_STMT is terminated.
fn when_stmt_terminated(ctx: ref CgCtx, stmt: ref parser.Node) bool! = {
    val plat: ref u8 = stmt.d0 as ref u8
    if cg_platform_matches(ctx, plat) {
        return stmts_terminated(stmt.d1 as ref parser.Node)
    }
    val or_when_branches: ref void = stmt.d2 as ref void
    if or_when_branches != 0 as ref void {
        for ow_node in or_when_branches as list[ref parser.Node] {
            val ow_plat: ref u8 = ow_node.d0 as ref u8
            if cg_platform_matches(ctx, ow_plat) {
                return stmts_terminated(ow_node.d1 as ref parser.Node)
            }
        }
    }
    val otherwise_stmts: ref void = stmt.d3 as ref void
    if otherwise_stmts != 0 as ref void {
        return stmts_terminated(stmt.d3 as ref parser.Node)
    }
    return false
}

fn gen_stmts(ctx: ref CgCtx, stmts: ref parser.Node) void! = {
    if stmts == 0 as ref parser.Node { return }
    val len: i64 = @len(stmts) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(stmts, i as usize)
        if s_opt is some s {
            val snode: ref parser.Node = s as ref parser.Node
            if snode.kind == parser.NK_GENERIC_WHEN {
                val matched: mut bool = false
                val j: mut i64 = i
                for {
                    if j >= len { break }
                    val s_opt2 = @get(stmts, j as usize)
                    match s_opt2 {
                        some s2 => {
                            val sn2: ref parser.Node = s2 as ref parser.Node
                            if sn2.kind != parser.NK_GENERIC_WHEN { break }
                            if !matched && gwhen_matches_gsubst(ctx, sn2) {
                                gen_stmts(ctx, sn2.d1 as ref parser.Node)
                                matched = true
                            }
                        }
                        none => { break }
                    }
                    j++
                }
                i = j
                continue
            } else {
                gen_stmt(ctx, snode)
                if snode.kind == parser.NK_WHEN_STMT {
                    if when_stmt_terminated(ctx, snode) { break }
                }
            }
        }
        i++
    }
}

fn gen_stmt(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    if stmt == 0 as ref parser.Node { return }
    val k: i64 = stmt.kind

    if k == parser.NK_VAL {
        val name: ref u8 = stmt.d0 as ref u8
        val mutable: i64 = stmt.d1
        val raw_ty_node: ref parser.Node = stmt.d2 as ref parser.Node
        val ty_node: ref parser.Node = cg_concrete_ty(ctx, raw_ty_node)
        val expr: ref parser.Node = stmt.d3 as ref parser.Node
        val val_tmp: mut ref u8 = "0"
        val use_fixed_arr_lit: mut bool = false
        if ty_node != 0 as ref parser.Node {
            if ty_node.kind == parser.TY_FIXED_ARR {
                if expr != 0 as ref parser.Node {
                    if expr.kind == parser.NK_LIST_LIT || expr.kind == parser.NK_ZERO_INIT {
                        use_fixed_arr_lit = true
                    }
                }
            }
        }
        if use_fixed_arr_lit {
            val_tmp = gen_fixed_arr_lit(ctx, expr, ty_node)
        } else {
            val_tmp = gen_expr_expected(ctx, expr, ty_node)
        }

        if ty_node != 0 as ref parser.Node && expr != 0 as ref parser.Node {
            val decl_qbe_type: ref u8 = qbe_type_of(ty_node)
            val expr_qbe_type_val: ref u8 = expr_qbe_type(ctx, expr)
            if !(str.rchar_cmp(expr_qbe_type_val, "w") == 0 && str.rchar_cmp(decl_qbe_type, "l") == 0 && is_ref_type(ty_node)) {
                val_tmp = cg_coerce_qtype(ctx, val_tmp, expr_qbe_type_val, decl_qbe_type)
            }
        }

        if ty_node != 0 as ref parser.Node {
            val local_ann: mut ref u8 = ""
            if ty_node.kind == parser.TY_LIST || ty_node.kind == parser.TY_FIXED_ARR {
                val full_type: ref u8 = type_expr_to_annotation(ctx, ty_node)
                if str.rchar_cmp(full_type, "") != 0 {
                    cg_register_local_type(ctx, name, full_type)
                    local_ann = full_type
                }
            } else {
                val tname: ref u8 = unwrap_type_name(ty_node)
                if str.rchar_cmp(tname, "") != 0 {
                    cg_register_local_type(ctx, name, tname)
                    local_ann = tname
                }
            }
            if is_ref_type(ty_node) || cg_ann_is_indirect_value(ctx, local_ann) {
                cg_register_local_ref_type(ctx, name)
            }
        } elif expr != 0 as ref parser.Node && expr.kind == parser.NK_CALL {
            val callee: ref parser.Node = parser.call_callee(expr)
            val callee_name: mut ref u8 = resolve_callee_name(ctx, callee)
            val ret_expr: mut ref parser.Node = 0 as ref parser.Node
            if callee != 0 as ref parser.Node && callee.kind == parser.NK_GENERIC_INST {
                val gi_base: ref parser.Node = parser.generic_inst_base(callee)
                val gi_targs: list[ref parser.Node] = parser.generic_inst_type_args(callee)
                val base_name: ref u8 = generic_callee_base_name(gi_base)
                val gfn_node: ref parser.Node = lookup_generic_fn(ctx, base_name)
                if gfn_node != 0 as ref parser.Node {
                    val gfn_prefix: ref u8 = lookup_generic_fn_prefix(ctx, base_name)
                    val resolved_targs2: mut list[ref parser.Node] = []
                    for ta2 in gi_targs { @append(resolved_targs2, cg_concrete_ty(ctx, ta2 as ref parser.Node)) }
                    val mono_base: ref u8 = monomorphize_generic_fn(ctx, gfn_node, gfn_prefix, resolved_targs2)
                    if mono_base != 0 as ref u8 {
                        callee_name = mono_base
                        ret_expr = cg_lookup_fn_ret(ctx, mono_base) as ref parser.Node
                    }
                }
            }
            if ret_expr == 0 as ref parser.Node &&
               callee != 0 as ref parser.Node &&
               callee_name != 0 as ref u8 &&
               str.rchar_cmp(callee_name, "unknown") != 0 {
                ret_expr = cg_lookup_fn_ret_type_expr(ctx, callee_name)
            }
            if ret_expr != 0 as ref parser.Node {
                val ret_ann: ref u8 = type_expr_to_annotation(ctx, ret_expr)
                if str.rchar_cmp(ret_ann, "") != 0 {
                    val type_copy: ref u8 = @alloc(str.len_raw(ret_ann) + 1) as ref u8
                    @memcpy(type_copy as ref void, ret_ann as ref void, str.len_raw(ret_ann) + 1)
                    cg_register_local_type(ctx, name, type_copy)
                    if cg_ann_is_indirect_value(ctx, ret_ann) {
                        cg_register_local_ref_type(ctx, name)
                    }
                }
            }
        } elif expr != 0 as ref parser.Node {
            val inferred: ref u8 = infer_type_annotation(ctx, expr)
            if str.rchar_cmp(inferred, "") != 0 {
                val type_copy: ref u8 = @alloc(str.len_raw(inferred) + 1) as ref u8
                @memcpy(type_copy as ref void, inferred as ref void, str.len_raw(inferred) + 1)
                cg_register_local_type(ctx, name, type_copy)
                if cg_ann_is_indirect_value(ctx, inferred) {
                    cg_register_local_ref_type(ctx, name)
                }
            }
        }

        if mutable != 0 {
            val named_agg_name: ref u8 = unwrap_type_name(ty_node)
            val named_agg_fields: ref void = cg_lookup_struct(ctx, named_agg_name)
            val named_agg_union: ref void = cg_lookup_union_suffix(ctx, named_agg_name)
            val is_named_aggregate: bool = ty_node != 0 as ref parser.Node &&
                str.rchar_cmp(named_agg_name, "") != 0 &&
                !is_ref_type(ty_node) &&
                (named_agg_fields != 0 as ref void || named_agg_union != 0 as ref void)
            if is_named_aggregate {
                val agg_size: i64 = cg_alloc_size_for_type(ctx, ty_node)
                val agg_ptr: i64 = fresh_tmp(ctx)
                val agg_buf: ref u8 = @alloc(256) as ref u8
                @snprintf(agg_buf, 256, "    %%t{lld} =l call $malloc(l {lld})\n    call $memset(l %%t{lld}, w 0, l {lld})\n",
                    {agg_ptr, agg_size, agg_ptr, agg_size})
                emit(ctx, agg_buf)
                @free(agg_buf)

                val zero_named_init: mut bool = false
                if expr != 0 as ref parser.Node {
                    if expr.kind == parser.NK_ZERO_INIT {
                        zero_named_init = true
                    } elif expr.kind == parser.NK_INT_LIT {
                        zero_named_init = str.rchar_cmp(parser.int_lit_text(expr), "0") == 0
                    } elif expr.kind == parser.NK_CAST {
                        val cast_inner: ref parser.Node = expr.d0 as ref parser.Node
                        if cast_inner != 0 as ref parser.Node && cast_inner.kind == parser.NK_INT_LIT {
                            zero_named_init = str.rchar_cmp(parser.int_lit_text(cast_inner), "0") == 0
                        }
                    }
                }

                if !zero_named_init {
                    val copy_buf: ref u8 = @alloc(128) as ref u8
                    @snprintf(copy_buf, 128, "    call $memcpy(l %%t{lld}, l {s}, l {lld})\n", {agg_ptr, val_tmp, agg_size})
                    emit(ctx, copy_buf)
                    @free(copy_buf)
                }

                val agg_res: ref u8 = @alloc(16) as ref u8
                @snprintf(agg_res, 16, "%%t{lld}", {agg_ptr})
                val_tmp = agg_res
            }

            val qbe_tmp: i64 = fresh_tmp(ctx)
            val qbe_name: ref u8 = @alloc(32) as ref u8
            @snprintf(qbe_name, 32, "{lld}", {qbe_tmp})

            val buf: ref u8 = @alloc(256) as ref u8
            val store_op: mut ref u8 = "storel"
            val is_ref: bool = ty_node != 0 as ref parser.Node && is_ref_type(ty_node)

            if !is_ref {
                val ltype2: ref u8 = cg_local_type(ctx, name)
                if str.rchar_cmp(ltype2, "f64") == 0 { store_op = "stored" }
                elif str.rchar_cmp(ltype2, "f32") == 0 { store_op = "stores" }
                elif is_word_type_name(ltype2) { store_op = "storew" }
            }

            @snprintf(buf, 256, "    %%t{lld} =l alloc8 8\n    {s} {s}, %%t{lld}\n", {qbe_tmp, store_op, val_tmp, qbe_tmp})
            emit(ctx, buf)
            @free(buf)

            cg_register_local_var(ctx, name, qbe_name)
            cg_mark_as_slot(ctx, name)
        } else {
            val c0: u8 = @load8(val_tmp) as u8
            if c0 == 37 || c0 == 36 {
                val qbe_val: ref u8 = @alloc(str.len_raw(val_tmp) + 1) as ref u8
                @memcpy(qbe_val as ref void, val_tmp as ref void, str.len_raw(val_tmp) + 1)
                cg_register_local_var(ctx, name, qbe_val)
            } else {
                val copy_tmp: i64 = fresh_tmp(ctx)
                val copy_qt: mut ref u8 = "l"
                if ty_node != 0 as ref parser.Node {
                    copy_qt = qbe_type_of(ty_node)
                } elif expr != 0 as ref parser.Node {
                    copy_qt = expr_qbe_type(ctx, expr)
                }
                val buf_copy: ref u8 = @alloc(128) as ref u8
                @snprintf(buf_copy, 128, "    %%t{lld} ={s} copy {s}\n", {copy_tmp, copy_qt, val_tmp})
                emit(ctx, buf_copy)
                @free(buf_copy)
                val qbe_val2: ref u8 = @alloc(32) as ref u8
                @snprintf(qbe_val2, 32, "%%t{lld}", {copy_tmp})
                cg_register_local_var(ctx, name, qbe_val2)
            }
        }
        return
    }

    if k == parser.NK_ASSIGN {
        val target: ref parser.Node = stmt.d0 as ref parser.Node
        val value: ref parser.Node = stmt.d1 as ref parser.Node
        val tk: i64 = target.kind as i64
        if tk == parser.NK_IDENT {
            val tname: ref u8 = target.d0 as ref u8
            val qbe_var: ref u8 = cg_lookup_local_var(ctx, tname)
            val buf2: ref u8 = @alloc(128) as ref u8
            val store_op2: mut ref u8 = "storel"
            val is_ref2: bool = cg_is_local_ref_type(ctx, tname)
            val dst_qtype2: mut ref u8 = "l"
            if !is_ref2 {
                val ltype3_pre: ref u8 = cg_local_type(ctx, tname)
                dst_qtype2 = cg_ann_qtype(ltype3_pre)
            }
            val val_tmp2_raw: ref u8 = gen_expr_with_type(ctx, value, dst_qtype2)
            val val_qtype2: mut ref u8 = expr_qbe_type(ctx, value)
            if ((value.kind == parser.NK_INT_LIT || value.kind == parser.NK_FLOAT_LIT) && str.rchar_cmp(dst_qtype2, "") != 0) {
                val_qtype2 = dst_qtype2
            }
            val val_tmp2: mut ref u8 = val_tmp2_raw

            if !is_ref2 {
                val ltype3: ref u8 = cg_local_type(ctx, tname)
                if str.rchar_cmp(ltype3, "f64") == 0 { store_op2 = "stored" }
                elif str.rchar_cmp(ltype3, "f32") == 0 { store_op2 = "stores" }
                elif is_word_type_name(ltype3) { store_op2 = "storew" }
                if str.rchar_cmp(dst_qtype2, "") != 0 {
                    val_tmp2 = cg_coerce_qtype(ctx, val_tmp2, val_qtype2, dst_qtype2)
                }
            }

            if str.rchar_cmp(qbe_var, "") != 0 {
                val qbe_store_ref: ref u8 = cg_qbe_value_ref(qbe_var)
                @snprintf(buf2, 128, "    {s} {s}, {s}\n", {store_op2, val_tmp2, qbe_store_ref})
            } else {
                @snprintf(buf2, 128, "    {s} {s}, %%{s}\n", {store_op2, val_tmp2, tname})
            }
            emit(ctx, buf2)
            @free(buf2)
        } elif tk == parser.NK_FIELD {
            val val_tmp2_raw: ref u8 = gen_expr(ctx, value)
            val val_qtype2: ref u8 = expr_qbe_type(ctx, value)
            gen_store_field_value(ctx, target, val_tmp2_raw, val_qtype2)
        } elif tk == parser.NK_DEREF {
            val val_tmp2_raw: ref u8 = gen_expr(ctx, value)
            val ptr: ref u8 = gen_expr(ctx, target.d0 as ref parser.Node)
            val buf4: ref u8 = @alloc(128) as ref u8
            @snprintf(buf4, 128, "    storel {s}, {s}\n", {val_tmp2_raw, ptr})
            emit(ctx, buf4)
            @free(buf4)
        }
        return
    }

    if k == parser.NK_RETURN {
        val expr2: ref parser.Node = stmt.d0 as ref parser.Node
        if expr2 == 0 as ref parser.Node {
            cg_emit_invariant_checks(ctx)
            cg_emit_defers(ctx)
            emitln(ctx, "    ret 0")
        } else {
            val rv0: ref u8 = gen_expr_expected(ctx, expr2, ctx.current_fn_ret_ty as ref parser.Node)
            val rv_qt: ref u8 = expr_qbe_type(ctx, expr2)
            val rv: mut ref u8 = rv0
            if str.rchar_cmp(rv_qt, ctx.current_fn_ret_qtype) != 0 {
                if str.rchar_cmp(rv_qt, "w") == 0 && str.rchar_cmp(ctx.current_fn_ret_qtype, "l") == 0 {
                    val ann: ref u8 = infer_type_annotation(ctx, expr2)
                    val instr: mut ref u8 = "extsw"
                    if str.rchar_cmp(ann, "u8") == 0
                    || str.rchar_cmp(ann, "u16") == 0
                    || str.rchar_cmp(ann, "u32") == 0
                    || str.rchar_cmp(ann, "bool") == 0
                    || str.rchar_cmp(ann, "u8") == 0 {
                        instr = "extuw"
                    }
                    val promoted_tmp: i64 = fresh_tmp(ctx)
                    val promoted_buf: ref u8 = @alloc(128) as ref u8
                    @snprintf(promoted_buf, 128, "    %%t{lld} =l {s} {s}\n", {promoted_tmp, instr, rv})
                    emit(ctx, promoted_buf)
                    @free(promoted_buf)
                    val promoted_val: ref u8 = @alloc(16) as ref u8
                    @snprintf(promoted_val, 16, "%%t{lld}", {promoted_tmp})
                    rv = promoted_val
                }
            }
            cg_emit_invariant_checks(ctx)
            cg_emit_defers(ctx)

            // If returning a union, use memcpy to copy to %__ret
            if str.rchar_cmp(ctx.current_fn_ret_union, "") != 0 {
                val buf5: ref u8 = @alloc(128) as ref u8
                @snprintf(buf5, 128, "    call $memcpy(l %%__ret, l {s}, l 16)\n    ret %%__ret\n", {rv})
                emit(ctx, buf5)
                @free(buf5)
            } else {
                val buf5: ref u8 = @alloc(64) as ref u8
                @snprintf(buf5, 64, "    ret {s}\n", {rv})
                emit(ctx, buf5)
                @free(buf5)
            }
        }
        return
    }

    if k == parser.NK_EXPR_STMT {
        gen_expr(ctx, stmt.d0 as ref parser.Node)
        return
    }

    if k == parser.NK_IF {
        gen_if_stmt(ctx, stmt)
        return
    }

    if k == parser.NK_GUARD {
        val gcond: ref u8 = gen_expr(ctx, stmt.d0 as ref parser.Node)
        val pass_lbl: i64 = fresh_lbl(ctx)
        val fail_lbl: i64 = fresh_lbl(ctx)
        val gbuf: ref u8 = @alloc(128) as ref u8
        @snprintf(gbuf, 128, "    jnz {s}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n", {gcond, pass_lbl, fail_lbl, fail_lbl})
        emit(ctx, gbuf)
        @free(gbuf)
        gen_stmts(ctx, stmt.d1 as ref parser.Node)
        val glbl_buf: ref u8 = @alloc(64) as ref u8
        @snprintf(glbl_buf, 64, "@lbl{lld}\n", {pass_lbl})
        emit(ctx, glbl_buf)
        @free(glbl_buf)
        return
    }

    if k == parser.NK_FOR {
        gen_for_stmt(ctx, stmt)
        return
    }

    if k == parser.NK_FORIN {
        gen_forin_stmt(ctx, stmt)
        return
    }

    if k == parser.NK_BREAK {
        val blbl: i64 = cg_break_lbl(ctx)
        val bbuf: ref u8 = @alloc(64) as ref u8
        @snprintf(bbuf, 64, "    jmp @lbl{lld}\n", {blbl})
        emit(ctx, bbuf)
        @free(bbuf)
        return
    }

    if k == parser.NK_CONTINUE {
        val clbl: i64 = cg_cont_lbl(ctx)
        val cbuf: ref u8 = @alloc(64) as ref u8
        @snprintf(cbuf, 64, "    jmp @lbl{lld}\n", {clbl})
        emit(ctx, cbuf)
        @free(cbuf)
        return
    }

    if k == parser.NK_DEFER {
        cg_defer_push(ctx, stmt.d0 as ref parser.Node)
        return
    }

    if k == parser.NK_ASSERT {
        val cond: ref u8 = gen_expr(ctx, stmt.d0 as ref parser.Node)
        val ok_lbl: i64 = fresh_lbl(ctx)
        val fail_lbl: i64 = fresh_lbl(ctx)
        val buf6: ref u8 = @alloc(128) as ref u8
        @snprintf(buf6, 128, "    jnz {s}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n", {cond, ok_lbl, fail_lbl, fail_lbl})
        emit(ctx, buf6)
        @free(buf6)
        val node: ref parser.Node = stmt as ref parser.Node
        val msg_buf: ref u8 = @alloc(512) as ref u8
        @snprintf(msg_buf, 512, "spectre: assertion failed at line {lld}\n", {node.line})
        val msg_idx: i64 = intern_string(ctx, msg_buf)
        @free(msg_buf)
        val msg_tmp: i64 = fresh_tmp(ctx)
        val abuf: ref u8 = @alloc(256) as ref u8
        @snprintf(abuf, 256,
            "    %%t{lld} =l copy $__str{lld}\n    call $dprintf(w 2, l %%t{lld})\n    call $fflush(l 0)\n    call $exit(l 1)\n    hlt\n@lbl{lld}\n",
            {msg_tmp, msg_idx, msg_tmp, ok_lbl})
        emit(ctx, abuf)
        @free(abuf)
        return
    }

    if k == parser.NK_PRE || k == parser.NK_GUARDED_PRE ||
       k == parser.NK_POST || k == parser.NK_GUARDED_POST {
        if ctx.release_mode {
            if k == parser.NK_PRE || k == parser.NK_POST {
                return
            }
        }
        val is_pre: bool = k == parser.NK_PRE || k == parser.NK_GUARDED_PRE
        val kind_str: mut ref u8 = "precondition"
        if !is_pre { kind_str = "postcondition" }
        val fn_name: ref u8 = cg_fn_name(ctx)
        val clist: ref void = stmt.d0 as ref void
        if clist != 0 as ref void {
            val clen: i64 = @len(clist) as i64
            val ci: mut i64 = 0
            for {
                if ci >= clen { break }
                val c_opt = @get(clist, ci as usize)
                match c_opt {
                    some c => {
                        val cnode: ref parser.Node = c as ref parser.Node
                        val label: ref u8 = cnode.d0 as ref u8
                        val cexpr: ref parser.Node = cnode.d1 as ref parser.Node
                        val cv: ref u8 = gen_expr(ctx, cexpr)
                        val ok_lbl: i64 = fresh_lbl(ctx)
                        val fail_lbl: i64 = fresh_lbl(ctx)
                        val jbuf: ref u8 = @alloc(128) as ref u8
                        @snprintf(jbuf, 128, "    jnz {s}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
                            {cv, ok_lbl, fail_lbl, fail_lbl})
                        emit(ctx, jbuf)
                        @free(jbuf)
                        val msg_buf: ref u8 = @alloc(512) as ref u8
                        if label != 0 as ref u8 {
                            @snprintf(msg_buf, 512, "spectre: {s} '{s}' violated in function '{s}'\n",
                                {kind_str, label, fn_name})
                        } else {
                            @snprintf(msg_buf, 512, "spectre: {s} violated in function '{s}'\n",
                                {kind_str, fn_name})
                        }
                        val msg_idx: i64 = intern_string(ctx, msg_buf)
                        @free(msg_buf)
                        val msg_tmp: i64 = fresh_tmp(ctx)
                        val call_buf: ref u8 = @alloc(256) as ref u8
                        @snprintf(call_buf, 256,
                            "    %%t{lld} =l copy $__str{lld}\n    call $dprintf(w 2, l %%t{lld})\n    call $fflush(l 0)\n    call $exit(l 1)\n    hlt\n@lbl{lld}\n",
                            {msg_tmp, msg_idx, msg_tmp, ok_lbl})
                        emit(ctx, call_buf)
                        @free(call_buf)
                    }
                    none => {}
                }
                ci++
            }
        }
        return
    }

    if k == parser.NK_MATCH_OPT {
        gen_match_opt(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_RES {
        gen_match_res(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_ENUM {
        gen_match_enum(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_VALUE {
        gen_match_value(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_STR {
        gen_match_str(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_UNION {
        // union match: emit tag-based dispatch
        gen_match_union(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_TAGGED_UNION {
        gen_match_tagged_union(ctx, stmt)
        return
    }

    if k == parser.NK_GENERIC_WHEN {
        return
    }

    if k == parser.NK_WHEN_STMT {
        val plat: ref u8 = stmt.d0 as ref u8
        if cg_platform_matches(ctx, plat) {
            gen_stmts(ctx, stmt.d1 as ref parser.Node)
        } else {
            val or_when_branches: ref void = stmt.d2 as ref void
            val matched: mut bool = false
            if or_when_branches != 0 as ref void {
                for ow_node in or_when_branches as list[ref parser.Node] {
                    if !matched {
                        val ow_plat: ref u8 = ow_node.d0 as ref u8
                        if cg_platform_matches(ctx, ow_plat) {
                            gen_stmts(ctx, ow_node.d1 as ref parser.Node)
                            matched = true
                        }
                    }
                }
            }
            if !matched {
                val otherwise_stmts: ref void = stmt.d3 as ref void
                if otherwise_stmts != 0 as ref void {
                    gen_stmts(ctx, stmt.d3 as ref parser.Node)
                }
            }
        }
        return
    }

    if k == parser.NK_INCREMENT {
        val target2: ref parser.Node = stmt.d0 as ref parser.Node
        if target2.kind == parser.NK_DEREF {
            gen_update_deref_value(ctx, target2, 1)
            return
        }
        if target2.kind == parser.NK_FIELD {
            val curv3: ref u8 = gen_expr(ctx, target2)
            val next_tmp3: i64 = fresh_tmp(ctx)
            val next_buf3: ref u8 = @alloc(256) as ref u8
            val target2_qt: ref u8 = expr_qbe_type(ctx, target2)
            if str.rchar_cmp(target2_qt, "w") == 0 {
                @snprintf(next_buf3, 256, "    %%t{lld} =l add {s}, 1\n", {next_tmp3, curv3})
                emit(ctx, next_buf3)
                @free(next_buf3)
                val next_res3: ref u8 = @alloc(16) as ref u8
                @snprintf(next_res3, 16, "%%t{lld}", {next_tmp3})
                gen_store_field_value(ctx, target2, next_res3, "w")
            } else {
                @snprintf(next_buf3, 256, "    %%t{lld} =l add {s}, 1\n", {next_tmp3, curv3})
                emit(ctx, next_buf3)
                @free(next_buf3)
                val next_res3: ref u8 = @alloc(16) as ref u8
                @snprintf(next_res3, 16, "%%t{lld}", {next_tmp3})
                gen_store_field_value(ctx, target2, next_res3, "l")
            }
            return
        }
        val tname2: mut ref u8 = 0 as ref u8
        if target2.kind == parser.NK_IDENT {
            tname2 = target2.d0 as ref u8
        } else {
            tname2 = stmt.d0 as ref u8
        }
        if tname2 != 0 as ref u8 {
            // Look up QBE temporary name for local variables
            val qbe_var: ref u8 = cg_lookup_local_var(ctx, tname2)
            val var_ref: ref u8 = @alloc(64) as ref u8
            if str.rchar_cmp(qbe_var, "") != 0 {
                val qbe_ref: ref u8 = cg_qbe_value_ref(qbe_var)
                @snprintf(var_ref, 64, "{s}", {qbe_ref})
                @free(qbe_ref)
            } else {
                @snprintf(var_ref, 64, "%%{s}", {tname2})
            }

            val cur: i64 = fresh_tmp(ctx)
            val nxt: i64 = fresh_tmp(ctx)
            val buf9: ref u8 = @alloc(256) as ref u8
            val ltype_inc: ref u8 = cg_local_type(ctx, tname2)
            if is_word_type_name(ltype_inc) {
                val w_cur: i64 = fresh_tmp(ctx)
                @snprintf(buf9, 256, "    %%t{lld} =w loadw {s}\n    %%t{lld} =l extsw %%t{lld}\n    %%t{lld} =l add %%t{lld}, 1\n    storew %%t{lld}, {s}\n",
                    {w_cur, var_ref, cur, w_cur, nxt, cur, nxt, var_ref})
            } else {
                @snprintf(buf9, 256, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l add %%t{lld}, 1\n    storel %%t{lld}, {s}\n",
                    {cur, var_ref, nxt, cur, nxt, var_ref})
            }
            emit(ctx, buf9)
            @free(buf9)
            @free(var_ref)
        }
        return
    }

    if k == parser.NK_DECREMENT {
        val target3: ref parser.Node = stmt.d0 as ref parser.Node
        if target3.kind == parser.NK_DEREF {
            gen_update_deref_value(ctx, target3, -1)
            return
        }
        if target3.kind == parser.NK_FIELD {
            val curv4: ref u8 = gen_expr(ctx, target3)
            val next_tmp4: i64 = fresh_tmp(ctx)
            val next_buf4: ref u8 = @alloc(256) as ref u8
            val target3_qt: ref u8 = expr_qbe_type(ctx, target3)
            if str.rchar_cmp(target3_qt, "w") == 0 {
                @snprintf(next_buf4, 256, "    %%t{lld} =l sub {s}, 1\n", {next_tmp4, curv4})
                emit(ctx, next_buf4)
                @free(next_buf4)
                val next_res4: ref u8 = @alloc(16) as ref u8
                @snprintf(next_res4, 16, "%%t{lld}", {next_tmp4})
                gen_store_field_value(ctx, target3, next_res4, "w")
            } else {
                @snprintf(next_buf4, 256, "    %%t{lld} =l sub {s}, 1\n", {next_tmp4, curv4})
                emit(ctx, next_buf4)
                @free(next_buf4)
                val next_res4: ref u8 = @alloc(16) as ref u8
                @snprintf(next_res4, 16, "%%t{lld}", {next_tmp4})
                gen_store_field_value(ctx, target3, next_res4, "l")
            }
            return
        }
        val tname3: mut ref u8 = 0 as ref u8
        if target3.kind == parser.NK_IDENT {
            tname3 = target3.d0 as ref u8
        } else {
            tname3 = stmt.d0 as ref u8
        }
        if tname3 != 0 as ref u8 {
            val qbe_var: ref u8 = cg_lookup_local_var(ctx, tname3)
            val var_ref: ref u8 = @alloc(64) as ref u8
            if str.rchar_cmp(qbe_var, "") != 0 {
                val qbe_ref: ref u8 = cg_qbe_value_ref(qbe_var)
                @snprintf(var_ref, 64, "{s}", {qbe_ref})
                @free(qbe_ref)
            } else {
                @snprintf(var_ref, 64, "%%{s}", {tname3})
            }

            val cur2: i64 = fresh_tmp(ctx)
            val nxt2: i64 = fresh_tmp(ctx)
            val buf10: ref u8 = @alloc(256) as ref u8
            val ltype_dec: ref u8 = cg_local_type(ctx, tname3)
            if is_word_type_name(ltype_dec) {
                val w_cur2: i64 = fresh_tmp(ctx)
                @snprintf(buf10, 256, "    %%t{lld} =w loadw {s}\n    %%t{lld} =l extsw %%t{lld}\n    %%t{lld} =l sub %%t{lld}, 1\n    storew %%t{lld}, {s}\n",
                    {w_cur2, var_ref, cur2, w_cur2, nxt2, cur2, nxt2, var_ref})
            } else {
                @snprintf(buf10, 256, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l sub %%t{lld}, 1\n    storel %%t{lld}, {s}\n",
                    {cur2, var_ref, nxt2, cur2, nxt2, var_ref})
            }
            emit(ctx, buf10)
            @free(buf10)
            @free(var_ref)
        }
        return
    }

    if k == parser.NK_ADD_ASSIGN {
        val target4: ref parser.Node = stmt.d0 as ref parser.Node
        val rhs_node: ref parser.Node = stmt.d1 as ref parser.Node
        val rhs: ref u8 = gen_expr(ctx, rhs_node)
        val rhs_qt: ref u8 = expr_qbe_type(ctx, rhs_node)
        if target4.kind == parser.NK_FIELD {
            val curv: ref u8 = gen_expr(ctx, target4)
            val target4_qt: ref u8 = expr_qbe_type(ctx, target4)
            val sum_tmp: i64 = fresh_tmp(ctx)
            val sum_buf: ref u8 = @alloc(256) as ref u8
            if str.rchar_cmp(target4_qt, "s") == 0 || str.rchar_cmp(target4_qt, "d") == 0 {
                val curv_d: ref u8 = cg_coerce_qtype(ctx, curv, target4_qt, "d")
                val rhs_d: ref u8 = cg_coerce_qtype(ctx, rhs, rhs_qt, "d")
                @snprintf(sum_buf, 256, "    %%t{lld} =d add {s}, {s}\n", {sum_tmp, curv_d, rhs_d})
            } else {
                @snprintf(sum_buf, 256, "    %%t{lld} =l add {s}, {s}\n", {sum_tmp, curv, rhs})
            }
            emit(ctx, sum_buf)
            @free(sum_buf)
            val sum_res: ref u8 = @alloc(16) as ref u8
            @snprintf(sum_res, 16, "%%t{lld}", {sum_tmp})
            if str.rchar_cmp(target4_qt, "s") == 0 || str.rchar_cmp(target4_qt, "d") == 0 {
                gen_store_field_value(ctx, target4, sum_res, "d")
            } else {
                gen_store_field_value(ctx, target4, sum_res, "l")
            }
            return
        }
        val tname4: mut ref u8 = 0 as ref u8
        if target4.kind == parser.NK_IDENT {
            tname4 = target4.d0 as ref u8
        } else {
            tname4 = stmt.d0 as ref u8
        }
        if tname4 != 0 as ref u8 {
            val qbe_var: ref u8 = cg_lookup_local_var(ctx, tname4)
            val var_ref: ref u8 = @alloc(64) as ref u8
            if str.rchar_cmp(qbe_var, "") != 0 {
                val qbe_ref: ref u8 = cg_qbe_value_ref(qbe_var)
                @snprintf(var_ref, 64, "{s}", {qbe_ref})
                @free(qbe_ref)
            } else {
                @snprintf(var_ref, 64, "%%{s}", {tname4})
            }

            val cur3: i64 = fresh_tmp(ctx)
            val nxt3: i64 = fresh_tmp(ctx)
            val buf11: ref u8 = @alloc(256) as ref u8
            val ltype_add: ref u8 = cg_local_type(ctx, tname4)
            if str.rchar_cmp(ltype_add, "f32") == 0 || str.rchar_cmp(ltype_add, "f64") == 0 {
                val load_op_add: mut ref u8 = "loads"
                if str.rchar_cmp(ltype_add, "f64") == 0 { load_op_add = "loadd" }
                val cur_qt_add: ref u8 = cg_ann_qtype(ltype_add)
                val cur_val_add: ref u8 = @alloc(16) as ref u8
                val rhs_d_add: ref u8 = cg_coerce_qtype(ctx, rhs, rhs_qt, "d")
                @snprintf(cur_val_add, 16, "%%t{lld}", {cur3})
                @snprintf(buf11, 256, "    %%t{lld} ={s} {s} {s}\n", {cur3, cur_qt_add, load_op_add, var_ref})
                emit(ctx, buf11)
                val cur_d_add: ref u8 = cg_coerce_qtype(ctx, cur_val_add, cur_qt_add, "d")
                @snprintf(buf11, 256, "    %%t{lld} =d add {s}, {s}\n", {nxt3, cur_d_add, rhs_d_add})
                emit(ctx, buf11)
                if str.rchar_cmp(cur_qt_add, "s") == 0 {
                    val trunc_tmp_add: i64 = fresh_tmp(ctx)
                    @snprintf(buf11, 256, "    %%t{lld} =s truncd %%t{lld}\n    stores %%t{lld}, {s}\n", {trunc_tmp_add, nxt3, trunc_tmp_add, var_ref})
                } else {
                    @snprintf(buf11, 256, "    stored %%t{lld}, {s}\n", {nxt3, var_ref})
                }
            } else {
                @snprintf(buf11, 256, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l add %%t{lld}, {s}\n    storel %%t{lld}, {s}\n",
                    {cur3, var_ref, nxt3, cur3, rhs, nxt3, var_ref})
            }
            emit(ctx, buf11)
            @free(buf11)
            @free(var_ref)
        }
        return
    }

    if k == parser.NK_SUB_ASSIGN {
        val target5: ref parser.Node = stmt.d0 as ref parser.Node
        val rhs2_node: ref parser.Node = stmt.d1 as ref parser.Node
        val rhs2: ref u8 = gen_expr(ctx, rhs2_node)
        val rhs2_qt: ref u8 = expr_qbe_type(ctx, rhs2_node)
        if target5.kind == parser.NK_FIELD {
            val curv2: ref u8 = gen_expr(ctx, target5)
            val target5_qt: ref u8 = expr_qbe_type(ctx, target5)
            val diff_tmp: i64 = fresh_tmp(ctx)
            val diff_buf: ref u8 = @alloc(256) as ref u8
            if str.rchar_cmp(target5_qt, "s") == 0 || str.rchar_cmp(target5_qt, "d") == 0 {
                val curv2_d: ref u8 = cg_coerce_qtype(ctx, curv2, target5_qt, "d")
                val rhs2_d: ref u8 = cg_coerce_qtype(ctx, rhs2, rhs2_qt, "d")
                @snprintf(diff_buf, 256, "    %%t{lld} =d sub {s}, {s}\n", {diff_tmp, curv2_d, rhs2_d})
            } else {
                @snprintf(diff_buf, 256, "    %%t{lld} =l sub {s}, {s}\n", {diff_tmp, curv2, rhs2})
            }
            emit(ctx, diff_buf)
            @free(diff_buf)
            val diff_res: ref u8 = @alloc(16) as ref u8
            @snprintf(diff_res, 16, "%%t{lld}", {diff_tmp})
            if str.rchar_cmp(target5_qt, "s") == 0 || str.rchar_cmp(target5_qt, "d") == 0 {
                gen_store_field_value(ctx, target5, diff_res, "d")
            } else {
                gen_store_field_value(ctx, target5, diff_res, "l")
            }
            return
        }
        val tname5: mut ref u8 = 0 as ref u8
        if target5.kind == parser.NK_IDENT {
            tname5 = target5.d0 as ref u8
        } else {
            tname5 = stmt.d0 as ref u8
        }
        if tname5 != 0 as ref u8 {
            val qbe_var: ref u8 = cg_lookup_local_var(ctx, tname5)
            val var_ref: ref u8 = @alloc(64) as ref u8
            if str.rchar_cmp(qbe_var, "") != 0 {
                val qbe_ref: ref u8 = cg_qbe_value_ref(qbe_var)
                @snprintf(var_ref, 64, "{s}", {qbe_ref})
                @free(qbe_ref)
            } else {
                @snprintf(var_ref, 64, "%%{s}", {tname5})
            }

            val cur4: i64 = fresh_tmp(ctx)
            val nxt4: i64 = fresh_tmp(ctx)
            val buf12: ref u8 = @alloc(256) as ref u8
            val ltype_sub: ref u8 = cg_local_type(ctx, tname5)
            if str.rchar_cmp(ltype_sub, "f32") == 0 || str.rchar_cmp(ltype_sub, "f64") == 0 {
                val load_op_sub: mut ref u8 = "loads"
                if str.rchar_cmp(ltype_sub, "f64") == 0 { load_op_sub = "loadd" }
                val cur_qt_sub: ref u8 = cg_ann_qtype(ltype_sub)
                val cur_val_sub: ref u8 = @alloc(16) as ref u8
                val rhs_d_sub: ref u8 = cg_coerce_qtype(ctx, rhs2, rhs2_qt, "d")
                @snprintf(cur_val_sub, 16, "%%t{lld}", {cur4})
                @snprintf(buf12, 256, "    %%t{lld} ={s} {s} {s}\n", {cur4, cur_qt_sub, load_op_sub, var_ref})
                emit(ctx, buf12)
                val cur_d_sub: ref u8 = cg_coerce_qtype(ctx, cur_val_sub, cur_qt_sub, "d")
                @snprintf(buf12, 256, "    %%t{lld} =d sub {s}, {s}\n", {nxt4, cur_d_sub, rhs_d_sub})
                emit(ctx, buf12)
                if str.rchar_cmp(cur_qt_sub, "s") == 0 {
                    val trunc_tmp_sub: i64 = fresh_tmp(ctx)
                    @snprintf(buf12, 256, "    %%t{lld} =s truncd %%t{lld}\n    stores %%t{lld}, {s}\n", {trunc_tmp_sub, nxt4, trunc_tmp_sub, var_ref})
                } else {
                    @snprintf(buf12, 256, "    stored %%t{lld}, {s}\n", {nxt4, var_ref})
                }
            } else {
                @snprintf(buf12, 256, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l sub %%t{lld}, {s}\n    storel %%t{lld}, {s}\n",
                    {cur4, var_ref, nxt4, cur4, rhs2, nxt4, var_ref})
            }
            emit(ctx, buf12)
            @free(buf12)
            @free(var_ref)
        }
        return
    }
}

fn gen_update_deref_value(ctx: ref CgCtx, target: ref parser.Node, delta: i64) void! = {
    val ptr_expr: ref parser.Node = target.d0 as ref parser.Node
    val ptr: ref u8 = gen_expr(ctx, ptr_expr)
    val deref_ann: ref u8 = infer_type_annotation(ctx, target)
    val cur_tmp: i64 = fresh_tmp(ctx)
    val next_tmp: i64 = fresh_tmp(ctx)
    val buf: ref u8 = @alloc(256) as ref u8
    if is_word_type_name(deref_ann) {
        val w_cur_tmp: i64 = fresh_tmp(ctx)
        @snprintf(buf, 256, "    %%t{lld} =w loadw {s}\n    %%t{lld} =l extsw %%t{lld}\n    %%t{lld} =l add %%t{lld}, {lld}\n    storew %%t{lld}, {s}\n",
            {w_cur_tmp, ptr, cur_tmp, w_cur_tmp, next_tmp, cur_tmp, delta, next_tmp, ptr})
    } else {
        val op: mut ref u8 = "+"
        val amount: mut i64 = delta
        if delta < 0 {
            op = "-"
            amount = 0 - delta
        }
        @snprintf(buf, 256, "    %%t{lld} =l loadl {s}\n    %%t{lld} =l {s} %%t{lld}, {lld}\n    storel %%t{lld}, {s}\n",
            {cur_tmp, ptr, next_tmp, op, cur_tmp, amount, next_tmp, ptr})
    }
    emit(ctx, buf)
    @free(buf)
}

fn block_ends_with_terminator(stmts: ref parser.Node) bool! = {
    if stmts == 0 as ref parser.Node { return false }
    val len: i64 = @len(stmts) as i64
    if len == 0 { return false }
    val last_opt = @get(stmts, (len - 1) as usize)
    match last_opt {
        some last => {
            val lk: i64 = (last as ref parser.Node).kind
            return lk == parser.NK_RETURN || lk == parser.NK_BREAK || lk == parser.NK_CONTINUE
        }
        none => { return false }
    }
}

/// Like block_ends_with_terminator but takes a body wrapper node (d0 = stmts list).
fn body_ends_with_terminator(body_node: ref parser.Node) bool! = {
    if body_node == 0 as ref parser.Node { return false }
    return block_ends_with_terminator(body_node.d0 as ref parser.Node)
}

fn gen_if_stmt(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val then_lbl: i64 = fresh_lbl(ctx)
    val end_lbl: i64 = fresh_lbl(ctx)
    val has_else: bool = stmt.d3 != 0
    val elif_list: ref void = stmt.d2 as ref void
    val has_elif: bool = elif_list != 0 as ref void && @len(elif_list as list[ref void]) > 0

    // Determine where the main if/false branch jumps.
    // If there are elifs, we need to pre-allocate their condition labels so we
    // can chain them. We collect them first, then emit everything in order.
    //
    // So, the strategy here is: allocate one "next" label per elif plus one for else/end.
    //   next_lbls[i] = label to jump to when elif[i-1] condition is false
    //   next_lbls[0] = first elif cond label (or else_lbl or end_lbl)
    val next_lbls: mut list[i64] = []
    val body_lbls: mut list[i64] = []

    if has_elif {
        val elen: i64 = @len(elif_list) as i64
        val pi: mut i64 = 0
        for {
            if pi >= elen { break }
            @append(next_lbls, fresh_lbl(ctx))
            @append(body_lbls, fresh_lbl(ctx))
            pi++
        }
    }

    val else_lbl: i64 = fresh_lbl(ctx)
    val first_false: mut i64 = end_lbl

    if has_elif {
        val fl_opt = @get(next_lbls, 0 as usize)
        if fl_opt is some fl { first_false = fl as i64 }
    } elif has_else {
        first_false = else_lbl
    }

    val cond: ref u8 = gen_expr(ctx, stmt.d0 as ref parser.Node)
    val buf: ref u8 = @alloc(128) as ref u8
    @snprintf(buf, 128, "    jnz {s}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n", {cond, then_lbl, first_false, then_lbl})
    emit(ctx, buf)
    @free(buf)

    gen_stmts(ctx, stmt.d1 as ref parser.Node)

    if !block_ends_with_terminator(stmt.d1 as ref parser.Node) {
        val buf2: ref u8 = @alloc(64) as ref u8
        @snprintf(buf2, 64, "    jmp @lbl{lld}\n", {end_lbl})
        emit(ctx, buf2)
        @free(buf2)
    }

    if has_elif {
        val elen: i64 = @len(elif_list) as i64
        val ei: mut i64 = 0
        for {
            if ei >= elen { break }
            if @get(elif_list, ei as usize) is some ep {
                if @get(next_lbls, ei as usize) is some cl {
                    if @get(body_lbls, ei as usize) is some bl {
                        val cond_lbl: i64 = cl as i64
                        val body_lbl: i64 = bl as i64
                        val false_lbl: mut i64 = end_lbl
                        if ei + 1 < elen {
                            if @get(next_lbls, (ei + 1) as usize) is some nl {
                                false_lbl = nl as i64
                            }
                        } elif has_else {
                            false_lbl = else_lbl
                        }
                        val clbuf: ref u8 = @alloc(32) as ref u8
                        @snprintf(clbuf, 32, "@lbl{lld}\n", {cond_lbl})
                        emit(ctx, clbuf)
                        @free(clbuf)
                        val econd: ref u8 = gen_expr(ctx, (ep as ref parser.Node).d0 as ref parser.Node)
                        val ebuf: ref u8 = @alloc(128) as ref u8
                        @snprintf(ebuf, 128, "    jnz {s}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
                            {econd, body_lbl, false_lbl, body_lbl})
                        emit(ctx, ebuf)
                        @free(ebuf)
                        gen_stmts(ctx, (ep as ref parser.Node).d1 as ref parser.Node)
                        if !block_ends_with_terminator((ep as ref parser.Node).d1 as ref parser.Node) {
                            val ejbuf: ref u8 = @alloc(64) as ref u8
                            @snprintf(ejbuf, 64, "    jmp @lbl{lld}\n", {end_lbl})
                            emit(ctx, ejbuf)
                            @free(ejbuf)
                        }
                    }
                }
            }
            ei++
        }
    }

    if has_else {
        val ebuf2: ref u8 = @alloc(32) as ref u8
        @snprintf(ebuf2, 32, "@lbl{lld}\n", {else_lbl})
        emit(ctx, ebuf2)
        @free(ebuf2)
        gen_stmts(ctx, (stmt.d3 as ref parser.Node).d0 as ref parser.Node)
        if !block_ends_with_terminator((stmt.d3 as ref parser.Node).d0 as ref parser.Node) {
            val ejbuf3: ref u8 = @alloc(64) as ref u8
            @snprintf(ejbuf3, 64, "    jmp @lbl{lld}\n", {end_lbl})
            emit(ctx, ejbuf3)
            @free(ejbuf3)
        }
    }

    val endbuf: ref u8 = @alloc(32) as ref u8
    @snprintf(endbuf, 32, "@lbl{lld}\n", {end_lbl})
    emit(ctx, endbuf)
    @free(endbuf)
}

fn gen_for_stmt(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val loop_lbl: i64 = fresh_lbl(ctx)
    val body_lbl: i64 = fresh_lbl(ctx)
    val cont_lbl: i64 = fresh_lbl(ctx)
    val break_lbl: i64 = fresh_lbl(ctx)
    val init_name: ref u8 = stmt.d0 as ref u8
    val prev_break: i64 = cg_break_lbl(ctx)
    val prev_cont: i64 = cg_cont_lbl(ctx)

    cg_set_break_lbl(ctx, break_lbl)
    cg_set_cont_lbl(ctx, cont_lbl)

    if init_name != 0 as ref u8 {
        val init_val: ref u8 = gen_expr(ctx, stmt.d1 as ref parser.Node)
        val buf: ref u8 = @alloc(128) as ref u8
        val already_local: bool = str.rchar_cmp(cg_local_type(ctx, init_name), "") != 0
        val already_direct: bool = str.rchar_cmp(cg_direct_type(ctx, init_name), "") != 0
        if already_local || already_direct {
            @snprintf(buf, 128, "    storel {s}, %%{s}\n", {init_val, init_name})
        } else {
            @snprintf(buf, 128, "    %%{s} =l alloc8 8\n    storel {s}, %%{s}\n", {init_name, init_val, init_name})
        }
        emit(ctx, buf)
        @free(buf)
    }

    val ljbuf: ref u8 = @alloc(64) as ref u8
    @snprintf(ljbuf, 64, "    jmp @lbl{lld}\n@lbl{lld}\n", {loop_lbl, loop_lbl})
    emit(ctx, ljbuf)
    @free(ljbuf)

    val cond_node: ref void = stmt.d2 as ref void
    if cond_node != 0 as ref void {
        val cond: ref u8 = gen_expr(ctx, cond_node as ref parser.Node)
        val cbuf: ref u8 = @alloc(128) as ref u8
        @snprintf(cbuf, 128, "    jnz {s}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
            {cond, body_lbl, break_lbl, body_lbl})
        emit(ctx, cbuf)
        @free(cbuf)
    } else {
        val ibuf: ref u8 = @alloc(64) as ref u8
        @snprintf(ibuf, 64, "    jmp @lbl{lld}\n@lbl{lld}\n", {body_lbl, body_lbl})
        emit(ctx, ibuf)
        @free(ibuf)
    }

    gen_stmts(ctx, stmt.d4 as ref parser.Node)

    if !block_ends_with_terminator(stmt.d4 as ref parser.Node) {
        val cjbuf: ref u8 = @alloc(64) as ref u8
        @snprintf(cjbuf, 64, "    jmp @lbl{lld}\n", {cont_lbl})
        emit(ctx, cjbuf)
        @free(cjbuf)
    }

    val clbuf: ref u8 = @alloc(32) as ref u8
    @snprintf(clbuf, 32, "@lbl{lld}\n", {cont_lbl})
    emit(ctx, clbuf)
    @free(clbuf)

    val post_step: ref void = stmt.d3 as ref void
    if post_step != 0 as ref void {
        gen_stmt(ctx, post_step as ref parser.Node)
    }

    val jbuf: ref u8 = @alloc(64) as ref u8
    @snprintf(jbuf, 64, "    jmp @lbl{lld}\n@lbl{lld}\n", {loop_lbl, break_lbl})
    emit(ctx, jbuf)
    @free(jbuf)

    cg_set_break_lbl(ctx, prev_break)
    cg_set_cont_lbl(ctx, prev_cont)
}

fn gen_forin_stmt(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val binding: ref u8 = stmt.d0 as ref u8
    val iter: ref u8 = gen_expr(ctx, stmt.d1 as ref parser.Node)
    val body: ref void = stmt.d2 as ref void
    val idx: i64 = fresh_tmp(ctx)
    val len: i64 = fresh_tmp(ctx)
    val loop_lbl: i64 = fresh_lbl(ctx)
    val body_lbl: i64 = fresh_lbl(ctx)
    val break_lbl: i64 = fresh_lbl(ctx)
    val cont_lbl: i64 = fresh_lbl(ctx)
    val prev_break2: i64 = cg_break_lbl(ctx)
    val prev_cont2: i64 = cg_cont_lbl(ctx)

    cg_set_break_lbl(ctx, break_lbl)
    cg_set_cont_lbl(ctx, cont_lbl)

    val len_slot: i64 = fresh_tmp(ctx)
    val buf: ref u8 = @alloc(512) as ref u8

    @snprintf(buf, 512,
        "    %%t{lld} =l alloc8 8\n    storel 0, %%t{lld}\n    %%t{lld} =l add {s}, 8\n    %%t{lld} =l loadl %%t{lld}\n@lbl{lld}\n",
        {idx, idx, len_slot, iter, len, len_slot, loop_lbl})
    emit(ctx, buf)
    @free(buf)

    val cur_idx: i64 = fresh_tmp(ctx)
    val cmp: i64 = fresh_tmp(ctx)
    val buf2: ref u8 = @alloc(256) as ref u8
    @snprintf(buf2, 256,
        "    %%t{lld} =l loadl %%t{lld}\n    %%t{lld} =w csltl %%t{lld}, %%t{lld}\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
        {cur_idx, idx, cmp, cur_idx, len, cmp, body_lbl, break_lbl, body_lbl})
    emit(ctx, buf2)
    @free(buf2)

    val buf_tmp: i64 = fresh_tmp(ctx)
    val off: i64 = fresh_tmp(ctx)
    val elem_ptr: i64 = fresh_tmp(ctx)
    val elem: i64 = fresh_tmp(ctx)
    val binding_qbe: ref u8 = @alloc(32) as ref u8
    @snprintf(binding_qbe, 32, "%%t{lld}", {elem})

    val elem_stype: mut ref u8 = "l"
    val iter_node2: ref parser.Node = stmt.d1 as ref parser.Node
    val iter_type2: mut ref u8 = infer_type_annotation(ctx, iter_node2)
    if str.rchar_cmp(iter_type2, "") == 0 && iter_node2 != 0 as ref parser.Node && iter_node2.kind == parser.NK_IDENT {
        val iter_name2: ref u8 = iter_node2.d0 as ref u8
        iter_type2 = cg_local_type(ctx, iter_name2)
        if str.rchar_cmp(iter_type2, "") == 0 {
            val fparams2: ref void = cg_lookup_fn_params(ctx, ctx.fn_name)
            if fparams2 != 0 as ref void {
                val plen2: i64 = @len(fparams2 as list[ref parser.Node]) as i64
                val pi2: mut i64 = 0
                for {
                    if pi2 >= plen2 { break }
                    val p_opt2 = @get(fparams2 as list[ref parser.Node], pi2 as usize)
                    match p_opt2 {
                        some p2 => {
                            val pnode2: ref parser.Node = p2 as ref parser.Node
                            if str.rchar_cmp(pnode2.d0 as ref u8, iter_name2) == 0 {
                                iter_type2 = type_expr_to_annotation(ctx, cg_concrete_ty(ctx, pnode2.d1 as ref parser.Node))
                            }
                        }
                        none => {}
                    }
                    pi2++
                }
            }
        }
    }
    if str.rchar_cmp(iter_type2, "") != 0 && rchar_starts_with(iter_type2, "list[") {
        val elem_type2: ref u8 = @ptradd(iter_type2, 5) as ref u8 // skip "list["
        val elem_len2: i64 = str.len_raw(elem_type2)
        if elem_len2 > 1 {
            val elem_type_copy2: ref u8 = @alloc(elem_len2) as ref u8
            @memcpy(elem_type_copy2 as ref void, elem_type2 as ref void, (elem_len2 - 1) as usize)
            @store8(@ptradd(elem_type_copy2 as ref void, elem_len2 - 1), 0)
            if is_float_type_name(elem_type_copy2) { elem_stype = "d" }
            elif is_word_type_name(elem_type_copy2) { elem_stype = "w" }
        }
    }

    val buf3: ref u8 = @alloc(512) as ref u8
    @snprintf(buf3, 512,
        "    %%t{lld} =l loadl {s}\n    %%t{lld} =l mul %%t{lld}, 8\n    %%t{lld} =l add %%t{lld}, %%t{lld}\n    %%t{lld} =l loadl %%t{lld}\n",
        {buf_tmp, iter, off, cur_idx, elem_ptr, buf_tmp, off, elem, elem_ptr})
    emit(ctx, buf3)
    @free(buf3)

    cg_register_local_var(ctx, binding, binding_qbe)

    val iter_type: mut ref u8 = infer_type_annotation(ctx, iter_node2)
    if str.rchar_cmp(iter_type, "") == 0 && iter_node2 != 0 as ref parser.Node && iter_node2.kind == parser.NK_IDENT {
        val iter_name: ref u8 = iter_node2.d0 as ref u8
        iter_type = cg_local_type(ctx, iter_name)
        if str.rchar_cmp(iter_type, "") == 0 {
            val fparams: ref void = cg_lookup_fn_params(ctx, ctx.fn_name)
            if fparams != 0 as ref void {
                val plen: i64 = @len(fparams as list[ref parser.Node]) as i64
                val pi: mut i64 = 0
                for {
                    if pi >= plen { break }
                    val p_opt = @get(fparams as list[ref parser.Node], pi as usize)
                    match p_opt {
                        some p => {
                            val pnode: ref parser.Node = p as ref parser.Node
                            if str.rchar_cmp(pnode.d0 as ref u8, iter_name) == 0 {
                                iter_type = type_expr_to_annotation(ctx, cg_concrete_ty(ctx, pnode.d1 as ref parser.Node))
                            }
                        }
                        none => {}
                    }
                    pi++
                }
            }
        }
    }
    if str.rchar_cmp(iter_type, "") != 0 && rchar_starts_with(iter_type, "list[") {
        val elem_type: ref u8 = @ptradd(iter_type, 5) as ref u8 // skip "list["
        val elem_len: i64 = str.len_raw(elem_type)
        val yo = @load8(@ptradd(elem_type as ref void, elem_len - 1)) as i64
        if elem_len > 1 && yo == 93 { // ']'
            val elem_type_copy: ref u8 = @alloc(elem_len) as ref u8
            @memcpy(elem_type_copy as ref void, elem_type as ref void, (elem_len - 1) as usize)
            @store8(@ptradd(elem_type_copy as ref void, elem_len - 1), 0)
            cg_register_local_type(ctx, binding, elem_type_copy)
            if rchar_starts_with(elem_type_copy, "ref ") {
                cg_register_local_ref_type(ctx, binding)
            }
        }
    }

    gen_stmts(ctx, body as ref parser.Node)

    val nxt: i64 = fresh_tmp(ctx)
    val buf4: ref u8 = @alloc(256) as ref u8
    @snprintf(buf4, 256,
        "@lbl{lld}\n    %%t{lld} =l add %%t{lld}, 1\n    storel %%t{lld}, %%t{lld}\n    jmp @lbl{lld}\n@lbl{lld}\n",
        {cont_lbl, nxt, cur_idx, nxt, idx, loop_lbl, break_lbl})
    emit(ctx, buf4)
    @free(buf4)

    cg_set_break_lbl(ctx, prev_break2)
    cg_set_cont_lbl(ctx, prev_cont2)
}

fn gen_match_opt(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr_node = parser.match_opt_expr(stmt)
    val expr: mut ref u8 = "0"
    if expr_node != 0 as ref parser.Node { expr = gen_expr(ctx, expr_node) }
    val some_bind: ref u8 = parser.match_opt_some_bind(stmt)
    val some_body_node = parser.match_opt_some_body(stmt)
    val none_body_node = parser.match_opt_none_body(stmt)

    val some_lbl: i64 = fresh_lbl(ctx)
    val none_lbl: i64 = fresh_lbl(ctx)
    val end_lbl: i64 = fresh_lbl(ctx)
    val tag: i64 = fresh_tmp(ctx)
    val buf: ref u8 = @alloc(256) as ref u8
    @snprintf(buf, 256,
        "    %%t{lld} =w cnel {s}, 0\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
        {tag, expr, tag, some_lbl, none_lbl, some_lbl})
    emit(ctx, buf)
    @free(buf)

        if some_bind != 0 as ref u8 {
            val val_tmp: i64 = fresh_tmp(ctx)
            val vbuf: ref u8 = @alloc(128) as ref u8
            @snprintf(vbuf, 128, "    %%t{lld} =l sub {s}, 1\n", {val_tmp, expr})
            emit(ctx, vbuf)
        @free(vbuf)
            val opt_ann: ref u8 = infer_type_annotation(ctx, expr_node)
            val inner_type: ref u8 = parse_option_inner(opt_ann)
            val eff_tmp: mut i64 = val_tmp
            if str.rchar_cmp(inner_type, "f64") == 0 {
                val cast_tmp: i64 = fresh_tmp(ctx)
            val cbuf: ref u8 = @alloc(64) as ref u8
            @snprintf(cbuf, 64, "    %%t{lld} =d cast %%t{lld}\n", {cast_tmp, val_tmp})
                emit(ctx, cbuf)
                @free(cbuf)
                eff_tmp = cast_tmp
            } elif str.rchar_cmp(inner_type, "f32") == 0 {
                val load_tmp: i64 = fresh_tmp(ctx)
                val cbuf2: ref u8 = @alloc(64) as ref u8
                @snprintf(cbuf2, 64, "    %%t{lld} =s loads %%t{lld}\n", {load_tmp, val_tmp})
                emit(ctx, cbuf2)
                @free(cbuf2)
                eff_tmp = load_tmp
            }
        val tmp_str: ref u8 = @alloc(16) as ref u8
        @snprintf(tmp_str, 16, "{lld}", {eff_tmp})
        cg_register_local_var(ctx, some_bind, tmp_str)
        if str.rchar_cmp(inner_type, "") != 0 {
            cg_register_local_type(ctx, some_bind, inner_type)
            if rchar_starts_with(inner_type, "ref ") {
                cg_register_local_ref_type(ctx, some_bind)
            }
        } else {
            cg_register_local_ref_type(ctx, some_bind)
        }
    }

    if some_body_node != 0 as ref parser.Node {
        gen_stmts(ctx, some_body_node.d0 as ref parser.Node)
    }

    val jbuf: ref u8 = @alloc(64) as ref u8
    if !body_ends_with_terminator(some_body_node) {
        @snprintf(jbuf, 64, "    jmp @lbl{lld}\n@lbl{lld}\n", {end_lbl, none_lbl})
        emit(ctx, jbuf)
    } else {
        @snprintf(jbuf, 64, "@lbl{lld}\n", {none_lbl})
        emit(ctx, jbuf)
    }
    @free(jbuf)

    if none_body_node != 0 as ref parser.Node {
        gen_stmts(ctx, none_body_node.d0 as ref parser.Node)
    }

    val endbuf: ref u8 = @alloc(32) as ref u8
    if !body_ends_with_terminator(none_body_node) {
        @snprintf(endbuf, 32, "    jmp @lbl{lld}\n@lbl{lld}\n", {end_lbl, end_lbl})
        emit(ctx, endbuf)
    } else {
        @snprintf(endbuf, 32, "@lbl{lld}\n", {end_lbl})
        emit(ctx, endbuf)
    }
    @free(endbuf)
}

fn gen_match_res(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr_node = parser.match_res_expr(stmt)
    val expr: mut ref u8 = "0"
    if expr_node != 0 as ref parser.Node { expr = gen_expr(ctx, expr_node) }
    val ok_bind: ref u8 = parser.match_res_ok_bind(stmt)
    val ok_body_node = parser.match_res_ok_body(stmt)
    val err_bind: ref u8 = parser.match_res_err_bind(stmt)
    val err_body_node = parser.match_res_err_body(stmt)
    val tag: i64 = fresh_tmp(ctx)
    val is_ok: i64 = fresh_tmp(ctx)
    val ok_lbl: i64 = fresh_lbl(ctx)
    val err_lbl: i64 = fresh_lbl(ctx)
    val end_lbl: i64 = fresh_lbl(ctx)
    val buf: ref u8 = @alloc(256) as ref u8

    val result_ann: ref u8 = infer_type_annotation(ctx, expr_node)
    val ok_type_buf: ref u8 = @alloc(256) as ref u8
    val err_type_buf: ref u8 = @alloc(256) as ref u8
    parse_result_types(result_ann, ok_type_buf, err_type_buf)
    val is_real_result: bool = str.rchar_cmp(result_ann, "") == 0 || rchar_starts_with(result_ann, "result[")

    if is_real_result {
        val is_direct_param: mut bool = false
        if @load8(expr) as i64 == 37 {  // '%'
            val second_char: i64 = @load8(@ptradd(expr, 1)) as i64
            if second_char != 116 {  // not 't'
                is_direct_param = true
            }
        }
        if is_direct_param {
            @snprintf(buf, 256,
                "    %%t{lld} =l copy {s}\n    %%t{lld} =w ceql %%t{lld}, 0\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
                {tag, expr, is_ok, tag, is_ok, ok_lbl, err_lbl, ok_lbl})
        } else {
            @snprintf(buf, 256,
                "    %%t{lld} =l loadl {s}\n    %%t{lld} =w ceql %%t{lld}, 0\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
                {tag, expr, is_ok, tag, is_ok, ok_lbl, err_lbl, ok_lbl})
        }
    } else {
        @snprintf(buf, 256,
            "    %%t{lld} =w copy 1\n    jnz {s}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
            {tag, expr, ok_lbl, err_lbl, ok_lbl})
    }

    emit(ctx, buf)
    @free(buf)

    if is_real_result {
        if ok_bind != 0 as ref u8 {
            val off_ok: i64 = fresh_tmp(ctx)
            val val_ok: i64 = fresh_tmp(ctx)
            val vbuf: ref u8 = @alloc(256) as ref u8
            @snprintf(vbuf, 256,
                "    %%t{lld} =l add {s}, 8\n    %%t{lld} =l loadl %%t{lld}\n",
                {off_ok, expr, val_ok, off_ok})
            emit(ctx, vbuf)
            @free(vbuf)
            val tmp_str: ref u8 = @alloc(16) as ref u8
            @snprintf(tmp_str, 16, "{lld}", {val_ok})
            cg_register_local_var(ctx, ok_bind, tmp_str)
            val ok_inner: ref u8 = ok_type_buf
            if str.rchar_cmp(ok_inner, "") != 0 {
                cg_register_local_type(ctx, ok_bind, ok_inner)
                if rchar_starts_with(ok_inner, "ref ") {
                    cg_register_local_ref_type(ctx, ok_bind)
                }
            }
        }
    } else {
        if ok_bind != 0 as ref u8 {
            val ok_copy: i64 = fresh_tmp(ctx)
            val ok_cbuf: ref u8 = @alloc(64) as ref u8
            val expr_qt: ref u8 = expr_qbe_type(ctx, expr_node)
            if str.rchar_cmp(expr_qt, "w") == 0 {
                val ext_tmp: i64 = fresh_tmp(ctx)
                @snprintf(ok_cbuf, 64, "    %%t{lld} =l extsw {s}\n", {ext_tmp, expr})
                emit(ctx, ok_cbuf)
                @free(ok_cbuf)
                val ok_str: ref u8 = @alloc(16) as ref u8
                @snprintf(ok_str, 16, "{lld}", {ext_tmp})
                cg_register_local_var(ctx, ok_bind, ok_str)
            } else {
                @snprintf(ok_cbuf, 64, "    %%t{lld} =l copy {s}\n", {ok_copy, expr})
                emit(ctx, ok_cbuf)
                @free(ok_cbuf)
                val ok_str: ref u8 = @alloc(16) as ref u8
                @snprintf(ok_str, 16, "{lld}", {ok_copy})
                cg_register_local_var(ctx, ok_bind, ok_str)
            }
            if str.rchar_cmp(result_ann, "") != 0 {
                cg_register_local_type(ctx, ok_bind, result_ann)
            }
        }
    }
    if ok_body_node != 0 as ref parser.Node {
        gen_stmts(ctx, ok_body_node.d0 as ref parser.Node)
    }

    val jbuf: ref u8 = @alloc(64) as ref u8
    if !body_ends_with_terminator(ok_body_node) {
        @snprintf(jbuf, 64, "    jmp @lbl{lld}\n@lbl{lld}\n", {end_lbl, err_lbl})
        emit(ctx, jbuf)
    } else {
        @snprintf(jbuf, 64, "@lbl{lld}\n", {err_lbl})
        emit(ctx, jbuf)
    }
    @free(jbuf)

    if is_real_result {
        if err_bind != 0 as ref u8 {
            val off_err: i64 = fresh_tmp(ctx)
            val val_err: i64 = fresh_tmp(ctx)
            val vbuf2: ref u8 = @alloc(256) as ref u8
            @snprintf(vbuf2, 256,
                "    %%t{lld} =l add {s}, 8\n    %%t{lld} =l loadl %%t{lld}\n    %%{s} =l copy %%t{lld}\n",
                {off_err, expr, val_err, off_err, err_bind, val_err})
            emit(ctx, vbuf2)
            @free(vbuf2)
            val tmp_str_err: ref u8 = @alloc(16) as ref u8
            @snprintf(tmp_str_err, 16, "{lld}", {val_err})
            cg_register_local_var(ctx, err_bind, tmp_str_err)
        }
    } else {
        if err_bind != 0 as ref u8 {
            val err_tmp: i64 = fresh_tmp(ctx)
            val err_zbuf: ref u8 = @alloc(64) as ref u8
            @snprintf(err_zbuf, 64, "    %%t{lld} =l copy 0\n", {err_tmp})
            emit(ctx, err_zbuf)
            @free(err_zbuf)
            val err_str: ref u8 = @alloc(16) as ref u8
            @snprintf(err_str, 16, "{lld}", {err_tmp})
            cg_register_local_var(ctx, err_bind, err_str)
        }
    }
    if err_body_node != 0 as ref parser.Node {
        gen_stmts(ctx, err_body_node.d0 as ref parser.Node)
    }

    val endbuf: ref u8 = @alloc(32) as ref u8
    if !body_ends_with_terminator(err_body_node) {
        @snprintf(endbuf, 32, "    jmp @lbl{lld}\n@lbl{lld}\n", {end_lbl, end_lbl})
        emit(ctx, endbuf)
    } else {
        @snprintf(endbuf, 32, "@lbl{lld}\n", {end_lbl})
        emit(ctx, endbuf)
    }
    @free(endbuf)
}

fn gen_match_enum(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr_node = parser.match_enum_expr(stmt)
    val expr: mut ref u8 = "0"
    if expr_node != 0 as ref parser.Node { expr = gen_expr(ctx, expr_node) }
    val arms = parser.match_enum_arms(stmt)
    val end_lbl: i64 = fresh_lbl(ctx)

    val alen: i64 = @len(arms) as i64
    if alen == 0 { return }
    val ai: mut i64 = 0
    for {
        if ai >= alen { break }
        val arm_opt = @get(arms, ai as usize)
        match arm_opt {
            some arm => {
                val arm_node: ref parser.Node = arm as ref parser.Node
                val variant_name: ref u8 = arm_node.d0 as ref u8
                val type_name: ref u8 = arm_node.d2 as ref u8
                val eval_str: ref u8 = @alloc(32) as ref u8
                @snprintf(eval_str, 32, "{lld}", {ai})
                if type_name != 0 as ref u8 && str.rchar_cmp(type_name, "") != 0 {
                    val key: ref u8 = @alloc(512) as ref u8
                    @snprintf(key, 512, "{s}__{s}", {type_name, variant_name})
                    val found: ref u8 = cg_const_val(ctx, key)
                    @free(key)
                    if str.rchar_cmp(found, "") != 0 { @snprintf(eval_str, 32, "{s}", {found}) }
                }
                val body_lbl: i64 = fresh_lbl(ctx)
                val next_lbl: i64 = fresh_lbl(ctx)
                val cmp: i64 = fresh_tmp(ctx)
                val buf: ref u8 = @alloc(256) as ref u8
                @snprintf(buf, 256,
                    "    %%t{lld} =w ceql {s}, {s}\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
                    {cmp, expr, eval_str, cmp, body_lbl, next_lbl, body_lbl})
                @free(eval_str)
                emit(ctx, buf)
                @free(buf)
                val arm_body = parser.match_enum_arm_body(arm_node)
                gen_stmts(ctx, arm_body as ref parser.Node)
                val jbuf: ref u8 = @alloc(64) as ref u8
                if !block_ends_with_terminator(arm_body as ref parser.Node) {
                    @snprintf(jbuf, 64, "    jmp @lbl{lld}\n@lbl{lld}\n", {end_lbl, next_lbl})
                } else {
                    @snprintf(jbuf, 64, "@lbl{lld}\n", {next_lbl})
                }
                emit(ctx, jbuf)
                @free(jbuf)
            }
            none => {}
        }
        ai++
    }
    val endbuf: ref u8 = @alloc(32) as ref u8
    @snprintf(endbuf, 32, "@lbl{lld}\n", {end_lbl})
    emit(ctx, endbuf)
    @free(endbuf)
}

fn gen_match_value(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr_node = parser.match_value_expr(stmt)
    val expr_ann: ref u8 = infer_type_annotation(ctx, expr_node)
    val target_qt: ref u8 = cg_ann_qtype(expr_ann)
    val expr_qt_raw: ref u8 = expr_qbe_type(ctx, expr_node)
    val expr_raw: ref u8 = gen_expr_with_type(ctx, expr_node, target_qt)
    val arms = parser.match_value_arms(stmt)
    val else_body = parser.match_value_else(stmt)
    val end_lbl: i64 = fresh_lbl(ctx)

    val expr_cmp: mut ref u8 = expr_raw
    val expr_cmp_qt: mut ref u8 = target_qt
    if str.rchar_cmp(expr_cmp_qt, "") == 0 { expr_cmp_qt = expr_qt_raw }
    if str.rchar_cmp(expr_cmp_qt, "s") == 0 {
        val ext_tmp: i64 = fresh_tmp(ctx)
        val ext_buf: ref u8 = @alloc(128) as ref u8
        @snprintf(ext_buf, 128, "    %%t{lld} =d exts {s}\n", {ext_tmp, expr_cmp})
        emit(ctx, ext_buf)
        @free(ext_buf)
        expr_cmp = @alloc(32) as ref u8
        @snprintf(expr_cmp, 32, "%%t{lld}", {ext_tmp})
        expr_cmp_qt = "d"
    }

    val alen: i64 = @len(arms) as i64
    if alen > 0 {
        val ai: mut i64 = 0
        for {
            if ai >= alen { break }
            val arm_opt = @get(arms, ai as usize)
            match arm_opt {
                some arm => {
                    val arm_node: ref parser.Node = arm as ref parser.Node
                    val pat_node: ref parser.Node = parser.match_value_arm_pattern(arm_node)
                    val body_lbl: i64 = fresh_lbl(ctx)
                    val next_lbl: i64 = fresh_lbl(ctx)
                    val cmp_tmp: i64 = fresh_tmp(ctx)
                    val pat_raw: ref u8 = gen_expr_with_type(ctx, pat_node, target_qt)
                    val pat_cmp: mut ref u8 = pat_raw
                    if str.rchar_cmp(expr_cmp_qt, "d") == 0 && str.rchar_cmp(target_qt, "s") == 0 {
                        val pat_ext_tmp: i64 = fresh_tmp(ctx)
                        val pat_ext_buf: ref u8 = @alloc(128) as ref u8
                        @snprintf(pat_ext_buf, 128, "    %%t{lld} =d exts {s}\n", {pat_ext_tmp, pat_cmp})
                        emit(ctx, pat_ext_buf)
                        @free(pat_ext_buf)
                        pat_cmp = @alloc(32) as ref u8
                        @snprintf(pat_cmp, 32, "%%t{lld}", {pat_ext_tmp})
                    }
                    val cmp_op: mut ref u8 = "ceql"
                    if str.rchar_cmp(expr_cmp_qt, "w") == 0 { cmp_op = "ceqw" }
                    elif str.rchar_cmp(expr_cmp_qt, "d") == 0 { cmp_op = "ceqd" }
                    val buf: ref u8 = @alloc(256) as ref u8
                    @snprintf(buf, 256,
                        "    %%t{lld} =w {s} {s}, {s}\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
                        {cmp_tmp, cmp_op, expr_cmp, pat_cmp, cmp_tmp, body_lbl, next_lbl, body_lbl})
                    emit(ctx, buf)
                    @free(buf)
                    val arm_body = parser.match_value_arm_body(arm_node)
                    gen_stmts(ctx, arm_body as ref parser.Node)
                    val jbuf: ref u8 = @alloc(64) as ref u8
                    if !block_ends_with_terminator(arm_body as ref parser.Node) {
                        @snprintf(jbuf, 64, "    jmp @lbl{lld}\n@lbl{lld}\n", {end_lbl, next_lbl})
                    } else {
                        @snprintf(jbuf, 64, "@lbl{lld}\n", {next_lbl})
                    }
                    emit(ctx, jbuf)
                    @free(jbuf)
                }
                none => {}
            }
            ai++
        }
    }

    if else_body != 0 as ref parser.Node {
        gen_stmts(ctx, else_body.d0 as ref parser.Node)
    }

    val endbuf: ref u8 = @alloc(32) as ref u8
    @snprintf(endbuf, 32, "@lbl{lld}\n", {end_lbl})
    emit(ctx, endbuf)
    @free(endbuf)
}

fn gen_match_str(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr_node = parser.match_str_expr(stmt)
    val expr: mut ref u8 = "0"
    if expr_node != 0 as ref parser.Node { expr = gen_expr(ctx, expr_node) }
    val arms = parser.match_str_arms(stmt)
    val else_body = parser.match_str_else(stmt)
    val end_lbl: i64 = fresh_lbl(ctx)

    val alen: i64 = @len(arms) as i64
    if alen > 0 {
        val ai: mut i64 = 0
        for {
            if ai >= alen { break }
            val arm_opt = @get(arms, ai as usize)
            match arm_opt {
                some arm => {
                    val arm_node: ref parser.Node = arm as ref parser.Node
                    val pat: ref u8 = parser.match_str_arm_value(arm_node)
                    val pat_idx: i64 = intern_string(ctx, pat)
                    val body_lbl: i64 = fresh_lbl(ctx)
                    val next_lbl: i64 = fresh_lbl(ctx)
                    val cmp: i64 = fresh_tmp(ctx)
                    val cmp2: i64 = fresh_tmp(ctx)
                    val buf: ref u8 = @alloc(256) as ref u8
                    @snprintf(buf, 256,
                        "    %%t{lld} =l call $strcmp(l {s}, l $__str{lld})\n    %%t{lld} =w ceql %%t{lld}, 0\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
                        {cmp, expr, pat_idx, cmp2, cmp, cmp2, body_lbl, next_lbl, body_lbl})
                    emit(ctx, buf)
                    @free(buf)
                    val arm_body = parser.match_str_arm_body(arm_node)
                    gen_stmts(ctx, arm_body as ref parser.Node)
                    val jbuf: ref u8 = @alloc(64) as ref u8
                    if !block_ends_with_terminator(arm_body as ref parser.Node) {
                        @snprintf(jbuf, 64, "    jmp @lbl{lld}\n@lbl{lld}\n", {end_lbl, next_lbl})
                    } else {
                        @snprintf(jbuf, 64, "@lbl{lld}\n", {next_lbl})
                    }
                    emit(ctx, jbuf)
                    @free(jbuf)
                }
                none => {}
            }
            ai++
        }
    }

    if else_body != 0 as ref parser.Node {
        gen_stmts(ctx, else_body.d0 as ref parser.Node)
    }

    val endbuf: ref u8 = @alloc(32) as ref u8
    @snprintf(endbuf, 32, "@lbl{lld}\n", {end_lbl})
    emit(ctx, endbuf)
    @free(endbuf)
}

/// Look up union variants by type name, trying exact match then suffix match for mangled names.
fn cg_lookup_union_suffix(ctx: ref CgCtx, type_name: ref u8) ref void! = {
    val exact = cg_lookup_union(ctx, type_name)
    if exact != 0 as ref void { return exact }
    val names: ref void = cg_unames(ctx)
    val nlen: i64 = @len(names as list[ref u8]) as i64
    val tlen: i64 = str.len_raw(type_name)
    val suffix_len: i64 = tlen + 2
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref u8], ni as usize)
        match n_opt {
            some n => {
                val candidate: ref u8 = n as ref u8
                val clen: i64 = str.len_raw(candidate)
                if clen > suffix_len {
                    val tail: ref u8 = @ptradd(candidate, clen - suffix_len) as ref u8
                    val c1: u8 = @load8(@ptradd(tail as ref void, 0))
                    val c2: u8 = @load8(@ptradd(tail as ref void, 1))
                    if c1 == 95 && c2 == 95 {
                        val rest: ref u8 = @ptradd(tail as ref void, 2) as ref u8
                        if str.rchar_cmp(rest, type_name) == 0 {
                            val v_opt = @get(cg_uvariants(ctx) as list[ref void], ni as usize)
                            match v_opt { some v => { return v as ref void } none => {} }
                        }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref void
}

fn gen_match_union(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr_node = parser.match_union_expr(stmt)
    val expr: mut ref u8 = "0"
    if expr_node != 0 as ref parser.Node { expr = gen_expr(ctx, expr_node) }
    val arms = parser.match_union_arms(stmt)
    val else_body = parser.match_union_else(stmt)
    val end_lbl: i64 = fresh_lbl(ctx)
    val tag: i64 = fresh_tmp(ctx)
    val tbuf: ref u8 = @alloc(64) as ref u8

    @snprintf(tbuf, 64, "    %%t{lld} =l loadl {s}\n", {tag, expr})
    emit(ctx, tbuf)
    @free(tbuf)

    val union_variants: mut ref void = 0 as ref void
    if expr_node != 0 as ref parser.Node && expr_node.kind == parser.NK_IDENT {
        val ename: ref u8 = expr_node.d0 as ref u8
        val local_ty: ref u8 = cg_local_type(ctx, ename)
        if str.rchar_cmp(local_ty, "") != 0 {
            union_variants = cg_lookup_union_suffix(ctx, local_ty)
        }
    }

    val alen: i64 = @len(arms) as i64
    if alen > 0 {
        val ai: mut i64 = 0
        for {
            if ai >= alen { break }
            val arm_opt = @get(arms, ai as usize)
            match arm_opt {
                some arm => {
                    val arm_node: ref parser.Node = arm as ref parser.Node
                    val arm_ty = parser.match_union_arm_type(arm_node)
                    val tag_idx: mut i64 = ai

                    if union_variants != 0 as ref void && arm_ty != 0 as ref parser.Node {
                        if arm_ty.kind == parser.TY_NAMED {
                            val arm_tname: ref u8 = arm_ty.d0 as ref u8
                            val vlen: i64 = @len(union_variants) as i64
                            val vi: mut i64 = 0
                            for {
                                if vi >= vlen { break }
                                val v_opt = @get(union_variants, vi as usize)
                                match v_opt {
                                    some v => {
                                        if str.rchar_cmp(v as ref u8, arm_tname) == 0 {
                                            tag_idx = vi
                                            break
                                        }
                                    }
                                    none => {}
                                }
                                vi++
                            }
                        }
                    }

                    val body_lbl: i64 = fresh_lbl(ctx)
                    val next_lbl: i64 = fresh_lbl(ctx)
                    val cmp: i64 = fresh_tmp(ctx)
                    val buf: ref u8 = @alloc(256) as ref u8
                    @snprintf(buf, 256,
                        "    %%t{lld} =w ceql %%t{lld}, {lld}\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
                        {cmp, tag, tag_idx, cmp, body_lbl, next_lbl, body_lbl})
                    emit(ctx, buf)
                    @free(buf)
                    val arm_body = parser.match_union_arm_body(arm_node)
                    gen_stmts(ctx, arm_body as ref parser.Node)
                    val jbuf: ref u8 = @alloc(64) as ref u8
                    if !block_ends_with_terminator(arm_body as ref parser.Node) {
                        @snprintf(jbuf, 64, "    jmp @lbl{lld}\n@lbl{lld}\n", {end_lbl, next_lbl})
                    } else {
                        @snprintf(jbuf, 64, "@lbl{lld}\n", {next_lbl})
                    }
                    emit(ctx, jbuf)
                    @free(jbuf)
                }
                none => {}
            }
            ai++
        }
    }

    if else_body != 0 as ref parser.Node {
        gen_stmts(ctx, else_body.d0 as ref parser.Node)
    }

    val endbuf: ref u8 = @alloc(32) as ref u8
    @snprintf(endbuf, 32, "@lbl{lld}\n", {end_lbl})
    emit(ctx, endbuf)
    @free(endbuf)
}

/// Tagged union match: `match expr { VariantName binding => { ... } ... }`
/// Node layout: d0=expr, d1=list[arm], d2=else_arm
/// Arm layout: d0=variant_name(ref u8), d1=list[ref u8] bindings, d2=body stmts list
fn gen_match_tagged_union(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr_node = parser.match_tagged_union_expr(stmt)
    val expr: mut ref u8 = "0"
    if expr_node != 0 as ref parser.Node { expr = gen_expr(ctx, expr_node) }
    val arms = parser.match_tagged_union_arms(stmt)
    val else_body = parser.match_tagged_union_else(stmt)
    val end_lbl: i64 = fresh_lbl(ctx)
    val tag: i64 = fresh_tmp(ctx)
    val tbuf: ref u8 = @alloc(64) as ref u8

    @snprintf(tbuf, 64, "    %%t{lld} =l loadl {s}\n", {tag, expr})
    emit(ctx, tbuf)
    @free(tbuf)

    val alen: i64 = @len(arms) as i64
    if alen > 0 {
        val ai: mut i64 = 0
        for {
            if ai >= alen { break }
            val arm_opt = @get(arms, ai as usize)
            match arm_opt {
                some arm => {
                    val arm_node: ref parser.Node = arm as ref parser.Node
                    val vname: ref u8 = parser.match_tagged_union_arm_variant(arm_node)
                    val bindings = parser.match_tagged_union_arm_bindings(arm_node)

                    val owner_slot: ref void = @alloc(8)
                    val field_slot: ref void = @alloc(8)
                    @store(owner_slot, 0)
                    @store(field_slot, 0)
                    val tag_idx: i64 = cg_lookup_tv(ctx, vname, owner_slot, field_slot)
                    val variant_fields: ref void = @load(field_slot) as ref void
                    @free(owner_slot)
                    @free(field_slot)
                    val actual_idx: mut i64 = ai
                    if tag_idx >= 0 { actual_idx = tag_idx }

                    val body_lbl: i64 = fresh_lbl(ctx)
                    val next_lbl: i64 = fresh_lbl(ctx)
                    val cmp: i64 = fresh_tmp(ctx)
                    val buf: ref u8 = @alloc(256) as ref u8
                    @snprintf(buf, 256,
                        "    %%t{lld} =w ceql %%t{lld}, {lld}\n    jnz %%t{lld}, @lbl{lld}, @lbl{lld}\n@lbl{lld}\n",
                        {cmp, tag, actual_idx, cmp, body_lbl, next_lbl, body_lbl})
                    emit(ctx, buf)
                    @free(buf)

                    val blen: i64 = @len(bindings) as i64
                    if blen > 0 {
                        val bi: mut i64 = 0
                        for {
                            if bi >= blen { break }
                            val b_opt = @get(bindings, bi as usize)
                            match b_opt {
                                some b => {
                                    val bname: ref u8 = b as ref u8
                                    if str.rchar_cmp(bname, "_") != 0 {
                                        val offset: i64 = 8 + bi * 8
                                        val is_inline_struct: mut bool = false
                                        val struct_type_name: mut ref u8 = ""
                                        
                                        if variant_fields != 0 as ref void {
                                            val field_ty_opt = @get(variant_fields as list[ref parser.Node], bi as usize)
                                            match field_ty_opt {
                                                some field_ty => {
                                                    val fty: ref parser.Node = field_ty as ref parser.Node
                                                    val concrete_fty: ref parser.Node = cg_concrete_ty(ctx, fty)
                                                    if concrete_fty != 0 as ref parser.Node && concrete_fty.kind == parser.TY_NAMED {
                                                        val type_name: ref u8 = concrete_fty.d0 as ref u8
                                                        val is_struct: ref void = cg_lookup_struct(ctx, type_name)
                                                        if is_struct != 0 as ref void {
                                                            is_inline_struct = true
                                                            struct_type_name = type_name
                                                        }
                                                    }
                                                }
                                                none => {}
                                            }
                                        }
                                        
                                        if is_inline_struct {
                                            val payload_ptr: i64 = fresh_tmp(ctx)
                                            val bbuf: ref u8 = @alloc(256) as ref u8
                                            @snprintf(bbuf, 256,
                                                "    %%t{lld} =l add {s}, {lld}\n    %%{s} =l copy %%t{lld}\n",
                                                {payload_ptr, expr, offset, bname, payload_ptr})
                                            emit(ctx, bbuf)
                                            @free(bbuf)
                                            cg_dvars_add(ctx, bname, "l")
                                            cg_register_local_ref_type(ctx, bname)
                                            cg_register_local_type(ctx, bname, struct_type_name)
                                        } else {
                                            val payload_ptr: i64 = fresh_tmp(ctx)
                                            val bbuf: ref u8 = @alloc(256) as ref u8
                                            val payload_val: i64 = fresh_tmp(ctx)
                                            @snprintf(bbuf, 256,
                                                "    %%t{lld} =l add {s}, {lld}\n    %%t{lld} =l loadl %%t{lld}\n    %%{s} =l copy %%t{lld}\n",
                                                {payload_ptr, expr, offset, payload_val, payload_ptr, bname, payload_val})
                                            emit(ctx, bbuf)
                                            @free(bbuf)
                                            cg_dvars_add(ctx, bname, "l")
                                        }
                                    }
                                }
                                none => {}
                            }
                            bi++
                        }
                    }

                    val arm_body = parser.match_tagged_union_arm_body(arm_node)
                    gen_stmts(ctx, arm_body as ref parser.Node)
                    val jbuf: ref u8 = @alloc(64) as ref u8
                    if !block_ends_with_terminator(arm_body as ref parser.Node) {
                        @snprintf(jbuf, 64, "    jmp @lbl{lld}\n@lbl{lld}\n", {end_lbl, next_lbl})
                    } else {
                        @snprintf(jbuf, 64, "@lbl{lld}\n", {next_lbl})
                    }
                    emit(ctx, jbuf)
                    @free(jbuf)
                }
                none => {}
            }
            ai++
        }
    }

    if else_body != 0 as ref parser.Node {
        gen_stmts(ctx, else_body.d0 as ref parser.Node)
    }

    val endbuf2: ref u8 = @alloc(32) as ref u8
    @snprintf(endbuf2, 32, "@lbl{lld}\n", {end_lbl})
    emit(ctx, endbuf2)
    @free(endbuf2)
}

fn get_std_child_names() mut list[ref u8] = {
    val std_child_names: list[ref u8] = ["allocators", "collections", "crypto", "fmt", "fs", "log", "math", "os", "path", "random", "reflection", "stdio", "string", "str", "time", "thread", "algorithms"]
    return std_child_names
}

fn gen_fn_prefixed(ctx: mut ref CgCtx, fn_node: ref parser.Node, mod_prefix: ref u8) void! = {
    val public: i64 = fn_node.d0 as i64
    val ns: ref u8 = fn_node.d1 as ref u8
    val name: ref u8 = fn_node.d2 as ref u8
    val params: ref void = fn_node.d3 as ref void
    val ret_ty: ref parser.Node = fn_node.d4 as ref parser.Node
    val body: ref parser.Node = fn_node.d5 as ref parser.Node
    val mangled: ref u8 = @alloc(512) as ref u8
    val base: ref u8 = @alloc(256) as ref u8

    if ns != 0 as ref u8 {
        @snprintf(base, 256, "{s}__{s}", {ns, name})
    } else {
        @snprintf(base, 256, "{s}", {name})
    }

    val is_std_child: mut bool = false
    val scn_len: i64 = @len(get_std_child_names()) as i64
    val scn_i: mut i64 = 0
    for {
        if scn_i >= scn_len { break }
        val scn_opt = @get(get_std_child_names(), scn_i as usize)
        if scn_opt is some scn {
            if str.rchar_cmp(scn as ref u8, mod_prefix) == 0 {
                is_std_child = true
                break
            }
        }
        scn_i++
    }

    if str.rchar_cmp(mod_prefix, "") == 0 {
        @snprintf(mangled, 512, "{s}", {base})
    } elif is_std_child {
        @snprintf(mangled, 512, "std__{s}__{s}", {mod_prefix, base})
    } else {
        @snprintf(mangled, 512, "{s}__{s}", {mod_prefix, base})
    }

    if !cg_emit_label_if_new(ctx, mangled) {
        @free(mangled)
        @free(base)
        return
    }

    cg_set_fn_name(ctx, mangled)

    if params != 0 as ref void {
        cg_register_fn(ctx, mangled, params, ret_ty as ref void)
    }

    val export_kw: mut ref u8 = ""
    if public == 1 { export_kw = "export " }
    val ret_qt: ref u8 = qbe_type_of(ret_ty)
    val sig_buf: ref u8 = @alloc(512) as ref u8

    val ret_union_name: mut ref u8 = is_union_type(ctx, ret_ty)
    if str.rchar_cmp(ret_union_name, "") == 0 && ret_ty != 0 as ref parser.Node && ret_ty.kind == parser.TY_NAMED {
        val unprefixed_name: ref u8 = ret_ty.d0 as ref u8
        if str.rchar_cmp(mod_prefix, "") != 0 {
            val prefixed_name: ref u8 = @alloc(256) as ref u8
            @snprintf(prefixed_name, 256, "{s}__{s}", {mod_prefix, unprefixed_name})
            val union_vars: ref void = cg_lookup_union_suffix(ctx, prefixed_name)
            if union_vars != 0 as ref void {
                ret_union_name = prefixed_name
            }
        }
    }
    val returns_union: bool = str.rchar_cmp(ret_union_name, "") != 0

    @snprintf(sig_buf, 512, "{s}function {s} ${s}(", {export_kw, ret_qt, mangled})
    emit(ctx, sig_buf)
    @free(sig_buf)

    if returns_union {
        emit(ctx, "l %__ret")
    }

    val is_main: bool = str.rchar_cmp(name, "main") == 0 && str.rchar_cmp(mod_prefix, "") == 0
    if is_main {
        if returns_union {
            emit(ctx, ", ")
        }
        emit(ctx, "w %argc, l %argv")
    }

    if params != 0 as ref void && !is_main {
        val plen: i64 = @len(params) as i64
        val pi: mut i64 = 0
        for {
            if pi >= plen { break }
            val p_opt = @get(params, pi as usize)
            match p_opt {
                some param => {
                    val pname: ref u8 = (param as ref parser.Node).d0 as ref u8
                    val pty: ref parser.Node = (param as ref parser.Node).d1 as ref parser.Node
                    val pqt: ref u8 = qbe_type_of(pty)
                    val pbuf: ref u8 = @alloc(64) as ref u8
                    if pi > 0 || returns_union { emit(ctx, ", ") }
                    @snprintf(pbuf, 64, "{s} %%{s}", {pqt, pname})
                    emit(ctx, pbuf)
                    @free(pbuf)
                }
                none => {}
            }
            pi++
        }
    }

    emitln(ctx, ") {")
    emitln(ctx, "@start")

    if is_main {
        emitln(ctx, "    %sx_argc_val =l extsw %argc")
        emitln(ctx, "    storel %sx_argc_val, $sx_argc_store")
        emitln(ctx, "    storel %argv, $sx_argv_store")
        if !ctx.release_mode {
            emitln(ctx, "    call $__sx_panic_init()")
        }
    }

    if returns_union {
        ctx.current_fn_ret_union = ret_union_name
    } else {
        ctx.current_fn_ret_union = ""
    }
    ctx.current_fn_ret_qtype = ret_qt
    ctx.current_fn_ret_ty = ret_ty as ref void
    ctx.expected_ty = 0 as ref void

    cg_dvars_clear(ctx)
    ctx.inv_cur_pnames = []
    ctx.inv_cur_ptypes = []

    if params != 0 as ref void {
        val plen2: i64 = @len(params) as i64
        val pi2: mut i64 = 0
        for {
            if pi2 >= plen2 { break }
            val p_opt2 = @get(params, pi2 as usize)
            match p_opt2 {
                some param2 => {
                    val pname2: ref u8 = (param2 as ref parser.Node).d0 as ref u8
                    val pty2: ref parser.Node = cg_concrete_ty(ctx, (param2 as ref parser.Node).d1 as ref parser.Node)
                    val pty_name2: ref u8 = unwrap_type_name(pty2)
                    if pty2 != 0 as ref parser.Node && (pty2.kind == parser.TY_LIST || pty2.kind == parser.TY_FIXED_ARR) {
                        val full_ptype: ref u8 = type_expr_to_annotation(ctx, pty2)
                        if str.rchar_cmp(full_ptype, "") != 0 {
                            cg_register_local_type(ctx, pname2, full_ptype)
                        }
                    } elif str.rchar_cmp(pty_name2, "") != 0 {
                        cg_register_local_type(ctx, pname2, pty_name2)
                    }
                    if is_ref_type(pty2) {
                        cg_register_local_ref_type(ctx, pname2)
                    }

                    if pty2 != 0 as ref parser.Node && pty2.kind == parser.TY_MUT {
                        val slot_tmp: i64 = fresh_tmp(ctx)
                        val slot_name: ref u8 = @alloc(32) as ref u8
                        @snprintf(slot_name, 32, "{lld}", {slot_tmp})

                        val slot_buf: ref u8 = @alloc(256) as ref u8
                        val param_qt: ref u8 = qbe_type_of(pty2)
                        val store_op: mut ref u8 = "storel"
                        if str.rchar_cmp(param_qt, "w") == 0 {
                            store_op = "storew"
                        } elif str.rchar_cmp(param_qt, "s") == 0 {
                            store_op = "stores"
                        } elif str.rchar_cmp(param_qt, "d") == 0 {
                            store_op = "stored"
                        }

                        @snprintf(slot_buf, 256, "    %%t{lld} =l alloc8 8\n    {s} %%{s}, %%t{lld}\n", {slot_tmp, store_op, pname2, slot_tmp})
                        emit(ctx, slot_buf)
                        @free(slot_buf)

                        cg_register_local_var(ctx, pname2, slot_name)
                        cg_mark_as_slot(ctx, pname2)
                    }
                }
                none => {}
            }
            pi2++
        }
    }

    val gnames_list: ref void = cg_global_src_names(ctx)
    val glen: i64 = @len(gnames_list) as i64
    val gi: mut i64 = 0
    for {
        if gi >= glen { break }
        val gn_opt = @get(gnames_list, gi as usize)
        match gn_opt {
            some gn => {
                val glbl_buf: ref u8 = @alloc(256) as ref u8
                val gqt_buf: ref u8 = @alloc(8) as ref u8
                val gann_buf: ref u8 = @alloc(256) as ref u8
                val found: bool = cg_lookup_global(ctx, gn as ref u8, glbl_buf, gqt_buf, gann_buf)
                if found {
                    val dollar_label: ref u8 = @alloc(260) as ref u8
                    @snprintf(dollar_label, 260, "${s}", {glbl_buf})
                    cg_register_local_var(ctx, gn as ref u8, dollar_label)
                    val is_fixed_arr_global: bool = @load8(gann_buf as ref void) as i64 == 91
                    if !is_fixed_arr_global {
                        cg_mark_as_slot(ctx, gn as ref u8)
                    }
                    if str.rchar_cmp(gann_buf, "") != 0 {
                        val gann_copy: ref u8 = @alloc(str.len_raw(gann_buf) + 1) as ref u8
                        @memcpy(gann_copy as ref void, gann_buf as ref void, str.len_raw(gann_buf) + 1)
                        cg_register_local_type(ctx, gn as ref u8, gann_copy)
                        if rchar_starts_with(gann_copy, "ref ") || rchar_starts_with(gann_copy, "mut ref ") || cg_ann_is_indirect_value(ctx, gann_copy) {
                            cg_register_local_ref_type(ctx, gn as ref u8)
                        }
                    } elif str.rchar_cmp(gqt_buf, "w") == 0 {
                        cg_register_local_type(ctx, gn as ref u8, "i32")
                    } elif str.rchar_cmp(gqt_buf, "s") == 0 {
                        cg_register_local_type(ctx, gn as ref u8, "f32")
                    } elif str.rchar_cmp(gqt_buf, "d") == 0 {
                        cg_register_local_type(ctx, gn as ref u8, "f64")
                    }
                }
                @free(glbl_buf)
                @free(gqt_buf)
                @free(gann_buf)
            }
            none => {}
        }
        gi++
    }

    if params != 0 as ref void {
        val plen2: i64 = @len(params) as i64
        val pi2: mut i64 = 0
        for {
            if pi2 >= plen2 { break }
            val p2_opt = @get(params, pi2 as usize)
            match p2_opt {
                some param2 => {
                    val pname2: ref u8 = (param2 as ref parser.Node).d0 as ref u8
                    val pty2: ref parser.Node = cg_concrete_ty(ctx, (param2 as ref parser.Node).d1 as ref parser.Node)
                    val ptk: i64 = pty2.kind
                    if ptk != parser.TY_MUT {
                        cg_dvars_add(ctx, pname2, qbe_type_of(pty2))
                    }
                    if ptk == parser.TY_NAMED {
                        val tname: ref u8 = pty2.d0 as ref u8
                        cg_register_local_type(ctx, pname2, tname)
                    } elif ptk == parser.TY_FIXED_ARR || ptk == parser.TY_LIST {
                        val full_ptype2: ref u8 = type_expr_to_annotation(ctx, pty2)
                        if str.rchar_cmp(full_ptype2, "") != 0 {
                            cg_register_local_type(ctx, pname2, full_ptype2)
                        }
                    } elif ptk == parser.TY_MUT {
                        val inner: ref parser.Node = pty2.d0 as ref parser.Node
                        if inner != 0 as ref parser.Node && inner.kind == parser.TY_NAMED {
                            val tname2: ref u8 = inner.d0 as ref u8
                            cg_register_local_type(ctx, pname2, tname2)
                            if !ctx.release_mode {
                                val has_inv: ref void = cg_lookup_invariant(ctx, tname2)
                                if has_inv != 0 as ref void {
                                    @append(ctx.inv_cur_pnames as list[ref u8], pname2)
                                    @append(ctx.inv_cur_ptypes as list[ref u8], tname2)
                                }
                            }
                        } elif inner != 0 as ref parser.Node && inner.kind == parser.TY_FIXED_ARR {
                            val full_ptype3: ref u8 = type_expr_to_annotation(ctx, inner)
                            if str.rchar_cmp(full_ptype3, "") != 0 {
                                cg_register_local_type(ctx, pname2, full_ptype3)
                            }
                        }
                    }
                }
                none => {}
            }
            pi2++
        }
    }

    gen_stmts(ctx, body)

    val blen: i64 = @len(body) as i64
    val needs_ret: mut bool = true
    if blen > 0 {
        val last_opt = @get(body, (blen - 1) as usize)
        match last_opt {
            some last => {
                val lk: i64 = (last as ref parser.Node).kind
                if lk == parser.NK_RETURN { needs_ret = false }
            }
            none => {}
        }
    }
    if needs_ret {
        cg_emit_invariant_checks(ctx)
        cg_emit_defers(ctx)
        emitln(ctx, "    ret 0")
    }
    ctx.current_fn_ret_qtype = "l"
    ctx.current_fn_ret_union = ""
    ctx.current_fn_ret_ty = 0 as ref void
    ctx.expected_ty = 0 as ref void
    emitln(ctx, "}")
    emitln(ctx, "")
}

/// Register all variants of a tagged union into the ctx variant table.
fn gen_tagged_union_def(ctx: ref CgCtx, item: ref parser.Node, mod_prefix: ref u8) void! = {
    val name: ref u8 = item.d1 as ref u8
    val variants: ref void = item.d2 as ref void
    if variants == 0 as ref void { return }
    val vlen: i64 = @len(variants) as i64
    val mangled_name: ref u8 = @alloc(256) as ref u8
    if str.rchar_cmp(mod_prefix, "") == 0 {
        @snprintf(mangled_name, 256, "{s}", {name})
    } else {
        @snprintf(mangled_name, 256, "{s}__{s}", {mod_prefix, name})
    }

    cg_register_union(ctx, mangled_name, variants)

    val vi: mut i64 = 0
    for {
        if vi >= vlen { break }
        val v_opt = @get(variants, vi as usize)
        match v_opt {
            some v => {
                val vnode: ref parser.Node = v as ref parser.Node
                val vname: ref u8 = vnode.d0 as ref u8
                val vty: ref void = vnode.d1 as ref void
                cg_register_tv(ctx, vname, mangled_name, vi, vty)
                if str.rchar_cmp(mod_prefix, "") != 0 {
                    val prefixed_vname: ref u8 = @alloc(256) as ref u8
                    @snprintf(prefixed_vname, 256, "{s}__{s}", {mod_prefix, vname})
                    cg_register_tv(ctx, prefixed_vname, mangled_name, vi, vty)
                }
            }
            none => {}
        }
        vi++
    }
}

fn gen_extern_fn(ctx: ref CgCtx, item: ref parser.Node) void! = {
    gen_extern_fn_prefixed(ctx, item, "")
}

fn gen_extern_fn_prefixed(ctx: ref CgCtx, item: ref parser.Node, mod_prefix: ref u8) void! = {
    val public: i64 = item.d0 as i64
    val name: ref u8 = item.d1 as ref u8
    val symbol: ref u8 = item.d2 as ref u8
    val params: ref void = item.d4 as ref void
    val ret_ty: ref void = item.d5 as ref void

    cg_register_extern(ctx, name, symbol, ret_ty)

    if params != 0 as ref void {
        cg_register_fn(ctx, symbol, params, ret_ty)
    }

    if public == 1 && str.rchar_cmp(mod_prefix, "") != 0 {
        val mangled_name: ref u8 = @alloc(512) as ref u8
        @snprintf(mangled_name, 512, "{s}__{s}", {mod_prefix, name})
        cg_register_extern(ctx, mangled_name, symbol, ret_ty)
        if params != 0 as ref void {
            cg_register_fn(ctx, mangled_name, params, ret_ty)
        }
        @free(mangled_name)
    }
}

fn gen_union_def_prefixed(ctx: ref CgCtx, item: ref parser.Node, mod_prefix: ref u8) void! = {
    val name: ref u8 = item.d1 as ref u8
    val variants: ref void = item.d2 as ref void
    if variants == 0 as ref void { return }
    val vlen: i64 = @len(variants) as i64
    val vnames: mut list[ref u8] = []
    val vi: mut i64 = 0
    for {
        if vi >= vlen { break }
        val v_opt = @get(variants, vi as usize)
        match v_opt {
            some v => {
                val vty: ref parser.Node = v as ref parser.Node
                val tname: mut ref u8 = "unknown"
                if vty.kind == parser.TY_NAMED {
                    tname = vty.d0 as ref u8
                } elif vty.kind == parser.TY_REF {
                    tname = "ref"
                }
                @append(vnames, tname)
            }
            none => {}
        }
        vi++
    }
    val mangled_name: ref u8 = @alloc(256) as ref u8
    if str.rchar_cmp(mod_prefix, "") == 0 {
        @snprintf(mangled_name, 256, "{s}", {name})
    } else {
        @snprintf(mangled_name, 256, "{s}__{s}", {mod_prefix, name})
    }
    val vl: list[ref u8] = vnames
    cg_register_union(ctx, mangled_name, vl as ref void)
}

fn gen_enum_def_prefixed(ctx: ref CgCtx, item: ref parser.Node, mod_prefix: ref u8) void! = {
    val name: ref u8 = item.d1 as ref u8
    val variants: ref void = item.d2 as ref void

    if variants == 0 as ref void { return }

    val vlen: i64 = @len(variants) as i64
    val vi: mut i64 = 0

    for {
        if vi >= vlen { break }
        val v_opt = @get(variants, vi as usize)
        match v_opt {
            some v => {
                val vname: ref u8 = v as ref u8
                val const_key: ref u8 = @alloc(512) as ref u8
                val idx_str: ref u8 = @alloc(32) as ref u8

                @snprintf(idx_str, 32, "{lld}", {vi})

                if str.rchar_cmp(mod_prefix, "") == 0 {
                    @snprintf(const_key, 512, "{s}__{s}", {name, vname})
                } else {
                    @snprintf(const_key, 512, "{s}__{s}__{s}", {mod_prefix, name, vname})
                }

                cg_register_module_const(ctx, const_key, idx_str)
                if str.rchar_cmp(mod_prefix, "") != 0 {
                    val bare_key: ref u8 = @alloc(256) as ref u8
                    @snprintf(bare_key, 256, "{s}__{s}", {name, vname})
                    val idx_str2: ref u8 = @alloc(32) as ref u8
                    @snprintf(idx_str2, 32, "{lld}", {vi})
                    cg_register_module_const(ctx, bare_key, idx_str2)
                }
            }
            none => {}
        }
        vi++
    }
}

/// Generate the assert_fail handler and any needed runtime helpers.
fn emit_runtime_helpers(ctx: ref CgCtx) void! = {
    emitln(ctx,
      \\data $str_w_mode = { b "w", b 0 }
      \\data $str_r_mode = { b "r", b 0 }
      \\data $sx_stdin_ptr = { l 0 }
      \\data $sx_stdout_ptr = { l 0 }
      \\data $sx_stderr_ptr = { l 0 }
      \\
      \\function l $sx_stdout() {
      \\@start
      \\    %p =l loadl $sx_stdout_ptr
      \\    %c =w cnel %p, 0
      \\    jnz %c, @done, @init
      \\@init
      \\    %r =l call $fdopen(w 1, l $str_w_mode)
      \\    storel %r, $sx_stdout_ptr
      \\    ret %r
      \\@done
      \\    ret %p
      \\}
      \\function l $sx_stderr() {
      \\@start
      \\    %p =l loadl $sx_stderr_ptr
      \\    %c =w cnel %p, 0
      \\    jnz %c, @done, @init
      \\@init
      \\    %r =l call $fdopen(w 2, l $str_w_mode)
      \\    storel %r, $sx_stderr_ptr
      \\    ret %r
      \\@done
      \\    ret %p
      \\}
      \\function l $sx_stdin() {
      \\@start
      \\    %p =l loadl $sx_stdin_ptr
      \\    %c =w cnel %p, 0
      \\    jnz %c, @done, @init
      \\@init
      \\    %r =l call $fdopen(w 0, l $str_r_mode)
      \\    storel %r, $sx_stdin_ptr
      \\    ret %r
      \\@done
      \\    ret %p
      \\}
      \\
      \\data $sx_argc_store = { l 0 }
      \\data $sx_argv_store = { l 0 }
      \\
      \\function l $sx_get_args() {
      \\@start
      \\    %argc =l loadl $sx_argc_store
      \\    %argv =l loadl $sx_argv_store
      \\    %hdr =l call $malloc(l 24)
      \\    %cap =l mul %argc, 8
      \\    %buf =l call $malloc(l %cap)
      \\    storel %buf, %hdr
      \\    %len_slot =l add %hdr, 8
      \\    storel 0, %len_slot
      \\    %cap_slot =l add %hdr, 16
      \\    storel %argc, %cap_slot
      \\    %i =l copy 0
      \\@args_loop
      \\    %done =w csgel %i, %argc
      \\    jnz %done, @args_done, @args_body
      \\@args_body
      \\    %off =l mul %i, 8
      \\    %slot =l add %argv, %off
      \\    %str =l loadl %slot
      \\    %cur_len =l loadl %len_slot
      \\    %boff =l mul %cur_len, 8
      \\    %bslot =l add %buf, %boff
      \\    storel %str, %bslot
      \\    %new_len =l add %cur_len, 1
      \\    storel %new_len, %len_slot
      \\    %i =l add %i, 1
      \\    jmp @args_loop
      \\@args_done
      \\    ret %hdr
      \\}
      \\
      \\function l $__sx_get_args() {
      \\@start
      \\    %r =l call $sx_get_args()
      \\    ret %r
      \\}
      \\
      \\function w $os__exit(w %code) {
      \\@start
      \\    call $exit(w %code)
      \\    ret 0
      \\}
    )
}

/// Pre-registration pass: register all function names and tagged union variants
/// before emitting any code, so forward references resolve correctly.
fn preregister_items(ctx: ref CgCtx, items: list[ref parser.Node], mod_prefix: ref u8) void! = {
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_GENERIC_FN {
                    val gname: ref u8 = node.d2 as ref u8
                    register_generic_fn(ctx, gname, node, mod_prefix)
                } elif k == parser.NK_FN {
                    val ns: ref u8 = node.d1 as ref u8
                    val name: ref u8 = node.d2 as ref u8
                    val params: ref void = node.d3 as ref void
                    val ret_ty: ref void = node.d4 as ref void
                    val base: ref u8 = @alloc(256) as ref u8
                    if ns != 0 as ref u8 {
                        @snprintf(base, 256, "{s}__{s}", {ns, name})
                    } else {
                        @snprintf(base, 256, "{s}", {name})
                    }
                    val is_std_child: mut bool = false
                    val scn_len: i64 = @len(get_std_child_names()) as i64
                    val scn_i: mut i64 = 0
                    for {
                        if scn_i >= scn_len { break }
                        val scn_opt = @get(get_std_child_names(), scn_i as usize)
                        match scn_opt {
                            some scn => {
                                if str.rchar_cmp(scn as ref u8, mod_prefix) == 0 {
                                    is_std_child = true
                                    break
                                }
                            }
                            none => {}
                        }
                        scn_i++
                    }
                    val mangled: ref u8 = @alloc(512) as ref u8
                    if str.rchar_cmp(mod_prefix, "") == 0 {
                        @snprintf(mangled, 512, "{s}", {base})
                    } elif is_std_child {
                        @snprintf(mangled, 512, "std__{s}__{s}", {mod_prefix, base})
                    } else {
                        @snprintf(mangled, 512, "{s}__{s}", {mod_prefix, base})
                    }
                    if params != 0 as ref void {
                        cg_register_fn(ctx, mangled, params, ret_ty)
                    }
                } elif k == parser.NK_TAGGED_UNIONDEF {
                    gen_tagged_union_def(ctx, node, mod_prefix)
                } elif k == parser.NK_UNIONDEF {
                    gen_union_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_ENUMDEF {
                    gen_enum_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_TYPEDEF {
                    val tname: ref u8 = node.d1 as ref u8
                    val tfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, tname, tfields)
                    if node.d3 != 0 as i64 { cg_register_invariant(ctx, tname, node.d3 as ref void) }
                } elif k == parser.NK_EXTERN_TYPE {
                    val etname: ref u8 = node.d1 as ref u8
                    val etfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, etname, etfields)
                } elif k == parser.NK_CONST {
                    val cname: ref u8 = node.d1 as ref u8
                    val cexpr: ref parser.Node = node.d2 as ref parser.Node
                    val cval_reg: mut ref u8 = 0 as ref u8
                    if cexpr != 0 as ref parser.Node {
                        if cexpr.kind == parser.NK_INT_LIT {
                            cval_reg = parser.int_lit_text(cexpr)
                        } elif cexpr.kind == parser.NK_FLOAT_LIT {
                            val ftext: ref u8 = parser.float_lit_text(cexpr)
                            val fval: ref u8 = @alloc(128) as ref u8
                            @snprintf(fval, 128, "d_{s}", {ftext})
                            cval_reg = fval
                        } elif cexpr.kind == parser.NK_UNOP {
                            val uop: i64 = parser.unop_op(cexpr)
                            val inner: ref parser.Node = parser.unop_inner(cexpr)
                            if inner != 0 as ref parser.Node {
                                if uop == parser.UOP_NEG {
                                    if inner.kind == parser.NK_INT_LIT {
                                        val itext: ref u8 = parser.int_lit_text(inner)
                                        val ival: ref u8 = @alloc(128) as ref u8
                                        @snprintf(ival, 128, "-{s}", {itext})
                                        cval_reg = ival
                                    } elif inner.kind == parser.NK_FLOAT_LIT {
                                        val ftext2: ref u8 = parser.float_lit_text(inner)
                                        val fval2: ref u8 = @alloc(128) as ref u8
                                        @snprintf(fval2, 128, "d_-{s}", {ftext2})
                                        cval_reg = fval2
                                    }
                                }
                            }
                        } elif cexpr.kind == parser.NK_BOOL {
                            val bval: i64 = cexpr.d0 as i64
                            if bval != 0 { cval_reg = "1" } else { cval_reg = "0" }
                        } elif cexpr.kind == parser.NK_STR_LIT {
                            val sidx: i64 = intern_string(ctx, parser.str_lit_text(cexpr))
                            val sbuf: ref u8 = @alloc(64) as ref u8
                            @snprintf(sbuf, 64, "$__str{lld}", {sidx})
                            cval_reg = sbuf
                        }
                    }
                    if cval_reg != 0 as ref u8 {
                        cg_register_module_const(ctx, cname, cval_reg)
                        if str.rchar_cmp(mod_prefix, "") != 0 {
                            val pkey: ref u8 = @alloc(512) as ref u8
                            @snprintf(pkey, 512, "{s}__{s}", {mod_prefix, cname})
                            cg_register_module_const(ctx, pkey, cval_reg)
                        }
                    }
                } elif k == parser.NK_WHEN_ITEMS {
                    val plat: ref u8 = node.d0 as ref u8
                    if cg_platform_matches(ctx, plat) {
                        val witems: list[ref parser.Node] = node.d1 as list[ref parser.Node]
                        preregister_items(ctx, witems, mod_prefix)
                    } else {
                        val or_when_branches2: ref void = node.d2 as ref void
                        val matched2: mut bool = false
                        if or_when_branches2 != 0 as ref void {
                            for ow2 in or_when_branches2 as list[ref parser.Node] {
                                if !matched2 {
                                    val ow_plat2: ref u8 = ow2.d0 as ref u8
                                    if cg_platform_matches(ctx, ow_plat2) {
                                        val ow_items2: list[ref parser.Node] = ow2.d1 as list[ref parser.Node]
                                        preregister_items(ctx, ow_items2, mod_prefix)
                                        matched2 = true
                                    }
                                }
                            }
                        }
                        if !matched2 {
                            val ow_otherwise2: ref void = node.d3 as ref void
                            if ow_otherwise2 != 0 as ref void {
                                val ow_oi2: list[ref parser.Node] = ow_otherwise2 as list[ref parser.Node]
                                preregister_items(ctx, ow_oi2, mod_prefix)
                            }
                        }
                    }
                }
            }
            none => {}
        }
        i++
    }
}

/// Emit all items from one module layer, using `mod_prefix` for name mangling.
fn gen_items_with_prefix(ctx: ref CgCtx, items: list[ref parser.Node], mod_prefix: ref u8) void! = {
    preregister_items(ctx, items, mod_prefix)
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_GENERIC_FN {
                    // already registered in preregister_items; skip generation
                } elif k == parser.NK_FN {
                    gen_fn_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_EXTERN_FN {
                    gen_extern_fn_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_ENUMDEF {
                    gen_enum_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_UNIONDEF {
                    gen_union_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_TAGGED_UNIONDEF {
                    gen_tagged_union_def(ctx, node, mod_prefix)
                } elif k == parser.NK_TYPEDEF {
                    val tname: ref u8 = node.d1 as ref u8
                    val tfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, tname, tfields)
                    if node.d3 != 0 as i64 { cg_register_invariant(ctx, tname, node.d3 as ref void) }
                } elif k == parser.NK_EXTERN_TYPE {
                    val etname: ref u8 = node.d1 as ref u8
                    val etfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, etname, etfields)
                } elif k == parser.NK_WHEN_ITEMS {
                    val plat: ref u8 = node.d0 as ref u8
                    if cg_platform_matches(ctx, plat) {
                        val witems: list[ref parser.Node] = node.d1 as list[ref parser.Node]
                        gen_items_with_prefix(ctx, witems, mod_prefix)
                    } else {
                        val or_when_branches3: ref void = node.d2 as ref void
                        val matched3: mut bool = false
                        if or_when_branches3 != 0 as ref void {
                            for ow3 in or_when_branches3 as list[ref parser.Node] {
                                if !matched3 {
                                    val ow_plat3: ref u8 = ow3.d0 as ref u8
                                    if cg_platform_matches(ctx, ow_plat3) {
                                        val ow_items3: list[ref parser.Node] = ow3.d1 as list[ref parser.Node]
                                        gen_items_with_prefix(ctx, ow_items3, mod_prefix)
                                        matched3 = true
                                    }
                                }
                            }
                        }
                        if !matched3 {
                            val ow_otherwise3: ref void = node.d3 as ref void
                            if ow_otherwise3 != 0 as ref void {
                                val ow_oi3: list[ref parser.Node] = ow_otherwise3 as list[ref parser.Node]
                                gen_items_with_prefix(ctx, ow_oi3, mod_prefix)
                            }
                        }
                    }
                } elif k == parser.NK_VAL {
                    emit_global_val(ctx, mod_prefix, node)
                } elif k == parser.NK_CONST {
                    val cname: ref u8 = node.d1 as ref u8
                    val cexpr: ref parser.Node = node.d2 as ref parser.Node
                    if cexpr != 0 as ref parser.Node {
                        val const_label: ref u8 = @alloc(512) as ref u8
                        if str.rchar_cmp(mod_prefix, "") == 0 {
                            @snprintf(const_label, 512, "{s}", {cname})
                        } else {
                            @snprintf(const_label, 512, "{s}__{s}", {mod_prefix, cname})
                        }

                        if cexpr.kind == parser.NK_INT_LIT {
                            val cval: ref u8 = parser.int_lit_text(cexpr)
                            cg_register_module_const(ctx, cname, cval)
                            if cg_emit_label_if_new(ctx, const_label) {
                                val data_buf: ref u8 = @alloc(256) as ref u8
                                @snprintf(data_buf, 256, "data ${s} = \{ l {s} \}\n", {const_label, cval})
                                emit(ctx, data_buf)
                                @free(data_buf)
                            } else {
                                @free(const_label)
                            }
                        } elif cexpr.kind == parser.NK_FLOAT_LIT {
                            val ftext: ref u8 = parser.float_lit_text(cexpr)
                            val fval: ref u8 = @alloc(128) as ref u8
                            @snprintf(fval, 128, "d_{s}", {ftext})
                            cg_register_module_const(ctx, cname, fval)
                            @free(const_label)
                        } elif cexpr.kind == parser.NK_UNOP {
                            val uop: i64 = parser.unop_op(cexpr)
                            val inner: ref parser.Node = parser.unop_inner(cexpr)
                            if inner != 0 as ref parser.Node {
                                if uop == parser.UOP_NEG {
                                    if inner.kind == parser.NK_INT_LIT {
                                        val itext: ref u8 = parser.int_lit_text(inner)
                                        val ival: ref u8 = @alloc(128) as ref u8
                                        @snprintf(ival, 128, "-{s}", {itext})
                                        cg_register_module_const(ctx, cname, ival)
                                        if cg_emit_label_if_new(ctx, const_label) {
                                            val data_buf2: ref u8 = @alloc(256) as ref u8
                                            @snprintf(data_buf2, 256, "data ${s} = \{ l {s} \}\n", {const_label, ival})
                                            emit(ctx, data_buf2)
                                            @free(data_buf2)
                                        } else {
                                            @free(const_label)
                                        }
                                    } elif inner.kind == parser.NK_FLOAT_LIT {
                                        val ftext2: ref u8 = parser.float_lit_text(inner)
                                        val fval2: ref u8 = @alloc(128) as ref u8
                                        @snprintf(fval2, 128, "d_-{s}", {ftext2})
                                        cg_register_module_const(ctx, cname, fval2)
                                        @free(const_label)
                                    } else {
                                        @free(const_label)
                                    }
                                } else {
                                    @free(const_label)
                                }
                            } else {
                                @free(const_label)
                            }
                        } elif cexpr.kind == parser.NK_BOOL {
                            val bval: i64 = cexpr.d0 as i64
                            val bstr: mut ref u8 = "0"
                            if bval != 0 {
                                cg_register_module_const(ctx, cname, "1")
                                bstr = "1"
                            } else {
                                cg_register_module_const(ctx, cname, "0")
                            }
                            if cg_emit_label_if_new(ctx, const_label) {
                                val data_buf3: ref u8 = @alloc(256) as ref u8
                                @snprintf(data_buf3, 256, "data ${s} = \{ w {s} \}\n", {const_label, bstr})
                                emit(ctx, data_buf3)
                                @free(data_buf3)
                            } else {
                                @free(const_label)
                            }
                        } elif cexpr.kind == parser.NK_LIST_LIT {
                            if cg_emit_label_if_new(ctx, const_label) {
                                emit_global_list_literal(ctx, const_label, cexpr)
                                cg_register_global(ctx, cname, const_label, "l", "")
                            } else {
                                @free(const_label)
                            }
                        } else {
                            @free(const_label)
                        }
                    }
                }
            }
            none => {}
        }
        i++
    }
}

/// Returns true if the items contain any external link statements.
fn items_have_external_links(items: list[ref parser.Node]) bool! = {
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                if node.kind == parser.NK_LINK { return true }
                if node.kind == parser.NK_WHEN_ITEMS {
                    val witems: list[ref parser.Node] = node.d1 as list[ref parser.Node]
                    if items_have_external_links(witems) { return true }
                    val or_when_branches: ref void = node.d2 as ref void
                    if or_when_branches != 0 as ref void {
                        for ow in or_when_branches as list[ref parser.Node] {
                            val ow_items: list[ref parser.Node] = ow.d1 as list[ref parser.Node]
                            if items_have_external_links(ow_items) { return true }
                        }
                    }
                    val ow_otherwise: ref void = node.d3 as ref void
                    if ow_otherwise != 0 as ref void {
                        if items_have_external_links(ow_otherwise as list[ref parser.Node]) { return true }
                    }
                }
            }
            none => {}
        }
        i++
    }
    return false
}

/// Scan items for function calls to track which modules are used, without emitting code.
fn scan_items_for_usage(ctx: ref CgCtx, items: list[ref parser.Node], mod_prefix: ref u8) void! = {
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_FN {
                    val body: ref void = node.d5 as ref void
                    if body != 0 as ref void {
                        val blen: i64 = @len(body as list[ref parser.Node]) as i64
                        val bi: mut i64 = 0
                        for {
                            if bi >= blen { break }
                            val stmt_opt = @get(body as list[ref parser.Node], bi as usize)
                            match stmt_opt {
                                some stmt_val => {
                                    val stmt: ref parser.Node = stmt_val as ref parser.Node
                                    scan_node_for_calls_depth(ctx, stmt, 0)
                                }
                                none => {}
                            }
                            bi++
                        }
                    }
                } elif k == parser.NK_WHEN_ITEMS {
                    val plat: ref u8 = node.d0 as ref u8
                    if cg_platform_matches(ctx, plat) {
                        val witems: list[ref parser.Node] = node.d1 as list[ref parser.Node]
                        scan_items_for_usage(ctx, witems, mod_prefix)
                    }
                }
            }
            none => {}
        }
        i++
    }
}

/// Scan a statement list (function body) for calls.
fn scan_stmts_for_calls(ctx: ref CgCtx, stmts: ref void) void! = {
    if stmts == 0 as ref void { return }

    val slen: i64 = @len(stmts as list[ref parser.Node]) as i64
    if slen < 0 || slen > 100000 {
        return
    }
    val si: mut i64 = 0
    for {
        if si >= slen { break }
        val stmt_opt = @get(stmts as list[ref parser.Node], si as usize)
        match stmt_opt {
            some stmt_val => {
                val stmt: ref parser.Node = stmt_val as ref parser.Node
                scan_node_for_calls_depth(ctx, stmt, 0)
            }
            none => {}
        }
        si++
    }
}

/// Recursively scan a node tree for function calls to mark prefixes as used, with depth limit.
fn scan_node_for_calls_depth(ctx: ref CgCtx, node: ref parser.Node, depth: i64) void! = {
    if node == 0 as ref parser.Node { return }
    if depth > 100 { return }

    val k: i64 = node.kind

    if k == parser.NK_CALL {
        val callee: ref parser.Node = parser.call_callee(node)
        if callee != 0 as ref parser.Node {
            if callee.kind == parser.NK_IDENT || callee.kind == parser.NK_FIELD {
                val callee_name: ref u8 = resolve_callee_name(ctx, callee)
                cg_resolve_fn_name(ctx, callee_name)
            } elif callee.kind == parser.NK_GENERIC_INST {
                val gi_base: ref parser.Node = parser.generic_inst_base(callee)
                val gi_name: ref u8 = generic_callee_base_name(gi_base)
                cg_resolve_fn_name(ctx, gi_name)
            }
            scan_node_for_calls_depth(ctx, callee, depth + 1)
        }
        val args: ref void = parser.call_args(node) as ref void
        if args != 0 as ref void {
            val alen: i64 = @len(args as list[ref parser.Node]) as i64
            val ai: mut i64 = 0
            for {
                if ai >= alen { break }
                val arg_opt = @get(args as list[ref parser.Node], ai as usize)
                match arg_opt {
                    some arg => { scan_node_for_calls_depth(ctx, arg as ref parser.Node, depth + 1) }
                    none => {}
                }
                ai++
            }
        }
    } elif k == parser.NK_IDENT {
        val name: ref u8 = node.d0 as ref u8
        cg_resolve_fn_name(ctx, name)
    } elif k == parser.NK_FIELD {
        scan_node_for_calls_depth(ctx, parser.field_base(node), depth + 1)
    } elif k == parser.NK_IF {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
        val then_stmts: ref void = node.d1 as ref void
        if then_stmts != 0 as ref void {
            scan_stmts_for_calls(ctx, then_stmts)
        }
        val else_stmts: ref void = node.d2 as ref void
        if else_stmts != 0 as ref void {
            scan_stmts_for_calls(ctx, else_stmts)
        }
    } elif k == parser.NK_FOR {
        val body: ref void = node.d4 as ref void
        if body != 0 as ref void {
            scan_stmts_for_calls(ctx, body)
        }
    } elif k == parser.NK_FORIN {
        scan_node_for_calls_depth(ctx, node.d2 as ref parser.Node, depth + 1)
        val body: ref void = node.d3 as ref void
        if body != 0 as ref void {
            scan_stmts_for_calls(ctx, body)
        }
    } elif k == parser.NK_MATCH_OPT {
        val mexpr = parser.match_opt_expr(node)
        if mexpr != 0 as ref parser.Node { scan_node_for_calls_depth(ctx, mexpr, depth + 1) }
        val some_body = parser.match_opt_some_body(node)
        if some_body != 0 as ref parser.Node {
            val some_stmts: ref void = some_body.d0 as ref void
            if some_stmts != 0 as ref void { scan_stmts_for_calls(ctx, some_stmts) }
        }
        val none_body = parser.match_opt_none_body(node)
        if none_body != 0 as ref parser.Node {
            val none_stmts: ref void = none_body.d0 as ref void
            if none_stmts != 0 as ref void { scan_stmts_for_calls(ctx, none_stmts) }
        }
    } elif k == parser.NK_MATCH_RES {
        val rexpr = parser.match_res_expr(node)
        if rexpr != 0 as ref parser.Node { scan_node_for_calls_depth(ctx, rexpr, depth + 1) }
        val ok_body = parser.match_res_ok_body(node)
        if ok_body != 0 as ref parser.Node {
            val ok_stmts: ref void = ok_body.d0 as ref void
            if ok_stmts != 0 as ref void { scan_stmts_for_calls(ctx, ok_stmts) }
        }
        val err_body = parser.match_res_err_body(node)
        if err_body != 0 as ref parser.Node {
            val err_stmts: ref void = err_body.d0 as ref void
            if err_stmts != 0 as ref void { scan_stmts_for_calls(ctx, err_stmts) }
        }
    } elif k == parser.NK_MATCH_ENUM {
        val mexpr2 = parser.match_enum_expr(node)
        if mexpr2 != 0 as ref parser.Node { scan_node_for_calls_depth(ctx, mexpr2, depth + 1) }
        val arms = parser.match_enum_arms(node)
        val alen: i64 = @len(arms) as i64
        if alen > 0 {
            val ai: mut i64 = 0
            for {
                if ai >= alen { break }
                val arm_opt = @get(arms, ai as usize)
                match arm_opt {
                    some arm_val => {
                        val arm: ref parser.Node = arm_val as ref parser.Node
                        val arm_body = parser.match_enum_arm_body(arm)
                        scan_stmts_for_calls(ctx, arm_body as ref void)
                    }
                    none => {}
                }
                ai++
            }
        }
    } elif k == parser.NK_MATCH_VALUE {
        val mexprv = parser.match_value_expr(node)
        if mexprv != 0 as ref parser.Node { scan_node_for_calls_depth(ctx, mexprv, depth + 1) }
        val varms = parser.match_value_arms(node)
        val valen: i64 = @len(varms) as i64
        if valen > 0 {
            val vai: mut i64 = 0
            for {
                if vai >= valen { break }
                val varm_opt = @get(varms, vai as usize)
                match varm_opt {
                    some varm_val => {
                        val varm: ref parser.Node = varm_val as ref parser.Node
                        val vpat = parser.match_value_arm_pattern(varm)
                        if vpat != 0 as ref parser.Node { scan_node_for_calls_depth(ctx, vpat, depth + 1) }
                        val varm_body = parser.match_value_arm_body(varm)
                        scan_stmts_for_calls(ctx, varm_body as ref void)
                    }
                    none => {}
                }
                vai++
            }
        }
        val velse = parser.match_value_else(node)
        if velse != 0 as ref parser.Node {
            val velse_stmts: ref void = velse.d0 as ref void
            if velse_stmts != 0 as ref void { scan_stmts_for_calls(ctx, velse_stmts) }
        }
    } elif k == parser.NK_MATCH_STR {
        val mexpr3 = parser.match_str_expr(node)
        if mexpr3 != 0 as ref parser.Node { scan_node_for_calls_depth(ctx, mexpr3, depth + 1) }
        val sarms = parser.match_str_arms(node)
        val salen: i64 = @len(sarms) as i64
        if salen > 0 {
            val sai: mut i64 = 0
            for {
                if sai >= salen { break }
                val sarm_opt = @get(sarms, sai as usize)
                match sarm_opt {
                    some sarm_val => {
                        val sarm: ref parser.Node = sarm_val as ref parser.Node
                        val sarm_body = parser.match_str_arm_body(sarm)
                        scan_stmts_for_calls(ctx, sarm_body as ref void)
                    }
                    none => {}
                }
                sai++
            }
        }
        val selse = parser.match_str_else(node)
        if selse != 0 as ref parser.Node {
            val selse_stmts: ref void = selse.d0 as ref void
            if selse_stmts != 0 as ref void { scan_stmts_for_calls(ctx, selse_stmts) }
        }
    } elif k == parser.NK_MATCH_UNION {
        val uexpr = parser.match_union_expr(node)
        if uexpr != 0 as ref parser.Node { scan_node_for_calls_depth(ctx, uexpr, depth + 1) }
        val uarms = parser.match_union_arms(node)
        val ualen: i64 = @len(uarms) as i64
        if ualen > 0 {
            val uai: mut i64 = 0
            for {
                if uai >= ualen { break }
                val uarm_opt = @get(uarms, uai as usize)
                match uarm_opt {
                    some uarm_val => {
                        val uarm: ref parser.Node = uarm_val as ref parser.Node
                        val uarm_body = parser.match_union_arm_body(uarm)
                        scan_stmts_for_calls(ctx, uarm_body as ref void)
                    }
                    none => {}
                }
                uai++
            }
        }
        val uelse = parser.match_union_else(node)
        if uelse != 0 as ref parser.Node {
            val uelse_stmts: ref void = uelse.d0 as ref void
            if uelse_stmts != 0 as ref void { scan_stmts_for_calls(ctx, uelse_stmts) }
        }
    } elif k == parser.NK_MATCH_TAGGED_UNION {
        val texpr = parser.match_tagged_union_expr(node)
        if texpr != 0 as ref parser.Node { scan_node_for_calls_depth(ctx, texpr, depth + 1) }
        val tarms = parser.match_tagged_union_arms(node)
        val talen: i64 = @len(tarms) as i64
        if talen > 0 {
            val tai: mut i64 = 0
            for {
                if tai >= talen { break }
                val tarm_opt = @get(tarms, tai as usize)
                match tarm_opt {
                    some tarm_val => {
                        val tarm: ref parser.Node = tarm_val as ref parser.Node
                        val tarm_body = parser.match_tagged_union_arm_body(tarm)
                        scan_stmts_for_calls(ctx, tarm_body as ref void)
                    }
                    none => {}
                }
                tai++
            }
        }
        val telse = parser.match_tagged_union_else(node)
        if telse != 0 as ref parser.Node {
            val telse_stmts: ref void = telse.d0 as ref void
            if telse_stmts != 0 as ref void { scan_stmts_for_calls(ctx, telse_stmts) }
        }
    } elif k == parser.NK_RETURN {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_ASSIGN {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
        scan_node_for_calls_depth(ctx, node.d1 as ref parser.Node, depth + 1)
    } elif k == parser.NK_VAL {
        scan_node_for_calls_depth(ctx, node.d3 as ref parser.Node, depth + 1)
    } elif k == parser.NK_BINOP {
        scan_node_for_calls_depth(ctx, parser.binop_left(node), depth + 1)
        scan_node_for_calls_depth(ctx, parser.binop_right(node), depth + 1)
    } elif k == parser.NK_UNOP {
        scan_node_for_calls_depth(ctx, parser.unop_inner(node), depth + 1)
    } elif k == parser.NK_FIELD {
        scan_node_for_calls_depth(ctx, parser.field_base(node), depth + 1)
    } elif k == parser.NK_BUILTIN {
        val args: ref void = node.d1 as ref void
        if args != 0 as ref void {
            val alen: i64 = @len(args as list[ref parser.Node]) as i64
            val ai: mut i64 = 0
            for {
                if ai >= alen { break }
                val arg_opt = @get(args as list[ref parser.Node], ai as usize)
                match arg_opt {
                    some arg => { scan_node_for_calls_depth(ctx, arg as ref parser.Node, depth + 1) }
                    none => {}
                }
                ai++
            }
        }
    } elif k == parser.NK_CAST {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_STRUCT_LIT {
        val fields: ref void = node.d1 as ref void
        if fields != 0 as ref void {
            val flen: i64 = @len(fields as list[ref parser.Node]) as i64
            val fi: mut i64 = 0
            for {
                if fi >= flen { break }
                val field_opt = @get(fields as list[ref parser.Node], fi as usize)
                match field_opt {
                    some field_val => {
                        val field: ref parser.Node = field_val as ref parser.Node
                        scan_node_for_calls_depth(ctx, field.d1 as ref parser.Node, depth + 1)
                    }
                    none => {}
                }
                fi++
            }
        }
    } elif k == parser.NK_LIST_LIT {
        val elems: ref void = node.d0 as ref void
        if elems != 0 as ref void {
            val elen: i64 = @len(elems as list[ref parser.Node]) as i64
            val ei: mut i64 = 0
            for {
                if ei >= elen { break }
                val elem_opt = @get(elems as list[ref parser.Node], ei as usize)
                match elem_opt {
                    some elem_val => {
                        val elem: ref parser.Node = elem_val as ref parser.Node
                        scan_node_for_calls_depth(ctx, elem, depth + 1)
                    }
                    none => {}
                }
                ei++
            }
        }
    } elif k == parser.NK_ARGS_PACK {
        val elems: ref void = node.d0 as ref void
        if elems != 0 as ref void {
            val elen: i64 = @len(elems as list[ref parser.Node]) as i64
            val ei: mut i64 = 0
            for {
                if ei >= elen { break }
                val elem_opt = @get(elems as list[ref parser.Node], ei as usize)
                match elem_opt {
                    some elem_val => {
                        val elem: ref parser.Node = elem_val as ref parser.Node
                        scan_node_for_calls_depth(ctx, elem, depth + 1)
                    }
                    none => {}
                }
                ei++
            }
        }
    } elif k == parser.NK_EXPR_STMT {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_DEFER {
        val body: ref void = node.d0 as ref void
        if body != 0 as ref void {
            scan_stmts_for_calls(ctx, body)
        }
    } elif k == parser.NK_TRY {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_SOME {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_OK_VAL {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_ERR_VAL {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_ADDR {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_DEREF {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    }
}

/// Main entry for the resolved module tree.
/// Flattens children depth-first, emits each layer with its mangled prefix.
pub fn gen_module_resolved(root: ref module.ResolvedModule, release_mode: bool, src_target: ref u8) ref u8! = {
    val ctx: mut ref CgCtx = cg_new()
    ctx.release_mode = release_mode
    ctx.src_target = src_target
    emit_runtime_helpers(ctx)

    val out_prefixes: list[ref u8] = []
    val out_items:    list[ref void] = []
    val seen:         list[String] = []

    module.flatten_modules(
        root, "",
        out_prefixes,
        out_items,
        seen
    )

    val layers: i64 = @len(out_prefixes) as i64

    cg_mark_prefix_used(ctx, "")

    val li: mut i64 = 0
    for {
        if li >= layers { break }
        val pfx_opt   = @get(out_prefixes, li as usize)
        val items_opt = @get(out_items,    li as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some items_ptr => {
                        val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                        preregister_items(ctx, items, pfx as ref u8)
                        if str.rchar_cmp(pfx as ref u8, "") == 0 {
                            scan_items_for_usage(ctx, items, "")
                        }
                    }
                    none => {}
                }
            }
            none => {}
        }
        li++
    }

    val scan_pass: mut i64 = 0
    for {
        if scan_pass >= 10 { break }
        scan_pass++

        val li_scan: mut i64 = 0
        for {
            if li_scan >= layers { break }
            val pfx_scan_opt   = @get(out_prefixes, li_scan as usize)
            val items_scan_opt = @get(out_items,    li_scan as usize)
            match pfx_scan_opt {
                some pfx_scan => {
                    if cg_is_prefix_used(ctx, pfx_scan as ref u8) {
                        match items_scan_opt {
                            some items_scan_ptr => {
                                val items_scan: list[ref parser.Node] = items_scan_ptr as list[ref parser.Node]
                                scan_items_for_usage(ctx, items_scan, pfx_scan as ref u8)
                            }
                            none => {}
                        }
                    }
                }
                none => {}
            }
            li_scan++
        }
    }

    if cg_is_prefix_used(ctx, "std") {
        val li_std: mut i64 = 0
        for {
            if li_std >= layers { break }
            val pfx_std_opt = @get(out_prefixes, li_std as usize)
            match pfx_std_opt {
                some pfx_std => {
                    val pfx_str: ref u8 = pfx_std as ref u8
                    val nlen: i64 = @len(get_std_child_names()) as i64
                    val ni: mut i64 = 0
                    for {
                        if ni >= nlen { break }
                        val std_name_opt = @get(get_std_child_names(), ni as usize)
                        match std_name_opt {
                            some std_name => {
                                if str.rchar_cmp(pfx_str, std_name as ref u8) == 0 {
                                    cg_mark_prefix_used(ctx, pfx_str)
                                    break
                                }
                            }
                            none => {}
                        }
                        ni++
                    }
                }
                none => {}
            }
            li_std++
        }
    }

    val li2: mut i64 = 0
    for {
        if li2 >= layers { break }
        val pfx_opt   = @get(out_prefixes, li2 as usize)
        val items_opt = @get(out_items,    li2 as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some items_ptr => {
                        val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                        val is_root2: bool = str.rchar_cmp(pfx as ref u8, "") == 0
                        val is_used2: bool = cg_is_prefix_used(ctx, pfx as ref u8)
                        val has_links: bool = items_have_external_links(items)

                        if !has_links || is_root2 || is_used2 {
                            gen_items_with_prefix(ctx, items, pfx as ref u8)
                        } else {
                            gen_items_with_prefix_skip_links(ctx, items, pfx as ref u8)
                        }
                    }
                    none => {}
                }
            }
            none => {}
        }
        li2++
    }

    emit_string_data(ctx)

    val mono_built: ref void = str.StringBuilder.build(ctx.mono_sb)
    val mono_str: ref u8 = str.cstr(mono_built)
    str.StringBuilder.append_cstr(cg_sb(ctx), mono_str)
    str.StringBuilder.free(ctx.mono_sb)

    val built: ref void = str.StringBuilder.build(cg_sb(ctx))
    val result: ref u8 = str.cstr(built)
    str.StringBuilder.free(cg_sb(ctx))
    return result
}

pub fn get_used_prefixes(root: ref module.ResolvedModule) list[ref u8]! = {
    val ctx: ref CgCtx = cg_new()

    val out_prefixes: list[ref u8] = []
    val out_items:    list[ref void] = []
    val seen:         list[String] = []

    module.flatten_modules(
        root, "",
        out_prefixes,
        out_items,
        seen
    )

    val layers: i64 = @len(out_prefixes) as i64

    cg_mark_prefix_used(ctx, "")

    val li: mut i64 = 0
    for {
        if li >= layers { break }
        val pfx_opt   = @get(out_prefixes, li as usize)
        val items_opt = @get(out_items,    li as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some items_ptr => {
                        val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                        preregister_items(ctx, items, pfx as ref u8)
                    }
                    none => {}
                }
            }
            none => {}
        }
        li++
    }

    val li2: mut i64 = 0
    for {
        if li2 >= layers { break }
        val pfx_opt   = @get(out_prefixes, li2 as usize)
        val items_opt = @get(out_items,    li2 as usize)
        match pfx_opt {
            some pfx => {
                if cg_is_prefix_used(ctx, pfx as ref u8) {
                    match items_opt {
                        some items_ptr => {
                            val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                            scan_items_for_usage(ctx, items, pfx as ref u8)
                        }
                        none => {}
                    }
                }
            }
            none => {}
        }
        li2++
    }

    if cg_is_prefix_used(ctx, "std") {
        val li_std: mut i64 = 0
        for {
            if li_std >= layers { break }
            val pfx_std_opt = @get(out_prefixes, li_std as usize)
            match pfx_std_opt {
                some pfx_std => {
                    val pfx_str: ref u8 = pfx_std as ref u8
                    val nlen: i64 = @len(get_std_child_names()) as i64
                    val ni: mut i64 = 0
                    for {
                        if ni >= nlen { break }
                        val std_name_opt = @get(get_std_child_names(), ni as usize)
                        match std_name_opt {
                            some std_name => {
                                if str.rchar_cmp(pfx_str, std_name as ref u8) == 0 {
                                    cg_mark_prefix_used(ctx, pfx_str)
                                    break
                                }
                            }
                            none => {}
                        }
                        ni++
                    }
                }
                none => {}
            }
            li_std++
        }
    }

    return ctx.used_prefixes
}

/// Emit a single test block as a numbered function. Returns the function name.
fn gen_test_fn(ctx: ref CgCtx, body_stmts: ref parser.Node, test_id: i64) void! = {
    cg_dvars_clear(ctx)
    val fname: ref u8 = @fmt("__sx_test_{lld}", {test_id})
    val hdr: ref u8 = @fmt("export function w ${s}() {\n@start\n", {fname})
    emit(ctx, hdr)
    val gnames_list: ref void = cg_global_src_names(ctx)
    val glen: i64 = @len(gnames_list) as i64
    val gi: mut i64 = 0
    for {
        if gi >= glen { break }
        val gn_opt = @get(gnames_list, gi as usize)
        match gn_opt {
            some gn => {
                val glbl_buf: ref u8 = @alloc(256) as ref u8
                val gqt_buf: ref u8 = @alloc(8) as ref u8
                val gann_buf: ref u8 = @alloc(256) as ref u8
                val found: bool = cg_lookup_global(ctx, gn as ref u8, glbl_buf, gqt_buf, gann_buf)
                if found {
                    val dollar_label: ref u8 = @alloc(260) as ref u8
                    @snprintf(dollar_label, 260, "${s}", {glbl_buf})
                    cg_register_local_var(ctx, gn as ref u8, dollar_label)
                    val is_fixed_arr_global2: bool = @load8(gann_buf as ref void) as i64 == 91
                    if !is_fixed_arr_global2 {
                        cg_mark_as_slot(ctx, gn as ref u8)
                    }
                    if str.rchar_cmp(gann_buf, "") != 0 {
                        val gann_copy: ref u8 = @alloc(str.len_raw(gann_buf) + 1) as ref u8
                        @memcpy(gann_copy as ref void, gann_buf as ref void, str.len_raw(gann_buf) + 1)
                        cg_register_local_type(ctx, gn as ref u8, gann_copy)
                        if rchar_starts_with(gann_copy, "ref ") || rchar_starts_with(gann_copy, "mut ref ") || cg_ann_is_indirect_value(ctx, gann_copy) {
                            cg_register_local_ref_type(ctx, gn as ref u8)
                        }
                    } elif str.rchar_cmp(gqt_buf, "w") == 0 {
                        cg_register_local_type(ctx, gn as ref u8, "i32")
                    } elif str.rchar_cmp(gqt_buf, "s") == 0 {
                        cg_register_local_type(ctx, gn as ref u8, "f32")
                    } elif str.rchar_cmp(gqt_buf, "d") == 0 {
                        cg_register_local_type(ctx, gn as ref u8, "f64")
                    }
                }
                @free(glbl_buf)
                @free(gqt_buf)
                @free(gann_buf)
            }
            none => {}
        }
        gi++
    }
    gen_stmts(ctx, body_stmts)
    cg_emit_defers(ctx)
    emitln(ctx, "    ret 0")
    emitln(ctx, "}")
    emitln(ctx, "")
}

/// Emit a $main that calls all collected test functions and prints a summary.
fn gen_test_main(ctx: ref CgCtx, test_ids: list[i64]) void! = {
    emitln(ctx, "export function w $main(w %argc, l %argv) {")
    emitln(ctx, "@start")
    emitln(ctx, "    %sx_argc_val =l extsw %argc")
    emitln(ctx, "    storel %sx_argc_val, $sx_argc_store")
    emitln(ctx, "    storel %argv, $sx_argv_store")
    if !ctx.release_mode {
        emitln(ctx, "    call $__sx_panic_init()")
    }
    val tlen: i64 = @len(test_ids) as i64
    val ti: mut i64 = 0
    for {
        if ti >= tlen { break }
        val id_opt = @get(test_ids, ti as usize)
        match id_opt {
            some id => {
                val call: ref u8 = @fmt("    call $__sx_test_{lld}()\n", {id as i64})
                emit(ctx, call)
            }
            none => {}
        }
        ti++
    }
    val ok_idx: i64 = intern_string(ctx, "all tests passed\n")
    val ok_tmp: i64 = fresh_tmp(ctx)
    val ok_buf: ref u8 = @alloc(128) as ref u8
    @snprintf(ok_buf, 128, "    %%t{lld} =l copy $__str{lld}\n    call $printf(l %%t{lld})\n    ret 0\n}\n\n",
        {ok_tmp, ok_idx, ok_tmp})
    emit(ctx, ok_buf)
    @free(ok_buf)
}

/// Entry point for --test mode: emits test blocks from root module only,
/// suppresses main(), and emits a test runner $main.
pub fn gen_module_resolved_test(root: ref module.ResolvedModule, release_mode: bool, src_target: ref u8) ref u8! = {
    val ctx: mut ref CgCtx = cg_new()
    ctx.release_mode = release_mode
    ctx.src_target = src_target
    emit_runtime_helpers(ctx)

    val out_prefixes: list[ref u8] = []
    val out_items:    list[ref void] = []
    val seen:         list[String] = []

    module.flatten_modules(
        root, "",
        out_prefixes,
        out_items,
        seen
    )

    val layers: i64 = @len(out_prefixes) as i64

    cg_mark_prefix_used(ctx, "")

    val root_imports: list[ref u8] = root.import_names
    val rimp_len: i64 = @len(root_imports) as i64
    val ri_idx: mut i64 = 0
    for {
        if ri_idx >= rimp_len { break }
        val imp_opt = @get(root_imports, ri_idx as usize)
        match imp_opt {
            some imp_name => {
                cg_mark_prefix_used(ctx, imp_name as ref u8)
            }
            none => {}
        }
        ri_idx++
    }

    val li: mut i64 = 0
    for {
        if li >= layers { break }
        val pfx_opt   = @get(out_prefixes, li as usize)
        val items_opt = @get(out_items,    li as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some items_ptr => {
                        val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                        preregister_items(ctx, items, pfx as ref u8)
                    }
                    none => {}
                }
            }
            none => {}
        }
        li++
    }

    val test_ids: mut list[i64] = []
    val test_counter: mut i64 = 0
    val root_items: list[ref parser.Node] = root.items
    val rlen: i64 = @len(root_items) as i64
    val ri: mut i64 = 0
    for {
        if ri >= rlen { break }
        val item_opt = @get(root_items, ri as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                if node.kind == parser.NK_TEST {
                    val body: ref void = node.d0 as ref void
                    if body != 0 as ref void {
                        scan_stmts_for_calls(ctx, body)
                    }
                }
            }
            none => {}
        }
        ri++
    }

    val scan_pass: mut i64 = 0
    for {
        if scan_pass >= 10 { break }
        scan_pass++

        val li_scan: mut i64 = 0
        for {
            if li_scan >= layers { break }
            val pfx_scan_opt   = @get(out_prefixes, li_scan as usize)
            val items_scan_opt = @get(out_items,    li_scan as usize)
            match pfx_scan_opt {
                some pfx_scan => {
                    if cg_is_prefix_used(ctx, pfx_scan as ref u8) {
                        match items_scan_opt {
                            some items_scan_ptr => {
                                val items_scan: list[ref parser.Node] = items_scan_ptr as list[ref parser.Node]
                                scan_items_for_usage(ctx, items_scan, pfx_scan as ref u8)
                            }
                            none => {}
                        }
                    }
                }
                none => {}
            }
            li_scan++
        }
    }

    if cg_is_prefix_used(ctx, "std") {
        val li_std: mut i64 = 0
        for {
            if li_std >= layers { break }
            val pfx_std_opt = @get(out_prefixes, li_std as usize)
            match pfx_std_opt {
                some pfx_std => {
                    val pfx_str: ref u8 = pfx_std as ref u8
                    val nlen: i64 = @len(get_std_child_names()) as i64
                    val ni: mut i64 = 0
                    for {
                        if ni >= nlen { break }
                        val std_name_opt = @get(get_std_child_names(), ni as usize)
                        match std_name_opt {
                            some std_name => {
                                if str.rchar_cmp(pfx_str, std_name as ref u8) == 0 {
                                    cg_mark_prefix_used(ctx, pfx_str)
                                    break
                                }
                            }
                            none => {}
                        }
                        ni++
                    }
                }
                none => {}
            }
            li_std++
        }
    }

    val li2: mut i64 = 0
    for {
        if li2 >= layers { break }
        val pfx_opt   = @get(out_prefixes, li2 as usize)
        val items_opt = @get(out_items,    li2 as usize)
        match pfx_opt {
            some pfx => {
                val is_root: bool = str.rchar_cmp(pfx as ref u8, "") == 0
                val is_used: bool = cg_is_prefix_used(ctx, pfx as ref u8)

                match items_opt {
                    some items_ptr => {
                        val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                        val has_links: bool = items_have_external_links(items)

                        if is_root || is_used || !has_links {
                            if is_root {
                                gen_items_with_prefix_skip_main(ctx, items, "")
                            } else {
                                gen_items_with_prefix(ctx, items, pfx as ref u8)
                            }
                        }
		    }
                    none => {}
                }
            }
            none => {}
        }
        li2++
    }

    val ri2: mut i64 = 0
    for {
        if ri2 >= rlen { break }
        val item_opt = @get(root_items, ri2 as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                if node.kind == parser.NK_TEST {
                    test_counter++
                    @append(test_ids, test_counter)
                    gen_test_fn(ctx, node.d0 as ref parser.Node, test_counter)
                }
            }
            none => {}
        }
        ri2++
    }

    gen_test_main(ctx, test_ids)
    emit_string_data(ctx)

    val mono_built: ref void = str.StringBuilder.build(ctx.mono_sb)
    val mono_str: ref u8 = str.cstr(mono_built)
    str.StringBuilder.append_cstr(cg_sb(ctx), mono_str)
    str.StringBuilder.free(ctx.mono_sb)

    val built: ref void = str.StringBuilder.build(cg_sb(ctx))
    val result: ref u8 = str.cstr(built)
    str.StringBuilder.free(cg_sb(ctx))
    return result
}

/// Like gen_items_with_prefix but skips NK_LINK directives.
/// Used to emit module code without pulling in external libraries.
fn gen_items_with_prefix_skip_links(ctx: ref CgCtx, items: list[ref parser.Node], mod_prefix: ref u8) void! = {
    preregister_items(ctx, items, mod_prefix)
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_LINK {
                    // Skip link directive to avoid pulling in external library
                } elif k == parser.NK_GENERIC_FN {
                    register_generic_fn(ctx, node.d2 as ref u8, node, mod_prefix)
                } elif k == parser.NK_FN {
                    gen_fn_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_EXTERN_FN {
                    gen_extern_fn_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_ENUMDEF {
                    gen_enum_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_UNIONDEF {
                    gen_union_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_TAGGED_UNIONDEF {
                    gen_tagged_union_def(ctx, node, mod_prefix)
                } elif k == parser.NK_TYPEDEF {
                    val tname: ref u8 = node.d1 as ref u8
                    val tfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, tname, tfields)
                    if node.d3 != 0 as i64 { cg_register_invariant(ctx, tname, node.d3 as ref void) }
                } elif k == parser.NK_EXTERN_TYPE {
                    val etname: ref u8 = node.d1 as ref u8
                    val etfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, etname, etfields)
                } elif k == parser.NK_WHEN_ITEMS {
                    val plat: ref u8 = node.d0 as ref u8
                    if cg_platform_matches(ctx, plat) {
                        val witems: list[ref parser.Node] = node.d1 as list[ref parser.Node]
                        gen_items_with_prefix_skip_links(ctx, witems, mod_prefix)
                    }
                } elif k == parser.NK_VAL {
                    emit_global_val(ctx, mod_prefix, node)
                } elif k == parser.NK_CONST {
                    val cname: ref u8 = node.d1 as ref u8
                    val cexpr: ref parser.Node = node.d2 as ref parser.Node
                    if cexpr != 0 as ref parser.Node {
                        val const_label: ref u8 = @alloc(512) as ref u8
                        if str.rchar_cmp(mod_prefix, "") == 0 {
                            @snprintf(const_label, 512, "{s}", {cname})
                        } else {
                            @snprintf(const_label, 512, "{s}__{s}", {mod_prefix, cname})
                        }

                        if cexpr.kind == parser.NK_INT_LIT {
                            val cval: ref u8 = parser.int_lit_text(cexpr)
                            cg_register_module_const(ctx, cname, cval)
                            if cg_emit_label_if_new(ctx, const_label) {
                                val data_buf: ref u8 = @alloc(256) as ref u8
                                @snprintf(data_buf, 256, "data ${s} = \{ l {s} \}\n", {const_label, cval})
                                emit(ctx, data_buf)
                                @free(data_buf)
                            } else {
                                @free(const_label)
                            }
                        } elif cexpr.kind == parser.NK_FLOAT_LIT {
                            val ftext: ref u8 = parser.float_lit_text(cexpr)
                            val fval: ref u8 = @alloc(128) as ref u8
                            @snprintf(fval, 128, "d_{s}", {ftext})
                            cg_register_module_const(ctx, cname, fval)
                            @free(const_label)
                        } elif cexpr.kind == parser.NK_UNOP {
                            val uop: i64 = parser.unop_op(cexpr)
                            val inner: ref parser.Node = parser.unop_inner(cexpr)
                            if inner != 0 as ref parser.Node {
                                if uop == parser.UOP_NEG {
                                    if inner.kind == parser.NK_INT_LIT {
                                        val itext: ref u8 = parser.int_lit_text(inner)
                                        val ival: ref u8 = @alloc(128) as ref u8
                                        @snprintf(ival, 128, "-{s}", {itext})
                                        cg_register_module_const(ctx, cname, ival)
                                        if cg_emit_label_if_new(ctx, const_label) {
                                            val data_buf2: ref u8 = @alloc(256) as ref u8
                                            @snprintf(data_buf2, 256, "data ${s} = \{ l {s} \}\n", {const_label, ival})
                                            emit(ctx, data_buf2)
                                            @free(data_buf2)
                                        } else {
                                            @free(const_label)
                                        }
                                    } elif inner.kind == parser.NK_FLOAT_LIT {
                                        val ftext2: ref u8 = parser.float_lit_text(inner)
                                        val fval2: ref u8 = @alloc(128) as ref u8
                                        @snprintf(fval2, 128, "d_-{s}", {ftext2})
                                        cg_register_module_const(ctx, cname, fval2)
                                        @free(const_label)
                                    } else {
                                        @free(const_label)
                                    }
                                } else {
                                    @free(const_label)
                                }
                            } else {
                                @free(const_label)
                            }
                        } elif cexpr.kind == parser.NK_BOOL {
                            val bval: i64 = cexpr.d0 as i64
                            val bstr: mut ref u8 = "0"
                            if bval != 0 {
                                cg_register_module_const(ctx, cname, "1")
                                bstr = "1"
                            } else {
                                cg_register_module_const(ctx, cname, "0")
                            }
                            if cg_emit_label_if_new(ctx, const_label) {
                                val data_buf3: ref u8 = @alloc(256) as ref u8
                                @snprintf(data_buf3, 256, "data ${s} = \{ w {s} \}\n", {const_label, bstr})
                                emit(ctx, data_buf3)
                                @free(data_buf3)
                            } else {
                                @free(const_label)
                            }
                        } elif cexpr.kind == parser.NK_LIST_LIT {
                            if cg_emit_label_if_new(ctx, const_label) {
                                emit_global_list_literal(ctx, const_label, cexpr)
                                cg_register_global(ctx, cname, const_label, "l", "")
                            } else {
                                @free(const_label)
                            }
                        } else {
                            @free(const_label)
                        }
                    }
                }
            }
            none => {}
        }
        i++
    }
}

/// Kinda like gen_items_with_prefix but skips NK_FN named "main" and handles NK_TEST.
fn gen_items_with_prefix_skip_main(ctx: ref CgCtx, items: list[ref parser.Node], mod_prefix: ref u8) void! = {
    preregister_items(ctx, items, mod_prefix)
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_GENERIC_FN {
                    register_generic_fn(ctx, node.d2 as ref u8, node, mod_prefix)
                } elif k == parser.NK_FN {
                    val fname: ref u8 = node.d2 as ref u8
                    if str.rchar_cmp(fname, "main") != 0 {
                        gen_fn_prefixed(ctx, node, mod_prefix)
                    }
                } elif k == parser.NK_EXTERN_FN {
                    gen_extern_fn_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_ENUMDEF {
                    gen_enum_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_UNIONDEF {
                    gen_union_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_TAGGED_UNIONDEF {
                    gen_tagged_union_def(ctx, node, mod_prefix)
                } elif k == parser.NK_TYPEDEF {
                    val tname: ref u8 = node.d1 as ref u8
                    val tfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, tname, tfields)
                    if node.d3 != 0 as i64 { cg_register_invariant(ctx, tname, node.d3 as ref void) }
                } elif k == parser.NK_EXTERN_TYPE {
                    val etname: ref u8 = node.d1 as ref u8
                    val etfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, etname, etfields)
                } elif k == parser.NK_WHEN_ITEMS {
                    val plat: ref u8 = node.d0 as ref u8
                    if cg_platform_matches(ctx, plat) {
                        val witems: list[ref parser.Node] = node.d1 as list[ref parser.Node]
                        gen_items_with_prefix_skip_main(ctx, witems, mod_prefix)
                    } else {
                        val or_when_branches4: ref void = node.d2 as ref void
                        val matched4: mut bool = false
                        if or_when_branches4 != 0 as ref void {
                            for ow4 in or_when_branches4 as list[ref parser.Node] {
                                if !matched4 {
                                    val ow_plat4: ref u8 = ow4.d0 as ref u8
                                    if cg_platform_matches(ctx, ow_plat4) {
                                        val ow_items4: list[ref parser.Node] = ow4.d1 as list[ref parser.Node]
                                        gen_items_with_prefix_skip_main(ctx, ow_items4, mod_prefix)
                                        matched4 = true
                                    }
                                }
                            }
                        }
                        if !matched4 {
                            val ow_otherwise4: ref void = node.d3 as ref void
                            if ow_otherwise4 != 0 as ref void {
                                val ow_oi4: list[ref parser.Node] = ow_otherwise4 as list[ref parser.Node]
                                gen_items_with_prefix_skip_main(ctx, ow_oi4, mod_prefix)
                            }
                        }
                    }
                } elif k == parser.NK_CONST {
                    val cname: ref u8 = node.d1 as ref u8
                    val cexpr: ref parser.Node = node.d2 as ref parser.Node
                    if cexpr != 0 as ref parser.Node {
                        if cexpr.kind == parser.NK_INT_LIT {
                            cg_register_module_const(ctx, cname, parser.int_lit_text(cexpr))
                        } elif cexpr.kind == parser.NK_FLOAT_LIT {
                            val ftext3: ref u8 = parser.float_lit_text(cexpr)
                            val fval3: ref u8 = @alloc(128) as ref u8
                            @snprintf(fval3, 128, "d_{s}", {ftext3})
                            cg_register_module_const(ctx, cname, fval3)
                        } elif cexpr.kind == parser.NK_UNOP {
                            val uop2: i64 = parser.unop_op(cexpr)
                            val inner2: ref parser.Node = parser.unop_inner(cexpr)
                            if inner2 != 0 as ref parser.Node {
                                if uop2 == parser.UOP_NEG {
                                    if inner2.kind == parser.NK_INT_LIT {
                                        val itext2: ref u8 = parser.int_lit_text(inner2)
                                        val ival2: ref u8 = @alloc(128) as ref u8
                                        @snprintf(ival2, 128, "-{s}", {itext2})
                                        cg_register_module_const(ctx, cname, ival2)
                                    } elif inner2.kind == parser.NK_FLOAT_LIT {
                                        val ftext4: ref u8 = parser.float_lit_text(inner2)
                                        val fval4: ref u8 = @alloc(128) as ref u8
                                        @snprintf(fval4, 128, "d_-{s}", {ftext4})
                                        cg_register_module_const(ctx, cname, fval4)
                                    }
                                }
                            }
                        } elif cexpr.kind == parser.NK_BOOL {
                            val bval2: i64 = cexpr.d0 as i64
                            if bval2 != 0 {
                                cg_register_module_const(ctx, cname, "1")
                            } else {
                                cg_register_module_const(ctx, cname, "0")
                            }
                        } elif cexpr.kind == parser.NK_LIST_LIT {
                            val const_label2: ref u8 = @alloc(512) as ref u8
                            if str.rchar_cmp(mod_prefix, "") == 0 {
                                @snprintf(const_label2, 512, "{s}", {cname})
                            } else {
                                @snprintf(const_label2, 512, "{s}__{s}", {mod_prefix, cname})
                            }
                            if cg_emit_label_if_new(ctx, const_label2) {
                                emit_global_list_literal(ctx, const_label2, cexpr)
                                cg_register_global(ctx, cname, const_label2, "l", "")
                            } else {
                                @free(const_label2)
                            }
                        }
                    }
                } elif k == parser.NK_VAL {
                    emit_global_val(ctx, mod_prefix, node)
                }
            }
            none => {}
        }
        i++
    }
}

// Main entry: generate QBE IR for a module (single-file, no imports).
pub fn gen_module(items: list[ref parser.Node]) ref u8! = {
    val ctx: ref CgCtx = cg_new()

    emit_runtime_helpers(ctx)
    preregister_items(ctx, items, "")

    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0

    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val k: i64 = (item as ref parser.Node).kind
                if k == parser.NK_GENERIC_FN {
                    register_generic_fn(ctx, (item as ref parser.Node).d2 as ref u8, item as ref parser.Node, "")
                } elif k == parser.NK_FN {
                    gen_fn_prefixed(ctx, item as ref parser.Node, "")
                } elif k == parser.NK_EXTERN_FN {
                    gen_extern_fn(ctx, item as ref parser.Node)
                } elif k == parser.NK_ENUMDEF {
                    gen_enum_def_prefixed(ctx, item as ref parser.Node, "")
                } elif k == parser.NK_TYPEDEF {
                    // Already registered during preregister, but emit type info
                } elif k == parser.NK_EXTERN_TYPE {
                    // Already registered during preregister
                } elif k == parser.NK_UNIONDEF {
                    gen_union_def_prefixed(ctx, item as ref parser.Node, "")
                } elif k == parser.NK_TAGGED_UNIONDEF {
                    gen_tagged_union_def(ctx, item as ref parser.Node, "")
                }
            }
            none => {}
        }
        i++
    }

    emit_string_data(ctx)

    val mono_built: ref void = str.StringBuilder.build(ctx.mono_sb)
    val mono_str: ref u8 = str.cstr(mono_built)
    str.StringBuilder.append_cstr(cg_sb(ctx), mono_str)
    str.StringBuilder.free(ctx.mono_sb)

    val built: ref void = str.StringBuilder.build(cg_sb(ctx))
    val result: ref u8 = str.cstr(built)
    str.StringBuilder.free(cg_sb(ctx))
    return result
}
