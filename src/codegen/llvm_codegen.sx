                val fp_opt = @get(args, 1)
                match fp_opt {
                    some fp_node => {
                        val fpn: ref parser.Node = fp_node as ref parser.Node
                        if fpn.kind == parser.NK_ARGS_PACK {
                            val fpack: ref void = fpn.d0 as ref void
                            val fplen: i64 = @len(fpack) as i64
                            val fpi: mut i64 = 0
                            for {
                                if fpi >= fplen { break }
                                val fpe_opt = @get(fpack, fpi as usize)
                                match fpe_opt {
                                    some fpe => {
                                        val fpe_node: ref parser.Node = fpe as ref parser.Node
                                        val fv_raw: ref char = gen_expr(ctx, fpe_node)
                                        val fabi: ref char = ll_variadic_abi_type(ctx, fpe_node)
                                        val fv: ref char = ll_coerce_arg_to_abi(ctx, fpe_node, fv_raw, fabi)
                                        val fb2: ref char = @alloc(64) as ref char
                                        @snprintf(fb2, 64, ", {s} {s}", {fabi, fv})
                                        str.StringBuilder.append_cstr(call_sb, fb2)
                                        @free(fb2)
                                    }
                                    none => {}
                                }
                                fpi++
                            }
                        }
                    }
                    none => {}
                }
            }
        }
        str.StringBuilder.append_cstr(call_sb, ")\n")
        emit(ctx, str.cstr(str.StringBuilder.build(call_sb)))
        str.StringBuilder.free(call_sb)
        tmp = alloc_tmp
    } else {
        val buf: ref char = @alloc(64) as ref char
        @snprintf(buf, 64, "  %%t{lld} = add i64 0, 0\n", {tmp})
        emit(ctx, buf)
        @free(buf)
    }
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn get_arg_node(args: ref void, i: i64) ref parser.Node! = {
    if args == 0 as ref void { return 0 as ref parser.Node }
    val opt = @get(args, i as usize)
    match opt {
        some a => { return a as ref parser.Node }
        none => { return 0 as ref parser.Node }
    }
}

fn rewrite_fmt(s: ref char) ref char! = {
    val slen: i64 = str.len_raw(s)
    val out: ref char = @alloc(slen * 2 + 1) as ref char
    val oi: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= slen { break }
        val c: u8 = @load8(@ptradd(s as ref void, i))

        if c == 92 {
            if i + 1 < slen {
                val next: u8 = @load8(@ptradd(s as ref void, i + 1))
                if next == 123 || next == 125 {
                    @store8(@ptradd(out as ref void, oi), next)
                    oi++
                    i += 2
                } else {
                    @store8(@ptradd(out as ref void, oi), c)
                    oi++
                    i++
                }
            } else {
                @store8(@ptradd(out as ref void, oi), c)
                oi++
                i++
            }
        } elif c == 123 {
            val j: mut i64 = i + 1
            val found: mut bool = false
            for {
                if j >= slen { break }
                val ic: u8 = @load8(@ptradd(s as ref void, j))
                if ic == 125 { found = true break }
                j++
            }
            if found {
                @store8(@ptradd(out as ref void, oi), 37)
                oi++
                val k: mut i64 = i + 1
                for {
                    if k >= j { break }
                    val sc: u8 = @load8(@ptradd(s as ref void, k))
                    @store8(@ptradd(out as ref void, oi), sc)
                    oi++
                    k++
                }
                i = j + 1
            } else {
                @store8(@ptradd(out as ref void, oi), c)
                oi++
                i++
            }
        } else {
            @store8(@ptradd(out as ref void, oi), c)
            oi++
            i++
        }
    }
    @store8(@ptradd(out as ref void, oi), 0)
    return out
}

fn intern_format_string(ctx: ref LLCtx, s: ref char) i64! = {
    return intern_string(ctx, rewrite_fmt(s))
}

fn ll_lookup_tagged_call_variant(ctx: ref LLCtx, callee_name: ref char, tv_owner_slot: ref void, tv_field_slot: ref void) i64! = {
    @store(tv_owner_slot, 0)
    @store(tv_field_slot, 0)
    val tv_tag: mut i64 = ll_lookup_tv(ctx, callee_name, tv_owner_slot, tv_field_slot)
    if tv_tag < 0 {
        val sep_pos: mut i64 = -1
        val scan_i: mut i64 = 0
        for {
            val sc: u8 = @load8(@ptradd(callee_name as ref void, scan_i))
            if sc == 0 { break }
            val sc2: u8 = @load8(@ptradd(callee_name as ref void, scan_i + 1))
            if sc == 95 && sc2 == 95 { sep_pos = scan_i }
            scan_i++
        }
        if sep_pos >= 0 {
            val bare_name: ref char = @ptradd(callee_name as ref void, sep_pos + 2) as ref char
            @store(tv_owner_slot, 0)
            @store(tv_field_slot, 0)
            tv_tag = ll_lookup_tv(ctx, bare_name, tv_owner_slot, tv_field_slot)
        }
    }
    return tv_tag
}

fn gen_call_tv_variant(ctx: ref LLCtx, args_list: ref void, tv_tag: i64, field_ty_list: ref void) ref char! = {
    ensure_declared(ctx, "malloc", "declare ptr @malloc(i64)")
    val n_args: mut i64 = 0
    if args_list != 0 as ref void { n_args = @len(args_list) as i64 }
    val payload_size: mut i64 = 0
    if field_ty_list != 0 as ref void {
        val ftlen: i64 = @len(field_ty_list as list[ref parser.Node]) as i64
        val fti: mut i64 = 0
        for {
            if fti >= ftlen { break }
            val ft_opt = @get(field_ty_list as list[ref parser.Node], fti as usize)
            match ft_opt {
                some ft => {
                    val ft_node: ref parser.Node = ft as ref parser.Node
                    val fsize: i64 = ll_type_size(ctx, ft_node)
                    if fsize == 0 { payload_size = payload_size + 8 }
                    else { payload_size = payload_size + ll_aligned_size(fsize) }
                }
                none => { payload_size = payload_size + 8 }
            }
            fti++
        }
    } else {
        payload_size = n_args * 8
    }
    val alloc_size: i64 = 8 + payload_size
    val actual_alloc_size: mut i64 = alloc_size
    if actual_alloc_size < 16 { actual_alloc_size = 16 }
    val ptr: i64 = fresh_tmp(ctx)
    val pbuf: ref char = @alloc(96) as ref char
    @snprintf(pbuf, 96, "  %%t{lld} = call ptr @malloc(i64 {lld})\n  store i64 {lld}, ptr %%t{lld}\n",
        {ptr, actual_alloc_size, tv_tag, ptr})
    emit(ctx, pbuf)
    @free(pbuf)
    if args_list != 0 as ref void {
        val flen: i64 = @len(args_list) as i64
        val fi: mut i64 = 0
        val offset: mut i64 = 8
        for {
            if fi >= flen { break }
            val fa_opt = @get(args_list, fi as usize)
            match fa_opt {
                some fa => {
                    val fa_node: ref parser.Node = fa as ref parser.Node
                    val field_val_raw: ref char = gen_expr(ctx, fa_node)
                    val field_ty: mut ref parser.Node = 0 as ref parser.Node
                    if field_ty_list != 0 as ref void {
                        val ft_opt = @get(field_ty_list as list[ref parser.Node], fi as usize)
                        match ft_opt {
                            some ft => { field_ty = ft as ref parser.Node }
                            none => {}
                        }
                    }
                    val field_val: ref char = ll_coerce_value_for_type(ctx, fa_node, field_ty, field_val_raw)
                    val fptr: i64 = fresh_tmp(ctx)
                    val fbuf: ref char = @alloc(128) as ref char
                    @snprintf(fbuf, 128, "  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 {lld}\n", {fptr, ptr, offset})
                    emit(ctx, fbuf)
                    @free(fbuf)
                    val fptr_name: ref char = @alloc(16) as ref char
                    @snprintf(fptr_name, 16, "%%t{lld}", {fptr})
                    ll_emit_store_value(ctx, fptr_name, field_ty, field_val)
                    if field_ty_list != 0 as ref void && field_ty != 0 as ref parser.Node {
                        offset = offset + ll_aligned_size(ll_type_size(ctx, field_ty))
                    } else {
                        offset = offset + 8
                    }
                }
                none => {}
            }
            fi++
        }
    }
    val tv_res: ref char = @alloc(16) as ref char
    @snprintf(tv_res, 16, "%%t{lld}", {ptr})
    return tv_res
}

fn gen_call_print_builtin(ctx: ref LLCtx, args_list: ref void) ref char! = {
    if args_list == 0 as ref void { return 0 as ref char }
    val alen_p: i64 = @len(args_list) as i64
    if alen_p <= 0 { return 0 as ref char }
    val first_arg_opt = @get(args_list, 0)
    match first_arg_opt {
        some first_arg => {
            val first_node: ref parser.Node = first_arg as ref parser.Node
            if first_node.kind != parser.NK_STR_LIT { return 0 as ref char }
            ensure_declared(ctx, "printf", "declare i32 @printf(ptr, ...)")
            val fmt_str: ref char = parser.str_lit_text(first_node)
            val fmt_idx: i64 = intern_format_string(ctx, fmt_str)
            val slen: i64 = str.len_raw(rewrite_fmt(fmt_str)) + 1
            val fmt_tmp: i64 = fresh_tmp(ctx)
            val fmt_buf: ref char = @alloc(128) as ref char
            @snprintf(fmt_buf, 128, "  %%t{lld} = getelementptr [{lld} x i8], ptr @__str{lld}, i64 0, i64 0\n", {fmt_tmp, slen, fmt_idx})
            emit(ctx, fmt_buf)
            @free(fmt_buf)

            val call_sb: ref void = str.StringBuilder.new()
            val result_tmp: i64 = fresh_tmp(ctx)
            val hdr: ref char = @alloc(256) as ref char
            @snprintf(hdr, 256, "  %%t{lld} = call i32 (ptr, ...) @printf(ptr %%t{lld}", {result_tmp, fmt_tmp})
            str.StringBuilder.append_cstr(call_sb, hdr)
            @free(hdr)

            val ai_p: mut i64 = 1
            for {
                if ai_p >= alen_p { break }
                val arg_opt_p = @get(args_list, ai_p as usize)
                match arg_opt_p {
                    some arg_p => {
                        val arg_node_p: ref parser.Node = arg_p as ref parser.Node
                        if arg_node_p.kind == parser.NK_ARGS_PACK {
                            val pack_p: ref void = arg_node_p.d0 as ref void
                            val plen_p: i64 = @len(pack_p) as i64
                            val pi_p: mut i64 = 0
                            for {
                                if pi_p >= plen_p { break }
                                val pe_opt_p = @get(pack_p, pi_p as usize)
                                match pe_opt_p {
                                    some pe_p => {
                                        val pe_node_p: ref parser.Node = pe_p as ref parser.Node
                                        val pv: ref char = gen_expr(ctx, pe_node_p)
                                        val ab: ref char = @alloc(64) as ref char
                                        @snprintf(ab, 64, ", {s} {s}", {ll_variadic_abi_type(ctx, pe_node_p), pv})
                                        str.StringBuilder.append_cstr(call_sb, ab)
                                        @free(ab)
                                    }
                                    none => {}
                                }
                                pi_p++
                            }
                        } else {
                            val pv2: ref char = gen_expr(ctx, arg_node_p)
                            val ab2: ref char = @alloc(64) as ref char
                            @snprintf(ab2, 64, ", {s} {s}", {ll_variadic_abi_type(ctx, arg_node_p), pv2})
                            str.StringBuilder.append_cstr(call_sb, ab2)
                            @free(ab2)
                        }
                    }
                    none => {}
                }
                ai_p++
            }

            str.StringBuilder.append_cstr(call_sb, ")\n")
            emit(ctx, str.cstr(str.StringBuilder.build(call_sb)))
            str.StringBuilder.free(call_sb)

            val widened_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref char = @alloc(128) as ref char
            @snprintf(ext_buf, 128, "  %%t{lld} = sext i32 %%t{lld} to i64\n", {widened_tmp, result_tmp})
            emit(ctx, ext_buf)
            @free(ext_buf)

            val res_p: ref char = @alloc(16) as ref char
            @snprintf(res_p, 16, "%%t{lld}", {widened_tmp})
            return res_p
        }
        none => { return 0 as ref char }
    }
}

fn gen_call_eprint_builtin(ctx: ref LLCtx, args_list: ref void) ref char! = {
    if args_list == 0 as ref void { return 0 as ref char }
    val alen_p: i64 = @len(args_list) as i64
    if alen_p <= 0 { return 0 as ref char }
    val first_arg_opt = @get(args_list, 0)
    match first_arg_opt {
        some first_arg => {
            val first_node: ref parser.Node = first_arg as ref parser.Node
            if first_node.kind != parser.NK_STR_LIT { return 0 as ref char }
            ensure_declared(ctx, "dprintf", "declare i32 @dprintf(i32, ptr, ...)")
            val fmt_str: ref char = parser.str_lit_text(first_node)
            val fmt_idx: i64 = intern_format_string(ctx, fmt_str)
            val slen: i64 = str.len_raw(rewrite_fmt(fmt_str)) + 1
            val fd_tmp: i64 = fresh_tmp(ctx)
            val fmt_tmp: i64 = fresh_tmp(ctx)
            val fmt_buf: ref char = @alloc(192) as ref char
            @snprintf(fmt_buf, 192,
                "  %%t{lld} = trunc i64 2 to i32\n  %%t{lld} = getelementptr [{lld} x i8], ptr @__str{lld}, i64 0, i64 0\n",
                {fd_tmp, fmt_tmp, slen, fmt_idx})
            emit(ctx, fmt_buf)
            @free(fmt_buf)

            val call_sb: ref void = str.StringBuilder.new()
            val result_tmp: i64 = fresh_tmp(ctx)
            val hdr: ref char = @alloc(256) as ref char
            @snprintf(hdr, 256, "  %%t{lld} = call i32 (i32, ptr, ...) @dprintf(i32 %%t{lld}, ptr %%t{lld}", {result_tmp, fd_tmp, fmt_tmp})
            str.StringBuilder.append_cstr(call_sb, hdr)
            @free(hdr)

            val ai_p: mut i64 = 1
            for {
                if ai_p >= alen_p { break }
                val arg_opt_p = @get(args_list, ai_p as usize)
                match arg_opt_p {
                    some arg_p => {
                        val arg_node_p: ref parser.Node = arg_p as ref parser.Node
                        if arg_node_p.kind == parser.NK_ARGS_PACK {
                            val pack_p: ref void = arg_node_p.d0 as ref void
                            val plen_p: i64 = @len(pack_p) as i64
                            val pi_p: mut i64 = 0
                            for {
                                if pi_p >= plen_p { break }
                                val pe_opt_p = @get(pack_p, pi_p as usize)
                                match pe_opt_p {
                                    some pe_p => {
                                        val pe_node_p: ref parser.Node = pe_p as ref parser.Node
                                        val pv: ref char = gen_expr(ctx, pe_node_p)
                                        val ab: ref char = @alloc(64) as ref char
                                        @snprintf(ab, 64, ", {s} {s}", {ll_variadic_abi_type(ctx, pe_node_p), pv})
                                        str.StringBuilder.append_cstr(call_sb, ab)
                                        @free(ab)
                                    }
                                    none => {}
                                }
                                pi_p++
                            }
                        } else {
                            val pv2: ref char = gen_expr(ctx, arg_node_p)
                            val ab2: ref char = @alloc(64) as ref char
                            @snprintf(ab2, 64, ", {s} {s}", {ll_variadic_abi_type(ctx, arg_node_p), pv2})
                            str.StringBuilder.append_cstr(call_sb, ab2)
                            @free(ab2)
                        }
                    }
                    none => {}
                }
                ai_p++
            }

            str.StringBuilder.append_cstr(call_sb, ")\n")
            emit(ctx, str.cstr(str.StringBuilder.build(call_sb)))
            str.StringBuilder.free(call_sb)

            val widened_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref char = @alloc(128) as ref char
            @snprintf(ext_buf, 128, "  %%t{lld} = sext i32 %%t{lld} to i64\n", {widened_tmp, result_tmp})
            emit(ctx, ext_buf)
            @free(ext_buf)

            val res_p: ref char = @alloc(16) as ref char
            @snprintf(res_p, 16, "%%t{lld}", {widened_tmp})
            return res_p
        }
        none => { return 0 as ref char }
    }
}

fn gen_call_read_line_builtin(ctx: ref LLCtx, args_list: ref void) ref char! = {
    if args_list == 0 as ref void { return 0 as ref char }
    ensure_declared(ctx, "fgets", "declare ptr @fgets(ptr, i32, ptr)")
    ensure_declared(ctx, "stdin", "@stdin = external global ptr")
    val buf_node: ref parser.Node = get_arg_node(args_list, 0)
    val len_node: ref parser.Node = get_arg_node(args_list, 1)
    val buf_arg: ref char = gen_expr(ctx, buf_node)
    val len_arg: ref char = gen_expr(ctx, len_node)
    val len32: i64 = fresh_tmp(ctx)
    val stdin_tmp: i64 = fresh_tmp(ctx)
    val call_tmp: i64 = fresh_tmp(ctx)
    val ibuf: ref char = @alloc(256) as ref char
    @snprintf(ibuf, 256, "  %%t{lld} = trunc i64 {s} to i32\n  %%t{lld} = load ptr, ptr @stdin\n  %%t{lld} = call ptr @fgets(ptr {s}, i32 %%t{lld}, ptr %%t{lld})\n", {len32, len_arg, stdin_tmp, call_tmp, buf_arg, len32, stdin_tmp})
    emit(ctx, ibuf)
    @free(ibuf)
    val res_rl: ref char = @alloc(16) as ref char
    @snprintf(res_rl, 16, "%%t{lld}", {call_tmp})
    return res_rl
}

fn gen_call_read_key_builtin(ctx: ref LLCtx) ref char! = {
    ensure_declared(ctx, "getchar", "declare i32 @getchar()")
    val key32: i64 = fresh_tmp(ctx)
    val key64: i64 = fresh_tmp(ctx)
    val kbuf: ref char = @alloc(128) as ref char
    @snprintf(kbuf, 128, "  %%t{lld} = call i32 @getchar()\n  %%t{lld} = sext i32 %%t{lld} to i64\n", {key32, key64, key32})
    emit(ctx, kbuf)
    @free(kbuf)
    val res_rk: ref char = @alloc(16) as ref char
    @snprintf(res_rk, 16, "%%t{lld}", {key64})
    return res_rk
}

fn gen_call_collect_args(ctx: ref LLCtx, args_list: ref void, arg_tmps: mut list[ref char], arg_nodes: mut list[ref parser.Node]) void! = {
    if args_list == 0 as ref void { return }
    val alen: i64 = @len(args_list) as i64
    val ai: mut i64 = 0
    for {
        if ai >= alen { break }
        val arg_opt = @get(args_list, ai as usize)
        match arg_opt {
            some arg => {
                val an: ref parser.Node = arg as ref parser.Node
                if an.kind == parser.NK_ARGS_PACK {
                    val pack: ref void = an.d0 as ref void
                    val plen: i64 = @len(pack) as i64
                    val pi: mut i64 = 0
                    for {
                        if pi >= plen { break }
                        val pe_opt = @get(pack, pi as usize)
                        match pe_opt {
                            some pe => {
                                @append(arg_tmps, gen_expr(ctx, pe as ref parser.Node))
                                @append(arg_nodes, pe as ref parser.Node)
                            }
                            none => {}
                        }
                        pi++
                    }
                } else {
                    @append(arg_tmps, gen_expr(ctx, an))
                    @append(arg_nodes, an)
                }
            }
            none => {}
        }
        ai++
    }
}

fn gen_call_resolve_target(ctx: ref LLCtx, callee_node: ref parser.Node, callee_name: ref char, callee_ty: ref parser.Node, is_fnptr_call: bool, callee_operand_slot: ref void, param_types_slot: ref void, ret_ty_slot: ref void) void! = {
    @store(callee_operand_slot, "" as ref void)
    @store(param_types_slot, 0)
    @store(ret_ty_slot, 0)
    if is_fnptr_call {
        @store(callee_operand_slot, gen_expr(ctx, callee_node) as ref void)
        @store(param_types_slot, callee_ty.d0 as ref void)
        @store(ret_ty_slot, callee_ty.d1 as ref void)
        return
    }
    val resolved: ref char = ll_resolve_fn_name(ctx, callee_name)
    val ext_sym: ref char = ll_lookup_extern_symbol(ctx, callee_name)
    val effective: mut ref char = callee_name
    if resolved != 0 as ref char { effective = resolved }
    elif ext_sym != 0 as ref char { effective = ext_sym }
    @store(callee_operand_slot, effective as ref void)
    @store(param_types_slot, ll_lookup_fn_params(ctx, effective))
    @store(ret_ty_slot, ll_lookup_fn_ret(ctx, effective) as ref void)
}

fn gen_call_append_header(call_sb: ref void, tmp: i64, call_ret_abi: ref char, callee_value: ref char, is_fnptr_call: bool) void! = {
    val tmp_buf: ref char = @alloc(32) as ref char
    @snprintf(tmp_buf, 32, "%%t{lld}", {tmp})
    str.StringBuilder.append_cstr(call_sb, "  ")
    if str.rchar_cmp(call_ret_abi, "void") != 0 {
        str.StringBuilder.append_cstr(call_sb, tmp_buf)
        str.StringBuilder.append_cstr(call_sb, " = ")
    }
    str.StringBuilder.append_cstr(call_sb, "call ")
    str.StringBuilder.append_cstr(call_sb, call_ret_abi)
    str.StringBuilder.append_char(call_sb, 32)
    if !is_fnptr_call { str.StringBuilder.append_char(call_sb, 64) }
    str.StringBuilder.append_cstr(call_sb, callee_value)
    str.StringBuilder.append_char(call_sb, 40)
    @free(tmp_buf)
}

fn gen_call_append_args(ctx: ref LLCtx, call_sb: ref void, arg_tmps: list[ref char], arg_nodes: list[ref parser.Node], param_types: ref void, is_fnptr_call: bool) void! = {
    val tlen: i64 = @len(arg_tmps) as i64
    val ti: mut i64 = 0
    for {
        if ti >= tlen { break }
        val t_opt = @get(arg_tmps, ti as usize)
        match t_opt {
            some t => {
                if ti > 0 { str.StringBuilder.append_cstr(call_sb, ", ") }
                val abi_ty: mut ref char = "i64"
                val arg_val: mut ref char = t as ref char
                if param_types != 0 as ref void {
                    val p_opt = @get(param_types, ti as usize)
                    match p_opt {
                        some p => {
                            val pty: mut ref parser.Node = 0 as ref parser.Node
                            if is_fnptr_call {
                                pty = p as ref parser.Node
                            } else {
                                pty = (p as ref parser.Node).d1 as ref parser.Node
                            }
                            abi_ty = ll_param_abi_type(ctx, pty)
                            if ll_is_union_type(ctx, pty) {
                                val union_variants: ref void = ll_lookup_union_suffix(ctx, ll_unwrap_named_type(pty))
                                val n_wrap_opt = @get(arg_nodes, ti as usize)
                                match n_wrap_opt {
                                    some n_wrap => {
                                        val arg_ty: ref parser.Node = ll_expr_storage_type(ctx, n_wrap as ref parser.Node)
                                        if !ll_is_union_type(ctx, arg_ty) {
                                            arg_val = ll_wrap_union_arg(ctx, n_wrap as ref parser.Node, union_variants, arg_val)
                                        }
                                    }
                                    none => {
                                        arg_val = ll_wrap_union_arg(ctx, 0 as ref parser.Node, union_variants, arg_val)
                                    }
                                }
                            }
                        }
                        none => {}
                    }
                }
                val n_opt = @get(arg_nodes, ti as usize)
                match n_opt {
                    some n => { arg_val = ll_coerce_arg_to_abi(ctx, n as ref parser.Node, arg_val, abi_ty) }
                    none => {}
                }
                str.StringBuilder.append_cstr(call_sb, abi_ty)
                str.StringBuilder.append_char(call_sb, 32)
                str.StringBuilder.append_cstr(call_sb, arg_val)
            }
            none => {}
        }
        ti++
    }
}

fn gen_call_finish_result(ctx: ref LLCtx, tmp: i64, call_ret_abi: ref char) ref char! = {
    if str.rchar_cmp(call_ret_abi, "void") == 0 {
        val zbuf: ref char = @alloc(64) as ref char
        @snprintf(zbuf, 64, "  %%t{lld} = add i64 0, 0\n", {tmp})
        emit(ctx, zbuf)
        @free(zbuf)
        val zres: ref char = @alloc(16) as ref char
        @snprintf(zres, 16, "%%t{lld}", {tmp})
        return zres
    }
    if str.rchar_cmp(call_ret_abi, "i32") == 0 {
        val ext: i64 = fresh_tmp(ctx)
        val ebuf: ref char = @alloc(128) as ref char
        @snprintf(ebuf, 128, "  %%t{lld} = sext i32 %%t{lld} to i64\n", {ext, tmp})
        emit(ctx, ebuf)
        @free(ebuf)
        val eres: ref char = @alloc(16) as ref char
        @snprintf(eres, 16, "%%t{lld}", {ext})
        return eres
    }
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn gen_call_regular(ctx: ref LLCtx, callee_node: ref parser.Node, callee_name: ref char, callee_ty: ref parser.Node, is_fnptr_call: bool, args_list: ref void) ref char! = {
    val arg_tmps: mut list[ref char] = []
    val arg_nodes: mut list[ref parser.Node] = []
    gen_call_collect_args(ctx, args_list, arg_tmps, arg_nodes)

    val tmp: i64 = fresh_tmp(ctx)
    val callee_value_slot: ref void = @alloc(8)
    val param_types_slot: ref void = @alloc(8)
    val ret_ty_slot: ref void = @alloc(8)
    gen_call_resolve_target(ctx, callee_node, callee_name, callee_ty, is_fnptr_call, callee_value_slot, param_types_slot, ret_ty_slot)
    val callee_value: ref char = @load(callee_value_slot) as ref char
    val param_types: ref void = @load(param_types_slot) as ref void
    val ret_ty_node: ref parser.Node = @load(ret_ty_slot) as ref parser.Node
    val call_ret_abi: ref char = ll_call_ret_abi(ctx, ret_ty_node)

    val call_sb: ref void = str.StringBuilder.new()
    gen_call_append_header(call_sb, tmp, call_ret_abi, callee_value, is_fnptr_call)
    gen_call_append_args(ctx, call_sb, arg_tmps, arg_nodes, param_types, is_fnptr_call)
    str.StringBuilder.append_cstr(call_sb, ")\n")
    emit(ctx, str.cstr(str.StringBuilder.build(call_sb)))
    str.StringBuilder.free(call_sb)
    return gen_call_finish_result(ctx, tmp, call_ret_abi)
}

fn gen_call(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    val callee_node: ref parser.Node = expr.d0 as ref parser.Node
    val args_list: ref void = expr.d1 as ref void
    val callee_name: ref char = resolve_callee_name(callee_node)
    val callee_ty: ref parser.Node = ll_unwrap_mut_type(ll_expr_storage_type(ctx, callee_node))
    val is_fnptr_call: bool = ll_is_fnptr_type(callee_ty)
    val tv_owner_slot: ref void = @alloc(8)
    val tv_field_slot: ref void = @alloc(8)
    val tv_tag: i64 = ll_lookup_tagged_call_variant(ctx, callee_name, tv_owner_slot, tv_field_slot)

    if tv_tag >= 0 {
        return gen_call_tv_variant(ctx, args_list, tv_tag, @load(tv_field_slot) as ref void)
    }
    
    val is_print: bool = str.rchar_cmp(callee_name, "print") == 0
        || str.ends_with(str.from(callee_name), str.from("__print"))
    val is_eprint: bool = str.rchar_cmp(callee_name, "eprint") == 0
        || str.ends_with(str.from(callee_name), str.from("__eprint"))
    if is_print {
        val print_res: ref char = gen_call_print_builtin(ctx, args_list)
        if print_res != 0 as ref char { return print_res }
    }
    if is_eprint {
        val eprint_res: ref char = gen_call_eprint_builtin(ctx, args_list)
        if eprint_res != 0 as ref char { return eprint_res }
    }

    val args_len: mut i64 = @len(args_list) as i64
    if args_list == 0 as ref void { args_len = 0 }

    val is_read_line: bool = str.rchar_cmp(callee_name, "read_line") == 0
        && args_len == 2
    if is_read_line {
        val rl_res: ref char = gen_call_read_line_builtin(ctx, args_list)
        if rl_res != 0 as ref char { return rl_res }
    }

    val is_read_key: bool = str.rchar_cmp(callee_name, "read_key") == 0
        && args_len == 0
    if is_read_key {
        return gen_call_read_key_builtin(ctx)
    }
    return gen_call_regular(ctx, callee_node, callee_name, callee_ty, is_fnptr_call, args_list)
}

fn gen_stmts(ctx: ref LLCtx, stmts: ref parser.Node) void! = {
    if stmts == 0 as ref parser.Node { return }
    val len: i64 = @len(stmts) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(stmts, i as usize)
        match s_opt {
            some s => {
                val snode: ref parser.Node = s as ref parser.Node
                gen_stmt(ctx, snode)
                if snode.kind == parser.NK_WHEN_STMT {
                    if ll_when_stmt_terminated(snode) { break }
                }
            }
            none => {}
        }
        i++
    }
}

fn ll_block_ends_with_terminator(stmts: ref parser.Node) bool! = {
    if stmts == 0 as ref parser.Node { return false }
    val blen: i64 = @len(stmts) as i64
    if blen <= 0 { return false }
    val last_opt = @get(stmts, (blen - 1) as usize)
    match last_opt {
        some last => {
            val k: i64 = (last as ref parser.Node).kind
            return k == parser.NK_RETURN || k == parser.NK_BREAK || k == parser.NK_CONTINUE
        }
        none => { return false }
    }
}

fn ll_when_stmt_terminated(stmt: ref parser.Node) bool! = {
    val plat: ref char = stmt.d0 as ref char
    if platform_matches(plat) {
        return ll_block_ends_with_terminator(stmt.d1 as ref parser.Node)
    }
    val or_when_branches: ref void = stmt.d2 as ref void
    if or_when_branches != 0 as ref void {
        val ow_len: i64 = @len(or_when_branches as list[ref parser.Node]) as i64
        val ow_i: mut i64 = 0
        for {
            if ow_i >= ow_len { break }
            val ow_opt = @get(or_when_branches as list[ref parser.Node], ow_i as usize)
            match ow_opt {
                some ow_val => {
                    val ow_node: ref parser.Node = ow_val as ref parser.Node
                    val ow_plat: ref char = ow_node.d0 as ref char
                    if platform_matches(ow_plat) {
                        return ll_block_ends_with_terminator(ow_node.d1 as ref parser.Node)
                    }
                }
                none => {}
            }
            ow_i++
        }
    }
    val otherwise_stmts: ref void = stmt.d3 as ref void
    if otherwise_stmts != 0 as ref void {
        return ll_block_ends_with_terminator(stmt.d3 as ref parser.Node)
    }
    return false
}

fn gen_stmt(ctx: ref LLCtx, stmt: ref parser.Node) void! = {
    if stmt == 0 as ref parser.Node { return }
    val k: i64 = stmt.kind

    if k == parser.NK_WHEN_STMT {
        val plat: ref char = stmt.d0 as ref char
        if platform_matches(plat) {
            gen_stmts(ctx, stmt.d1 as ref parser.Node)
        } else {
            val or_when_branches: ref void = stmt.d2 as ref void
            val matched: mut bool = false
            if or_when_branches != 0 as ref void {
                val ow_len: i64 = @len(or_when_branches as list[ref parser.Node]) as i64
                val ow_i: mut i64 = 0
                for {
                    if ow_i >= ow_len { break }
                    val ow_opt = @get(or_when_branches as list[ref parser.Node], ow_i as usize)
                    match ow_opt {
                        some ow_val => {
                            if !matched {
                                val ow_node: ref parser.Node = ow_val as ref parser.Node
                                val ow_plat: ref char = ow_node.d0 as ref char
                                if platform_matches(ow_plat) {
                                    gen_stmts(ctx, ow_node.d1 as ref parser.Node)
                                    matched = true
                                }
                            }
                        }
                        none => {}
                    }
                    ow_i++
                }
            }
            if !matched {
                val otherwise_stmts: ref void = stmt.d3 as ref void
                if otherwise_stmts != 0 as ref void {
                    gen_stmts(ctx, stmt.d3 as ref parser.Node)
                }
            }
        }
        return
    }

    if k == parser.NK_EXPR_STMT {
        gen_expr(ctx, stmt.d0 as ref parser.Node)
        return
    }

    if k == parser.NK_GUARD {
        val gcond_node: ref parser.Node = stmt.d0 as ref parser.Node
        val gcond_ty: ref parser.Node = ll_expr_storage_type(ctx, gcond_node)
        val gcond: ref char = gen_expr(ctx, stmt.d0 as ref parser.Node)
        val cmp: i64 = fresh_tmp(ctx)
        val pass_lbl: i64 = fresh_lbl(ctx)
        val fail_lbl: i64 = fresh_lbl(ctx)
        val gbuf: ref char = @alloc(256) as ref char
        if ll_slot_is_ptr(ctx, gcond_ty) {
            @snprintf(gbuf, 256,
                "  %%t{lld} = icmp ne ptr {s}, null\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
                {cmp, gcond, cmp, pass_lbl, fail_lbl, fail_lbl})
        } else {
            @snprintf(gbuf, 256,
                "  %%t{lld} = icmp ne i64 {s}, 0\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
                {cmp, gcond, cmp, pass_lbl, fail_lbl, fail_lbl})
        }
        emit(ctx, gbuf)
        @free(gbuf)
        gen_stmts(ctx, stmt.d1 as ref parser.Node)
        val endbuf: ref char = @alloc(64) as ref char
        if !ll_block_ends_with_terminator(stmt.d1 as ref parser.Node) {
            @snprintf(endbuf, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {pass_lbl, pass_lbl})
        } else {
            @snprintf(endbuf, 64, "lbl{lld}:\n", {pass_lbl})
        }
        emit(ctx, endbuf)
        @free(endbuf)
        return
    }

    if k == parser.NK_RETURN {
        val expr: ref parser.Node = stmt.d0 as ref parser.Node
        if expr == 0 as ref parser.Node {
            ll_emit_defers(ctx)
            if ctx.current_is_main {
                emitln(ctx, "  ret i32 0")
            } elif str.rchar_cmp(ctx.current_ret_abi, "i32") == 0 {
                emitln(ctx, "  ret i32 0")
            } elif str.rchar_cmp(ctx.current_ret_abi, "double") == 0 {
                emitln(ctx, "  ret double 0.000000e+00")
            } elif str.rchar_cmp(ctx.current_ret_abi, "float") == 0 {
                emitln(ctx, "  ret float 0.000000e+00")
            } elif str.rchar_cmp(ctx.current_ret_abi, "void") == 0 {
                emitln(ctx, "  ret void")
            } elif str.rchar_cmp(ctx.current_ret_abi, "ptr") == 0 {
                emitln(ctx, "  ret ptr null")
            } else {
                emitln(ctx, "  ret i64 0")
            }
        } else {
            val rv: ref char = gen_expr(ctx, expr)
            val rv_ty: ref parser.Node = ll_expr_storage_type(ctx, expr)
            val rv_word: mut ref char = rv
            if ll_slot_is_ptr(ctx, rv_ty) { 
                rv_word = ll_coerce_ptr_to_word(ctx, rv) 
            }
            val buf: ref char = @alloc(256) as ref char
            ll_emit_defers(ctx)
            if ctx.current_is_main {
                if expr.kind == parser.NK_OK_VAL || expr.kind == parser.NK_ERR_VAL || ll_is_result_type(rv_ty) {
                    val tag: i64 = fresh_tmp(ctx)
                    val is_ok: i64 = fresh_tmp(ctx)
                    val code: i64 = fresh_tmp(ctx)
                    @snprintf(buf, 256, "  %%t{lld} = load i64, ptr {s}\n  %%t{lld} = icmp eq i64 %%t{lld}, 0\n  %%t{lld} = select i1 %%t{lld}, i32 0, i32 1\n  ret i32 %%t{lld}\n",
                        {tag, rv, is_ok, tag, code, is_ok, code})
                } else {
                    val tr: i64 = fresh_tmp(ctx)
                    @snprintf(buf, 256, "  %%t{lld} = trunc i64 {s} to i32\n  ret i32 %%t{lld}\n", {tr, rv_word, tr})
                }
            } elif str.rchar_cmp(ctx.current_ret_abi, "i32") == 0 {
                val tr: i64 = fresh_tmp(ctx)
                @snprintf(buf, 128, "  %%t{lld} = trunc i64 {s} to i32\n  ret i32 %%t{lld}\n", {tr, rv_word, tr})
            } elif str.rchar_cmp(ctx.current_ret_abi, "double") == 0 {
                @snprintf(buf, 128, "  ret double {s}\n", {rv})
            } elif str.rchar_cmp(ctx.current_ret_abi, "float") == 0 {
                @snprintf(buf, 128, "  ret float {s}\n", {rv})
            } elif str.rchar_cmp(ctx.current_ret_abi, "void") == 0 {
                @snprintf(buf, 128, "  ret void\n", {})
            } elif str.rchar_cmp(ctx.current_ret_abi, "ptr") == 0 {
                if ll_expr_is_null_ptr_literal(expr) {
                    @snprintf(buf, 128, "  ret ptr null\n", {})
                } elif !ll_slot_is_ptr(ctx, rv_ty) && ll_expr_is_raw_load(expr) {
                    @snprintf(buf, 128, "  ret ptr {s}\n", {ll_coerce_word_to_ptr(ctx, rv)})
                } else {
                    @snprintf(buf, 128, "  ret ptr {s}\n", {rv})
                }
            } else {
                @snprintf(buf, 128, "  ret i64 {s}\n", {rv_word})
            }
            emit(ctx, buf)
            @free(buf)
        }
        return
    }

    if k == parser.NK_ASSERT {
        val cond_node: ref parser.Node = stmt.d0 as ref parser.Node
        val cond: ref char = gen_expr(ctx, cond_node)
        val cond_ty: ref parser.Node = ll_expr_storage_type(ctx, cond_node)
        val ok_lbl: i64 = fresh_lbl(ctx)
        val fail_lbl: i64 = fresh_lbl(ctx)
        val cmp: i64 = fresh_tmp(ctx)
        val jbuf: ref char = @alloc(256) as ref char
        if ll_slot_is_ptr(ctx, cond_ty) {
            @snprintf(jbuf, 256, "  %%t{lld} = icmp ne ptr {s}, null\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
                {cmp, cond, cmp, ok_lbl, fail_lbl, fail_lbl})
        } else {
            @snprintf(jbuf, 256, "  %%t{lld} = icmp ne i64 {s}, 0\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
                {cmp, cond, cmp, ok_lbl, fail_lbl, fail_lbl})
        }
        emit(ctx, jbuf)
        @free(jbuf)

        ensure_declared(ctx, "dprintf", "declare i32 @dprintf(i32, ptr, ...)")
        ensure_declared(ctx, "fflush", "declare i32 @fflush(ptr)")
        ensure_declared(ctx, "abort", "declare void @abort()")
        val msg_buf: ref char = @alloc(512) as ref char
        @snprintf(msg_buf, 512, "spectre: assertion failed at line {lld}\n", {stmt.line})
        val msg_len: i64 = str.len_raw(msg_buf) + 1
        val msg_idx: i64 = intern_string(ctx, msg_buf)
        @free(msg_buf)
        val msg_tmp: i64 = fresh_tmp(ctx)
        val fd_tmp: i64 = fresh_tmp(ctx)
        val call_tmp: i64 = fresh_tmp(ctx)
        val fbuf: ref char = @alloc(256) as ref char
        @snprintf(fbuf, 256,
            "  %%t{lld} = getelementptr [{lld} x i8], ptr @__str{lld}, i64 0, i64 0\n  %%t{lld} = trunc i64 2 to i32\n  %%t{lld} = call i32 (i32, ptr, ...) @dprintf(i32 %%t{lld}, ptr %%t{lld})\n  call i32 @fflush(ptr null)\n  call void @abort()\n  unreachable\nlbl{lld}:\n",
            {msg_tmp, msg_len, msg_idx, fd_tmp, call_tmp, fd_tmp, msg_tmp, ok_lbl})
        emit(ctx, fbuf)
        @free(fbuf)
        return
    }

    if k == parser.NK_DEFER {
        ll_defer_push(ctx, stmt.d0 as ref void)
        return
    }

    if k == parser.NK_VAL {
        val name: ref char = stmt.d0 as ref char
        val _: i64 = stmt.d1
        val ty_node: ref parser.Node = stmt.d2 as ref parser.Node
        val expr: ref parser.Node = stmt.d3 as ref parser.Node
        val storage_ty: mut ref parser.Node = ty_node
        if storage_ty == 0 as ref parser.Node {
            storage_ty = ll_expr_storage_type(ctx, expr)
        }
        val val_tmp_raw: ref char = gen_expr(ctx, expr)
        val val_tmp: ref char = ll_coerce_value_for_type(ctx, expr, storage_ty, val_tmp_raw)
        val slot_ptr_name: ref char = ll_alloca_typed_slot(ctx, storage_ty)
        ll_emit_store_value(ctx, slot_ptr_name, storage_ty, val_tmp)
        ll_register_local(ctx, name, slot_ptr_name, storage_ty as ref void)
        return
    }

    if k == parser.NK_ASSIGN {
        val target: ref parser.Node = stmt.d0 as ref parser.Node
        val value: ref parser.Node = stmt.d1 as ref parser.Node
        val target_ty: ref parser.Node = ll_expr_storage_type(ctx, target)
        val val_tmp2_raw: ref char = gen_expr(ctx, value)
        val val_tmp2: ref char = ll_coerce_value_for_type(ctx, value, target_ty, val_tmp2_raw)
        ll_store_target_value(ctx, target, val_tmp2)
        return
    }

    if k == parser.NK_INCREMENT || k == parser.NK_DECREMENT {
        val target: ref parser.Node = stmt.d0 as ref parser.Node
        val cur: ref char = gen_expr(ctx, target)
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        if k == parser.NK_INCREMENT {
            @snprintf(buf, 128, "  %%t{lld} = add i64 {s}, 1\n", {tmp, cur})
        } else {
            @snprintf(buf, 128, "  %%t{lld} = sub i64 {s}, 1\n", {tmp, cur})
        }
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        ll_store_target_value(ctx, target, res)
        return
    }

    if k == parser.NK_ADD_ASSIGN || k == parser.NK_SUB_ASSIGN {
        val target: ref parser.Node = stmt.d0 as ref parser.Node
        val rhs_node: ref parser.Node = stmt.d1 as ref parser.Node
        val cur: ref char = gen_expr(ctx, target)
        val rhs: ref char = gen_expr(ctx, rhs_node)
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        if k == parser.NK_ADD_ASSIGN {
            @snprintf(buf, 128, "  %%t{lld} = add i64 {s}, {s}\n", {tmp, cur, rhs})
        } else {
            @snprintf(buf, 128, "  %%t{lld} = sub i64 {s}, {s}\n", {tmp, cur, rhs})
        }
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        ll_store_target_value(ctx, target, res)
        return
    }

    if k == parser.NK_IF {
        gen_if_stmt(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_OPT {
        val expr_node: ref parser.Node = parser.match_opt_expr(stmt)
        val expr: mut ref char = "0"
        if expr_node != 0 as ref parser.Node { expr = gen_expr(ctx, expr_node) }
        val some_bind: ref char = parser.match_opt_some_bind(stmt)
        val some_body_node: ref parser.Node = parser.match_opt_some_body(stmt)
        val none_body_node: ref parser.Node = parser.match_opt_none_body(stmt)

        val some_lbl: i64 = fresh_lbl(ctx)
        val none_lbl: i64 = fresh_lbl(ctx)
        val end_lbl: i64 = fresh_lbl(ctx)
        val cmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "  %%t{lld} = icmp ne i64 {s}, 0\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n", {cmp, expr, cmp, some_lbl, none_lbl, some_lbl})
        emit(ctx, buf)
        @free(buf)

        if some_bind != 0 as ref char {
            val payload_tmp: i64 = fresh_tmp(ctx)
            val pbuf: ref char = @alloc(128) as ref char
            @snprintf(pbuf, 128, "  %%t{lld} = sub i64 {s}, 1\n", {payload_tmp, expr})
            emit(ctx, pbuf)
            @free(pbuf)

            val inner_ty: ref parser.Node = ll_option_inner_type(ll_expr_storage_type(ctx, expr_node))
            val slot: i64 = fresh_tmp(ctx)
            val sbuf: ref char = @alloc(128) as ref char
            @snprintf(sbuf, 128, "  %%t{lld} = alloca i64, align 8\n", {slot})
            emit(ctx, sbuf)
            @free(sbuf)

            val slot_name: ref char = @alloc(16) as ref char
            @snprintf(slot_name, 16, "%%t{lld}", {slot})
            val payload_name: ref char = @alloc(16) as ref char
            @snprintf(payload_name, 16, "%%t{lld}", {payload_tmp})
            val stored_payload: mut ref char = payload_name
            if ll_slot_is_ptr(ctx, inner_ty) {
                stored_payload = ll_coerce_word_to_ptr(ctx, payload_name)
            }
            ll_emit_store_value(ctx, slot_name, inner_ty, stored_payload)
            ll_register_local(ctx, some_bind, slot_name, inner_ty as ref void)
        }

        if some_body_node != 0 as ref parser.Node {
            gen_stmts(ctx, some_body_node.d0 as ref parser.Node)
        }

        val jbuf: ref char = @alloc(64) as ref char
        @snprintf(jbuf, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {end_lbl, none_lbl})
        emit(ctx, jbuf)
        @free(jbuf)

        if none_body_node != 0 as ref parser.Node {
            gen_stmts(ctx, none_body_node.d0 as ref parser.Node)
        }

        val ebuf: ref char = @alloc(64) as ref char
        @snprintf(ebuf, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {end_lbl, end_lbl})
        emit(ctx, ebuf)
        @free(ebuf)
        return
    }

    if k == parser.NK_MATCH_RES {
        val expr_node: ref parser.Node = parser.match_res_expr(stmt)
        val expr: mut ref char = "0"
        if expr_node != 0 as ref parser.Node { expr = gen_expr(ctx, expr_node) }
        val ok_bind: ref char = parser.match_res_ok_bind(stmt)
        val ok_body_node: ref parser.Node = parser.match_res_ok_body(stmt)
        val err_bind: ref char = parser.match_res_err_bind(stmt)
        val err_body_node: ref parser.Node = parser.match_res_err_body(stmt)
        val result_ty: ref parser.Node = ll_expr_storage_type(ctx, expr_node)
        val ok_ty: ref parser.Node = ll_result_ok_type(result_ty)
        val err_ty: ref parser.Node = ll_result_err_type(result_ty)
        if !ll_is_result_type(result_ty) && ll_slot_is_ptr(ctx, result_ty) {
            val cmp_ptr: i64 = fresh_tmp(ctx)
            val ok_lbl_ptr: i64 = fresh_lbl(ctx)
            val err_lbl_ptr: i64 = fresh_lbl(ctx)
            val end_lbl_ptr: i64 = fresh_lbl(ctx)
            val pbuf: ref char = @alloc(256) as ref char
            @snprintf(pbuf, 256,
                "  %%t{lld} = icmp ne ptr {s}, null\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
                {cmp_ptr, expr, cmp_ptr, ok_lbl_ptr, err_lbl_ptr, ok_lbl_ptr})
            emit(ctx, pbuf)
            @free(pbuf)

            if ok_bind != 0 as ref char {
                val slot_ok: i64 = fresh_tmp(ctx)
                val sbuf_ok: ref char = @alloc(128) as ref char
                @snprintf(sbuf_ok, 128, "  %%t{lld} = alloca ptr, align 8\n", {slot_ok})
                emit(ctx, sbuf_ok)
                @free(sbuf_ok)
                val slot_ok_name: ref char = @alloc(16) as ref char
                @snprintf(slot_ok_name, 16, "%%t{lld}", {slot_ok})
                ll_emit_store_value(ctx, slot_ok_name, result_ty, expr)
                ll_register_local(ctx, ok_bind, slot_ok_name, result_ty as ref void)
            }
            if ok_body_node != 0 as ref parser.Node {
                gen_stmts(ctx, ok_body_node.d0 as ref parser.Node)
            }
            val jbuf_ptr: ref char = @alloc(64) as ref char
            if ok_body_node == 0 as ref parser.Node || !ll_block_ends_with_terminator(ok_body_node.d0 as ref parser.Node) {
                @snprintf(jbuf_ptr, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {end_lbl_ptr, err_lbl_ptr})
            } else {
                @snprintf(jbuf_ptr, 64, "lbl{lld}:\n", {err_lbl_ptr})
            }
            emit(ctx, jbuf_ptr)
            @free(jbuf_ptr)

            if err_bind != 0 as ref char {
                val slot_err: i64 = fresh_tmp(ctx)
                val sbuf_err: ref char = @alloc(128) as ref char
                @snprintf(sbuf_err, 128, "  %%t{lld} = alloca i64, align 8\n", {slot_err})
                emit(ctx, sbuf_err)
                @free(sbuf_err)
                val slot_err_name: ref char = @alloc(16) as ref char
                @snprintf(slot_err_name, 16, "%%t{lld}", {slot_err})
                ll_emit_store_value(ctx, slot_err_name, 0 as ref parser.Node, "0")
                ll_register_local(ctx, err_bind, slot_err_name, 0 as ref void)
            }
            if err_body_node != 0 as ref parser.Node {
                gen_stmts(ctx, err_body_node.d0 as ref parser.Node)
            }
            val endbuf_ptr: ref char = @alloc(64) as ref char
            if err_body_node == 0 as ref parser.Node || !ll_block_ends_with_terminator(err_body_node.d0 as ref parser.Node) {
                @snprintf(endbuf_ptr, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {end_lbl_ptr, end_lbl_ptr})
            } else {
                @snprintf(endbuf_ptr, 64, "lbl{lld}:\n", {end_lbl_ptr})
            }
            emit(ctx, endbuf_ptr)
            @free(endbuf_ptr)
            return
        }
        val tag: i64 = fresh_tmp(ctx)
        val cmp: i64 = fresh_tmp(ctx)
        val ok_lbl: i64 = fresh_lbl(ctx)
        val err_lbl: i64 = fresh_lbl(ctx)
        val end_lbl: i64 = fresh_lbl(ctx)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256,
            "  %%t{lld} = load i64, ptr {s}\n  %%t{lld} = icmp eq i64 %%t{lld}, 0\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
            {tag, expr, cmp, tag, cmp, ok_lbl, err_lbl, ok_lbl})
        emit(ctx, buf)
        @free(buf)

        if ok_bind != 0 as ref char {
            val off_ok: i64 = fresh_tmp(ctx)
            val obuf: ref char = @alloc(128) as ref char
            @snprintf(obuf, 128, "  %%t{lld} = getelementptr i8, ptr {s}, i64 8\n", {off_ok, expr})
            emit(ctx, obuf)
            @free(obuf)
            val off_ok_name: ref char = @alloc(16) as ref char
            @snprintf(off_ok_name, 16, "%%t{lld}", {off_ok})
            val val_ok: ref char = ll_load_typed_value(ctx, off_ok_name, ok_ty)
            val slot_ok: i64 = fresh_tmp(ctx)
            val sbuf_ok: ref char = @alloc(128) as ref char
            if ll_slot_is_ptr(ctx, ok_ty) {
                @snprintf(sbuf_ok, 128, "  %%t{lld} = alloca ptr, align 8\n", {slot_ok})
            } else {
                @snprintf(sbuf_ok, 128, "  %%t{lld} = alloca i64, align 8\n", {slot_ok})
            }
            emit(ctx, sbuf_ok)
            @free(sbuf_ok)
            val slot_ok_name: ref char = @alloc(16) as ref char
            @snprintf(slot_ok_name, 16, "%%t{lld}", {slot_ok})
            ll_emit_store_value(ctx, slot_ok_name, ok_ty, val_ok)
            ll_register_local(ctx, ok_bind, slot_ok_name, ok_ty as ref void)
        }
        if ok_body_node != 0 as ref parser.Node {
            gen_stmts(ctx, ok_body_node.d0 as ref parser.Node)
        }
        val jbuf: ref char = @alloc(64) as ref char
        if ok_body_node == 0 as ref parser.Node || !ll_block_ends_with_terminator(ok_body_node.d0 as ref parser.Node) {
            @snprintf(jbuf, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {end_lbl, err_lbl})
        } else {
            @snprintf(jbuf, 64, "lbl{lld}:\n", {err_lbl})
        }
        emit(ctx, jbuf)
        @free(jbuf)

        if err_bind != 0 as ref char {
            val off_err: i64 = fresh_tmp(ctx)
            val ebuf: ref char = @alloc(128) as ref char
            @snprintf(ebuf, 128, "  %%t{lld} = getelementptr i8, ptr {s}, i64 8\n", {off_err, expr})
            emit(ctx, ebuf)
            @free(ebuf)
            val off_err_name: ref char = @alloc(16) as ref char
            @snprintf(off_err_name, 16, "%%t{lld}", {off_err})
            val val_err: ref char = ll_load_typed_value(ctx, off_err_name, err_ty)
            val slot_err: i64 = fresh_tmp(ctx)
            val sbuf_err: ref char = @alloc(128) as ref char
            if ll_slot_is_ptr(ctx, err_ty) {
                @snprintf(sbuf_err, 128, "  %%t{lld} = alloca ptr, align 8\n", {slot_err})
            } else {
                @snprintf(sbuf_err, 128, "  %%t{lld} = alloca i64, align 8\n", {slot_err})
            }
            emit(ctx, sbuf_err)
            @free(sbuf_err)
            val slot_err_name: ref char = @alloc(16) as ref char
            @snprintf(slot_err_name, 16, "%%t{lld}", {slot_err})
            ll_emit_store_value(ctx, slot_err_name, err_ty, val_err)
            ll_register_local(ctx, err_bind, slot_err_name, err_ty as ref void)
        }
        if err_body_node != 0 as ref parser.Node {
            gen_stmts(ctx, err_body_node.d0 as ref parser.Node)
        }
        val endbuf: ref char = @alloc(64) as ref char
        if err_body_node == 0 as ref parser.Node || !ll_block_ends_with_terminator(err_body_node.d0 as ref parser.Node) {
            @snprintf(endbuf, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {end_lbl, end_lbl})
        } else {
            @snprintf(endbuf, 64, "lbl{lld}:\n", {end_lbl})
        }
        emit(ctx, endbuf)
        @free(endbuf)
        return
    }

    if k == parser.NK_MATCH_UNION {
        gen_match_union(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_TAGGED_UNION {
        gen_match_tagged_union(ctx, stmt)
        return
    }

    if k == parser.NK_FOR {
        gen_for_stmt(ctx, stmt)
        return
    }

    if k == parser.NK_FORIN {
        gen_forin_stmt(ctx, stmt)
        return
    }

    if k == parser.NK_BREAK {
        val blbl: i64 = ll_break_lbl(ctx)
        if blbl >= 0 {
            val bbuf: ref char = @alloc(64) as ref char
            @snprintf(bbuf, 64, "  br label %%lbl{lld}\n", {blbl})
            emit(ctx, bbuf)
            @free(bbuf)
        }
        return
    }

    if k == parser.NK_CONTINUE {
        val clbl: i64 = ll_cont_lbl(ctx)
        if clbl >= 0 {
            val cbuf: ref char = @alloc(64) as ref char
            @snprintf(cbuf, 64, "  br label %%lbl{lld}\n", {clbl})
            emit(ctx, cbuf)
            @free(cbuf)
        }
        return
    }
}

fn gen_if_stmt(ctx: ref LLCtx, stmt: ref parser.Node) void! = {
    val then_lbl: i64 = fresh_lbl(ctx)
    val end_lbl: i64 = fresh_lbl(ctx)
    val else_body: ref parser.Node = stmt.d3 as ref parser.Node
    val elif_list: ref void = stmt.d2 as ref void
    val has_else: bool = else_body != 0 as ref parser.Node
    val has_elif: bool = elif_list != 0 as ref void && @len(elif_list as list[ref void]) > 0
    val next_lbls: mut list[i64] = []
    val body_lbls: mut list[i64] = []
    if has_elif {
        val elen: i64 = @len(elif_list as list[ref void]) as i64
        val pi: mut i64 = 0
        for {
            if pi >= elen { break }
            @append(next_lbls, fresh_lbl(ctx))
            @append(body_lbls, fresh_lbl(ctx))
            pi++
        }
    }
    val else_lbl: i64 = fresh_lbl(ctx)
    val first_false: mut i64 = end_lbl
    if has_elif {
        val fl_opt = @get(next_lbls, 0)
        match fl_opt {
            some fl => { first_false = fl as i64 }
            none => {}
        }
    } elif has_else {
        first_false = else_lbl
    }

    val cond_node: ref parser.Node = stmt.d0 as ref parser.Node
    val cond_ty: ref parser.Node = ll_expr_storage_type(ctx, cond_node)
    val cond: ref char = gen_expr(ctx, cond_node)
    val cmp: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(256) as ref char
    if ll_slot_is_ptr(ctx, cond_ty) {
        @snprintf(buf, 256, "  %%t{lld} = icmp ne ptr {s}, null\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n", {cmp, cond, cmp, then_lbl, first_false, then_lbl})
    } else {
        @snprintf(buf, 256, "  %%t{lld} = icmp ne i64 {s}, 0\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n", {cmp, cond, cmp, then_lbl, first_false, then_lbl})
    }
    emit(ctx, buf)
    @free(buf)
    gen_stmts(ctx, stmt.d1 as ref parser.Node)

    if !ll_block_ends_with_terminator(stmt.d1 as ref parser.Node) {
        val jbuf: ref char = @alloc(64) as ref char
        @snprintf(jbuf, 64, "  br label %%lbl{lld}\n", {end_lbl})
        emit(ctx, jbuf)
        @free(jbuf)
    }

    if has_elif {
        val elen: i64 = @len(elif_list as list[ref void]) as i64
        val ei: mut i64 = 0
        for {
            if ei >= elen { break }
            val ep_opt = @get(elif_list as list[ref void], ei as usize)
            val cl_opt = @get(next_lbls, ei as usize)
            val bl_opt = @get(body_lbls, ei as usize)
            match ep_opt {
                some ep => {
                    match cl_opt {
                        some cl => {
                            match bl_opt {
                                some bl => {
                                    val cond_lbl: i64 = cl as i64
                                    val body_lbl: i64 = bl as i64
                                    val false_lbl: mut i64 = end_lbl
                                    if ei + 1 < elen {
                                        val nl_opt = @get(next_lbls, (ei + 1) as usize)
                                        match nl_opt {
                                            some nl => { false_lbl = nl as i64 }
                                            none => {}
                                        }
                                    } elif has_else {
                                        false_lbl = else_lbl
                                    }

                                    val clbuf: ref char = @alloc(32) as ref char
                                    @snprintf(clbuf, 32, "lbl{lld}:\n", {cond_lbl})
                                    emit(ctx, clbuf)
                                    @free(clbuf)

                                    val ep_node: ref parser.Node = ep as ref parser.Node
                                    val econd_node: ref parser.Node = ep_node.d0 as ref parser.Node
                                    val econd_ty: ref parser.Node = ll_expr_storage_type(ctx, econd_node)
                                    val econd: ref char = gen_expr(ctx, econd_node)
                                    val ecmp: i64 = fresh_tmp(ctx)
                                    val ebuf: ref char = @alloc(256) as ref char
                                    if ll_slot_is_ptr(ctx, econd_ty) {
                                        @snprintf(ebuf, 256, "  %%t{lld} = icmp ne ptr {s}, null\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
                                            {ecmp, econd, ecmp, body_lbl, false_lbl, body_lbl})
                                    } else {
                                        @snprintf(ebuf, 256, "  %%t{lld} = icmp ne i64 {s}, 0\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
                                            {ecmp, econd, ecmp, body_lbl, false_lbl, body_lbl})
                                    }
                                    emit(ctx, ebuf)
                                    @free(ebuf)

                                    gen_stmts(ctx, ep_node.d1 as ref parser.Node)
                                    if !ll_block_ends_with_terminator(ep_node.d1 as ref parser.Node) {
                                        val ejbuf: ref char = @alloc(64) as ref char
                                        @snprintf(ejbuf, 64, "  br label %%lbl{lld}\n", {end_lbl})
                                        emit(ctx, ejbuf)
                                        @free(ejbuf)
                                    }
                                }
                                none => {}
                            }
                        }
                        none => {}
                    }
                }
                none => {}
            }
            ei++
        }
    }

    if has_else {
        val lbuf: ref char = @alloc(32) as ref char
        @snprintf(lbuf, 32, "lbl{lld}:\n", {else_lbl})
        emit(ctx, lbuf)
        @free(lbuf)
        gen_stmts(ctx, else_body.d0 as ref parser.Node)
        if !ll_block_ends_with_terminator(else_body.d0 as ref parser.Node) {
            val jbuf2: ref char = @alloc(64) as ref char
            @snprintf(jbuf2, 64, "  br label %%lbl{lld}\n", {end_lbl})
            emit(ctx, jbuf2)
            @free(jbuf2)
        }
    }

    val ebuf: ref char = @alloc(32) as ref char
    @snprintf(ebuf, 32, "lbl{lld}:\n", {end_lbl})
    emit(ctx, ebuf)
    @free(ebuf)
}

fn gen_match_union(ctx: ref LLCtx, stmt: ref parser.Node) void! = {
    val expr_node: ref parser.Node = parser.match_union_expr(stmt)
    val expr: mut ref char = "0"
    if expr_node != 0 as ref parser.Node { expr = gen_expr(ctx, expr_node) }
    val arms: ref void = parser.match_union_arms(stmt)
    val else_body: ref parser.Node = parser.match_union_else(stmt)
    val end_lbl: i64 = fresh_lbl(ctx)
    val tag: i64 = fresh_tmp(ctx)
    val tbuf: ref char = @alloc(96) as ref char
    @snprintf(tbuf, 96, "  %%t{lld} = load i64, ptr {s}\n", {tag, expr})
    emit(ctx, tbuf)
    @free(tbuf)

    val union_variants: ref void = ll_union_variants_for_expr(ctx, expr_node)
    val alen: i64 = @len(arms) as i64
    if alen > 0 {
        val ai: mut i64 = 0
        for {
            if ai >= alen { break }
            val arm_opt = @get(arms, ai as usize)
            match arm_opt {
                some arm => {
                    val arm_node: ref parser.Node = arm as ref parser.Node
                    val arm_ty: ref parser.Node = parser.match_union_arm_type(arm_node)
                    val tag_idx: mut i64 = ai
                    if union_variants != 0 as ref void && arm_ty != 0 as ref parser.Node && arm_ty.kind == parser.TY_NAMED {
                        val arm_tname: ref char = arm_ty.d0 as ref char
                        val vlen: i64 = @len(union_variants) as i64
                        val vi: mut i64 = 0
                        for {
                            if vi >= vlen { break }
                            val v_opt = @get(union_variants, vi as usize)
                            match v_opt {
                                some v => {
                                    val vnode: ref parser.Node = v as ref parser.Node
                                    if vnode != 0 as ref parser.Node && vnode.kind == parser.TY_NAMED && str.rchar_cmp(vnode.d0 as ref char, arm_tname) == 0 {
                                        tag_idx = vi
                                        break
                                    }
                                }
                                none => {}
                            }
                            vi++
                        }
                    }
                    val body_lbl: i64 = fresh_lbl(ctx)
                    val next_lbl: i64 = fresh_lbl(ctx)
                    val cmp: i64 = fresh_tmp(ctx)
                    val buf: ref char = @alloc(256) as ref char
                    @snprintf(buf, 256, "  %%t{lld} = icmp eq i64 %%t{lld}, {lld}\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
                        {cmp, tag, tag_idx, cmp, body_lbl, next_lbl, body_lbl})
                    emit(ctx, buf)
                    @free(buf)
                    val arm_body: ref void = parser.match_union_arm_body(arm_node) as ref void
                    gen_stmts(ctx, arm_body as ref parser.Node)
                    val jbuf: ref char = @alloc(64) as ref char
                    if !ll_block_ends_with_terminator(arm_body as ref parser.Node) {
                        @snprintf(jbuf, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {end_lbl, next_lbl})
                    } else {
                        @snprintf(jbuf, 64, "lbl{lld}:\n", {next_lbl})
                    }
                    emit(ctx, jbuf)
                    @free(jbuf)
                }
                none => {}
            }
            ai++
        }
    }

    if else_body != 0 as ref parser.Node {
        gen_stmts(ctx, else_body.d0 as ref parser.Node)
        if !ll_block_ends_with_terminator(else_body.d0 as ref parser.Node) {
            val ebr: ref char = @alloc(64) as ref char
            @snprintf(ebr, 64, "  br label %%lbl{lld}\n", {end_lbl})
            emit(ctx, ebr)
            @free(ebr)
        }
    } else {
        val ebr: ref char = @alloc(64) as ref char
        @snprintf(ebr, 64, "  br label %%lbl{lld}\n", {end_lbl})
        emit(ctx, ebr)
        @free(ebr)
    }

    val endbuf: ref char = @alloc(32) as ref char
    @snprintf(endbuf, 32, "lbl{lld}:\n", {end_lbl})
    emit(ctx, endbuf)
    @free(endbuf)
}

fn gen_match_tagged_union(ctx: ref LLCtx, stmt: ref parser.Node) void! = {
    val expr_node: ref parser.Node = parser.match_tagged_union_expr(stmt)
    val expr: mut ref char = "0"
    if expr_node != 0 as ref parser.Node { expr = gen_expr(ctx, expr_node) }
    val arms: ref void = parser.match_tagged_union_arms(stmt)
    val else_body: ref parser.Node = parser.match_tagged_union_else(stmt)
    val end_lbl: i64 = fresh_lbl(ctx)
    val tag: i64 = fresh_tmp(ctx)
    val tbuf: ref char = @alloc(96) as ref char
    @snprintf(tbuf, 96, "  %%t{lld} = load i64, ptr {s}\n", {tag, expr})
    emit(ctx, tbuf)
    @free(tbuf)

    val alen: i64 = @len(arms) as i64
    if alen > 0 {
        val ai: mut i64 = 0
        for {
            if ai >= alen { break }
            val arm_opt = @get(arms, ai as usize)
            match arm_opt {
                some arm => {
                    val arm_node: ref parser.Node = arm as ref parser.Node
                    val vname: ref char = parser.match_tagged_union_arm_variant(arm_node)
                    val bindings: ref void = parser.match_tagged_union_arm_bindings(arm_node)

                    val owner_slot: ref void = @alloc(8)
                    val field_slot: ref void = @alloc(8)
                    @store(owner_slot, 0)
                    @store(field_slot, 0)
                    val tag_idx: mut i64 = ll_lookup_tv(ctx, vname, owner_slot, field_slot)
                    if tag_idx < 0 {
                        val sep_pos: mut i64 = -1
                        val scan_i: mut i64 = 0
                        for {
                            val sc: u8 = @load8(@ptradd(vname as ref void, scan_i))
                            if sc == 0 { break }
                            val sc2: u8 = @load8(@ptradd(vname as ref void, scan_i + 1))
                            if sc == 95 && sc2 == 95 { sep_pos = scan_i }
                            scan_i++
                        }
                        if sep_pos >= 0 {
                            val bare_name: ref char = @ptradd(vname as ref void, sep_pos + 2) as ref char
                            @store(owner_slot, 0)
                            @store(field_slot, 0)
                            tag_idx = ll_lookup_tv(ctx, bare_name, owner_slot, field_slot)
                        }
                    }
                    val body_lbl: i64 = fresh_lbl(ctx)
                    val next_lbl: i64 = fresh_lbl(ctx)
                    val cmp: i64 = fresh_tmp(ctx)
                    val buf: ref char = @alloc(256) as ref char
                    @snprintf(buf, 256,
                        "  %%t{lld} = icmp eq i64 %%t{lld}, {lld}\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
                        {cmp, tag, tag_idx, cmp, body_lbl, next_lbl, body_lbl})
                    emit(ctx, buf)
                    @free(buf)

                    val field_ty_list: ref void = @load(field_slot) as ref void
                    val blen: i64 = @len(bindings) as i64
                    if blen > 0 {
                        val bi: mut i64 = 0
                        val offset: mut i64 = 8
                        for {
                            if bi >= blen { break }
                            val b_opt = @get(bindings as list[ref char], bi as usize)
                            match b_opt {
                                some b => {
                                    val bname: ref char = b as ref char
                                    if str.rchar_cmp(bname, "_") != 0 {
                                        val field_ty: mut ref parser.Node = 0 as ref parser.Node
                                        if field_ty_list != 0 as ref void {
                                            val ft_opt = @get(field_ty_list as list[ref parser.Node], bi as usize)
                                            match ft_opt {
                                                some ft => { field_ty = ft as ref parser.Node }
                                                none => {}
                                            }
                                        }
                                        val payload_ptr: i64 = fresh_tmp(ctx)
                                        val pbuf: ref char = @alloc(128) as ref char
                                        @snprintf(pbuf, 128, "  %%t{lld} = getelementptr i8, ptr {s}, i64 {lld}\n", {payload_ptr, expr, offset})
                                        emit(ctx, pbuf)
                                        @free(pbuf)
                                        val payload_ptr_name: ref char = @alloc(16) as ref char
                                        @snprintf(payload_ptr_name, 16, "%%t{lld}", {payload_ptr})
                                        val payload_val: ref char = ll_load_typed_value(ctx, payload_ptr_name, field_ty)
                                        val slot: i64 = fresh_tmp(ctx)
                                        val sbuf: ref char = @alloc(128) as ref char
                                        if ll_slot_is_ptr(ctx, field_ty) {
                                            @snprintf(sbuf, 128, "  %%t{lld} = alloca ptr, align 8\n", {slot})
                                        } else {
                                            @snprintf(sbuf, 128, "  %%t{lld} = alloca i64, align 8\n", {slot})
                                        }
                                        emit(ctx, sbuf)
                                        @free(sbuf)
                                        val slot_name: ref char = @alloc(16) as ref char
                                        @snprintf(slot_name, 16, "%%t{lld}", {slot})
                                        ll_emit_store_value(ctx, slot_name, field_ty, payload_val)
                                        ll_register_local(ctx, bname, slot_name, field_ty as ref void)
                                        if field_ty_list != 0 as ref void && field_ty != 0 as ref parser.Node {
                                            offset = offset + ll_aligned_size(ll_type_size(ctx, field_ty))
                                        } else {
                                            offset = offset + 8
                                        }
                                    }
                                }
                                none => {}
                            }
                            bi++
                        }
                    }

                    val arm_body: ref void = parser.match_tagged_union_arm_body(arm_node) as ref void
                    gen_stmts(ctx, arm_body as ref parser.Node)
                    val jbuf: ref char = @alloc(64) as ref char
                    if !ll_block_ends_with_terminator(arm_body as ref parser.Node) {
                        @snprintf(jbuf, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {end_lbl, next_lbl})
                    } else {
                        @snprintf(jbuf, 64, "lbl{lld}:\n", {next_lbl})
                    }
                    emit(ctx, jbuf)
                    @free(jbuf)
                }
                none => {}
            }
            ai++
        }
    }

    if else_body != 0 as ref parser.Node {
        gen_stmts(ctx, else_body.d0 as ref parser.Node)
        if !ll_block_ends_with_terminator(else_body.d0 as ref parser.Node) {
            val ebr: ref char = @alloc(64) as ref char
            @snprintf(ebr, 64, "  br label %%lbl{lld}\n", {end_lbl})
            emit(ctx, ebr)
            @free(ebr)
        }
    } else {
        val ebr: ref char = @alloc(64) as ref char
        @snprintf(ebr, 64, "  br label %%lbl{lld}\n", {end_lbl})
        emit(ctx, ebr)
        @free(ebr)
    }

    val endbuf: ref char = @alloc(32) as ref char
    @snprintf(endbuf, 32, "lbl{lld}:\n", {end_lbl})
    emit(ctx, endbuf)
    @free(endbuf)
}

fn gen_for_stmt(ctx: ref LLCtx, stmt: ref parser.Node) void! = {
    val loop_lbl: i64 = fresh_lbl(ctx)
    val body_lbl: i64 = fresh_lbl(ctx)
    val cont_lbl: i64 = fresh_lbl(ctx)
    val end_lbl: i64 = fresh_lbl(ctx)
    val init_name: ref char = stmt.d0 as ref char
    val init_expr: ref parser.Node = stmt.d1 as ref parser.Node
    val cond_node: ref parser.Node = stmt.d2 as ref parser.Node
    val post_node: ref parser.Node = stmt.d3 as ref parser.Node
    val body: ref void = stmt.d4 as ref void
    val prev_break: i64 = ll_break_lbl(ctx)
    val prev_cont: i64 = ll_cont_lbl(ctx)

    ll_set_break_lbl(ctx, end_lbl)
    ll_set_cont_lbl(ctx, cont_lbl)

    if init_name != 0 as ref char && init_expr != 0 as ref parser.Node {
        val init_val: ref char = gen_expr(ctx, init_expr)
        val existing_ptr: ref char = ll_lookup_local_ptr(ctx, init_name)
        if str.rchar_cmp(existing_ptr, "") == 0 {
            val slot: i64 = fresh_tmp(ctx)
            val buf: ref char = @alloc(128) as ref char
            @snprintf(buf, 128, "  %%t{lld} = alloca i64, align 8\n", {slot})
            emit(ctx, buf)
            @free(buf)
            val slot_name: ref char = @alloc(16) as ref char
            @snprintf(slot_name, 16, "%%t{lld}", {slot})
            ll_emit_store_value(ctx, slot_name, 0 as ref parser.Node, init_val)
            ll_register_local(ctx, init_name, slot_name, 0 as ref void)
        } else {
            ll_emit_store_value(ctx, existing_ptr, ll_lookup_local_type(ctx, init_name), init_val)
        }
    }

    val lbuf: ref char = @alloc(64) as ref char
    @snprintf(lbuf, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {loop_lbl, loop_lbl})
    emit(ctx, lbuf)
    @free(lbuf)

    if cond_node != 0 as ref parser.Node {
        val cond: ref char = gen_expr(ctx, cond_node)
        val cmp: i64 = fresh_tmp(ctx)
        val cbuf: ref char = @alloc(192) as ref char
        @snprintf(cbuf, 192, "  %%t{lld} = icmp ne i64 {s}, 0\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
            {cmp, cond, cmp, body_lbl, end_lbl, body_lbl})
        emit(ctx, cbuf)
        @free(cbuf)
    } else {
        val ibuf: ref char = @alloc(64) as ref char
        @snprintf(ibuf, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {body_lbl, body_lbl})
        emit(ctx, ibuf)
        @free(ibuf)
    }

    if body != 0 as ref void { gen_stmts(ctx, body as ref parser.Node) }

    if !ll_block_ends_with_terminator(body as ref parser.Node) {
        val cbuf2: ref char = @alloc(64) as ref char
        @snprintf(cbuf2, 64, "  br label %%lbl{lld}\n", {cont_lbl})
        emit(ctx, cbuf2)
        @free(cbuf2)
    }

    val clbuf: ref char = @alloc(32) as ref char
    @snprintf(clbuf, 32, "lbl{lld}:\n", {cont_lbl})
    emit(ctx, clbuf)
    @free(clbuf)

    if post_node != 0 as ref parser.Node {
        val pk: i64 = post_node.kind
        if pk == parser.NK_INCREMENT || pk == parser.NK_DECREMENT {
            val name: ref char = post_node.d0 as ref char
            val cur: ref char = ll_load_named_local_value(ctx, name)
            val tmp: i64 = fresh_tmp(ctx)
            val buf: ref char = @alloc(128) as ref char
            if pk == parser.NK_INCREMENT {
                @snprintf(buf, 128, "  %%t{lld} = add i64 {s}, 1\n", {tmp, cur})
            } else {
                @snprintf(buf, 128, "  %%t{lld} = sub i64 {s}, 1\n", {tmp, cur})
            }
            emit(ctx, buf)
            @free(buf)
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t{lld}", {tmp})
            ll_store_named_local_value(ctx, name, res)
        } elif pk == parser.NK_ADD_ASSIGN || pk == parser.NK_SUB_ASSIGN {
            val name: ref char = post_node.d0 as ref char
            val cur: ref char = ll_load_named_local_value(ctx, name)
            val rhs: ref char = gen_expr(ctx, post_node.d1 as ref parser.Node)
            val tmp: i64 = fresh_tmp(ctx)
            val buf: ref char = @alloc(128) as ref char
            if pk == parser.NK_ADD_ASSIGN {
                @snprintf(buf, 128, "  %%t{lld} = add i64 {s}, {s}\n", {tmp, cur, rhs})
            } else {
                @snprintf(buf, 128, "  %%t{lld} = sub i64 {s}, {s}\n", {tmp, cur, rhs})
            }
            emit(ctx, buf)
            @free(buf)
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t{lld}", {tmp})
            ll_store_named_local_value(ctx, name, res)
        } else {
            gen_stmt(ctx, post_node)
        }
    }

    val jbuf: ref char = @alloc(64) as ref char
    @snprintf(jbuf, 64, "  br label %%lbl{lld}\nlbl{lld}:\n", {loop_lbl, end_lbl})
    emit(ctx, jbuf)
    @free(jbuf)

    ll_set_break_lbl(ctx, prev_break)
    ll_set_cont_lbl(ctx, prev_cont)
}

fn gen_forin_stmt(ctx: ref LLCtx, stmt: ref parser.Node) void! = {
    val binding: ref char = stmt.d0 as ref char
    val iter_node: ref parser.Node = stmt.d1 as ref parser.Node
    val body: ref void = stmt.d2 as ref void
    val iter: ref char = gen_expr(ctx, iter_node)
    val iter_ty: ref parser.Node = ll_expr_storage_type(ctx, iter_node)
    val elem_ty: ref parser.Node = ll_list_inner_type(iter_ty)
    val loop_lbl: i64 = fresh_lbl(ctx)
    val body_lbl: i64 = fresh_lbl(ctx)
    val cont_lbl: i64 = fresh_lbl(ctx)
    val end_lbl: i64 = fresh_lbl(ctx)
    val prev_break: i64 = ll_break_lbl(ctx)
    val prev_cont: i64 = ll_cont_lbl(ctx)

    ll_set_break_lbl(ctx, end_lbl)
    ll_set_cont_lbl(ctx, cont_lbl)

    val idx_slot_name: ref char = ll_alloca_typed_slot(ctx, 0 as ref parser.Node)
    ll_emit_store_value(ctx, idx_slot_name, 0 as ref parser.Node, "0")

    val binding_slot_name: ref char = ll_alloca_typed_slot(ctx, elem_ty)
    ll_register_local(ctx, binding, binding_slot_name, elem_ty as ref void)

    val len_ptr: i64 = fresh_tmp(ctx)
    val len_val: i64 = fresh_tmp(ctx)
    val lbuf: ref char = @alloc(160) as ref char
    @snprintf(lbuf, 160, "  %%t{lld} = getelementptr i8, ptr {s}, i64 8\n  %%t{lld} = load i64, ptr %%t{lld}\n  br label %%lbl{lld}\nlbl{lld}:\n",
        {len_ptr, iter, len_val, len_ptr, loop_lbl, loop_lbl})
    emit(ctx, lbuf)
    @free(lbuf)

    val cur_idx: i64 = fresh_tmp(ctx)
    val cmp: i64 = fresh_tmp(ctx)
    val cbuf: ref char = @alloc(192) as ref char
    @snprintf(cbuf, 192, "  %%t{lld} = load i64, ptr {s}\n  %%t{lld} = icmp slt i64 %%t{lld}, %%t{lld}\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
        {cur_idx, idx_slot_name, cmp, cur_idx, len_val, cmp, body_lbl, end_lbl, body_lbl})
    emit(ctx, cbuf)
    @free(cbuf)

    val buf_ptr: i64 = fresh_tmp(ctx)
    val off: i64 = fresh_tmp(ctx)
    val elem_ptr: i64 = fresh_tmp(ctx)
    val ebuf: ref char = @alloc(192) as ref char
    @snprintf(ebuf, 192, "  %%t{lld} = load ptr, ptr {s}\n  %%t{lld} = mul i64 %%t{lld}, 8\n  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 %%t{lld}\n",
        {buf_ptr, iter, off, cur_idx, elem_ptr, buf_ptr, off})
    emit(ctx, ebuf)
    @free(ebuf)
    val elem_ptr_name: ref char = @alloc(16) as ref char
    @snprintf(elem_ptr_name, 16, "%%t{lld}", {elem_ptr})
    val elem_val: ref char = ll_load_typed_value(ctx, elem_ptr_name, elem_ty)
    ll_emit_store_value(ctx, binding_slot_name, elem_ty, elem_val)

    if body != 0 as ref void { gen_stmts(ctx, body as ref parser.Node) }

    if !ll_block_ends_with_terminator(body as ref parser.Node) {
        val cbuf2: ref char = @alloc(64) as ref char
        @snprintf(cbuf2, 64, "  br label %%lbl{lld}\n", {cont_lbl})
        emit(ctx, cbuf2)
        @free(cbuf2)
    }

    val next_idx: i64 = fresh_tmp(ctx)
    val nbuf: ref char = @alloc(160) as ref char
    @snprintf(nbuf, 160, "lbl{lld}:\n  %%t{lld} = add i64 %%t{lld}, 1\n  store i64 %%t{lld}, ptr {s}\n  br label %%lbl{lld}\nlbl{lld}:\n",
        {cont_lbl, next_idx, cur_idx, next_idx, idx_slot_name, loop_lbl, end_lbl})
    emit(ctx, nbuf)
    @free(nbuf)

    ll_set_break_lbl(ctx, prev_break)
    ll_set_cont_lbl(ctx, prev_cont)
}


fn gen_fn_prefixed(ctx: mut ref LLCtx, fn_node: ref parser.Node, mod_prefix: ref char) void! = {
    // val public: i64 = fn_node.d0 as i64
    val ns: ref char = fn_node.d1 as ref char
    val name: ref char = fn_node.d2 as ref char
    val params: ref void = fn_node.d3 as ref void
    val ret_ty: ref parser.Node = fn_node.d4 as ref parser.Node
    val body: ref parser.Node = fn_node.d5 as ref parser.Node
    val mangled: ref char = @alloc(512) as ref char
    val base: ref char = @alloc(256) as ref char

    if ns != 0 as ref char {
        @snprintf(base, 256, "{s}__{s}", {ns, name})
    } else {
        @snprintf(base, 256, "{s}", {name})
    }

    val is_std_child: mut bool = false
    for scn in get_std_child_names() {
        if str.rchar_cmp(scn, mod_prefix) == 0 { is_std_child = true break }
    }

    if str.rchar_cmp(mod_prefix, "") == 0 {
        @snprintf(mangled, 512, "{s}", {base})
    } elif is_std_child {
        @snprintf(mangled, 512, "std__{s}__{s}", {mod_prefix, base})
    } else {
        @snprintf(mangled, 512, "{s}__{s}", {mod_prefix, base})
    }

    if !ll_emit_label_if_new(ctx, mangled) { return }

    if params != 0 as ref void {
        ll_register_fn(ctx, mangled, params, ret_ty as ref void)
    }

    val is_main: bool = str.rchar_cmp(name, "main") == 0 && str.rchar_cmp(mod_prefix, "") == 0

    ctx.tmp = 0
    ctx.current_is_main = is_main
    ctx.current_prefix = mod_prefix
    ll_defer_clear(ctx)
    if is_main {
        ctx.current_ret_abi = "i32"
    } else {
        ctx.current_ret_abi = ll_call_ret_abi(ctx, ret_ty)
    }
    ll_clear_locals(ctx)

    if is_main {
        if !ctx.release_mode {
            ensure_declared(ctx, "__sx_panic_init", "declare void @__sx_panic_init()")
        }
        emitln(ctx, "define i32 @main(i32 %argc, ptr %argv) {")
    } else {
        val hdr: ref char = @alloc(512) as ref char
        @snprintf(hdr, 512, "define {s} @{s}(", {ctx.current_ret_abi, mangled})
        emit(ctx, hdr)
        @free(hdr)
        if params != 0 as ref void {
            val plen: i64 = @len(params) as i64
            val pi: mut i64 = 0
            for {
                if pi >= plen { break }
                val p_opt = @get(params, pi as usize)
                match p_opt {
                    some param => {
                        val pnode: ref parser.Node = param as ref parser.Node
                        val pname: ref char = pnode.d0 as ref char
                        val pssa: ref char = ll_param_ssa_name_at(pname, pi)
                        val pty: ref parser.Node = pnode.d1 as ref parser.Node
                        if pi > 0 { emit(ctx, ", ") }
                        val pb: ref char = @alloc(64) as ref char
                        @snprintf(pb, 64, "{s} %%{s}", {ll_param_abi_type(ctx, pty), pssa})
                        emit(ctx, pb)
                        @free(pb)
                    }
                    none => {}
                }
                pi++
            }
        }
        emitln(ctx, ") {")
    }
    emitln(ctx, "entry:")
    if is_main {
        if !ctx.release_mode {
            emitln(ctx, "  call void @__sx_panic_init()")
        }
    }

    if is_main {
        emitln(ctx, "  %t.argc = sext i32 %argc to i64")
        emitln(ctx, "  store i64 %t.argc, ptr @sx_argc_store")
        emitln(ctx, "  store ptr %argv, ptr @sx_argv_store")
    } elif params != 0 as ref void {
        val plen2: i64 = @len(params) as i64
        val pi2: mut i64 = 0
        for {
            if pi2 >= plen2 { break }
            val p_opt2 = @get(params, pi2 as usize)
            match p_opt2 {
                some param2 => {
                    val pnode2: ref parser.Node = param2 as ref parser.Node
                    val pname2: ref char = pnode2.d0 as ref char
                    val pssa2: ref char = ll_param_ssa_name_at(pname2, pi2)
                    val pty2: ref parser.Node = pnode2.d1 as ref parser.Node
                    val slot_name: ref char = ll_alloca_typed_slot(ctx, pty2)
                    val abi_ty: ref char = ll_param_abi_type(ctx, pty2)
                    if str.rchar_cmp(abi_ty, "i32") == 0 {
                        val ext: i64 = fresh_tmp(ctx)
                        val sbuf: ref char = @alloc(128) as ref char
                        @snprintf(sbuf, 128, "  %%t{lld} = sext i32 %%{s} to i64\n", {ext, pssa2})
                        emit(ctx, sbuf)
                        @free(sbuf)
                        val ext_name: ref char = @alloc(16) as ref char
                        @snprintf(ext_name, 16, "%%t{lld}", {ext})
                        ll_emit_store_value(ctx, slot_name, pty2, ext_name)
                    } else {
                        val incoming: ref char = @alloc(str.len_raw(pssa2) + 2) as ref char
                        @snprintf(incoming, str.len_raw(pssa2) + 2, "%%{s}", {pssa2})
                        ll_emit_store_value(ctx, slot_name, pty2, incoming)
                    }
                    ll_register_local(ctx, pname2, slot_name, pty2 as ref void)
                }
                none => {}
            }
            pi2++
        }
    }

    gen_stmts(ctx, body)

    val blen: i64 = @len(body) as i64
    val needs_ret: mut bool = true
    if blen > 0 {
        val last_opt = @get(body, (blen - 1) as usize)
        match last_opt {
            some last => {
                if ((last as ref parser.Node).kind == parser.NK_RETURN) { needs_ret = false }
            }
            none => {}
        }
    }
    if needs_ret {
        ll_emit_defers(ctx)
        if is_main {
            emitln(ctx, "  ret i32 0")
        } elif str.rchar_cmp(ctx.current_ret_abi, "i32") == 0 {
            emitln(ctx, "  ret i32 0")
        } elif str.rchar_cmp(ctx.current_ret_abi, "double") == 0 {
            emitln(ctx, "  ret double 0.000000e+00")
        } elif str.rchar_cmp(ctx.current_ret_abi, "float") == 0 {
            emitln(ctx, "  ret float 0.000000e+00")
        } elif str.rchar_cmp(ctx.current_ret_abi, "void") == 0 {
            emitln(ctx, "  ret void")
        } elif str.rchar_cmp(ctx.current_ret_abi, "ptr") == 0 {
            emitln(ctx, "  ret ptr null")
        } else {
            emitln(ctx, "  ret i64 0")
        }
    }
    emitln(ctx, "}")
    emitln(ctx, "")
}

fn ll_declare_extern(ctx: ref LLCtx, symbol: ref char, params: ref void, ret_ty: ref void) void! = {
    val decl_sb: ref void = str.StringBuilder.new()
    val hdr: ref char = @alloc(256) as ref char
    @snprintf(hdr, 256, "declare {s} @{s}(", {ll_call_ret_abi(ctx, ret_ty as ref parser.Node), symbol})
    str.StringBuilder.append_cstr(decl_sb, hdr)
    @free(hdr)
    if params != 0 as ref void {
        val plen: i64 = @len(params) as i64
        val pi: mut i64 = 0
        for {
            if pi >= plen { break }
            val p_opt = @get(params, pi as usize)
            match p_opt {
                some param => {
                    val pnode: ref parser.Node = param as ref parser.Node
                    val pty: ref parser.Node = pnode.d1 as ref parser.Node
                    if pi > 0 { str.StringBuilder.append_cstr(decl_sb, ", ") }
                    val pb: ref char = @alloc(64) as ref char
                    @snprintf(pb, 64, "{s}", {ll_param_abi_type(ctx, pty)})
                    str.StringBuilder.append_cstr(decl_sb, pb)
                    @free(pb)
                }
                none => {}
            }
            pi++
        }
    }
    str.StringBuilder.append_cstr(decl_sb, ")")
    ensure_declared(ctx, symbol, str.cstr(str.StringBuilder.build(decl_sb)))
    str.StringBuilder.free(decl_sb)
}

fn gen_extern_fn_prefixed(ctx: ref LLCtx, item: ref parser.Node, mod_prefix: ref char) void! = {
    val public: i64 = item.d0 as i64
    val name: ref char = item.d1 as ref char
    val symbol: ref char = item.d2 as ref char
    val params: ref void = item.d4 as ref void
    val ret_ty: ref void = item.d5 as ref void
    ll_register_extern(ctx, name, symbol, ret_ty)
    ll_declare_extern(ctx, symbol, params, ret_ty)
    if params != 0 as ref void {
        ll_register_fn(ctx, symbol, params, ret_ty)
    }
    if public == 1 && str.rchar_cmp(mod_prefix, "") != 0 {
        val mangled_name: ref char = @alloc(512) as ref char
        @snprintf(mangled_name, 512, "{s}__{s}", {mod_prefix, name})
        ll_register_extern(ctx, mangled_name, symbol, ret_ty)
        if params != 0 as ref void {
            ll_register_fn(ctx, mangled_name, params, ret_ty)
        }
        @free(mangled_name)
    }
}


fn preregister_items(ctx: ref LLCtx, items: list[ref parser.Node], mod_prefix: ref char) void! = {
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_FN {
                    val ns: ref char = node.d1 as ref char
                    val name: ref char = node.d2 as ref char
                    val params: ref void = node.d3 as ref void
                    val ret_ty: ref void = node.d4 as ref void
                    val base: ref char = @alloc(256) as ref char
                    if ns != 0 as ref char {
                        @snprintf(base, 256, "{s}__{s}", {ns, name})
                    } else {
                        @snprintf(base, 256, "{s}", {name})
                    }
                    val is_std_child: mut bool = false
                    for scn in get_std_child_names() {
                        if str.rchar_cmp(scn, mod_prefix) == 0 { is_std_child = true break }
                    }
                    val mangled: ref char = @alloc(512) as ref char
                    if str.rchar_cmp(mod_prefix, "") == 0 { @snprintf(mangled, 512, "{s}", {base}) }
                    elif is_std_child { @snprintf(mangled, 512, "std__{s}__{s}", {mod_prefix, base}) }
                    else { @snprintf(mangled, 512, "{s}__{s}", {mod_prefix, base}) }
                    if params != 0 as ref void {
                        ll_register_fn(ctx, mangled, params, ret_ty)
                    }
                } elif k == parser.NK_EXTERN_FN {
                    val public: i64 = node.d0 as i64
                    val name: ref char = node.d1 as ref char
                    val symbol: ref char = node.d2 as ref char
                    val params: ref void = node.d4 as ref void
                    val ret_ty: ref void = node.d5 as ref void
                    ll_register_extern(ctx, name, symbol, ret_ty)
                    ll_declare_extern(ctx, symbol, params, ret_ty)
                    if params != 0 as ref void {
                        ll_register_fn(ctx, symbol, params, ret_ty)
                    }
                    if public == 1 && str.rchar_cmp(mod_prefix, "") != 0 {
                        val mangled_name: ref char = @alloc(512) as ref char
                        @snprintf(mangled_name, 512, "{s}__{s}", {mod_prefix, name})
                        ll_register_extern(ctx, mangled_name, symbol, ret_ty)
                        if params != 0 as ref void {
                            ll_register_fn(ctx, mangled_name, params, ret_ty)
                        }
                        @free(mangled_name)
                    }
                } elif k == parser.NK_UNIONDEF {
                    val uname: ref char = node.d1 as ref char
                    val variants: ref void = node.d2 as ref void
                    ll_register_union(ctx, uname, variants)
                } elif k == parser.NK_ENUMDEF {
                    val ename: ref char = node.d1 as ref char
                    val variants: ref void = node.d2 as ref void
                    if variants != 0 as ref void {
                        val vlen: i64 = @len(variants) as i64
                        val vi: mut i64 = 0
                        for {
                            if vi >= vlen { break }
                            val v_opt = @get(variants, vi as usize)
                            match v_opt {
                                some v => {
                                    val vname: ref char = v as ref char
                                    val const_key: ref char = @alloc(512) as ref char
                                    val idx_str: ref char = @alloc(32) as ref char
                                    @snprintf(idx_str, 32, "{lld}", {vi})
                                    if str.rchar_cmp(mod_prefix, "") == 0 {
                                        @snprintf(const_key, 512, "{s}__{s}", {ename, vname})
                                    } else {
                                        @snprintf(const_key, 512, "{s}__{s}__{s}", {mod_prefix, ename, vname})
                                    }
                                    ll_register_global_const(ctx, const_key, idx_str, 0 as ref void)
                                    ll_register_module_const(ctx, const_key, idx_str)
                                    if str.rchar_cmp(mod_prefix, "") != 0 {
                                        val bare_key: ref char = @alloc(256) as ref char
                                        val idx_str2: ref char = @alloc(32) as ref char
                                        @snprintf(bare_key, 256, "{s}__{s}", {ename, vname})
                                        @snprintf(idx_str2, 32, "{lld}", {vi})
                                        ll_register_module_const(ctx, bare_key, idx_str2)
                                    }
                                }
                                none => {}
                            }
                            vi++
                        }
                    }
                } elif k == parser.NK_TAGGED_UNIONDEF {
                    val tname: ref char = node.d1 as ref char
                    val variants: ref void = node.d2 as ref void
                    if variants != 0 as ref void {
                        val vlen: i64 = @len(variants) as i64
                        val vi: mut i64 = 0
                        for {
                            if vi >= vlen { break }
                            val v_opt = @get(variants, vi as usize)
                            match v_opt {
                                some v => {
                                    val vnode: ref parser.Node = v as ref parser.Node
                                    val vname: ref char = vnode.d0 as ref char
                                    val vty: ref void = vnode.d1 as ref void
                                    @append(ctx.tv_names, vname)
                                    @append(ctx.tv_owners, tname)
                                    @append(ctx.tv_tags, vi)
                                    @append(ctx.tv_fields, vty)
                                }
                                none => {}
                            }
                            vi++
                        }
                    }
                } elif k == parser.NK_TYPEDEF {
                    val tname: ref char = node.d1 as ref char
                    val tfields: ref void = node.d2 as ref void
                    @append(ctx.snames, tname)
                    @append(ctx.sfields, tfields)
                } elif k == parser.NK_EXTERN_TYPE {
                    val etname: ref char = node.d1 as ref char
                    val etfields: ref void = node.d2 as ref void
                    @append(ctx.snames, etname)
                    @append(ctx.sfields, etfields)
                } elif k == parser.NK_CONST {
                    val cname: ref char = node.d1 as ref char
                    val cexpr: ref parser.Node = node.d2 as ref parser.Node
                    if cexpr != 0 as ref parser.Node {
                        val const_key: ref char = @alloc(512) as ref char
                        if str.rchar_cmp(mod_prefix, "") == 0 {
                            @snprintf(const_key, 512, "{s}", {cname})
                        } else {
                            @snprintf(const_key, 512, "{s}__{s}", {mod_prefix, cname})
                        }
                        val static_init: ref char = ll_static_global_init_value(ctx, cexpr)
                        if str.rchar_cmp(static_init, "") != 0 {
                            ll_register_global_const(ctx, const_key, static_init, 0 as ref void)
                            ll_register_module_const(ctx, const_key, static_init)
                            if str.rchar_cmp(mod_prefix, "") != 0 {
                                ll_register_module_const(ctx, cname, static_init)
                            }
                        }
                    }
                } elif k == parser.NK_VAL {
                    val gname: ref char = node.d0 as ref char
                    val gmut: i64 = node.d1 as i64
                    val gty_node: ref parser.Node = node.d2 as ref parser.Node
                    val gexpr: ref parser.Node = node.d3 as ref parser.Node
                    val global_key: ref char = @alloc(512) as ref char
                    if str.rchar_cmp(mod_prefix, "") == 0 {
                        @snprintf(global_key, 512, "{s}", {gname})
                    } else {
                        @snprintf(global_key, 512, "{s}__{s}", {mod_prefix, gname})
                    }
                    val global_ty: mut ref parser.Node = gty_node
                    if global_ty == 0 as ref parser.Node {
                        global_ty = ll_expr_storage_type(ctx, gexpr)
                    }
                    if gexpr != 0 as ref parser.Node && gexpr.kind == parser.NK_LIST_LIT {
                        ll_register_global_list_literal(ctx, global_key, gexpr)
                    }
                    val static_init: ref char = ll_static_global_init_value(ctx, gexpr)
                    if gmut != 0 || str.rchar_cmp(static_init, "") != 0 {
                        val global_init: mut ref char = "0"
                        if str.rchar_cmp(static_init, "") != 0 {
                            global_init = static_init
                        }
                        ll_register_global_const(ctx, global_key, global_init, global_ty as ref void)
                        ll_register_module_const(ctx, global_key, global_init)
                        if str.rchar_cmp(mod_prefix, "") != 0 {
                            ll_register_module_const(ctx, gname, global_init)
                        }
                    }
                } elif k == parser.NK_WHEN_ITEMS {
                    val active_items: ref void = ll_active_when_items(node)
                    if active_items != 0 as ref void {
                        preregister_items(ctx, active_items as list[ref parser.Node], mod_prefix)
                    }
                }
            }
            none => {}
        }
        i++
    }
}


fn gen_items_with_prefix(ctx: mut ref LLCtx, items: list[ref parser.Node], mod_prefix: ref char) void! = {
    preregister_items(ctx, items, mod_prefix)
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_FN {
                    gen_fn_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_EXTERN_FN {
                    gen_extern_fn_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_WHEN_ITEMS {
                    val active_items: ref void = ll_active_when_items(node)
                    if active_items != 0 as ref void {
                        gen_items_with_prefix(ctx, active_items as list[ref parser.Node], mod_prefix)
                    }
                }
            }
            none => {}
        }
        i++
    }
}

fn gen_items_with_prefix_skip_main(ctx: mut ref LLCtx, items: list[ref parser.Node], mod_prefix: ref char) void! = {
    preregister_items(ctx, items, mod_prefix)
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_FN {
                    val fname: ref char = node.d2 as ref char
                    if str.rchar_cmp(fname, "main") != 0 {
                        gen_fn_prefixed(ctx, node, mod_prefix)
                    }
                } elif k == parser.NK_EXTERN_FN {
                    gen_extern_fn_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_WHEN_ITEMS {
                    val active_items: ref void = ll_active_when_items(node)
                    if active_items != 0 as ref void {
                        gen_items_with_prefix_skip_main(ctx, active_items as list[ref parser.Node], mod_prefix)
                    }
                }
            }
            none => {}
        }
        i++
    }
}


fn scan_items_for_usage(ctx: ref LLCtx, items: list[ref parser.Node], mod_prefix: ref char) void! = {
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                if node.kind == parser.NK_FN {
                    val body: ref void = node.d5 as ref void
                    if body != 0 as ref void {
                        scan_stmts_for_calls(ctx, body)
                    }
                } elif node.kind == parser.NK_WHEN_ITEMS {
                    val active_items: ref void = ll_active_when_items(node)
                    if active_items != 0 as ref void {
                        scan_items_for_usage(ctx, active_items as list[ref parser.Node], mod_prefix)
                    }
                }
            }
            none => {}
        }
        i++
    }
}

fn scan_stmts_for_calls(ctx: ref LLCtx, stmts: ref void) void! = {
    if stmts == 0 as ref void { return }
    val slen: i64 = @len(stmts as list[ref parser.Node]) as i64
    val si: mut i64 = 0
    for {
        if si >= slen { break }
        val s_opt = @get(stmts as list[ref parser.Node], si as usize)
        match s_opt {
            some s => { scan_node_for_calls(ctx, s as ref parser.Node) }
            none => {}
        }
        si++
    }
}

fn scan_node_for_calls(ctx: ref LLCtx, node: ref parser.Node) void! = {
    if node == 0 as ref parser.Node { return }
    val k: i64 = node.kind
    if k == parser.NK_CALL {
        val callee: ref parser.Node = parser.call_callee(node)
        val cn: ref char = resolve_callee_name(callee)
        val resolved: ref char = ll_resolve_fn_name(ctx, cn)
        if resolved != 0 as ref char {
            val prefix: ref char = extract_call_prefix(resolved, cn)
            if str.rchar_cmp(prefix, "") != 0 {
                ll_mark_prefix_used(ctx, prefix)
            }
        }
        val args: ref void = parser.call_args(node) as ref void
        if args != 0 as ref void {
            val alen: i64 = @len(args as list[ref parser.Node]) as i64
            val ai: mut i64 = 0
            for {
                if ai >= alen { break }
                val arg_opt = @get(args as list[ref parser.Node], ai as usize)
                match arg_opt {
                    some arg => { scan_node_for_calls(ctx, arg as ref parser.Node) }
                    none => {}
                }
                ai++
            }
        }
    } elif k == parser.NK_EXPR_STMT {
        scan_node_for_calls(ctx, node.d0 as ref parser.Node)
    } elif k == parser.NK_DEFER {
        if node.d0 != 0 { scan_stmts_for_calls(ctx, node.d0 as ref void) }
    } elif k == parser.NK_VAL {
        scan_node_for_calls(ctx, node.d3 as ref parser.Node)
    } elif k == parser.NK_IF {
        scan_node_for_calls(ctx, node.d0 as ref parser.Node)
        if node.d1 != 0 { scan_stmts_for_calls(ctx, node.d1 as ref void) }
        if node.d2 != 0 { scan_stmts_for_calls(ctx, node.d2 as ref void) }
    } elif k == parser.NK_MATCH_UNION {
        val uexpr: ref parser.Node = parser.match_union_expr(node)
        if uexpr != 0 as ref parser.Node { scan_node_for_calls(ctx, uexpr) }
        val uarms: ref void = parser.match_union_arms(node) as ref void
        if uarms != 0 as ref void {
            val ualen: i64 = @len(uarms as list[ref parser.Node]) as i64
            val uai: mut i64 = 0
            for {
                if uai >= ualen { break }
                val uarm_opt = @get(uarms as list[ref parser.Node], uai as usize)
                match uarm_opt {
                    some uarm_val => { scan_stmts_for_calls(ctx, parser.match_union_arm_body(uarm_val as ref parser.Node) as ref void) }
                    none => {}
                }
                uai++
            }
        }
        val uelse: ref parser.Node = parser.match_union_else(node)
        if uelse != 0 as ref parser.Node && uelse.d0 != 0 { scan_stmts_for_calls(ctx, uelse.d0 as ref void) }
    } elif k == parser.NK_MATCH_RES {
        val rexpr: ref parser.Node = parser.match_res_expr(node)
        if rexpr != 0 as ref parser.Node { scan_node_for_calls(ctx, rexpr) }
        val ok_body: ref parser.Node = parser.match_res_ok_body(node)
        if ok_body != 0 as ref parser.Node && ok_body.d0 != 0 { scan_stmts_for_calls(ctx, ok_body.d0 as ref void) }
        val err_body: ref parser.Node = parser.match_res_err_body(node)
        if err_body != 0 as ref parser.Node && err_body.d0 != 0 { scan_stmts_for_calls(ctx, err_body.d0 as ref void) }
    } elif k == parser.NK_MATCH_OPT {
        val mexpr: ref parser.Node = parser.match_opt_expr(node)
        if mexpr != 0 as ref parser.Node { scan_node_for_calls(ctx, mexpr) }
        val some_body: ref parser.Node = parser.match_opt_some_body(node)
        if some_body != 0 as ref parser.Node && some_body.d0 != 0 { scan_stmts_for_calls(ctx, some_body.d0 as ref void) }
        val none_body: ref parser.Node = parser.match_opt_none_body(node)
        if none_body != 0 as ref parser.Node && none_body.d0 != 0 { scan_stmts_for_calls(ctx, none_body.d0 as ref void) }
    } elif k == parser.NK_FOR {
        if node.d1 != 0 { scan_node_for_calls(ctx, node.d1 as ref parser.Node) }
        if node.d2 != 0 { scan_node_for_calls(ctx, node.d2 as ref parser.Node) }
        if node.d3 != 0 { scan_node_for_calls(ctx, node.d3 as ref parser.Node) }
        if node.d4 != 0 { scan_stmts_for_calls(ctx, node.d4 as ref void) }
    } elif k == parser.NK_FORIN {
        if node.d1 != 0 { scan_node_for_calls(ctx, node.d1 as ref parser.Node) }
        if node.d2 != 0 { scan_stmts_for_calls(ctx, node.d2 as ref void) }
    } elif k == parser.NK_ADD_ASSIGN || k == parser.NK_SUB_ASSIGN {
        scan_node_for_calls(ctx, node.d1 as ref parser.Node)
    } elif k == parser.NK_RETURN {
        scan_node_for_calls(ctx, node.d0 as ref parser.Node)
    } elif k == parser.NK_BUILTIN {
        if node.d1 != 0 {
            val args2: ref void = node.d1 as ref void
            val alen2: i64 = @len(args2 as list[ref parser.Node]) as i64
            val ai2: mut i64 = 0
            for {
                if ai2 >= alen2 { break }
                val arg_opt2 = @get(args2 as list[ref parser.Node], ai2 as usize)
                match arg_opt2 {
                    some arg2 => { scan_node_for_calls(ctx, arg2 as ref parser.Node) }
                    none => {}
                }
                ai2++
            }
        }
    } elif k == parser.NK_BINOP {
        scan_node_for_calls(ctx, parser.binop_left(node))
        scan_node_for_calls(ctx, parser.binop_right(node))
    } elif k == parser.NK_UNOP {
        scan_node_for_calls(ctx, parser.unop_inner(node))
    } elif k == parser.NK_ARGS_PACK {
        val args3: ref void = node.d0 as ref void
        if args3 != 0 as ref void {
            val alen3: i64 = @len(args3 as list[ref parser.Node]) as i64
            val ai3: mut i64 = 0
            for {
                if ai3 >= alen3 { break }
                val arg_opt3 = @get(args3 as list[ref parser.Node], ai3 as usize)
                match arg_opt3 {
                    some arg3 => { scan_node_for_calls(ctx, arg3 as ref parser.Node) }
                    none => {}
                }
                ai3++
            }
        }
    } elif k == parser.NK_TRY || k == parser.NK_TRUST || k == parser.NK_CAST || k == parser.NK_ADDR || k == parser.NK_DEREF {
        scan_node_for_calls(ctx, node.d0 as ref parser.Node)
    } elif k == parser.NK_FIELD {
        scan_node_for_calls(ctx, parser.field_base(node))
    }
}

fn extract_call_prefix(mangled: ref char, bare: ref char) ref char! = {
    if str.rchar_cmp(mangled, bare) == 0 { return ll_first_path_segment(bare) }
    if str.len_raw(mangled) > 5 {
        val s0: u8 = @load8(mangled as ref void)
        val s1: u8 = @load8(@ptradd(mangled as ref void, 1))
        val s2: u8 = @load8(@ptradd(mangled as ref void, 2))
        val s3: u8 = @load8(@ptradd(mangled as ref void, 3))
        val s4: u8 = @load8(@ptradd(mangled as ref void, 4))
        if s0 == 115 && s1 == 116 && s2 == 100 && s3 == 95 && s4 == 95 {
            val child_prefix: ref char = ll_first_path_segment(bare)
            if str.rchar_cmp(child_prefix, "") != 0 { return child_prefix }
        }
    }
    val mlen: i64 = str.len_raw(mangled)
    val blen: i64 = str.len_raw(bare)
    if mlen <= blen + 2 { return "" }
    val plen: i64 = mlen - blen - 2
    val prefix: ref char = @alloc(plen + 1) as ref char
    @memcpy(prefix as ref void, mangled as ref void, plen as usize)
    @store8(@ptradd(prefix as ref void, plen), 0)
    return prefix
}

fn gen_test_fn(ctx: mut ref LLCtx, body: ref parser.Node, id: i64) void! = {
    ctx.tmp = 0
    ctx.current_is_main = false
    ctx.current_ret_abi = "void"
    ll_clear_locals(ctx)
    ll_defer_clear(ctx)
    val hdr: ref char = @alloc(128) as ref char
    @snprintf(hdr, 128, "define void @__sx_test_{lld}() {\n", {id})
    emit(ctx, hdr)
    @free(hdr)
    emitln(ctx, "entry:")
    gen_stmts(ctx, body)
    ll_emit_defers(ctx)
    emitln(ctx, "  ret void")
    emitln(ctx, "}")
    emitln(ctx, "")
}

fn gen_test_main(ctx: ref LLCtx, test_ids: list[i64]) void! = {
    ensure_declared(ctx, "printf", "declare i32 @printf(ptr, ...)")
    if !ctx.release_mode {
        ensure_declared(ctx, "__sx_panic_init", "declare void @__sx_panic_init()")
    }
    emitln(ctx, "define i32 @main(i32 %argc, ptr %argv) {")
    emitln(ctx, "entry:")
    if !ctx.release_mode {
        emitln(ctx, "  call void @__sx_panic_init()")
    }
    emitln(ctx, "  %t.argc = sext i32 %argc to i64")
    emitln(ctx, "  store i64 %t.argc, ptr @sx_argc_store")
    emitln(ctx, "  store ptr %argv, ptr @sx_argv_store")
    val tlen: i64 = @len(test_ids) as i64
    val ti: mut i64 = 0
    for {
        if ti >= tlen { break }
        val t_opt = @get(test_ids, ti as usize)
        match t_opt {
            some id => {
                val call: ref char = @alloc(64) as ref char
                @snprintf(call, 64, "  call void @__sx_test_{lld}()\n", {id as i64})
                emit(ctx, call)
                @free(call)
            }
            none => {}
        }
        ti++
    }
    val ok_idx: i64 = intern_string(ctx, "all tests passed\n")
    val ok_tmp: i64 = fresh_tmp(ctx)
    val ok_call_tmp: i64 = fresh_tmp(ctx)
    val ok_buf: ref char = @alloc(160) as ref char
    @snprintf(ok_buf, 160, "  %%t{lld} = getelementptr [18 x i8], ptr @__str{lld}, i64 0, i64 0\n  %%t{lld} = call i32 (ptr, ...) @printf(ptr %%t{lld})\n  ret i32 0\n}\n\n", {ok_tmp, ok_idx, ok_call_tmp, ok_tmp})
    emit(ctx, ok_buf)
    @free(ok_buf)
}


pub fn gen_module_resolved(root: ref module.ResolvedModule, release_mode: bool) ref char! = {
    val ctx: mut ref LLCtx = ll_new()
    ctx.release_mode = release_mode
    val root_prefix: ref char = ll_root_prefix(root)

    val out_prefixes: list[ref char] = []
    val out_items:    list[ref void] = []
    val seen:         list[String] = []

    module.flatten_modules(root, "", out_prefixes, out_items, seen)

    val layers: i64 = @len(out_prefixes) as i64

    ll_mark_prefix_used(ctx, "")

    val li: mut i64 = 0
    for {
        if li >= layers { break }
        val pfx_opt = @get(out_prefixes, li as usize)
        val items_opt = @get(out_items, li as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some items_ptr => {
                        val effective_pfx: ref char = ll_effective_prefix(root_prefix, pfx as ref char)
                        preregister_items(ctx, items_ptr as list[ref parser.Node], effective_pfx)
                        if str.rchar_cmp(pfx as ref char, "") == 0 {
                            scan_items_for_usage(ctx, items_ptr as list[ref parser.Node], "")
                        }
                    }
                    none => {}
                }
            }
            none => {}
        }
        li++
    }

    val scan_pass: mut i64 = 0
    for {
        if scan_pass >= 10 { break }
        scan_pass++
        val li_s: mut i64 = 0
        for {
            if li_s >= layers { break }
            val pfx_opt = @get(out_prefixes, li_s as usize)
            val items_opt = @get(out_items, li_s as usize)
            match pfx_opt {
                some pfx => {
                    val effective_pfx: ref char = ll_effective_prefix(root_prefix, pfx as ref char)
                    if ll_is_prefix_used(ctx, effective_pfx) {
                        match items_opt {
                            some items_ptr => {
                                scan_items_for_usage(ctx, items_ptr as list[ref parser.Node], effective_pfx)
                            }
                            none => {}
                        }
                    }
                }
                none => {}
            }
            li_s++
        }
    }

    // Propagate std child prefixes
    if ll_is_prefix_used(ctx, "std") {
        val li_std: mut i64 = 0
        for {
            if li_std >= layers { break }
            val pfx_opt = @get(out_prefixes, li_std as usize)
            match pfx_opt {
                some pfx => {
                    for scn in get_std_child_names() {
                        val effective_pfx: ref char = ll_effective_prefix(root_prefix, pfx as ref char)
                        if str.rchar_cmp(effective_pfx, scn) == 0 {
                            ll_mark_prefix_used(ctx, effective_pfx)
                            break
                        }
                    }
                }
                none => {}
            }
            li_std++
        }
    }

    val li2: mut i64 = 0
    for {
        if li2 >= layers { break }
        val pfx_opt = @get(out_prefixes, li2 as usize)
        val items_opt = @get(out_items, li2 as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some items_ptr => {
                        val is_root: bool = str.rchar_cmp(pfx as ref char, "") == 0
                        val effective_pfx: ref char = ll_effective_prefix(root_prefix, pfx as ref char)
                        val is_used: bool = ll_is_prefix_used(ctx, effective_pfx)
                        if is_root || is_used {
                            gen_items_with_prefix(ctx, items_ptr as list[ref parser.Node], effective_pfx)
                        }
                    }
                    none => {}
                }
            }
            none => {}
        }
        li2++
    }

    ensure_declared(ctx, "malloc", "declare ptr @malloc(i64)")
    val final_sb: ref void = str.StringBuilder.new()

    str.StringBuilder.append_cstr(final_sb, "@sx_argc_store = global i64 0\n")
    str.StringBuilder.append_cstr(final_sb, "@sx_argv_store = global ptr null\n\n")
    val gc_len: i64 = @len(ctx.gc_names) as i64
    val gc_i: mut i64 = 0
    for {
        if gc_i >= gc_len { break }
        val n_opt = @get(ctx.gc_names, gc_i as usize)
        val v_opt = @get(ctx.gc_vals, gc_i as usize)
        match n_opt {
            some n => {
                match v_opt {
                    some v => {
                        val gbuf: ref char = @alloc(256) as ref char
                        val gty: ref parser.Node = ll_lookup_global_type(ctx, n as ref char)
                        val list_expr: ref parser.Node = ll_lookup_global_list_literal(ctx, n as ref char)
                        if list_expr != 0 as ref parser.Node {
                            if ll_emit_global_list_literal(final_sb, ctx, n as ref char, gty, list_expr) {
                                @free(gbuf)
                                gc_i++
                                continue
                            }
                        }
                        val ginit: mut ref char = v as ref char
                        val gabi: ref char = ll_type_of(gty)
                        if ll_slot_is_ptr(ctx, gty) && str.rchar_cmp(ginit, "0") == 0 {
                            ginit = "null"
                        }
                        @snprintf(gbuf, 256, "@{s} = global {s} {s}\n", {n as ref char, gabi, ginit})
                        str.StringBuilder.append_cstr(final_sb, gbuf)
                        @free(gbuf)
                    }
                    none => {}
                }
            }
            none => {}
        }
        gc_i++
    }
    if gc_len > 0 { str.StringBuilder.append_char(final_sb, 10) }
    str.StringBuilder.append_cstr(final_sb,
        \\define ptr @__sx_get_args() {
        \\entry:
        \\  %argc = load i64, ptr @sx_argc_store
        \\  %argv = load ptr, ptr @sx_argv_store
        \\  %hdr = call ptr @malloc(i64 24)
        \\  %cap = mul i64 %argc, 8
        \\  %buf = call ptr @malloc(i64 %cap)
        \\  store ptr %buf, ptr %hdr
        \\  %len_slot = getelementptr i8, ptr %hdr, i64 8
        \\  store i64 0, ptr %len_slot
        \\  %cap_slot = getelementptr i8, ptr %hdr, i64 16
        \\  store i64 %argc, ptr %cap_slot
        \\  br label %args_loop
        \\
        \\args_loop:
        \\  %i = phi i64 [0, %entry], [%next_i, %args_body]
        \\  %done = icmp sge i64 %i, %argc
        \\  br i1 %done, label %args_done, label %args_body
        \\
        \\args_body:
        \\  %off = mul i64 %i, 8
        \\  %slot = getelementptr i8, ptr %argv, i64 %off
        \\  %str = load ptr, ptr %slot
        \\  %cur_len = load i64, ptr %len_slot
        \\  %boff = mul i64 %cur_len, 8
        \\  %bslot = getelementptr i8, ptr %buf, i64 %boff
        \\  store ptr %str, ptr %bslot
        \\  %new_len = add i64 %cur_len, 1
        \\  store i64 %new_len, ptr %len_slot
        \\  %next_i = add i64 %i, 1
        \\  br label %args_loop
        \\
        \\args_done:
        \\  ret ptr %hdr
        \\}
        \\
    )

    val decl_str: ref void = str.StringBuilder.build(ctx.decl_sb)
    val decl_cstr: ref char = str.cstr(decl_str)
    if str.len_raw(decl_cstr) > 0 {
        str.StringBuilder.append_cstr(final_sb, decl_cstr)
        str.StringBuilder.append_char(final_sb, 10)
    }

    val str_sb: ref void = str.StringBuilder.new()
    val old_sb: ref void = ctx.sb
    ctx.sb = str_sb
    emit_string_data(ctx)
    ctx.sb = old_sb
    val str_str: ref void = str.StringBuilder.build(str_sb)
    val str_cstr: ref char = str.cstr(str_str)
    if str.len_raw(str_cstr) > 0 {
        str.StringBuilder.append_cstr(final_sb, str_cstr)
        str.StringBuilder.append_char(final_sb, 10)
    }
    str.StringBuilder.free(str_sb)

    val fn_str: ref void = str.StringBuilder.build(ctx.fn_sb)
    str.StringBuilder.append_cstr(final_sb, str.cstr(fn_str))

    val result: ref char = str.cstr(str.StringBuilder.build(final_sb))
    str.StringBuilder.free(final_sb)
    return result
}

pub fn gen_module_resolved_test(root: ref module.ResolvedModule, release_mode: bool) ref char! = {
    val ctx: mut ref LLCtx = ll_new()
    ctx.release_mode = release_mode
    val root_prefix: ref char = ll_root_prefix(root)

    val out_prefixes: list[ref char] = []
    val out_items:    list[ref void] = []
    val seen:         list[String] = []

    module.flatten_modules(root, "", out_prefixes, out_items, seen)

    val layers: i64 = @len(out_prefixes) as i64
    ll_mark_prefix_used(ctx, "")

    val root_imports: list[ref char] = root.import_names
    val rimp_len: i64 = @len(root_imports) as i64
    val ri_idx: mut i64 = 0
    for {
        if ri_idx >= rimp_len { break }
        val imp_opt = @get(root_imports, ri_idx as usize)
        match imp_opt {
            some imp_name => { ll_mark_prefix_used(ctx, imp_name as ref char) }
            none => {}
        }
        ri_idx++
    }

    val li: mut i64 = 0
    for {
        if li >= layers { break }
        val pfx_opt = @get(out_prefixes, li as usize)
        val items_opt = @get(out_items, li as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some items_ptr => {
                        val effective_pfx: ref char = ll_effective_prefix(root_prefix, pfx as ref char)
                        preregister_items(ctx, items_ptr as list[ref parser.Node], effective_pfx)
                    }
                    none => {}
                }
            }
            none => {}
        }
        li++
    }

    val test_ids: mut list[i64] = []
    val test_counter: mut i64 = 0
    val root_items: list[ref parser.Node] = root.items
    val rlen: i64 = @len(root_items) as i64
    val ri: mut i64 = 0
    for {
        if ri >= rlen { break }
        val item_opt = @get(root_items, ri as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                if node.kind == parser.NK_TEST {
                    val body: ref void = node.d0 as ref void
                    if body != 0 as ref void {
                        scan_stmts_for_calls(ctx, body)
                    }
                }
            }
            none => {}
        }
        ri++
    }

    val scan_pass: mut i64 = 0
    for {
        if scan_pass >= 10 { break }
        scan_pass++
        val li_s: mut i64 = 0
        for {
            if li_s >= layers { break }
            val pfx_opt = @get(out_prefixes, li_s as usize)
            val items_opt = @get(out_items, li_s as usize)
            match pfx_opt {
                some pfx => {
                    val effective_pfx: ref char = ll_effective_prefix(root_prefix, pfx as ref char)
                    if ll_is_prefix_used(ctx, effective_pfx) {
                        match items_opt {
                            some items_ptr => {
                                scan_items_for_usage(ctx, items_ptr as list[ref parser.Node], effective_pfx)
                            }
                            none => {}
                        }
                    }
                }
                none => {}
            }
            li_s++
        }
    }

    if ll_is_prefix_used(ctx, "std") {
        val li_std: mut i64 = 0
        for {
            if li_std >= layers { break }
            val pfx_opt = @get(out_prefixes, li_std as usize)
            match pfx_opt {
                some pfx => {
                    val effective_pfx: ref char = ll_effective_prefix(root_prefix, pfx as ref char)
                    if ll_is_std_child_name(effective_pfx) {
                        ll_mark_prefix_used(ctx, effective_pfx)
                    }
                }
                none => {}
            }
            li_std++
        }
    }

    val li2: mut i64 = 0
    for {
        if li2 >= layers { break }
        val pfx_opt = @get(out_prefixes, li2 as usize)
        val items_opt = @get(out_items, li2 as usize)
        match pfx_opt {
            some pfx => {
                val is_root: bool = str.rchar_cmp(pfx as ref char, "") == 0
                val effective_pfx: ref char = ll_effective_prefix(root_prefix, pfx as ref char)
                val is_used: bool = ll_is_prefix_used(ctx, effective_pfx)
                match items_opt {
                    some items_ptr => {
                        if is_root || is_used {
                            if is_root {
                                gen_items_with_prefix_skip_main(ctx, items_ptr as list[ref parser.Node], effective_pfx)
                            } else {
                                gen_items_with_prefix(ctx, items_ptr as list[ref parser.Node], effective_pfx)
                            }
                        }
                    }
                    none => {}
                }
            }
            none => {}
        }
        li2++
    }

    val ri2: mut i64 = 0
    for {
        if ri2 >= rlen { break }
        val item_opt = @get(root_items, ri2 as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                if node.kind == parser.NK_TEST {
                    test_counter++
                    @append(test_ids, test_counter)
                    gen_test_fn(ctx, node.d0 as ref parser.Node, test_counter)
                }
            }
            none => {}
        }
        ri2++
    }

    gen_test_main(ctx, test_ids)

    ensure_declared(ctx, "malloc", "declare ptr @malloc(i64)")
    val final_sb: ref void = str.StringBuilder.new()
    str.StringBuilder.append_cstr(final_sb, "@sx_argc_store = global i64 0\n")
    str.StringBuilder.append_cstr(final_sb, "@sx_argv_store = global ptr null\n\n")
    val gc_len: i64 = @len(ctx.gc_names) as i64
    val gc_i: mut i64 = 0
    for {
        if gc_i >= gc_len { break }
        val n_opt = @get(ctx.gc_names, gc_i as usize)
        val v_opt = @get(ctx.gc_vals, gc_i as usize)
        match n_opt {
            some n => {
                match v_opt {
                    some v => {
                        val gbuf: ref char = @alloc(256) as ref char
                        val gty: ref parser.Node = ll_lookup_global_type(ctx, n as ref char)
                        val list_expr: ref parser.Node = ll_lookup_global_list_literal(ctx, n as ref char)
                        if list_expr != 0 as ref parser.Node {
                            if ll_emit_global_list_literal(final_sb, ctx, n as ref char, gty, list_expr) {
                                @free(gbuf)
                                gc_i++
                                continue
                            }
                        }
                        val ginit: mut ref char = v as ref char
                        val gabi: ref char = ll_type_of(gty)
                        if ll_slot_is_ptr(ctx, gty) && str.rchar_cmp(ginit, "0") == 0 {
                            ginit = "null"
                        }
                        @snprintf(gbuf, 256, "@{s} = global {s} {s}\n", {n as ref char, gabi, ginit})
                        str.StringBuilder.append_cstr(final_sb, gbuf)
                        @free(gbuf)
                    }
                    none => {}
                }
            }
            none => {}
        }
        gc_i++
    }
    if gc_len > 0 { str.StringBuilder.append_char(final_sb, 10) }
    str.StringBuilder.append_cstr(final_sb,
        \\define ptr @__sx_get_args() {
        \\entry:
        \\  %argc = load i64, ptr @sx_argc_store
        \\  %argv = load ptr, ptr @sx_argv_store
        \\  %hdr = call ptr @malloc(i64 24)
        \\  %cap = mul i64 %argc, 8
        \\  %buf = call ptr @malloc(i64 %cap)
        \\  store ptr %buf, ptr %hdr
        \\  %len_slot = getelementptr i8, ptr %hdr, i64 8
        \\  store i64 0, ptr %len_slot
        \\  %cap_slot = getelementptr i8, ptr %hdr, i64 16
        \\  store i64 %argc, ptr %cap_slot
        \\  br label %args_loop
        \\
        \\args_loop:
        \\  %i = phi i64 [0, %entry], [%next_i, %args_body]
        \\  %done = icmp sge i64 %i, %argc
        \\  br i1 %done, label %args_done, label %args_body
        \\
        \\args_body:
        \\  %off = mul i64 %i, 8
        \\  %slot = getelementptr i8, ptr %argv, i64 %off
        \\  %str = load ptr, ptr %slot
        \\  %cur_len = load i64, ptr %len_slot
        \\  %boff = mul i64 %cur_len, 8
        \\  %bslot = getelementptr i8, ptr %buf, i64 %boff
        \\  store ptr %str, ptr %bslot
        \\  %new_len = add i64 %cur_len, 1
        \\  store i64 %new_len, ptr %len_slot
        \\  %next_i = add i64 %i, 1
        \\  br label %args_loop
        \\
        \\args_done:
        \\  ret ptr %hdr
        \\}
        \\
    )

    val decl_str: ref void = str.StringBuilder.build(ctx.decl_sb)
    val decl_cstr: ref char = str.cstr(decl_str)
    if str.len_raw(decl_cstr) > 0 {
        str.StringBuilder.append_cstr(final_sb, decl_cstr)
        str.StringBuilder.append_char(final_sb, 10)
    }

    val str_sb: ref void = str.StringBuilder.new()
    val old_sb: ref void = ctx.sb
    ctx.sb = str_sb
    emit_string_data(ctx)
    ctx.sb = old_sb
    val str_str: ref void = str.StringBuilder.build(str_sb)
    val str_cstr: ref char = str.cstr(str_str)
    if str.len_raw(str_cstr) > 0 {
        str.StringBuilder.append_cstr(final_sb, str_cstr)
        str.StringBuilder.append_char(final_sb, 10)
    }
    str.StringBuilder.free(str_sb)

    val fn_str: ref void = str.StringBuilder.build(ctx.fn_sb)
    str.StringBuilder.append_cstr(final_sb, str.cstr(fn_str))

    val result: ref char = str.cstr(str.StringBuilder.build(final_sb))
    str.StringBuilder.free(final_sb)
    return result
}
