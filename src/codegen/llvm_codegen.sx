        val snprintf_tmp: i64 = fresh_tmp(ctx)
        val hdr: ref char = @alloc(256) as ref char
        @snprintf(hdr, 256, "  %%t{lld} = call i32 (ptr, i64, ptr, ...) @snprintf(ptr {s}, i64 {s}, ptr {s}", {snprintf_tmp, sb_arg, ssz, sfmt})
        str.StringBuilder.append_cstr(call_sb, hdr)
        @free(hdr)
        if args != 0 as ref void {
            val salen: i64 = @len(args) as i64
            if salen > 3 {
