val std        = use("std")
val str        = use("std/string")
val reflection = use("std/reflection")
val parser     = use("../ast/parser.sx")
val module     = use("../module/module.sx")

pub type LLCtx = {
    sb: mut ref void
    tmp: mut i64
    lbl: mut i64
    strs: mut list[ref char]
    str_cnt: mut i64
    fn_names: mut list[ref char]
    fn_params: mut list[ref void]
    fn_rets: mut list[ref void]
    ext_names: mut list[ref char]
    ext_syms: mut list[ref char]
    ext_rets: mut list[ref void]
    used_prefixes: mut list[ref char]
    emitted_labels: mut list[ref char]
    release_mode: mut bool
    declared_externs: mut list[ref char]
    decl_sb: mut ref void
    snames: mut list[ref char]
    sfields: mut list[ref void]
    tv_names: mut list[ref char]
    tv_owners: mut list[ref char]
    tv_tags: mut list[i64]
    tv_fields: mut list[ref void]
    mc_names: mut list[ref char]
    mc_vals: mut list[ref char]
    gc_names: mut list[ref char]
    gc_vals: mut list[ref char]
    gc_types: mut list[ref void]
    gl_names: mut list[ref char]
    gl_exprs: mut list[ref void]
    unames: mut list[ref char]
    uvariants: mut list[ref void]
    break_lbl: mut i64
    cont_lbl: mut i64
    defer_stack: mut list[ref void]
    lnames: mut list[ref char]
    lptrs: mut list[ref char]
    ltypes: mut list[ref void]
    current_is_main: mut bool
    current_ret_abi: mut ref char
    current_prefix: mut ref char
}

fn ll_new() ref LLCtx! = {
    val ctx: mut ref LLCtx = @alloc(@sizeof(LLCtx)) as ref LLCtx
    ctx.sb = str.StringBuilder.new()
    ctx.tmp = 0
    ctx.lbl = 0
    ctx.strs = []
    ctx.str_cnt = 0
    ctx.fn_names = []
    ctx.fn_params = []
    ctx.fn_rets = []
    ctx.ext_names = []
    ctx.ext_syms = []
    ctx.ext_rets = []
    ctx.used_prefixes = []
    ctx.emitted_labels = []
    ctx.release_mode = false
    ctx.declared_externs = []
    ctx.decl_sb = str.StringBuilder.new()
    ctx.snames = []
    ctx.sfields = []
    ctx.tv_names = []
    ctx.tv_owners = []
    ctx.tv_tags = []
    ctx.tv_fields = []
    ctx.mc_names = []
    ctx.mc_vals = []
    ctx.gc_names = []
    ctx.gc_vals = []
    ctx.gc_types = []
    ctx.gl_names = []
    ctx.gl_exprs = []
    ctx.unames = []
    ctx.uvariants = []
    ctx.break_lbl = -1
    ctx.cont_lbl = -1
    ctx.defer_stack = []
    ctx.lnames = []
    ctx.lptrs = []
    ctx.ltypes = []
    ctx.current_is_main = false
    ctx.current_ret_abi = "i64"
    ctx.current_prefix = ""
    return ctx
}

fn ll_clear_locals(ctx: mut ref LLCtx) void! = {
    ctx.lnames = []
    ctx.lptrs = []
    ctx.ltypes = []
}

fn ll_break_lbl(ctx: ref LLCtx) i64! = { return ctx.break_lbl }
fn ll_cont_lbl(ctx: ref LLCtx) i64! = { return ctx.cont_lbl }
fn ll_set_break_lbl(ctx: mut ref LLCtx, v: i64) void! = { ctx.break_lbl = v }
fn ll_set_cont_lbl(ctx: mut ref LLCtx, v: i64) void! = { ctx.cont_lbl = v }

fn ll_defer_push(ctx: ref LLCtx, body: ref void) void! = {
    @append(ctx.defer_stack, body)
}

fn ll_defer_clear(ctx: mut ref LLCtx) void! = {
    ctx.defer_stack = []
}

fn ll_emit_defers(ctx: ref LLCtx) void! = {
    val n: i64 = @len(ctx.defer_stack) as i64
    val i: mut i64 = n - 1
    for {
        if i < 0 { break }
        val d_opt = @get(ctx.defer_stack, i as usize)
        match d_opt {
            some d => { gen_stmts(ctx, d as ref parser.Node) }
            none => {}
        }
        i--
    }
}

fn ll_register_local(ctx: ref LLCtx, name: ref char, ptr_name: ref char, ty: ref void) void! = {
    @append(ctx.lnames, name)
    @append(ctx.lptrs, ptr_name)
    @append(ctx.ltypes, ty)
}

fn ll_lookup_local_ptr(ctx: ref LLCtx, name: ref char) ref char! = {
    val len: i64 = @len(ctx.lnames) as i64
    val i: mut i64 = len - 1
    for {
        if i < 0 { break }
        val n_opt = @get(ctx.lnames, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val p_opt = @get(ctx.lptrs, i as usize)
                    match p_opt {
                        some p => { return p as ref char }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i--
    }
    return ""
}

fn ll_lookup_local_type(ctx: ref LLCtx, name: ref char) ref parser.Node! = {
    val len: i64 = @len(ctx.lnames) as i64
    val i: mut i64 = len - 1
    for {
        if i < 0 { break }
        val n_opt = @get(ctx.lnames, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val t_opt = @get(ctx.ltypes, i as usize)
                    match t_opt {
                        some t => { return t as ref parser.Node }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i--
    }
    return 0 as ref parser.Node
}

fn ll_register_module_const(ctx: ref LLCtx, name: ref char, value: ref char) void! = {
    @append(ctx.mc_names, name)
    @append(ctx.mc_vals, value)
}

fn ll_register_global_const(ctx: ref LLCtx, name: ref char, value: ref char, ty: ref void) void! = {
    val len: i64 = @len(ctx.gc_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val n_opt = @get(ctx.gc_names, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 { return }
            }
            none => {}
        }
        i++
    }
    @append(ctx.gc_names, name)
    @append(ctx.gc_vals, value)
    @append(ctx.gc_types, ty)
}

fn ll_register_global_list_literal(ctx: ref LLCtx, name: ref char, expr: ref parser.Node) void! = {
    val len: i64 = @len(ctx.gl_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val n_opt = @get(ctx.gl_names, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 { return }
            }
            none => {}
        }
        i++
    }
    @append(ctx.gl_names, name)
    @append(ctx.gl_exprs, expr as ref void)
}

fn ll_lookup_global_list_literal(ctx: ref LLCtx, name: ref char) ref parser.Node! = {
    val len: i64 = @len(ctx.gl_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val n_opt = @get(ctx.gl_names, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val e_opt = @get(ctx.gl_exprs, i as usize)
                    match e_opt {
                        some e => { return e as ref parser.Node }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return 0 as ref parser.Node
}

fn ll_lookup_module_const(ctx: ref LLCtx, name: ref char) ref char! = {
    val len: i64 = @len(ctx.mc_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val n_opt = @get(ctx.mc_names, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val v_opt = @get(ctx.mc_vals, i as usize)
                    match v_opt {
                        some v => { return v as ref char }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return ""
}

fn ll_lookup_global_type(ctx: ref LLCtx, name: ref char) ref parser.Node! = {
    val len: i64 = @len(ctx.gc_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val n_opt = @get(ctx.gc_names, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val t_opt = @get(ctx.gc_types, i as usize)
                    match t_opt {
                        some t => { return t as ref parser.Node }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return 0 as ref parser.Node
}

fn ll_lookup_module_const_symbol(ctx: ref LLCtx, name: ref char) ref char! = {
    val local_key: ref char = @alloc(512) as ref char
    if str.rchar_cmp(ctx.current_prefix, "") != 0 {
        @snprintf(local_key, 512, "{s}__{s}", {ctx.current_prefix, name})
        if str.rchar_cmp(ll_lookup_module_const(ctx, local_key), "") != 0 {
            return local_key
        }
    }
    @free(local_key)
    if str.rchar_cmp(ll_lookup_module_const(ctx, name), "") != 0 {
        return name
    }
    return ""
}

fn ll_normalize_int_text(text: ref char) ref char! = {
    if text == 0 as ref char { return "0" }
    val start: mut ref char = text
    val sign: mut i64 = 1
    if @load8(start as ref void) == 45 {
        sign = -1
        start = @ptradd(start as ref void, 1) as ref char
    }
    if @load8(start as ref void) == 48 {
        val next: i64 = @load8(@ptradd(start as ref void, 1)) as i64
        if next == 120 || next == 88 {
            val hex_start: ref char = @ptradd(start as ref void, 2) as ref char
            val val_: mut i64 = 0
            val hi: mut i64 = 0
            for {
                val hc: i64 = @load8(@ptradd(hex_start as ref void, hi)) as i64
                if hc == 0 { break }
                val digit: mut i64 = hc - 48
                if hc >= 97 { digit = hc - 87 }
                elif hc >= 65 { digit = hc - 55 }
                val_ = val_ * 16 + digit
                hi++
            }
            if sign < 0 { val_ = 0 - val_ }
            val dec_buf: ref char = @alloc(32) as ref char
            @snprintf(dec_buf, 32, "{lld}", {val_})
            return dec_buf
        }
    }
    return text
}

fn ll_static_global_init_value(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    if expr == 0 as ref parser.Node { return "0" }
    val k: i64 = expr.kind
    if k == parser.NK_INT_LIT {
        return ll_normalize_int_text(parser.int_lit_text(expr))
    }
    if k == parser.NK_BOOL {
        if expr.d0 != 0 { return "1" }
        return "0"
    }
    if k == parser.NK_CHAR_LIT {
        val cv: i64 = expr.d0 as i64
        val cv_buf: ref char = @alloc(32) as ref char
        @snprintf(cv_buf, 32, "{lld}", {cv})
        return cv_buf
    }
    if k == parser.NK_NONE {
        return "null"
    }
    if k == parser.NK_IDENT {
        val cval: ref char = ll_lookup_module_const(ctx, expr.d0 as ref char)
        if str.rchar_cmp(cval, "") != 0 {
            return ll_normalize_int_text(cval)
        }
    }
    if k == parser.NK_UNOP {
        val uop: i64 = parser.unop_op(expr)
        val inner: ref parser.Node = parser.unop_inner(expr)
        if uop == parser.UOP_NEG && inner != 0 as ref parser.Node {
            if inner.kind == parser.NK_INT_LIT {
                val inner_val: ref char = ll_normalize_int_text(parser.int_lit_text(inner))
                val neg_buf: ref char = @alloc(64) as ref char
                @snprintf(neg_buf, 64, "-{s}", {inner_val})
                return neg_buf
            }
        }
    }
    return ""
}

fn ll_emit_global_list_literal(final_sb: ref void, ctx: ref LLCtx, gname: ref char, gty: ref parser.Node, gexpr: ref parser.Node) bool! = {
    if gexpr == 0 as ref parser.Node { return false }
    if gexpr.kind != parser.NK_LIST_LIT { return false }
    val elems: ref void = gexpr.d0 as ref void
    val elen: mut i64 = 0
    if elems != 0 as ref void { elen = @len(elems as list[ref parser.Node]) as i64 }

    val inner_ty: ref parser.Node = ll_list_inner_type(gty)
    val elem_abi: mut ref char = "i64"
    if ll_slot_is_ptr(ctx, inner_ty) { elem_abi = "ptr" }
    val data_name: ref char = @alloc(640) as ref char
    val hdr_name: ref char = @alloc(640) as ref char
    @snprintf(data_name, 640, "{s}__data", {gname})
    @snprintf(hdr_name, 640, "{s}__hdr", {gname})

    val data_buf: ref char = @alloc(2048) as ref char
    val cap: mut i64 = elen
    if cap == 0 { cap = 1 }

    if elen == 0 {
        @snprintf(data_buf, 2048, "@{s} = global [{lld} x {s}] zeroinitializer\n", {data_name, cap, elem_abi})
        str.StringBuilder.append_cstr(final_sb, data_buf)
    } else {
        @snprintf(data_buf, 2048, "@{s} = global [{lld} x {s}] [", {data_name, cap, elem_abi})
        str.StringBuilder.append_cstr(final_sb, data_buf)
        val ei: mut i64 = 0
        for {
            if ei >= elen { break }
            val elem_opt = @get(elems as list[ref parser.Node], ei as usize)
            match elem_opt {
                some elem => {
                    val init_val: ref char = ll_static_global_init_value(ctx, elem as ref parser.Node)
                    if str.rchar_cmp(init_val, "") == 0 {
                        @free(data_buf)
                        @free(data_name)
                        @free(hdr_name)
                        return false
                    }
                    if ei != 0 { str.StringBuilder.append_cstr(final_sb, ", ") }
                    @snprintf(data_buf, 2048, "{s} {s}", {elem_abi, init_val})
                    str.StringBuilder.append_cstr(final_sb, data_buf)
                }
                none => {}
            }
            ei++
        }
        str.StringBuilder.append_cstr(final_sb, "]\n")
    }

    @snprintf(data_buf, 2048, "@{s} = global ", {hdr_name})
    str.StringBuilder.append_cstr(final_sb, data_buf)
    str.StringBuilder.append_cstr(final_sb, "{ ptr, i64, i64 } ")
    str.StringBuilder.append_cstr(final_sb, "{ ptr @")
    str.StringBuilder.append_cstr(final_sb, data_name)
    @snprintf(data_buf, 2048, ", i64 {lld}, i64 {lld} }\n", {elen, cap})
    str.StringBuilder.append_cstr(final_sb, data_buf)
    @snprintf(data_buf, 2048, "@{s} = global ptr @{s}\n", {gname, hdr_name})
    str.StringBuilder.append_cstr(final_sb, data_buf)
    @free(data_buf)
    @free(data_name)
    @free(hdr_name)
    return true
}

fn fresh_tmp(ctx: mut ref LLCtx) i64! = {
    val n: i64 = ctx.tmp
    ctx.tmp = n + 1
    return n
}

fn fresh_lbl(ctx: mut ref LLCtx) i64! = {
    val n: i64 = ctx.lbl
    ctx.lbl = n + 1
    return n
}

fn emit(ctx: ref LLCtx, s: ref char) void! = {
    str.StringBuilder.append_cstr(ctx.sb, s)
}

fn emitln(ctx: ref LLCtx, s: ref char) void! = {
    str.StringBuilder.append_cstr(ctx.sb, s)
    str.StringBuilder.append_char(ctx.sb, 10)
}

fn emit_decl(ctx: ref LLCtx, s: ref char) void! = {
    str.StringBuilder.append_cstr(ctx.decl_sb, s)
    str.StringBuilder.append_char(ctx.decl_sb, 10)
}

fn ensure_declared(ctx: ref LLCtx, name: ref char, decl: ref char) void! = {
    val nlen: i64 = @len(ctx.declared_externs) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.declared_externs, ni as usize)
        match n_opt {
            some n => { if str.rchar_cmp(n as ref char, name) == 0 { return } }
            none => {}
        }
        ni++
    }
    @append(ctx.declared_externs, name)
    emit_decl(ctx, decl)
}

fn intern_string(ctx: mut ref LLCtx, s: ref char) i64! = {
    val len: i64 = @len(ctx.strs) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(ctx.strs, i as usize)
        match s_opt {
            some existing => {
                if str.rchar_cmp(existing as ref char, s) == 0 { return i }
            }
            none => {}
        }
        i++
    }
    val slen: i64 = str.len_raw(s)
    val scopy: ref char = @alloc(slen + 1) as ref char
    @memcpy(scopy as ref void, s as ref void, slen + 1)
    @append(ctx.strs, scopy)
    val idx: i64 = ctx.str_cnt
    ctx.str_cnt = idx + 1
    return idx
}

fn emit_string_data(ctx: ref LLCtx) void! = {
    val len: i64 = @len(ctx.strs) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(ctx.strs, i as usize)
        match s_opt {
            some s => {
                val sptr: ref char = s as ref char
                val slen: i64 = str.len_raw(sptr)
                val arr_len: i64 = slen + 1
                val buf: ref char = @alloc(64) as ref char
                @snprintf(buf, 64, "@__str{lld} = private global [{lld} x i8] c\"", {i, arr_len})
                emit(ctx, buf)
                @free(buf)
                val j: mut i64 = 0
                for {
                    val c: u8 = @load8(@ptradd(sptr as ref void, j))
                    if c == 0 { break }
                    if c == 10 { emit(ctx, "\\0A") }
                    elif c == 9 { emit(ctx, "\\09") }
                    elif c == 13 { emit(ctx, "\\0D") }
                    elif c == 34 { emit(ctx, "\\22") }
                    elif c == 92 { emit(ctx, "\\5C") }
                    else {
                        val cb: ref char = @alloc(2) as ref char
                        @store8(cb as ref void, c)
                        @store8(@ptradd(cb as ref void, 1), 0)
                        emit(ctx, cb)
                        @free(cb)
                    }
                    j++
                }
                emitln(ctx, "\\00\"")
            }
            none => {}
        }
        i++
    }
}


fn platform_matches(name: ref char) bool! = {
    val cur: ref char = reflection.current_platform_name()
    if str.rchar_cmp(name, cur) == 0 { return true }
    if str.rchar_cmp(name, "posix") == 0 {
        if str.rchar_cmp(cur, "linux")   == 0 { return true }
        if str.rchar_cmp(cur, "darwin")  == 0 { return true }
        if str.rchar_cmp(cur, "freebsd") == 0 { return true }
        if str.rchar_cmp(cur, "openbsd") == 0 { return true }
        if str.rchar_cmp(cur, "netbsd")  == 0 { return true }
    }
    return false
}

fn ll_active_when_items(node: ref parser.Node) ref void! = {
    if node == 0 as ref parser.Node || node.kind != parser.NK_WHEN_ITEMS {
        return 0 as ref void
    }
    val plat: ref char = node.d0 as ref char
    if platform_matches(plat) {
        return node.d1 as ref void
    }
    val or_when_branches: ref void = node.d2 as ref void
    if or_when_branches != 0 as ref void {
        val ow_len: i64 = @len(or_when_branches as list[ref parser.Node]) as i64
        val ow_i: mut i64 = 0
        for {
            if ow_i >= ow_len { break }
            val ow_opt = @get(or_when_branches as list[ref parser.Node], ow_i as usize)
            match ow_opt {
                some ow_val => {
                    val ow: ref parser.Node = ow_val as ref parser.Node
                    val ow_plat: ref char = ow.d0 as ref char
                    if platform_matches(ow_plat) {
                        return ow.d1 as ref void
                    }
                }
                none => {}
            }
            ow_i++
        }
    }
    val otherwise_items: ref void = node.d3 as ref void
    if otherwise_items != 0 as ref void {
        return otherwise_items
    }
    return 0 as ref void
}


fn ll_mark_prefix_used(ctx: ref LLCtx, prefix: ref char) void! = {
    val nlen: i64 = @len(ctx.used_prefixes) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.used_prefixes, ni as usize)
        match n_opt {
            some n => { if str.rchar_cmp(n as ref char, prefix) == 0 { return } }
            none => {}
        }
        ni++
    }
    @append(ctx.used_prefixes, prefix)
}

fn ll_is_prefix_used(ctx: ref LLCtx, prefix: ref char) bool! = {
    val nlen: i64 = @len(ctx.used_prefixes) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.used_prefixes, ni as usize)
        match n_opt {
            some n => { if str.rchar_cmp(n as ref char, prefix) == 0 { return true } }
            none => {}
        }
        ni++
    }
    return false
}

fn ll_emit_label_if_new(ctx: ref LLCtx, label: ref char) bool! = {
    val elen: i64 = @len(ctx.emitted_labels) as i64
    val ei: mut i64 = 0
    for {
        if ei >= elen { break }
        val e_opt = @get(ctx.emitted_labels, ei as usize)
        match e_opt {
            some e => { if str.rchar_cmp(e as ref char, label) == 0 { return false } }
            none => {}
        }
        ei++
    }
    @append(ctx.emitted_labels, label)
    return true
}


fn ll_register_fn(ctx: ref LLCtx, mangled: ref char, params: ref void, ret_ty: ref void) void! = {
    @append(ctx.fn_names, mangled)
    @append(ctx.fn_params, params)
    @append(ctx.fn_rets, ret_ty)
}

fn ll_resolve_fn_name(ctx: ref LLCtx, name: ref char) ref char! = {
    val nlen: i64 = @len(ctx.fn_names) as i64
    val namelen: i64 = str.len_raw(name)
    val suffix: ref char = @alloc(namelen + 3) as ref char
    @snprintf(suffix, namelen + 3, "__{s}", {name})
    val ni: mut i64 = 0
    val found: mut ref char = 0 as ref char
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.fn_names, ni as usize)
        match n_opt {
            some n => {
                val candidate: ref char = n as ref char
                if str.rchar_cmp(candidate, name) == 0 {
                    @free(suffix)
                    return candidate
                }
                val clen: i64 = str.len_raw(candidate)
                val slen: i64 = namelen + 2
                if clen > slen {
                    val tail: ref char = @ptradd(candidate as ref void, clen - slen) as ref char
                    if str.rchar_cmp(tail, suffix) == 0 { found = candidate }
                }
            }
            none => {}
        }
        ni++
    }
    @free(suffix)
    return found
}

fn ll_register_extern(ctx: ref LLCtx, name: ref char, symbol: ref char, ret_ty: ref void) void! = {
    @append(ctx.ext_names, name)
    @append(ctx.ext_syms, symbol)
    @append(ctx.ext_rets, ret_ty)
}

fn ll_lookup_extern_symbol(ctx: ref LLCtx, name: ref char) ref char! = {
    val nlen: i64 = @len(ctx.ext_names) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.ext_names, ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val s_opt = @get(ctx.ext_syms, ni as usize)
                    match s_opt {
                        some s => { return s as ref char }
                        none   => { return 0 as ref char }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    val namelen: i64 = str.len_raw(name)
    val ni2: mut i64 = 0
    for {
        if ni2 >= nlen { break }
        val n_opt = @get(ctx.ext_names, ni2 as usize)
        match n_opt {
            some n => {
                val candidate: ref char = n as ref char
                val clen: i64 = str.len_raw(candidate)
                if namelen > clen {
                    val suffix_pos: i64 = namelen - clen
                    val sc: u8 = @load8(@ptradd(name as ref void, suffix_pos - 1))
                    if sc == 95 {
                        val rest: ref char = @ptradd(name as ref void, suffix_pos) as ref char
                        if str.rchar_cmp(rest, candidate) == 0 {
                            val s_opt = @get(ctx.ext_syms, ni2 as usize)
                            match s_opt {
                                some s => { return s as ref char }
                                none => {}
                            }
                        }
                    }
                }
            }
            none => {}
        }
        ni2++
    }
    return 0 as ref char
}

fn ll_lookup_extern_ret(ctx: ref LLCtx, name: ref char) ref parser.Node! = {
    val nlen: i64 = @len(ctx.ext_names) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.ext_names, ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val r_opt = @get(ctx.ext_rets, ni as usize)
                    match r_opt {
                        some r => { return r as ref parser.Node }
                        none => {}
                    }
                }
            }
            none => {}
        }
        ni++
    }
    val ni2: mut i64 = 0
    for {
        if ni2 >= nlen { break }
        val s_opt = @get(ctx.ext_syms, ni2 as usize)
        match s_opt {
            some s => {
                if str.rchar_cmp(s as ref char, name) == 0 {
                    val r_opt = @get(ctx.ext_rets, ni2 as usize)
                    match r_opt {
                        some r => { return r as ref parser.Node }
                        none => {}
                    }
                }
            }
            none => {}
        }
        ni2++
    }
    val namelen: i64 = str.len_raw(name)
    val ni3: mut i64 = 0
    for {
        if ni3 >= nlen { break }
        val n_opt = @get(ctx.ext_names, ni3 as usize)
        match n_opt {
            some n => {
                val candidate: ref char = n as ref char
                val clen: i64 = str.len_raw(candidate)
                if namelen > clen {
                    val suffix_pos: i64 = namelen - clen
                    val sc: u8 = @load8(@ptradd(name as ref void, suffix_pos - 1))
                    if sc == 95 {
                        val rest: ref char = @ptradd(name as ref void, suffix_pos) as ref char
                        if str.rchar_cmp(rest, candidate) == 0 {
                            val r_opt = @get(ctx.ext_rets, ni3 as usize)
                            match r_opt {
                                some r => { return r as ref parser.Node }
                                none => {}
                            }
                        }
                    }
                }
            }
            none => {}
        }
        ni3++
    }
    return 0 as ref parser.Node
}

fn ll_type_of(ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return "i64" }
    val k: i64 = ty.kind
    if k == parser.TY_VOID   { return "i32" }
    if k == parser.TY_MUT    { return ll_type_of(ty.d0 as ref parser.Node) }
    if k == parser.TY_REF    { return "ptr" }
    if k == parser.TY_OPTION { return "i64" }
    if k == parser.TY_LIST   { return "ptr" }
    if k == parser.TY_RESULT { return "ptr" }
    if k == parser.TY_FNPTR  { return "ptr" }
    if k == parser.TY_NAMED {
        val name: ref char = ty.d0 as ref char
        if str.rchar_cmp(name, "i32") == 0 || str.rchar_cmp(name, "u32") == 0 { return "i32" }
        if str.rchar_cmp(name, "bool") == 0 { return "i32" }
        if str.rchar_cmp(name, "f64") == 0 { return "double" }
        if str.rchar_cmp(name, "f32") == 0 { return "float" }
        return "i64"
    }
    return "i64"
}

fn ll_lookup_struct(ctx: ref LLCtx, type_name: ref char) ref void! = {
    val len: i64 = @len(ctx.snames) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val n_opt = @get(ctx.snames, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, type_name) == 0 {
                    val f_opt = @get(ctx.sfields, i as usize)
                    match f_opt {
                        some f => { return f as ref void }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return 0 as ref void
}

fn ll_register_union(ctx: ref LLCtx, union_name: ref char, variants: ref void) void! = {
    @append(ctx.unames, union_name)
    @append(ctx.uvariants, variants)
}

fn ll_lookup_union(ctx: ref LLCtx, union_name: ref char) ref void! = {
    val len: i64 = @len(ctx.unames) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val n_opt = @get(ctx.unames, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, union_name) == 0 {
                    val v_opt = @get(ctx.uvariants, i as usize)
                    match v_opt {
                        some v => { return v as ref void }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return 0 as ref void
}

fn ll_lookup_union_suffix(ctx: ref LLCtx, type_name: ref char) ref void! = {
    val exact: ref void = ll_lookup_union(ctx, type_name)
    if exact != 0 as ref void { return exact }
    val nlen: i64 = @len(ctx.unames) as i64
    val tlen: i64 = str.len_raw(type_name)
    val suffix_len: i64 = tlen + 2
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.unames, ni as usize)
        match n_opt {
            some n => {
                val candidate: ref char = n as ref char
                val clen: i64 = str.len_raw(candidate)
                if clen > suffix_len {
                    val tail: ref char = @ptradd(candidate as ref void, clen - suffix_len) as ref char
                    val c1: u8 = @load8(tail as ref void)
                    val c2: u8 = @load8(@ptradd(tail as ref void, 1))
                    if c1 == 95 && c2 == 95 {
                        val rest: ref char = @ptradd(tail as ref void, 2) as ref char
                        if str.rchar_cmp(rest, type_name) == 0 {
                            val v_opt = @get(ctx.uvariants, ni as usize)
                            match v_opt { some v => { return v as ref void } none => {} }
                        }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref void
}

fn ll_lookup_tv(ctx: ref LLCtx, vname: ref char, out_owner: ref void, out_field_ty: ref void) i64! = {
    val nlen: i64 = @len(ctx.tv_names) as i64
    val vlen: i64 = str.len_raw(vname)
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.tv_names, ni as usize)
        match n_opt {
            some n => {
                val candidate: ref char = n as ref char
                val matched: mut bool = str.rchar_cmp(candidate, vname) == 0
                if !matched {
                    val clen: i64 = str.len_raw(candidate)
                    if vlen > clen + 2 {
                        val suffix_pos: i64 = vlen - clen
                        val s0: u8 = @load8(@ptradd(vname as ref void, suffix_pos - 2))
                        val s1: u8 = @load8(@ptradd(vname as ref void, suffix_pos - 1))
                        if s0 == 95 && s1 == 95 {
                            val tail: ref char = @ptradd(vname as ref void, suffix_pos) as ref char
                            matched = str.rchar_cmp(candidate, tail) == 0
                        }
                    }
                }
                if matched {
                    val tag_opt = @get(ctx.tv_tags, ni as usize)
                    val owner_opt = @get(ctx.tv_owners, ni as usize)
                    val field_opt = @get(ctx.tv_fields, ni as usize)
                    match tag_opt {
                        some tag => {
                            match owner_opt {
                                some owner => { @store(out_owner, owner as usize) }
                                none => {}
                            }
                            match field_opt {
                                some field => { @store(out_field_ty, field as usize) }
                                none => {}
                            }
                            return tag as i64
                        }
                        none => {}
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return -1
}

fn ll_is_tagged_union_name(ctx: ref LLCtx, name: ref char) bool! = {
    val nlen: i64 = @len(ctx.tv_owners) as i64
    val name_len: i64 = str.len_raw(name)
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val owner_opt = @get(ctx.tv_owners, ni as usize)
        match owner_opt {
            some owner => {
                val owner_name: ref char = owner as ref char
                if str.rchar_cmp(owner_name, name) == 0 {
                    return true
                }
                val owner_len: i64 = str.len_raw(owner_name)
                if name_len > owner_len {
                    val tail: ref char = @ptradd(name as ref void, name_len - owner_len) as ref char
                    if str.rchar_cmp(tail, owner_name) == 0 {
                        val sep_pos: i64 = name_len - owner_len - 1
                        val sep: u8 = @load8(@ptradd(name as ref void, sep_pos))
                        if sep == 46 {
                            return true
                        }
                        if sep_pos >= 1 {
                            val sep_prev: u8 = @load8(@ptradd(name as ref void, sep_pos - 1))
                            if sep_prev == 95 && sep == 95 {
                                return true
                            }
                        }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return false
}

fn ll_is_union_type(ctx: ref LLCtx, ty: ref parser.Node) bool! = {
    if ty == 0 as ref parser.Node { return false }
    val k: i64 = ty.kind
    if k == parser.TY_MUT { return ll_is_union_type(ctx, ty.d0 as ref parser.Node) }
    if k == parser.TY_NAMED {
        return ll_lookup_union_suffix(ctx, ty.d0 as ref char) != 0 as ref void
    }
    return false
}

fn ll_unwrap_named_type(ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return "" }
    val k: i64 = ty.kind
    if k == parser.TY_MUT { return ll_unwrap_named_type(ty.d0 as ref parser.Node) }
    if k == parser.TY_REF { return ll_unwrap_named_type(ty.d0 as ref parser.Node) }
    if k == parser.TY_NAMED { return ty.d0 as ref char }
    return ""
}

fn ll_struct_type_name(ctx: ref LLCtx, ty: ref parser.Node) ref char! = {
    val tname: ref char = ll_unwrap_named_type(ty)
    if str.rchar_cmp(tname, "") == 0 { return "" }
    if ll_lookup_struct(ctx, tname) != 0 as ref void { return tname }
    return ""
}

fn ll_slot_is_ptr(ctx: ref LLCtx, ty: ref parser.Node) bool! = {
    if ty == 0 as ref parser.Node { return false }
    val k: i64 = ty.kind
    if k == parser.TY_MUT { return ll_slot_is_ptr(ctx, ty.d0 as ref parser.Node) }
    if k == parser.TY_REF || k == parser.TY_LIST || k == parser.TY_RESULT || k == parser.TY_FNPTR { return true }
    if k == parser.TY_NAMED {
        val name: ref char = ty.d0 as ref char
        if ll_is_tagged_union_name(ctx, name) { return true }
        if ll_lookup_union_suffix(ctx, name) != 0 as ref void { return true }
        if ll_lookup_struct(ctx, name) != 0 as ref void { return true }
    }
    return false
}

fn ll_is_unsigned_type(ty: ref parser.Node) bool! = {
    if ty == 0 as ref parser.Node { return false }
    val k: i64 = ty.kind
    if k == parser.TY_MUT { return ll_is_unsigned_type(ty.d0 as ref parser.Node) }
    if k == parser.TY_NAMED {
        val name: ref char = ty.d0 as ref char
        if str.rchar_cmp(name, "u8") == 0 || str.rchar_cmp(name, "u16") == 0 || str.rchar_cmp(name, "u32") == 0 ||
           str.rchar_cmp(name, "bool") == 0 || str.rchar_cmp(name, "char") == 0 {
            return true
        }
    }
    return false
}

fn ll_type_size(ctx: ref LLCtx, ty: ref parser.Node) i64! = {
    if ty == 0 as ref parser.Node { return 8 }
    val k: i64 = ty.kind
    if k == parser.TY_MUT { return ll_type_size(ctx, ty.d0 as ref parser.Node) }
    if k == parser.TY_REF || k == parser.TY_LIST || k == parser.TY_RESULT || k == parser.TY_FNPTR { return 8 }
    if k == parser.TY_NAMED {
        val name: ref char = ty.d0 as ref char
        if ll_is_tagged_union_name(ctx, name) { return 8 }
        if ll_lookup_union_suffix(ctx, name) != 0 as ref void { return 16 }
        if str.rchar_cmp(name, "i8") == 0 || str.rchar_cmp(name, "u8") == 0 || str.rchar_cmp(name, "char") == 0 { return 1 }
        if str.rchar_cmp(name, "i16") == 0 || str.rchar_cmp(name, "u16") == 0 { return 2 }
        if str.rchar_cmp(name, "i32") == 0 || str.rchar_cmp(name, "u32") == 0 || str.rchar_cmp(name, "f32") == 0 { return 4 }
        if str.rchar_cmp(name, "f64") == 0 { return 8 }
        if str.rchar_cmp(name, "bool") == 0 { return 4 }
        if str.rchar_cmp(name, "isize") == 0 || str.rchar_cmp(name, "usize") == 0 { return 8 }
        val fields: ref void = ll_lookup_struct(ctx, name)
        if fields != 0 as ref void { return ll_struct_size(ctx, fields) }
    }
    if k == parser.TY_FIXED_ARR {
        val count: i64 = ty.d0
        val elem_size: i64 = ll_type_size(ctx, ty.d1 as ref parser.Node)
        return count * elem_size
    }
    return 8
}

fn ll_type_align(ty: ref parser.Node) i64! = {
    if ty == 0 as ref parser.Node { return 8 }
    val k: i64 = ty.kind
    if k == parser.TY_MUT { return ll_type_align(ty.d0 as ref parser.Node) }
    if k == parser.TY_NAMED {
        val name: ref char = ty.d0 as ref char
        if str.rchar_cmp(name, "i8") == 0 || str.rchar_cmp(name, "u8") == 0 || str.rchar_cmp(name, "char") == 0 { return 1 }
        if str.rchar_cmp(name, "i16") == 0 || str.rchar_cmp(name, "u16") == 0 { return 2 }
        if str.rchar_cmp(name, "i32") == 0 || str.rchar_cmp(name, "u32") == 0 || str.rchar_cmp(name, "f32") == 0 { return 4 }
        return 8
    }
    if k == parser.TY_FIXED_ARR { return ll_type_align(ty.d1 as ref parser.Node) }
    return 8
}

fn ll_align_to(n: i64, align: i64) i64! = {
    if align <= 1 { return n }
    return (n + align - 1) / align * align
}

fn ll_fields_have_fixed_arr(fields: ref void) bool! = {
    if fields == 0 as ref void { return false }
    val flen: i64 = @len(fields as list[ref void]) as i64
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fty: ref parser.Node = fnode.d2 as ref parser.Node
                if fty != 0 as ref parser.Node && fty.kind == parser.TY_FIXED_ARR { return true }
            }
            none => {}
        }
        fi++
    }
    return false
}

fn ll_aligned_size(size: i64) i64! = {
    val rem: i64 = size % 8
    if rem == 0 { return size }
    return size + (8 - rem)
}

fn ll_struct_size(ctx: ref LLCtx, fields: ref void) i64! = {
    if fields == 0 as ref void { return 0 }
    val flen: i64 = @len(fields as list[ref void]) as i64
    val has_fa: bool = ll_fields_have_fixed_arr(fields)
    val offset: mut i64 = 0
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fty: ref parser.Node = fnode.d2 as ref parser.Node
                if has_fa {
                    offset = ll_align_to(offset, ll_type_align(fty))
                    offset = offset + ll_type_size(ctx, fty)
                } else {
                    offset = offset + ll_aligned_size(ll_type_size(ctx, fty))
                }
            }
            none => {}
        }
        fi++
    }
    return offset
}

fn ll_field_offset(ctx: ref LLCtx, fields: ref void, field_name: ref char) i64! = {
    if fields == 0 as ref void { return -1 }
    val flen: i64 = @len(fields as list[ref void]) as i64
    val has_fa: bool = ll_fields_have_fixed_arr(fields)
    val offset: mut i64 = 0
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fname: ref char = fnode.d0 as ref char
                if str.rchar_cmp(fname, field_name) == 0 { return offset }
                val fty: ref parser.Node = fnode.d2 as ref parser.Node
                if has_fa {
                    offset = ll_align_to(offset, ll_type_align(fty))
                    offset = offset + ll_type_size(ctx, fty)
                } else {
                    offset = offset + ll_aligned_size(ll_type_size(ctx, fty))
                }
            }
            none => {}
        }
        fi++
    }
    return -1
}

fn ll_field_type(fields: ref void, field_name: ref char) ref parser.Node! = {
    if fields == 0 as ref void { return 0 as ref parser.Node }
    val flen: i64 = @len(fields as list[ref void]) as i64
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fname: ref char = fnode.d0 as ref char
                if str.rchar_cmp(fname, field_name) == 0 { return fnode.d2 as ref parser.Node }
            }
            none => {}
        }
        fi++
    }
    return 0 as ref parser.Node
}

fn ll_param_abi_type(ctx: ref LLCtx, ty: ref parser.Node) ref char! = {
    if ll_slot_is_ptr(ctx, ty) { return "ptr" }
    return ll_type_of(ty)
}

fn ll_call_ret_abi(ctx: ref LLCtx, ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return "i64" }
    if ty.kind == parser.TY_VOID { return "void" }
    if ll_slot_is_ptr(ctx, ty) { return "ptr" }
    return ll_type_of(ty)
}

fn ll_unwrap_mut_type(ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return 0 as ref parser.Node }
    if ty.kind == parser.TY_MUT { return ll_unwrap_mut_type(ty.d0 as ref parser.Node) }
    return ty
}

fn ll_is_fnptr_type(ty: ref parser.Node) bool! = {
    if ty == 0 as ref parser.Node { return false }
    return ty.kind == parser.TY_FNPTR
}

fn ll_make_named_type(name: ref char) ref parser.Node! = {
    val named: mut ref parser.Node = @alloc(@sizeof(parser.Node)) as ref parser.Node
    named.kind = parser.TY_NAMED
    named.line = 0
    named.d0 = name as ref void
    named.d1 = 0
    named.d2 = 0
    named.d3 = 0
    named.d4 = 0
    named.d5 = 0
    named.d6 = 0
    return named
}

fn ll_make_ref_type(inner: ref parser.Node) ref parser.Node! = {
    val ref_ty: mut ref parser.Node = @alloc(@sizeof(parser.Node)) as ref parser.Node
    ref_ty.kind = parser.TY_REF
    ref_ty.line = 0
    ref_ty.d0 = inner as ref void
    ref_ty.d1 = 0
    ref_ty.d2 = 0
    ref_ty.d3 = 0
    ref_ty.d4 = 0
    ref_ty.d5 = 0
    ref_ty.d6 = 0
    return ref_ty
}

fn ll_fnptr_param_types(params: ref void) ref void! = {
    if params == 0 as ref void { return 0 as ref void }
    val out: mut list[ref parser.Node] = []
    val plen: i64 = @len(params as list[ref parser.Node]) as i64
    val pi: mut i64 = 0
    for {
        if pi >= plen { break }
        val p_opt = @get(params as list[ref parser.Node], pi as usize)
        match p_opt {
            some p => {
                val pnode: ref parser.Node = p as ref parser.Node
                @append(out, pnode.d1 as ref parser.Node)
            }
            none => {}
        }
        pi++
    }
    return out as ref void
}

fn ll_make_fnptr_type(params: ref void, ret_ty: ref parser.Node) ref parser.Node! = {
    val fn_ty: mut ref parser.Node = @alloc(@sizeof(parser.Node)) as ref parser.Node
    fn_ty.kind = parser.TY_FNPTR
    fn_ty.line = 0
    fn_ty.d0 = ll_fnptr_param_types(params)
    fn_ty.d1 = ret_ty as ref void
    fn_ty.d2 = 0
    fn_ty.d3 = 0
    fn_ty.d4 = 0
    fn_ty.d5 = 0
    fn_ty.d6 = 0
    return fn_ty
}

fn ll_make_list_type(inner: ref parser.Node) ref parser.Node! = {
    val list_ty: mut ref parser.Node = @alloc(@sizeof(parser.Node)) as ref parser.Node
    list_ty.kind = parser.TY_LIST
    list_ty.line = 0
    list_ty.d0 = inner as ref void
    list_ty.d1 = 0
    list_ty.d2 = 0
    list_ty.d3 = 0
    list_ty.d4 = 0
    list_ty.d5 = 0
    list_ty.d6 = 0
    return list_ty
}

fn ll_make_option_type(inner: ref parser.Node) ref parser.Node! = {
    val opt_ty: mut ref parser.Node = @alloc(@sizeof(parser.Node)) as ref parser.Node
    opt_ty.kind = parser.TY_OPTION
    opt_ty.line = 0
    opt_ty.d0 = inner as ref void
    opt_ty.d1 = 0
    opt_ty.d2 = 0
    opt_ty.d3 = 0
    opt_ty.d4 = 0
    opt_ty.d5 = 0
    opt_ty.d6 = 0
    return opt_ty
}

fn ll_list_lit_inner_type(ctx: ref LLCtx, elems: ref void) ref parser.Node! = {
    if elems != 0 as ref void {
        val e_opt = @get(elems as list[ref parser.Node], 0)
        match e_opt {
            some e => {
                val inner_ty: ref parser.Node = ll_expr_storage_type(ctx, e as ref parser.Node)
                if inner_ty != 0 as ref parser.Node { return inner_ty }
            }
            none => {}
        }
    }
    return ll_make_named_type("i64")
}

fn ll_param_ssa_name(name: ref char) ref char! = {
    if str.rchar_cmp(name, "_") == 0 {
        return "__anon_param"
    }
    if str.rchar_cmp(name, "entry") == 0 {
        return "__param_entry"
    }
    if str.starts_with(str.from(name), str.from("lbl")) {
        val out: ref char = @alloc(str.len_raw(name) + 9) as ref char
        @snprintf(out, str.len_raw(name) + 9, "__param_{s}", {name})
        return out
    }
    return name
}

fn ll_param_ssa_name_at(name: ref char, index: i64) ref char! = {
    val base: ref char = ll_param_ssa_name(name)
    if str.rchar_cmp(name, "_") == 0 {
        val out: ref char = @alloc(32) as ref char
        @snprintf(out, 32, "{s}_{lld}", {base, index})
        return out
    }
    return base
}

fn ll_is_float_type(ty: ref parser.Node) bool! = {
    if ty == 0 as ref parser.Node { return false }
    val abi_ty: ref char = ll_type_of(ty)
    return str.rchar_cmp(abi_ty, "double") == 0 || str.rchar_cmp(abi_ty, "float") == 0
}

fn ll_float_binop_abi(lhs_ty: ref parser.Node, rhs_ty: ref parser.Node) ref char! = {
    if lhs_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(lhs_ty), "double") == 0 { return "double" }
    if rhs_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(rhs_ty), "double") == 0 { return "double" }
    return "float"
}

fn ll_lookup_fn_params(ctx: ref LLCtx, name: ref char) ref void! = {
    val len: i64 = @len(ctx.fn_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val n_opt = @get(ctx.fn_names, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val p_opt = @get(ctx.fn_params, i as usize)
                    match p_opt {
                        some p => { return p as ref void }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return 0 as ref void
}

fn ll_lookup_fn_ret(ctx: ref LLCtx, name: ref char) ref parser.Node! = {
    val len: i64 = @len(ctx.fn_names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val n_opt = @get(ctx.fn_names, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val r_opt = @get(ctx.fn_rets, i as usize)
                    match r_opt {
                        some r => { return r as ref parser.Node }
                        none => {}
                    }
                }
            }
            none => {}
        }
        i++
    }
    return ll_lookup_extern_ret(ctx, name)
}

fn ll_expr_storage_type(ctx: ref LLCtx, expr: ref parser.Node) ref parser.Node! = {
    if expr == 0 as ref parser.Node { return 0 as ref parser.Node }
    if expr.kind == parser.NK_TRUST {
        return ll_expr_storage_type(ctx, expr.d0 as ref parser.Node)
    }
    if expr.kind == parser.NK_TRY {
        return ll_result_ok_type(ll_expr_storage_type(ctx, expr.d0 as ref parser.Node))
    }
    if expr.kind == parser.NK_CAST {
        return expr.d1 as ref parser.Node
    }
    if expr.kind == parser.NK_IDENT {
        val name: ref char = expr.d0 as ref char
        val local_ty: ref parser.Node = ll_lookup_local_type(ctx, name)
        if local_ty != 0 as ref parser.Node { return local_ty }
        val resolved: ref char = ll_resolve_fn_name(ctx, name)
        val ext_sym: ref char = ll_lookup_extern_symbol(ctx, name)
        val effective: mut ref char = name
        if resolved != 0 as ref char { effective = resolved }
        elif ext_sym != 0 as ref char { effective = ext_sym }
        val ret_ty: ref parser.Node = ll_lookup_fn_ret(ctx, effective)
        if ret_ty != 0 as ref parser.Node {
            return ll_make_fnptr_type(ll_lookup_fn_params(ctx, effective), ret_ty)
        }
        return 0 as ref parser.Node
    }
    if expr.kind == parser.NK_ADDR {
        val inner_ty: ref parser.Node = ll_expr_storage_type(ctx, expr.d0 as ref parser.Node)
        return ll_make_ref_type(inner_ty)
    }
    if expr.kind == parser.NK_DEREF {
        val inner_ty0: ref parser.Node = ll_expr_storage_type(ctx, expr.d0 as ref parser.Node)
        val inner_ty: mut ref parser.Node = inner_ty0
        if inner_ty != 0 as ref parser.Node && inner_ty.kind == parser.TY_MUT {
            inner_ty = inner_ty.d0 as ref parser.Node
        }
        if inner_ty != 0 as ref parser.Node && inner_ty.kind == parser.TY_REF {
            return inner_ty.d0 as ref parser.Node
        }
    }
    if expr.kind == parser.NK_FIELD {
        val base_expr: ref parser.Node = parser.field_base(expr)
        if base_expr.kind == parser.NK_IDENT {
            val base_ty: ref parser.Node = ll_lookup_local_type(ctx, base_expr.d0 as ref char)
            val struct_name: ref char = ll_struct_type_name(ctx, base_ty)
            if str.rchar_cmp(struct_name, "") != 0 {
                val fields: ref void = ll_lookup_struct(ctx, struct_name)
                return ll_field_type(fields, parser.field_name(expr))
            }
            val const_key: ref char = @alloc(512) as ref char
            @snprintf(const_key, 512, "{s}__{s}", {base_expr.d0 as ref char, parser.field_name(expr)})
            val const_sym: ref char = ll_lookup_module_const_symbol(ctx, const_key)
            if str.rchar_cmp(const_sym, "") != 0 {
                return ll_lookup_global_type(ctx, const_sym)
            }
        }
        val field_full_name: ref char = resolve_callee_name(expr)
        val resolved_field: ref char = ll_resolve_fn_name(ctx, field_full_name)
        val ext_field: ref char = ll_lookup_extern_symbol(ctx, field_full_name)
        val effective_field: mut ref char = field_full_name
        if resolved_field != 0 as ref char { effective_field = resolved_field }
        elif ext_field != 0 as ref char { effective_field = ext_field }
        val field_ret_ty: ref parser.Node = ll_lookup_fn_ret(ctx, effective_field)
        if field_ret_ty != 0 as ref parser.Node {
            return ll_make_fnptr_type(ll_lookup_fn_params(ctx, effective_field), field_ret_ty)
        }
    }
    if expr.kind == parser.NK_CALL {
        val callee_node: ref parser.Node = expr.d0 as ref parser.Node
        val callee_ty: ref parser.Node = ll_unwrap_mut_type(ll_expr_storage_type(ctx, callee_node))
        if ll_is_fnptr_type(callee_ty) {
            return callee_ty.d1 as ref parser.Node
        }
        val callee_name: ref char = resolve_callee_name(callee_node)
        val tv_owner_slot: ref void = @alloc(8)
        val tv_field_slot: ref void = @alloc(8)
        @store(tv_owner_slot, 0)
        @store(tv_field_slot, 0)
        val tv_tag: i64 = ll_lookup_tv(ctx, callee_name, tv_owner_slot, tv_field_slot)
        if tv_tag >= 0 {
            val owner: ref char = @load(tv_owner_slot) as ref char
            val named: mut ref parser.Node = @alloc(@sizeof(parser.Node)) as ref parser.Node
            named.kind = parser.TY_NAMED
            named.line = 0
            named.d0 = owner as ref void
            named.d1 = 0
            named.d2 = 0
            named.d3 = 0
            named.d4 = 0
            named.d5 = 0
            named.d6 = 0
            return named
        }
        val resolved: ref char = ll_resolve_fn_name(ctx, callee_name)
        val ext_sym: ref char = ll_lookup_extern_symbol(ctx, callee_name)
        val effective: mut ref char = callee_name
        if resolved != 0 as ref char { effective = resolved }
        elif ext_sym != 0 as ref char { effective = ext_sym }
        return ll_lookup_fn_ret(ctx, effective)
    }
    if expr.kind == parser.NK_BUILTIN {
        val bname: ref char = expr.d0 as ref char
        if str.rchar_cmp(bname, "alloc") == 0
        || str.rchar_cmp(bname, "realloc") == 0
        || str.rchar_cmp(bname, "ptradd") == 0
        || str.rchar_cmp(bname, "fmt") == 0 {
            val dummy: mut ref parser.Node = @alloc(@sizeof(parser.Node)) as ref parser.Node
            dummy.kind = parser.TY_REF
            dummy.line = 0
            dummy.d0 = 0
            dummy.d1 = 0
            dummy.d2 = 0
            dummy.d3 = 0
            dummy.d4 = 0
            dummy.d5 = 0
            dummy.d6 = 0
            return dummy
        } elif str.rchar_cmp(bname, "args") == 0 {
            val inner: mut ref parser.Node = @alloc(@sizeof(parser.Node)) as ref parser.Node
            inner.kind = parser.TY_REF
            inner.line = 0
            inner.d0 = 0
            inner.d1 = 0
            inner.d2 = 0
            inner.d3 = 0
            inner.d4 = 0
            inner.d5 = 0
            inner.d6 = 0
            val dummy: mut ref parser.Node = @alloc(@sizeof(parser.Node)) as ref parser.Node
            dummy.kind = parser.TY_LIST
            dummy.line = 0
            dummy.d0 = inner as ref void
            dummy.d1 = 0
            dummy.d2 = 0
            dummy.d3 = 0
            dummy.d4 = 0
            dummy.d5 = 0
            dummy.d6 = 0
            return dummy
        } elif str.rchar_cmp(bname, "get") == 0 {
            val list_node: ref parser.Node = get_arg_node(expr.d1 as ref void, 0)
            val list_ty: ref parser.Node = ll_expr_storage_type(ctx, list_node)
            if list_ty != 0 as ref parser.Node {
                if list_ty.kind == parser.TY_LIST || list_ty.kind == parser.TY_SLICE {
                    return ll_make_option_type(list_ty.d0 as ref parser.Node)
                }
            }
            return ll_make_option_type(ll_make_named_type("i64"))
        }
    }
    if expr.kind == parser.NK_STR_LIT { return ll_make_ref_type(ll_make_named_type("char")) }
    if expr.kind == parser.NK_FLOAT_LIT { return ll_make_named_type("f64") }
    if expr.kind == parser.NK_INT_LIT { return ll_make_named_type("i64") }
    if expr.kind == parser.NK_BOOL { return ll_make_named_type("bool") }
    if expr.kind == parser.NK_CHAR_LIT { return ll_make_named_type("char") }
    if expr.kind == parser.NK_UNOP {
        val op: i64 = parser.unop_op(expr)
        if op == parser.UOP_NEG { return ll_expr_storage_type(ctx, parser.unop_inner(expr)) }
        return ll_make_named_type("i64")
    }
    if expr.kind == parser.NK_BINOP {
        val op: i64 = expr.d0 as i64
        if op == parser.OP_EQ || op == parser.OP_NE || op == parser.OP_LT || op == parser.OP_GT || op == parser.OP_LE || op == parser.OP_GE
            || op == parser.OP_AND || op == parser.OP_OR {
            return ll_make_named_type("i64")
        }
        val lhs_ty: ref parser.Node = ll_expr_storage_type(ctx, expr.d1 as ref parser.Node)
        val rhs_ty: ref parser.Node = ll_expr_storage_type(ctx, expr.d2 as ref parser.Node)
        if ll_is_float_type(lhs_ty) { return lhs_ty }
        if ll_is_float_type(rhs_ty) { return rhs_ty }
        if lhs_ty != 0 as ref parser.Node { return lhs_ty }
        return rhs_ty
    }
    if expr.kind == parser.NK_LIST_LIT {
        val elems: ref void = expr.d0 as ref void
        return ll_make_list_type(ll_list_lit_inner_type(ctx, elems))
    }
    return 0 as ref parser.Node
}

fn ll_option_inner_type(ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return 0 as ref parser.Node }
    if ty.kind == parser.TY_MUT { return ll_option_inner_type(ty.d0 as ref parser.Node) }
    if ty.kind == parser.TY_OPTION { return ty.d0 as ref parser.Node }
    return 0 as ref parser.Node
}

fn ll_result_ok_type(ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return 0 as ref parser.Node }
    if ty.kind == parser.TY_MUT { return ll_result_ok_type(ty.d0 as ref parser.Node) }
    if ty.kind == parser.TY_RESULT { return ty.d0 as ref parser.Node }
    return 0 as ref parser.Node
}

fn ll_result_err_type(ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return 0 as ref parser.Node }
    if ty.kind == parser.TY_MUT { return ll_result_err_type(ty.d0 as ref parser.Node) }
    if ty.kind == parser.TY_RESULT { return ty.d1 as ref parser.Node }
    return 0 as ref parser.Node
}

fn ll_list_inner_type(ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return 0 as ref parser.Node }
    if ty.kind == parser.TY_MUT { return ll_list_inner_type(ty.d0 as ref parser.Node) }
    if ty.kind == parser.TY_LIST { return ty.d0 as ref parser.Node }
    return 0 as ref parser.Node
}

fn ll_is_result_type(ty: ref parser.Node) bool! = {
    if ty == 0 as ref parser.Node { return false }
    if ty.kind == parser.TY_MUT { return ll_is_result_type(ty.d0 as ref parser.Node) }
    return ty.kind == parser.TY_RESULT
}

fn ll_expr_is_raw_load(expr: ref parser.Node) bool! = {
    if expr == 0 as ref parser.Node { return false }
    if expr.kind == parser.NK_TRUST || expr.kind == parser.NK_CAST {
        return ll_expr_is_raw_load(expr.d0 as ref parser.Node)
    }
    if expr.kind == parser.NK_BUILTIN {
        return str.rchar_cmp(expr.d0 as ref char, "load") == 0
    }
    return false
}

fn ll_expr_is_null_ptr_literal(expr: ref parser.Node) bool! = {
    if expr == 0 as ref parser.Node { return false }
    if expr.kind == parser.NK_TRUST {
        return ll_expr_is_null_ptr_literal(expr.d0 as ref parser.Node)
    }
    if expr.kind == parser.NK_NONE { return true }
    if expr.kind == parser.NK_INT_LIT {
        return str.rchar_cmp(ll_normalize_int_text(parser.int_lit_text(expr)), "0") == 0
    }
    if expr.kind == parser.NK_CAST {
        val cast_ty: ref parser.Node = expr.d1 as ref parser.Node
        if cast_ty != 0 as ref parser.Node && cast_ty.kind == parser.TY_REF {
            return ll_expr_is_null_ptr_literal(expr.d0 as ref parser.Node)
        }
    }
    return false
}

fn ll_coerce_word_to_ptr(ctx: ref LLCtx, value: ref void) ref char! = {
    if str.rchar_cmp(value as ref char, "0") == 0 { return "null" }
    val tmp: i64 = fresh_tmp(ctx)
    val head: ref char = @alloc(64) as ref char
    @snprintf(head, 64, "  %%t{lld} = inttoptr i64 ", {tmp})
    emit(ctx, head)
    @free(head)
    val vi: mut i64 = 0
    for {
        val ch: u8 = @load8(@ptradd(value as ref void, vi))
        if ch == 0 { break }
        str.StringBuilder.append_char(ctx.sb, ch)
        vi++
    }
    emitln(ctx, " to ptr")
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn ll_coerce_ptr_to_word(ctx: ref LLCtx, value: ref void) ref char! = {
    if str.rchar_cmp(value as ref char, "null") == 0 { return "0" }
    val tmp: i64 = fresh_tmp(ctx)
    val head: ref char = @alloc(64) as ref char
    @snprintf(head, 64, "  %%t{lld} = ptrtoint ptr ", {tmp})
    emit(ctx, head)
    @free(head)
    val vi: mut i64 = 0
    for {
        val ch: u8 = @load8(@ptradd(value as ref void, vi))
        if ch == 0 { break }
        str.StringBuilder.append_char(ctx.sb, ch)
        vi++
    }
    emitln(ctx, " to i64")
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn ll_coerce_value_for_type(ctx: ref LLCtx, expr: ref parser.Node, ty: ref parser.Node, value: ref char) ref char! = {
    if ll_slot_is_ptr(ctx, ty) && ll_expr_is_null_ptr_literal(expr) {
        return "null"
    }
    val expr_ty: ref parser.Node = ll_expr_storage_type(ctx, expr)
    if ll_slot_is_ptr(ctx, ty) && !ll_slot_is_ptr(ctx, expr_ty) && ll_expr_is_raw_load(expr) {
        return ll_coerce_word_to_ptr(ctx, value)
    }
    return value
}

fn ll_some_payload_is_ptr_like(ctx: ref LLCtx, expr: ref parser.Node) bool! = {
    if expr == 0 as ref parser.Node { return false }
    val k: i64 = expr.kind
    if k == parser.NK_TRUST {
        return ll_some_payload_is_ptr_like(ctx, expr.d0 as ref parser.Node)
    }
    if k == parser.NK_CAST {
        return ll_slot_is_ptr(ctx, expr.d1 as ref parser.Node)
    }
    if k == parser.NK_IDENT {
        val name: ref char = expr.d0 as ref char
        val local_ty: ref parser.Node = ll_lookup_local_type(ctx, name)
        if ll_slot_is_ptr(ctx, local_ty) { return true }
        val resolved: ref char = ll_resolve_fn_name(ctx, name)
        val ext_sym: ref char = ll_lookup_extern_symbol(ctx, name)
        val effective: mut ref char = name
        if resolved != 0 as ref char { effective = resolved }
        elif ext_sym != 0 as ref char { effective = ext_sym }
        return str.rchar_cmp(effective, name) != 0 || ll_lookup_fn_ret(ctx, effective) != 0 as ref parser.Node
    }
    if k == parser.NK_STR_LIT || k == parser.NK_ADDR || k == parser.NK_LIST_LIT || k == parser.NK_STRUCT_LIT {
        return true
    }
    if k == parser.NK_OK_VAL || k == parser.NK_ERR_VAL {
        return true
    }
    if k == parser.NK_CALL {
        val callee_name: ref char = resolve_callee_name(expr.d0 as ref parser.Node)
        val tv_owner_slot: ref void = @alloc(8)
        val tv_field_slot: ref void = @alloc(8)
        @store(tv_owner_slot, 0)
        @store(tv_field_slot, 0)
        if ll_lookup_tv(ctx, callee_name, tv_owner_slot, tv_field_slot) >= 0 {
            return true
        }
        val resolved: ref char = ll_resolve_fn_name(ctx, callee_name)
        val direct_ret: ref parser.Node = ll_lookup_fn_ret(ctx, callee_name)
        if resolved != 0 as ref char {
            return ll_slot_is_ptr(ctx, ll_lookup_fn_ret(ctx, resolved))
        }
        return ll_slot_is_ptr(ctx, direct_ret)
    }
    if k == parser.NK_BUILTIN {
        val name: ref char = expr.d0 as ref char
        if str.rchar_cmp(name, "alloc") == 0 || str.rchar_cmp(name, "realloc") == 0 ||
           str.rchar_cmp(name, "ptradd") == 0 || str.rchar_cmp(name, "fmt") == 0 ||
           str.rchar_cmp(name, "fgets") == 0 || str.rchar_cmp(name, "stdin") == 0 ||
           str.rchar_cmp(name, "stdout") == 0 || str.rchar_cmp(name, "stderr") == 0 {
            return true
        }
    }
    return false
}

fn ll_load_typed_value(ctx: ref LLCtx, ptr: ref char, ty: ref parser.Node) ref char! = {
    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(128) as ref char
    if ll_slot_is_ptr(ctx, ty) {
        @snprintf(buf, 128, "  %%t{lld} = load ptr, ptr {s}\n", {tmp, ptr})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }
    if ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(ty), "double") == 0 {
        @snprintf(buf, 128, "  %%t{lld} = load double, ptr {s}\n", {tmp, ptr})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }
    if ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(ty), "float") == 0 {
        @snprintf(buf, 128, "  %%t{lld} = load float, ptr {s}\n", {tmp, ptr})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }
    if ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(ty), "i32") == 0 {
        @snprintf(buf, 128, "  %%t{lld} = load i32, ptr {s}\n", {tmp, ptr})
        emit(ctx, buf)
        @free(buf)
        val loaded: ref char = @alloc(16) as ref char
        @snprintf(loaded, 16, "%%t{lld}", {tmp})
        return ll_widen_to_i64(ctx, loaded, ty)
    }
    @snprintf(buf, 128, "  %%t{lld} = load i64, ptr {s}\n", {tmp, ptr})
    emit(ctx, buf)
    @free(buf)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn ll_variadic_abi_type(ctx: ref LLCtx, node: ref parser.Node) ref char! = {
    if node == 0 as ref parser.Node { return "i64" }
    if node.kind == parser.NK_STR_LIT { return "ptr" }
    if node.kind == parser.NK_FLOAT_LIT { return "double" }
    val ty: ref parser.Node = ll_expr_storage_type(ctx, node)
    if ll_slot_is_ptr(ctx, ty) { return "ptr" }
    if ty != 0 as ref parser.Node {
        val abi_ty: ref char = ll_type_of(ty)
        if str.rchar_cmp(abi_ty, "double") == 0 { return "double" }
        if str.rchar_cmp(abi_ty, "float") == 0 { return "double" }
    }
    if node.kind == parser.NK_IDENT {
        val local_ty: ref parser.Node = ll_lookup_local_type(ctx, node.d0 as ref char)
        if ll_slot_is_ptr(ctx, local_ty) { return "ptr" }
    }
    return "i64"
}

fn resolve_callee_name(node: ref parser.Node) ref char! = {
    if node.kind == parser.NK_IDENT { return node.d0 as ref char }
    if node.kind == parser.NK_FIELD {
        val base: ref char = resolve_callee_name(parser.field_base(node))
        val field: ref char = parser.field_name(node)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "{s}__{s}", {base, field})
        return buf
    }
    return "unknown"
}

fn get_std_child_names() mut list[ref char] = {
    return ["allocators", "collections", "crypto", "fmt", "fs", "log", "math", "os", "path", "random", "reflection", "stdio", "string", "str", "time", "thread"]
}

fn ll_is_std_child_name(name: ref char) bool! = {
    for scn in get_std_child_names() {
        if str.rchar_cmp(scn, name) == 0 { return true }
    }
    return false
}

fn ll_first_path_segment(src: ref char) ref char! = {
    val len: i64 = str.len_raw(src)
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = @load8(@ptradd(src as ref void, i))
        if c == 95 && @load8(@ptradd(src as ref void, i + 1)) == 95 {
            val out: ref char = @alloc(i + 1) as ref char
            @memcpy(out as ref void, src as ref void, i as usize)
            @store8(@ptradd(out as ref void, i), 0)
            return out
        }
        i++
    }
    return ""
}

fn ll_root_prefix(root: ref module.ResolvedModule) ref char! = {
    val fname: ref char = str.cstr(root.filename)
    val len: i64 = str.len_raw(fname)
    val slash: mut i64 = -1
    val dot: mut i64 = len
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val c: u8 = @load8(@ptradd(fname as ref void, i))
        if c == 47 { slash = i }
        elif c == 46 { dot = i }
        i++
    }
    val base_start: i64 = slash + 1
    if dot <= base_start { dot = len }
    val base_len: i64 = dot - base_start
    if base_len <= 0 { return "" }
    val base: ref char = @alloc(base_len + 1) as ref char
    @memcpy(base as ref void, @ptradd(fname as ref void, base_start), base_len as usize)
    @store8(@ptradd(base as ref void, base_len), 0)
    if !ll_is_std_child_name(base) { return "" }
    if slash < 3 { return "" }
    val p3: u8 = @load8(@ptradd(fname as ref void, slash - 3))
    val p2: u8 = @load8(@ptradd(fname as ref void, slash - 2))
    val p1: u8 = @load8(@ptradd(fname as ref void, slash - 1))
    if p3 == 115 && p2 == 116 && p1 == 100 { return base }
    return ""
}

fn ll_effective_prefix(root_prefix: ref char, original_prefix: ref char) ref char! = {
    if str.rchar_cmp(original_prefix, "") == 0 && str.rchar_cmp(root_prefix, "") != 0 {
        return root_prefix
    }
    return original_prefix
}

fn ll_widen_to_i64(ctx: ref LLCtx, value: ref char, ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return value }
    val k: i64 = ty.kind
    if k == parser.TY_MUT { return ll_widen_to_i64(ctx, value, ty.d0 as ref parser.Node) }
    if str.rchar_cmp(ll_type_of(ty), "i32") == 0 {
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        if ll_is_unsigned_type(ty) {
            @snprintf(buf, 128, "  %%t{lld} = zext i32 {s} to i64\n", {tmp, value})
        } else {
            @snprintf(buf, 128, "  %%t{lld} = sext i32 {s} to i64\n", {tmp, value})
        }
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }
    return value
}

fn ll_emit_store_value(ctx: ref LLCtx, ptr: ref char, ty: ref parser.Node, value: ref char) void! = {
    val buf: ref char = @alloc(256) as ref char
    if ll_slot_is_ptr(ctx, ty) {
        val ptr_value: mut ref char = value
        if str.rchar_cmp(value, "0") == 0 { ptr_value = "null" }
        @snprintf(buf, 256, "  store ptr {s}, ptr {s}\n", {ptr_value, ptr})
    } elif ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(ty), "double") == 0 {
        @snprintf(buf, 256, "  store double {s}, ptr {s}\n", {value, ptr})
    } elif ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(ty), "float") == 0 {
        @snprintf(buf, 256, "  store float {s}, ptr {s}\n", {value, ptr})
    } elif ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(ty), "i32") == 0 {
        val tr: i64 = fresh_tmp(ctx)
        if ll_is_unsigned_type(ty) {
            @snprintf(buf, 256, "  %%t{lld} = trunc i64 {s} to i32\n  store i32 %%t{lld}, ptr {s}\n", {tr, value, tr, ptr})
        } else {
            @snprintf(buf, 256, "  %%t{lld} = trunc i64 {s} to i32\n  store i32 %%t{lld}, ptr {s}\n", {tr, value, tr, ptr})
        }
    } else {
        @snprintf(buf, 256, "  store i64 {s}, ptr {s}\n", {value, ptr})
    }
    emit(ctx, buf)
    @free(buf)
}

fn ll_alloca_typed_slot(ctx: ref LLCtx, ty: ref parser.Node) ref char! = {
    val slot: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(128) as ref char
    if ll_slot_is_ptr(ctx, ty) {
        @snprintf(buf, 128, "  %%t{lld} = alloca ptr, align 8\n", {slot})
    } elif ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(ty), "double") == 0 {
        @snprintf(buf, 128, "  %%t{lld} = alloca double, align 8\n", {slot})
    } elif ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(ty), "float") == 0 {
        @snprintf(buf, 128, "  %%t{lld} = alloca float, align 4\n", {slot})
    } elif ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(ty), "i32") == 0 {
        @snprintf(buf, 128, "  %%t{lld} = alloca i32, align 4\n", {slot})
    } else {
        @snprintf(buf, 128, "  %%t{lld} = alloca i64, align 8\n", {slot})
    }
    emit(ctx, buf)
    @free(buf)
    val slot_name: ref char = @alloc(16) as ref char
    @snprintf(slot_name, 16, "%%t{lld}", {slot})
    return slot_name
}

fn ll_load_named_local_value(ctx: ref LLCtx, name: ref char) ref char! = {
    val local_ptr: ref char = ll_lookup_local_ptr(ctx, name)
    if str.rchar_cmp(local_ptr, "") == 0 { return "0" }
    val local_ty: ref parser.Node = ll_lookup_local_type(ctx, name)
    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(128) as ref char
    if ll_slot_is_ptr(ctx, local_ty) {
        @snprintf(buf, 128, "  %%t{lld} = load ptr, ptr {s}\n", {tmp, local_ptr})
    } elif local_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(local_ty), "i32") == 0 {
        @snprintf(buf, 128, "  %%t{lld} = load i32, ptr {s}\n", {tmp, local_ptr})
    } else {
        @snprintf(buf, 128, "  %%t{lld} = load i64, ptr {s}\n", {tmp, local_ptr})
    }
    emit(ctx, buf)
    @free(buf)
    val loaded: ref char = @alloc(16) as ref char
    @snprintf(loaded, 16, "%%t{lld}", {tmp})
    if local_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(local_ty), "i32") == 0 {
        return ll_widen_to_i64(ctx, loaded, local_ty)
    }
    return loaded
}

fn ll_store_named_local_value(ctx: ref LLCtx, name: ref char, value: ref char) void! = {
    val slot_ptr: ref char = ll_lookup_local_ptr(ctx, name)
    if str.rchar_cmp(slot_ptr, "") == 0 { return }
    ll_emit_store_value(ctx, slot_ptr, ll_lookup_local_type(ctx, name), value)
}

fn ll_wrap_union_arg(ctx: ref LLCtx, node: ref parser.Node, union_variants: ref void, value: ref char) ref char! = {
    ensure_declared(ctx, "malloc", "declare ptr @malloc(i64)")
    val tag_val: mut i64 = 0
    val arg_ty: ref parser.Node = ll_expr_storage_type(ctx, node)
    if union_variants != 0 as ref void && arg_ty != 0 as ref parser.Node {
        val vlen: i64 = @len(union_variants as list[ref parser.Node]) as i64
        val vi: mut i64 = 0
        for {
            if vi >= vlen { break }
            val v_opt = @get(union_variants as list[ref parser.Node], vi as usize)
            match v_opt {
                some v => {
                    val vty: ref parser.Node = v as ref parser.Node
                    if arg_ty.kind == parser.TY_NAMED && vty.kind == parser.TY_NAMED {
                        if str.rchar_cmp(arg_ty.d0 as ref char, vty.d0 as ref char) == 0 { tag_val = vi break }
                    } elif arg_ty.kind == parser.TY_REF && vty.kind == parser.TY_REF {
                        tag_val = vi
                        break
                    }
                }
                none => {}
            }
            vi++
        }
    }
    val box_ptr: i64 = fresh_tmp(ctx)
    val payload_ptr: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(320) as ref char
    val payload_store: mut ref char = "store i64"
    if ll_slot_is_ptr(ctx, arg_ty) {
        payload_store = "store ptr"
    } elif arg_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(arg_ty), "double") == 0 {
        payload_store = "store double"
    }
    @snprintf(buf, 256,
        "  %%t{lld} = call ptr @malloc(i64 16)\n  store i64 {lld}, ptr %%t{lld}\n  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 8\n  {s} {s}, ptr %%t{lld}\n",
        {box_ptr, tag_val, box_ptr, payload_ptr, box_ptr, payload_store, value, payload_ptr})
    emit(ctx, buf)
    @free(buf)
    val wrapped: ref char = @alloc(16) as ref char
    @snprintf(wrapped, 16, "%%t{lld}", {box_ptr})
    return wrapped
}

fn ll_union_variants_for_expr(ctx: ref LLCtx, expr_node: ref parser.Node) ref void! = {
    if expr_node == 0 as ref parser.Node { return 0 as ref void }
    val ty: ref parser.Node = ll_expr_storage_type(ctx, expr_node)
    if ty != 0 as ref parser.Node && ty.kind == parser.TY_NAMED {
        return ll_lookup_union_suffix(ctx, ty.d0 as ref char)
    }
    if ty != 0 as ref parser.Node && ty.kind == parser.TY_MUT {
        val inner: ref parser.Node = ty.d0 as ref parser.Node
        if inner != 0 as ref parser.Node && inner.kind == parser.TY_NAMED {
            return ll_lookup_union_suffix(ctx, inner.d0 as ref char)
        }
    }
    return 0 as ref void
}

fn ll_store_target_value(ctx: ref LLCtx, target: ref parser.Node, value: ref char) void! = {
    if target == 0 as ref parser.Node { return }
    if target.kind == parser.NK_IDENT {
        val name: ref char = target.d0 as ref char
        val slot_ptr: ref char = ll_lookup_local_ptr(ctx, name)
        if str.rchar_cmp(slot_ptr, "") != 0 {
            ll_emit_store_value(ctx, slot_ptr, ll_lookup_local_type(ctx, name), value)
        } else {
            val global_sym: ref char = ll_lookup_module_const_symbol(ctx, name)
            if str.rchar_cmp(global_sym, "") != 0 {
                val global_ty: ref parser.Node = ll_lookup_global_type(ctx, global_sym)
                val coerced_value: ref char = ll_coerce_value_for_type(ctx, target, global_ty, value)
                val gptr: ref char = @alloc(str.len_raw(global_sym) + 2) as ref char
                @snprintf(gptr, str.len_raw(global_sym) + 2, "@{s}", {global_sym})
                ll_emit_store_value(ctx, gptr, global_ty, coerced_value)
            }
        }
        return
    }
    if target.kind == parser.NK_FIELD {
        val fptr: ref char = ll_field_ptr(ctx, target)
        val base_expr: ref parser.Node = parser.field_base(target)
        if base_expr.kind == parser.NK_IDENT && str.rchar_cmp(fptr, "0") != 0 {
            val base_ty: ref parser.Node = ll_lookup_local_type(ctx, base_expr.d0 as ref char)
            val sname: ref char = ll_struct_type_name(ctx, base_ty)
            val fields: ref void = ll_lookup_struct(ctx, sname)
            val fty: ref parser.Node = ll_field_type(fields, parser.field_name(target))
            ll_emit_store_value(ctx, fptr, fty, value)
        }
        return
    }
    if target.kind == parser.NK_DEREF {
        val ptr: ref char = gen_expr(ctx, target.d0 as ref parser.Node)
        val ty: ref parser.Node = ll_expr_storage_type(ctx, target)
        ll_emit_store_value(ctx, ptr, ty, value)
    }
}

fn ll_coerce_arg_to_abi(ctx: ref LLCtx, node: ref parser.Node, value: ref char, abi_ty: ref char) ref char! = {
    if str.rchar_cmp(abi_ty, "ptr") == 0 && ll_expr_is_null_ptr_literal(node) {
        return "null"
    }
    val node_ty_for_abi: ref parser.Node = ll_expr_storage_type(ctx, node)
    if str.rchar_cmp(abi_ty, "ptr") == 0 && !ll_slot_is_ptr(ctx, node_ty_for_abi) {
        val arg_node: mut ref parser.Node = node
        if arg_node != 0 as ref parser.Node && arg_node.kind == parser.NK_TRUST {
            arg_node = arg_node.d0 as ref parser.Node
        }
        if arg_node != 0 as ref parser.Node && ll_some_payload_is_ptr_like(ctx, arg_node) {
            return value
        }
        return ll_coerce_word_to_ptr(ctx, value)
    }
    if str.rchar_cmp(abi_ty, "i64") == 0 {
        if ll_expr_is_null_ptr_literal(node) {
            return "0"
        }
        val node_ty: ref parser.Node = node_ty_for_abi
        if ll_slot_is_ptr(ctx, node_ty) {
            return ll_coerce_ptr_to_word(ctx, value)
        }
    }
    if str.rchar_cmp(abi_ty, "i32") == 0 {
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "  %%t{lld} = trunc i64 {s} to i32\n", {tmp, value})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }
    return value
}

fn ll_field_ptr(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    if expr == 0 as ref parser.Node || expr.kind != parser.NK_FIELD { return "0" }
    val base_expr: ref parser.Node = parser.field_base(expr)
    val field_name: ref char = parser.field_name(expr)
    val base_ty: mut ref parser.Node = ll_expr_storage_type(ctx, base_expr)
    val base_ptr: mut ref char = ""
    if base_expr.kind == parser.NK_IDENT {
        val base_name: ref char = base_expr.d0 as ref char
        val slot_ptr: ref char = ll_lookup_local_ptr(ctx, base_name)
        base_ty = ll_lookup_local_type(ctx, base_name)
        if str.rchar_cmp(slot_ptr, "") != 0 {
            val base_tmp: i64 = fresh_tmp(ctx)
            val base_buf: ref char = @alloc(128) as ref char
            @snprintf(base_buf, 128, "  %%t{lld} = load ptr, ptr {s}\n", {base_tmp, slot_ptr})
            emit(ctx, base_buf)
            @free(base_buf)
            base_ptr = @alloc(16) as ref char
            @snprintf(base_ptr, 16, "%%t{lld}", {base_tmp})
        }
    } else {
        base_ptr = gen_expr(ctx, base_expr)
    }
    if str.rchar_cmp(base_ptr, "") == 0 || base_ty == 0 as ref parser.Node { return "0" }
    val struct_name: ref char = ll_struct_type_name(ctx, base_ty)
    if str.rchar_cmp(struct_name, "") == 0 { return "0" }
    val fields: ref void = ll_lookup_struct(ctx, struct_name)
    val offset: i64 = ll_field_offset(ctx, fields, field_name)
    if offset <= 0 {
        return base_ptr
    }
    val ptr_tmp: i64 = fresh_tmp(ctx)
    val ptr_buf: ref char = @alloc(128) as ref char
    @snprintf(ptr_buf, 128, "  %%t{lld} = getelementptr i8, ptr {s}, i64 {lld}\n", {ptr_tmp, base_ptr, offset})
    emit(ctx, ptr_buf)
    @free(ptr_buf)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t{lld}", {ptr_tmp})
    return res
}

fn gen_try(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    val inner_node: ref parser.Node = expr.d0 as ref parser.Node
    val inner: ref char = gen_expr(ctx, inner_node)
    val ok_ty: ref parser.Node = ll_result_ok_type(ll_expr_storage_type(ctx, inner_node))
    val tag_tmp: i64 = fresh_tmp(ctx)
    val cmp_tmp: i64 = fresh_tmp(ctx)
    val ok_lbl: i64 = fresh_lbl(ctx)
    val err_lbl: i64 = fresh_lbl(ctx)
    val buf: ref char = @alloc(256) as ref char
    @snprintf(buf, 256,
        "  %%t{lld} = load i64, ptr {s}\n  %%t{lld} = icmp eq i64 %%t{lld}, 0\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
        {tag_tmp, inner, cmp_tmp, tag_tmp, cmp_tmp, ok_lbl, err_lbl, err_lbl})
    emit(ctx, buf)
    @free(buf)
    val rbuf: ref char = @alloc(64) as ref char
    if ctx.current_is_main {
        ll_emit_defers(ctx)
        @snprintf(rbuf, 64, "  ret i32 1\nlbl{lld}:\n", {ok_lbl})
    } elif str.rchar_cmp(ctx.current_ret_abi, "void") == 0 {
        ll_emit_defers(ctx)
        @snprintf(rbuf, 64, "  ret void\nlbl{lld}:\n", {ok_lbl})
    } elif str.rchar_cmp(ctx.current_ret_abi, "ptr") == 0 {
        ll_emit_defers(ctx)
        @snprintf(rbuf, 64, "  ret ptr {s}\nlbl{lld}:\n", {inner, ok_lbl})
    } else {
        ll_emit_defers(ctx)
        if @load8(ctx.current_ret_abi as ref void) == 112
        && @load8(@ptradd(ctx.current_ret_abi as ref void, 1)) == 116
        && @load8(@ptradd(ctx.current_ret_abi as ref void, 2)) == 114
        && @load8(@ptradd(ctx.current_ret_abi as ref void, 3)) == 0 {
            @snprintf(rbuf, 64, "  ret ptr null\nlbl{lld}:\n", {ok_lbl})
        } else {
            @snprintf(rbuf, 64, "  ret {s} 0\nlbl{lld}:\n", {ctx.current_ret_abi, ok_lbl})
        }
    }
    emit(ctx, rbuf)
    @free(rbuf)
    val off_tmp: i64 = fresh_tmp(ctx)
    val vbuf: ref char = @alloc(128) as ref char
    @snprintf(vbuf, 128, "  %%t{lld} = getelementptr i8, ptr {s}, i64 8\n", {off_tmp, inner})
    emit(ctx, vbuf)
    @free(vbuf)
    val off_name: ref char = @alloc(16) as ref char
    @snprintf(off_name, 16, "%%t{lld}", {off_tmp})
    return ll_load_typed_value(ctx, off_name, ok_ty)
}

fn gen_expr_unop(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    val op: i64 = parser.unop_op(expr)
    val inner_node: ref parser.Node = parser.unop_inner(expr)
    val inner_ty: ref parser.Node = ll_expr_storage_type(ctx, inner_node)
    val inner: ref char = gen_expr(ctx, inner_node)
    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(256) as ref char
    if op == parser.UOP_NEG {
        if ll_is_float_type(inner_ty) {
            @snprintf(buf, 256, "  %%t{lld} = fsub {s} 0.000000e+00, {s}\n", {tmp, ll_type_of(inner_ty), inner})
        } else {
            @snprintf(buf, 256, "  %%t{lld} = sub i64 0, {s}\n", {tmp, inner})
        }
    } elif op == parser.UOP_NOT {
        val cmp: i64 = fresh_tmp(ctx)
        @snprintf(buf, 256, "  %%t{lld} = icmp eq i64 {s}, 0\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, inner, tmp, cmp})
    } elif op == parser.UOP_BNOT {
        @snprintf(buf, 256, "  %%t{lld} = xor i64 {s}, -1\n", {tmp, inner})
    } else {
        @snprintf(buf, 256, "  %%t{lld} = add i64 {s}, 0\n", {tmp, inner})
    }
    emit(ctx, buf)
    @free(buf)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn gen_expr_field(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    val field_ptr: ref char = ll_field_ptr(ctx, expr)
    val base_expr: ref parser.Node = parser.field_base(expr)
    val field_name: ref char = parser.field_name(expr)
    if base_expr.kind == parser.NK_IDENT && str.rchar_cmp(field_ptr, "0") == 0 {
        val base_name: ref char = base_expr.d0 as ref char
        val const_key: ref char = @alloc(512) as ref char
        @snprintf(const_key, 512, "{s}__{s}", {base_name, field_name})
        val const_sym: ref char = ll_lookup_module_const_symbol(ctx, const_key)
        if str.rchar_cmp(const_sym, "") != 0 {
            val tmp: i64 = fresh_tmp(ctx)
            val buf: ref char = @alloc(128) as ref char
            @snprintf(buf, 128, "  %%t{lld} = load i64, ptr @{s}\n", {tmp, const_sym})
            emit(ctx, buf)
            @free(buf)
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t{lld}", {tmp})
            return res
        }
        @free(const_key)
    }
    if str.rchar_cmp(field_ptr, "0") != 0 {
        val base_ty: ref parser.Node = ll_expr_storage_type(ctx, base_expr)
        val struct_name: ref char = ll_struct_type_name(ctx, base_ty)
        val fields: ref void = ll_lookup_struct(ctx, struct_name)
        val field_ty: ref parser.Node = ll_field_type(fields, field_name)
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        if ll_slot_is_ptr(ctx, field_ty) {
            @snprintf(buf, 128, "  %%t{lld} = load ptr, ptr {s}\n", {tmp, field_ptr})
            emit(ctx, buf)
            @free(buf)
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t{lld}", {tmp})
            return res
        }
        if field_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(field_ty), "double") == 0 {
            @snprintf(buf, 128, "  %%t{lld} = load double, ptr {s}\n", {tmp, field_ptr})
            emit(ctx, buf)
            @free(buf)
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t{lld}", {tmp})
            return res
        }
        if field_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(field_ty), "float") == 0 {
            @snprintf(buf, 128, "  %%t{lld} = load float, ptr {s}\n", {tmp, field_ptr})
            emit(ctx, buf)
            @free(buf)
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t{lld}", {tmp})
            return res
        }
        if field_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(field_ty), "i32") == 0 {
            @snprintf(buf, 128, "  %%t{lld} = load i32, ptr {s}\n", {tmp, field_ptr})
            emit(ctx, buf)
            @free(buf)
            val loaded: ref char = @alloc(16) as ref char
            @snprintf(loaded, 16, "%%t{lld}", {tmp})
            return ll_widen_to_i64(ctx, loaded, field_ty)
        }
        @snprintf(buf, 128, "  %%t{lld} = load i64, ptr {s}\n", {tmp, field_ptr})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }
    val field_full_name: ref char = resolve_callee_name(expr)
    val resolved_field: ref char = ll_resolve_fn_name(ctx, field_full_name)
    if resolved_field != 0 as ref char {
        val res: ref char = @alloc(str.len_raw(resolved_field) + 2) as ref char
        @snprintf(res, str.len_raw(resolved_field) + 2, "@{s}", {resolved_field})
        return res
    }
    val extern_field: ref char = ll_lookup_extern_symbol(ctx, field_full_name)
    if extern_field != 0 as ref char {
        val res: ref char = @alloc(str.len_raw(extern_field) + 2) as ref char
        @snprintf(res, str.len_raw(extern_field) + 2, "@{s}", {extern_field})
        return res
    }
    return "0"
}

fn gen_expr_cast(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    val inner_expr: ref parser.Node = expr.d0 as ref parser.Node
    val inner: ref char = gen_expr(ctx, inner_expr)
    val src_ty: ref parser.Node = ll_expr_storage_type(ctx, inner_expr)
    val dst_ty: ref parser.Node = expr.d1 as ref parser.Node
    val src_abi: ref char = ll_type_of(src_ty)
    val dst_abi: ref char = ll_type_of(dst_ty)
    if ll_slot_is_ptr(ctx, dst_ty) && !ll_slot_is_ptr(ctx, src_ty) {
        if ll_expr_is_null_ptr_literal(inner_expr) { return "null" }
        return ll_coerce_word_to_ptr(ctx, inner as ref void)
    }
    if !ll_slot_is_ptr(ctx, dst_ty) && ll_slot_is_ptr(ctx, src_ty) {
        return ll_coerce_ptr_to_word(ctx, inner as ref void)
    }
    if ((str.rchar_cmp(src_abi, "double") == 0 || str.rchar_cmp(src_abi, "float") == 0)
        && str.rchar_cmp(dst_abi, "i64") == 0) {
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "  %%t{lld} = fptosi {s} {s} to i64\n", {tmp, src_abi, inner})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }
    if str.rchar_cmp(src_abi, "i64") == 0
        && (str.rchar_cmp(dst_abi, "double") == 0 || str.rchar_cmp(dst_abi, "float") == 0) {
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "  %%t{lld} = sitofp i64 {s} to {s}\n", {tmp, inner, dst_abi})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }
    if str.rchar_cmp(src_abi, "float") == 0 && str.rchar_cmp(dst_abi, "double") == 0 {
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "  %%t{lld} = fpext float {s} to double\n", {tmp, inner})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }
    if str.rchar_cmp(src_abi, "double") == 0 && str.rchar_cmp(dst_abi, "float") == 0 {
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "  %%t{lld} = fptrunc double {s} to float\n", {tmp, inner})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }
    return inner
}

fn gen_expr_some(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    val inner_node: ref parser.Node = expr.d0 as ref parser.Node
    val inner_raw: ref void = gen_expr(ctx, inner_node) as ref void
    val inner: mut ref void = inner_raw
    if ll_some_payload_is_ptr_like(ctx, inner_node) {
        inner = ll_coerce_ptr_to_word(ctx, inner_raw)
    }
    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(128) as ref char
    @snprintf(buf, 128, "  %%t{lld} = add i64 {s}, 1\n", {tmp, inner as ref char})
    emit(ctx, buf)
    @free(buf)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}

fn gen_expr_ok_val(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    ensure_declared(ctx, "malloc", "declare ptr @malloc(i64)")
    val ptr: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(256) as ref char
    @snprintf(buf, 256, "  %%t{lld} = call ptr @malloc(i64 16)\n  store i64 0, ptr %%t{lld}\n", {ptr, ptr})
    emit(ctx, buf)
    @free(buf)
    if expr.d0 != 0 {
        val inner_node: ref parser.Node = expr.d0 as ref parser.Node
        val inner_raw: ref char = gen_expr(ctx, inner_node)
        val inner_ty: ref parser.Node = ll_expr_storage_type(ctx, inner_node)
        val inner: ref char = ll_coerce_value_for_type(ctx, inner_node, inner_ty, inner_raw)
        val off: i64 = fresh_tmp(ctx)
        val pbuf: ref char = @alloc(128) as ref char
        @snprintf(pbuf, 128, "  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 8\n", {off, ptr})
        emit(ctx, pbuf)
        @free(pbuf)
        val off_name: ref char = @alloc(16) as ref char
        @snprintf(off_name, 16, "%%t{lld}", {off})
        ll_emit_store_value(ctx, off_name, inner_ty, inner)
    }
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t{lld}", {ptr})
    return res
}

fn gen_expr_err_val(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    ensure_declared(ctx, "malloc", "declare ptr @malloc(i64)")
    val inner_node: ref parser.Node = expr.d0 as ref parser.Node
    val inner_raw: ref char = gen_expr(ctx, inner_node)
    val inner_ty: ref parser.Node = ll_expr_storage_type(ctx, inner_node)
    val inner: ref char = ll_coerce_value_for_type(ctx, inner_node, inner_ty, inner_raw)
    val ptr: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(256) as ref char
    @snprintf(buf, 256, "  %%t{lld} = call ptr @malloc(i64 16)\n  store i64 1, ptr %%t{lld}\n", {ptr, ptr})
    emit(ctx, buf)
    @free(buf)
    val off: i64 = fresh_tmp(ctx)
    val pbuf: ref char = @alloc(128) as ref char
    @snprintf(pbuf, 128, "  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 8\n", {off, ptr})
    emit(ctx, pbuf)
    @free(pbuf)
    val off_name: ref char = @alloc(16) as ref char
    @snprintf(off_name, 16, "%%t{lld}", {off})
    ll_emit_store_value(ctx, off_name, inner_ty, inner)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t{lld}", {ptr})
    return res
}

fn gen_expr(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    if expr == 0 as ref parser.Node { return "0" }
    val k: i64 = expr.kind

    if k == parser.NK_ADDR {
        val inner: ref parser.Node = expr.d0 as ref parser.Node
        if inner.kind == parser.NK_IDENT {
            val name: ref char = inner.d0 as ref char
            val local_ptr: ref char = ll_lookup_local_ptr(ctx, name)
            if str.rchar_cmp(local_ptr, "") != 0 {
                val local_ty: ref parser.Node = ll_lookup_local_type(ctx, name)
                if ll_slot_is_ptr(ctx, local_ty) && (local_ty == 0 as ref parser.Node || local_ty.kind != parser.TY_REF) {
                    val tmp: i64 = fresh_tmp(ctx)
                    val buf: ref char = @alloc(128) as ref char
                    @snprintf(buf, 128, "  %%t{lld} = load ptr, ptr {s}\n", {tmp, local_ptr})
                    emit(ctx, buf)
                    @free(buf)
                    val res: ref char = @alloc(16) as ref char
                    @snprintf(res, 16, "%%t{lld}", {tmp})
                    return res
                }
                return local_ptr
            }
        }
        if inner.kind == parser.NK_FIELD {
            return ll_field_ptr(ctx, inner)
        }
        return gen_expr(ctx, inner)
    }

    if k == parser.NK_DEREF {
        val ptr_val: ref char = gen_expr(ctx, expr.d0 as ref parser.Node)
        val deref_ty: ref parser.Node = ll_expr_storage_type(ctx, expr)
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        if ll_slot_is_ptr(ctx, deref_ty) {
            @snprintf(buf, 128, "  %%t{lld} = load ptr, ptr {s}\n", {tmp, ptr_val})
            emit(ctx, buf)
            @free(buf)
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t{lld}", {tmp})
            return res
        }
        if deref_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(deref_ty), "double") == 0 {
            @snprintf(buf, 128, "  %%t{lld} = load double, ptr {s}\n", {tmp, ptr_val})
            emit(ctx, buf)
            @free(buf)
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t{lld}", {tmp})
            return res
        }
        if deref_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(deref_ty), "float") == 0 {
            @snprintf(buf, 128, "  %%t{lld} = load float, ptr {s}\n", {tmp, ptr_val})
            emit(ctx, buf)
            @free(buf)
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t{lld}", {tmp})
            return res
        }
        if deref_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(deref_ty), "i32") == 0 {
            @snprintf(buf, 128, "  %%t{lld} = load i32, ptr {s}\n", {tmp, ptr_val})
            emit(ctx, buf)
            @free(buf)
            val loaded: ref char = @alloc(16) as ref char
            @snprintf(loaded, 16, "%%t{lld}", {tmp})
            return ll_widen_to_i64(ctx, loaded, deref_ty)
        }
        @snprintf(buf, 128, "  %%t{lld} = load i64, ptr {s}\n", {tmp, ptr_val})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }

    if k == parser.NK_INT_LIT {
        val text: ref char = ll_normalize_int_text(parser.int_lit_text(expr))
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "  %%t{lld} = add i64 {s}, 0\n", {tmp, text})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }

    if k == parser.NK_FLOAT_LIT {
        val text: ref char = parser.float_lit_text(expr)
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(160) as ref char
        @snprintf(buf, 160, "  %%t{lld} = fadd double {s}, 0.000000e+00\n", {tmp, text})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }

    if k == parser.NK_STR_LIT {
        val s: ref char = parser.str_lit_text(expr)
        val idx: i64 = intern_string(ctx, s)
        val tmp: i64 = fresh_tmp(ctx)
        val slen: i64 = str.len_raw(s) + 1
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "  %%t{lld} = getelementptr [{lld} x i8], ptr @__str{lld}, i64 0, i64 0\n", {tmp, slen, idx})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }

    if k == parser.NK_BOOL {
        val v: i64 = expr.d0 as i64
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "  %%t{lld} = add i64 {lld}, 0\n", {tmp, v})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }

    if k == parser.NK_CHAR_LIT {
        val cv: i64 = expr.d0 as i64
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "  %%t{lld} = add i64 {lld}, 0\n", {tmp, cv})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }

    if k == parser.NK_NONE {
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(64) as ref char
        @snprintf(buf, 64, "  %%t{lld} = add i64 0, 0\n", {tmp})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }

    if k == parser.NK_IDENT {
        val name: ref char = expr.d0 as ref char
        val local_ptr: ref char = ll_lookup_local_ptr(ctx, name)
        if str.rchar_cmp(local_ptr, "") != 0 {
            val tmp: i64 = fresh_tmp(ctx)
            val buf: ref char = @alloc(128) as ref char
            val local_ty: ref parser.Node = ll_lookup_local_type(ctx, name)
            if ll_slot_is_ptr(ctx, local_ty) {
                @snprintf(buf, 128, "  %%t{lld} = load ptr, ptr {s}\n", {tmp, local_ptr})
            } elif local_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(local_ty), "double") == 0 {
                @snprintf(buf, 128, "  %%t{lld} = load double, ptr {s}\n", {tmp, local_ptr})
            } elif local_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(local_ty), "float") == 0 {
                @snprintf(buf, 128, "  %%t{lld} = load float, ptr {s}\n", {tmp, local_ptr})
            } elif local_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(local_ty), "i32") == 0 {
                @snprintf(buf, 128, "  %%t{lld} = load i32, ptr {s}\n", {tmp, local_ptr})
            } else {
                @snprintf(buf, 128, "  %%t{lld} = load i64, ptr {s}\n", {tmp, local_ptr})
            }
            emit(ctx, buf)
            @free(buf)
            if str.rchar_cmp(local_ptr, "") != 0 {
                val local_ty2: ref parser.Node = ll_lookup_local_type(ctx, name)
                if local_ty2 != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(local_ty2), "i32") == 0 {
                    val loaded: ref char = @alloc(16) as ref char
                    @snprintf(loaded, 16, "%%t{lld}", {tmp})
                    return ll_widen_to_i64(ctx, loaded, local_ty2)
                }
            }
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t{lld}", {tmp})
            return res
        } else {
            val global_sym: ref char = ll_lookup_module_const_symbol(ctx, name)
            if str.rchar_cmp(global_sym, "") != 0 {
                val tmp: i64 = fresh_tmp(ctx)
                val buf: ref char = @alloc(128) as ref char
                val global_ty: ref parser.Node = ll_lookup_global_type(ctx, global_sym)
                if ll_slot_is_ptr(ctx, global_ty) {
                    @snprintf(buf, 128, "  %%t{lld} = load ptr, ptr @{s}\n", {tmp, global_sym})
                } elif global_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(global_ty), "double") == 0 {
                    @snprintf(buf, 128, "  %%t{lld} = load double, ptr @{s}\n", {tmp, global_sym})
                } elif global_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(global_ty), "float") == 0 {
                    @snprintf(buf, 128, "  %%t{lld} = load float, ptr @{s}\n", {tmp, global_sym})
                } elif global_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(global_ty), "i32") == 0 {
                    @snprintf(buf, 128, "  %%t{lld} = load i32, ptr @{s}\n", {tmp, global_sym})
                } else {
                    @snprintf(buf, 128, "  %%t{lld} = load i64, ptr @{s}\n", {tmp, global_sym})
                }
                emit(ctx, buf)
                @free(buf)
                if global_ty != 0 as ref parser.Node && str.rchar_cmp(ll_type_of(global_ty), "i32") == 0 {
                    val loaded: ref char = @alloc(16) as ref char
                    @snprintf(loaded, 16, "%%t{lld}", {tmp})
                    return ll_widen_to_i64(ctx, loaded, global_ty)
                }
                val res: ref char = @alloc(16) as ref char
                @snprintf(res, 16, "%%t{lld}", {tmp})
                return res
            } else {
                val resolved: ref char = ll_resolve_fn_name(ctx, name)
                val ext_sym: ref char = ll_lookup_extern_symbol(ctx, name)
                val effective: mut ref char = name
                if resolved != 0 as ref char { effective = resolved }
                elif ext_sym != 0 as ref char { effective = ext_sym }
                if str.rchar_cmp(effective, name) != 0 || ll_lookup_fn_ret(ctx, effective) != 0 as ref parser.Node {
                    val sym: ref char = @alloc(str.len_raw(effective) + 2) as ref char
                    @snprintf(sym, str.len_raw(effective) + 2, "@{s}", {effective})
                    return sym
                }
                val tmp: i64 = fresh_tmp(ctx)
                val buf: ref char = @alloc(128) as ref char
                @snprintf(buf, 128, "  %%t{lld} = add i64 %%{s}, 0\n", {tmp, name})
                emit(ctx, buf)
                @free(buf)
                val res: ref char = @alloc(16) as ref char
                @snprintf(res, 16, "%%t{lld}", {tmp})
                return res
            }
        }
    }

    if k == parser.NK_TRUST {
        return gen_expr(ctx, expr.d0 as ref parser.Node)
    }

    if k == parser.NK_BINOP {
        val op: i64 = expr.d0 as i64
        val lhs_node: ref parser.Node = expr.d1 as ref parser.Node
        val rhs_node: ref parser.Node = expr.d2 as ref parser.Node
        val lhs_ty: ref parser.Node = ll_expr_storage_type(ctx, lhs_node)
        val rhs_ty: ref parser.Node = ll_expr_storage_type(ctx, rhs_node)
        val lhs: ref char = gen_expr(ctx, expr.d1 as ref parser.Node)
        val rhs: ref char = gen_expr(ctx, expr.d2 as ref parser.Node)
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(256) as ref char
        val is_float_binop: bool = ll_is_float_type(lhs_ty) || ll_is_float_type(rhs_ty)
        val float_abi: ref char = ll_float_binop_abi(lhs_ty, rhs_ty)
        val lhs_is_result_like: bool = ll_is_result_type(lhs_ty) || lhs_node.kind == parser.NK_OK_VAL || lhs_node.kind == parser.NK_ERR_VAL
        val rhs_is_result_like: bool = ll_is_result_type(rhs_ty) || rhs_node.kind == parser.NK_OK_VAL || rhs_node.kind == parser.NK_ERR_VAL
        if op == parser.OP_ADD {
            if ll_slot_is_ptr(ctx, lhs_ty) && !ll_slot_is_ptr(ctx, rhs_ty) {
                @snprintf(buf, 256, "  %%t{lld} = getelementptr i8, ptr {s}, i64 {s}\n", {tmp, lhs, rhs})
            } elif ll_slot_is_ptr(ctx, rhs_ty) && !ll_slot_is_ptr(ctx, lhs_ty) {
                @snprintf(buf, 256, "  %%t{lld} = getelementptr i8, ptr {s}, i64 {s}\n", {tmp, rhs, lhs})
            } elif is_float_binop { @snprintf(buf, 256, "  %%t{lld} = fadd {s} {s}, {s}\n", {tmp, float_abi, lhs, rhs}) }
            else { @snprintf(buf, 256, "  %%t{lld} = add i64 {s}, {s}\n", {tmp, lhs, rhs}) }
        }
        elif op == parser.OP_SUB {
            if ll_slot_is_ptr(ctx, lhs_ty) && !ll_slot_is_ptr(ctx, rhs_ty) {
                val neg_tmp: i64 = fresh_tmp(ctx)
                @snprintf(buf, 256, "  %%t{lld} = sub i64 0, {s}\n  %%t{lld} = getelementptr i8, ptr {s}, i64 %%t{lld}\n", {neg_tmp, rhs, tmp, lhs, neg_tmp})
            } elif is_float_binop { @snprintf(buf, 256, "  %%t{lld} = fsub {s} {s}, {s}\n", {tmp, float_abi, lhs, rhs}) }
            else { @snprintf(buf, 256, "  %%t{lld} = sub i64 {s}, {s}\n", {tmp, lhs, rhs}) }
        }
        elif op == parser.OP_MUL {
            if is_float_binop { @snprintf(buf, 256, "  %%t{lld} = fmul {s} {s}, {s}\n", {tmp, float_abi, lhs, rhs}) }
            else { @snprintf(buf, 256, "  %%t{lld} = mul i64 {s}, {s}\n", {tmp, lhs, rhs}) }
        }
        elif op == parser.OP_DIV {
            if is_float_binop { @snprintf(buf, 256, "  %%t{lld} = fdiv {s} {s}, {s}\n", {tmp, float_abi, lhs, rhs}) }
            else { @snprintf(buf, 256, "  %%t{lld} = sdiv i64 {s}, {s}\n", {tmp, lhs, rhs}) }
        }
        elif op == parser.OP_REM {
            if is_float_binop { @snprintf(buf, 256, "  %%t{lld} = frem {s} {s}, {s}\n", {tmp, float_abi, lhs, rhs}) }
            else { @snprintf(buf, 256, "  %%t{lld} = srem i64 {s}, {s}\n", {tmp, lhs, rhs}) }
        }
        elif op == parser.OP_EQ {
            val cmp: i64 = fresh_tmp(ctx)
            if lhs_is_result_like && rhs_is_result_like {
                val lhs_payload_ptr: i64 = fresh_tmp(ctx)
                val rhs_payload_ptr: i64 = fresh_tmp(ctx)
                val lhs_tag: i64 = fresh_tmp(ctx)
                val rhs_tag: i64 = fresh_tmp(ctx)
                val lhs_payload: i64 = fresh_tmp(ctx)
                val rhs_payload: i64 = fresh_tmp(ctx)
                val tag_cmp: i64 = fresh_tmp(ctx)
                val payload_cmp: i64 = fresh_tmp(ctx)
                val both_cmp: i64 = fresh_tmp(ctx)
                @snprintf(buf, 512,
                    "  %%t{lld} = getelementptr i8, ptr {s}, i64 8\n  %%t{lld} = getelementptr i8, ptr {s}, i64 8\n  %%t{lld} = load i64, ptr {s}\n  %%t{lld} = load i64, ptr {s}\n  %%t{lld} = load i64, ptr %%t{lld}\n  %%t{lld} = load i64, ptr %%t{lld}\n  %%t{lld} = icmp eq i64 %%t{lld}, %%t{lld}\n  %%t{lld} = icmp eq i64 %%t{lld}, %%t{lld}\n  %%t{lld} = and i1 %%t{lld}, %%t{lld}\n  %%t{lld} = zext i1 %%t{lld} to i64\n",
                    {lhs_payload_ptr, lhs, rhs_payload_ptr, rhs,
                     lhs_tag, lhs, rhs_tag, rhs, lhs_payload, lhs_payload_ptr, rhs_payload, rhs_payload_ptr,
                     tag_cmp, lhs_tag, rhs_tag, payload_cmp, lhs_payload, rhs_payload, both_cmp, tag_cmp, payload_cmp, tmp, both_cmp})
            } elif ll_slot_is_ptr(ctx, lhs_ty) || ll_slot_is_ptr(ctx, rhs_ty) {
                val lhs_cmp: mut ref char = lhs
                val rhs_cmp: mut ref char = rhs
                if ll_expr_is_null_ptr_literal(lhs_node) { lhs_cmp = "null" }
                if ll_expr_is_null_ptr_literal(rhs_node) { rhs_cmp = "null" }
                @snprintf(buf, 256, "  %%t{lld} = icmp eq ptr {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, lhs_cmp, rhs_cmp, tmp, cmp})
            } elif is_float_binop {
                @snprintf(buf, 256, "  %%t{lld} = fcmp oeq {s} {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, float_abi, lhs, rhs, tmp, cmp})
            } else {
                @snprintf(buf, 256, "  %%t{lld} = icmp eq i64 {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, lhs, rhs, tmp, cmp})
            }
        } elif op == parser.OP_NE {
            val cmp: i64 = fresh_tmp(ctx)
            if lhs_is_result_like && rhs_is_result_like {
                val lhs_payload_ptr: i64 = fresh_tmp(ctx)
                val rhs_payload_ptr: i64 = fresh_tmp(ctx)
                val lhs_tag: i64 = fresh_tmp(ctx)
                val rhs_tag: i64 = fresh_tmp(ctx)
                val lhs_payload: i64 = fresh_tmp(ctx)
                val rhs_payload: i64 = fresh_tmp(ctx)
                val tag_cmp: i64 = fresh_tmp(ctx)
                val payload_cmp: i64 = fresh_tmp(ctx)
                val both_cmp: i64 = fresh_tmp(ctx)
                @snprintf(buf, 512,
                    "  %%t{lld} = getelementptr i8, ptr {s}, i64 8\n  %%t{lld} = getelementptr i8, ptr {s}, i64 8\n  %%t{lld} = load i64, ptr {s}\n  %%t{lld} = load i64, ptr {s}\n  %%t{lld} = load i64, ptr %%t{lld}\n  %%t{lld} = load i64, ptr %%t{lld}\n  %%t{lld} = icmp eq i64 %%t{lld}, %%t{lld}\n  %%t{lld} = icmp eq i64 %%t{lld}, %%t{lld}\n  %%t{lld} = and i1 %%t{lld}, %%t{lld}\n  %%t{lld} = xor i1 %%t{lld}, true\n  %%t{lld} = zext i1 %%t{lld} to i64\n",
                    {lhs_payload_ptr, lhs, rhs_payload_ptr, rhs, lhs_tag, lhs, rhs_tag, rhs,
                     lhs_payload, lhs_payload_ptr, rhs_payload, rhs_payload_ptr, tag_cmp, lhs_tag, rhs_tag,
                     payload_cmp, lhs_payload, rhs_payload, both_cmp, tag_cmp, payload_cmp, cmp, both_cmp, tmp, cmp})
            } elif ll_slot_is_ptr(ctx, lhs_ty) || ll_slot_is_ptr(ctx, rhs_ty) {
                val lhs_cmp: mut ref char = lhs
                val rhs_cmp: mut ref char = rhs
                if ll_expr_is_null_ptr_literal(lhs_node) { lhs_cmp = "null" }
                if ll_expr_is_null_ptr_literal(rhs_node) { rhs_cmp = "null" }
                @snprintf(buf, 256, "  %%t{lld} = icmp ne ptr {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, lhs_cmp, rhs_cmp, tmp, cmp})
            } elif is_float_binop {
                @snprintf(buf, 256, "  %%t{lld} = fcmp one {s} {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, float_abi, lhs, rhs, tmp, cmp})
            } else {
                @snprintf(buf, 256, "  %%t{lld} = icmp ne i64 {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, lhs, rhs, tmp, cmp})
            }
        } elif op == parser.OP_LT {
            val cmp: i64 = fresh_tmp(ctx)
            if is_float_binop { @snprintf(buf, 256, "  %%t{lld} = fcmp olt {s} {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, float_abi, lhs, rhs, tmp, cmp}) }
            else { @snprintf(buf, 256, "  %%t{lld} = icmp slt i64 {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, lhs, rhs, tmp, cmp}) }
        } elif op == parser.OP_GT {
            val cmp: i64 = fresh_tmp(ctx)
            if is_float_binop { @snprintf(buf, 256, "  %%t{lld} = fcmp ogt {s} {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, float_abi, lhs, rhs, tmp, cmp}) }
            else { @snprintf(buf, 256, "  %%t{lld} = icmp sgt i64 {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, lhs, rhs, tmp, cmp}) }
        } elif op == parser.OP_LE {
            val cmp: i64 = fresh_tmp(ctx)
            if is_float_binop { @snprintf(buf, 256, "  %%t{lld} = fcmp ole {s} {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, float_abi, lhs, rhs, tmp, cmp}) }
            else { @snprintf(buf, 256, "  %%t{lld} = icmp sle i64 {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, lhs, rhs, tmp, cmp}) }
        } elif op == parser.OP_GE {
            val cmp: i64 = fresh_tmp(ctx)
            if is_float_binop { @snprintf(buf, 256, "  %%t{lld} = fcmp oge {s} {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, float_abi, lhs, rhs, tmp, cmp}) }
            else { @snprintf(buf, 256, "  %%t{lld} = icmp sge i64 {s}, {s}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {cmp, lhs, rhs, tmp, cmp}) }
        } elif op == parser.OP_AND {
            val c1: i64 = fresh_tmp(ctx)
            val c2: i64 = fresh_tmp(ctx)
            val a: i64 = fresh_tmp(ctx)
            @snprintf(buf, 256, "  %%t{lld} = icmp ne i64 {s}, 0\n  %%t{lld} = icmp ne i64 {s}, 0\n  %%t{lld} = and i1 %%t{lld}, %%t{lld}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {c1, lhs, c2, rhs, a, c1, c2, tmp, a})
        } elif op == parser.OP_OR {
            val c1: i64 = fresh_tmp(ctx)
            val c2: i64 = fresh_tmp(ctx)
            val o: i64 = fresh_tmp(ctx)
            @snprintf(buf, 256, "  %%t{lld} = icmp ne i64 {s}, 0\n  %%t{lld} = icmp ne i64 {s}, 0\n  %%t{lld} = or i1 %%t{lld}, %%t{lld}\n  %%t{lld} = zext i1 %%t{lld} to i64\n", {c1, lhs, c2, rhs, o, c1, c2, tmp, o})
        } elif op == parser.OP_BAND { @snprintf(buf, 256, "  %%t{lld} = and i64 {s}, {s}\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_BOR  { @snprintf(buf, 256, "  %%t{lld} = or i64 {s}, {s}\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_BXOR { @snprintf(buf, 256, "  %%t{lld} = xor i64 {s}, {s}\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_SHL  { @snprintf(buf, 256, "  %%t{lld} = shl i64 {s}, {s}\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_SHR  { @snprintf(buf, 256, "  %%t{lld} = ashr i64 {s}, {s}\n", {tmp, lhs, rhs}) }
        else { @snprintf(buf, 256, "  %%t{lld} = add i64 {s}, {s}\n", {tmp, lhs, rhs}) }
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {tmp})
        return res
    }

    if k == parser.NK_UNOP { return gen_expr_unop(ctx, expr) }

    if k == parser.NK_CALL {
        return gen_call(ctx, expr)
    }

    if k == parser.NK_FIELD { return gen_expr_field(ctx, expr) }

    if k == parser.NK_BUILTIN {
        return gen_builtin(ctx, expr)
    }

    if k == parser.NK_CAST { return gen_expr_cast(ctx, expr) }

    if k == parser.NK_SOME { return gen_expr_some(ctx, expr) }

    if k == parser.NK_OK_VAL { return gen_expr_ok_val(ctx, expr) }

    if k == parser.NK_ERR_VAL { return gen_expr_err_val(ctx, expr) }

    if k == parser.NK_LIST_LIT {
        ensure_declared(ctx, "malloc", "declare ptr @malloc(i64)")
        val elems: ref void = expr.d0 as ref void
        val elen: mut i64 = 0
        if elems != 0 as ref void { elen = @len(elems as list[ref parser.Node]) as i64 }
        val cap: mut i64 = 1
        if elen > 0 { cap = elen }
        val elem_ty: ref parser.Node = ll_list_lit_inner_type(ctx, elems)
        val hdr_tmp: i64 = fresh_tmp(ctx)
        val buf_tmp: i64 = fresh_tmp(ctx)
        val lbuf1: ref char = @alloc(256) as ref char
        @snprintf(lbuf1, 256, "  %%t{lld} = call ptr @malloc(i64 24)\n  %%t{lld} = call ptr @malloc(i64 {lld})\n", {hdr_tmp, buf_tmp, cap * 8})
        emit(ctx, lbuf1)
        @free(lbuf1)
        val lbuf2: ref char = @alloc(256) as ref char
        @snprintf(lbuf2, 256, "  store ptr %%t{lld}, ptr %%t{lld}\n", {buf_tmp, hdr_tmp})
        emit(ctx, lbuf2)
        @free(lbuf2)
        val len_ptr: i64 = fresh_tmp(ctx)
        val cap_ptr: i64 = fresh_tmp(ctx)
        val lbuf3: ref char = @alloc(256) as ref char
        @snprintf(lbuf3, 256,
            "  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 8\n  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 16\n  store i64 {lld}, ptr %%t{lld}\n  store i64 {lld}, ptr %%t{lld}\n",
            {len_ptr, hdr_tmp, cap_ptr, hdr_tmp, elen, len_ptr, cap, cap_ptr})
        emit(ctx, lbuf3)
        @free(lbuf3)
        if elems != 0 as ref void {
            val ei: mut i64 = 0
            for {
                if ei >= elen { break }
                val e_opt = @get(elems as list[ref parser.Node], ei as usize)
                match e_opt {
                    some e => {
                        val elem_node: ref parser.Node = e as ref parser.Node
                        val elem_raw: ref char = gen_expr(ctx, elem_node)
                        val elem_val: ref char = ll_coerce_value_for_type(ctx, elem_node, elem_ty, elem_raw)
                        val off_tmp: i64 = fresh_tmp(ctx)
                        val elem_ptr: i64 = fresh_tmp(ctx)
                        val lbuf4: ref char = @alloc(256) as ref char
                        @snprintf(lbuf4, 256, "  %%t{lld} = add i64 {lld}, 0\n  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 %%t{lld}\n",
                            {off_tmp, ei * 8, elem_ptr, buf_tmp, off_tmp})
                        emit(ctx, lbuf4)
                        @free(lbuf4)
                        val elem_ptr_name: ref char = @alloc(16) as ref char
                        @snprintf(elem_ptr_name, 16, "%%t{lld}", {elem_ptr})
                        ll_emit_store_value(ctx, elem_ptr_name, elem_ty, elem_val)
                    }
                    none => {}
                }
                ei++
            }
        }
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {hdr_tmp})
        return res
    }

    if k == parser.NK_STRUCT_LIT {
        val fields: ref void = expr.d0 as ref void
        val flen: mut i64 = 0
        if fields != 0 as ref void { flen = @len(fields) as i64 }
        val struct_fields: mut ref void = 0 as ref void
        if flen > 0 {
            val f0_opt = @get(fields, 0)
            match f0_opt {
                some f0 => {
                    val fname0: ref char = (f0 as ref parser.Node).d0 as ref char
                    val slen: i64 = @len(ctx.snames) as i64
                    val si: mut i64 = 0
                    for {
                        if si >= slen { break }
                        val sf_opt = @get(ctx.sfields, si as usize)
                        match sf_opt {
                            some sf => {
                                val sfields: ref void = sf as ref void
                                val off: i64 = ll_field_offset(ctx, sfields, fname0)
                                if off >= 0 {
                                    struct_fields = sfields
                                    si = slen
                                }
                            }
                            none => {}
                        }
                        si++
                    }
                }
                none => {}
            }
        }
        ensure_declared(ctx, "malloc", "declare ptr @malloc(i64)")
        val size: mut i64 = flen * 8
        if struct_fields != 0 as ref void { size = ll_struct_size(ctx, struct_fields) }
        val ptr_tmp: i64 = fresh_tmp(ctx)
        val abuf: ref char = @alloc(128) as ref char
        @snprintf(abuf, 128, "  %%t{lld} = call ptr @malloc(i64 {lld})\n", {ptr_tmp, size})
        emit(ctx, abuf)
        @free(abuf)
        val fi: mut i64 = 0
        for {
            if fi >= flen { break }
            val f_opt = @get(fields, fi as usize)
            match f_opt {
                some f => {
                    val fnode: ref parser.Node = f as ref parser.Node
                    val fname: ref char = fnode.d0 as ref char
                    val fexpr: ref parser.Node = fnode.d1 as ref parser.Node
                    val fty: ref parser.Node = ll_field_type(struct_fields, fname)
                    val off: mut i64 = fi * 8
                    if struct_fields != 0 as ref void {
                        val real_off: i64 = ll_field_offset(ctx, struct_fields, fname)
                        if real_off >= 0 { off = real_off }
                    }
                    val fptr: ref char = @alloc(16) as ref char
                    if off == 0 {
                        @snprintf(fptr, 16, "%%t{lld}", {ptr_tmp})
                    } else {
                        val off_tmp: i64 = fresh_tmp(ctx)
                        val obuf: ref char = @alloc(128) as ref char
                        @snprintf(obuf, 128, "  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 {lld}\n", {off_tmp, ptr_tmp, off})
                        emit(ctx, obuf)
                        @free(obuf)
                        @snprintf(fptr, 16, "%%t{lld}", {off_tmp})
                    }
                    ll_emit_store_value(ctx, fptr, fty, gen_expr(ctx, fexpr))
                }
                none => {}
            }
            fi++
        }
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t{lld}", {ptr_tmp})
        return res
    }

    if k == parser.NK_TRY {
        return gen_try(ctx, expr)
    }

    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(64) as ref char
    @snprintf(buf, 64, "  %%t{lld} = add i64 0, 0\n", {tmp})
    emit(ctx, buf)
    @free(buf)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t{lld}", {tmp})
    return res
}


fn gen_builtin(ctx: ref LLCtx, expr: ref parser.Node) ref char! = {
    val name: ref char = expr.d0 as ref char
    val args: ref void = expr.d1 as ref void
    val tmp: mut i64 = fresh_tmp(ctx)

    if str.rchar_cmp(name, "puts") == 0 {
        ensure_declared(ctx, "puts", "declare i32 @puts(ptr)")
        val s: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val puts_tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "  %%t{lld} = call i32 @puts(ptr {s})\n  %%t{lld} = sext i32 %%t{lld} to i64\n", {puts_tmp, s, tmp, puts_tmp})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "alloc") == 0 {
        ensure_declared(ctx, "malloc", "declare ptr @malloc(i64)")
        val sz: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "  %%t{lld} = call ptr @malloc(i64 {s})\n", {tmp, sz})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "free") == 0 {
        ensure_declared(ctx, "free", "declare void @free(ptr)")
        val ptr: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "  call void @free(ptr {s})\n  %%t{lld} = add i64 0, 0\n", {ptr, tmp})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "realloc") == 0 {
        ensure_declared(ctx, "realloc", "declare ptr @realloc(ptr, i64)")
        val ptr: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val sz: ref char = gen_expr(ctx, get_arg_node(args, 1))
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "  %%t{lld} = call ptr @realloc(ptr {s}, i64 {s})\n", {tmp, ptr, sz})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "memcpy") == 0 {
        ensure_declared(ctx, "memcpy", "declare ptr @memcpy(ptr, ptr, i64)")
        val dst: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val src: ref char = gen_expr(ctx, get_arg_node(args, 1))
        val len: ref char = gen_expr(ctx, get_arg_node(args, 2))
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "  call ptr @memcpy(ptr {s}, ptr {s}, i64 {s})\n  %%t{lld} = add i64 0, 0\n", {dst, src, len, tmp})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "memset") == 0 {
        ensure_declared(ctx, "memset", "declare ptr @memset(ptr, i32, i64)")
        val dst: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val val2: ref char = gen_expr(ctx, get_arg_node(args, 1))
        val len: ref char = gen_expr(ctx, get_arg_node(args, 2))
        val tr: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(512) as ref char
        @snprintf(buf, 512, "  %%t{lld} = trunc i64 {s} to i32\n  call ptr @memset(ptr {s}, i32 %%t{lld}, i64 {s})\n  %%t{lld} = add i64 0, 0\n", {tr, val2, dst, tr, len, tmp})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "load") == 0 {
        val ptr: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "  %%t{lld} = load i64, ptr {s}\n", {tmp, ptr})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "store") == 0 {
        val ptr: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val val_node3: ref parser.Node = get_arg_node(args, 1)
        val val3_raw: ref char = gen_expr(ctx, val_node3)
        val val3: mut ref char = val3_raw
        val val_ty3: ref parser.Node = ll_expr_storage_type(ctx, val_node3)
        if ll_slot_is_ptr(ctx, val_ty3) {
            val3 = ll_coerce_ptr_to_word(ctx, val3_raw)
        }
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "  store i64 {s}, ptr {s}\n  %%t{lld} = add i64 0, 0\n", {val3, ptr, tmp})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "load8") == 0 {
        val ptr: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val bt: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "  %%t{lld} = load i8, ptr {s}\n  %%t{lld} = zext i8 %%t{lld} to i64\n", {bt, ptr, tmp, bt})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "store8") == 0 {
        val ptr: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val val4: ref char = gen_expr(ctx, get_arg_node(args, 1))
        val tr: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "  %%t{lld} = trunc i64 {s} to i8\n  store i8 %%t{lld}, ptr {s}\n  %%t{lld} = add i64 0, 0\n", {tr, val4, tr, ptr, tmp})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "ptradd") == 0 {
        val ptr: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val off: ref char = gen_expr(ctx, get_arg_node(args, 1))
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "  %%t{lld} = getelementptr i8, ptr {s}, i64 {s}\n", {tmp, ptr, off})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "sizeof") == 0 {
        val arg_nd: ref parser.Node = get_arg_node(args, 0)
        val sizeof_val: mut i64 = 0
        if arg_nd != 0 as ref parser.Node {
            val arg_k: i64 = arg_nd.kind
            if arg_k == parser.TY_NAMED || arg_k == parser.TY_LIST || arg_k == parser.TY_REF ||
               arg_k == parser.TY_MUT || arg_k == parser.TY_OPTION || arg_k == parser.TY_RESULT ||
               arg_k == parser.TY_SLICE || arg_k == parser.TY_FIXED_ARR || arg_k == parser.TY_FNPTR ||
               arg_k == parser.TY_VOID {
                sizeof_val = ll_type_size(ctx, arg_nd)
            } elif arg_k == parser.NK_CAST {
                sizeof_val = ll_type_size(ctx, arg_nd.d1 as ref parser.Node)
            } else {
                sizeof_val = ll_type_size(ctx, ll_expr_storage_type(ctx, arg_nd))
            }
        }
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "  %%t{lld} = add i64 {lld}, 0\n", {tmp, sizeof_val})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "append") == 0 {
        ensure_declared(ctx, "realloc", "declare ptr @realloc(ptr, i64)")
        val list_node: ref parser.Node = get_arg_node(args, 0)
        val val_node: ref parser.Node = get_arg_node(args, 1)
        val lp: ref char = gen_expr(ctx, list_node)
        val list_ty: ref parser.Node = ll_expr_storage_type(ctx, list_node)
        val elem_ty: mut ref parser.Node = 0 as ref parser.Node
        if list_ty != 0 as ref parser.Node {
            val inner_list_ty: mut ref parser.Node = list_ty
            if inner_list_ty.kind == parser.TY_MUT {
                inner_list_ty = inner_list_ty.d0 as ref parser.Node
            }
            if inner_list_ty.kind == parser.TY_LIST || inner_list_ty.kind == parser.TY_SLICE {
                elem_ty = inner_list_ty.d0 as ref parser.Node
            }
        }
        val len_ptr: i64 = fresh_tmp(ctx)
        val cap_ptr: i64 = fresh_tmp(ctx)
        val len_val: i64 = fresh_tmp(ctx)
        val cap_val: i64 = fresh_tmp(ctx)
        val fits: i64 = fresh_tmp(ctx)
        val grow_lbl: i64 = fresh_lbl(ctx)
        val cont_lbl: i64 = fresh_lbl(ctx)
        val abuf1: ref char = @alloc(512) as ref char
        @snprintf(abuf1, 512,
            "  %%t{lld} = getelementptr i8, ptr {s}, i64 8\n  %%t{lld} = getelementptr i8, ptr {s}, i64 16\n  %%t{lld} = load i64, ptr %%t{lld}\n  %%t{lld} = load i64, ptr %%t{lld}\n  %%t{lld} = icmp slt i64 %%t{lld}, %%t{lld}\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
            {len_ptr, lp, cap_ptr, lp, len_val, len_ptr, cap_val, cap_ptr, fits, len_val, cap_val, fits, cont_lbl, grow_lbl, grow_lbl})
        emit(ctx, abuf1)
        @free(abuf1)
        val new_cap_tmp: i64 = fresh_tmp(ctx)
        val new_cap: i64 = fresh_tmp(ctx)
        val old_buf: i64 = fresh_tmp(ctx)
        val new_cap_bytes: i64 = fresh_tmp(ctx)
        val new_buf: i64 = fresh_tmp(ctx)
        val abuf2: ref char = @alloc(512) as ref char
        @snprintf(abuf2, 512,
            "  %%t{lld} = mul i64 %%t{lld}, 2\n  %%t{lld} = add i64 %%t{lld}, 1\n  %%t{lld} = load ptr, ptr {s}\n  %%t{lld} = mul i64 %%t{lld}, 8\n  %%t{lld} = call ptr @realloc(ptr %%t{lld}, i64 %%t{lld})\n  store ptr %%t{lld}, ptr {s}\n  store i64 %%t{lld}, ptr %%t{lld}\n  br label %%lbl{lld}\nlbl{lld}:\n",
            {new_cap_tmp, cap_val, new_cap, new_cap_tmp, old_buf, lp, new_cap_bytes, new_cap, new_buf, old_buf, new_cap_bytes, new_buf, lp, new_cap, cap_ptr, cont_lbl, cont_lbl})
        emit(ctx, abuf2)
        @free(abuf2)
        val buf_tmp: i64 = fresh_tmp(ctx)
        val off: i64 = fresh_tmp(ctx)
        val elem_ptr: i64 = fresh_tmp(ctx)
        val abuf3: ref char = @alloc(256) as ref char
        @snprintf(abuf3, 256,
            "  %%t{lld} = load ptr, ptr {s}\n  %%t{lld} = mul i64 %%t{lld}, 8\n  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 %%t{lld}\n",
            {buf_tmp, lp, off, len_val, elem_ptr, buf_tmp, off})
        emit(ctx, abuf3)
        @free(abuf3)
        val elem_ptr_name: ref char = @alloc(16) as ref char
        @snprintf(elem_ptr_name, 16, "%%t{lld}", {elem_ptr})
        val val_raw: ref char = gen_expr(ctx, val_node)
        val elem_is_ptr: mut bool = ll_slot_is_ptr(ctx, elem_ty)
        val store_ty: mut ref parser.Node = elem_ty
        if !elem_is_ptr && elem_ty == 0 as ref parser.Node {
            elem_is_ptr = ll_some_payload_is_ptr_like(ctx, val_node)
            if elem_is_ptr {
                store_ty = ll_expr_storage_type(ctx, val_node)
            }
        }
        if elem_is_ptr {
            if store_ty == 0 as ref parser.Node {
                store_ty = ll_make_ref_type(0 as ref parser.Node)
            }
            ll_emit_store_value(ctx, elem_ptr_name, store_ty, val_raw)
        } else {
            val store_val: ref char = ll_coerce_value_for_type(ctx, val_node, ll_make_named_type("i64"), val_raw)
            val sbuf: ref char = @alloc(128) as ref char
            @snprintf(sbuf, 128, "  store i64 {s}, ptr {s}\n", {store_val, elem_ptr_name})
            emit(ctx, sbuf)
            @free(sbuf)
        }
        val new_len: i64 = fresh_tmp(ctx)
        val abuf4: ref char = @alloc(160) as ref char
        @snprintf(abuf4, 160, "  %%t{lld} = add i64 %%t{lld}, 1\n  store i64 %%t{lld}, ptr %%t{lld}\n  %%t{lld} = add i64 0, 0\n",
            {new_len, len_val, new_len, len_ptr, tmp})
        emit(ctx, abuf4)
        @free(abuf4)
    } elif str.rchar_cmp(name, "len") == 0 {
        val lp: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val lptr: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "  %%t{lld} = getelementptr i8, ptr {s}, i64 8\n  %%t{lld} = load i64, ptr %%t{lld}\n", {lptr, lp, tmp, lptr})
        emit(ctx, buf)
        @free(buf)
    } elif str.rchar_cmp(name, "get") == 0 {
        val list_node: ref parser.Node = get_arg_node(args, 0)
        val idx_node: ref parser.Node = get_arg_node(args, 1)
        val lp: ref char = gen_expr(ctx, list_node)
        val idx: ref char = gen_expr(ctx, idx_node)
        val list_ty: ref parser.Node = ll_expr_storage_type(ctx, list_node)
        val inner_ty: mut ref parser.Node = 0 as ref parser.Node
        if list_ty != 0 as ref parser.Node {
            if list_ty.kind == parser.TY_LIST || list_ty.kind == parser.TY_SLICE {
                inner_ty = list_ty.d0 as ref parser.Node
            }
        }
        val len_ptr: i64 = fresh_tmp(ctx)
        val len_val: i64 = fresh_tmp(ctx)
        val result_slot: i64 = fresh_tmp(ctx)
        val in_bounds: i64 = fresh_tmp(ctx)
        val some_lbl: i64 = fresh_lbl(ctx)
        val none_lbl: i64 = fresh_lbl(ctx)
        val end_lbl: i64 = fresh_lbl(ctx)
        val gbuf1: ref char = @alloc(512) as ref char
        @snprintf(gbuf1, 512,
            "  %%t{lld} = getelementptr i8, ptr {s}, i64 8\n  %%t{lld} = load i64, ptr %%t{lld}\n  %%t{lld} = alloca i64, align 8\n  %%t{lld} = icmp slt i64 {s}, %%t{lld}\n  br i1 %%t{lld}, label %%lbl{lld}, label %%lbl{lld}\nlbl{lld}:\n",
            {len_ptr, lp, len_val, len_ptr, result_slot, in_bounds, idx, len_val, in_bounds, some_lbl, none_lbl, some_lbl})
        emit(ctx, gbuf1)
        @free(gbuf1)
        val data_ptr: i64 = fresh_tmp(ctx)
        val off: i64 = fresh_tmp(ctx)
        val elem_ptr: i64 = fresh_tmp(ctx)
        val elem_word: mut ref char = ""
        if ll_slot_is_ptr(ctx, inner_ty) {
            val elem_ptr_val: i64 = fresh_tmp(ctx)
            val elem_as_word: i64 = fresh_tmp(ctx)
            val gbuf2: ref char = @alloc(512) as ref char
            @snprintf(gbuf2, 512,
                "  %%t{lld} = load ptr, ptr {s}\n  %%t{lld} = mul i64 {s}, 8\n  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 %%t{lld}\n  %%t{lld} = load ptr, ptr %%t{lld}\n  %%t{lld} = ptrtoint ptr %%t{lld} to i64\n",
                {data_ptr, lp, off, idx, elem_ptr, data_ptr, off, elem_ptr_val, elem_ptr, elem_as_word, elem_ptr_val})
            emit(ctx, gbuf2)
            @free(gbuf2)
            elem_word = @alloc(16) as ref char
            @snprintf(elem_word, 16, "%%t{lld}", {elem_as_word})
        } else {
            val elem_val: i64 = fresh_tmp(ctx)
            val gbuf2: ref char = @alloc(512) as ref char
            @snprintf(gbuf2, 512,
                "  %%t{lld} = load ptr, ptr {s}\n  %%t{lld} = mul i64 {s}, 8\n  %%t{lld} = getelementptr i8, ptr %%t{lld}, i64 %%t{lld}\n  %%t{lld} = load i64, ptr %%t{lld}\n",
                {data_ptr, lp, off, idx, elem_ptr, data_ptr, off, elem_val, elem_ptr})
            emit(ctx, gbuf2)
            @free(gbuf2)
            elem_word = @alloc(16) as ref char
            @snprintf(elem_word, 16, "%%t{lld}", {elem_val})
        }
        val some_val: i64 = fresh_tmp(ctx)
        val gbuf3: ref char = @alloc(256) as ref char
        @snprintf(gbuf3, 256,
            "  %%t{lld} = add i64 {s}, 1\n  store i64 %%t{lld}, ptr %%t{lld}\n  br label %%lbl{lld}\nlbl{lld}:\n  store i64 0, ptr %%t{lld}\n  br label %%lbl{lld}\nlbl{lld}:\n  %%t{lld} = load i64, ptr %%t{lld}\n",
            {some_val, elem_word, some_val, result_slot, end_lbl, none_lbl, result_slot, end_lbl, end_lbl, tmp, result_slot})
        emit(ctx, gbuf3)
        @free(gbuf3)
    } elif str.rchar_cmp(name, "printf") == 0 {
        ensure_declared(ctx, "printf", "declare i32 @printf(ptr, ...)")
        val fmt_node: ref parser.Node = get_arg_node(args, 0)
        val fmt: mut ref char = ""
        if fmt_node != 0 as ref parser.Node && fmt_node.kind == parser.NK_STR_LIT {
            val s: ref char = parser.str_lit_text(fmt_node)
            val idx: i64 = intern_format_string(ctx, s)
            val slen: i64 = str.len_raw(rewrite_fmt(s)) + 1
            val ft: i64 = fresh_tmp(ctx)
            val fb: ref char = @alloc(128) as ref char
            @snprintf(fb, 128, "  %%t{lld} = getelementptr [{lld} x i8], ptr @__str{lld}, i64 0, i64 0\n", {ft, slen, idx})
            emit(ctx, fb)
            @free(fb)
            val fres: ref char = @alloc(16) as ref char
            @snprintf(fres, 16, "%%t{lld}", {ft})
            fmt = fres
        } else {
            fmt = gen_expr(ctx, fmt_node)
        }
        val call_sb: ref void = str.StringBuilder.new()
        val printf_tmp: i64 = fresh_tmp(ctx)
        val hdr: ref char = @alloc(256) as ref char
        @snprintf(hdr, 256, "  %%t{lld} = call i32 (ptr, ...) @printf(ptr {s}", {printf_tmp, fmt})
        str.StringBuilder.append_cstr(call_sb, hdr)
        @free(hdr)
        if args != 0 as ref void {
            val alen: i64 = @len(args) as i64
            if alen > 1 {
                val pack_opt = @get(args, 1)
                match pack_opt {
                    some pack_node => {
                        val pn: ref parser.Node = pack_node as ref parser.Node
                        if pn.kind == parser.NK_ARGS_PACK {
                            val pack: ref void = pn.d0 as ref void
                            val plen: i64 = @len(pack) as i64
                            val pi: mut i64 = 0
                            for {
                                if pi >= plen { break }
                                val pe_opt = @get(pack, pi as usize)
                                match pe_opt {
                                    some pe => {
                                        val pe_node: ref parser.Node = pe as ref parser.Node
                                        val pv: ref char = gen_expr(ctx, pe_node)
                                        val ab: ref char = @alloc(64) as ref char
                                        @snprintf(ab, 64, ", {s} {s}", {ll_variadic_abi_type(ctx, pe_node), pv})
                                        str.StringBuilder.append_cstr(call_sb, ab)
                                        @free(ab)
                                    }
                                    none => {}
                                }
                                pi++
                            }
                        }
                    }
                    none => {}
                }
            }
        }
        str.StringBuilder.append_cstr(call_sb, ")\n")
        emit(ctx, str.cstr(str.StringBuilder.build(call_sb)))
        str.StringBuilder.free(call_sb)
        val ebuf: ref char = @alloc(128) as ref char
        @snprintf(ebuf, 128, "  %%t{lld} = sext i32 %%t{lld} to i64\n", {tmp, printf_tmp})
        emit(ctx, ebuf)
        @free(ebuf)
    } elif str.rchar_cmp(name, "dprintf") == 0 {
        ensure_declared(ctx, "dprintf", "declare i32 @dprintf(i32, ptr, ...)")
        val fd_arg: ref char = gen_expr(ctx, get_arg_node(args, 0))
        val fd32: i64 = fresh_tmp(ctx)
        val fd_buf: ref char = @alloc(64) as ref char
        @snprintf(fd_buf, 64, "  %%t{lld} = trunc i64 {s} to i32\n", {fd32, fd_arg})
        emit(ctx, fd_buf)
        @free(fd_buf)
        val fmt_node: ref parser.Node = get_arg_node(args, 1)
        val fmt: mut ref char = ""
        if fmt_node != 0 as ref parser.Node && fmt_node.kind == parser.NK_STR_LIT {
            val s: ref char = parser.str_lit_text(fmt_node)
            val idx: i64 = intern_format_string(ctx, s)
            val slen: i64 = str.len_raw(rewrite_fmt(s)) + 1
            val ft: i64 = fresh_tmp(ctx)
            val fb: ref char = @alloc(128) as ref char
            @snprintf(fb, 128, "  %%t{lld} = getelementptr [{lld} x i8], ptr @__str{lld}, i64 0, i64 0\n", {ft, slen, idx})
            emit(ctx, fb)
            @free(fb)
            val fres: ref char = @alloc(16) as ref char
            @snprintf(fres, 16, "%%t{lld}", {ft})
            fmt = fres
        } else {
            fmt = gen_expr(ctx, fmt_node)
        }
        val call_sb: ref void = str.StringBuilder.new()
        val dprintf_tmp: i64 = fresh_tmp(ctx)
        val hdr: ref char = @alloc(256) as ref char
        @snprintf(hdr, 256, "  %%t{lld} = call i32 (i32, ptr, ...) @dprintf(i32 %%t{lld}, ptr {s}", {dprintf_tmp, fd32, fmt})
        str.StringBuilder.append_cstr(call_sb, hdr)
        @free(hdr)
        if args != 0 as ref void {
            val alen: i64 = @len(args) as i64
            if alen > 2 {
                val pack_opt = @get(args, 2)
                match pack_opt {
                    some pack_node => {
                        val pn: ref parser.Node = pack_node as ref parser.Node
                        if pn.kind == parser.NK_ARGS_PACK {
                            val pack: ref void = pn.d0 as ref void
                            val plen: i64 = @len(pack) as i64
                            val pi: mut i64 = 0
                            for {
                                if pi >= plen { break }
                                val pe_opt = @get(pack, pi as usize)
                                match pe_opt {
                                    some pe => {
                                        val pe_node: ref parser.Node = pe as ref parser.Node
                                        val pv: ref char = gen_expr(ctx, pe_node)
                                        val ab: ref char = @alloc(64) as ref char
                                        @snprintf(ab, 64, ", {s} {s}", {ll_variadic_abi_type(ctx, pe_node), pv})
                                        str.StringBuilder.append_cstr(call_sb, ab)
                                        @free(ab)
                                    }
                                    none => {}
                                }
                                pi++
                            }
                        } else {
                            val pv2: ref char = gen_expr(ctx, pn)
                            val ab2: ref char = @alloc(64) as ref char
                            @snprintf(ab2, 64, ", {s} {s}", {ll_variadic_abi_type(ctx, pn), pv2})
                            str.StringBuilder.append_cstr(call_sb, ab2)
                            @free(ab2)
                        }
                    }
                    none => {}
                }
            }
        }
        str.StringBuilder.append_cstr(call_sb, ")\n")
        emit(ctx, str.cstr(str.StringBuilder.build(call_sb)))
        str.StringBuilder.free(call_sb)
        val ebuf: ref char = @alloc(128) as ref char
        @snprintf(ebuf, 128, "  %%t{lld} = sext i32 %%t{lld} to i64\n", {tmp, dprintf_tmp})
        emit(ctx, ebuf)
        @free(ebuf)
    } elif str.rchar_cmp(name, "gettimeofday") == 0 {
        ensure_declared(ctx, "gettimeofday", "declare i32 @gettimeofday(ptr, ptr)")
        val tv_node: ref parser.Node = get_arg_node(args, 0)
        val tz_node: ref parser.Node = get_arg_node(args, 1)
        val tv_arg: ref char = gen_expr(ctx, tv_node)
        val tz_arg_raw: ref char = gen_expr(ctx, tz_node)
        val tz_arg: mut ref char = tz_arg_raw
        if ll_expr_is_null_ptr_literal(tz_node) { tz_arg = "null" }
        val gtod_tmp: i64 = fresh_tmp(ctx)
        val gbuf: ref char = @alloc(192) as ref char
        @snprintf(gbuf, 192, "  %%t{lld} = call i32 @gettimeofday(ptr {s}, ptr {s})\n  %%t{lld} = sext i32 %%t{lld} to i64\n",
            {gtod_tmp, tv_arg, tz_arg, tmp, gtod_tmp})
        emit(ctx, gbuf)
        @free(gbuf)
    } elif str.rchar_cmp(name, "snprintf") == 0 {
        ensure_declared(ctx, "snprintf", "declare i32 @snprintf(ptr, i64, ptr, ...)")
