            val ft: i64 = fresh_tmp(ctx)
            val fb: ref char = @alloc(128) as ref char
            @snprintf(fb, 128, "  %%t{lld} = getelementptr [{lld} x i8], ptr @__str{lld}, i64 0, i64 0\n", {ft, slen, idx})
            emit(ctx, fb)
            @free(fb)
            val fres: ref char = @alloc(16) as ref char
            @snprintf(fres, 16, "%%t{lld}", {ft})
            sfmt = fres
