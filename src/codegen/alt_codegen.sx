val std        = use("std")
val str        = use("std/string")
val reflection = use("std/reflection")
val parser     = use("../ast/parser.sx")
val module     = use("../module/module.sx")
val codegen    = use("codegen.sx")

pub type CCtx = {
    sb: mut ref void
    tmp: mut i64
    lbl: mut i64
    fn_name: mut ref char
    strs: mut list[ref char]
    str_cnt: mut i64
    snames: mut list[ref char]
    sfields: mut list[ref void]
    unames: mut list[ref char]
    uvariants: mut list[ref void]
    fn_names: mut list[ref char]
    fn_params: mut list[ref void]
    fn_rets: mut list[ref void]
    fn_variadics: mut list[bool]
    ext_names: mut list[ref char]
    ext_syms: mut list[ref char]
    ext_rets: mut list[ref void]
    tv_names: mut list[ref char]
    tv_owners: mut list[ref char]
    tv_tags: mut list[i64]
    tv_fields: mut list[ref void]
    mc_names: mut list[ref char]
    mc_vals: mut list[ref char]
    gnames: mut list[ref char]
    gsyms: mut list[ref char]
    break_lbl: mut i64
    cont_lbl: mut i64
    defer_stack: mut list[ref void]
    local_names: mut list[ref char]
    local_ctypes: mut list[ref char]
    local_ty_nodes: mut list[ref parser.Node]
    local_is_slot: mut list[i64]
    used_prefixes: mut list[ref char]
    emitted_labels: mut list[ref char]
    expr_arena: mut list[ref void]
    release_mode: mut bool
    current_ret_ctype: mut ref char
    current_ret_is_void: mut bool
    current_ret_ty: mut ref parser.Node
    current_prefix: mut ref char
    fwd_sb: mut ref void
    inv_tnames: mut list[ref char]
    inv_tlists: mut list[ref void]
    inv_cur_pnames: mut list[ref char]
    inv_cur_ptypes: mut list[ref char]
    expected_ty: mut ref parser.Node
    init_sb: mut ref void
    gfn_names:   mut list[ref char]
    gfn_nodes:   mut list[ref void]
    gfn_prefixes: mut list[ref char]
    gsubst_names: mut list[ref char]
    gsubst_tnodes: mut list[ref void]
    mono_sb: mut ref void
}

fn cc_new() ref CCtx! = {
    val ctx: mut ref CCtx = @alloc(@sizeof(CCtx)) as ref CCtx
    ctx.sb = str.StringBuilder.new()
    ctx.fwd_sb = str.StringBuilder.new()
    ctx.tmp = 0
    ctx.lbl = 0
    ctx.fn_name = 0 as ref char
    ctx.strs = []
    ctx.str_cnt = 0
    ctx.snames = []
    ctx.sfields = []
    ctx.unames = []
    ctx.uvariants = []
    ctx.fn_names = []
    ctx.fn_params = []
    ctx.fn_rets = []
    ctx.fn_variadics = []
    ctx.ext_names = []
    ctx.ext_syms = []
    ctx.ext_rets = []
    ctx.tv_names = []
    ctx.tv_owners = []
    ctx.tv_tags = []
    ctx.tv_fields = []
    ctx.mc_names = []
    ctx.mc_vals = []
    ctx.gnames = []
    ctx.gsyms = []
    ctx.break_lbl = -1
    ctx.cont_lbl = -1
    ctx.defer_stack = []
    ctx.local_names = []
    ctx.local_ctypes = []
    ctx.local_ty_nodes = []
    ctx.local_is_slot = []
    ctx.used_prefixes = []
    ctx.emitted_labels = []
    ctx.expr_arena = []
    ctx.release_mode = false
    ctx.current_ret_ctype = "int64_t"
    ctx.current_ret_is_void = false
    ctx.current_ret_ty = 0 as ref parser.Node
    ctx.current_prefix = ""
    ctx.inv_tnames = []
    ctx.inv_tlists = []
    ctx.inv_cur_pnames = []
    ctx.inv_cur_ptypes = []
    ctx.expected_ty = 0 as ref parser.Node
    ctx.init_sb = str.StringBuilder.new()
    ctx.gfn_names = []
    ctx.gfn_nodes = []
    ctx.gfn_prefixes = []
    ctx.gsubst_names = []
    ctx.gsubst_tnodes = []
    ctx.mono_sb = str.StringBuilder.new()
    return ctx
}

fn cc_expr_track(ctx: ref CCtx, s: ref char) ref char! = {
    @append(ctx.expr_arena, s as ref void)
    return s
}

fn cc_expr_drain(ctx: mut ref CCtx) void! = {
    val alen: i64 = @len(ctx.expr_arena) as i64
    val ai: mut i64 = 0
    for { if ai >= alen { break }
        val a_opt = @get(ctx.expr_arena, ai as usize)
        match a_opt { some a => { @free(a) } none => {} }
        ai++ }
    ctx.expr_arena = []
}

fn fresh_tmp(ctx: mut ref CCtx) i64! = {
    val n: i64 = ctx.tmp 
    ctx.tmp = n + 1 
    return n 
}

fn emit(ctx: ref CCtx, s: ref char) void! = { 
    str.StringBuilder.append_cstr(ctx.sb, s) 
}

fn emitln(ctx: ref CCtx, s: ref char) void! = {
    str.StringBuilder.append_cstr(ctx.sb, s) 
    str.StringBuilder.append_char(ctx.sb, 10) 
}

fn rewrite_fmt(s: ref char) ref char! = {
    val slen: i64 = str.len_raw(s)
    val out: ref char = @alloc(slen * 4 + 1) as ref char
    val oi: mut i64 = 0
    val i: mut i64 = 0
    for { if i >= slen { break }
        val c: u8 = @load8(@ptradd(s as ref void, i))
        if c == 92 { if i + 1 < slen { val next: u8 = @load8(@ptradd(s as ref void, i + 1))
                if next == 123 || next == 125 { @store8(@ptradd(out as ref void, oi), next) oi++ i += 2 }
                else { @store8(@ptradd(out as ref void, oi), c) oi++ i++ } }
            else { @store8(@ptradd(out as ref void, oi), c) oi++ i++ } }
        elif c == 123 { val j: mut i64 = i + 1 val found: mut bool = false
            for { if j >= slen { break } val ic: u8 = @load8(@ptradd(s as ref void, j)) if ic == 125 { found = true break } j++ }
            if found { val tlen: i64 = j - (i + 1)
                if tlen == 1 { val sc: u8 = @load8(@ptradd(s as ref void, i + 1))
                    if sc == 100 || sc == 105 { @store8(@ptradd(out as ref void, oi), 37) @store8(@ptradd(out as ref void, oi+1), 108) @store8(@ptradd(out as ref void, oi+2), 108) @store8(@ptradd(out as ref void, oi+3), 100) oi += 4 }
                    elif sc == 115 { @store8(@ptradd(out as ref void, oi), 37) @store8(@ptradd(out as ref void, oi+1), 115) oi += 2 }
                    elif sc == 120 { @store8(@ptradd(out as ref void, oi), 37) @store8(@ptradd(out as ref void, oi+1), 108) @store8(@ptradd(out as ref void, oi+2), 108) @store8(@ptradd(out as ref void, oi+3), 120) oi += 4 }
                    elif sc == 99 { @store8(@ptradd(out as ref void, oi), 37) @store8(@ptradd(out as ref void, oi+1), 99) oi += 2 }
                    elif sc == 112 { @store8(@ptradd(out as ref void, oi), 37) @store8(@ptradd(out as ref void, oi+1), 112) oi += 2 }
                    elif sc == 102 { @store8(@ptradd(out as ref void, oi), 37) @store8(@ptradd(out as ref void, oi+1), 102) oi += 2 }
                    else { @store8(@ptradd(out as ref void, oi), 37) @store8(@ptradd(out as ref void, oi+1), sc) oi += 2 }
                } else { @store8(@ptradd(out as ref void, oi), 37) oi++ val k: mut i64 = i + 1
                    for { if k >= j { break } @store8(@ptradd(out as ref void, oi), @load8(@ptradd(s as ref void, k))) oi++ k++ } }
                i = j + 1
            } else { @store8(@ptradd(out as ref void, oi), c) oi++ i++ }
        } else { @store8(@ptradd(out as ref void, oi), c) oi++ i++ } }
    @store8(@ptradd(out as ref void, oi), 0) return out }

fn intern_string(ctx: mut ref CCtx, s: ref char) i64! = {
    val idx: i64 = ctx.str_cnt
    @append(ctx.strs, s)
    ctx.str_cnt = idx + 1
    return idx
}

fn intern_format_string(ctx: mut ref CCtx, s: ref char) i64! = {
    val rewritten: ref char = rewrite_fmt(s)
    val idx: i64 = ctx.str_cnt
    @append(ctx.strs, rewritten)
    ctx.str_cnt = idx + 1
    return idx
}

fn cc_emit_label_if_new(ctx: ref CCtx, label: ref char) bool! = {
    val elen: i64 = @len(ctx.emitted_labels as list[ref char]) as i64
    val ei: mut i64 = 0
    for { 
        if ei >= elen { break }
        val e_opt = @get(ctx.emitted_labels as list[ref char], ei as usize)
        match e_opt { 
            some e => { if str.rchar_cmp(e as ref char, label) == 0 { return false } } 
            none => {} 
        }
        ei++ 
    }
    @append(ctx.emitted_labels as list[ref char], label)
    return true
}

fn cc_clear_locals(ctx: mut ref CCtx) void! = {
    ctx.local_names = [] 
    ctx.local_ctypes = [] 
    ctx.local_ty_nodes = []
    ctx.local_is_slot = []
    ctx.defer_stack = [] 
    ctx.tmp = 0
    ctx.inv_cur_pnames = [] 
    ctx.inv_cur_ptypes = []
}

/// Infer the type node of an expression. Returns 0 if unknown.
fn cc_infer_expr_ty(ctx: ref CCtx, expr: ref parser.Node) ref parser.Node! = {
    if expr == 0 as ref parser.Node { return 0 as ref parser.Node }
    val k: i64 = expr.kind
    if k == parser.NK_CAST {
        return expr.d1 as ref parser.Node
    }
    if k == parser.NK_IDENT {
        val ty: ref parser.Node = cc_lookup_local_ty_node(ctx, expr.d0 as ref char)
        if ty != 0 as ref parser.Node { return ty }
        val fparams: ref void = cc_lookup_fn_params(ctx, ctx.fn_name)
        if fparams != 0 as ref void {
            val plen: i64 = @len(fparams as list[ref parser.Node]) as i64
            val pi: mut i64 = 0
            for { if pi >= plen { break }
                val p_opt = @get(fparams as list[ref parser.Node], pi as usize)
                match p_opt { some p => {
                    val pn: ref char = (p as ref parser.Node).d0 as ref char
                    if str.rchar_cmp(pn, expr.d0 as ref char) == 0 {
                        return (p as ref parser.Node).d1 as ref parser.Node
                    }
                } none => {} }
                pi++
            }
        }
        return 0 as ref parser.Node
    }
    if k == parser.NK_TRUST || k == parser.NK_SOME || k == parser.NK_TRY {
        return cc_infer_expr_ty(ctx, expr.d0 as ref parser.Node)
    }
    if k == parser.NK_CALL {
        val callee: ref parser.Node = parser.call_callee(expr)
        val cname: ref char = resolve_callee_name(callee)
        val ret: ref parser.Node = cc_lookup_fn_ret(ctx, cname)
        if ret != 0 as ref parser.Node { return ret }
    }
    if k == parser.NK_BUILTIN {
        val bname: ref char = expr.d0 as ref char
        if str.rchar_cmp(bname, "get") == 0 {
            val bargs: ref void = expr.d1 as ref void
            if bargs != 0 as ref void {
                val first_opt = @get(bargs as list[ref parser.Node], 0 as usize)
                match first_opt { some first => {
                    val list_expr_ty: ref parser.Node = cc_infer_expr_ty(ctx, first as ref parser.Node)
                    val elem: ref parser.Node = cc_unwrap_list_elem_ty(list_expr_ty)
                    if elem != 0 as ref parser.Node {
                        val opt_node: mut ref parser.Node = @alloc(@sizeof(parser.Node)) as ref parser.Node
                        opt_node.kind = parser.TY_OPTION
                        opt_node.line = 0
                        opt_node.d0 = elem as i64
                        opt_node.d1 = 0 opt_node.d2 = 0 opt_node.d3 = 0 opt_node.d4 = 0 opt_node.d5 = 0 opt_node.d6 = 0
                        return opt_node
                    }
                } none => {} }
            }
        }
    }
    if k == parser.NK_FIELD {
        val base_node: ref parser.Node = parser.field_base(expr)
        val fname: ref char = parser.field_name(expr)
        val base_ty: ref parser.Node = cc_infer_expr_ty(ctx, base_node)
        if base_ty != 0 as ref parser.Node {
            val struct_name: ref char = spectre_type_name_of(base_ty)
            val fields: ref void = cc_lookup_struct(ctx, struct_name)
            if fields != 0 as ref void {
                val flen: i64 = @len(fields as list[ref void]) as i64
                val fi: mut i64 = 0
                for { if fi >= flen { break }
                    val f_opt = @get(fields as list[ref void], fi as usize)
                    match f_opt { some f => {
                        val fn_node: ref parser.Node = f as ref parser.Node
                        if str.rchar_cmp(fn_node.d0 as ref char, fname) == 0 {
                            return fn_node.d2 as ref parser.Node
                        }
                    } none => {} }
                    fi++
                }
            }
        }
    }
    return 0 as ref parser.Node
}

/// Extract the list element type node from a type. Unwraps mut wrappers.
fn cc_unwrap_list_elem_ty(ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return 0 as ref parser.Node }
    val k: i64 = ty.kind
    if k == parser.TY_LIST { return ty.d0 as ref parser.Node }
    if k == parser.TY_MUT { return cc_unwrap_list_elem_ty(ty.d0 as ref parser.Node) }
    return 0 as ref parser.Node
}

/// Extract the option inner type node from a type. Unwraps mut/result wrappers.
fn cc_unwrap_option_inner_ty(ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return 0 as ref parser.Node }
    val k: i64 = ty.kind
    if k == parser.TY_OPTION { return ty.d0 as ref parser.Node }
    if k == parser.TY_MUT { return cc_unwrap_option_inner_ty(ty.d0 as ref parser.Node) }
    return 0 as ref parser.Node
}

/// Extract the result ok type node from a type. Unwraps mut wrappers.
fn cc_unwrap_result_ok_ty(ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return 0 as ref parser.Node }
    val k: i64 = ty.kind
    if k == parser.TY_RESULT { return ty.d0 as ref parser.Node }
    if k == parser.TY_MUT { return cc_unwrap_result_ok_ty(ty.d0 as ref parser.Node) }
    return 0 as ref parser.Node
}

fn cc_register_local(ctx: ref CCtx, name: ref char, ctype: ref char, ty_node: ref parser.Node, is_slot: i64) void! = {
    @append(ctx.local_names, name) 
    @append(ctx.local_ctypes, ctype) 
    @append(ctx.local_ty_nodes, ty_node)
    @append(ctx.local_is_slot, is_slot)
}

fn cc_is_local_declared(ctx: ref CCtx, name: ref char) bool! = {
    val nlen: i64 = @len(ctx.local_names as list[ref char]) as i64
    val ni: mut i64 = 0
    for { 
        if ni >= nlen { break }
        val n_opt = @get(ctx.local_names as list[ref char], ni as usize)
        match n_opt { 
            some n => { 
                if str.rchar_cmp(n as ref char, name) == 0 {
                    return true
                } 
            } none => {} 
        }
        ni++ 
    }
    return false
}

fn cc_lookup_local_type(ctx: ref CCtx, name: ref char) ref char! = {
    val nlen: i64 = @len(ctx.local_names as list[ref char]) as i64
    val ni: mut i64 = nlen - 1
    for { 
        if ni < 0 { break }
        val n_opt = @get(ctx.local_names as list[ref char], ni as usize)
        match n_opt { 
            some n => { 
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val t_opt = @get(ctx.local_ctypes as list[ref char], ni as usize)
                    match t_opt { 
                        some t => { return t as ref char } 
                        none => { return "int64_t" } 
                    } 
                } 
            } none => {} 
        }
        ni-- 
    }
    return ""
}

fn cc_lookup_local_ty_node(ctx: ref CCtx, name: ref char) ref parser.Node! = {
    val nlen: i64 = @len(ctx.local_names as list[ref char]) as i64
    val ni: mut i64 = nlen - 1
    for { 
        if ni < 0 { break }
        val n_opt = @get(ctx.local_names as list[ref char], ni as usize)
        match n_opt { 
            some n => { 
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val t_opt = @get(ctx.local_ty_nodes as list[ref parser.Node], ni as usize)
                    match t_opt { 
                        some t => { return t as ref parser.Node } 
                        none => { return 0 as ref parser.Node } 
                    } 
                } 
            } none => {} 
        }
        ni-- 
    }
    return 0 as ref parser.Node
}

fn cc_mark_prefix_used(ctx: ref CCtx, prefix: ref char) void! = {
    val nlen: i64 = @len(ctx.used_prefixes as list[ref char]) as i64
    val ni: mut i64 = 0
    for { 
        if ni >= nlen { break }
        val n_opt = @get(ctx.used_prefixes as list[ref char], ni as usize)
        match n_opt { 
            some n => { 
                if str.rchar_cmp(n as ref char, prefix) == 0 { return } 
            } 
            none => {} 
        }
        ni++ 
    }
    @append(ctx.used_prefixes as list[ref char], prefix)
}

fn c_type_of(ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return "int64_t" }
    val k: i64 = ty.kind
    if k == parser.TY_VOID { return "void" }
    if k == parser.TY_MUT { return c_type_of(ty.d0 as ref parser.Node) }
    if k == parser.TY_REF || k == parser.TY_OPTION || k == parser.TY_LIST || k == parser.TY_RESULT || k == parser.TY_SLICE || k == parser.TY_FNPTR || k == parser.TY_FIXED_ARR { return "int64_t" }
    if k == parser.TY_NAMED {
        val name: ref char = ty.d0 as ref char
        if str.rchar_cmp(name, "i8") == 0 { return "int8_t" }
        if str.rchar_cmp(name, "u8") == 0 { return "uint8_t" }
        if str.rchar_cmp(name, "i16") == 0 { return "int16_t" }
        if str.rchar_cmp(name, "u16") == 0 { return "uint16_t" }
        if str.rchar_cmp(name, "i32") == 0 { return "int32_t" }
        if str.rchar_cmp(name, "u32") == 0 { return "uint32_t" }
        if str.rchar_cmp(name, "i64") == 0 { return "int64_t" }
        if str.rchar_cmp(name, "usize") == 0 { return "uint64_t" }
        if str.rchar_cmp(name, "bool") == 0 { return "int32_t" }
        if str.rchar_cmp(name, "char") == 0 { return "int32_t" }
        if str.rchar_cmp(name, "f32") == 0 { return "float" }
        if str.rchar_cmp(name, "f64") == 0 { return "double" }
        return "int64_t"
    }
    return "int64_t"
}

fn cc_register_generic_fn(ctx: ref CCtx, name: ref char, node: ref parser.Node, prefix: ref char) void! = {
    @append(ctx.gfn_names, name)
    @append(ctx.gfn_nodes as list[ref void], node as ref void)
    @append(ctx.gfn_prefixes, prefix)
}

fn cc_lookup_generic_fn(ctx: ref CCtx, name: ref char) ref parser.Node! = {
    val nlen: i64 = @len(ctx.gfn_names) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.gfn_names, ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val nd_opt = @get(ctx.gfn_nodes as list[ref void], ni as usize)
                    match nd_opt {
                        some nd => { return nd as ref parser.Node }
                        none => { return 0 as ref parser.Node }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref parser.Node
}

fn cc_gsubst_push(ctx: ref CCtx, name: ref char, ty: ref parser.Node) void! = {
    @append(ctx.gsubst_names, name)
    @append(ctx.gsubst_tnodes as list[ref void], ty as ref void)
}

fn cc_gsubst_resolve(ctx: ref CCtx, ty: ref parser.Node) ref parser.Node! = {
    if ty == 0 as ref parser.Node { return ty }
    if ty.kind != parser.TY_NAMED { return ty }
    val name: ref char = ty.d0 as ref char
    val nlen: i64 = @len(ctx.gsubst_names) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.gsubst_names, ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val t_opt = @get(ctx.gsubst_tnodes as list[ref void], ni as usize)
                    match t_opt {
                        some t => { return t as ref parser.Node }
                        none => { return ty }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return ty
}

fn cc_type_node_to_str(ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return "void" }
    val k: i64 = ty.kind
    if k == parser.TY_NAMED { return ty.d0 as ref char }
    if k == parser.TY_REF {
        val inner: ref char = cc_type_node_to_str(ty.d0 as ref parser.Node)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "ref {s}", {inner})
        return buf
    }
    if k == parser.TY_MUT {
        val inner: ref char = cc_type_node_to_str(ty.d0 as ref parser.Node)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "mut {s}", {inner})
        return buf
    }
    if k == parser.TY_VOID { return "void" }
    return "unknown"
}

fn cc_type_node_to_mangle(ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return "void" }
    val k: i64 = ty.kind
    if k == parser.TY_NAMED { return ty.d0 as ref char }
    if k == parser.TY_REF {
        val inner: ref char = cc_type_node_to_mangle(ty.d0 as ref parser.Node)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "ref_{s}", {inner})
        return buf
    }
    if k == parser.TY_MUT {
        val inner: ref char = cc_type_node_to_mangle(ty.d0 as ref parser.Node)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "mut_{s}", {inner})
        return buf
    }
    if k == parser.TY_VOID { return "void" }
    return "unknown"
}

fn cc_gwhen_matches(ctx: ref CCtx, when_node: ref parser.Node) bool! = {
    val conds: ref void = when_node.d0 as ref void
    if conds == 0 as ref void { return true }
    val clen: i64 = @len(conds as list[ref parser.Node]) as i64
    val ci: mut i64 = 0
    for {
        if ci >= clen { break }
        val c_opt = @get(conds as list[ref parser.Node], ci as usize)
        match c_opt {
            some c => {
                val cond: ref parser.Node = c as ref parser.Node
                val ckind: i64 = cond.d1
                if ckind == 0 { ci++ continue }
                val tparam: ref char = cond.d0 as ref char
                val dummy: mut ref parser.Node = parser.make_node(parser.TY_NAMED, 0)
                dummy.d0 = tparam as i64
                val resolved: ref parser.Node = cc_gsubst_resolve(ctx, dummy)
                if resolved == dummy { ci++ continue }
                val concrete_str: ref char = cc_type_node_to_str(resolved)
                val ctypes: ref void = cond.d2 as ref void
                if ckind == 1 {
                    val matched: mut bool = false
                    if ctypes != 0 as ref void {
                        val tlen: i64 = @len(ctypes as list[ref parser.Node]) as i64
                        val ti: mut i64 = 0
                        for {
                            if ti >= tlen { break }
                            val t_opt = @get(ctypes as list[ref parser.Node], ti as usize)
                            match t_opt {
                                some t => {
                                    val ts: ref char = cc_type_node_to_str(t as ref parser.Node)
                                    if str.rchar_cmp(concrete_str, ts) == 0 { matched = true }
                                }
                                none => {}
                            }
                            ti++
                        }
                    }
                    if !matched { return false }
                } elif ckind == 2 {
                    val matched2: mut bool = false
                    if ctypes != 0 as ref void {
                        val t_opt = @get(ctypes as list[ref parser.Node], 0)
                        match t_opt {
                            some t => {
                                val ts: ref char = cc_type_node_to_str(t as ref parser.Node)
                                if str.rchar_cmp(concrete_str, ts) == 0 { matched2 = true }
                            }
                            none => {}
                        }
                    }
                    if !matched2 { return false }
                }
            }
            none => {}
        }
        ci++
    }
    return true
}

fn cc_find_matching_gwhen_body(ctx: ref CCtx, fn_body: ref parser.Node) ref parser.Node! = {
    if fn_body == 0 as ref parser.Node { return 0 as ref parser.Node }
    val blen: i64 = @len(fn_body) as i64
    val bi: mut i64 = 0
    for {
        if bi >= blen { break }
        val s_opt = @get(fn_body, bi as usize)
        match s_opt {
            some s => {
                val sn: ref parser.Node = s as ref parser.Node
                if sn.kind == parser.NK_GENERIC_WHEN {
                    if cc_gwhen_matches(ctx, sn) { return sn.d1 as ref parser.Node }
                }
            }
            none => {}
        }
        bi++
    }
    return 0 as ref parser.Node
}

fn cc_make_concrete_param(ctx: ref CCtx, param: ref parser.Node) ref parser.Node! = {
    val pname: ref char = param.d0 as ref char
    val pty: ref parser.Node = param.d1 as ref parser.Node
    val resolved: ref parser.Node = cc_gsubst_resolve(ctx, pty)
    val np: mut ref parser.Node = parser.make_node(parser.NK_VAL, param.line)
    np.d0 = pname as i64
    np.d1 = resolved as i64
    return np
}

fn cc_monomorphize_generic_fn(ctx: mut ref CCtx, gfn_node: ref parser.Node, _: ref char,
                               type_args: list[ref parser.Node]) ref char! = {
    val fn_name: ref char = gfn_node.d2 as ref char
    val tparams: ref void = gfn_node.d6 as ref void
    val suffix: ref char = @alloc(512) as ref char
    val spos: mut i64 = 0
    val nargs: i64 = @len(type_args) as i64
    val ai: mut i64 = 0
    for {
        if ai >= nargs { break }
        val ta_opt = @get(type_args, ai as usize)
        match ta_opt {
            some ta => {
                val mangle: ref char = cc_type_node_to_mangle(ta as ref parser.Node)
                val seplen: i64 = 2
                val mlen: i64 = str.len_raw(mangle)
                @memcpy(@ptradd(suffix as ref void, spos), "__" as ref void, seplen as usize)
                spos = spos + seplen
                @memcpy(@ptradd(suffix as ref void, spos), mangle as ref void, mlen as usize)
                spos = spos + mlen
            }
            none => {}
        }
        ai++
    }
    @store8(@ptradd(suffix as ref void, spos), 0)
    val mono_base: ref char = @alloc(1024) as ref char
    @snprintf(mono_base, 1024, "{s}__GENMONO{s}", {fn_name, suffix})
    @free(suffix)
    val old_gsubst_names: list[ref char] = ctx.gsubst_names
    val old_gsubst_tnodes: list[ref void] = ctx.gsubst_tnodes
    ctx.gsubst_names = []
    ctx.gsubst_tnodes = []
    if tparams != 0 as ref void {
        val nparms: i64 = @len(tparams as list[ref char]) as i64
        val pi: mut i64 = 0
        for {
            if pi >= nparms { break }
            val pn_opt = @get(tparams as list[ref char], pi as usize)
            val ta_opt = @get(type_args, pi as usize)
            match pn_opt {
                some pn => {
                    match ta_opt {
                        some ta => { cc_gsubst_push(ctx, pn as ref char, ta as ref parser.Node) }
                        none => {}
                    }
                }
                none => {}
            }
            pi++
        }
    }
    val orig_params: ref void = gfn_node.d3 as ref void
    val new_params: mut list[ref parser.Node] = []
    if orig_params != 0 as ref void {
        for param in orig_params as list[ref parser.Node] {
            @append(new_params, cc_make_concrete_param(ctx, param))
        }
    }
    val orig_ret: ref parser.Node = gfn_node.d4 as ref parser.Node
    val new_ret: ref parser.Node = cc_gsubst_resolve(ctx, orig_ret)
    val fn_body: ref parser.Node = gfn_node.d5 as ref parser.Node
    val branch_body: ref parser.Node = cc_find_matching_gwhen_body(ctx, fn_body)
    if branch_body != 0 as ref parser.Node {
        val syn: mut ref parser.Node = parser.make_node(parser.NK_FN, gfn_node.line)
        syn.d0 = 0
        syn.d1 = 0 as i64
        syn.d2 = mono_base as i64
        val pl: list[ref parser.Node] = new_params
        syn.d3 = pl as i64
        syn.d4 = new_ret as i64
        syn.d5 = branch_body as i64
        syn.d6 = 0
        val saved_sb: ref void = ctx.sb
        val saved_tmp: i64 = ctx.tmp
        val saved_lbl: i64 = ctx.lbl
        ctx.sb = ctx.mono_sb
        gen_fn_prefixed(ctx, syn, "")
        ctx.sb = saved_sb
        ctx.tmp = saved_tmp
        ctx.lbl = saved_lbl
    }
    ctx.gsubst_names = old_gsubst_names
    ctx.gsubst_tnodes = old_gsubst_tnodes
    return mono_base
}

fn cc_generic_callee_base_name(node: ref parser.Node) ref char! = {
    val k: i64 = node.kind
    if k == parser.NK_IDENT { return node.d0 as ref char }
    if k == parser.NK_FIELD { return parser.field_name(node) }
    return "unknown"
}

fn c_ret_type_of(ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return "int64_t" }
    if ty.kind == parser.TY_VOID { return "int32_t" }
    return c_type_of(ty)
}

fn is_void_ret(ty: ref parser.Node) bool! = {
    if ty == 0 as ref parser.Node { return false }
    return ty.kind == parser.TY_VOID
}

fn spectre_type_name_of(ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return "int64_t" }
    val k: i64 = ty.kind
    if k == parser.TY_MUT || k == parser.TY_REF || k == parser.TY_OPTION || k == parser.TY_LIST || k == parser.TY_RESULT || k == parser.TY_SLICE {
        return spectre_type_name_of(ty.d0 as ref parser.Node)
    }
    if k == parser.TY_NAMED {
        return ty.d0 as ref char
    }
    return "int64_t"
}

fn cc_register_fn(ctx: ref CCtx, mangled: ref char, params: ref void, ret_ty: ref void, is_variadic: bool) void! = {
    @append(ctx.fn_names, mangled)
    @append(ctx.fn_params, params)
    @append(ctx.fn_rets, ret_ty)
    @append(ctx.fn_variadics, is_variadic)
}

fn cc_lookup_fn_params(ctx: ref CCtx, mangled: ref char) ref void! = {
    if mangled == 0 as ref char { return 0 as ref void }
    val nlen: i64 = @len(ctx.fn_names as list[ref char]) as i64
    val ni: mut i64 = 0
    for { if ni >= nlen { break }
        val n_opt = @get(ctx.fn_names as list[ref char], ni as usize)
        match n_opt { some n => {
            if str.rchar_cmp(n as ref char, mangled) == 0 {
                val p_opt = @get(ctx.fn_params as list[ref void], ni as usize)
                match p_opt { some p => { return p as ref void } none => { return 0 as ref void } }
            }
        } none => {} }
        ni++
    }
    return 0 as ref void
}

fn cc_lookup_fn_ret(ctx: ref CCtx, name: ref char) ref parser.Node! = {
    val nlen: i64 = @len(ctx.fn_names as list[ref char]) as i64
    val suffix: ref char = @alloc(str.len_raw(name) + 3) as ref char
    @snprintf(suffix, str.len_raw(name) + 3, "__{s}", {name})
    val ni: mut i64 = 0
    for { if ni >= nlen { break }
        val n_opt = @get(ctx.fn_names as list[ref char], ni as usize)
        match n_opt { some n => {
            val candidate: ref char = n as ref char
            val matches: mut bool = str.rchar_cmp(candidate, name) == 0
            if !matches {
                val clen: i64 = str.len_raw(candidate)
                val slen: i64 = str.len_raw(name) + 2
                if clen > slen {
                    val tail: ref char = @ptradd(candidate, clen - slen) as ref char
                    if str.rchar_cmp(tail, suffix) == 0 { matches = true }
                }
            }
            if matches {
                val r_opt = @get(ctx.fn_rets as list[ref void], ni as usize)
                match r_opt { some r => { @free(suffix) return r as ref parser.Node } none => {} }
            }
        } none => {} }
        ni++ }
    @free(suffix)
    return 0 as ref parser.Node
}

fn cc_resolve_fn_name(ctx: ref CCtx, name: ref char) ref char! = {
    val ext: ref char = cc_lookup_extern_symbol(ctx, name)
    if ext != 0 as ref char { return ext }
    val nlen: i64 = @len(ctx.fn_names as list[ref char]) as i64
    val namelen: i64 = str.len_raw(name)
    val suffix: ref char = @alloc(namelen + 3) as ref char
    @snprintf(suffix, namelen + 3, "__{s}", {name})
    val sx_name: ref char = @alloc(namelen + 5) as ref char
    @snprintf(sx_name, namelen + 5, "sx__{s}", {name})
    val ni: mut i64 = 0
    val found: mut ref char = 0 as ref char
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.fn_names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                val candidate: ref char = n as ref char
                if str.rchar_cmp(candidate, name) == 0 {
                    @free(suffix)
                    @free(sx_name)
                    cc_mark_prefix_used(ctx, "")
                    return candidate
                }
                if str.rchar_cmp(candidate, sx_name) == 0 {
                    @free(suffix)
                    @free(sx_name)
                    cc_mark_prefix_used(ctx, "")
                    return candidate
                }
                val clen: i64 = str.len_raw(candidate)
                val slen: i64 = namelen + 2
                if clen > slen {
                    val tail: ref char = @ptradd(candidate, clen - slen) as ref char
                    if str.rchar_cmp(tail, suffix) == 0 { found = candidate }
                }
            } none => {}
        }
        ni++
    }
    @free(suffix)
    @free(sx_name)
    if found != 0 as ref char {
        val prefix: ref char = codegen.extract_prefix_from_mangled(found, name)
        cc_mark_prefix_used(ctx, prefix)
    }
    return found
}

fn cc_register_extern(ctx: ref CCtx, name: ref char, symbol: ref char, ret_ty: ref void) void! = {
    @append(ctx.ext_names, name) 
    @append(ctx.ext_syms, symbol) 
    @append(ctx.ext_rets, ret_ty)
}

fn cc_lookup_extern_symbol(ctx: ref CCtx, name: ref char) ref char! = {
    val nlen: i64 = @len(ctx.ext_names as list[ref char]) as i64
    val ni: mut i64 = 0
    for { 
        if ni >= nlen { break }
        val n_opt = @get(ctx.ext_names as list[ref char], ni as usize)
        match n_opt { 
            some n => { 
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val s_opt = @get(ctx.ext_syms as list[ref char], ni as usize)
                    match s_opt { 
                        some s => { return s as ref char } 
                        none => { return 0 as ref char } 
                    } 
                } 
            } 
            none => {} 
        }
        ni++ 
    }
    return 0 as ref char
}

fn cc_register_struct(ctx: ref CCtx, tname: ref char, fields: ref void) void! = {
    @append(ctx.snames, tname) @append(ctx.sfields, fields)
}

fn cc_lookup_struct(ctx: ref CCtx, tname: ref char) ref void! = {
    val nlen: i64 = @len(ctx.snames as list[ref char]) as i64
    val ni: mut i64 = 0
    for { if ni >= nlen { break }
        val n_opt = @get(ctx.snames as list[ref char], ni as usize)
        match n_opt { some n => { if str.rchar_cmp(n as ref char, tname) == 0 {
            val f_opt = @get(ctx.sfields as list[ref void], ni as usize)
            match f_opt { some f => { return f as ref void } none => { return 0 as ref void } } } } none => {} }
        ni++ }
    return 0 as ref void
}

fn c_size_of(ctx: ref CCtx, ty: ref parser.Node) i64! = {
    if ty == 0 as ref parser.Node { return 8 }
    val k: i64 = ty.kind
    if k == parser.TY_VOID { return 0 }
    if k == parser.TY_MUT { return c_size_of(ctx, ty.d0 as ref parser.Node) }
    if k == parser.TY_REF || k == parser.TY_OPTION || k == parser.TY_RESULT || k == parser.TY_FNPTR { return 8 }
    if k == parser.TY_LIST { return 24 }
    if k == parser.TY_SLICE { return 16 }
    if k == parser.TY_FIXED_ARR {
        val sz: i64 = ty.d0
        val inner: ref parser.Node = ty.d1 as ref parser.Node
        return sz * c_size_of(ctx, inner)
    }
    if k == parser.TY_NAMED {
        val name: ref char = ty.d0 as ref char
        if str.rchar_cmp(name, "i8") == 0 || str.rchar_cmp(name, "u8") == 0 { return 1 }
        if str.rchar_cmp(name, "i16") == 0 || str.rchar_cmp(name, "u16") == 0 { return 2 }
        if str.rchar_cmp(name, "i32") == 0 || str.rchar_cmp(name, "u32") == 0 || str.rchar_cmp(name, "bool") == 0 || str.rchar_cmp(name, "char") == 0 { return 4 }
        if str.rchar_cmp(name, "i64") == 0 || str.rchar_cmp(name, "usize") == 0 || str.rchar_cmp(name, "f64") == 0 { return 8 }
        if str.rchar_cmp(name, "f32") == 0 { return 4 }
        
        val fields: ref void = cc_lookup_struct(ctx, name)
        if fields != 0 as ref void {
            return struct_size_bytes(ctx, fields)
        }
    }
    return 8
}

fn struct_size_bytes(ctx: ref CCtx, fields: ref void) i64! = {
    val flen: i64 = @len(fields as list[ref void]) as i64
    val size: mut i64 = 0
    val fi: mut i64 = 0
    for { if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt { 
            some f => { 
                val fn_node: ref parser.Node = f as ref parser.Node
                val fty: ref parser.Node = fn_node.d2 as ref parser.Node
                size = size + c_size_of(ctx, fty)
            } 
            none => {} 
        }
        fi++ 
    }
    return size
}

fn cc_register_union(ctx: ref CCtx, uname: ref char, variants: ref void) void! = {
    @append(ctx.unames, uname) @append(ctx.uvariants, variants)
}

fn cc_register_tv(ctx: ref CCtx, vname: ref char, owner: ref char, tag: i64, field_ty: ref void) void! = {
    @append(ctx.tv_names, vname) @append(ctx.tv_owners, owner)
    @append(ctx.tv_tags, tag) @append(ctx.tv_fields, field_ty)
}

fn cc_lookup_tv(ctx: ref CCtx, vname: ref char, out_owner: ref void, out_field_ty: ref void) i64! = {
    val nlen: i64 = @len(ctx.tv_names as list[ref char]) as i64
    val ni: mut i64 = 0
    for { 
        if ni >= nlen { break }
        val n_opt = @get(ctx.tv_names as list[ref char], ni as usize)
        match n_opt { 
            some n => { 
                if str.rchar_cmp(n as ref char, vname) == 0 {
                    val tag_opt = @get(ctx.tv_tags as list[i64], ni as usize)
                    match tag_opt { 
                        some tag => {
                            val o_opt = @get(ctx.tv_owners as list[ref char], ni as usize)
                            match o_opt { 
                                some o => { @store(out_owner, o as usize) } none => {} 
                            }
                            val f_opt = @get(ctx.tv_fields as list[ref void], ni as usize)
                            match f_opt { some f => { @store(out_field_ty, f as usize) } none => {} }
                            return tag as i64
                        } none => {} 
                    }
                } 
            } none => {} 
        }
        ni++ 
    }
    return -1
}

fn cc_register_module_const(ctx: ref CCtx, name: ref char, val_str: ref char) void! = {
    @append(ctx.mc_names, name) 
    @append(ctx.mc_vals, val_str)
}

fn cc_const_val(ctx: ref CCtx, name: ref char) ref char! = {
    val nlen: i64 = @len(ctx.mc_names as list[ref char]) as i64
    val ni: mut i64 = 0
    for { if ni >= nlen { break }
        val n_opt = @get(ctx.mc_names as list[ref char], ni as usize)
        match n_opt { some n => { if str.rchar_cmp(n as ref char, name) == 0 {
            val v_opt = @get(ctx.mc_vals as list[ref char], ni as usize)
            match v_opt { some v => { return v as ref char } none => {} }
        } } none => {} }
        ni++ }
    return ""
}

fn cc_register_module_val(ctx: ref CCtx, name: ref char, symbol: ref char) void! = {
    @append(ctx.gnames, name)
    @append(ctx.gsyms, symbol)
}

fn cc_resolve_global_name(ctx: ref CCtx, name: ref char) ref char! = {
    val nlen: i64 = @len(ctx.gnames as list[ref char]) as i64
    val ni: mut i64 = 0
    for { if ni >= nlen { break }
        val n_opt = @get(ctx.gnames as list[ref char], ni as usize)
        match n_opt { some n => { if str.rchar_cmp(n as ref char, name) == 0 {
            val s_opt = @get(ctx.gsyms as list[ref char], ni as usize)
            match s_opt { some s => { return s as ref char } none => {} }
        } } none => {} }
        ni++ }
    return ""
}

fn cc_register_invariant(ctx: ref CCtx, tname: ref char, inv_list: ref void) void! = {
    @append(ctx.inv_tnames as list[ref char], tname) 
    @append(ctx.inv_tlists as list[ref void], inv_list)
}

fn cc_defer_push(ctx: ref CCtx, body: ref parser.Node) void! = { @append(ctx.defer_stack, body as ref void) }

fn cc_emit_defers(ctx: ref CCtx) void! = {
    val n: i64 = @len(ctx.defer_stack) as i64
    val i: mut i64 = n - 1
    for { 
        if i < 0 { break }
        val d_opt = @get(ctx.defer_stack, i as usize)
        match d_opt { 
            some d => { gen_stmts(ctx, d as ref parser.Node) } none => {} 
        }
        i-- 
    }
}

fn cc_handle_block_defers(ctx: ref CCtx, target_depth: i64) void! = {
    for {
        val n: i64 = @len(ctx.defer_stack) as i64
        if n <= target_depth { break }
        val d_opt = @get(ctx.defer_stack, n - 1)
        match d_opt {
            some d => { gen_stmts(ctx, d as ref parser.Node) }
            none => {}
        }
        @remove(ctx.defer_stack, (n - 1) as usize)
    }
}

fn field_offset_bytes(ctx: ref CCtx, fields: ref void, field_name: ref char) i64! = {
    val flen: i64 = @len(fields as list[ref void]) as i64
    val off: mut i64 = 0
    val fi: mut i64 = 0
    for { if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt { 
            some f => { 
                val fn_node: ref parser.Node = f as ref parser.Node
                val fn_: ref char = fn_node.d0 as ref char
                if str.rchar_cmp(fn_, field_name) == 0 { return off } 
                val fty: ref parser.Node = fn_node.d2 as ref parser.Node
                off = off + c_size_of(ctx, fty)
            } 
            none => {} 
        }
        fi++ 
    }
    return -1
}

fn resolve_callee_name_tracked(ctx: ref CCtx, callee: ref parser.Node) ref char! = {
    if callee == 0 as ref parser.Node { return "unknown" }
    if callee.kind == parser.NK_IDENT { return callee.d0 as ref char }
    if callee.kind == parser.NK_FIELD {
        val base: ref parser.Node = parser.field_base(callee)
        val fname: ref char = parser.field_name(callee)
        if base != 0 as ref parser.Node {
            if base.kind == parser.NK_IDENT {
                val buf: ref char = @alloc(512) as ref char
                @snprintf(buf, 512, "{s}__{s}", {base.d0 as ref char, fname})
                return cc_expr_track(ctx, buf)
            }
            if base.kind == parser.NK_FIELD {
                val b2: ref parser.Node = parser.field_base(base)
                val f2: ref char = parser.field_name(base)
                if b2 != 0 as ref parser.Node && b2.kind == parser.NK_IDENT {
                    val buf: ref char = @alloc(512) as ref char
                    @snprintf(buf, 512, "{s}__{s}__{s}", {b2.d0 as ref char, f2, fname})
                    return cc_expr_track(ctx, buf)
                }
                if b2 != 0 as ref parser.Node && b2.kind == parser.NK_FIELD {
                    val b3: ref parser.Node = parser.field_base(b2)
                    val f3: ref char = parser.field_name(b2)
                    if b3 != 0 as ref parser.Node && b3.kind == parser.NK_IDENT {
                        val buf: ref char = @alloc(512) as ref char
                        @snprintf(buf, 512, "{s}__{s}__{s}__{s}", {b3.d0 as ref char, f3, f2, fname})
                        return cc_expr_track(ctx, buf)
                    }
                }
            }
        }
        return fname
    }
    return "unknown"
}

fn resolve_callee_name(callee: ref parser.Node) ref char! = {
    if callee == 0 as ref parser.Node { return "unknown" }
    if callee.kind == parser.NK_IDENT { return callee.d0 as ref char }
    if callee.kind == parser.NK_FIELD {
        val base: ref parser.Node = parser.field_base(callee)
        val fname: ref char = parser.field_name(callee)
        if base != 0 as ref parser.Node {
            if base.kind == parser.NK_IDENT {
                val buf: ref char = @alloc(512) as ref char
                @snprintf(buf, 512, "{s}__{s}", {base.d0 as ref char, fname})
                return buf
            }
            if base.kind == parser.NK_FIELD {
                val b2: ref parser.Node = parser.field_base(base)
                val f2: ref char = parser.field_name(base)
                if b2 != 0 as ref parser.Node && b2.kind == parser.NK_IDENT {
                    val buf: ref char = @alloc(512) as ref char
                    @snprintf(buf, 512, "{s}__{s}__{s}", {b2.d0 as ref char, f2, fname})
                    return buf
                }
                if b2 != 0 as ref parser.Node && b2.kind == parser.NK_FIELD {
                    val b3: ref parser.Node = parser.field_base(b2)
                    val f3: ref char = parser.field_name(b2)
                    if b3 != 0 as ref parser.Node && b3.kind == parser.NK_IDENT {
                        val buf: ref char = @alloc(512) as ref char
                        @snprintf(buf, 512, "{s}__{s}__{s}__{s}", {b3.d0 as ref char, f3, f2, fname})
                        return buf
                    }
                }
            }
        }
        return fname
    }
    return "unknown"
}

fn get_arg(ctx: ref CCtx, args: ref void, idx: i64) ref char! = {
    if args == 0 as ref void { return "0" }
    val a_opt = @get(args as list[ref parser.Node], idx as usize)
    match a_opt { some a => { return gen_expr(ctx, a as ref parser.Node) } none => { return "0" } }
}

fn get_format_arg(ctx: mut ref CCtx, args: ref void, idx: i64) ref char! = {
    if args == 0 as ref void { return "0" }
    val a_opt = @get(args as list[ref parser.Node], idx as usize)
    match a_opt {
        some a => {
            val node: ref parser.Node = a as ref parser.Node
            if node.kind == parser.NK_STR_LIT {
                val s: ref char = parser.str_lit_text(node)
                val fidx: i64 = intern_format_string(ctx, s)
                val buf: ref char = @alloc(64) as ref char
                @snprintf(buf, 64, "sx__str{lld}", {fidx})
                return cc_expr_track(ctx, buf)
            }
            return gen_expr(ctx, node)
        }
        none => { return "0" }
    }
}


fn gen_expr(ctx: ref CCtx, expr: ref parser.Node) ref char! = {
    if expr == 0 as ref parser.Node { return "0" }
    val k: i64 = expr.kind
    if k == parser.NK_INT_LIT {
        val text: ref char = parser.int_lit_text(expr)
        val buf: ref char = @alloc(64) as ref char
        if @load8(text as ref void) == 48 && @load8(@ptradd(text as ref void, 1)) == 120 {
            @snprintf(buf, 64, "((int64_t){s})", {text})
        } else {
            @snprintf(buf, 64, "INT64_C({s})", {text})
        }
        return cc_expr_track(ctx, buf)
    }
    if k == parser.NK_FLOAT_LIT {
        val buf: ref char = @alloc(64) as ref char
        @snprintf(buf, 64, "{s}", {parser.float_lit_text(expr)})
        return cc_expr_track(ctx, buf)
    }
    if k == parser.NK_STR_LIT {
        val idx: i64 = intern_string(ctx, parser.str_lit_text(expr))
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "((int64_t)(intptr_t)sx__str{lld})", {idx})
        return cc_expr_track(ctx, buf)
    }
    if k == parser.NK_BOOL { 
        if expr.d0 as i64 != 0 { return "1" } return "0" 
    }
    if k == parser.NK_CHAR_LIT {
        val buf: ref char = @alloc(32) as ref char
        @snprintf(buf, 32, "{lld}", {expr.d0 as i64})
        return cc_expr_track(ctx, buf)
    }
    if k == parser.NK_NONE { return "0" }
    if k == parser.NK_IDENT {
        val name: ref char = expr.d0 as ref char
        val cval: ref char = cc_const_val(ctx, name)
        if str.rchar_cmp(cval, "") != 0 {
            val buf: ref char = @alloc(128) as ref char
            @snprintf(buf, 128, "({s})", {cval}) return cc_expr_track(ctx, buf)
        }
        val lt: ref char = cc_lookup_local_type(ctx, name)
        if str.rchar_cmp(lt, "") != 0 {
            val buf: ref char = @alloc(128) as ref char
            @snprintf(buf, 128, "t_{s}", {name}) return cc_expr_track(ctx, buf)
        }
        val gn: ref char = cc_resolve_global_name(ctx, name)
        if str.rchar_cmp(gn, "") != 0 {
            val buf: ref char = @alloc(128) as ref char
            @snprintf(buf, 128, "{s}", {gn}) return cc_expr_track(ctx, buf)
        }
        val resolved: ref char = cc_resolve_fn_name(ctx, name)
        if resolved != 0 as ref char {
            val buf: ref char = @alloc(256) as ref char
            @snprintf(buf, 256, "((int64_t)(intptr_t)&{s})", {resolved}) return cc_expr_track(ctx, buf)
        }
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "t_{s}", {name})
        return cc_expr_track(ctx, buf)
    }
    if k == parser.NK_TRUST { return gen_expr(ctx, expr.d0 as ref parser.Node) }
    if k == parser.NK_TRY {
        val inner_expr: ref char = gen_expr(ctx, expr.d0 as ref parser.Node)
        val t: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(8192) as ref char
        @snprintf(buf, 8192, "int64_t* sx__try{lld} = (int64_t*)(intptr_t)({s});\nif(sx__try{lld}[0] != 0) {\n", {t, inner_expr, t})
        emit(ctx, buf)
        cc_emit_defers(ctx)
        if ctx.current_ret_is_void {
            @snprintf(buf, 8192, "return;\n}\nint64_t sx__val{lld} = sx__try{lld}[1];\n", {t, t})
        } else {
            @snprintf(buf, 8192, "return ({s})(intptr_t)sx__try{lld};\n}\nint64_t sx__val{lld} = sx__try{lld}[1];\n", {ctx.current_ret_ctype, t, t, t})
        }
        emit(ctx, buf)        @free(buf)
        val res: ref char = @alloc(64) as ref char
        @snprintf(res, 64, "sx__val{lld}", {t})
        return cc_expr_track(ctx, res)
    }
    if k == parser.NK_SOME {
        val inner: ref char = gen_expr(ctx, expr.d0 as ref parser.Node)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "(({s})+1)", {inner}) return cc_expr_track(ctx, buf) }
    if k == parser.NK_OK_VAL {
        val t: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(512) as ref char
        @snprintf(buf, 512, "sx__ok{lld}", {t})
        val decl: ref char = @alloc(256) as ref char
        @snprintf(decl, 256, "int64_t*sx__ok{lld}=(int64_t*)calloc(1,16);sx__ok{lld}[0]=0;\n", {t, t})
        emit(ctx, decl) @free(decl)
        if expr.d0 != 0 {
            val inner: ref char = gen_expr(ctx, expr.d0 as ref parser.Node)
            val sb: ref char = @alloc(256) as ref char
            @snprintf(sb, 256, "sx__ok{lld}[1]=(int64_t)({s});\n", {t, inner})
            emit(ctx, sb) @free(sb)
        }
        val res: ref char = @alloc(64) as ref char
        @snprintf(res, 64, "(int64_t)(intptr_t)sx__ok{lld}", {t}) return cc_expr_track(ctx, res) }
    if k == parser.NK_ERR_VAL {
        val inner: ref char = gen_expr(ctx, expr.d0 as ref parser.Node)
        val t: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(512) as ref char
        @snprintf(buf, 512, "int64_t*sx__err{lld}=(int64_t*)calloc(1,16);sx__err{lld}[0]=1;sx__err{lld}[1]=(int64_t)({s});\n", {t, t, t, inner})
        emit(ctx, buf) @free(buf)
        val res: ref char = @alloc(64) as ref char
        @snprintf(res, 64, "(int64_t)(intptr_t)sx__err{lld}", {t})
        return cc_expr_track(ctx, res)
    }
    if k == parser.NK_BINOP { return gen_binop(ctx, expr) }
    if k == parser.NK_UNOP { return gen_unop(ctx, expr) }
    if k == parser.NK_FIELD { return gen_field(ctx, expr) }
    if k == parser.NK_CALL { return gen_call(ctx, expr) }
    if k == parser.NK_ARGS_PACK {
        val t: i64 = fresh_tmp(ctx)
        val pack: ref void = expr.d0 as ref void
        val plen: i64 = @len(pack as list[ref parser.Node]) as i64
        val buf: ref char = @alloc(8192) as ref char
        @snprintf(buf, 256, "int64_t sx__ap{lld}[]={", {t})
        val pi: mut i64 = 0
        for { if pi >= plen { break }
            val pe_opt = @get(pack as list[ref parser.Node], pi as usize)
            match pe_opt { some pe => { val av: ref char = gen_expr(ctx, pe as ref parser.Node)
                val ol: i64 = str.len_raw(buf) val ab: ref char = @alloc(512) as ref char
                if pi == 0 { @snprintf(ab, 512, "(int64_t)({s})", {av}) }
                else { @snprintf(ab, 512, ",(int64_t)({s})", {av}) }
                val al: i64 = str.len_raw(ab) @memcpy(@ptradd(buf as ref void, ol), ab as ref void, (al+1) as usize) @free(ab)
            } none => {} } pi++ }
        val cl: i64 = str.len_raw(buf) @store8(@ptradd(buf as ref void, cl), 125) @store8(@ptradd(buf as ref void, cl+1), 59) @store8(@ptradd(buf as ref void, cl+2), 10) @store8(@ptradd(buf as ref void, cl+3), 0)
        emit(ctx, buf) @free(buf)
        val res: ref char = @alloc(64) as ref char @snprintf(res, 64, "(int64_t)(intptr_t)sx__ap{lld}", {t}) return cc_expr_track(ctx, res) }
    if k == parser.NK_BUILTIN { return gen_builtin(ctx, expr) }
    if k == parser.NK_CAST {
        val inner: ref char = gen_expr(ctx, expr.d0 as ref parser.Node)
        val ct: ref char = c_type_of(expr.d1 as ref parser.Node)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "({s})({s})", {ct, inner}) return cc_expr_track(ctx, buf) }
    if k == parser.NK_ADDR {
        val inner_node: ref parser.Node = expr.d0 as ref parser.Node
        if inner_node.kind == parser.NK_IDENT {
            val iname: ref char = inner_node.d0 as ref char
            val resolved: ref char = cc_resolve_fn_name(ctx, iname)
            if resolved != 0 as ref char {
                val buf: ref char = @alloc(256) as ref char
                @snprintf(buf, 256, "(int64_t)(intptr_t)&{s}", {resolved}) return cc_expr_track(ctx, buf) }
            val lt: ref char = cc_lookup_local_type(ctx, iname)
            if str.rchar_cmp(lt, "") != 0 {
                if str.rchar_cmp(lt, "i64") != 0 && str.rchar_cmp(lt, "u64") != 0 &&
                   str.rchar_cmp(lt, "i32") != 0 && str.rchar_cmp(lt, "u32") != 0 &&
                   str.rchar_cmp(lt, "i16") != 0 && str.rchar_cmp(lt, "u16") != 0 &&
                   str.rchar_cmp(lt, "i8") != 0 && str.rchar_cmp(lt, "u8") != 0 &&
                   str.rchar_cmp(lt, "f64") != 0 && str.rchar_cmp(lt, "f32") != 0 &&
                   str.rchar_cmp(lt, "char") != 0 && str.rchar_cmp(lt, "bool") != 0 {
                    val buf: ref char = @alloc(128) as ref char
                    @snprintf(buf, 128, "t_{s}", {iname}) return cc_expr_track(ctx, buf) }
            }
            val buf: ref char = @alloc(128) as ref char
            @snprintf(buf, 128, "(int64_t)(intptr_t)&t_{s}", {iname}) return cc_expr_track(ctx, buf) }
        if inner_node.kind == parser.NK_FIELD {
            return gen_field_addr(ctx, inner_node)
        }
        if inner_node.kind == parser.NK_STRUCT_LIT || inner_node.kind == parser.NK_LIST_LIT {
            return gen_expr(ctx, inner_node)
        }
        if inner_node.kind == parser.NK_BUILTIN {
            val bname: ref char = inner_node.d0 as ref char
            if str.rchar_cmp(bname, "alloc") == 0 || str.rchar_cmp(bname, "realloc") == 0 ||
               str.rchar_cmp(bname, "ptradd") == 0 || str.rchar_cmp(bname, "fmt") == 0 ||
               str.rchar_cmp(bname, "args") == 0 {
                return gen_expr(ctx, inner_node)
            }
        }
        val inner: ref char = gen_expr(ctx, inner_node)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "(int64_t)(intptr_t)&({s})", {inner}) return cc_expr_track(ctx, buf)
    }
    if k == parser.NK_DEREF {
        val inner: ref char = gen_expr(ctx, expr.d0 as ref parser.Node)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "(*(int64_t*)(intptr_t)({s}))", {inner}) return cc_expr_track(ctx, buf) 
    }
    if k == parser.NK_STRUCT_LIT { return gen_struct_lit(ctx, expr) }
    if k == parser.NK_LIST_LIT { return gen_list_lit(ctx, expr) }
    if k == parser.NK_ZERO_INIT { return "0" }
    return "0"
}

fn gen_binop(ctx: ref CCtx, expr: ref parser.Node) ref char! = {
    val op: i64 = parser.binop_op(expr)
    val lhs_expr: ref parser.Node = parser.binop_left(expr)
    val rhs_expr: ref parser.Node = parser.binop_right(expr)
    val lhs_is_result: bool = lhs_expr.kind == parser.NK_OK_VAL || lhs_expr.kind == parser.NK_ERR_VAL
    val rhs_is_result: bool = rhs_expr.kind == parser.NK_OK_VAL || rhs_expr.kind == parser.NK_ERR_VAL
    val lhs: ref char = gen_expr(ctx, lhs_expr)
    val rhs: ref char = gen_expr(ctx, rhs_expr)
    val buf: ref char = @alloc(8192) as ref char
    if ((lhs_is_result || rhs_is_result) && (op == parser.OP_EQ || op == parser.OP_NE)) {
        val t: i64 = fresh_tmp(ctx)
        val decl: ref char = @alloc(1024) as ref char
        @snprintf(decl, 1024, "int64_t*sx__rl{lld}=(int64_t*)(intptr_t)({s});int64_t*sx__rr{lld}=(int64_t*)(intptr_t)({s});\n", {t, lhs, t, rhs})
        emit(ctx, decl) @free(decl)
        if op == parser.OP_EQ {
            @snprintf(buf, 8192, "(sx__rl{lld}[0]==sx__rr{lld}[0]&&sx__rl{lld}[1]==sx__rr{lld}[1])", {t, t, t, t})
        } else {
            @snprintf(buf, 8192, "!(sx__rl{lld}[0]==sx__rr{lld}[0]&&sx__rl{lld}[1]==sx__rr{lld}[1])", {t, t, t, t})
        }
        return cc_expr_track(ctx, buf)
    }
    if op == parser.OP_ADD { @snprintf(buf, 8192, "(({s})+({s}))", {lhs, rhs}) }
    elif op == parser.OP_SUB { @snprintf(buf, 8192, "(({s})-({s}))", {lhs, rhs}) }
    elif op == parser.OP_MUL { @snprintf(buf, 8192, "(({s})*({s}))", {lhs, rhs}) }
    elif op == parser.OP_DIV { @snprintf(buf, 8192, "(({s})/({s}))", {lhs, rhs}) }
    elif op == parser.OP_REM { @snprintf(buf, 8192, "(({s})%%({s}))", {lhs, rhs}) }
    elif op == parser.OP_EQ { @snprintf(buf, 8192, "(({s})==({s}))", {lhs, rhs}) }
    elif op == parser.OP_NE { @snprintf(buf, 8192, "(({s})!=({s}))", {lhs, rhs}) }
    elif op == parser.OP_LT { @snprintf(buf, 8192, "(({s})<({s}))", {lhs, rhs}) }
    elif op == parser.OP_GT { @snprintf(buf, 8192, "(({s})>({s}))", {lhs, rhs}) }
    elif op == parser.OP_LE { @snprintf(buf, 8192, "(({s})<=({s}))", {lhs, rhs}) }
    elif op == parser.OP_GE { @snprintf(buf, 8192, "(({s})>=({s}))", {lhs, rhs}) }
    elif op == parser.OP_AND { @snprintf(buf, 8192, "(({s})&&({s}))", {lhs, rhs}) }
    elif op == parser.OP_OR { @snprintf(buf, 8192, "(({s})||({s}))", {lhs, rhs}) }
    elif op == parser.OP_BAND { @snprintf(buf, 8192, "(({s})&({s}))", {lhs, rhs}) }
    elif op == parser.OP_BOR { @snprintf(buf, 8192, "(({s})|({s}))", {lhs, rhs}) }
    elif op == parser.OP_BXOR { @snprintf(buf, 8192, "(({s})^({s}))", {lhs, rhs}) }
    elif op == parser.OP_SHL { @snprintf(buf, 8192, "(({s})<<({s}))", {lhs, rhs}) }
    elif op == parser.OP_SHR { @snprintf(buf, 8192, "((int64_t)((uint64_t)({s})>>({s})))", {lhs, rhs}) }
    else { @snprintf(buf, 8192, "(({s})+({s}))", {lhs, rhs}) }
    return cc_expr_track(ctx, buf)
}

fn gen_unop(ctx: ref CCtx, expr: ref parser.Node) ref char! = {
    val op: i64 = parser.unop_op(expr)
    val inner: ref char = gen_expr(ctx, parser.unop_inner(expr))
    val buf: ref char = @alloc(256) as ref char
    if op == parser.UOP_NOT { @snprintf(buf, 256, "(!({s}))", {inner}) }
    elif op == parser.UOP_NEG { @snprintf(buf, 256, "(-({s}))", {inner}) }
    elif op == parser.UOP_BNOT { @snprintf(buf, 256, "(~({s}))", {inner}) }
    else { @snprintf(buf, 256, "({s})", {inner}) }
    return cc_expr_track(ctx, buf)
}

fn gen_field(ctx: ref CCtx, expr: ref parser.Node) ref char! = {
    val base_node: ref parser.Node = parser.field_base(expr)
    val fname: ref char = parser.field_name(expr)
    val buf: ref char = @alloc(512) as ref char
    if base_node.kind == parser.NK_IDENT {
        val base_name: ref char = base_node.d0 as ref char
        val key: ref char = @alloc(512) as ref char
        @snprintf(key, 512, "{s}__{s}", {base_name, fname})
        val cval: ref char = cc_const_val(ctx, key)
        @free(key)
        if str.rchar_cmp(cval, "") != 0 { @snprintf(buf, 512, "({s})", {cval}) return cc_expr_track(ctx, buf) }
        val base_lt: ref char = cc_lookup_local_type(ctx, base_name)
        if str.rchar_cmp(base_lt, "") == 0 {
            val qkey: ref char = @alloc(512) as ref char
            @snprintf(qkey, 512, "{s}__{s}", {base_name, fname})
            val gn: ref char = cc_resolve_global_name(ctx, qkey)
            if str.rchar_cmp(gn, "") != 0 {
                @free(qkey)
                @snprintf(buf, 512, "((int64_t){s})", {gn})
                return cc_expr_track(ctx, buf)
            }
            val resolved: ref char = cc_resolve_fn_name(ctx, qkey)
            @free(qkey)
            if resolved != 0 as ref char {
                @snprintf(buf, 512, "((int64_t)(intptr_t)&{s})", {resolved})
                return cc_expr_track(ctx, buf)
            }
            @free(buf)
            return "0"
        }
    }
    if base_node.kind == parser.NK_FIELD {
        val mid_node: ref parser.Node = parser.field_base(base_node)
        val mid_name: ref char = parser.field_name(base_node)
        if mid_node != 0 as ref parser.Node && mid_node.kind == parser.NK_IDENT {
            val key: ref char = @alloc(512) as ref char
            @snprintf(key, 512, "{s}__{s}__{s}", {mid_node.d0 as ref char, mid_name, fname})
            val cval: ref char = cc_const_val(ctx, key)
            @free(key)
            if str.rchar_cmp(cval, "") != 0 { @snprintf(buf, 512, "({s})", {cval}) return cc_expr_track(ctx, buf) }
            val mid_lt: ref char = cc_lookup_local_type(ctx, mid_node.d0 as ref char)
            if str.rchar_cmp(mid_lt, "") == 0 {
                val qkey: ref char = @alloc(512) as ref char
                @snprintf(qkey, 512, "{s}__{s}__{s}", {mid_node.d0 as ref char, mid_name, fname})
                val resolved: ref char = cc_resolve_fn_name(ctx, qkey)
                @free(qkey)
                if resolved != 0 as ref char {
                    @snprintf(buf, 512, "((int64_t)(intptr_t)&{s})", {resolved})
                    return cc_expr_track(ctx, buf)
                }
                @free(buf)
                return "0"
            }
        }
    }
    val base: ref char = gen_expr(ctx, base_node)
    val base_type: mut ref char = ""
    if base_node.kind == parser.NK_IDENT { base_type = cc_lookup_local_type(ctx, base_node.d0 as ref char) }
    elif base_node.kind == parser.NK_CAST {
        val cast_ty: ref parser.Node = base_node.d1 as ref parser.Node
        if cast_ty != 0 as ref parser.Node { base_type = spectre_type_name_of(cast_ty) }
    }
    elif base_node.kind == parser.NK_FIELD {
        val mid_node2: ref parser.Node = parser.field_base(base_node)
        val mid_name2: ref char = parser.field_name(base_node)
        val mid_type: mut ref char = ""
        if mid_node2 != 0 as ref parser.Node && mid_node2.kind == parser.NK_IDENT {
            mid_type = cc_lookup_local_type(ctx, mid_node2.d0 as ref char)
        }
        if str.rchar_cmp(mid_type, "") != 0 {
            val mid_fields: mut ref void = cc_lookup_struct(ctx, mid_type)
            if mid_fields == 0 as ref void {
                val mtlen: i64 = str.len_raw(mid_type)
                val mdot: mut i64 = -1
                val mi: mut i64 = 0
                for { if mi >= mtlen { break }
                    if @load8(@ptradd(mid_type as ref void, mi)) == 46 { mdot = mi }
                    mi++ }
                if mdot >= 0 {
                    val msuf: ref char = @ptradd(mid_type as ref void, mdot + 1) as ref char
                    mid_fields = cc_lookup_struct(ctx, msuf) } }
            if mid_fields != 0 as ref void {
                val mflen: i64 = @len(mid_fields as list[ref void]) as i64
                val mfi: mut i64 = 0
                for { if mfi >= mflen { break }
                    val mf_opt = @get(mid_fields as list[ref void], mfi as usize)
                    match mf_opt { some mf => {
                        val mf_node: ref parser.Node = mf as ref parser.Node
                        if str.rchar_cmp(mf_node.d0 as ref char, mid_name2) == 0 {
                            val fty: ref parser.Node = mf_node.d2 as ref parser.Node
                            if fty != 0 as ref parser.Node { base_type = spectre_type_name_of(fty) }
                        }
                    } none => {} }
                    mfi++ }
            }
        }
    }
    val fields: mut ref void = cc_lookup_struct(ctx, base_type)
    if fields == 0 as ref void && str.rchar_cmp(base_type, "") != 0 {
        val btlen: i64 = str.len_raw(base_type)
        val dotpos: mut i64 = -1
        val bi: mut i64 = 0
        for { if bi >= btlen { break }
            if @load8(@ptradd(base_type as ref void, bi)) == 46 { dotpos = bi }
            bi++ }
        if dotpos >= 0 {
            val suffix: ref char = @ptradd(base_type as ref void, dotpos + 1) as ref char
            fields = cc_lookup_struct(ctx, suffix) } }
    if fields != 0 as ref void {
        val off: i64 = field_offset_bytes(ctx, fields, fname)
        if off >= 0 {
            val fsz: i64 = cc_field_size_from_fields(ctx, fields, fname)
            if fsz > 8 { @snprintf(buf, 512, "((int64_t)(intptr_t)((char*)(intptr_t)({s})+{lld}))", {base, off}) }
            else { @snprintf(buf, 512, "(*(int64_t*)((char*)(intptr_t)({s})+{lld}))", {base, off}) }
            return cc_expr_track(ctx, buf) } }
    if str.rchar_cmp(fname, "len") == 0 || str.rchar_cmp(fname, "length") == 0 {
        @snprintf(buf, 512, "(*(int64_t*)((char*)(intptr_t)({s})+8))", {base}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(fname, "cap") == 0 || str.rchar_cmp(fname, "capacity") == 0 {
        @snprintf(buf, 512, "(*(int64_t*)((char*)(intptr_t)({s})+16))", {base}) return cc_expr_track(ctx, buf) }
    @snprintf(buf, 512, "(*(int64_t*)((char*)(intptr_t)({s})))", {base})
    return cc_expr_track(ctx, buf)
}

fn gen_call(ctx: mut ref CCtx, expr: ref parser.Node) ref char! = {
    val callee: ref parser.Node = parser.call_callee(expr)
    val args: ref void = parser.call_args(expr) as ref void

    if callee.kind == parser.NK_GENERIC_INST {
        val gi_base: ref parser.Node = parser.generic_inst_base(callee)
        val gi_targs: list[ref parser.Node] = parser.generic_inst_type_args(callee)
        val base_name: ref char = cc_generic_callee_base_name(gi_base)
        val gfn_node: ref parser.Node = cc_lookup_generic_fn(ctx, base_name)
        val mono_base: mut ref char = 0 as ref char
        if gfn_node != 0 as ref parser.Node {
            mono_base = cc_monomorphize_generic_fn(ctx, gfn_node, "", gi_targs)
        }
        if mono_base == 0 as ref char { mono_base = base_name }
        val c_mangled: ref char = @alloc(1024) as ref char
        @snprintf(c_mangled, 1024, "sx__{s}", {mono_base})
        val arg_parts: mut list[ref char] = []
        if args != 0 as ref void {
            val galen: i64 = @len(args as list[ref parser.Node]) as i64
            val gai: mut i64 = 0
            for {
                if gai >= galen { break }
                val ga_opt = @get(args as list[ref parser.Node], gai as usize)
                match ga_opt {
                    some ga => {
                        val gak: i64 = (ga as ref parser.Node).kind
                        if gak == parser.NK_ARGS_PACK {
                            val pack: ref void = (ga as ref parser.Node).d0 as ref void
                            val plen: i64 = @len(pack) as i64
                            val gpi: mut i64 = 0
                            for {
                                if gpi >= plen { break }
                                val gpe_opt = @get(pack, gpi as usize)
                                match gpe_opt {
                                    some gpe => { @append(arg_parts, gen_expr(ctx, gpe as ref parser.Node)) }
                                    none => {}
                                }
                                gpi++
                            }
                        } else {
                            @append(arg_parts, gen_expr(ctx, ga as ref parser.Node))
                        }
                    }
                    none => {}
                }
                gai++
            }
        }
        ctx.tmp = ctx.tmp + 1
        val gtmp: i64 = ctx.tmp
        val gret_node: ref parser.Node = cc_lookup_fn_ret(ctx, c_mangled)
        val gret_ct: mut ref char = "int64_t"
        if gret_node != 0 as ref parser.Node { gret_ct = c_type_of(gret_node) }
        val gcall_buf: ref char = @alloc(4096) as ref char
        @snprintf(gcall_buf, 4096, "{s} sx__gv{lld}={s}(", {gret_ct, gtmp, c_mangled})
        val aplen: i64 = @len(arg_parts) as i64
        val api: mut i64 = 0
        for {
            if api >= aplen { break }
            val ap_opt = @get(arg_parts, api as usize)
            match ap_opt {
                some ap => {
                    if api > 0 {
                        val gclen: i64 = str.len_raw(gcall_buf)
                        @memcpy(@ptradd(gcall_buf as ref void, gclen), "," as ref void, 1)
                    }
                    val gclen2: i64 = str.len_raw(gcall_buf)
                    val apstr: ref char = ap as ref char
                    @memcpy(@ptradd(gcall_buf as ref void, gclen2), apstr as ref void, str.len_raw(apstr) as usize)
                }
                none => {}
            }
            api++
        }
        val gclen3: i64 = str.len_raw(gcall_buf)
        @memcpy(@ptradd(gcall_buf as ref void, gclen3), ");\n" as ref void, 3)
        emit(ctx, gcall_buf)
        @free(gcall_buf)
        @free(c_mangled)
        val gres: ref char = @alloc(64) as ref char
        @snprintf(gres, 64, "sx__gv{lld}", {gtmp})
        return cc_expr_track(ctx, gres)
    }

    val callee_name: ref char = resolve_callee_name_tracked(ctx, callee)
    val tv_owner_slot: ref void = @alloc(8)
    val tv_field_slot: ref void = @alloc(8)
    @store(tv_owner_slot, 0)
    @store(tv_field_slot, 0)
    
    val tv_tag: i64 = cc_lookup_tv(ctx, callee_name, tv_owner_slot, tv_field_slot)
    
    if tv_tag >= 0 {
        ctx.tmp = ctx.tmp + 1
        val t: i64 = ctx.tmp
        val alloc_stmt: ref char = @alloc(512) as ref char
        @snprintf(alloc_stmt, 512, "int64_t sx__uv{lld}=(int64_t)(intptr_t)calloc(1,24);*(int64_t*)(intptr_t)sx__uv{lld}={lld};\n", {t, t, tv_tag})
        emit(ctx, alloc_stmt)
        @free(alloc_stmt)
        
        if args != 0 as ref void {
            val alen: i64 = @len(args as list[ref parser.Node]) as i64
            val ai: mut i64 = 0
            for { if ai >= alen { break }
                val a_opt = @get(args as list[ref parser.Node], ai as usize)
                match a_opt {
                    some a => {
                        val av: ref char = gen_expr(ctx, a as ref parser.Node)
                        val offset: i64 = 8 + (ai * 8)
                        val assign_stmt: ref char = @alloc(512) as ref char
                        @snprintf(assign_stmt, 512, "*(int64_t*)(intptr_t)((char*)(intptr_t)sx__uv{lld}+{lld})={s};\n", {t, offset, av})
                        emit(ctx, assign_stmt)
                        @free(assign_stmt)
                    } none => {}
                }
                ai++ }
        }
        
        @free(tv_owner_slot)
        @free(tv_field_slot)
        
        val res: ref char = @alloc(64) as ref char
        @snprintf(res, 64, "sx__uv{lld}", {t})
        return cc_expr_track(ctx, res)
    }
    
    @free(tv_owner_slot)
    @free(tv_field_slot)
    
    val resolved: ref char = cc_resolve_fn_name(ctx, callee_name)
    val ext_sym: ref char = cc_lookup_extern_symbol(ctx, callee_name)
    val is_fn_ptr: bool = resolved == 0 as ref char && ext_sym == 0 as ref char && cc_is_local_declared(ctx, callee_name)
    
    val effective: mut ref char = callee_name
    if resolved != 0 as ref char { effective = resolved }
    elif ext_sym != 0 as ref char { effective = ext_sym }

    val is_print: bool = str.rchar_cmp(callee_name, "print") == 0
        || str.rchar_cmp(effective, "std__stdio__print") == 0
        || str.ends_with(str.from(callee_name), str.from("__print"))
        || str.ends_with(str.from(callee_name), str.from("__eprint"))
        || str.rchar_cmp(callee_name, "printf") == 0
    val is_eprint: bool = str.ends_with(str.from(callee_name), str.from("__eprint"))

    if is_print && args != 0 as ref void {
        val alen: i64 = @len(args as list[ref parser.Node]) as i64
        if alen > 0 {
            val first_opt = @get(args as list[ref parser.Node], 0 as usize)
            match first_opt {
                some first => {
                    val first_node: ref parser.Node = first as ref parser.Node
                    if first_node.kind == parser.NK_STR_LIT {
                        val fmt_str: ref char = parser.str_lit_text(first_node)
                        val fmt_idx: i64 = intern_format_string(ctx, fmt_str)
                        val pbuf: ref char = @alloc(4096) as ref char
                        if is_eprint { @snprintf(pbuf, 4096, "dprintf(2,(const char*)(intptr_t)sx__str{lld}", {fmt_idx}) }
                        else { @snprintf(pbuf, 4096, "printf((const char*)(intptr_t)sx__str{lld}", {fmt_idx}) }
                        val ai2: mut i64 = 1
                        for { if ai2 >= alen { break }
                            val pa_opt = @get(args as list[ref parser.Node], ai2 as usize)
                            match pa_opt { some pa => {
                                val pa_node: ref parser.Node = pa as ref parser.Node
                                if pa_node.kind == parser.NK_ARGS_PACK {
                                    val pack: ref void = pa_node.d0 as ref void
                                    val plen: i64 = @len(pack as list[ref parser.Node]) as i64
                                    val pi: mut i64 = 0
                                    for { if pi >= plen { break }
                                        val pe_opt = @get(pack as list[ref parser.Node], pi as usize)
                                        match pe_opt { some pe => {
                                            val av: ref char = gen_expr(ctx, pe as ref parser.Node)
                                            val ol: i64 = str.len_raw(pbuf) val ab: ref char = @alloc(256) as ref char
                                            @snprintf(ab, 256, ",({s})", {av}) val al: i64 = str.len_raw(ab)
                                            @memcpy(@ptradd(pbuf as ref void, ol), ab as ref void, (al+1) as usize) @free(ab)
                                        } none => {} }
                                        pi++ }
                                } else {
                                    val av2: ref char = gen_expr(ctx, pa_node)
                                    val ol: i64 = str.len_raw(pbuf) val ab: ref char = @alloc(256) as ref char
                                    @snprintf(ab, 256, ",({s})", {av2}) val al: i64 = str.len_raw(ab)
                                    @memcpy(@ptradd(pbuf as ref void, ol), ab as ref void, (al+1) as usize) @free(ab)
                                }
                            } none => {} }
                            ai2++ }
                        val cl: i64 = str.len_raw(pbuf)
                        @store8(@ptradd(pbuf as ref void, cl), 41) @store8(@ptradd(pbuf as ref void, cl+1), 0)
                        return cc_expr_track(ctx, pbuf)
                    }
                }
                none => {}
            }
        }
    }

    val buf: ref char = @alloc(4096) as ref char
    if is_fn_ptr {
        @snprintf(buf, 4096, "((int64_t(*)(int64_t,...))(intptr_t)t_{s})(", {callee_name})
    } else {
        @snprintf(buf, 4096, "{s}(", {effective})
    }
    if args != 0 as ref void {
        val alen: i64 = @len(args as list[ref parser.Node]) as i64
        val ai: mut i64 = 0
        for { if ai >= alen { break }
            val a_opt = @get(args as list[ref parser.Node], ai as usize)
            match a_opt {
                some a => {
                    if ai > 0 { val ol: i64 = str.len_raw(buf)
                        @store8(@ptradd(buf as ref void, ol), 44)
                        @store8(@ptradd(buf as ref void, ol+1), 0)
                    }
                    val av: ref char = gen_expr(ctx, a as ref parser.Node)
                    val ol2: i64 = str.len_raw(buf) val al: i64 = str.len_raw(av)
                    @memcpy(@ptradd(buf as ref void, ol2), av as ref void, (al+1) as usize)
                } none => {}
            }
            ai++ } }
    val cl: i64 = str.len_raw(buf)
    @store8(@ptradd(buf as ref void, cl), 41)
    @store8(@ptradd(buf as ref void, cl+1), 0)
    return cc_expr_track(ctx, buf)
}

fn gen_builtin(ctx: ref CCtx, expr: ref parser.Node) ref char! = {
    val bname: ref char = expr.d0 as ref char
    val args: ref void = expr.d1 as ref void
    if str.rchar_cmp(bname, "alloc") == 0 { val sz: ref char = get_arg(ctx, args, 0)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "(int64_t)(intptr_t)calloc(1,(size_t)({s}))", {sz}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "free") == 0 { val ptr: ref char = get_arg(ctx, args, 0)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "(free((void*)(intptr_t)({s})),0)", {ptr}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "realloc") == 0 { val p: ref char = get_arg(ctx, args, 0) val s: ref char = get_arg(ctx, args, 1)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "(int64_t)(intptr_t)realloc((void*)(intptr_t)({s}),(size_t)({s}))", {p, s}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "sizeof") == 0 {
        if args != 0 as ref void {
            val alen: i64 = @len(args as list[ref parser.Node]) as i64
            if alen > 0 {
                val ty_opt = @get(args as list[ref parser.Node], 0 as usize)
                match ty_opt {
                    some ty => {
                        val sz: i64 = c_size_of(ctx, ty as ref parser.Node)
                        val buf: ref char = @alloc(64) as ref char
                        @snprintf(buf, 64, "INT64_C({lld})", {sz})
                        return cc_expr_track(ctx, buf)
                    }
                    none => {}
                }
            }
        }
        return "8"
    }
    if str.rchar_cmp(bname, "memcpy") == 0 { val d: ref char = get_arg(ctx, args, 0) val s: ref char = get_arg(ctx, args, 1) val n: ref char = get_arg(ctx, args, 2)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "(memcpy((void*)(intptr_t)({s}),(void*)(intptr_t)({s}),(size_t)({s})),0)", {d, s, n}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "memset") == 0 { val d: ref char = get_arg(ctx, args, 0) val v: ref char = get_arg(ctx, args, 1) val n: ref char = get_arg(ctx, args, 2)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "(memset((void*)(intptr_t)({s}),(int)({s}),(size_t)({s})),0)", {d, v, n}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "ptradd") == 0 { val p: ref char = get_arg(ctx, args, 0) val o: ref char = get_arg(ctx, args, 1)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "(int64_t)(intptr_t)((char*)(intptr_t)({s})+({s}))", {p, o}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "load") == 0 || str.rchar_cmp(bname, "load64") == 0 {
        val p: ref char = get_arg(ctx, args, 0)
        val buf: ref char = @alloc(512) as ref char
        @snprintf(buf, 512, "(*(int64_t*)(intptr_t)({s}))", {p}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "load8") == 0 { val p: ref char = get_arg(ctx, args, 0)
        val buf: ref char = @alloc(512) as ref char
        @snprintf(buf, 512, "((int64_t)(*(uint8_t*)(intptr_t)({s})))", {p}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "load16") == 0 { val p: ref char = get_arg(ctx, args, 0)
        val buf: ref char = @alloc(512) as ref char
        @snprintf(buf, 512, "((int64_t)(*(uint16_t*)(intptr_t)({s})))", {p}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "load32") == 0 { val p: ref char = get_arg(ctx, args, 0)
        val buf: ref char = @alloc(512) as ref char
        @snprintf(buf, 512, "((int64_t)(*(int32_t*)(intptr_t)({s})))", {p}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "store") == 0 || str.rchar_cmp(bname, "store64") == 0 {
        val p: ref char = get_arg(ctx, args, 0) val v: ref char = get_arg(ctx, args, 1)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "(*(int64_t*)(intptr_t)({s})=(int64_t)({s}))", {p, v}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "store8") == 0 { val p: ref char = get_arg(ctx, args, 0) val v: ref char = get_arg(ctx, args, 1)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "(*(uint8_t*)(intptr_t)({s})=(uint8_t)({s}))", {p, v}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "store16") == 0 { val p: ref char = get_arg(ctx, args, 0) val v: ref char = get_arg(ctx, args, 1)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "(*(uint16_t*)(intptr_t)({s})=(uint16_t)({s}))", {p, v}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "store32") == 0 { val p: ref char = get_arg(ctx, args, 0) val v: ref char = get_arg(ctx, args, 1)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "(*(int32_t*)(intptr_t)({s})=(int32_t)({s}))", {p, v}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "len") == 0 { val l: ref char = get_arg(ctx, args, 0)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "({s}==0?0:(*(int64_t*)((char*)(intptr_t)({s})+8)))", {l, l}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "append") == 0 {
        val e: ref char = get_arg(ctx, args, 1)
        val buf: ref char = @alloc(512) as ref char
        val list_arg_opt = @get(args as list[ref parser.Node], 0 as usize)
        match list_arg_opt {
            some list_arg => {
                val lan: ref parser.Node = list_arg as ref parser.Node
                if lan.kind == parser.NK_FIELD {
                    val fa: ref char = gen_field_addr(ctx, lan)
                    @snprintf(buf, 512, "sx__rt_append((void*)(intptr_t)({s}),(int64_t)({s}))", {fa, e}) return cc_expr_track(ctx, buf)
                }
                if lan.kind == parser.NK_IDENT {
                    val iname: ref char = lan.d0 as ref char
                    val lt2: ref char = cc_lookup_local_type(ctx, iname)
                    if str.rchar_cmp(lt2, "") != 0 {
                        @snprintf(buf, 512, "sx__rt_append_f((int64_t*)&t_{s},(int64_t)({s}))", {iname, e}) return cc_expr_track(ctx, buf)
                    }
                }
            }
            none => {}
        }
        val l: ref char = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "sx__rt_append((void*)(intptr_t)({s}),(int64_t)({s}))", {l, e}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "get") == 0 { val l: ref char = get_arg(ctx, args, 0) val i: ref char = get_arg(ctx, args, 1)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "sx__rt_get((void*)(intptr_t)({s}),(int64_t)({s}))", {l, i}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "set") == 0 { val l: ref char = get_arg(ctx, args, 0) val i: ref char = get_arg(ctx, args, 1) val v: ref char = get_arg(ctx, args, 2)
        val buf: ref char = @alloc(512) as ref char
        @snprintf(buf, 512, "((*(int64_t**)(intptr_t)({s}))[(int64_t)({s})]=(int64_t)({s}),0)", {l, i, v}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "remove") == 0 { val l: ref char = get_arg(ctx, args, 0) val i: ref char = get_arg(ctx, args, 1)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "sx__rt_remove((void*)(intptr_t)({s}),(int64_t)({s}))", {l, i}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "reserve") == 0 { val l: ref char = get_arg(ctx, args, 0) val c: ref char = get_arg(ctx, args, 1)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "sx__rt_reserve((void*)(intptr_t)({s}),(int64_t)({s}))", {l, c}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "capacity") == 0 { val l: ref char = get_arg(ctx, args, 0)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "(*(int64_t*)((char*)(intptr_t)({s})+16))", {l}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "fmt") == 0 {
        val f: ref char = get_format_arg(ctx, args, 0) val p: mut ref char = "0"
        if args != 0 as ref void { val alen: i64 = @len(args as list[ref parser.Node]) as i64
            if alen > 1 { p = get_arg(ctx, args, 1) } }
        val buf: ref char = @alloc(512) as ref char
        @snprintf(buf, 512, "(int64_t)(intptr_t)sx__rt_fmt((const char*)(intptr_t)({s}),(int64_t*)(intptr_t)({s}))", {f, p})
        return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "args") == 0 { return "(int64_t)(intptr_t)sx__rt_get_args()" }
    if str.rchar_cmp(bname, "puts") == 0 { val s: ref char = get_arg(ctx, args, 0)
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "puts((const char*)(intptr_t)({s}))", {s}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "stdin") == 0 {
        return "(int64_t)(intptr_t)stdin" }
    if str.rchar_cmp(bname, "fgets") == 0 { val b: ref char = get_arg(ctx, args, 0) val n: ref char = get_arg(ctx, args, 1) val s: ref char = get_arg(ctx, args, 2)
        val buf: ref char = @alloc(512) as ref char
        @snprintf(buf, 512, "(int64_t)(intptr_t)fgets((char*)(intptr_t)({s}),(int)({s}),(FILE*)(intptr_t)({s}))", {b, n, s}) return cc_expr_track(ctx, buf) }
    if str.rchar_cmp(bname, "getchar") == 0 {
        return "(int64_t)(int)getchar()" }
    if str.rchar_cmp(bname, "snprintf") == 0 {
        val buf: ref char = @alloc(8192) as ref char
        val dest_arg: ref char = get_arg(ctx, args, 0)
        val sz_arg: ref char = get_arg(ctx, args, 1)
        val fmt_arg: ref char = get_format_arg(ctx, args, 2)
        @snprintf(buf, 8192, "snprintf((char*)(intptr_t)({s}),(size_t)({s}),(const char*)(intptr_t)({s})", {dest_arg, sz_arg, fmt_arg})
        if args != 0 as ref void { val alen: i64 = @len(args as list[ref parser.Node]) as i64
            if alen > 3 { val pack_opt = @get(args as list[ref parser.Node], 3 as usize)
                match pack_opt { some pack_node => { val pn: ref parser.Node = pack_node as ref parser.Node
                    if pn.kind == parser.NK_ARGS_PACK { val pack: ref void = pn.d0 as ref void
                        val plen: i64 = @len(pack as list[ref parser.Node]) as i64 val pi: mut i64 = 0
                        for { if pi >= plen { break } val pe_opt = @get(pack as list[ref parser.Node], pi as usize)
                            match pe_opt { some pe => { val av: ref char = gen_expr(ctx, pe as ref parser.Node)
                                val ol: i64 = str.len_raw(buf) val ab: ref char = @alloc(256) as ref char @snprintf(ab, 256, ",({s})", {av})
                                val al: i64 = str.len_raw(ab) @memcpy(@ptradd(buf as ref void, ol), ab as ref void, (al+1) as usize) @free(ab)
                            } none => {} } pi++ }
                    } else { val av2: ref char = gen_expr(ctx, pn)
                        val ol: i64 = str.len_raw(buf) val ab: ref char = @alloc(256) as ref char @snprintf(ab, 256, ",({s})", {av2})
                        val al: i64 = str.len_raw(ab) @memcpy(@ptradd(buf as ref void, ol), ab as ref void, (al+1) as usize) @free(ab) }
                } none => {} } } }
        val cl: i64 = str.len_raw(buf) @store8(@ptradd(buf as ref void, cl), 41) @store8(@ptradd(buf as ref void, cl+1), 0) return cc_expr_track(ctx, buf)
    }
    if str.rchar_cmp(bname, "dprintf") == 0 {
        val buf: ref char = @alloc(4096) as ref char
        val fd: ref char = get_arg(ctx, args, 0)
        val fmt_arg: ref char = get_format_arg(ctx, args, 1)
        if args != 0 as ref void { val alen: i64 = @len(args as list[ref parser.Node]) as i64
            if alen > 2 { val pack_opt = @get(args as list[ref parser.Node], 2 as usize)
                match pack_opt { some pack_node => { val pn: ref parser.Node = pack_node as ref parser.Node
                    if pn.kind == parser.NK_ARGS_PACK { val pack: ref void = pn.d0 as ref void
                        val plen: i64 = @len(pack as list[ref parser.Node]) as i64 val pi: mut i64 = 0
                        @snprintf(buf, 4096, "dprintf((int)({s}),(const char*)(intptr_t)({s})", {fd, fmt_arg})
                        for { if pi >= plen { break } val pe_opt = @get(pack as list[ref parser.Node], pi as usize)
                            match pe_opt { some pe => { val av: ref char = gen_expr(ctx, pe as ref parser.Node)
                                val ol: i64 = str.len_raw(buf) val ab: ref char = @alloc(256) as ref char @snprintf(ab, 256, ",({s})", {av})
                                val al: i64 = str.len_raw(ab) @memcpy(@ptradd(buf as ref void, ol), ab as ref void, (al+1) as usize) @free(ab)
                            } none => {} } pi++ }
                        val cl: i64 = str.len_raw(buf) @store8(@ptradd(buf as ref void, cl), 41) @store8(@ptradd(buf as ref void, cl+1), 0) return cc_expr_track(ctx, buf)
                    } else { val av2: ref char = gen_expr(ctx, pn)
                        @snprintf(buf, 4096, "sx__rt_dprintf((int)({s}),(const char*)(intptr_t)({s}),(int64_t*)(intptr_t)({s}))", {fd, fmt_arg, av2}) return cc_expr_track(ctx, buf) }
                } none => {} } } }
        @snprintf(buf, 4096, "dprintf((int)({s}),(const char*)(intptr_t)({s}))", {fd, fmt_arg}) return cc_expr_track(ctx, buf)
    }
    if (str.rchar_cmp(bname, "printf") == 0 || str.rchar_cmp(bname, "print") == 0) {
        val buf: ref char = @alloc(4096) as ref char
        val fmt_arg: ref char = get_format_arg(ctx, args, 0)
        if args != 0 as ref void { val alen: i64 = @len(args as list[ref parser.Node]) as i64
            if alen > 1 { val pack_opt = @get(args as list[ref parser.Node], 1 as usize)
                match pack_opt { some pack_node => { val pn: ref parser.Node = pack_node as ref parser.Node
                    if pn.kind == parser.NK_ARGS_PACK { val pack: ref void = pn.d0 as ref void
                        val plen: i64 = @len(pack as list[ref parser.Node]) as i64 val pi: mut i64 = 0
                        @snprintf(buf, 4096, "printf((const char*)(intptr_t)({s})", {fmt_arg})
                        for { if pi >= plen { break } val pe_opt = @get(pack as list[ref parser.Node], pi as usize)
                            match pe_opt { some pe => { val av: ref char = gen_expr(ctx, pe as ref parser.Node)
                                val ol: i64 = str.len_raw(buf) val ab: ref char = @alloc(256) as ref char @snprintf(ab, 256, ",({s})", {av})
                                val al: i64 = str.len_raw(ab) @memcpy(@ptradd(buf as ref void, ol), ab as ref void, (al+1) as usize) @free(ab)
                            } none => {} } pi++ }
                        val cl: i64 = str.len_raw(buf) @store8(@ptradd(buf as ref void, cl), 41) @store8(@ptradd(buf as ref void, cl+1), 0) return cc_expr_track(ctx, buf)
                    } else { val av2: ref char = gen_expr(ctx, pn)
                        @snprintf(buf, 4096, "sx__rt_printf((const char*)(intptr_t)({s}),(int64_t*)(intptr_t)({s}))", {fmt_arg, av2}) return cc_expr_track(ctx, buf) }
                } none => {} } } }
        @snprintf(buf, 4096, "printf((const char*)(intptr_t)({s}))", {fmt_arg}) return cc_expr_track(ctx, buf)
    }
    if is_libc_fn(bname) {
        val buf: ref char = @alloc(8192) as ref char @snprintf(buf, 8192, "{s}(", {bname})
        if args != 0 as ref void { val alen: i64 = @len(args as list[ref parser.Node]) as i64 val ai: mut i64 = 0
            for { if ai >= alen { break } val a_opt = @get(args as list[ref parser.Node], ai as usize)
                match a_opt { some a => { if ai > 0 { val ol: i64 = str.len_raw(buf) @store8(@ptradd(buf as ref void, ol), 44) @store8(@ptradd(buf as ref void, ol+1), 0) }
                    val av: ref char = gen_expr(ctx, a as ref parser.Node) val ol2: i64 = str.len_raw(buf) val al: i64 = str.len_raw(av)
                    @memcpy(@ptradd(buf as ref void, ol2), av as ref void, (al+1) as usize) } none => {} } ai++ } }
        val cl: i64 = str.len_raw(buf) @store8(@ptradd(buf as ref void, cl), 41) @store8(@ptradd(buf as ref void, cl+1), 0) return cc_expr_track(ctx, buf) }
    return "0"
}

fn gen_struct_lit(ctx: ref CCtx, expr: ref parser.Node) ref char! = {
    val lit_fields: ref void = expr.d0 as ref void
    val fcount: mut i64 = 0
    if lit_fields != 0 as ref void { fcount = @len(lit_fields as list[ref void]) as i64 }
    
    val alloc_size: mut i64 = (fcount * 8) as i64
    val struct_fields: mut ref void = 0 as ref void
    if ctx.expected_ty != 0 as ref parser.Node {
        alloc_size = c_size_of(ctx, ctx.expected_ty)
        if ctx.expected_ty.kind == parser.TY_NAMED {
            struct_fields = cc_lookup_struct(ctx, ctx.expected_ty.d0 as ref char)
        }
    }
    if fcount < 1 && alloc_size < 8 { alloc_size = 8 as i64 }
    
    val t: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(256) as ref char
    @snprintf(buf, 256, "int64_t*sx__sl{lld}=(int64_t*)calloc(1,{lld});\n", {t, alloc_size}) emit(ctx, buf) @free(buf)
    
    if lit_fields != 0 as ref void { val lflen: i64 = @len(lit_fields as list[ref void]) as i64
        val li: mut i64 = 0
        for { if li >= lflen { break }
            val lf_opt = @get(lit_fields as list[ref void], li as usize)
            match lf_opt { some lf => { val lf_node: ref parser.Node = lf as ref parser.Node
                val fval: ref char = gen_expr(ctx, lf_node.d1 as ref parser.Node)
                
                val off: mut i64 = li * 8
                val fld_sz: mut i64 = 8
                if struct_fields != 0 as ref void {
                     val fname: ref char = lf_node.d0 as ref char
                     val roff: i64 = field_offset_bytes(ctx, struct_fields, fname)
                     if roff >= 0 { off = roff }
                     fld_sz = cc_field_size_from_fields(ctx, struct_fields, fname)
                }
                
                val fb: ref char = @alloc(512) as ref char
                if fld_sz > 8 {
                    if str.rchar_cmp(fval, "INT64_C(0)") == 0 || str.rchar_cmp(fval, "0") == 0 {
                        @snprintf(fb, 512, "memset((char*)sx__sl{lld}+{lld},0,(size_t){lld});\n", {t, off, fld_sz})
                    } else {
                        @snprintf(fb, 512, "memcpy((char*)sx__sl{lld}+{lld},(void*)(intptr_t)({s}),(size_t){lld});\n", {t, off, fval, fld_sz})
                    }
                }
                else { @snprintf(fb, 512, "*(int64_t*)((char*)sx__sl{lld}+{lld})=(int64_t)({s});\n", {t, off, fval}) }
                emit(ctx, fb) @free(fb)
            } none => {} }
            li++ } }
    val res: ref char = @alloc(64) as ref char
    @snprintf(res, 64, "(int64_t)(intptr_t)sx__sl{lld}", {t}) return cc_expr_track(ctx, res)
}

fn gen_list_lit(ctx: ref CCtx, expr: ref parser.Node) ref char! = {
    val elems: ref void = expr.d0 as ref void
    val elen: mut i64 = 0
    if elems != 0 as ref void { elen = @len(elems as list[ref void]) as i64 }
    val t: i64 = fresh_tmp(ctx)
    val cap: mut i64 = elen * 8 if cap < 64 { cap = 64 }
    val buf: ref char = @alloc(512) as ref char
    @snprintf(buf, 512, "int64_t*sx__ll{lld}=(int64_t*)calloc(1,24);int64_t*sx__lld{lld}=(int64_t*)calloc(1,{lld});sx__ll{lld}[0]=(int64_t)(intptr_t)sx__lld{lld};sx__ll{lld}[1]={lld};sx__ll{lld}[2]={lld};\n",
        {t, t, cap, t, t, t, elen, t, cap/8}) emit(ctx, buf) @free(buf)
    if elems != 0 as ref void { val ei: mut i64 = 0
        for { if ei >= elen { break }
            val e_opt = @get(elems as list[ref void], ei as usize)
            match e_opt { some e => { val ev: ref char = gen_expr(ctx, e as ref parser.Node)
                val eb: ref char = @alloc(256) as ref char
                @snprintf(eb, 256, "sx__lld{lld}[{lld}]=(int64_t)({s});\n", {t, ei, ev}) emit(ctx, eb) @free(eb)
            } none => {} }
            ei++ } }
    val res: ref char = @alloc(64) as ref char
    @snprintf(res, 64, "(int64_t)(intptr_t)sx__ll{lld}", {t}) return cc_expr_track(ctx, res)
}

fn gen_field_addr(ctx: ref CCtx, expr: ref parser.Node) ref char! = {
    val base_node: ref parser.Node = parser.field_base(expr)
    val fname: ref char = parser.field_name(expr)
    val base: ref char = gen_expr(ctx, base_node)
    val bt: mut ref char = ""
    if bt == 0 as ref char { bt = "" }
    if base_node.kind == parser.NK_IDENT { bt = cc_lookup_local_type(ctx, base_node.d0 as ref char) }
    elif base_node.kind == parser.NK_CAST {
        val cast_ty: ref parser.Node = base_node.d1 as ref parser.Node
        if cast_ty != 0 as ref parser.Node { bt = spectre_type_name_of(cast_ty) }
    }
    elif base_node.kind == parser.NK_FIELD {
        val mid_node3: ref parser.Node = parser.field_base(base_node)
        val mid_name3: ref char = parser.field_name(base_node)
        val mid_type3: mut ref char = ""
        if mid_node3 != 0 as ref parser.Node && mid_node3.kind == parser.NK_IDENT {
            mid_type3 = cc_lookup_local_type(ctx, mid_node3.d0 as ref char)
        }
        if str.rchar_cmp(mid_type3, "") != 0 {
            val mid_fields3: mut ref void = cc_lookup_struct(ctx, mid_type3)
            if mid_fields3 == 0 as ref void {
                val mtlen3: i64 = str.len_raw(mid_type3)
                val mdot3: mut i64 = -1
                val mi3: mut i64 = 0
                for { if mi3 >= mtlen3 { break }
                    if @load8(@ptradd(mid_type3 as ref void, mi3)) == 46 { mdot3 = mi3 }
                    mi3++ }
                if mdot3 >= 0 {
                    val msuf3: ref char = @ptradd(mid_type3 as ref void, mdot3 + 1) as ref char
                    mid_fields3 = cc_lookup_struct(ctx, msuf3) } }
            if mid_fields3 != 0 as ref void {
                val mflen3: i64 = @len(mid_fields3 as list[ref void]) as i64
                val mfi3: mut i64 = 0
                for { if mfi3 >= mflen3 { break }
                    val mf_opt3 = @get(mid_fields3 as list[ref void], mfi3 as usize)
                    match mf_opt3 { some mf3 => {
                        val mfn3: ref parser.Node = mf3 as ref parser.Node
                        if str.rchar_cmp(mfn3.d0 as ref char, mid_name3) == 0 {
                            val fty3: ref parser.Node = mfn3.d2 as ref parser.Node
                            if fty3 != 0 as ref parser.Node { bt = spectre_type_name_of(fty3) }
                        }
                    } none => {} }
                    mfi3++ }
            }
        }
    }
    val fields: mut ref void = cc_lookup_struct(ctx, bt)
    if fields == 0 as ref void && str.rchar_cmp(bt, "") != 0 {
        val btlen2: i64 = str.len_raw(bt)
        val dotpos2: mut i64 = -1
        val bi2: mut i64 = 0
        for { if bi2 >= btlen2 { break }
            if @load8(@ptradd(bt as ref void, bi2)) == 46 { dotpos2 = bi2 }
            bi2++ }
        if dotpos2 >= 0 {
            val suffix2: ref char = @ptradd(bt as ref void, dotpos2 + 1) as ref char
            fields = cc_lookup_struct(ctx, suffix2) } }
    val off: mut i64 = 0
    if fields != 0 as ref void { val ro: i64 = field_offset_bytes(ctx, fields, fname) if ro >= 0 { off = ro } }
    elif str.rchar_cmp(fname, "len") == 0 { off = 8 }
    elif str.rchar_cmp(fname, "cap") == 0 { off = 16 }
    val buf: ref char = @alloc(4096) as ref char
    @snprintf(buf, 4096, "(int64_t)(intptr_t)((char*)(intptr_t)({s})+{lld})", {base, off})
    return cc_expr_track(ctx, buf)
}

fn cc_field_size_from_fields(ctx: ref CCtx, fields: ref void, fname: ref char) i64! = {
    if fields == 0 as ref void { return 8 }
    val flen: i64 = @len(fields as list[ref void]) as i64
    val fi: mut i64 = 0
    for { if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt { some f => {
            val fn_node: ref parser.Node = f as ref parser.Node
            if str.rchar_cmp(fn_node.d0 as ref char, fname) == 0 {
                return c_size_of(ctx, fn_node.d2 as ref parser.Node)
            }
        } none => {} }
        fi++ }
    return 8
}

fn cc_field_size_of_expr(ctx: ref CCtx, expr: ref parser.Node) i64! = {
    val base_node: ref parser.Node = parser.field_base(expr)
    val fname: ref char = parser.field_name(expr)
    val bt: mut ref char = ""
    if base_node.kind == parser.NK_IDENT { bt = cc_lookup_local_type(ctx, base_node.d0 as ref char) }
    elif base_node.kind == parser.NK_CAST {
        val cast_ty: ref parser.Node = base_node.d1 as ref parser.Node
        if cast_ty != 0 as ref parser.Node { bt = spectre_type_name_of(cast_ty) }
    }
    elif base_node.kind == parser.NK_FIELD {
        val mid_node4: ref parser.Node = parser.field_base(base_node)
        val mid_name4: ref char = parser.field_name(base_node)
        val mid_type4: mut ref char = ""
        if mid_node4 != 0 as ref parser.Node && mid_node4.kind == parser.NK_IDENT {
            mid_type4 = cc_lookup_local_type(ctx, mid_node4.d0 as ref char)
        }
        if str.rchar_cmp(mid_type4, "") != 0 {
            val mid_fields4: mut ref void = cc_lookup_struct(ctx, mid_type4)
            if mid_fields4 == 0 as ref void {
                val mtlen4: i64 = str.len_raw(mid_type4)
                val mdot4: mut i64 = -1
                val mi4: mut i64 = 0
                for { if mi4 >= mtlen4 { break }
                    if @load8(@ptradd(mid_type4 as ref void, mi4)) == 46 { mdot4 = mi4 }
                    mi4++ }
                if mdot4 >= 0 {
                    val msuf4: ref char = @ptradd(mid_type4 as ref void, mdot4 + 1) as ref char
                    mid_fields4 = cc_lookup_struct(ctx, msuf4) } }
            if mid_fields4 != 0 as ref void {
                val mflen4: i64 = @len(mid_fields4 as list[ref void]) as i64
                val mfi4: mut i64 = 0
                for { if mfi4 >= mflen4 { break }
                    val mf_opt4 = @get(mid_fields4 as list[ref void], mfi4 as usize)
                    match mf_opt4 { some mf4 => {
                        val mfn4: ref parser.Node = mf4 as ref parser.Node
                        if str.rchar_cmp(mfn4.d0 as ref char, mid_name4) == 0 {
                            val fty4: ref parser.Node = mfn4.d2 as ref parser.Node
                            if fty4 != 0 as ref parser.Node { bt = spectre_type_name_of(fty4) }
                        }
                    } none => {} }
                    mfi4++ }
            }
        }
    }
    val fields: mut ref void = cc_lookup_struct(ctx, bt)
    if fields == 0 as ref void && str.rchar_cmp(bt, "") != 0 {
        val btlen2: i64 = str.len_raw(bt)
        val dotpos2: mut i64 = -1
        val bi2: mut i64 = 0
        for { if bi2 >= btlen2 { break }
            if @load8(@ptradd(bt as ref void, bi2)) == 46 { dotpos2 = bi2 }
            bi2++ }
        if dotpos2 >= 0 {
            val suffix2: ref char = @ptradd(bt as ref void, dotpos2 + 1) as ref char
            fields = cc_lookup_struct(ctx, suffix2) } }
    if fields != 0 as ref void { return cc_field_size_from_fields(ctx, fields, fname) }
    return 8
}

fn gen_stmts(ctx: ref CCtx, stmts: ref parser.Node) void! = {
    if stmts == 0 as ref parser.Node { return }
    val old_depth: i64 = @len(ctx.defer_stack) as i64
    val len: i64 = @len(stmts) as i64
    val i: mut i64 = 0
    for { 
        if i >= len { break }
        val s_opt = @get(stmts, i as usize)
        match s_opt { 
            some s => {
                gen_stmt(ctx, s as ref parser.Node) 
            } 
            none => {} 
        }
        i++ 
    }
    cc_handle_block_defers(ctx, old_depth)
}

fn gen_stmt(ctx: mut ref CCtx, stmt: ref parser.Node) void! = {
    if stmt == 0 as ref parser.Node { return }
    val k: i64 = stmt.kind
    if k == parser.NK_VAL {
        val name: ref char = stmt.d0 as ref char
        val mutable: i64 = stmt.d1
        val ty_node: mut ref parser.Node = stmt.d2 as ref parser.Node
        val init_expr: ref parser.Node = stmt.d3 as ref parser.Node
        if ty_node == 0 as ref parser.Node && init_expr != 0 as ref parser.Node {
            val ie: mut ref parser.Node = init_expr
            if init_expr.kind == parser.NK_TRY || init_expr.kind == parser.NK_TRUST { 
                ie = init_expr.d0 as ref parser.Node 
            }
            if ie != 0 as ref parser.Node && ie.kind == parser.NK_CALL {
                val cname: ref char = resolve_callee_name_tracked(ctx, parser.call_callee(ie))
                val ret: ref parser.Node = cc_lookup_fn_ret(ctx, cname)
                if ret != 0 as ref parser.Node {
                    val rk: i64 = ret.kind
                    if rk == parser.TY_RESULT || rk == parser.TY_OPTION {
                        val inner: ref parser.Node = ret.d0 as ref parser.Node
                        if inner != 0 as ref parser.Node && inner.kind != parser.TY_VOID { ty_node = inner }
                    } elif rk != parser.TY_VOID { ty_node = ret }
                }
            }
            
        }
        val old_expected = ctx.expected_ty
        ctx.expected_ty = ty_node
        val val_str: ref char = gen_expr(ctx, init_expr)
        ctx.expected_ty = old_expected
        val ct: mut ref char = "int64_t"
        if ty_node != 0 as ref parser.Node { ct = c_type_of(ty_node) }
        
        val buf: ref char = @alloc(8192) as ref char
        @snprintf(buf, 8192, "{s} t_{s}=({s})({s});\n", {ct, name, ct, val_str}) emit(ctx, buf) @free(buf)
        cc_expr_drain(ctx)
        val is_slot: mut i64 = 0 if mutable != 0 { is_slot = 1 }
        cc_register_local(ctx, name, spectre_type_name_of(ty_node), ty_node, is_slot)
        return
    }
    if k == parser.NK_ASSIGN {
        val target: ref parser.Node = stmt.d0 as ref parser.Node
        val old_expected = ctx.expected_ty
        if target.kind == parser.NK_IDENT {
            ctx.expected_ty = cc_lookup_local_ty_node(ctx, target.d0 as ref char)
        }
        val val_str: ref char = gen_expr(ctx, stmt.d1 as ref parser.Node)
        ctx.expected_ty = old_expected
        if target.kind == parser.NK_IDENT { 
            val name: ref char = target.d0 as ref char
            val gn: ref char = cc_resolve_global_name(ctx, name)
            val buf: ref char = @alloc(4096) as ref char
            if str.rchar_cmp(gn, "") != 0 { @snprintf(buf, 4096, "{s}=({s});\n", {gn, val_str}) }
            else { @snprintf(buf, 4096, "t_{s}=({s});\n", {name, val_str}) }
            emit(ctx, buf) @free(buf)
        }
        elif target.kind == parser.NK_FIELD {
            val fsz: i64 = cc_field_size_of_expr(ctx, target)
            val fa: ref char = gen_field_addr(ctx, target) val buf: ref char = @alloc(4096) as ref char
            if fsz > 8 { @snprintf(buf, 4096, "memcpy((void*)(intptr_t)({s}),(void*)(intptr_t)({s}),(size_t){lld});\n", {fa, val_str, fsz}) }
            else { @snprintf(buf, 4096, "*(int64_t*)({s})=(int64_t)({s});\n", {fa, val_str}) }
            emit(ctx, buf) @free(buf) }
        elif target.kind == parser.NK_DEREF { val ptr: ref char = gen_expr(ctx, target.d0 as ref parser.Node)
            val buf: ref char = @alloc(4096) as ref char
            @snprintf(buf, 4096, "*(int64_t*)(intptr_t)({s})=(int64_t)({s});\n", {ptr, val_str}) emit(ctx, buf) @free(buf) }
        cc_expr_drain(ctx)
        return }
    if k == parser.NK_RETURN {
        val expr: ref parser.Node = stmt.d0 as ref parser.Node
        cc_emit_defers(ctx)
        if expr == 0 as ref parser.Node { if ctx.current_ret_is_void { emitln(ctx, "return;") } else { emitln(ctx, "return 0;") } }
        else {
            val old_expected = ctx.expected_ty
            ctx.expected_ty = ctx.current_ret_ty
            val rv: ref char = gen_expr(ctx, expr)
            ctx.expected_ty = old_expected
            val buf: ref char = @alloc(8192) as ref char
            @snprintf(buf, 8192, "return({s})({s});\n", {ctx.current_ret_ctype, rv}) emit(ctx, buf) @free(buf) }
        cc_expr_drain(ctx)
        return }
    if k == parser.NK_EXPR_STMT { val ev: ref char = gen_expr(ctx, stmt.d0 as ref parser.Node)
        val buf: ref char = @alloc(8192) as ref char @snprintf(buf, 8192, "(void)({s});\n", {ev}) emit(ctx, buf) @free(buf) cc_expr_drain(ctx) return }
    if k == parser.NK_IF { gen_if_stmt(ctx, stmt) return }
    if k == parser.NK_GUARD { val gc: ref char = gen_expr(ctx, stmt.d0 as ref parser.Node)
        val buf: ref char = @alloc(4096) as ref char @snprintf(buf, 4096, "if(!({s})){\n", {gc}) emit(ctx, buf) @free(buf)
        cc_expr_drain(ctx)
        gen_stmts(ctx, stmt.d1 as ref parser.Node) emitln(ctx, "}") return }
    if k == parser.NK_FOR { gen_for_stmt(ctx, stmt) return }
    if k == parser.NK_FORIN { gen_forin_stmt(ctx, stmt) return }
    if k == parser.NK_BREAK { emitln(ctx, "break;") return }
    if k == parser.NK_CONTINUE { emitln(ctx, "continue;") return }
    if k == parser.NK_DEFER { cc_defer_push(ctx, stmt.d0 as ref parser.Node) return }
    if k == parser.NK_ASSERT { val cond: ref char = gen_expr(ctx, stmt.d0 as ref parser.Node) val line: i64 = stmt.line
        val buf: ref char = @alloc(512) as ref char
        @snprintf(buf, 512, "if(!({s}))\{fprintf(stderr,\"spectre: assertion failed at line {lld}\\n\");fflush(stderr);abort();}\n", {cond, line})
        emit(ctx, buf) @free(buf) cc_expr_drain(ctx) return }
    if k == parser.NK_PRE || k == parser.NK_GUARDED_PRE || k == parser.NK_POST || k == parser.NK_GUARDED_POST {
        if ctx.release_mode { if k == parser.NK_PRE || k == parser.NK_POST { return } }
        val is_pre: bool = k == parser.NK_PRE || k == parser.NK_GUARDED_PRE
        val ks: mut ref char = "precondition" if !is_pre { ks = "postcondition" }
        val fn_n: ref char = ctx.fn_name
        val clist: ref void = stmt.d0 as ref void
        if clist != 0 as ref void { val clen: i64 = @len(clist) as i64 val ci: mut i64 = 0
            for { if ci >= clen { break }
                val c_opt = @get(clist, ci as usize)
                match c_opt { some c => { val cn: ref parser.Node = c as ref parser.Node
                    val label: ref char = cn.d0 as ref char val cexpr: ref parser.Node = cn.d1 as ref parser.Node
                    val cv: ref char = gen_expr(ctx, cexpr) val buf: ref char = @alloc(1024) as ref char
                    if label != 0 as ref char { @snprintf(buf, 1024, "if(!({s}))\{fprintf(stderr,\"spectre: {s} '%%s' violated in function '%%s'\\n\",\"{s}\",\"{s}\");fflush(stderr);abort();}\n", {cv, ks, label, fn_n}) }
                    else { @snprintf(buf, 1024, "if(!({s}))\{fprintf(stderr,\"spectre: {s} violated in function '%%s'\\n\",\"{s}\");fflush(stderr);abort();}\n", {cv, ks, fn_n}) }
                    emit(ctx, buf) @free(buf) cc_expr_drain(ctx)
                } none => {} }
                ci++ } }
        return }
    if k == parser.NK_MATCH_OPT { gen_match_opt(ctx, stmt) return }
    if k == parser.NK_MATCH_RES { gen_match_res(ctx, stmt) return }
    if k == parser.NK_MATCH_ENUM { gen_match_enum(ctx, stmt) return }
    if k == parser.NK_MATCH_STR { gen_match_str(ctx, stmt) return }
    if k == parser.NK_MATCH_UNION { gen_match_union(ctx, stmt) return }
    if k == parser.NK_MATCH_TAGGED_UNION { gen_match_tagged_union(ctx, stmt) return }
    if k == parser.NK_GENERIC_WHEN { return }
    if k == parser.NK_WHEN_STMT {
        val plat: ref char = stmt.d0 as ref char
        if codegen.platform_matches(plat) { gen_stmts(ctx, stmt.d1 as ref parser.Node) }
        else { val ow: ref void = stmt.d2 as ref void val matched: mut bool = false
            if ow != 0 as ref void { for own in ow as list[ref parser.Node] { if !matched {
                if codegen.platform_matches(own.d0 as ref char) { gen_stmts(ctx, own.d1 as ref parser.Node) matched = true } } } }
            if !matched { val otherwise: ref void = stmt.d3 as ref void
                if otherwise != 0 as ref void { gen_stmts(ctx, stmt.d3 as ref parser.Node) } } }
        return }
    if k == parser.NK_INCREMENT {
        val tgt: ref parser.Node = stmt.d0 as ref parser.Node
        if tgt.kind == parser.NK_IDENT {
            val name: ref char = tgt.d0 as ref char
            val gn: ref char = cc_resolve_global_name(ctx, name)
            val buf: ref char = @alloc(128) as ref char
            if str.rchar_cmp(gn, "") != 0 { @snprintf(buf, 128, "{s}++;\n", {gn}) }
            else { @snprintf(buf, 128, "t_{s}++;\n", {name}) }
            emit(ctx, buf) @free(buf)
        }
        elif tgt.kind == parser.NK_FIELD {
            val fa: ref char = gen_field_addr(ctx, tgt) val buf: ref char = @alloc(256) as ref char @snprintf(buf, 256, "(*(int64_t*)({s}))++;\n", {fa}) emit(ctx, buf) @free(buf)
        }
        elif tgt.kind == parser.NK_DEREF {
            val p: ref char = gen_expr(ctx, tgt.d0 as ref parser.Node) val buf: ref char = @alloc(256) as ref char @snprintf(buf, 256, "(*(int64_t*)(intptr_t)({s}))++;\n", {p}) emit(ctx, buf) @free(buf)
        }
        cc_expr_drain(ctx)
        return
    }
    if k == parser.NK_DECREMENT {
        val tgt: ref parser.Node = stmt.d0 as ref parser.Node
        if tgt.kind == parser.NK_IDENT {
            val name: ref char = tgt.d0 as ref char
            val gn: ref char = cc_resolve_global_name(ctx, name)
            val buf: ref char = @alloc(128) as ref char
            if str.rchar_cmp(gn, "") != 0 { @snprintf(buf, 128, "{s}--;\n", {gn}) }
            else { @snprintf(buf, 128, "t_{s}--;\n", {name}) }
            emit(ctx, buf) @free(buf)
        }
        elif tgt.kind == parser.NK_FIELD { val fa: ref char = gen_field_addr(ctx, tgt) val buf: ref char = @alloc(256) as ref char @snprintf(buf, 256, "(*(int64_t*)({s}))--;\n", {fa}) emit(ctx, buf) @free(buf) }
        elif tgt.kind == parser.NK_DEREF { val p: ref char = gen_expr(ctx, tgt.d0 as ref parser.Node) val buf: ref char = @alloc(256) as ref char @snprintf(buf, 256, "(*(int64_t*)(intptr_t)({s}))--;\n", {p}) emit(ctx, buf) @free(buf) }
        cc_expr_drain(ctx)
        return
    }
    if k == parser.NK_ADD_ASSIGN {
        val tgt: ref parser.Node = stmt.d0 as ref parser.Node val rhs: ref char = gen_expr(ctx, stmt.d1 as ref parser.Node)
        if tgt.kind == parser.NK_IDENT {
            val name: ref char = tgt.d0 as ref char
            val gn: ref char = cc_resolve_global_name(ctx, name)
            val buf: ref char = @alloc(256) as ref char
            if str.rchar_cmp(gn, "") != 0 { @snprintf(buf, 256, "{s}+=({s});\n", {gn, rhs}) }
            else { @snprintf(buf, 256, "t_{s}+=({s});\n", {name, rhs}) }
            emit(ctx, buf) @free(buf)
        }
        elif tgt.kind == parser.NK_FIELD { val fa: ref char = gen_field_addr(ctx, tgt) val buf: ref char = @alloc(256) as ref char @snprintf(buf, 256, "(*(int64_t*)({s}))+=({s});\n", {fa, rhs}) emit(ctx, buf) @free(buf) }
        cc_expr_drain(ctx)
        return
    }
    if k == parser.NK_SUB_ASSIGN {
        val tgt: ref parser.Node = stmt.d0 as ref parser.Node val rhs: ref char = gen_expr(ctx, stmt.d1 as ref parser.Node)
        if tgt.kind == parser.NK_IDENT {
            val name: ref char = tgt.d0 as ref char
            val gn: ref char = cc_resolve_global_name(ctx, name)
            val buf: ref char = @alloc(256) as ref char
            if str.rchar_cmp(gn, "") != 0 { @snprintf(buf, 256, "{s}-=({s});\n", {gn, rhs}) }
            else { @snprintf(buf, 256, "t_{s}-=({s});\n", {name, rhs}) }
            emit(ctx, buf) @free(buf)
        }
        elif tgt.kind == parser.NK_FIELD { val fa: ref char = gen_field_addr(ctx, tgt) val buf: ref char = @alloc(256) as ref char @snprintf(buf, 256, "(*(int64_t*)({s}))-=({s});\n", {fa, rhs}) emit(ctx, buf) @free(buf) }
        cc_expr_drain(ctx)
        return
    }
}

fn gen_if_stmt(ctx: mut ref CCtx, stmt: ref parser.Node) void! = {
    val cond: ref char = gen_expr(ctx, stmt.d0 as ref parser.Node)
    val buf: ref char = @alloc(4096) as ref char @snprintf(buf, 4096, "if({s}){\n", {cond}) emit(ctx, buf) @free(buf)
    cc_expr_drain(ctx)
    gen_stmts(ctx, stmt.d1 as ref parser.Node)
    val elif_list: ref void = stmt.d2 as ref void
    if elif_list != 0 as ref void && @len(elif_list as list[ref void]) > 0 {
        val elen: i64 = @len(elif_list as list[ref void]) as i64 val ei: mut i64 = 0
           for {
               if ei >= elen { break }
               val ep_opt = @get(elif_list as list[ref void], ei as usize)
               match ep_opt {
                   some ep => { val econd: ref char = gen_expr(ctx, (ep as ref parser.Node).d0 as ref parser.Node)
                   val eb: ref char = @alloc(4096) as ref char
                   @snprintf(eb, 4096, "}else if({s}){\n", {econd}) emit(ctx, eb)
                   @free(eb)
                   cc_expr_drain(ctx)
                   gen_stmts(ctx, (ep as ref parser.Node).d1 as ref parser.Node) } none => {}
               }
               ei++
           }
    }
    if stmt.d3 != 0 {
        emitln(ctx, "}else{")
        gen_stmts(ctx, (stmt.d3 as ref parser.Node).d0 as ref parser.Node)
    }
    emitln(ctx, "}")
}

fn gen_for_stmt(ctx: mut ref CCtx, stmt: ref parser.Node) void! = {
    val init_name: ref char = stmt.d0 as ref char
    val cond_node: ref void = stmt.d2 as ref void
    val pst: ref void = stmt.d3 as ref void

    val has_block: mut bool = false
    if init_name != 0 as ref char {
        emitln(ctx, "{")
        has_block = true
        val init_val: ref char = gen_expr(ctx, stmt.d1 as ref parser.Node)
        val ib: ref char = @alloc(256) as ref char
        @snprintf(ib, 256, "int64_t t_{s}=({s});\n", {init_name, init_val})
        emit(ctx, ib)
        @free(ib)
        cc_expr_drain(ctx)
        cc_register_local(ctx, init_name, "int64_t", 0 as ref parser.Node, 1)
    }

    if cond_node != 0 as ref void {
        val cond: ref char = gen_expr(ctx, cond_node as ref parser.Node)
        if pst != 0 as ref void {
            val pst_str: ref char = gen_for_post_expr(ctx, pst as ref parser.Node)
            val wb: ref char = @alloc(512) as ref char
            @snprintf(wb, 512, "for(;{s};{s}){\n", {cond, pst_str})
            emit(ctx, wb)
            @free(wb)
        } else {
            val wb: ref char = @alloc(256) as ref char
            @snprintf(wb, 256, "while({s}){\n", {cond})
            emit(ctx, wb)
            @free(wb)
        }
        cc_expr_drain(ctx)
    } else { emitln(ctx, "for(;;){") }
    gen_stmts(ctx, stmt.d4 as ref parser.Node)
    emitln(ctx, "}")
    if has_block {
        emitln(ctx, "}")
    }
}

/// Convert a for-loop post-step statement node into an expression string
fn gen_for_post_expr(ctx: ref CCtx, pst: ref parser.Node) ref char! = {
    if pst == 0 as ref parser.Node { return "" }
    val k: i64 = pst.kind
    val name: ref char = pst.d0 as ref char
    if k == parser.NK_INCREMENT {
        if name != 0 as ref char {
            val buf: ref char = @alloc(128) as ref char
            @snprintf(buf, 128, "t_{s}++", {name})
            return cc_expr_track(ctx, buf)
        }
        return ""
    }
    if k == parser.NK_DECREMENT {
        if name != 0 as ref char {
            val buf: ref char = @alloc(128) as ref char
            @snprintf(buf, 128, "t_{s}--", {name})
            return cc_expr_track(ctx, buf)
        }
        return ""
    }
    if k == parser.NK_ADD_ASSIGN {
        val rhs: ref char = gen_expr(ctx, pst.d1 as ref parser.Node)
        if name != 0 as ref char {
            val buf: ref char = @alloc(256) as ref char
            @snprintf(buf, 256, "t_{s}+=({s})", {name, rhs})
            return cc_expr_track(ctx, buf)
        }
        return ""
    }
    if k == parser.NK_SUB_ASSIGN {
        val rhs: ref char = gen_expr(ctx, pst.d1 as ref parser.Node)
        if name != 0 as ref char {
            val buf: ref char = @alloc(256) as ref char
            @snprintf(buf, 256, "t_{s}-=({s})", {name, rhs})
            return cc_expr_track(ctx, buf)
        }
        return ""
    }
    return gen_expr(ctx, pst)
}

fn gen_forin_stmt(ctx: mut ref CCtx, stmt: ref parser.Node) void! = {
    val binding: ref char = stmt.d0 as ref char
    val iter_node: ref parser.Node = stmt.d1 as ref parser.Node
    val iter: ref char = gen_expr(ctx, iter_node)
    val t: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(1024) as ref char
    @snprintf(buf, 1024, "\{int64_t sx__it{lld}={s};int64_t sx__len{lld}=(sx__it{lld}==0?0:*(int64_t*)((char*)(intptr_t)sx__it{lld}+8));int64_t*sx__buf{lld}=(sx__it{lld}==0?0:*(int64_t**)(intptr_t)sx__it{lld});int64_t sx__i{lld}=0;for(;sx__i{lld}<sx__len{lld};sx__i{lld}++)\{int64_t t_{s}=sx__buf{lld}[sx__i{lld}];\n",
        {t, iter, t, t, t, t, t, t, t, t, t, t, binding, t, t})
    emit(ctx, buf) @free(buf)
    cc_expr_drain(ctx)
    val elem_stype: mut ref char = "int64_t"
    val elem_ty: mut ref parser.Node = 0 as ref parser.Node
    val iter_ty: ref parser.Node = cc_infer_expr_ty(ctx, iter_node)
    val inner_ty: ref parser.Node = cc_unwrap_list_elem_ty(iter_ty)
    if inner_ty != 0 as ref parser.Node {
        elem_stype = spectre_type_name_of(inner_ty)
        elem_ty = inner_ty
    }
    cc_register_local(ctx, binding, elem_stype, elem_ty, 1)
    gen_stmts(ctx, stmt.d2 as ref parser.Node) emitln(ctx, "}}")
}

fn gen_match_opt(ctx: mut ref CCtx, stmt: ref parser.Node) void! = {
    val en: ref parser.Node = parser.match_opt_expr(stmt) val expr: mut ref char = "0"
    if en != 0 as ref parser.Node { expr = gen_expr(ctx, en) }
    val sb: ref char = parser.match_opt_some_bind(stmt) val sbody: ref parser.Node = parser.match_opt_some_body(stmt)
    val nbody: ref parser.Node = parser.match_opt_none_body(stmt) val t: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(256) as ref char @snprintf(buf, 256, "\{int64_t sx__mv{lld}={s};if(sx__mv{lld}!=0){\n", {t, expr, t}) emit(ctx, buf) @free(buf)
    cc_expr_drain(ctx)
    if sb != 0 as ref char {
        val vb: ref char = @alloc(128) as ref char @snprintf(vb, 128, "int64_t t_{s}=sx__mv{lld}-1;\n", {sb, t}) emit(ctx, vb) @free(vb)
        val bind_stype: mut ref char = "int64_t"
        val bind_ty: mut ref parser.Node = 0 as ref parser.Node
        val expr_ty: ref parser.Node = cc_infer_expr_ty(ctx, en)
        val opt_inner: ref parser.Node = cc_unwrap_option_inner_ty(expr_ty)
        if opt_inner != 0 as ref parser.Node {
            bind_stype = spectre_type_name_of(opt_inner)
            bind_ty = opt_inner
        }
        cc_register_local(ctx, sb, bind_stype, bind_ty, 0)
    }
    if sbody != 0 as ref parser.Node { gen_stmts(ctx, sbody.d0 as ref parser.Node) }
    emitln(ctx, "}else{")
    if nbody != 0 as ref parser.Node { gen_stmts(ctx, nbody.d0 as ref parser.Node) }
    emitln(ctx, "}}")
}

fn gen_match_res(ctx: mut ref CCtx, stmt: ref parser.Node) void! = {
    val en: ref parser.Node = parser.match_res_expr(stmt) val expr: mut ref char = "0"
    if en != 0 as ref parser.Node { expr = gen_expr(ctx, en) }
    val ob: ref char = parser.match_res_ok_bind(stmt) val obody: ref parser.Node = parser.match_res_ok_body(stmt)
    val eb: ref char = parser.match_res_err_bind(stmt) val ebody: ref parser.Node = parser.match_res_err_body(stmt)
    val t: i64 = fresh_tmp(ctx) val buf: ref char = @alloc(4096) as ref char
    @snprintf(buf, 4096, "\{int64_t*sx__rp{lld}=(int64_t*)(intptr_t)({s});if(sx__rp{lld}[0]==0){\n", {t, expr, t}) emit(ctx, buf) @free(buf)
    cc_expr_drain(ctx)
    val expr_ty: ref parser.Node = cc_infer_expr_ty(ctx, en)
    val ok_ty: ref parser.Node = cc_unwrap_result_ok_ty(expr_ty)
    if ob != 0 as ref char {
        val vb: ref char = @alloc(128) as ref char @snprintf(vb, 128, "int64_t t_{s}=sx__rp{lld}[1];\n", {ob, t}) emit(ctx, vb) @free(vb)
        val bind_stype: mut ref char = "int64_t"
        val bind_ty: mut ref parser.Node = 0 as ref parser.Node
        if ok_ty != 0 as ref parser.Node {
            bind_stype = spectre_type_name_of(ok_ty)
            bind_ty = ok_ty
        }
        cc_register_local(ctx, ob, bind_stype, bind_ty, 0)
    }
    if obody != 0 as ref parser.Node { gen_stmts(ctx, obody.d0 as ref parser.Node) }
    emitln(ctx, "}else{")
    if eb != 0 as ref char { val vb: ref char = @alloc(128) as ref char @snprintf(vb, 128, "int64_t t_{s}=sx__rp{lld}[1];\n", {eb, t}) emit(ctx, vb) @free(vb) cc_register_local(ctx, eb, "int64_t", 0 as ref parser.Node, 0) }
    if ebody != 0 as ref parser.Node { gen_stmts(ctx, ebody.d0 as ref parser.Node) }
    emitln(ctx, "}}")
}

fn gen_match_enum(ctx: mut ref CCtx, stmt: ref parser.Node) void! = {
    val en: ref parser.Node = parser.match_enum_expr(stmt) val expr: mut ref char = "0"
    if en != 0 as ref parser.Node { expr = gen_expr(ctx, en) }
    val arms: list[ref parser.Node] = parser.match_enum_arms(stmt) val alen: i64 = @len(arms) as i64
    if alen == 0 { cc_expr_drain(ctx) return }
    val t: i64 = fresh_tmp(ctx) val buf: ref char = @alloc(128) as ref char
    @snprintf(buf, 128, "\{int64_t sx__ev{lld}={s};\n", {t, expr}) emit(ctx, buf) @free(buf)
    cc_expr_drain(ctx)
    val ai: mut i64 = 0
    for { if ai >= alen { break } val arm_opt = @get(arms, ai as usize)
        match arm_opt { some arm => {
            val an: ref parser.Node = arm as ref parser.Node
            val variant_name: ref char = an.d0 as ref char
            val type_name: ref char = an.d2 as ref char
            val eval_str: ref char = @alloc(32) as ref char
            @snprintf(eval_str, 32, "{lld}", {ai})
            if type_name != 0 as ref char && str.rchar_cmp(type_name, "") != 0 {
                val key: ref char = @alloc(512) as ref char
                @snprintf(key, 512, "{s}__{s}", {type_name, variant_name})
                val found: ref char = cc_const_val(ctx, key)
                @free(key)
                if str.rchar_cmp(found, "") != 0 { @snprintf(eval_str, 32, "{s}", {found}) }
            }
            val ab: ref char = @alloc(128) as ref char
            if ai == 0 { @snprintf(ab, 128, "if(sx__ev{lld}=={s}){\n", {t, eval_str}) }
            else { @snprintf(ab, 128, "}else if(sx__ev{lld}=={s}){\n", {t, eval_str}) }
            @free(eval_str)
            emit(ctx, ab) @free(ab) gen_stmts(ctx, parser.match_enum_arm_body(an) as ref parser.Node)
        } none => {} }
        ai++ }
    emitln(ctx, "}}")
}

fn gen_match_str(ctx: mut ref CCtx, stmt: ref parser.Node) void! = {
    val en: ref parser.Node = parser.match_str_expr(stmt) val expr: mut ref char = "0"
    if en != 0 as ref parser.Node { expr = gen_expr(ctx, en) }
    val arms: list[ref parser.Node] = parser.match_str_arms(stmt) val else_body: ref parser.Node = parser.match_str_else(stmt)
    val t: i64 = fresh_tmp(ctx) val buf: ref char = @alloc(4096) as ref char
    @snprintf(buf, 4096, "\{const char*sx__sv{lld}=(const char*)(intptr_t)({s});\n", {t, expr}) emit(ctx, buf) @free(buf)
    cc_expr_drain(ctx)
    val alen: i64 = @len(arms) as i64
    if alen > 0 { val ai: mut i64 = 0
        for { if ai >= alen { break } val arm_opt = @get(arms, ai as usize)
            match arm_opt { some arm => { val an: ref parser.Node = arm as ref parser.Node
                val pat: ref char = parser.match_str_arm_value(an) val pi: i64 = intern_string(ctx, pat)
                val ab: ref char = @alloc(4096) as ref char
                if ai == 0 { @snprintf(ab, 4096, "if(strcmp(sx__sv{lld},sx__str{lld})==0){\n", {t, pi}) }
                else { @snprintf(ab, 4096, "}else if(strcmp(sx__sv{lld},sx__str{lld})==0){\n", {t, pi}) }
                emit(ctx, ab) @free(ab) gen_stmts(ctx, parser.match_str_arm_body(an) as ref parser.Node)
            } none => {} }
            ai++ } }
    if else_body != 0 as ref parser.Node { emitln(ctx, "}else{") gen_stmts(ctx, else_body.d0 as ref parser.Node) }
    emitln(ctx, "}}")
}

fn gen_match_union(ctx: mut ref CCtx, stmt: ref parser.Node) void! = {
    val en: ref parser.Node = parser.match_union_expr(stmt) val expr: mut ref char = "0"
    if en != 0 as ref parser.Node { expr = gen_expr(ctx, en) }
    val arms: list[ref parser.Node] = parser.match_union_arms(stmt) val else_body: ref parser.Node = parser.match_union_else(stmt)
    val t: i64 = fresh_tmp(ctx) val buf: ref char = @alloc(4096) as ref char
    @snprintf(buf, 4096, "\{int64_t sx__uv{lld}=(int64_t)({s});int64_t sx__ut{lld}=*(int64_t*)(intptr_t)sx__uv{lld};\n", {t, expr, t, t})
    emit(ctx, buf)
    @free(buf)
    cc_expr_drain(ctx)
    val alen: i64 = @len(arms) as i64
    if alen > 0 { 
        val ai: mut i64 = 0
        for { 
            if ai >= alen { break } 
            val arm_opt = @get(arms, ai as usize)
            match arm_opt { 
                some arm => { 
                    val ab: ref char = @alloc(128) as ref char
                    if ai == 0 { @snprintf(ab, 128, "if(sx__ut{lld}=={lld}){\n", {t, ai}) }
                    else { @snprintf(ab, 128, "}else if(sx__ut{lld}=={lld}){\n", {t, ai}) }
                    emit(ctx, ab) @free(ab) gen_stmts(ctx, parser.match_union_arm_body(arm as ref parser.Node) as ref parser.Node)
                } none => {} 
            }
            ai++ 
        } 
    }
    if else_body != 0 as ref parser.Node { 
        emitln(ctx, "}else{") 
        gen_stmts(ctx, else_body.d0 as ref parser.Node) 
    }
    emitln(ctx, "}}")
}

fn gen_match_tagged_union(ctx: mut ref CCtx, stmt: ref parser.Node) void! = {
    val en: ref parser.Node = parser.match_tagged_union_expr(stmt) val expr: mut ref char = "0"
    if en != 0 as ref parser.Node { expr = gen_expr(ctx, en) }
    val arms: list[ref parser.Node] = parser.match_tagged_union_arms(stmt) val else_body: ref parser.Node = parser.match_tagged_union_else(stmt)
    val t: i64 = fresh_tmp(ctx) val buf: ref char = @alloc(4096) as ref char
    @snprintf(buf, 4096, "\{int64_t sx__tv{lld}=(int64_t)({s});int64_t sx__tt{lld}=*(int64_t*)(intptr_t)sx__tv{lld};\n", {t, expr, t, t}) emit(ctx, buf) @free(buf)
    cc_expr_drain(ctx)
    val alen: i64 = @len(arms) as i64
    if alen > 0 { val ai: mut i64 = 0
        for { if ai >= alen { break } val arm_opt = @get(arms, ai as usize)
            match arm_opt { some arm => { val an: ref parser.Node = arm as ref parser.Node
                val vname: ref char = parser.match_tagged_union_arm_variant(an)
                val bindings: list[ref char] = parser.match_tagged_union_arm_bindings(an)
                val os: ref void = @alloc(8) val fs: ref void = @alloc(8) @store(os, 0) @store(fs, 0)
                val ti: i64 = cc_lookup_tv(ctx, vname, os, fs) @free(os) @free(fs)
                val idx: mut i64 = ai if ti >= 0 { idx = ti }
                val ab: ref char = @alloc(4096) as ref char
                if ai == 0 { @snprintf(ab, 4096, "if(sx__tt{lld}=={lld}){\n", {t, idx}) }
                else { @snprintf(ab, 4096, "}else if(sx__tt{lld}=={lld}){\n", {t, idx}) }
                emit(ctx, ab) @free(ab)
                val blen: i64 = @len(bindings) as i64
                if blen > 0 { val bi: mut i64 = 0
                    for { if bi >= blen { break } val b_opt = @get(bindings, bi as usize)
                        match b_opt { some b => { val bn: ref char = b as ref char
                            if str.rchar_cmp(bn, "_") != 0 { val off: i64 = 8 + bi * 8
                                val bb: ref char = @alloc(1024) as ref char
                                @snprintf(bb, 1024, "int64_t t_{s}=*(int64_t*)((char*)(intptr_t)sx__tv{lld}+{lld});\n", {bn, t, off})
                                emit(ctx, bb) @free(bb) cc_register_local(ctx, bn, "int64_t", 0 as ref parser.Node, 0) }
                        } none => {} }
                        bi++ } }
                gen_stmts(ctx, parser.match_tagged_union_arm_body(an) as ref parser.Node)
            } none => {} }
            ai++ } }
    if else_body != 0 as ref parser.Node { emitln(ctx, "}else{") gen_stmts(ctx, else_body.d0 as ref parser.Node) }
    emitln(ctx, "}}")
}

fn get_std_child_names() mut list[ref char] = {
    return ["allocators", "collections", "crypto", "fmt", "fs", "log", "math", "os", "path", "random", "reflection", "stdio", "string", "str", "time", "thread"]
}

fn gen_fn_prefixed(ctx: mut ref CCtx, fn_node: ref parser.Node, mod_prefix: ref char) void! = {
    val ns: ref char = fn_node.d1 as ref char val name: ref char = fn_node.d2 as ref char
    val params: ref void = fn_node.d3 as ref void val ret_ty: ref parser.Node = fn_node.d4 as ref parser.Node
    val body: ref parser.Node = fn_node.d5 as ref parser.Node
    val base: ref char = @alloc(256) as ref char
    if ns != 0 as ref char { @snprintf(base, 256, "{s}__{s}", {ns, name}) } else { @snprintf(base, 256, "{s}", {name}) }
    val is_std_child: mut bool = false
    for scn in get_std_child_names() { if str.rchar_cmp(scn, mod_prefix) == 0 { is_std_child = true break } }
    val mangled: ref char = @alloc(512) as ref char
    if str.rchar_cmp(mod_prefix, "") == 0 {
        if str.rchar_cmp(base, "main") == 0 { @snprintf(mangled, 512, "{s}", {base}) }
        else { @snprintf(mangled, 512, "sx__{s}", {base}) }
    } elif is_std_child { @snprintf(mangled, 512, "std__{s}__{s}", {mod_prefix, base}) }
    else { @snprintf(mangled, 512, "{s}__{s}", {mod_prefix, base}) }
    if !cc_emit_label_if_new(ctx, mangled) { @free(mangled) @free(base) return }
    ctx.fn_name = mangled
    if params != 0 as ref void { cc_register_fn(ctx, mangled, params, ret_ty as ref void, false) }
    val ret_ct: ref char = c_ret_type_of(ret_ty)
    val is_main: bool = str.rchar_cmp(name, "main") == 0 && str.rchar_cmp(mod_prefix, "") == 0
    ctx.current_ret_ctype = ret_ct 
    ctx.current_ret_is_void = is_void_ret(ret_ty)
    ctx.current_ret_ty = ret_ty
    cc_clear_locals(ctx)
    if is_main { emitln(ctx, "int32_t main(int argc,char**argv){") }
    else {
        val sig: ref char = @alloc(1024) as ref char @snprintf(sig, 1024, "{s} {s}(", {ret_ct, mangled}) emit(ctx, sig) @free(sig)
        if params != 0 as ref void { val plen: i64 = @len(params) as i64
            if plen == 0 { emit(ctx, "void") }
            val pi: mut i64 = 0
            for { if pi >= plen { break } val p_opt = @get(params, pi as usize)
                match p_opt { some param => { val pn: ref char = (param as ref parser.Node).d0 as ref char
                    val pt: ref parser.Node = (param as ref parser.Node).d1 as ref parser.Node
                    val pct: ref char = c_type_of(pt) if pi > 0 { emit(ctx, ",") }
                    val pb: ref char = @alloc(1024) as ref char
                    if str.rchar_cmp(pn, "_") == 0 {
                        @snprintf(pb, 1024, "{s} t__{lld}", {pct, pi})
                    } else {
                        @snprintf(pb, 1024, "{s} t_{s}", {pct, pn})
                    }
                    emit(ctx, pb) @free(pb)
                    cc_register_local(ctx, pn, spectre_type_name_of(pt), pt, 0) } none => {} }
                pi++ }
        } else { emit(ctx, "void") }
        emitln(ctx, "){") }
    if is_main { emitln(ctx, "sx__argc=(int64_t)argc;sx__argv=(int64_t)(intptr_t)argv;")
        emitln(ctx, "sx__init();")
        if !ctx.release_mode { emitln(ctx, "__sx_panic_init();") } }
    gen_stmts(ctx, body)
    val blen: i64 = @len(body) as i64 val needs_ret: mut bool = true
    if blen > 0 { 
        val last_opt = @get(body, (blen - 1) as usize)
        match last_opt { 
            some last => { 
                if ((last as ref parser.Node).kind == parser.NK_RETURN) { 
                    needs_ret = false 
                } 
            } none => {} 
        } 
    }
    if needs_ret { cc_emit_defers(ctx) if is_main { emitln(ctx, "return 0;") }
        elif ctx.current_ret_is_void { emitln(ctx, "return;") } else { emitln(ctx, "return 0;") } }
    emitln(ctx, "}") emitln(ctx, "")
}

fn gen_extern_fn_prefixed(_: ref CCtx, _: ref parser.Node, _: ref char) void! = {
    // NOOP.
}

fn gen_tagged_union_def(ctx: ref CCtx, item: ref parser.Node, mod_prefix: ref char) void! = {
    val name: ref char = item.d1 as ref char val variants: ref void = item.d2 as ref void
    if variants == 0 as ref void { return }
    val is_sc: mut bool = false
    for scn in get_std_child_names() { if str.rchar_cmp(scn, mod_prefix) == 0 { is_sc = true break } }
    val vlen: i64 = @len(variants) as i64 val mangled: ref char = @alloc(256) as ref char
    if str.rchar_cmp(mod_prefix, "") == 0 { @snprintf(mangled, 256, "{s}", {name}) }
    else { @snprintf(mangled, 256, "{s}__{s}", {mod_prefix, name}) }
    cc_register_union(ctx, mangled, variants)
    val vi: mut i64 = 0
    for { if vi >= vlen { break } val v_opt = @get(variants, vi as usize)
        match v_opt { some v => { val vn: ref parser.Node = v as ref parser.Node val vname: ref char = vn.d0 as ref char
            cc_register_tv(ctx, vname, mangled, vi, vn.d1 as ref void)
            if str.rchar_cmp(mod_prefix, "") != 0 { val pv: ref char = @alloc(256) as ref char
                @snprintf(pv, 256, "{s}__{s}", {mod_prefix, vname}) cc_register_tv(ctx, pv, mangled, vi, vn.d1 as ref void) }
            if is_sc { val sv: ref char = @alloc(256) as ref char
                @snprintf(sv, 256, "std__{s}__{s}", {mod_prefix, vname}) cc_register_tv(ctx, sv, mangled, vi, vn.d1 as ref void) }
        } none => {} }
        vi++ }
}

fn gen_union_def_prefixed(ctx: ref CCtx, item: ref parser.Node, mod_prefix: ref char) void! = {
    val name: ref char = item.d1 as ref char val variants: ref void = item.d2 as ref void
    if variants == 0 as ref void { return }
    val vlen: i64 = @len(variants) as i64 val vnames: mut list[ref char] = [] val vi: mut i64 = 0
    for { if vi >= vlen { break } val v_opt = @get(variants, vi as usize)
        match v_opt { some v => { val vty: ref parser.Node = v as ref parser.Node val tn: mut ref char = "unknown"
            if vty.kind == parser.TY_NAMED { tn = vty.d0 as ref char } elif vty.kind == parser.TY_REF { tn = "ref" }
            @append(vnames, tn) } none => {} }
        vi++ }
    val mangled: ref char = @alloc(256) as ref char
    if str.rchar_cmp(mod_prefix, "") == 0 { @snprintf(mangled, 256, "{s}", {name}) }
    else { @snprintf(mangled, 256, "{s}__{s}", {mod_prefix, name}) }
    cc_register_union(ctx, mangled, vnames as ref void)
}

fn gen_enum_def_prefixed(ctx: ref CCtx, item: ref parser.Node, mod_prefix: ref char) void! = {
    val name: ref char = item.d1 as ref char val variants: ref void = item.d2 as ref void
    if variants == 0 as ref void { return }
    val vlen: i64 = @len(variants) as i64 val vi: mut i64 = 0
    for { if vi >= vlen { break } val v_opt = @get(variants, vi as usize)
        match v_opt { some v => { val vname: ref char = v as ref char
            val ck: ref char = @alloc(512) as ref char val is: ref char = @alloc(32) as ref char @snprintf(is, 32, "{lld}", {vi})
            if str.rchar_cmp(mod_prefix, "") == 0 { @snprintf(ck, 512, "{s}__{s}", {name, vname}) }
            else { @snprintf(ck, 512, "{s}__{s}__{s}", {mod_prefix, name, vname}) }
            cc_register_module_const(ctx, ck, is)
            if str.rchar_cmp(mod_prefix, "") != 0 { val bk: ref char = @alloc(256) as ref char @snprintf(bk, 256, "{s}__{s}", {name, vname})
                val is2: ref char = @alloc(32) as ref char @snprintf(is2, 32, "{lld}", {vi}) cc_register_module_const(ctx, bk, is2) }
        } none => {} }
        vi++ }
}

fn preregister_items(ctx: ref CCtx, items: list[ref parser.Node], mod_prefix: ref char) void! = {
    val ilen: i64 = @len(items) as i64 val i: mut i64 = 0
    for { if i >= ilen { break } val item_opt = @get(items, i as usize)
        match item_opt { some item => { val node: ref parser.Node = item as ref parser.Node val k: i64 = node.kind
            if k == parser.NK_GENERIC_FN { cc_register_generic_fn(ctx, node.d2 as ref char, node, mod_prefix) }
            elif k == parser.NK_FN { val ns: ref char = node.d1 as ref char val name: ref char = node.d2 as ref char
                val params: ref void = node.d3 as ref void val ret_ty: ref void = node.d4 as ref void
                val base: ref char = @alloc(256) as ref char
                if ns != 0 as ref char { @snprintf(base, 256, "{s}__{s}", {ns, name}) } else { @snprintf(base, 256, "{s}", {name}) }
                val is_sc: mut bool = false
                for scn in get_std_child_names() { if str.rchar_cmp(scn, mod_prefix) == 0 { is_sc = true break } }
                val mangled: ref char = @alloc(512) as ref char
                if str.rchar_cmp(mod_prefix, "") == 0 {
                    if str.rchar_cmp(base, "main") == 0 { @snprintf(mangled, 512, "{s}", {base}) }
                    else { @snprintf(mangled, 512, "sx__{s}", {base}) }
                } elif is_sc { @snprintf(mangled, 512, "std__{s}__{s}", {mod_prefix, base}) }
                else { @snprintf(mangled, 512, "{s}__{s}", {mod_prefix, base}) }
                if params != 0 as ref void { cc_register_fn(ctx, mangled, params, ret_ty, false) }
            } elif k == parser.NK_TAGGED_UNIONDEF { gen_tagged_union_def(ctx, node, mod_prefix) }
            elif k == parser.NK_UNIONDEF { gen_union_def_prefixed(ctx, node, mod_prefix) }
            elif k == parser.NK_ENUMDEF { gen_enum_def_prefixed(ctx, node, mod_prefix) }
            elif k == parser.NK_TYPEDEF { cc_register_struct(ctx, node.d1 as ref char, node.d2 as ref void)
                if node.d3 != 0 as i64 { cc_register_invariant(ctx, node.d1 as ref char, node.d3 as ref void) } }
            elif k == parser.NK_EXTERN_TYPE { cc_register_struct(ctx, node.d1 as ref char, node.d2 as ref void) }
            elif k == parser.NK_EXTERN_FN {
                val name: ref char = node.d1 as ref char val symbol: ref char = node.d2 as ref char
                val params: ref void = node.d4 as ref void val ret_ty: ref void = node.d5 as ref void
                val is_var: bool = (node.d6 >> 1) & 1 != 0
                val is_sc2: mut bool = false
                for scn2 in get_std_child_names() { if str.rchar_cmp(scn2, mod_prefix) == 0 { is_sc2 = true break } }
                cc_register_extern(ctx, name, symbol, ret_ty)
                if params != 0 as ref void { cc_register_fn(ctx, symbol, params, ret_ty, is_var) }
                if str.rchar_cmp(mod_prefix, "") != 0 { val m: ref char = @alloc(512) as ref char
                    @snprintf(m, 512, "{s}__{s}", {mod_prefix, name}) cc_register_extern(ctx, m, symbol, ret_ty)
                    if params != 0 as ref void { cc_register_fn(ctx, m, params, ret_ty, is_var) } }
                if is_sc2 { val sm: ref char = @alloc(512) as ref char
                    @snprintf(sm, 512, "std__{s}__{s}", {mod_prefix, name}) cc_register_extern(ctx, sm, symbol, ret_ty)
                    if params != 0 as ref void { cc_register_fn(ctx, sm, params, ret_ty, is_var) } }
            }
            elif k == parser.NK_CONST { val cn: ref char = node.d1 as ref char val ce: ref parser.Node = node.d2 as ref parser.Node
                val cv: mut ref char = 0 as ref char
                if ce != 0 as ref parser.Node {
                    if ce.kind == parser.NK_INT_LIT { cv = parser.int_lit_text(ce) }
                    elif ce.kind == parser.NK_BOOL { if ce.d0 as i64 != 0 { cv = "1" } else { cv = "0" } }
                    elif ce.kind == parser.NK_UNOP { val uop: i64 = parser.unop_op(ce) val inner: ref parser.Node = parser.unop_inner(ce)
                        if inner != 0 as ref parser.Node && uop == parser.UOP_NEG && inner.kind == parser.NK_INT_LIT {
                            val iv: ref char = @alloc(128) as ref char @snprintf(iv, 128, "-{s}", {parser.int_lit_text(inner)}) cv = iv } }
                    elif ce.kind == parser.NK_STR_LIT {
                        val sidx: i64 = intern_string(ctx, parser.str_lit_text(ce))
                        val sb: ref char = @alloc(128) as ref char
                        @snprintf(sb, 128, "((int64_t)(intptr_t)sx__str{lld})", {sidx})
                        cv = sb
                    } }
                if cv != 0 as ref char {
                    cc_register_module_const(ctx, cn, cv)
                    if str.rchar_cmp(mod_prefix, "") != 0 {
                        val pk: ref char = @alloc(512) as ref char @snprintf(pk, 512, "{s}__{s}", {mod_prefix, cn})
                        cc_register_module_const(ctx, pk, cv) }
                    val is_sc3: mut bool = false
                    for scn3 in get_std_child_names() { if str.rchar_cmp(scn3, mod_prefix) == 0 { is_sc3 = true break } }
                    if is_sc3 { val sk: ref char = @alloc(512) as ref char @snprintf(sk, 512, "std__{s}__{s}", {mod_prefix, cn})
                        cc_register_module_const(ctx, sk, cv) } } }
            elif k == parser.NK_WHEN_ITEMS { val plat: ref char = node.d0 as ref char
                if codegen.platform_matches(plat) { preregister_items(ctx, node.d1 as list[ref parser.Node], mod_prefix) }
                else { val ow: ref void = node.d2 as ref void val matched: mut bool = false
                    if ow != 0 as ref void { for own in ow as list[ref parser.Node] { if !matched {
                        if codegen.platform_matches(own.d0 as ref char) { preregister_items(ctx, own.d1 as list[ref parser.Node], mod_prefix) matched = true } } } }
                    if !matched { val otherwise: ref void = node.d3 as ref void
                        if otherwise != 0 as ref void { preregister_items(ctx, otherwise as list[ref parser.Node], mod_prefix) } } } }
        } none => {} }
        i++ 
    }
}

fn gen_module_val(ctx: mut ref CCtx, node: ref parser.Node, mod_prefix: ref char) void! = {
    val name: ref char = node.d0 as ref char
    val ty_node: ref parser.Node = node.d2 as ref parser.Node
    val init_expr: ref parser.Node = node.d3 as ref parser.Node
    val ct: mut ref char = "int64_t"
    if ty_node != 0 as ref parser.Node { ct = c_type_of(ty_node) }
    val mangled: ref char = @alloc(512) as ref char
    if str.rchar_cmp(mod_prefix, "") == 0 { @snprintf(mangled, 512, "sx__{s}", {name}) }
    else { @snprintf(mangled, 512, "{s}__{s}", {mod_prefix, name}) }
    cc_register_module_val(ctx, name, mangled)
    if str.rchar_cmp(mod_prefix, "") != 0 {
        val m: ref char = @alloc(512) as ref char @snprintf(m, 512, "{s}__{s}", {mod_prefix, name})
        cc_register_module_val(ctx, m, mangled) }
    val buf: ref char = @alloc(1024) as ref char @snprintf(buf, 1024, "static {s} {s};\n", {ct, mangled})
    emit_to_fwd(ctx, buf) @free(buf)
    
    if init_expr != 0 as ref parser.Node {
        val old_sb = ctx.sb
        ctx.sb = ctx.init_sb
        val old_expected = ctx.expected_ty
        ctx.expected_ty = ty_node
        val val_str: ref char = gen_expr(ctx, init_expr)
        ctx.expected_ty = old_expected
        val init_buf: ref char = @alloc(2048) as ref char
        @snprintf(init_buf, 2048, "{s} = ({s})({s});\n", {mangled, ct, val_str})
        str.StringBuilder.append_cstr(ctx.init_sb, init_buf)
        @free(init_buf)
        cc_expr_drain(ctx)
        ctx.sb = old_sb
    }
}

fn gen_items_with_prefix(ctx: mut ref CCtx, items: list[ref parser.Node], mod_prefix: ref char) void! = {
    preregister_items(ctx, items, mod_prefix)
    val ilen: i64 = @len(items) as i64 val i: mut i64 = 0
    for { if i >= ilen { break } val item_opt = @get(items, i as usize)
        match item_opt { some item => { val node: ref parser.Node = item as ref parser.Node val k: i64 = node.kind
            if k == parser.NK_GENERIC_FN { cc_register_generic_fn(ctx, node.d2 as ref char, node, mod_prefix) }
            elif k == parser.NK_FN { gen_fn_prefixed(ctx, node, mod_prefix) }
            elif k == parser.NK_VAL { gen_module_val(ctx, node, mod_prefix) }
            elif k == parser.NK_EXTERN_FN { gen_extern_fn_prefixed(ctx, node, mod_prefix) }
            elif k == parser.NK_ENUMDEF { gen_enum_def_prefixed(ctx, node, mod_prefix) }
            elif k == parser.NK_UNIONDEF { gen_union_def_prefixed(ctx, node, mod_prefix) }
            elif k == parser.NK_TAGGED_UNIONDEF { gen_tagged_union_def(ctx, node, mod_prefix) }
            elif k == parser.NK_TYPEDEF { cc_register_struct(ctx, node.d1 as ref char, node.d2 as ref void)
                if node.d3 != 0 as i64 { cc_register_invariant(ctx, node.d1 as ref char, node.d3 as ref void) } }
            elif k == parser.NK_EXTERN_TYPE { cc_register_struct(ctx, node.d1 as ref char, node.d2 as ref void) }
            elif k == parser.NK_WHEN_ITEMS { val plat: ref char = node.d0 as ref char
                if codegen.platform_matches(plat) { gen_items_with_prefix(ctx, node.d1 as list[ref parser.Node], mod_prefix) }
                else { val ow: ref void = node.d2 as ref void val matched: mut bool = false
                    if ow != 0 as ref void { for own in ow as list[ref parser.Node] { if !matched {
                        if codegen.platform_matches(own.d0 as ref char) { gen_items_with_prefix(ctx, own.d1 as list[ref parser.Node], mod_prefix) matched = true } } } }
                    if !matched { val otherwise: ref void = node.d3 as ref void
                        if otherwise != 0 as ref void { gen_items_with_prefix(ctx, otherwise as list[ref parser.Node], mod_prefix) } } } }
        } none => {} }
        i++ }
}

fn emit_to_fwd(ctx: ref CCtx, s: ref char) void! = { str.StringBuilder.append_cstr(ctx.fwd_sb, s) }
fn emitln_fwd(ctx: ref CCtx, s: ref char) void! = { str.StringBuilder.append_cstr(ctx.fwd_sb, s) str.StringBuilder.append_char(ctx.fwd_sb, 10) }

fn emit_c_preamble(ctx: ref CCtx) void! = {
    when posix {
        emitln_fwd(ctx, "#define _POSIX_C_SOURCE 200809L")
    }
    emitln_fwd(ctx, "#include <stdint.h>")
    emitln_fwd(ctx, "#include <stdlib.h>")
    emitln_fwd(ctx, "#include <string.h>")
    emitln_fwd(ctx, "#include <stdio.h>")
    emitln_fwd(ctx, "#include <time.h>")
    emitln_fwd(ctx, "#include <sys/time.h>")
    emitln_fwd(ctx, "#include <sys/types.h>")
    emitln_fwd(ctx, "#include <sys/stat.h>")
    emitln_fwd(ctx, "#include <unistd.h>")
    emitln_fwd(ctx, "#include <dirent.h>")
    emitln_fwd(ctx, "static int64_t sx__argc=0;")
    emitln_fwd(ctx, "static int64_t sx__argv=0;")
    emitln_fwd(ctx, "static void sx__rt_append(void*list,int64_t elem){int64_t*hdr=(int64_t*)list;int64_t*buf=*(int64_t**)hdr;int64_t len=hdr[1];int64_t cap=hdr[2];if(len>=cap){cap=cap<4?8:cap*2;buf=(int64_t*)realloc(buf,(size_t)(cap*8));hdr[0]=(int64_t)(intptr_t)buf;hdr[2]=cap;}buf[len]=elem;hdr[1]=len+1;}")
    emitln_fwd(ctx, "static void sx__rt_append_f(int64_t*lfield,int64_t elem){if(*lfield==0){int64_t*hdr=(int64_t*)calloc(1,24);int64_t*buf=(int64_t*)calloc(1,64);hdr[0]=(int64_t)(intptr_t)buf;hdr[1]=0;hdr[2]=8;*lfield=(int64_t)(intptr_t)hdr;}sx__rt_append((void*)(intptr_t)(*lfield),elem);}")
    emitln_fwd(ctx, "static int64_t sx__rt_get(void*list,int64_t idx){if(!list)return 0;int64_t*hdr=(int64_t*)list;int64_t*buf=*(int64_t**)hdr;int64_t len=hdr[1];if(idx<0||idx>=len)return 0;return buf[idx]+1;}")
    emitln_fwd(ctx, "static int64_t sx__rt_remove(void*list,int64_t idx){int64_t*hdr=(int64_t*)list;int64_t*buf=*(int64_t**)hdr;int64_t len=hdr[1];if(idx<0||idx>=len)return 0;int64_t val=buf[idx];int64_t i;for(i=idx;i<len-1;i++)buf[i]=buf[i+1];hdr[1]=len-1;return val;}")
    emitln_fwd(ctx, "static void sx__rt_reserve(void*list,int64_t cap){int64_t*hdr=(int64_t*)list;int64_t cur=hdr[2];if(cap>cur){int64_t*buf=*(int64_t**)hdr;buf=(int64_t*)realloc(buf,(size_t)(cap*8));hdr[0]=(int64_t)(intptr_t)buf;hdr[2]=cap;}}")
    emitln_fwd(ctx, "static void*sx__rt_get_args(void){int64_t*hdr=(int64_t*)calloc(1,24);int64_t c=sx__argc;int64_t*buf=(int64_t*)calloc(1,(size_t)(c*8));char**av=(char**)(intptr_t)sx__argv;int64_t i;for(i=0;i<c;i++)buf[i]=(int64_t)(intptr_t)av[i];hdr[0]=(int64_t)(intptr_t)buf;hdr[1]=c;hdr[2]=c;return hdr;}")
    emitln_fwd(ctx, "static void sx__rt_printf(const char* f, int64_t* p){if(!p){printf(\"%s\",f);return;} printf(f,p[0],p[1],p[2],p[3],p[4],p[5],p[6],p[7],p[8],p[9],p[10],p[11],p[12],p[13],p[14],p[15]);}")
    emitln_fwd(ctx, "static void sx__rt_dprintf(int fd, const char* f, int64_t* p){if(!p){dprintf(fd,\"%s\",f);return;} dprintf(fd,f,p[0],p[1],p[2],p[3],p[4],p[5],p[6],p[7],p[8],p[9],p[10],p[11],p[12],p[13],p[14],p[15]);}")
    emitln_fwd(ctx, "static char* sx__rt_fmt(const char* f, int64_t* p){char* b=(char*)malloc(4096);if(!p){strcpy(b,f);return b;} snprintf(b,4096,f,p[0],p[1],p[2],p[3],p[4],p[5],p[6],p[7],p[8],p[9],p[10],p[11],p[12],p[13],p[14],p[15]);return b;}")
}

fn emit_c_panic_handler(ctx: ref CCtx) void! = {
    if !ctx.release_mode { emitln_fwd(ctx, "extern void __sx_panic_init(void);") }
}

fn emit_string_data(ctx: ref CCtx) void! = {
    val slen: i64 = @len(ctx.strs as list[ref char]) as i64
    val si: mut i64 = 0
    for { if si >= slen { break }
        val s_opt = @get(ctx.strs as list[ref char], si as usize)
        match s_opt { some s => {
            val buf: ref char = @alloc(4096) as ref char
            @snprintf(buf, 4096, "static char sx__str{lld}[]=\"", {si})
            emit_to_fwd(ctx, buf) @free(buf)
            val raw: ref char = s as ref char 
            val rlen: i64 = str.len_raw(raw) 
            val ri: mut i64 = 0
            for { if ri >= rlen { break }
                val ch: u8 = @load8(@ptradd(raw as ref void, ri))
                if ch == 10 { emit_to_fwd(ctx, "\\n") }
                elif ch == 13 { emit_to_fwd(ctx, "\\r") }
                elif ch == 9 { emit_to_fwd(ctx, "\\t") }
                elif ch == 0 { emit_to_fwd(ctx, "\\0") }
                elif ch == 34 { emit_to_fwd(ctx, "\\\"") }
                elif ch == 92 { emit_to_fwd(ctx, "\\\\") }
                else { val cb: ref char = @alloc(2) as ref char @store8(cb as ref void, ch) @store8(@ptradd(cb as ref void, 1), 0) emit_to_fwd(ctx, cb) @free(cb) }
                ri++ }
            emitln_fwd(ctx, "\";")
        } none => {} }
        si++ 
    }
}

fn is_libc_fn(name: ref char) bool! = {
    val libc_fns: list[ref char] = [
        "malloc", "free", "realloc", "calloc", "memset", "memcpy", 
        "strlen", "strcmp", "puts", "printf", "dprintf", "getchar", "fgets", 
        "exit", "abort", "abs", "getenv", "fopen", "fclose", "fread", "fwrite", 
        "remove", "rename", "system", "time","gmtime","localtime","strftime","clock",
        "gettimeofday","srand","rand","random","srandom","access","popen","pclose", 
        "open","close","read","write","lseek","pread","pwrite","fsync","ftruncate",
        "strlen","strnlen","strcmp","strncmp","strcpy","strncpy","strcat","strncat","strchr",
        "strrchr","strstr","strpbrk","strtok","strdup","strndup",
        "stat","fstat","lstat","opendir","readdir","closedir","isatty", "readlink", "rmdir",
        "fseek", "ftell", "rewind", "getcwd", "mkdir", "fread", "fwrite", "fprintf", "fflush"
    ]

    for fun in libc_fns { if str.rchar_cmp(name, fun) == 0 { return true } }
    return false
}

fn emit_forward_decls(ctx: ref CCtx) void! = {
    val flen: i64 = @len(ctx.fn_names as list[ref char]) as i64
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val mangled_opt = @get(ctx.fn_names as list[ref char], fi as usize)
        match mangled_opt { some mangled_ref => {
            val mangled: ref char = mangled_ref as ref char
            if str.rchar_cmp(mangled, "main") == 0 { fi++ continue }
            if is_libc_fn(mangled) { fi++ continue }
            
            val ret_ct: mut ref char = "int64_t"
            val r_opt = @get(ctx.fn_rets as list[ref void], fi as usize)
            match r_opt { some r => { ret_ct = c_ret_type_of(r as ref parser.Node) } none => {} }
            
            val sig: ref char = @alloc(1024) as ref char 
            @snprintf(sig, 1024, "{s} {s}(", {ret_ct, mangled}) 
            emit_to_fwd(ctx, sig) @free(sig)
            
            val is_var: mut bool = false
            val v_opt = @get(ctx.fn_variadics as list[bool], fi as usize)
            match v_opt { some v => { is_var = v as bool } none => {} }

            val p_opt = @get(ctx.fn_params as list[ref void], fi as usize)
            match p_opt { some p => {
                val params_list: ref void = p as ref void
                val plen: i64 = @len(params_list as list[ref void]) as i64
                if plen == 0 && !is_var { emit_to_fwd(ctx, "void") }
                val pi: mut i64 = 0
                for { if pi >= plen { break }
                    val param_opt = @get(params_list as list[ref void], pi as usize)
                    match param_opt { some param => {
                        val pt: ref parser.Node = (param as ref parser.Node).d1 as ref parser.Node
                        val pct: ref char = c_type_of(pt)
                        if pi > 0 { emit_to_fwd(ctx, ",") }
                        emit_to_fwd(ctx, pct)
                    } none => {} }
                    pi++ }
                if is_var { emit_to_fwd(ctx, ",...") }
            } none => { emit_to_fwd(ctx, "void") } }
            emitln_fwd(ctx, ");")
        } none => {} }
        fi++
    }
}

fn gen_init_fn(ctx: mut ref CCtx) void! = {
    val init_body: ref void = str.StringBuilder.build(ctx.init_sb)
    val body_str: ref char = str.cstr(init_body)
    emitln(ctx, "static void sx__init(void){")
    emit(ctx, body_str)
    emitln(ctx, "}")
    emitln(ctx, "")
}

fn gen_items_with_prefix_skip_main(ctx: mut ref CCtx, items: list[ref parser.Node], mod_prefix: ref char) void! = {
    preregister_items(ctx, items, mod_prefix)
    val ilen: i64 = @len(items) as i64 val i: mut i64 = 0
    for { if i >= ilen { break } val item_opt = @get(items, i as usize)
        match item_opt { some item => { val node: ref parser.Node = item as ref parser.Node val k: i64 = node.kind
            if k == parser.NK_FN {
                val fname: ref char = node.d2 as ref char
                if str.rchar_cmp(fname, "main") != 0 { gen_fn_prefixed(ctx, node, mod_prefix) }
            } elif k == parser.NK_VAL { gen_module_val(ctx, node, mod_prefix) }
            elif k == parser.NK_EXTERN_FN { gen_extern_fn_prefixed(ctx, node, mod_prefix) }
            elif k == parser.NK_ENUMDEF { gen_enum_def_prefixed(ctx, node, mod_prefix) }
            elif k == parser.NK_UNIONDEF { gen_union_def_prefixed(ctx, node, mod_prefix) }
            elif k == parser.NK_TAGGED_UNIONDEF { gen_tagged_union_def(ctx, node, mod_prefix) }
            elif k == parser.NK_TYPEDEF { cc_register_struct(ctx, node.d1 as ref char, node.d2 as ref void)
                if node.d3 != 0 as i64 { cc_register_invariant(ctx, node.d1 as ref char, node.d3 as ref void) } }
            elif k == parser.NK_EXTERN_TYPE { cc_register_struct(ctx, node.d1 as ref char, node.d2 as ref void) }
            elif k == parser.NK_WHEN_ITEMS { val plat: ref char = node.d0 as ref char
                if codegen.platform_matches(plat) { gen_items_with_prefix_skip_main(ctx, node.d1 as list[ref parser.Node], mod_prefix) }
                else { val ow: ref void = node.d2 as ref void val matched: mut bool = false
                    if ow != 0 as ref void { for own in ow as list[ref parser.Node] { if !matched {
                        if codegen.platform_matches(own.d0 as ref char) { gen_items_with_prefix_skip_main(ctx, own.d1 as list[ref parser.Node], mod_prefix) matched = true } } } }
                    if !matched { val otherwise: ref void = node.d3 as ref void
                        if otherwise != 0 as ref void { gen_items_with_prefix_skip_main(ctx, otherwise as list[ref parser.Node], mod_prefix) } } } }
        } none => {} }
        i++ }
}

fn gen_test_fn_c(ctx: mut ref CCtx, body_stmts: ref parser.Node, test_id: i64) void! = {
    cc_clear_locals(ctx)
    ctx.current_ret_ctype = "void"
    ctx.current_ret_is_void = true
    ctx.current_ret_ty = 0 as ref parser.Node
    val fname: ref char = @alloc(32) as ref char
    @snprintf(fname, 32, "sx__test_{lld}", {test_id})
    ctx.fn_name = fname
    val hdr: ref char = @alloc(64) as ref char
    @snprintf(hdr, 64, "void {s}(void)\{", {fname})
    emitln(ctx, hdr) @free(hdr) @free(fname)
    gen_stmts(ctx, body_stmts)
    cc_emit_defers(ctx)
    emitln(ctx, "return;")
    emitln(ctx, "}")
    emitln(ctx, "")
}

fn gen_test_main_c(ctx: ref CCtx, test_ids: list[i64]) void! = {
    emitln(ctx, "int main(int argc,char**argv) {")
    emitln(ctx, "sx__argc=(int64_t)argc;sx__argv=(int64_t)(intptr_t)argv;")
    emitln(ctx, "sx__init();")
    if !ctx.release_mode { emitln(ctx, "__sx_panic_init();") }
    val tlen: i64 = @len(test_ids) as i64 val ti: mut i64 = 0
    for { 
        if ti >= tlen { break } 
        val id_opt = @get(test_ids, ti as usize)
        match id_opt { 
            some id => {
                val call: ref char = @alloc(48) as ref char
                @snprintf(call, 48, "sx__test_{lld}();", {id as i64})
                emitln(ctx, call) 
                @free(call)
            } 
            none => {} 
        }
        ti++ 
    }
    val ok_idx: i64 = intern_format_string(ctx, "all tests passed\n")
    val ok_buf: ref char = @alloc(64) as ref char
    @snprintf(ok_buf, 64, "printf(sx__str{lld});", {ok_idx})
    emitln(ctx, ok_buf) @free(ok_buf)
    emitln(ctx, "return 0;")
    emitln(ctx, "}")
    emitln(ctx, "")
}

pub fn gen_module_c_test(root: ref module.ResolvedModule, release_mode: bool, extra_includes: list[ref char]) ref char! = {
    val ctx: mut ref CCtx = cc_new()
    ctx.release_mode = release_mode
    val out_prefixes: list[ref char] = []
    val out_items: list[ref void] = []
    val seen: list[String] = []
    module.flatten_modules(root, "", out_prefixes, out_items, seen)
    val layers: i64 = @len(out_prefixes) as i64
    cc_mark_prefix_used(ctx, "")
    emit_c_preamble(ctx)
    for inc in extra_includes {
        emitln_fwd(ctx, str.concat_raw("#include \"", str.concat_raw(inc, "\"")))
    }
    emit_c_panic_handler(ctx)
    val li: mut i64 = 0
    for {
        if li >= layers { break }
        val pfx_opt = @get(out_prefixes, li as usize)
        val items_opt = @get(out_items, li as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some ip => { preregister_items(ctx, ip as list[ref parser.Node], pfx as ref char) }
                    none => {}
                }
            } none => {}
        }
        li++
    }
    val li2: mut i64 = 0
    for {
        if li2 >= layers { break }
        val pfx_opt = @get(out_prefixes, li2 as usize)
        val items_opt = @get(out_items, li2 as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some ip => {
                        val is_root: bool = str.rchar_cmp(pfx as ref char, "") == 0
                        if is_root { gen_items_with_prefix_skip_main(ctx, ip as list[ref parser.Node], "") }
                        else { gen_items_with_prefix(ctx, ip as list[ref parser.Node], pfx as ref char) }
                    } none => {}
                }
            } none => {}
        }
        li2++
    }
    gen_init_fn(ctx)
    val test_ids: mut list[i64] = []
    val test_counter: mut i64 = 0
    val root_items: list[ref parser.Node] = root.items
    val rlen: i64 = @len(root_items) as i64
    val ri: mut i64 = 0
    for {
        if ri >= rlen { break }
        val item_opt = @get(root_items, ri as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                if node.kind == parser.NK_TEST {
                    test_counter++
                    @append(test_ids, test_counter)
                    gen_test_fn_c(ctx, node.d0 as ref parser.Node, test_counter)
                }
            }
            none => {}
        }
        ri++
    }
    gen_test_main_c(ctx, test_ids)
    emit_string_data(ctx)
    emit_forward_decls(ctx)
    val hdr_built: ref void = str.StringBuilder.build(ctx.fwd_sb)
    val hdr_str: ref char = str.cstr(hdr_built)
    val mono_built: ref void = str.StringBuilder.build(ctx.mono_sb)
    val mono_str: ref char = str.cstr(mono_built)
    val body_built: ref void = str.StringBuilder.build(ctx.sb)
    val body_str: ref char = str.cstr(body_built)
    val hdr_len: i64 = str.len_raw(hdr_str)
    val mono_len: i64 = str.len_raw(mono_str)
    val body_len: i64 = str.len_raw(body_str)
    val total: i64 = hdr_len + mono_len + body_len + 1
    val result: ref char = @alloc(total) as ref char
    @memcpy(result as ref void, hdr_str as ref void, hdr_len as usize)
    @memcpy(@ptradd(result as ref void, hdr_len), mono_str as ref void, mono_len as usize)
    @memcpy(@ptradd(result as ref void, hdr_len + mono_len), body_str as ref void, (body_len + 1) as usize)
    str.StringBuilder.free(ctx.fwd_sb)
    str.StringBuilder.free(ctx.mono_sb)
    str.StringBuilder.free(ctx.sb)
    return result
}

pub fn gen_module_c(root: ref module.ResolvedModule, release_mode: bool, extra_includes: list[ref char]) ref char! = {
    val ctx: mut ref CCtx = cc_new()
    ctx.release_mode = release_mode
    val out_prefixes: list[ref char] = []
    val out_items: list[ref void] = []
    val seen: list[String] = []
    module.flatten_modules(root, "", out_prefixes, out_items, seen)
    val layers: i64 = @len(out_prefixes) as i64
    cc_mark_prefix_used(ctx, "")
    emit_c_preamble(ctx)
    for inc in extra_includes {
        emitln_fwd(ctx, str.concat_raw("#include \"", str.concat_raw(inc, "\"")))
    }
    emit_c_panic_handler(ctx)
    emitln_fwd(ctx, "static void sx__init(void);")
    val li: mut i64 = 0
    for { 
        if li >= layers { break }
        val pfx_opt = @get(out_prefixes, li as usize) 
        val items_opt = @get(out_items, li as usize)
        match pfx_opt { 
            some pfx => { 
                match items_opt { 
                    some ip => {
                        preregister_items(ctx, ip as list[ref parser.Node], pfx as ref char)
                    } none => {} 
                } 
            } none => {} 
        }
        li++ 
    }
    val li2: mut i64 = 0
    for { 
        if li2 >= layers { break }
        val pfx_opt = @get(out_prefixes, li2 as usize) 
        val items_opt = @get(out_items, li2 as usize)
        match pfx_opt { 
            some pfx => { 
                match items_opt { 
                    some ip => {
                        gen_items_with_prefix(ctx, ip as list[ref parser.Node], pfx as ref char)
                    } none => {} 
                } 
            } 
            none => {} 
        }       
        li2++ 
    }
    gen_init_fn(ctx)
    emit_string_data(ctx)
    emit_forward_decls(ctx)
    val hdr_built: ref void = str.StringBuilder.build(ctx.fwd_sb)
    val hdr_str: ref char = str.cstr(hdr_built)
    val mono_built: ref void = str.StringBuilder.build(ctx.mono_sb)
    val mono_str: ref char = str.cstr(mono_built)
    val body_built: ref void = str.StringBuilder.build(ctx.sb)
    val body_str: ref char = str.cstr(body_built)
    val hdr_len: i64 = str.len_raw(hdr_str)
    val mono_len: i64 = str.len_raw(mono_str)
    val body_len: i64 = str.len_raw(body_str)
    val total: i64 = hdr_len + mono_len + body_len + 1
    val result: ref char = @alloc(total) as ref char
    @memcpy(result as ref void, hdr_str as ref void, hdr_len as usize)
    @memcpy(@ptradd(result as ref void, hdr_len), mono_str as ref void, mono_len as usize)
    @memcpy(@ptradd(result as ref void, hdr_len + mono_len), body_str as ref void, (body_len + 1) as usize)
    str.StringBuilder.free(ctx.fwd_sb)
    str.StringBuilder.free(ctx.mono_sb)
    str.StringBuilder.free(ctx.sb)
    return result
}
