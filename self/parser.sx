pub val TY_REF        : i64 = 101
pub val TY_MUT        : i64 = 102
pub val TY_OPTION     : i64 = 103
pub val TY_LIST       : i64 = 104
pub val TY_RESULT     : i64 = 105
pub val TY_SLICE      : i64 = 106
pub val TY_FIXED_ARR  : i64 = 107
pub val TY_FNPTR      : i64 = 108
pub val TY_VOID       : i64 = 109
pub val TY_UNTYPED    : i64 = 110
pub val OP_ADD  : i64 = 1
pub val OP_SUB  : i64 = 2
pub val OP_MUL  : i64 = 3
pub val OP_DIV  : i64 = 4
pub val OP_REM  : i64 = 5
pub val OP_EQ   : i64 = 6
pub val OP_NE   : i64 = 7
pub val OP_LT   : i64 = 8
pub val OP_GT   : i64 = 9
pub val OP_LE   : i64 = 10
pub val OP_GE   : i64 = 11
pub val OP_AND  : i64 = 12
pub val OP_OR   : i64 = 13
pub val OP_BAND : i64 = 14
pub val OP_BOR  : i64 = 15
pub val OP_BXOR : i64 = 16
pub val OP_SHL  : i64 = 17
