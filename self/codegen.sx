val std        = use("std")
val str        = use("std/string")
val stdio      = use("std/stdio")
val reflection = use("std/reflection")
val parser     = use("parser.sx")
val module     = use("module.sx")

/// Returns true if the given when-clause name matches the current platform.
/// Handles group aliases: "posix" matches linux/darwin/*bsd/haiku/android/redox.
fn platform_matches(name: ref char) bool! = {
    val cur: ref char = reflection.current_platform_name()
    if str.rchar_cmp(name, cur) == 0 { return true }
    if str.rchar_cmp(name, "posix") == 0 {
        if str.rchar_cmp(cur, "linux")        == 0 { return true }
        if str.rchar_cmp(cur, "darwin")       == 0 { return true }
        if str.rchar_cmp(cur, "freebsd")      == 0 { return true }
        if str.rchar_cmp(cur, "openbsd")      == 0 { return true }
        if str.rchar_cmp(cur, "netbsd")       == 0 { return true }
        if str.rchar_cmp(cur, "dragonflybsd") == 0 { return true }
        if str.rchar_cmp(cur, "haiku")        == 0 { return true }
        if str.rchar_cmp(cur, "android")      == 0 { return true }
        if str.rchar_cmp(cur, "redox")        == 0 { return true }
    }
    return false
}

/// Codegen context
pub type CgCtx = {
    sb: mut ref void
    tmp: mut i64
    lbl: mut i64
    fn_name: mut ref char
    current_fn_ret_union: mut ref char
    strs: mut list[ref char]
    str_cnt: mut i64
    tdefs: mut list[ref void]
    edefs: mut list[ref void]
    dvars: mut list[ref char]
    dqtypes: mut list[ref char]
    snames: mut list[ref char]
    sfields: mut list[ref void]
    lnames: mut list[ref char]
    ltypes: mut list[ref char]
    unames: mut list[ref char]
    uvariants:mut list[ref void]
    fn_names: mut list[ref char]
    fn_params: mut list[ref void]
    fn_rets: mut list[ref void]
    ext_names: mut list[ref char]
    ext_syms: mut list[ref char]
    ext_rets: mut list[ref void]
    tv_names: mut list[ref char]
    tv_owners: mut list[ref char]
    tv_tags: mut list[i64]
    tv_fields: mut list[ref void]
    break_lbl: mut i64
    cont_lbl: mut i64
    mc_names: mut list[ref char]
    mc_vals: mut list[ref char]
    defer_stack: mut list[ref void]
    local_src_names: mut list[ref char]
    local_qbe_names: mut list[ref char]
    local_slot_names: mut list[ref char]
    local_ref_types: mut list[ref char]
    global_src_names: mut list[ref char]
    global_labels: mut list[ref char]
    global_qtypes: mut list[ref char]
    used_prefixes: mut list[ref char]
}

fn cg_new() ref CgCtx! = {
    val ctx: mut ref CgCtx = @alloc(@sizeof(CgCtx)) as ref CgCtx
    ctx.sb = str.StringBuilder.new()
    ctx.tmp = 0
    ctx.lbl = 0
    ctx.fn_name = 0 as ref char
    ctx.current_fn_ret_union = ""
    ctx.strs = []
    ctx.str_cnt = 0
    ctx.tdefs = []
    ctx.edefs = []
    ctx.dvars = []
    ctx.dqtypes = []
    ctx.snames = []
    ctx.sfields = []
    ctx.lnames = []
    ctx.ltypes = []
    ctx.unames = []
    ctx.uvariants = []
    ctx.fn_names = []
    ctx.fn_params = []
    ctx.fn_rets = []
    ctx.ext_names = []
    ctx.ext_syms = []
    ctx.ext_rets = []
    ctx.tv_names = []
    ctx.tv_owners = []
    ctx.tv_tags = []
    ctx.tv_fields = []
    ctx.break_lbl = -1
    ctx.cont_lbl = -1
    ctx.mc_names = []
    ctx.mc_vals = []
    ctx.defer_stack = []
    ctx.local_src_names = []
    ctx.local_qbe_names = []
    ctx.local_slot_names = []
    ctx.local_ref_types = []
    ctx.global_src_names = []
    ctx.global_labels = []
    ctx.global_qtypes = []
    ctx.used_prefixes = []
    return ctx
}

fn cg_sb(ctx: ref CgCtx)      ref void! = { return ctx.sb as ref void }
fn cg_tmp(ctx: ref CgCtx)     i64!      = { return ctx.tmp as i64}
fn cg_lbl(ctx: ref CgCtx)     i64!      = { return ctx.lbl as i64 }
fn cg_fn_name(ctx: ref CgCtx) ref char! = { return ctx.fn_name as ref char }
fn cg_strs(ctx: ref CgCtx)    ref void! = { return ctx.strs as ref void }
fn cg_str_cnt(ctx: ref CgCtx) i64!      = { return ctx.str_cnt as i64 }
fn cg_tdefs(ctx: ref CgCtx)   ref void! = { return ctx.tdefs as ref void }
fn cg_edefs(ctx: ref CgCtx)   ref void! = { return ctx.edefs as ref void }

fn cg_set_tmp(ctx: ref CgCtx, v: i64) void! = {
    ctx.tmp = v
}
fn cg_set_lbl(ctx: ref CgCtx, v: i64) void! = {
    ctx.lbl = v
}
fn cg_set_fn_name(ctx: ref CgCtx, v: ref char) void! = {
    ctx.fn_name = v
}
fn cg_set_str_cnt(ctx: ref CgCtx, v: i64) void! = {
    ctx.str_cnt = v
}

fn cg_dvars(ctx: ref CgCtx) ref void! = { return ctx.dvars as ref void }
fn cg_snames(ctx: ref CgCtx) ref void! = { return ctx.snames as ref void }
fn cg_global_src_names(ctx: ref CgCtx) ref void! = { return ctx.global_src_names as ref void }
fn cg_global_labels(ctx: ref CgCtx)    ref void! = { return ctx.global_labels as ref void }
fn cg_global_qtypes(ctx: ref CgCtx)    ref void! = { return ctx.global_qtypes as ref void }

fn cg_mark_prefix_used(ctx: ref CgCtx, prefix: ref char) void! = {
    val nlen: i64 = @len(ctx.used_prefixes as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.used_prefixes as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, prefix) == 0 {
                    return
                }
            }
            none => {}
        }
        ni++
    }
    @append(ctx.used_prefixes as list[ref char], prefix)
}

fn cg_is_prefix_used(ctx: ref CgCtx, prefix: ref char) bool! = {
    val nlen: i64 = @len(ctx.used_prefixes as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.used_prefixes as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, prefix) == 0 {
                    return true
                }
            }
            none => {}
        }
        ni++
    }
    return false
}

/// Extract the module prefix from a mangled function name.
/// E.g. "std__stdio__puts" with bare name "puts" -> "std__stdio"
fn extract_prefix_from_mangled(mangled: ref char, bare_name: ref char) ref char! = {
    val mlen: i64 = str.len_raw(mangled)
    val blen: i64 = str.len_raw(bare_name)
    if mlen <= blen + 2 {
        return ""
    }
    val prefix_len: mut i64 = mlen - blen - 2
    val prefix: ref char = @alloc(prefix_len + 1) as ref char
    @memcpy(prefix as ref void, mangled as ref void, prefix_len as usize)
    @store8(@ptradd(prefix as ref void, prefix_len), 0)
    return prefix
}

fn cg_register_global(ctx: ref CgCtx, src_name: ref char, label: ref char, qtype: ref char) void! = {
    @append(cg_global_src_names(ctx) as list[ref char], src_name)
    @append(cg_global_labels(ctx)    as list[ref char], label)
    @append(cg_global_qtypes(ctx)    as list[ref char], qtype)
}

/// Look up a global by source name. Returns ("", "") if not found.
fn cg_lookup_global(ctx: ref CgCtx, src_name: ref char, out_label: ref char, out_qtype: ref char) bool! = {
    val names: ref void = cg_global_src_names(ctx)
    val len: i64 = @len(names) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val n_opt = @get(names, i as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, src_name) == 0 {
                    val lbl_opt = @get(cg_global_labels(ctx) as list[ref char], i as usize)
                    val qty_opt = @get(cg_global_qtypes(ctx) as list[ref char], i as usize)
                    match lbl_opt {
                        some lbl => {
                            @memcpy(out_label, lbl as ref char, str.len_raw(lbl as ref char) + 1)
                        }
                        none => {}
                    }
                    match qty_opt {
                        some qty => {
                            @memcpy(out_qtype, qty as ref char, str.len_raw(qty as ref char) + 1)
                        }
                        none => {}
                    }
                    return true
                }
            }
            none => {}
        }
        i++
    }
    return false
}

fn cg_sfields(ctx: ref CgCtx) list[ref void]! = { return ctx.sfields }
fn cg_unames(ctx: ref CgCtx) ref void! = { return ctx.unames as ref void }
fn cg_uvariants(ctx: ref CgCtx) ref void! = { return ctx.uvariants as ref void }
fn cg_fn_names(ctx: ref CgCtx) ref void! = { return ctx.fn_names as ref void }
fn cg_fn_params(ctx: ref CgCtx) ref void! = { return ctx.fn_params as ref void }
fn cg_fn_rets(ctx: ref CgCtx) ref void! = { return ctx.fn_rets as ref void }
fn cg_extern_names(ctx: ref CgCtx) ref void! = { return ctx.ext_names as ref void }
fn cg_extern_syms(ctx: ref CgCtx) ref void! = { return ctx.ext_syms as ref void }
fn cg_ext_rets(ctx: ref CgCtx) ref void! = { return ctx.ext_rets as ref void }
fn cg_tv_names(ctx: ref CgCtx) ref void! = { return ctx.tv_names as ref void }
fn cg_tv_owners(ctx: ref CgCtx) ref void! = { return ctx.tv_owners as ref void }
fn cg_tv_tags(ctx: ref CgCtx) ref void! = { return ctx.tv_tags as ref void }
fn cg_tv_fields(ctx: ref CgCtx) ref void! = { return ctx.tv_fields as ref void }
fn cg_break_lbl(ctx: ref CgCtx) i64! = { return ctx.break_lbl }
fn cg_cont_lbl(ctx: ref CgCtx) i64! = { return ctx.cont_lbl }
fn cg_set_break_lbl(ctx: ref CgCtx, v: i64) void! = { ctx.break_lbl = v }
fn cg_set_cont_lbl(ctx: ref CgCtx, v: i64) void! = { ctx.cont_lbl = v }
fn cg_defer_stack(ctx: ref CgCtx) ref void! = { return ctx.defer_stack as ref void }

fn cg_defer_push(ctx: ref CgCtx, body: ref parser.Node) void! = {
    val stack: ref void = cg_defer_stack(ctx)
    @append(stack as list[ref void], body as ref void)
}

fn cg_defer_clear(ctx: ref CgCtx) void! = {
    ctx.defer_stack = []
}

/// Emit all deferred statements in LIFO order.
fn cg_emit_defers(ctx: ref CgCtx) void! = {
    val stack: ref void = cg_defer_stack(ctx)
    val n: i64 = @len(stack as list[ref void]) as i64
    val i: mut i64 = n - 1
    for {
        if i < 0 { break }
        val d_opt = @get(stack as list[ref void], i as usize)
        match d_opt {
            some d => { gen_stmts(ctx, d as ref parser.Node) }
            none   => {}
        }
        i--
    }
}

fn cg_mc_names(ctx: ref CgCtx) ref void! = { return ctx.mc_names as ref void }
fn cg_mc_vals(ctx: ref CgCtx) ref void! = { return ctx.mc_vals as ref void }

fn cg_register_module_const(ctx: ref CgCtx, name: ref char, val_str: ref char) void! = {
    @append(cg_mc_names(ctx) as list[ref char], name)
    @append(cg_mc_vals(ctx)  as list[ref char], val_str)
}

/// Inject all module-level constants as direct vars so they resolve inline.
fn cg_inject_module_consts(ctx: ref CgCtx) void! = {
    val names: ref void = cg_mc_names(ctx)
    val vals:  ref void = cg_mc_vals(ctx)
    val nlen: i64 = @len(names as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref char], ni as usize)
        val v_opt = @get(vals  as list[ref char], ni as usize)
        match n_opt {
            some n => {
                match v_opt {
                    some v => { cg_dvars_add(ctx, n as ref char, v as ref char) }
                    none => {}
                }
            }
            none => {}
        }
        ni++
    }
}

/// Look up a module-level constant value by name. Returns "" if not found.
fn cg_const_val(ctx: ref CgCtx, name: ref char) ref char! = {
    val names: ref void = cg_mc_names(ctx)
    val nlen: i64 = @len(names as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val v_opt = @get(cg_mc_vals(ctx) as list[ref char], ni as usize)
                    match v_opt {
                        some v => { return v as ref char }
                        none   => { return "" }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return ""
}

/// Returns true if name is a registered function.
fn cg_is_fn(ctx: ref CgCtx, name: ref char) bool! = {
    val names: ref void = cg_fn_names(ctx)
    val nlen: i64 = @len(names as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 { return true }
            }
            none => {}
        }
        ni++
    }
    return false
}

/// Returns the mangled function name for a bare name, or 0 if not found.
///
/// Tries exact match first, then suffix match (e.g. "hash_string" -> "collections__hash_string").
fn cg_resolve_fn_name(ctx: ref CgCtx, name: ref char) ref char! = {
    val names: ref void = cg_fn_names(ctx)
    val nlen: i64 = @len(names as list[ref char]) as i64
    val namelen: i64 = str.len_raw(name)
    val suffix: ref char = @alloc(namelen + 3) as ref char
    @snprintf(suffix, namelen + 3, "__%s", {name})
    val ni: mut i64 = 0
    val found: mut ref char = 0 as ref char
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                val candidate: ref char = n as ref char
                if str.rchar_cmp(candidate, name) == 0 {
                    @free(suffix)
                    cg_mark_prefix_used(ctx, "")
                    return candidate
                }
                val clen: i64 = str.len_raw(candidate)
                val slen: i64 = namelen + 2
                if clen > slen {
                    val tail: ref char = @ptradd(candidate, clen - slen) as ref char
                    if str.rchar_cmp(tail, suffix) == 0 {
                        found = candidate
                    }
                }
            }
            none => {}
        }
        ni++
    }
    @free(suffix)
    if found != 0 as ref char {
        val prefix: ref char = extract_prefix_from_mangled(found, name)
        
        val plen: i64 = str.len_raw(prefix)
        val pi: mut i64 = 0
        for {
            if pi >= plen { break }
            val c1: u8 = @load8(@ptradd(prefix as ref void, pi))
            if pi + 1 < plen {
                val c2: u8 = @load8(@ptradd(prefix as ref void, pi + 1))
                if c1 == 95 && c2 == 95 {
                    val sub_prefix: ref char = @alloc(pi + 1) as ref char
                    @memcpy(sub_prefix as ref void, prefix as ref void, pi as usize)
                    @store8(@ptradd(sub_prefix as ref void, pi), 0)
                    cg_mark_prefix_used(ctx, sub_prefix)
                    pi++
                }
            }
            pi++
        }
        
        cg_mark_prefix_used(ctx, prefix)
    }
    return found
}

/// Register a function's mangled name and its param list for call-site type checking.
fn cg_register_fn(ctx: ref CgCtx, mangled: ref char, params: ref void, ret_ty: ref void) void! = {
    @append(cg_fn_names(ctx) as list[ref char], mangled)
    @append(cg_fn_params(ctx) as list[ref void], params)
    @append(cg_fn_rets(ctx) as list[ref void], ret_ty)
}

/// Look up param list for a mangled function name. Returns 0 if not found.
fn cg_lookup_fn_params(ctx: ref CgCtx, mangled: ref char) ref void! = {
    val names: ref void = cg_fn_names(ctx)
    val nlen: i64 = @len(names as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, mangled) == 0 {
                    val p_opt = @get(cg_fn_params(ctx) as list[ref void], ni as usize)
                    match p_opt {
                        some p => { return p as ref void }
                        none   => { return 0 as ref void }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref void
}

/// Look up the return type for a mangled function name. Returns 0 if not found.
fn cg_lookup_fn_ret(ctx: ref CgCtx, mangled: ref char) ref void! = {
    val names: ref void = cg_fn_names(ctx)
    val nlen: i64 = @len(names as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, mangled) == 0 {
                    val r_opt = @get(cg_fn_rets(ctx) as list[ref void], ni as usize)
                    match r_opt {
                        some r => { return r as ref void }
                        none   => { return 0 as ref void }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref void
}

/// Register an extern function: maps its declared name to its C symbol and stores return type.
fn cg_register_extern(ctx: ref CgCtx, name: ref char, symbol: ref char, ret_ty: ref void) void! = {
    @append(cg_extern_names(ctx) as list[ref char], name)
    @append(cg_extern_syms(ctx)  as list[ref char], symbol)
    @append(cg_ext_rets(ctx)     as list[ref void], ret_ty)
}

/// Look up the C symbol for an extern function name. Returns 0 if not found.
fn cg_lookup_extern_symbol(ctx: ref CgCtx, name: ref char) ref char! = {
    val names: ref void = cg_extern_names(ctx)
    val nlen: i64 = @len(names as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val s_opt = @get(cg_extern_syms(ctx) as list[ref char], ni as usize)
                    match s_opt {
                        some s => { return s as ref char }
                        none   => { return 0 as ref char }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref char
}

/// Look up the return type for an extern function name. Returns 0 if not found.
fn cg_lookup_ext_ret(ctx: ref CgCtx, name: ref char) ref void! = {
    val names: ref void = cg_extern_names(ctx)
    val nlen: i64 = @len(names as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val r_opt = @get(cg_ext_rets(ctx) as list[ref void], ni as usize)
                    match r_opt {
                        some r => { return r as ref void }
                        none   => { return 0 as ref void }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref void
}

/// Register a tagged union variant: variant_name -> (union_name, tag_index, field_type_node).
fn cg_register_tv(ctx: ref CgCtx, vname: ref char, owner: ref char, tag: i64, field_ty: ref void) void! = {
    @append(cg_tv_names(ctx)  as list[ref char], vname)
    @append(cg_tv_owners(ctx) as list[ref char], owner)
    @append(cg_tv_tags(ctx)   as list[i64],      tag)
    @append(cg_tv_fields(ctx) as list[ref void],  field_ty)
}

/// Look up a tagged union variant by name.
/// Returns the tag index, or -1 if not found.
/// Sets out_owner and out_field_ty if found (pass as ref void pointers to ref char / ref void).
fn cg_lookup_tv(ctx: ref CgCtx, vname: ref char, out_owner: ref void, out_field_ty: ref void) i64! = {
    val names: ref void = cg_tv_names(ctx)
    val nlen: i64 = @len(names as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, vname) == 0 {
                    val tag_opt = @get(cg_tv_tags(ctx) as list[i64], ni as usize)
                    val owner_opt = @get(cg_tv_owners(ctx) as list[ref char], ni as usize)
                    val field_opt = @get(cg_tv_fields(ctx) as list[ref void], ni as usize)
                    match tag_opt {
                        some tag => {
                            match owner_opt {
                                some owner => {
                                    @store(out_owner, owner as usize)
                                }
                                none => {}
                            }
                            match field_opt {
                                some field => {
                                    @store(out_field_ty, field as usize)
                                }
                                none => {}
                            }
                            return tag as i64
                        }
                        none => {}
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return -1
}

/// Register a struct type's field list by name.
fn cg_register_struct(ctx: ref CgCtx, type_name: ref char, fields: ref void) void! = {
    @append(cg_snames(ctx) as list[ref char], type_name)
    @append(cg_sfields(ctx) as list[ref void], fields)
}

/// Look up the field list for a struct type name. Returns 0 if not found.
fn cg_lookup_struct(ctx: ref CgCtx, type_name: ref char) ref void! = {
    val names: ref void = cg_snames(ctx)
    val nlen: i64 = @len(names as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, type_name) == 0 {
                    val f_opt = @get(cg_sfields(ctx) as list[ref void], ni as usize)
                    match f_opt {
                        some f => { return f as ref void }
                        none   => { return 0 as ref void }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref void
}

/// Register a union type's variant type-name list.
fn cg_register_union(ctx: ref CgCtx, union_name: ref char, variants: ref void) void! = {
    @append(cg_unames(ctx) as list[ref char], union_name)
    @append(cg_uvariants(ctx) as list[ref void], variants)
}

/// Look up the variant list for a union type. Returns 0 if not found.
fn cg_lookup_union(ctx: ref CgCtx, union_name: ref char) ref void! = {
    val names: ref void = cg_unames(ctx)
    val nlen: i64 = @len(names as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, union_name) == 0 {
                    val v_opt = @get(cg_uvariants(ctx) as list[ref void], ni as usize)
                    match v_opt {
                        some v => { return v as ref void }
                        none   => { return 0 as ref void }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return 0 as ref void
}

/// Compute the total byte size of a struct with the given fields.
fn struct_size(fields: ref void) i64! = {
    val flen: i64 = @len(fields as list[ref void]) as i64
    val has_fa: bool = fields_have_fixed_arr(fields)
    val offset: mut i64 = 0
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fty: ref parser.Node = fnode.d2 as ref parser.Node
                if has_fa {
                    val align: i64 = type_align(fty)
                    offset = align_to(offset, align)
                }
                val fsize: i64 = type_size(fty)
                if has_fa {
                    offset = offset + fsize
                } else {
                    val aligned_size: i64 = align_to(fsize, 8)
                    offset = offset + aligned_size
                }
            }
            none => {}
        }
        fi++
    }
    return offset
}

fn field_offset(fields: ref void, field_name: ref char) i64! = {
    val flen: i64 = @len(fields as list[ref void]) as i64
    val has_fa: bool = fields_have_fixed_arr(fields)
    val offset: mut i64 = 0
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fname: ref char = fnode.d0 as ref char
                val fty: ref parser.Node = fnode.d2 as ref parser.Node
                if has_fa {
                    val align: i64 = type_align(fty)
                    offset = align_to(offset, align)
                }
                if str.rchar_cmp(fname, field_name) == 0 { return offset }
                val fsize: i64 = type_size(fty)
                if has_fa {
                    offset = offset + fsize
                } else {
                    val aligned_size: i64 = align_to(fsize, 8)
                    offset = offset + aligned_size
                }
            }
            none => {}
        }
        fi++
    }
    return -1
}

fn cg_dvars_clear(ctx: ref CgCtx) void! = {
    ctx.dvars = []
    ctx.dqtypes = []
    ctx.lnames = []
    ctx.ltypes = []
    ctx.local_src_names = []
    ctx.local_qbe_names = []
    ctx.local_slot_names = []
    cg_defer_clear(ctx)
    cg_set_tmp(ctx, 0)
}

fn cg_register_local_type(ctx: ref CgCtx, name: ref char, type_name: ref char) void! = {
    @append(ctx.lnames as list[ref char], name)
    @append(ctx.ltypes as list[ref char], type_name)
}

/// Register a local variable as having a reference/pointer type
fn cg_register_local_ref_type(ctx: ref CgCtx, name: ref char) void! = {
    @append(ctx.local_ref_types as list[ref char], name)
}

/// Check if a local variable has a reference/pointer type
fn cg_is_local_ref_type(ctx: ref CgCtx, name: ref char) bool! = {
    val nlen: i64 = @len(ctx.local_ref_types as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.local_ref_types as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 { return true }
            }
            none => {}
        }
        ni++
    }
    return false
}

fn cg_local_type(ctx: ref CgCtx, name: ref char) ref char! = {
    val nlen: i64 = @len(ctx.lnames as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.lnames as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, name) == 0 {
                    val t_opt = @get(ctx.ltypes as list[ref char], ni as usize)
                    match t_opt {
                        some t => { return t as ref char }
                        none   => { return "" }
                    }
                }
            }
            none => {}
        }
        ni++
    }
    return ""
}

/// Register the type of a local variable (used for match bindings)
fn cg_register_local_var_type(ctx: ref CgCtx, src_name: ref char, type_name: ref char) void! = {
    @append(ctx.lnames as list[ref char], src_name)
    @append(ctx.ltypes as list[ref char], type_name)
}

/// Mark a local variable as having a reference/pointer type (for field access)
fn cg_mark_local_ref_type(ctx: ref CgCtx, src_name: ref char) void! = {
    @append(ctx.local_ref_types as list[ref char], src_name)
}

/// Generate a struct literal inline within a parent allocation (e.g., union payload).
/// base_offset is the starting offset within the parent allocation.
fn gen_struct_lit_inline(ctx: ref CgCtx, struct_node: ref parser.Node, parent_ptr: i64, base_offset: i64, fields: ref void) void! = {
    val sfields_node: ref void = fields
    val lit_fields: ref void = struct_node.d0 as ref void

    if lit_fields == 0 as ref void { return }
    
    val lit_flen: i64 = @len(lit_fields as list[ref void]) as i64
    val li: mut i64 = 0
    for {
        if li >= lit_flen { break }
        val lf_opt = @get(lit_fields as list[ref void], li as usize)
        match lf_opt {
            some lf => {
                val lf_node: ref parser.Node = lf as ref parser.Node
                val lf_name: ref char = lf_node.d0 as ref char
                val lf_expr: ref parser.Node = lf_node.d1 as ref parser.Node              
                val off: i64 = field_offset(sfields_node, lf_name)
                if off >= 0 {
                    val actual_off: i64 = base_offset + off
                    val fptr: i64 = fresh_tmp(ctx)
                    val fbuf: ref char = @alloc(128) as ref char
                    val fval: ref char = gen_expr(ctx, lf_expr)
                    @snprintf(fbuf, 128, "    %%t%lld =l add %%t%lld, %lld\n    storel %s, %%t%lld\n",
                        {fptr, parent_ptr, actual_off, fval, fptr})
                    emit(ctx, fbuf)
                    @free(fbuf)
                }
            }
            none => {}
        }
        li++
    }
}

fn cg_dvars_add(ctx: ref CgCtx, name: ref char, qtype: ref char) void! = {
    @append(cg_dvars(ctx) as list[ref char], name)
    @append(ctx.dqtypes as list[ref char], qtype)
}

/// Register a local variable: map source name to QBE temporary name
fn cg_register_local_var(ctx: ref CgCtx, src_name: ref char, qbe_name: ref char) void! = {
    @append(ctx.local_src_names as list[ref char], src_name)
    @append(ctx.local_qbe_names as list[ref char], qbe_name)
}

/// Mark a variable as a slot (mutable, needs load/store)
fn cg_mark_as_slot(ctx: ref CgCtx, src_name: ref char) void! = {
    @append(ctx.local_slot_names as list[ref char], src_name)
}

/// Check if a variable is a slot (mutable)
fn cg_is_slot(ctx: ref CgCtx, src_name: ref char) bool! = {
    val nlen: i64 = @len(ctx.local_slot_names as list[ref char]) as i64
    val ni: mut i64 = 0
    for {
        if ni >= nlen { break }
        val n_opt = @get(ctx.local_slot_names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, src_name) == 0 {
                    return true
                }
            }
            none => {}
        }
        ni++
    }
    return false
}

/// Look up the QBE temporary name for a source variable name. Returns "" if not found.
fn cg_lookup_local_var(ctx: ref CgCtx, src_name: ref char) ref char! = {
    val nlen: i64 = @len(ctx.local_src_names as list[ref char]) as i64
    val ni: mut i64 = nlen - 1
    // Search backwards to find most recent declaration (handles shadowing)
    for {
        if ni < 0 { break }
        val n_opt = @get(ctx.local_src_names as list[ref char], ni as usize)
        match n_opt {
            some n => {
                if str.rchar_cmp(n as ref char, src_name) == 0 {
                    val q_opt = @get(ctx.local_qbe_names as list[ref char], ni as usize)
                    match q_opt {
                        some q => { return q as ref char }
                        none   => { return "" }
                    }
                }
            }
            none => {}
        }
        ni--
    }
    return ""
}

/// Returns an empty ref char, i.e. "" if not direct, else the qbe type ("w" or "l")
fn cg_direct_type(ctx: ref CgCtx, name: ref char) ref char! = {
    val dv: ref void = cg_dvars(ctx)
    val dlen: i64 = @len(dv as list[ref char]) as i64
    val di: mut i64 = 0
    for {
        if di >= dlen { break }
        val d_opt = @get(dv as list[ref char], di as usize)
        match d_opt {
            some d => {
                if str.rchar_cmp(d as ref char, name) == 0 {
                    val q_opt = @get(ctx.dqtypes as list[ref char], di as usize)
                    match q_opt {
                        some q => { return q as ref char }
                        none   => { return "l" }
                    }
                }
            }
            none => {}
        }
        di++
    }
    return ""
}

fn fresh_tmp(ctx: ref CgCtx) i64! = {
    val n: i64 = cg_tmp(ctx)
    cg_set_tmp(ctx, n + 1)
    return n
}

fn fresh_lbl(ctx: ref CgCtx) i64! = {
    val n: i64 = cg_lbl(ctx)
    cg_set_lbl(ctx, n + 1)
    return n
}

fn emit(ctx: ref CgCtx, s: ref char) void! = {
    str.StringBuilder.append_cstr(cg_sb(ctx), s)
}

fn emitln(ctx: ref CgCtx, s: ref char) void! = {
    str.StringBuilder.append_cstr(cg_sb(ctx), s)
    str.StringBuilder.append_char(cg_sb(ctx), 10)
}

fn emit_fmt(ctx: ref CgCtx, fmt: ref char, args: untyped) void! = {
    val buf: ref char = @alloc(1024) as ref char
    @snprintf(buf, 1024, fmt, args)
    emit(ctx, buf)
    @free(buf)
}

/// Returns true if the type name maps to QBE word type (w).
fn is_word_type_name(name: ref char) bool! = {
    if str.rchar_cmp(name, "u8")   == 0 { return true }
    if str.rchar_cmp(name, "i8")   == 0 { return true }
    if str.rchar_cmp(name, "u16")  == 0 { return true }
    if str.rchar_cmp(name, "i16")  == 0 { return true }
    if str.rchar_cmp(name, "u32")  == 0 { return true }
    if str.rchar_cmp(name, "i32")  == 0 { return true }
    if str.rchar_cmp(name, "bool") == 0 { return true }
    if str.rchar_cmp(name, "char") == 0 { return true }
    return false
}

fn is_float_type_name(name: ref char) bool! = {
    if str.rchar_cmp(name, "f32") == 0 { return true }
    if str.rchar_cmp(name, "f64") == 0 { return true }
    return false
}

fn qbe_type_of(ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return "l" }
    val k: i64 = ty.kind
    if k == parser.TY_VOID    { return "w" }
    if k == parser.TY_MUT     { return qbe_type_of(ty.d0 as ref parser.Node) }
    if k == parser.TY_REF     { return "l" }
    if k == parser.TY_OPTION  { return "l" }
    if k == parser.TY_LIST    { return "l" }
    if k == parser.TY_RESULT  { return "l" }
    if k == parser.TY_SLICE   { return "l" }
    if k == parser.TY_FNPTR   { return "l" }
    if k == parser.TY_FIXED_ARR { return "a" }
    if k == parser.TY_NAMED {
        val name: ref char = ty.d0 as ref char
        if str.rchar_cmp(name, "i32") == 0 || str.rchar_cmp(name, "u32") == 0 { return "w" }
        if str.rchar_cmp(name, "i8")  == 0 || str.rchar_cmp(name, "u8")  == 0 { return "w" }
        if str.rchar_cmp(name, "i16") == 0 || str.rchar_cmp(name, "u16") == 0 { return "w" }
        if str.rchar_cmp(name, "bool") == 0 { return "w" }
        if str.rchar_cmp(name, "f32") == 0 { return "s" }
        if str.rchar_cmp(name, "f64") == 0 { return "d" }
        if str.rchar_cmp(name, "char") == 0 { return "w" }
        return "l"
    }
    return "l"
}

/// Returns true if the type is a reference/pointer type (TY_REF or TY_MUT with ref inside).
fn is_ref_type(ty: ref parser.Node) bool! = {
    if ty == 0 as ref parser.Node { return false }
    val k: i64 = ty.kind
    if k == parser.TY_REF { return true }
    if k == parser.TY_MUT { return is_ref_type(ty.d0 as ref parser.Node) }
    return false
}

/// Unwrap a type node to get the base named type, stripping ref/mut wrappers.
/// Returns "" if not a named type.
fn unwrap_type_name(ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return "" }
    val k: i64 = ty.kind
    if k == parser.TY_REF { return unwrap_type_name(ty.d0 as ref parser.Node) }
    if k == parser.TY_MUT { return unwrap_type_name(ty.d0 as ref parser.Node) }
    if k == parser.TY_NAMED { return ty.d0 as ref char }
    return ""
}

/// Check if a type is a tagged union. Returns the union name if it is, "" otherwise.
fn is_union_type(ctx: ref CgCtx, ty: ref parser.Node) ref char! = {
    if ty == 0 as ref parser.Node { return "" }
    val k: i64 = ty.kind
    if k == parser.TY_NAMED {
        val name: ref char = ty.d0 as ref char
        val union_vars: ref void = cg_lookup_union(ctx, name)
        if union_vars != 0 as ref void {
            return name
        }
    }
    return ""
}

fn type_size(ty: ref parser.Node) i64! = {
    if ty == 0 as ref parser.Node { return 8 }
    val k: i64 = ty.kind
    if k == parser.TY_VOID    { return 0 }
    if k == parser.TY_MUT     { return type_size(ty.d0 as ref parser.Node) }
    if k == parser.TY_NAMED {
        val tname: ref char = ty.d0 as ref char
        if str.rchar_cmp(tname, "i8")   == 0 { return 1 }
        if str.rchar_cmp(tname, "u8")   == 0 { return 1 }
        if str.rchar_cmp(tname, "char") == 0 { return 1 }
        if str.rchar_cmp(tname, "i16")  == 0 { return 2 }
        if str.rchar_cmp(tname, "u16")  == 0 { return 2 }
        if str.rchar_cmp(tname, "i32")  == 0 { return 4 }
        if str.rchar_cmp(tname, "u32")  == 0 { return 4 }
        if str.rchar_cmp(tname, "f32")  == 0 { return 4 }
        return 8
    }
    if k == parser.TY_FIXED_ARR {
        val count: i64 = ty.d0
        val elem_size: i64 = type_size(ty.d1 as ref parser.Node)
        return count * elem_size
    }
    if k == parser.TY_LIST { return 24 }
    return 8
}

fn type_align(ty: ref parser.Node) i64! = {
    if ty == 0 as ref parser.Node { return 8 }
    val k: i64 = ty.kind
    if k == parser.TY_MUT { return type_align(ty.d0 as ref parser.Node) }
    if k == parser.TY_NAMED {
        val tname: ref char = ty.d0 as ref char
        if str.rchar_cmp(tname, "i8")   == 0 { return 1 }
        if str.rchar_cmp(tname, "u8")   == 0 { return 1 }
        if str.rchar_cmp(tname, "char") == 0 { return 1 }
        if str.rchar_cmp(tname, "i16")  == 0 { return 2 }
        if str.rchar_cmp(tname, "u16")  == 0 { return 2 }
        if str.rchar_cmp(tname, "i32")  == 0 { return 4 }
        if str.rchar_cmp(tname, "u32")  == 0 { return 4 }
        if str.rchar_cmp(tname, "f32")  == 0 { return 4 }
        return 8
    }
    if k == parser.TY_FIXED_ARR { return type_align(ty.d1 as ref parser.Node) }
    return 8
}

fn align_to(n: i64, align: i64) i64! = {
    if align <= 1 { return n }
    return (n + align - 1) / align * align
}

fn fields_have_fixed_arr(fields: ref void) bool! = {
    val flen: i64 = @len(fields as list[ref void]) as i64
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields as list[ref void], fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fty: ref parser.Node = fnode.d2 as ref parser.Node
                if fty != 0 as ref parser.Node {
                    if fty.kind == parser.TY_FIXED_ARR { return true }
                }
            }
            none => {}
        }
        fi++
    }
    return false
}

/// Rewrite format string: {d} -> %d, {s} -> %s, etc.
/// Handles \{ and \} as escape sequences for literal { and }
fn rewrite_fmt(s: ref char) ref char! = {
    val slen: i64 = str.len_raw(s)
    val out: ref char = @alloc(slen * 2 + 1) as ref char
    val oi: mut i64 = 0
    val i: mut i64 = 0
    for {
        if i >= slen { break }
        val c: mut u8 = @load8(@ptradd(s as ref void, i))
        
        if c == 92 { // '\\'
            if i + 1 < slen {
                val next: mut u8 = @load8(@ptradd(s as ref void, i + 1))
                if next == 123 || next == 125 { // '{' or '}'
                    @store8(@ptradd(out as ref void, oi), next)
                    oi++
                    i += 2
                } else {
                    @store8(@ptradd(out as ref void, oi), c)
                    oi++
                    i++
                }
            } else {
                @store8(@ptradd(out as ref void, oi), c)
                oi++
                i++
            }
        } elif c == 123 { // '{'
            val j: mut i64 = i + 1
            val found: mut bool = false
            for {
                if j >= slen { break }
                val ic: u8 = @load8(@ptradd(s as ref void, j))
                if ic == 125 { found = true break } // '}'
                j++
            }
            if found {
                @store8(@ptradd(out as ref void, oi), 37) // '%'
                oi++
                val k: mut i64 = i + 1
                for {
                    if k >= j { break }
                    val sc: mut u8 = @load8(@ptradd(s as ref void, k))
                    @store8(@ptradd(out as ref void, oi), sc)
                    oi++
                    k++
                }
                i = j + 1
            } else {
                @store8(@ptradd(out as ref void, oi), c)
                oi++
                i++
            }
        } else {
            @store8(@ptradd(out as ref void, oi), c)
            oi++
            i++
        }
    }
    @store8(@ptradd(out as ref void, oi), 0)
    return out
}

/// Intern a string literal without format rewriting, return its global label index.
fn intern_string(ctx: ref CgCtx, s: ref char) i64! = {
    val strs: ref void = cg_strs(ctx)
    val len: i64 = @len(strs) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(strs, i as usize)
        match s_opt {
            some existing => {
                if str.rchar_cmp(existing as ref char, s) == 0 { return i }
            }
            none => {}
        }
        i++
    }
    @append(strs, s)
    val idx: i64 = cg_str_cnt(ctx)
    cg_set_str_cnt(ctx, idx + 1)
    return idx
}

/// Intern a format string with rewriting ({d} → %d), return its global label index.
fn intern_format_string(ctx: ref CgCtx, s: ref char) i64! = {
    val rewritten: ref char = rewrite_fmt(s)
    val strs: ref void = cg_strs(ctx)
    val len: i64 = @len(strs) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(strs, i as usize)
        match s_opt {
            some existing => {
                if str.rchar_cmp(existing as ref char, rewritten) == 0 { return i }
            }
            none => {}
        }
        i++
    }
    @append(strs, rewritten)
    val idx: i64 = cg_str_cnt(ctx)
    cg_set_str_cnt(ctx, idx + 1)
    return idx
}

/// Emit all interned string data sections.
fn emit_string_data(ctx: ref CgCtx) void! = {
    val strs: ref void = cg_strs(ctx)
    val len: i64 = @len(strs) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(strs, i as usize)
        match s_opt {
            some s => {
                emit_fmt(ctx, "data $__str%lld = { b \"", {i})
                // emit each byte, escaping special chars
                val sptr: ref char = s as ref char
                val j: mut i64 = 0
                for {
                    val c: mut u8 = @load8(@ptradd(sptr, j))
                    if c == 0 { break }
                    if c == 10 {
                        emit(ctx, "\\n")
                    } elif c == 9 {
                        emit(ctx, "\\t")
                    } elif c == 34 {
                        emit(ctx, "\\\"")
                    } elif c == 92 {
                        emit(ctx, "\\\\")
                    } else {
                        val cb: ref char = @alloc(2) as ref char
                        @store8(cb, c)
                        @store8(@ptradd(cb, 1), 0)
                        emit(ctx, cb)
                        @free(cb)
                    }
                    j++
                }
                emitln(ctx, "\", b 0 }")
            }
            none => {}
        }
        i++
    }
}

/// Generate an integer literal with a specific QBE type (w or l).
fn gen_int_lit_as(ctx: ref CgCtx, text: ref char, qbe_type: ref char) ref char! = {
    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(64) as ref char
    val emit_text: mut ref char = text

    if @load8(text as ref void) == 48 && @load8(@ptradd(text as ref void, 1)) == 120 {
        val hex_start: ref char = @ptradd(text as ref void, 2) as ref char
        val val_: mut i64 = 0
        val hi: mut i64 = 0
        for {
            val hc: i64 = @load8(@ptradd(hex_start as ref void, hi)) as i64
            if hc == 0 { break }
            val digit: mut i64 = hc - 48
            if hc >= 97 { digit = hc - 87 }
            elif hc >= 65 { digit = hc - 55 }
            val_ = val_ * 16 + digit
            hi++
        }
        val dec_buf: ref char = @alloc(32) as ref char
        @snprintf(dec_buf, 32, "%lld", {val_})
        emit_text = dec_buf
    }
    @snprintf(buf, 64, "    %%t%lld =%s copy %s\n", {tmp, qbe_type, emit_text})
    emit(ctx, buf)
    @free(buf)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t%lld", {tmp})
    return res
}

/// Generate an expression, with integer literals using the specified QBE type.
fn gen_expr_with_type(ctx: ref CgCtx, expr: ref parser.Node, target_type: ref char) ref char! = {
    if expr == 0 as ref parser.Node { return "0" }
    val k: i64 = expr.kind
    if k == parser.NK_INT_LIT {
        val text: ref char = expr.d0 as ref char
        return gen_int_lit_as(ctx, text, target_type)
    }
    return gen_expr(ctx, expr)
}

fn gen_expr(ctx: ref CgCtx, expr: ref parser.Node) ref char! = {
    if expr == 0 as ref parser.Node { return "0" }

    val k: i64 = expr.kind

    if k == parser.NK_INT_LIT {
        val text: ref char = expr.d0 as ref char
        val tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(64) as ref char
        val emit_text: mut ref char = text

        if @load8(text as ref void) == 48 && @load8(@ptradd(text as ref void, 1)) == 120 {
            val hex_start: ref char = @ptradd(text as ref void, 2) as ref char
            val val_: mut i64 = 0
            val hi: mut i64 = 0
            for {
                val hc: i64 = @load8(@ptradd(hex_start as ref void, hi)) as i64
                if hc == 0 { break }
                val digit: mut i64 = hc - 48
                if hc >= 97 { digit = hc - 87 }
                elif hc >= 65 { digit = hc - 55 }
                val_ = val_ * 16 + digit
                hi++
            }
            val dec_buf: ref char = @alloc(32) as ref char
            @snprintf(dec_buf, 32, "%lld", {val_})
            emit_text = dec_buf
        }
        @snprintf(buf, 64, "    %%t%lld =l copy %s\n", {tmp, emit_text})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t%lld", {tmp})
        return res
    }

    if k == parser.NK_FLOAT_LIT {
        val text2: ref char = expr.d0 as ref char
        val tmp2: i64 = fresh_tmp(ctx)
        val buf2: ref char = @alloc(64) as ref char
        @snprintf(buf2, 64, "    %%t%lld =d copy d_%s\n", {tmp2, text2})
        emit(ctx, buf2)
        @free(buf2)
        val res2: ref char = @alloc(16) as ref char
        @snprintf(res2, 16, "%%t%lld", {tmp2})
        return res2
    }

    if k == parser.NK_STR_LIT {
        val s: ref char = expr.d0 as ref char
        val idx: i64 = intern_string(ctx, s)
        val tmp3: i64 = fresh_tmp(ctx)
        val buf3: ref char = @alloc(64) as ref char
        @snprintf(buf3, 64, "    %%t%lld =l copy $__str%lld\n", {tmp3, idx})
        emit(ctx, buf3)
        @free(buf3)
        val res3: ref char = @alloc(16) as ref char
        @snprintf(res3, 16, "%%t%lld", {tmp3})
        return res3
    }

    if k == parser.NK_BOOL {
        val v: i64 = expr.d0 as i64
        val tmp4: i64 = fresh_tmp(ctx)
        val buf4: ref char = @alloc(64) as ref char
        @snprintf(buf4, 64, "    %%t%lld =l copy %lld\n", {tmp4, v})
        emit(ctx, buf4)
        @free(buf4)
        val res4: ref char = @alloc(16) as ref char
        @snprintf(res4, 16, "%%t%lld", {tmp4})
        return res4
    }

    if k == parser.NK_CHAR_LIT {
        val cv: i64 = expr.d0 as i64
        val tmp_c: i64 = fresh_tmp(ctx)
        val buf_c: ref char = @alloc(64) as ref char
        @snprintf(buf_c, 64, "    %%t%lld =l copy %lld\n", {tmp_c, cv})
        emit(ctx, buf_c)
        @free(buf_c)
        val res_c: ref char = @alloc(16) as ref char
        @snprintf(res_c, 16, "%%t%lld", {tmp_c})
        return res_c
    }

    if k == parser.NK_NONE {
        val tmp5: i64 = fresh_tmp(ctx)
        val buf5: ref char = @alloc(64) as ref char
        @snprintf(buf5, 64, "    %%t%lld =l copy 0\n", {tmp5})
        emit(ctx, buf5)
        @free(buf5)
        val res5: ref char = @alloc(16) as ref char
        @snprintf(res5, 16, "%%t%lld", {tmp5})
        return res5
    }

    if k == parser.NK_IDENT {
        val name: ref char = expr.d0 as ref char
        val cval: ref char = cg_const_val(ctx, name)
        if str.rchar_cmp(cval, "") != 0 {
            val tmp6: i64 = fresh_tmp(ctx)
            val buf6: ref char = @alloc(128) as ref char
            @snprintf(buf6, 128, "    %%t%lld =l copy %s\n", {tmp6, cval})
            emit(ctx, buf6)
            @free(buf6)
            val res6: ref char = @alloc(16) as ref char
            @snprintf(res6, 16, "%%t%lld", {tmp6})
            return res6
        } else {
            val qbe_var: ref char = cg_lookup_local_var(ctx, name)
            if str.rchar_cmp(qbe_var, "") != 0 {
                if cg_is_slot(ctx, name) {
                    val tmp_load: i64 = fresh_tmp(ctx)
                    val buf_load: ref char = @alloc(128) as ref char

                    // qbe_var is either a tmp number ("42") or a global label ("$foo") at this point
                    val is_global_slot: bool = @load8(qbe_var as ref void) == 36 // '$'
                    val slot_ref: ref char = @alloc(64) as ref char
                    if is_global_slot {
                        @snprintf(slot_ref, 64, "%s", {qbe_var})
                    } else {
                        @snprintf(slot_ref, 64, "%%t%s", {qbe_var})
                    }
                    
                    val is_ref_load: bool = cg_is_local_ref_type(ctx, name)
                    if is_ref_load {
                        @snprintf(buf_load, 128, "    %%t%lld =l loadl %s\n", {tmp_load, slot_ref})
                    } else {
                        val ltype_slot: ref char = cg_local_type(ctx, name)
                        if is_word_type_name(ltype_slot) {
                            val w_tmp_load: i64 = fresh_tmp(ctx)
                            val buf_w_load: ref char = @alloc(128) as ref char
                            @snprintf(buf_w_load, 128, "    %%t%lld =w loadw %s\n", {w_tmp_load, slot_ref})
                            emit(ctx, buf_w_load)
                            @free(buf_w_load)
                            @snprintf(buf_load, 128, "    %%t%lld =l extsw %%t%lld\n", {tmp_load, w_tmp_load})
                        } elif is_float_type_name(ltype_slot) {
                            @snprintf(buf_load, 128, "    %%t%lld =d loadd %s\n", {tmp_load, slot_ref})
                        } else {
                            @snprintf(buf_load, 128, "    %%t%lld =l loadl %s\n", {tmp_load, slot_ref})
                        }
                    }
                    emit(ctx, buf_load)
                    @free(buf_load)
                    @free(slot_ref)
                    val res_load: ref char = @alloc(16) as ref char
                    @snprintf(res_load, 16, "%%t%lld", {tmp_load})
                    return res_load
                } else {
                    val res_imm: ref char = @alloc(16) as ref char
                    @snprintf(res_imm, 16, "%%t%s", {qbe_var})
                    return res_imm
                }
            }

            val dqt: ref char = cg_direct_type(ctx, name)
            if str.rchar_cmp(dqt, "") != 0 {
                val res_direct: ref char = @alloc(32) as ref char
                @snprintf(res_direct, 32, "%%%s", {name})
                return res_direct
            } else {
                val tmp6b: i64 = fresh_tmp(ctx)
                val buf6b: ref char = @alloc(128) as ref char
                val ltype: ref char = cg_local_type(ctx, name)
                val fn_check: ref void = cg_lookup_fn_params(ctx, name)
                if fn_check != 0 as ref void {
                    @snprintf(buf6b, 128, "    %%t%lld =l copy $%s\n", {tmp6b, name})
                } elif str.rchar_cmp(ltype, "f64") == 0 {
                    @snprintf(buf6b, 128, "    %%t%lld =d loadd %%%s\n", {tmp6b, name})
                } elif str.rchar_cmp(ltype, "f32") == 0 {
                    @snprintf(buf6b, 128, "    %%t%lld =s loads %%%s\n", {tmp6b, name})
                } elif is_word_type_name(ltype) {
                    val w_tmp6: i64 = fresh_tmp(ctx)
                    val buf6c: ref char = @alloc(128) as ref char
                    @snprintf(buf6c, 128, "    %%t%lld =w loadw %%%s\n", {w_tmp6, name})
                    emit(ctx, buf6c)
                    @free(buf6c)
                    @snprintf(buf6b, 128, "    %%t%lld =l extsw %%t%lld\n", {tmp6b, w_tmp6})
                } else {
                    @snprintf(buf6b, 128, "    %%t%lld =l loadl %%%s\n", {tmp6b, name})
                }
                emit(ctx, buf6b)
                @free(buf6b)
                val res6b: ref char = @alloc(16) as ref char
                @snprintf(res6b, 16, "%%t%lld", {tmp6b})
                return res6b
            }
        }
    }

    if k == parser.NK_TRUST {
        return gen_expr(ctx, expr.d0 as ref parser.Node)
    }

    if k == parser.NK_SOME {
        val inner: ref char = gen_expr(ctx, expr.d0 as ref parser.Node)
        val inner_node: ref parser.Node = expr.d0 as ref parser.Node   
        val needs_extend: mut bool = false
        if inner_node != 0 as ref parser.Node && inner_node.kind == parser.NK_CALL {
            val callee_node: ref parser.Node = inner_node.d0 as ref parser.Node
            val callee_name: ref char = resolve_callee_name(callee_node)
            val ext_sym: ref char = cg_lookup_extern_symbol(ctx, callee_name)
            if ext_sym != 0 as ref char {
                val ret_ty: ref void = cg_lookup_ext_ret(ctx, callee_name)
                if ret_ty != 0 as ref void {
                    val ret_qtype: ref char = qbe_type_of(ret_ty as ref parser.Node)
                    if str.rchar_cmp(ret_qtype, "w") == 0 || str.rchar_cmp(ret_qtype, "s") == 0 {
                        needs_extend = true
                    }
                }
            }
        }
        
        val tmp_some: i64 = fresh_tmp(ctx)
        val buf_some: ref char = @alloc(128) as ref char
        if needs_extend != 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref char = @alloc(64) as ref char
            @snprintf(ext_buf, 64, "    %%t%lld =l extuw %s\n", {ext_tmp, inner})
            emit(ctx, ext_buf)
            @free(ext_buf)
            @snprintf(buf_some, 128, "    %%t%lld =l add %%t%lld, 1\n", {tmp_some, ext_tmp})
        } else {
            @snprintf(buf_some, 64, "    %%t%lld =l add %s, 1\n", {tmp_some, inner})
        }
        emit(ctx, buf_some)
        @free(buf_some)
        val res7: ref char = @alloc(16) as ref char
        @snprintf(res7, 16, "%%t%lld", {tmp_some})
        return res7
    }

    if k == parser.NK_OK_VAL {
        val ptr_ok: i64 = fresh_tmp(ctx)
        val buf_ok: ref char = @alloc(64) as ref char
        @snprintf(buf_ok, 64, "    %%t%lld =l call $malloc(l 16)\n    storel 0, %%t%lld\n", {ptr_ok, ptr_ok})
        emit(ctx, buf_ok)
        @free(buf_ok)
        if expr.d0 != 0 {
            val inner_ok_expr: ref parser.Node = expr.d0 as ref parser.Node
            val inner_ok: ref char = gen_expr(ctx, inner_ok_expr)
            val off_ok: i64 = fresh_tmp(ctx)
            val vbuf_ok: ref char = @alloc(128) as ref char
            val store_op_ok: mut ref char = ""
            if expr_is_float(ctx, inner_ok_expr) { store_op_ok = "stored" } else { store_op_ok = "storel" }
            @snprintf(vbuf_ok, 128, "    %%t%lld =l add %%t%lld, 8\n    %s %s, %%t%lld\n",
                {off_ok, ptr_ok, store_op_ok, inner_ok, off_ok})
            emit(ctx, vbuf_ok)
            @free(vbuf_ok)
        }
        val res_ok: ref char = @alloc(16) as ref char
        @snprintf(res_ok, 16, "%%t%lld", {ptr_ok})
        return res_ok
    }

    if k == parser.NK_ERR_VAL {
        // result err: [tag=1:l][value:l]
        val inner2: ref char = gen_expr(ctx, expr.d0 as ref parser.Node)
        val ptr3: i64 = fresh_tmp(ctx)
        val buf10: ref char = @alloc(64) as ref char
        @snprintf(buf10, 64, "    %%t%lld =l call $malloc(l 16)\n    storel 1, %%t%lld\n", {ptr3, ptr3})
        emit(ctx, buf10)
        @free(buf10)
        val off2: i64 = fresh_tmp(ctx)
        val buf11: ref char = @alloc(128) as ref char
        @snprintf(buf11, 128, "    %%t%lld =l add %%t%lld, 8\n    storel %s, %%t%lld\n",
            {off2, ptr3, inner2, off2})
        emit(ctx, buf11)
        @free(buf11)
        val res8: ref char = @alloc(16) as ref char
        @snprintf(res8, 16, "%%t%lld", {ptr3})
        return res8
    }

    if k == parser.NK_BINOP {
        return gen_binop(ctx, expr)
    }

    if k == parser.NK_UNOP {
        return gen_unop(ctx, expr)
    }

    if k == parser.NK_FIELD {
        return gen_field(ctx, expr)
    }

    if k == parser.NK_CALL {
        return gen_call(ctx, expr)
    }

    if k == parser.NK_BUILTIN {
        return gen_builtin(ctx, expr)
    }

    if k == parser.NK_CAST {
        val inner_expr: ref parser.Node = expr.d0 as ref parser.Node
        val inner3: ref char = gen_expr(ctx, inner_expr)
        val ty: ref parser.Node = expr.d1 as ref parser.Node
        val qt: ref char = qbe_type_of(ty)
        val src_is_float: bool = expr_is_float(ctx, inner_expr)
        val src_qt: mut ref char = ""

        if src_is_float { src_qt = "d" } else { src_qt = "l" }

        val needs_conversion: mut bool = false
        val conv_instr: mut ref char = "copy"

        if str.rchar_cmp(src_qt, "d") == 0 && str.rchar_cmp(qt, "l") == 0 {
            needs_conversion = true
            conv_instr = "dtosi"
        } elif str.rchar_cmp(src_qt, "d") == 0 && str.rchar_cmp(qt, "w") == 0 {
            needs_conversion = true
            conv_instr = "dtosi"
        } elif str.rchar_cmp(src_qt, "l") == 0 && str.rchar_cmp(qt, "d") == 0 {
            needs_conversion = true
            conv_instr = "sltof"
        } elif str.rchar_cmp(src_qt, "w") == 0 && str.rchar_cmp(qt, "d") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref char = @alloc(128) as ref char
            @snprintf(ext_buf, 128, "    %%t%lld =l extsw %s\n", {ext_tmp, inner3})
            emit(ctx, ext_buf)
            @free(ext_buf)
            val tmp_conv: i64 = fresh_tmp(ctx)
            val buf_conv: ref char = @alloc(128) as ref char
            @snprintf(buf_conv, 128, "    %%t%lld =d sltof %%t%lld\n", {tmp_conv, ext_tmp})
            emit(ctx, buf_conv)
            @free(buf_conv)
            val res_conv: ref char = @alloc(16) as ref char
            @snprintf(res_conv, 16, "%%t%lld", {tmp_conv})
            return res_conv
        }

        if str.rchar_cmp(qt, "w") == 0 && !needs_conversion {
            return inner3
        }

        val tmp7: i64 = fresh_tmp(ctx)
        val buf12: ref char = @alloc(128) as ref char
        if needs_conversion {
            @snprintf(buf12, 128, "    %%t%lld =%s %s %s\n", {tmp7, qt, conv_instr, inner3})
        } else {
            @snprintf(buf12, 128, "    %%t%lld =%s copy %s\n", {tmp7, qt, inner3})
        }
        emit(ctx, buf12)
        @free(buf12)
        val res9: ref char = @alloc(16) as ref char
        @snprintf(res9, 16, "%%t%lld", {tmp7})
        return res9
    }

    if k == parser.NK_ADDR {
        val inner4: ref parser.Node = expr.d0 as ref parser.Node
        if inner4.kind == parser.NK_IDENT {
            val iname: ref char = inner4.d0 as ref char
            val resolved_fn: ref char = cg_resolve_fn_name(ctx, iname)
            if resolved_fn != 0 as ref char {
                val res_fn: ref char = @alloc(256) as ref char
                @snprintf(res_fn, 256, "$%s", {resolved_fn})
                return res_fn
            }
            val qbe_var_addr: ref char = cg_lookup_local_var(ctx, iname)
            if str.rchar_cmp(qbe_var_addr, "") != 0 {
                if cg_is_slot(ctx, iname) {
                    val tmp_addr: i64 = fresh_tmp(ctx)
                    val buf_addr: ref char = @alloc(128) as ref char
                    val is_global_addr: bool = @load8(qbe_var_addr as ref void) == 36
                    val slot_ref_addr: ref char = @alloc(64) as ref char
                    if is_global_addr {
                        @snprintf(slot_ref_addr, 64, "%s", {qbe_var_addr})
                    } else {
                        @snprintf(slot_ref_addr, 64, "%%t%s", {qbe_var_addr})
                    }
                    @snprintf(buf_addr, 128, "    %%t%lld =l loadl %s\n", {tmp_addr, slot_ref_addr})
                    emit(ctx, buf_addr)
                    @free(buf_addr)
                    @free(slot_ref_addr)
                    val res_addr: ref char = @alloc(16) as ref char
                    @snprintf(res_addr, 16, "%%t%lld", {tmp_addr})
                    return res_addr
                }
                val res10: ref char = @alloc(32) as ref char
                @snprintf(res10, 32, "%%t%s", {qbe_var_addr})
                return res10
            }
            val res10: ref char = @alloc(32) as ref char
            @snprintf(res10, 32, "%%%s", {iname})
            return res10
        }
        return gen_expr(ctx, inner4)
    }

    if k == parser.NK_DEREF {
        val inner5: ref char = gen_expr(ctx, expr.d0 as ref parser.Node)
        val tmp8: i64 = fresh_tmp(ctx)
        val buf13: ref char = @alloc(128) as ref char
        @snprintf(buf13, 128, "    %%t%lld =l loadl %s\n", {tmp8, inner5})
        emit(ctx, buf13)
        @free(buf13)
        val res11: ref char = @alloc(16) as ref char
        @snprintf(res11, 16, "%%t%lld", {tmp8})
        return res11
    }

    if k == parser.NK_ARGS_PACK {
        // args pack — return the list pointer; caller handles unpacking
        val elist: ref void = expr.d0 as ref void
        val elen: i64 = @len(elist) as i64
        if elen == 0 { return "0" }
        // just return the first element for single-arg packs
        val e_opt = @get(elist, 0)
        match e_opt {
            some e => { return gen_expr(ctx, e as ref parser.Node) }
            none => { return "0" }
        }
    }

    if k == parser.NK_LIST_LIT {
        return gen_list_lit(ctx, expr)
    }

    if k == parser.NK_STRUCT_LIT {
        return gen_struct_lit(ctx, expr)
    }

    if k == parser.NK_ZERO_INIT {
        val tmp9: i64 = fresh_tmp(ctx)
        val buf14: ref char = @alloc(64) as ref char
        @snprintf(buf14, 64, "    %%t%lld =l alloc8 64\n    call $memset(l %%t%lld, w 0, l 64)\n", {tmp9, tmp9})
        emit(ctx, buf14)
        @free(buf14)
        val res12: ref char = @alloc(16) as ref char
        @snprintf(res12, 16, "%%t%lld", {tmp9})
        return res12
    }

    if k == parser.NK_TRY {
        return gen_try(ctx, expr)
    }

    // fallback
    val tmp10: i64 = fresh_tmp(ctx)
    val buf15: ref char = @alloc(64) as ref char
    @snprintf(buf15, 64, "    %%t%lld =l copy 0\n", {tmp10})
    emit(ctx, buf15)
    @free(buf15)
    val res13: ref char = @alloc(16) as ref char
    @snprintf(res13, 16, "%%t%lld", {tmp10})
    return res13
}

/// Check if an expression is float-typed by examining its structure
fn expr_is_float(ctx: ref CgCtx, expr: ref parser.Node) bool! = {
    if expr == 0 as ref parser.Node { return false }
    val k: i64 = expr.kind
    if k == parser.NK_FLOAT_LIT { return true }
    if k == parser.NK_IDENT {
        val name: ref char = expr.d0 as ref char
        val qtype: ref char = cg_direct_type(ctx, name)
        if str.rchar_cmp(qtype, "d") == 0 || str.rchar_cmp(qtype, "s") == 0 {
            return true
        }
        val ltype: ref char = cg_local_type(ctx, name)
        if str.rchar_cmp(ltype, "f64") == 0 || str.rchar_cmp(ltype, "f32") == 0 {
            return true
        }
        return false
    }
    if k == parser.NK_BINOP {
        val lhs_float: bool = expr_is_float(ctx, expr.d1 as ref parser.Node)
        val rhs_float: bool = expr_is_float(ctx, expr.d2 as ref parser.Node)
        return lhs_float || rhs_float
    }
    if k == parser.NK_UNOP {
        return expr_is_float(ctx, expr.d1 as ref parser.Node)
    }
    return false
}

/// Infer the QBE type of an expression.
fn expr_qbe_type(ctx: ref CgCtx, expr: ref parser.Node) ref char! = {
    if expr == 0 as ref parser.Node { return "l" } 

    val k: i64 = expr.kind

    if k == parser.NK_INT_LIT || k == parser.NK_STR_LIT || k == parser.NK_NONE {
        return "l"
    }
    if k == parser.NK_FLOAT_LIT {
        return "d"
    }
    if k == parser.NK_BOOL || k == parser.NK_CHAR_LIT {
        return "w"
    }

    if k == parser.NK_IDENT {
        val name: ref char = expr.d0 as ref char
        val dqt_opt: ref char = cg_direct_type(ctx, name)
        if str.rchar_cmp(dqt_opt, "") != 0 { return dqt_opt }

        val ltype: ref char = cg_local_type(ctx, name)
        if str.rchar_cmp(ltype, "") != 0 {
            if is_word_type_name(ltype) { return "w" }
            if is_float_type_name(ltype) { return "d" }
            return "l" 
        }
        return "l"
    }

    if k == parser.NK_CALL {
        val callee_node: ref parser.Node = expr.d0 as ref parser.Node
        val callee_name: ref char = resolve_callee_name(callee_node)
        val ext_ret_ty_node: ref void = cg_lookup_ext_ret(ctx, callee_name)
        if ext_ret_ty_node != 0 as ref void {
            return qbe_type_of(ext_ret_ty_node as ref parser.Node)
        }

        val fn_ret_ty_node: ref void = cg_lookup_fn_ret(ctx, callee_name)
        if fn_ret_ty_node != 0 as ref void {
            val ret_type: ref char = qbe_type_of(fn_ret_ty_node as ref parser.Node)
            return ret_type
        }
        
        val resolved_name: ref char = cg_resolve_fn_name(ctx, callee_name)
        if resolved_name != 0 as ref char {
            val fn_ret_ty_node2: ref void = cg_lookup_fn_ret(ctx, resolved_name)
            if fn_ret_ty_node2 != 0 as ref void {
                val ret_type2: ref char = qbe_type_of(fn_ret_ty_node2 as ref parser.Node)
                return ret_type2
            }
        }
        
        return "l"
    }

    if k == parser.NK_CAST {
        val cast_ty_node: ref parser.Node = expr.d1 as ref parser.Node
        return qbe_type_of(cast_ty_node)
    }

    if k == parser.NK_BINOP {
        val lhs_qbt = expr_qbe_type(ctx, expr.d1 as ref parser.Node)
        val rhs_qbt = expr_qbe_type(ctx, expr.d2 as ref parser.Node)
        if str.rchar_cmp(lhs_qbt, "d") == 0 || str.rchar_cmp(lhs_qbt, "s") == 0 ||
           str.rchar_cmp(rhs_qbt, "d") == 0 || str.rchar_cmp(rhs_qbt, "s") == 0 {
            return "d"
        }
        if str.rchar_cmp(lhs_qbt, "l") == 0 || str.rchar_cmp(rhs_qbt, "l") == 0 {
             val op: i64 = expr.d0 as i64
             if op == parser.OP_EQ || op == parser.OP_NE || op == parser.OP_LT ||
                op == parser.OP_GT || op == parser.OP_LE || op == parser.OP_GE ||
                op == parser.OP_AND || op == parser.OP_OR {
                 return "w" 
             }
             return "l" 
        }
        return "w"
    }

    if k == parser.NK_UNOP {
        val op_qbt = expr_qbe_type(ctx, expr.d1 as ref parser.Node)
        val op: i64 = expr.d0 as i64
        if op == parser.UOP_NEG { return op_qbt }
        if op == parser.UOP_NOT { return "w" } 
        if op == parser.UOP_BNOT { return op_qbt }
        return "l" 
    }
    
    return "l"
}

fn expr_is_result(expr: ref parser.Node) bool! = {
    if expr == 0 as ref parser.Node { return false }
    val k: i64 = expr.kind
    if k == parser.NK_OK_VAL || k == parser.NK_ERR_VAL { return true }
    return false
}

fn gen_binop(ctx: ref CgCtx, expr: ref parser.Node) ref char! = {
    val op: i64 = expr.d0 as i64
    val lhs_expr: ref parser.Node = expr.d1 as ref parser.Node
    val rhs_expr: ref parser.Node = expr.d2 as ref parser.Node
    val lhs_is_result: bool = expr_is_result(lhs_expr)
    val rhs_is_result: bool = expr_is_result(rhs_expr)

    if ((lhs_is_result || rhs_is_result) && (op == parser.OP_EQ || op == parser.OP_NE)) {
        val lhs: ref char = gen_expr(ctx, lhs_expr)
        val rhs: ref char = gen_expr(ctx, rhs_expr)
        val l_tag: i64 = fresh_tmp(ctx)
        val r_tag: i64 = fresh_tmp(ctx)
        val tag_buf: ref char = @alloc(128) as ref char
        @snprintf(tag_buf, 128, "    %%t%lld =l loadl %s\n    %%t%lld =l loadl %s\n", {l_tag, lhs, r_tag, rhs})
        emit(ctx, tag_buf)
        @free(tag_buf)

        val tags_eq: i64 = fresh_tmp(ctx)
        val tags_buf: ref char = @alloc(128) as ref char
        @snprintf(tags_buf, 128, "    %%t%lld =w ceql %%t%lld, %%t%lld\n", {tags_eq, l_tag, r_tag})
        emit(ctx, tags_buf)
        @free(tags_buf)

        val l_val_ptr: i64 = fresh_tmp(ctx)
        val r_val_ptr: i64 = fresh_tmp(ctx)
        val ptr_buf: ref char = @alloc(128) as ref char
        @snprintf(ptr_buf, 128, "    %%t%lld =l add %s, 8\n    %%t%lld =l add %s, 8\n", {l_val_ptr, lhs, r_val_ptr, rhs})
        emit(ctx, ptr_buf)
        @free(ptr_buf)

        val result_literal: mut ref parser.Node = 0 as ref parser.Node
        if lhs_is_result { result_literal = lhs_expr } else { result_literal = rhs_expr }
        val payload_expr: ref parser.Node = result_literal.d0 as ref parser.Node
        val payload_is_float: bool = expr_is_float(ctx, payload_expr)

        val vals_eq: i64 = fresh_tmp(ctx)
        if payload_is_float {
            val l_val: i64 = fresh_tmp(ctx)
            val r_val: i64 = fresh_tmp(ctx)
            val load_buf: ref char = @alloc(128) as ref char
            @snprintf(load_buf, 128, "    %%t%lld =d loadd %%t%lld\n    %%t%lld =d loadd %%t%lld\n", {l_val, l_val_ptr, r_val, r_val_ptr})
            emit(ctx, load_buf)
            @free(load_buf)
            val cmp_buf: ref char = @alloc(128) as ref char
            @snprintf(cmp_buf, 128, "    %%t%lld =w ceqd %%t%lld, %%t%lld\n", {vals_eq, l_val, r_val})
            emit(ctx, cmp_buf)
            @free(cmp_buf)
        } else {
            val l_val: i64 = fresh_tmp(ctx)
            val r_val: i64 = fresh_tmp(ctx)
            val load_buf: ref char = @alloc(128) as ref char
            @snprintf(load_buf, 128, "    %%t%lld =l loadl %%t%lld\n    %%t%lld =l loadl %%t%lld\n", {l_val, l_val_ptr, r_val, r_val_ptr})
            emit(ctx, load_buf)
            @free(load_buf)
            val cmp_buf: ref char = @alloc(128) as ref char
            @snprintf(cmp_buf, 128, "    %%t%lld =w ceql %%t%lld, %%t%lld\n", {vals_eq, l_val, r_val})
            emit(ctx, cmp_buf)
            @free(cmp_buf)
        }

        val both: i64 = fresh_tmp(ctx)
        val and_buf: ref char = @alloc(128) as ref char
        @snprintf(and_buf, 128, "    %%t%lld =w and %%t%lld, %%t%lld\n", {both, tags_eq, vals_eq})
        emit(ctx, and_buf)
        @free(and_buf)

        val result: i64 = fresh_tmp(ctx)
        val res_buf: ref char = @alloc(128) as ref char
        if op == parser.OP_NE {
            @snprintf(res_buf, 128, "    %%t%lld =w ceqw %%t%lld, 0\n", {result, both})
        } else {
            @snprintf(res_buf, 128, "    %%t%lld =w copy %%t%lld\n", {result, both})
        }
        emit(ctx, res_buf)
        @free(res_buf)

        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t%lld", {result})
        return res
    }

    val is_float: bool = expr_is_float(ctx, lhs_expr) || expr_is_float(ctx, rhs_expr)
    val lhs_qbt: ref char = expr_qbe_type(ctx, lhs_expr)
    val rhs_qbt: ref char = expr_qbe_type(ctx, rhs_expr)
    val lhs_is_word: bool = str.rchar_cmp(lhs_qbt, "w") == 0
    val rhs_is_word: bool = str.rchar_cmp(rhs_qbt, "w") == 0
    val lhs_is_int_lit: bool = lhs_expr.kind == parser.NK_INT_LIT
    val rhs_is_int_lit: bool = rhs_expr.kind == parser.NK_INT_LIT
    val is_comparison: bool = op == parser.OP_EQ || op == parser.OP_NE || op == parser.OP_LT ||
                              op == parser.OP_GT || op == parser.OP_LE || op == parser.OP_GE
    val target_type: mut ref char = "l"

    if !is_float && is_comparison {
        if ((lhs_is_word && rhs_is_int_lit) || (rhs_is_word && lhs_is_int_lit)) {
            target_type = "w"
        }
    }
    
    val lhs: ref char = gen_expr_with_type(ctx, lhs_expr, target_type)
    val rhs: ref char = gen_expr_with_type(ctx, rhs_expr, target_type)
    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(256) as ref char
    val lhs_l: mut ref char = lhs
    val rhs_l: mut ref char = rhs
    val both_word: bool = (lhs_is_word && rhs_is_word) || 
                          (lhs_is_word && rhs_is_int_lit) || 
                          (rhs_is_word && lhs_is_int_lit)

    if op == parser.OP_EQ || op == parser.OP_NE || op == parser.OP_LT ||
       op == parser.OP_GT || op == parser.OP_LE || op == parser.OP_GE {
        if !both_word {
            if str.rchar_cmp(lhs_qbt, "w") == 0 {
                val ext_tmp: i64 = fresh_tmp(ctx)
                val ext_buf: ref char = @alloc(128) as ref char
                @snprintf(ext_buf, 128, "    %%t%lld =l extsw %s\n", {ext_tmp, lhs_l})
                emit(ctx, ext_buf)
                @free(ext_buf)
                lhs_l = @alloc(16) as ref char
                @snprintf(lhs_l, 16, "%%t%lld", {ext_tmp})
            }
            if str.rchar_cmp(rhs_qbt, "w") == 0 {
                val ext_tmp: i64 = fresh_tmp(ctx)
                val ext_buf: ref char = @alloc(128) as ref char
                @snprintf(ext_buf, 128, "    %%t%lld =l extsw %s\n", {ext_tmp, rhs_l})
                emit(ctx, ext_buf)
                @free(ext_buf)
                rhs_l = @alloc(16) as ref char
                @snprintf(rhs_l, 16, "%%t%lld", {ext_tmp})
            }
        }
    }

    if is_float {
        if op == parser.OP_ADD  { @snprintf(buf, 256, "    %%t%lld =d add %s, %s\n",  {tmp, lhs, rhs}) }
        elif op == parser.OP_SUB { @snprintf(buf, 256, "    %%t%lld =d sub %s, %s\n",  {tmp, lhs, rhs}) }
        elif op == parser.OP_MUL { @snprintf(buf, 256, "    %%t%lld =d mul %s, %s\n",  {tmp, lhs, rhs}) }
        elif op == parser.OP_DIV { @snprintf(buf, 256, "    %%t%lld =d div %s, %s\n",  {tmp, lhs, rhs}) }
        elif op == parser.OP_REM { @snprintf(buf, 256, "    %%t%lld =d rem %s, %s\n",  {tmp, lhs, rhs}) }
        elif op == parser.OP_EQ  { @snprintf(buf, 256, "    %%t%lld =w ceqd %s, %s\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_NE  { @snprintf(buf, 256, "    %%t%lld =w cned %s, %s\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_LT  { @snprintf(buf, 256, "    %%t%lld =w cltd %s, %s\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_GT  { @snprintf(buf, 256, "    %%t%lld =w cgtd %s, %s\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_LE  { @snprintf(buf, 256, "    %%t%lld =w cled %s, %s\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_GE  { @snprintf(buf, 256, "    %%t%lld =w cged %s, %s\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_AND {
            @snprintf(buf, 256, "    %%t%lld =w and %s, %s\n", {tmp, lhs, rhs})
        }
        elif op == parser.OP_OR {
            @snprintf(buf, 256, "    %%t%lld =w or %s, %s\n", {tmp, lhs, rhs})
        }
        else { @snprintf(buf, 256, "    %%t%lld =l copy 0\n", {tmp}) }
    } else {
        if op == parser.OP_ADD  { @snprintf(buf, 256, "    %%t%lld =l add %s, %s\n",  {tmp, lhs, rhs}) }
        elif op == parser.OP_SUB { @snprintf(buf, 256, "    %%t%lld =l sub %s, %s\n",  {tmp, lhs, rhs}) }
        elif op == parser.OP_MUL { @snprintf(buf, 256, "    %%t%lld =l mul %s, %s\n",  {tmp, lhs, rhs}) }
        elif op == parser.OP_DIV { @snprintf(buf, 256, "    %%t%lld =l div %s, %s\n",  {tmp, lhs, rhs}) }
        elif op == parser.OP_REM { @snprintf(buf, 256, "    %%t%lld =l rem %s, %s\n",  {tmp, lhs, rhs}) }
        elif op == parser.OP_EQ  {
            if both_word {
                @snprintf(buf, 256, "    %%t%lld =w ceqw %s, %s\n", {tmp, lhs, rhs})
            } else {
                @snprintf(buf, 256, "    %%t%lld =w ceql %s, %s\n", {tmp, lhs_l, rhs_l})
            }
        }
        elif op == parser.OP_NE  {
            if both_word {
                @snprintf(buf, 256, "    %%t%lld =w cnew %s, %s\n", {tmp, lhs, rhs})
            } else {
                @snprintf(buf, 256, "    %%t%lld =w cnel %s, %s\n", {tmp, lhs_l, rhs_l})
            }
        }
        elif op == parser.OP_LT  {
            if both_word {
                @snprintf(buf, 256, "    %%t%lld =w csltw %s, %s\n", {tmp, lhs, rhs})
            } else {
                @snprintf(buf, 256, "    %%t%lld =w csltw %s, %s\n", {tmp, lhs_l, rhs_l})
            }
        }
        elif op == parser.OP_GT  {
            if both_word {
                @snprintf(buf, 256, "    %%t%lld =w csgtw %s, %s\n", {tmp, lhs, rhs})
            } else {
                @snprintf(buf, 256, "    %%t%lld =w csgtl %s, %s\n", {tmp, lhs_l, rhs_l})
            }
        }
        elif op == parser.OP_LE  {
            if both_word {
                @snprintf(buf, 256, "    %%t%lld =w cslew %s, %s\n", {tmp, lhs, rhs})
            } else {
                @snprintf(buf, 256, "    %%t%lld =w cslel %s, %s\n", {tmp, lhs_l, rhs_l})
            }
        }
        elif op == parser.OP_GE  { 
            val lt: i64 = fresh_tmp(ctx)
            if both_word {
                @snprintf(buf, 256, "    %%t%lld =w csltw %s, %s\n    %%t%lld =w ceqw %%t%lld, 0\n", {lt, lhs, rhs, tmp, lt})
            } else {
                @snprintf(buf, 256, "    %%t%lld =w csltw %s, %s\n    %%t%lld =w ceqw %%t%lld, 0\n", {lt, lhs_l, rhs_l, tmp, lt})
            }
        }
        elif op == parser.OP_AND {
            @snprintf(buf, 256, "    %%t%lld =w and %s, %s\n", {tmp, lhs, rhs})
        }
        elif op == parser.OP_OR {
            @snprintf(buf, 256, "    %%t%lld =w or %s, %s\n", {tmp, lhs, rhs})
        }
        elif op == parser.OP_BAND { @snprintf(buf, 256, "    %%t%lld =l and %s, %s\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_BOR  { @snprintf(buf, 256, "    %%t%lld =l or %s, %s\n",  {tmp, lhs, rhs}) }
        elif op == parser.OP_BXOR { @snprintf(buf, 256, "    %%t%lld =l xor %s, %s\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_SHL  { @snprintf(buf, 256, "    %%t%lld =l shl %s, %s\n", {tmp, lhs, rhs}) }
        elif op == parser.OP_SHR  { @snprintf(buf, 256, "    %%t%lld =l shr %s, %s\n", {tmp, lhs, rhs}) }
        else { @snprintf(buf, 256, "    %%t%lld =l copy 0\n", {tmp}) }
    }

    emit(ctx, buf)
    @free(buf)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t%lld", {tmp})
    return res
}

fn gen_unop(ctx: ref CgCtx, expr: ref parser.Node) ref char! = {
    val op: i64 = expr.d0 as i64
    val inner_expr: ref parser.Node = expr.d1 as ref parser.Node
    val inner: ref char = gen_expr(ctx, inner_expr)
    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(128) as ref char
    val is_float: bool = expr_is_float(ctx, inner_expr)

    if op == parser.UOP_NOT {
        @snprintf(buf, 128, "    %%t%lld =w ceqw %s, 0\n", {tmp, inner})
    } elif op == parser.UOP_NEG {
        if is_float {
            @snprintf(buf, 128, "    %%t%lld =d neg %s\n", {tmp, inner})
        } else {
            @snprintf(buf, 128, "    %%t%lld =l neg %s\n", {tmp, inner})
        }
    } elif op == parser.UOP_BNOT {
        @snprintf(buf, 128, "    %%t%lld =l xor %s, -1\n", {tmp, inner})
    } else {
        @snprintf(buf, 128, "    %%t%lld =l copy 0\n", {tmp})
    }
    emit(ctx, buf)
    @free(buf)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t%lld", {tmp})
    return res
}

fn gen_field(ctx: ref CgCtx, expr: ref parser.Node) ref char! = {
    val base_expr: ref parser.Node = expr.d0 as ref parser.Node
    val field_name: ref char = expr.d1 as ref char
    val offset: mut i64 = 0

    if base_expr.kind == parser.NK_IDENT {
        val base_name: ref char = base_expr.d0 as ref char
        val dqt_check: ref char = cg_direct_type(ctx, base_name)
        val local_type: ref char = cg_local_type(ctx, base_name)
        val is_local: bool = str.rchar_cmp(dqt_check, "") != 0 || str.rchar_cmp(local_type, "") != 0

        if !is_local {
            val tmp: i64 = fresh_tmp(ctx)
            val buf: ref char = @alloc(256) as ref char
            val enum_key: ref char = @alloc(512) as ref char
            @snprintf(enum_key, 512, "%s__%s", {base_name, field_name})
            val const_val: ref char = cg_const_val(ctx, enum_key)
            @free(enum_key)
            if str.rchar_cmp(const_val, "") != 0 {
                @snprintf(buf, 256, "    %%t%lld =l copy %s\n", {tmp, const_val})
            } else {
                @snprintf(buf, 256, "    %%t%lld =l loadl $%s__%s\n", {tmp, base_name, field_name})
            }
            emit(ctx, buf)
            @free(buf)
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t%lld", {tmp})
            return res
        }

        if str.rchar_cmp(local_type, "") != 0 {
            val fields: ref void = cg_lookup_struct(ctx, local_type)
            if fields != 0 as ref void {
                val off: i64 = field_offset(fields, field_name)
                if off >= 0 { offset = off }
            }
        }
    }

    val base: mut ref char = 0 as ref char
    val base_is_ref: mut bool = false
    if base_expr.kind == parser.NK_IDENT {
        val base_name2: ref char = base_expr.d0 as ref char
        val dqt: ref char = cg_direct_type(ctx, base_name2)
        if str.rchar_cmp(dqt, "") != 0 {
            val direct_buf: ref char = @alloc(32) as ref char
            @snprintf(direct_buf, 32, "%%%s", {base_name2})
            base = direct_buf
        } else {
            if cg_is_local_ref_type(ctx, base_name2) {
                base_is_ref = true
            }
        }
    }
    if base == 0 as ref char {
        base = gen_expr(ctx, base_expr)
        if base_expr.kind == parser.NK_IDENT {
            val base_name3: ref char = base_expr.d0 as ref char
            if cg_is_local_ref_type(ctx, base_name3) {
                base_is_ref = true
            }
        }
    }

    val field_is_fa: mut bool = false
    if base_expr.kind == parser.NK_IDENT {
        val base_name3: ref char = base_expr.d0 as ref char
        val local_type2: ref char = cg_local_type(ctx, base_name3)
        if str.rchar_cmp(local_type2, "") != 0 {
            val fields2: ref void = cg_lookup_struct(ctx, local_type2)
            if fields2 != 0 as ref void {
                val sflen3: i64 = @len(fields2 as list[ref void]) as i64
                val sfi3: mut i64 = 0
                for {
                    if sfi3 >= sflen3 { break }
                    val sf3_opt = @get(fields2 as list[ref void], sfi3 as usize)
                    match sf3_opt {
                        some sf3 => {
                            val sfn3: ref parser.Node = sf3 as ref parser.Node
                            val sfname3: ref char = sfn3.d0 as ref char
                            if str.rchar_cmp(sfname3, field_name) == 0 {
                                val sfty3: ref parser.Node = sfn3.d2 as ref parser.Node
                                if sfty3 != 0 as ref parser.Node && sfty3.kind == parser.TY_FIXED_ARR {
                                    field_is_fa = true
                                }
                                sfi3 = sflen3 // break
                            }
                        }
                        none => {}
                    }
                    sfi3++
                }
            }
        }
    }

    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(256) as ref char
    
    if base_is_ref {
        if field_is_fa {
            if offset == 0 {
                @snprintf(buf, 256, "    %%t%lld =l copy %s\n", {tmp, base})
            } else {
                @snprintf(buf, 256, "    %%t%lld =l add %s, %lld\n", {tmp, base, offset})
            }
        } else {
            if offset == 0 {
                @snprintf(buf, 256, "    %%t%lld =l loadl %s\n", {tmp, base})
            } else {
                val ptr_tmp: i64 = fresh_tmp(ctx)
                val buf2: ref char = @alloc(128) as ref char
                @snprintf(buf2, 128, "    %%t%lld =l add %s, %lld\n", {ptr_tmp, base, offset})
                emit(ctx, buf2)
                @free(buf2)
                val ptr_str: ref char = @alloc(16) as ref char
                @snprintf(ptr_str, 16, "%%t%lld", {ptr_tmp})
                @snprintf(buf, 256, "    %%t%lld =l loadl %s\n", {tmp, ptr_str})
                @free(ptr_str)
            }
        }
    } elif field_is_fa {
        if offset == 0 {
            @snprintf(buf, 256, "    %%t%lld =l copy %s\n", {tmp, base})
        } else {
            @snprintf(buf, 256, "    %%t%lld =l add %s, %lld\n", {tmp, base, offset})
        }
    } elif offset == 0 {
        @snprintf(buf, 256, "    %%t%lld =l loadl %s\n", {tmp, base})
    } else {
        val ptr_tmp: i64 = fresh_tmp(ctx)
        val buf2: ref char = @alloc(128) as ref char
        @snprintf(buf2, 128, "    %%t%lld =l add %s, %lld\n", {ptr_tmp, base, offset})
        emit(ctx, buf2)
        @free(buf2)
        val ptr_str: ref char = @alloc(16) as ref char
        @snprintf(ptr_str, 16, "%%t%lld", {ptr_tmp})
        @snprintf(buf, 256, "    %%t%lld =l loadl %s\n", {tmp, ptr_str})
        @free(ptr_str)
    }
    emit(ctx, buf)
    @free(buf)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t%lld", {tmp})
    return res
}

/// Returns the address of a field (or list variable) without loading its value.
/// Used by list builtins (@append, @len, @get, etc.) that need the list header address.
fn gen_list_ptr(ctx: ref CgCtx, expr: ref parser.Node) ref char! = {
    if expr == 0 as ref parser.Node { return "0" }
    if expr.kind == parser.NK_FIELD {
        val base_expr: ref parser.Node = expr.d0 as ref parser.Node
        val field_name: ref char = expr.d1 as ref char
        val offset: mut i64 = 0
        if base_expr.kind == parser.NK_IDENT {
            val base_name: ref char = base_expr.d0 as ref char
            val local_type: ref char = cg_local_type(ctx, base_name)
            if str.rchar_cmp(local_type, "") != 0 {
                val fields: ref void = cg_lookup_struct(ctx, local_type)
                if fields != 0 as ref void {
                    val off: i64 = field_offset(fields, field_name)
                    if off >= 0 { offset = off }
                }
            }
        }
        val base: mut ref char = 0 as ref char
        if base_expr.kind == parser.NK_IDENT {
            val base_name2: ref char = base_expr.d0 as ref char
            val dqt: ref char = cg_direct_type(ctx, base_name2)
            if str.rchar_cmp(dqt, "") != 0 {
                val direct_buf: ref char = @alloc(32) as ref char
                @snprintf(direct_buf, 32, "%%%s", {base_name2})
                base = direct_buf
            }
        }
        if base == 0 as ref char {
            base = gen_expr(ctx, base_expr)
        }
        if offset == 0 {
            return base
        }
        val ptr_tmp: i64 = fresh_tmp(ctx)
        val buf: ref char = @alloc(128) as ref char
        @snprintf(buf, 128, "    %%t%lld =l add %s, %lld\n", {ptr_tmp, base, offset})
        emit(ctx, buf)
        @free(buf)
        val res: ref char = @alloc(16) as ref char
        @snprintf(res, 16, "%%t%lld", {ptr_tmp})
        return res
    }
    if expr.kind == parser.NK_IDENT {
        val vname: ref char = expr.d0 as ref char
        val qbe_var: ref char = cg_lookup_local_var(ctx, vname)
        if str.rchar_cmp(qbe_var, "") != 0 && cg_is_slot(ctx, vname) {
            val slot_addr: ref char = @alloc(64) as ref char
            val is_global_ref: bool = @load8(qbe_var as ref void) == 36
            if is_global_ref {
                @snprintf(slot_addr, 64, "%s", {qbe_var})
            } else {
                @snprintf(slot_addr, 64, "%%t%s", {qbe_var})
            }
            val list_ptr_tmp: i64 = fresh_tmp(ctx)
            val load_buf: ref char = @alloc(128) as ref char
            @snprintf(load_buf, 128, "    %%t%lld =l loadl %s\n", {list_ptr_tmp, slot_addr})
            emit(ctx, load_buf)
            @free(load_buf)
            @free(slot_addr)
            
            val res: ref char = @alloc(16) as ref char
            @snprintf(res, 16, "%%t%lld", {list_ptr_tmp})
            return res
        }
        val dqt: ref char = cg_direct_type(ctx, vname)
        if str.rchar_cmp(dqt, "") != 0 {
            val res2: ref char = @alloc(32) as ref char
            @snprintf(res2, 32, "%%%s", {vname})
            return res2
        }
    }
    return gen_expr(ctx, expr)
}

fn gen_call(ctx: ref CgCtx, expr: ref parser.Node) ref char! = {
    val callee_node: ref parser.Node = expr.d0 as ref parser.Node
    val args_list: ref void = expr.d1 as ref void
    val callee_raw: ref char = resolve_callee_name(callee_node)
    val callee_name: ref char = @alloc(256) as ref char

    @snprintf(callee_name, 256, "%s", {callee_raw})

    val ext_sym: ref char = cg_lookup_extern_symbol(ctx, callee_name)
    if ext_sym != 0 as ref char {
        @snprintf(callee_name, 256, "%s", {ext_sym})
    }

    val tv_owner_slot: ref void = @alloc(8)
    val tv_field_slot: ref void = @alloc(8)

    @store(tv_owner_slot, 0)
    @store(tv_field_slot, 0)

    val tv_tag: i64 = cg_lookup_tv(ctx, callee_name, tv_owner_slot, tv_field_slot)

    if tv_tag < 0 {
        val sep_pos: mut i64 = -1
        val scan_i: mut i64 = 0
        for {
            val sc: u8 = @load8(@ptradd(callee_name as ref void, scan_i))
            if sc == 0 { break }
            val sc2: u8 = @load8(@ptradd(callee_name as ref void, scan_i + 1))
            if sc == 95 && sc2 == 95 { sep_pos = scan_i } // '__'
            scan_i++
        }
        if sep_pos >= 0 {
            val bare_name: ref char = @ptradd(callee_name as ref void, sep_pos + 2) as ref char
            @store(tv_owner_slot, 0)
            @store(tv_field_slot, 0)
            val tv_tag2: i64 = cg_lookup_tv(ctx, bare_name, tv_owner_slot, tv_field_slot)
            if tv_tag2 >= 0 {
                val field_ty_list2: ref void = @load(tv_field_slot) as ref void
                
                val payload_size2: mut i64 = 0
                if field_ty_list2 != 0 as ref void {
                    val ftlen2: i64 = @len(field_ty_list2 as list[ref parser.Node]) as i64
                    val fti2: mut i64 = 0
                    for {
                        if fti2 >= ftlen2 { break }
                        val ft_opt2 = @get(field_ty_list2 as list[ref parser.Node], fti2 as usize)
                        match ft_opt2 {
                            some ft2 => {
                                val ft_node2: ref parser.Node = ft2 as ref parser.Node
                                val fsize2: i64 = type_size(ft_node2)
                                if fsize2 == 0 {
                                    payload_size2 = payload_size2 + 8
                                } else {
                                    payload_size2 = payload_size2 + align_to(fsize2, 8)
                                }
                            }
                            none => {
                                payload_size2 = payload_size2 + 8
                            }
                        }
                        fti2++
                    }
                } else {
                }
                
                val alloc_size2: i64 = 8 + payload_size2
                val ptr2: i64 = fresh_tmp(ctx)
                val pbuf2: ref char = @alloc(64) as ref char
                @snprintf(pbuf2, 64, "    %%t%lld =l alloc8 %lld\n    storel %lld, %%t%lld\n",
                    {ptr2, alloc_size2, tv_tag2, ptr2})
                emit(ctx, pbuf2)
                @free(pbuf2)
                if args_list != 0 as ref void {
                    val flen2: i64 = @len(args_list) as i64
                    val fi2: mut i64 = 0
                    for {
                        if fi2 >= flen2 { break }
                        val fa2_opt = @get(args_list, fi2 as usize)
                        match fa2_opt {
                            some fa2 => {
                                val fa2_node: ref parser.Node = fa2 as ref parser.Node
                                val offset2: i64 = 8 + fi2 * 8
                                
                                if fa2_node.kind == parser.NK_STRUCT_LIT {
                                    if field_ty_list2 != 0 as ref void {
                                        val ft_opt2 = @get(field_ty_list2 as list[ref parser.Node], fi2 as usize)
                                        match ft_opt2 {
                                            some ft2 => {
                                                val ft_node2: ref parser.Node = ft2 as ref parser.Node
                                                if ft_node2.kind == parser.TY_NAMED {
                                                    val st_name2: ref char = ft_node2.d0 as ref char
                                                    val st_fields2: ref void = cg_lookup_struct(ctx, st_name2)
                                                    if st_fields2 != 0 as ref void {
                                                        gen_struct_lit_inline(ctx, fa2_node, ptr2, 8, st_fields2)
                                                    }
                                                }
                                            }
                                            none => {}
                                        }
                                    }
                                } else {
                                    val field_val2: ref char = gen_expr(ctx, fa2_node)
                                    val fptr2: i64 = fresh_tmp(ctx)
                                    val fbuf2: ref char = @alloc(128) as ref char
                                    @snprintf(fbuf2, 128, "    %%t%lld =l add %%t%lld, %lld\n    storel %s, %%t%lld\n",
                                        {fptr2, ptr2, offset2, field_val2, fptr2})
                                    emit(ctx, fbuf2)
                                    @free(fbuf2)
                                }
                            }
                            none => {}
                        }
                        fi2++
                    }
                }
                @free(tv_owner_slot)
                @free(tv_field_slot)
                val tv_res2: ref char = @alloc(16) as ref char
                @snprintf(tv_res2, 16, "%%t%lld", {ptr2})
                return tv_res2
            }
        }
    }

    if tv_tag >= 0 {
        val field_ty_list: ref void = @load(tv_field_slot) as ref void
        val n_args: mut i64 = 0
        if args_list != 0 as ref void { n_args = @len(args_list) as i64 }
        
        val payload_size: mut i64 = 0
        if field_ty_list != 0 as ref void {
            val ftlen: i64 = @len(field_ty_list as list[ref parser.Node]) as i64
            val fti: mut i64 = 0
            for {
                if fti >= ftlen { break }
                val ft_opt = @get(field_ty_list as list[ref parser.Node], fti as usize)
                match ft_opt {
                    some ft => {
                        val ft_node: ref parser.Node = ft as ref parser.Node
                        val fsize: i64 = type_size(ft_node)
                        if fsize == 0 {
                            payload_size = payload_size + 8
                        } else {
                            payload_size = payload_size + align_to(fsize, 8)
                        }
                    }
                    none => {
                        payload_size = payload_size + 8
                    }
                }
                fti++
            }
        } else {
            payload_size = n_args * 8
        }
        
        val alloc_size: i64 = 8 + payload_size
        val ptr: i64 = fresh_tmp(ctx)
        val pbuf: ref char = @alloc(64) as ref char
        @snprintf(pbuf, 64, "    %%t%lld =l alloc8 %lld\n    storel %lld, %%t%lld\n",
            {ptr, alloc_size, tv_tag, ptr})
        emit(ctx, pbuf)
        @free(pbuf)
        if args_list != 0 as ref void {
            val flen: i64 = @len(args_list) as i64
            val fi: mut i64 = 0
            for {
                if fi >= flen { break }
                val fa_opt = @get(args_list, fi as usize)
                match fa_opt {
                    some fa => {
                        val fa_node: ref parser.Node = fa as ref parser.Node
                        val offset: i64 = 8 + fi * 8
                        
                        if fa_node.kind == parser.NK_STRUCT_LIT {
                            if field_ty_list != 0 as ref void {
                                val ft_opt = @get(field_ty_list as list[ref parser.Node], fi as usize)
                                match ft_opt {
                                    some ft => {
                                        val ft_node: ref parser.Node = ft as ref parser.Node
                                        if ft_node.kind == parser.TY_NAMED {
                                            val st_name: ref char = ft_node.d0 as ref char
                                            val st_fields: ref void = cg_lookup_struct(ctx, st_name)
                                            if st_fields != 0 as ref void {
                                                gen_struct_lit_inline(ctx, fa_node, ptr, 8, st_fields)
                                            }
                                        }
                                    }
                                    none => {}
                                }
                            }
                        } else {
                            val field_val: ref char = gen_expr(ctx, fa_node)
                            val fptr: i64 = fresh_tmp(ctx)
                            val fbuf: ref char = @alloc(128) as ref char
                            @snprintf(fbuf, 128, "    %%t%lld =l add %%t%lld, %lld\n    storel %s, %%t%lld\n",
                                {fptr, ptr, offset, field_val, fptr})
                            emit(ctx, fbuf)
                            @free(fbuf)
                        }
                    }
                    none => {}
                }
                fi++
            }
        }
        @free(tv_owner_slot)
        @free(tv_field_slot)
        val tv_res: ref char = @alloc(16) as ref char
        @snprintf(tv_res, 16, "%%t%lld", {ptr})
        return tv_res
    }
    @free(tv_owner_slot)
    @free(tv_field_slot)

    val is_print: bool = str.rchar_cmp(callee_name, "print") == 0
        || str.ends_with(str.from(callee_name), str.from("__print"))
        || str.ends_with(str.from(callee_name), str.from("__eprint"))
    
    if is_print && args_list != 0 as ref void {
        val alen_p: i64 = @len(args_list) as i64
        if alen_p > 0 {
            val first_arg_opt = @get(args_list, 0)
            match first_arg_opt {
                some first_arg => {
                    val first_node: ref parser.Node = first_arg as ref parser.Node
                    if first_node.kind == parser.NK_STR_LIT {
                        val fmt_str: ref char = first_node.d0 as ref char
                        val fmt_idx: i64 = intern_format_string(ctx, fmt_str)
                        val fmt_tmp: i64 = fresh_tmp(ctx)
                        val fmt_buf: ref char = @alloc(64) as ref char
                        @snprintf(fmt_buf, 64, "    %%t%lld =l copy $__str%lld\n", {fmt_tmp, fmt_idx})
                        emit(ctx, fmt_buf)
                        @free(fmt_buf)
                        
                        val variadic_args: mut list[ref char] = []
                        val ai_p: mut i64 = 1
                        for {
                            if ai_p >= alen_p { break }
                            val arg_opt_p = @get(args_list, ai_p as usize)
                            match arg_opt_p {
                                some arg_p => {
                                    val arg_node_p: ref parser.Node = arg_p as ref parser.Node
                                    if arg_node_p.kind == parser.NK_ARGS_PACK {
                                        val pack_p: ref void = arg_node_p.d0 as ref void
                                        val plen_p: i64 = @len(pack_p) as i64
                                        val pi_p: mut i64 = 0
                                        for {
                                            if pi_p >= plen_p { break }
                                            val pe_opt_p = @get(pack_p, pi_p as usize)
                                            match pe_opt_p {
                                                some pe_p => {
                                                    val pe_node_p: ref parser.Node = pe_p as ref parser.Node
                                                    val pqt_p: ref char = expr_qtype(ctx, pe_node_p)
                                                    val pv_p: ref char = gen_expr(ctx, pe_node_p)
                                                    val pbuf_p: ref char = @alloc(64) as ref char
                                                    @snprintf(pbuf_p, 64, "%s %s", {pqt_p, pv_p})
                                                    @append(variadic_args, pbuf_p)
                                                }
                                                none => {}
                                            }
                                            pi_p++
                                        }
                                    } else {
                                        val aqt_p: ref char = expr_qtype(ctx, arg_node_p)
                                        val av_p: ref char = gen_expr(ctx, arg_node_p)
                                        val abuf_p: ref char = @alloc(64) as ref char
                                        @snprintf(abuf_p, 64, "%s %s", {aqt_p, av_p})
                                        @append(variadic_args, abuf_p)
                                    }
                                }
                                none => {}
                            }
                            ai_p++
                        }
                        
                        val result_tmp: i64 = fresh_tmp(ctx)
                        val call_buf_p: ref char = @alloc(4096) as ref char
                        val vlen: i64 = @len(variadic_args) as i64
                        if vlen == 0 {
                            @snprintf(call_buf_p, 4096, "    %%t%lld =l call $printf(l %%t%lld)\n", {result_tmp, fmt_tmp})
                        } else {
                            val call_pos_p: mut i64 = 0
                            val hdr_p: ref char = @alloc(256) as ref char
                            @snprintf(hdr_p, 256, "    %%t%lld =l call $printf(l %%t%lld, ...", {result_tmp, fmt_tmp})
                            val hdr_len_p: mut i64 = str.len_raw(hdr_p)
                            @memcpy(@ptradd(call_buf_p as ref void, call_pos_p), hdr_p as ref void, hdr_len_p)
                            call_pos_p = call_pos_p + hdr_len_p
                            @free(hdr_p)
                            
                            val vi: mut i64 = 0
                            for {
                                if vi >= vlen { break }
                                val v_opt = @get(variadic_args, vi as usize)
                                match v_opt {
                                    some v => {
                                        val vstr: ref char = v as ref char
                                        val vlen2: mut i64 = str.len_raw(vstr)
                                        @memcpy(@ptradd(call_buf_p as ref void, call_pos_p), ", " as ref void, 2)
                                        call_pos_p = call_pos_p + 2
                                        @memcpy(@ptradd(call_buf_p as ref void, call_pos_p), vstr as ref void, vlen2)
                                        call_pos_p = call_pos_p + vlen2
                                    }
                                    none => {}
                                }
                                vi++
                            }
                            @store8(@ptradd(call_buf_p as ref void, call_pos_p), 41) // ')'
                            call_pos_p++
                            @store8(@ptradd(call_buf_p as ref void, call_pos_p), 10) // '\n'
                            call_pos_p++
                            @store8(@ptradd(call_buf_p as ref void, call_pos_p), 0)
                        }
                        emit(ctx, call_buf_p)
                        @free(call_buf_p)
                        
                        val res_p: ref char = @alloc(16) as ref char
                        @snprintf(res_p, 16, "%%t%lld", {result_tmp})
                        return res_p
                    }
                }
                none => {}
            }
        }
    }

    val arg_tmps: mut list[ref char] = []

    if args_list != 0 as ref void {
        val alen: i64 = @len(args_list) as i64
        val ai: mut i64 = 0
        for {
            if ai >= alen { break }
            val arg_opt = @get(args_list, ai as usize)
            match arg_opt {
                some arg => {
                    val arg_node: ref parser.Node = arg as ref parser.Node
                    val ak: i64 = arg_node.kind
                    if ak == parser.NK_ARGS_PACK {
                        val pack: ref void = arg_node.d0 as ref void
                        val plen: i64 = @len(pack) as i64
                        val pi: mut i64 = 0
                        for {
                            if pi >= plen { break }
                            val pe_opt = @get(pack, pi as usize)
                            match pe_opt {
                                some pe => {
                                    val pt: ref char = gen_expr(ctx, pe as ref parser.Node)
                                    @append(arg_tmps, pt)
                                }
                                none => {}
                            }
                            pi++
                        }
                    } else {
                        val at: ref char = gen_expr(ctx, arg_node)
                        @append(arg_tmps, at)
                    }
                }
                none => {}
            }
            ai++
        }
    }

    val tmp: mut i64 = fresh_tmp(ctx)
    val resolved_callee: ref char = cg_resolve_fn_name(ctx, callee_name)
    val effective_callee: mut ref char = ""
    if resolved_callee != 0 as ref char { effective_callee = resolved_callee } else { effective_callee = callee_name }
    val fn_params_list: ref void = cg_lookup_fn_params(ctx, effective_callee)
    if fn_params_list != 0 as ref void {
        val plen: i64 = @len(fn_params_list) as i64
        val tlen0: i64 = @len(arg_tmps) as i64
        val wi: mut i64 = 0
        for {
            if wi >= plen { break }
            if wi >= tlen0 { break }
            val p_opt = @get(fn_params_list, wi as usize)
            match p_opt {
                some p => {
                    val param_node: ref parser.Node = p as ref parser.Node
                    val pty: ref parser.Node = param_node.d1 as ref parser.Node
                    if pty != 0 as ref parser.Node && pty.kind == parser.TY_NAMED {
                        val ptype_name: ref char = pty.d0 as ref char
                        val union_vars: ref void = cg_lookup_union(ctx, ptype_name)
                        if union_vars != 0 as ref void {
                            val at_opt = @get(arg_tmps, wi as usize)
                            match at_opt {
                                some at => {
                                    val arg_val: ref char = at as ref char
                                    val should_wrap: mut bool = true
                                    if @load8(arg_val) as i64 == 37 {
                                        val second: i64 = @load8(@ptradd(arg_val, 1)) as i64
                                        if second == 116 {
                                            should_wrap = false
                                        }
                                    }
                                    
                                    if should_wrap {
                                        val box_ptr: i64 = fresh_tmp(ctx)
                                        val payload_ptr: i64 = fresh_tmp(ctx)
                                        val bbuf: ref char = @alloc(256) as ref char
                                        @snprintf(bbuf, 256,
                                            "    %%t%lld =l call $malloc(l 16)\n    storew 0, %%t%lld\n    %%t%lld =l add %%t%lld, 8\n    storel %s, %%t%lld\n",
                                            {box_ptr, box_ptr, payload_ptr, box_ptr, arg_val, payload_ptr})
                                        emit(ctx, bbuf)
                                        @free(bbuf)
                                        val wrapped: ref char = @alloc(16) as ref char
                                        @snprintf(wrapped, 16, "%%t%lld", {box_ptr})
                                        val new_tmps: mut list[ref char] = []
                                        val tlen_r: i64 = @len(arg_tmps) as i64
                                        val ri: mut i64 = 0
                                        for {
                                            if ri >= tlen_r { break }
                                            val r_opt = @get(arg_tmps, ri as usize)
                                            match r_opt {
                                                some r => {
                                                    if ri == wi {
                                                        @append(new_tmps, wrapped)
                                                    } else {
                                                        @append(new_tmps, r as ref char)
                                                    }
                                                }
                                                none => {}
                                            }
                                            ri++
                                        }
                                        arg_tmps = new_tmps
                                    }
                                }
                                none => {}
                            }
                        }
                    }
                }
                none => {}
            }
            wi++
        }
    }

    val call_buf: ref char = @alloc(8192) as ref char
    val call_pos: mut i64 = 0
    val hdr: ref char = @alloc(256) as ref char
    val is_fn_ptr: bool = resolved_callee == 0 as ref char
        && ext_sym == 0 as ref char
        && callee_node.kind == parser.NK_IDENT

    val ret_qtype: mut ref char = "l"  // default to long/pointer
    val ret_union_name: mut ref char = ""
    if ext_sym != 0 as ref char {
        val ret_ty: ref void = cg_lookup_ext_ret(ctx, callee_raw)
        if ret_ty != 0 as ref void {
            ret_qtype = qbe_type_of(ret_ty as ref parser.Node)
            ret_union_name = is_union_type(ctx, ret_ty as ref parser.Node)
        }
    } else {
        val lookup_name: mut ref char = callee_name
        if resolved_callee != 0 as ref char {
            lookup_name = resolved_callee
        }
        val ret_ty: ref void = cg_lookup_fn_ret(ctx, lookup_name)
        if ret_ty != 0 as ref void {
            ret_qtype = qbe_type_of(ret_ty as ref parser.Node)
            ret_union_name = is_union_type(ctx, ret_ty as ref parser.Node)
        }
    }

    val returns_union: bool = str.rchar_cmp(ret_union_name, "") != 0
    val ret_buf_tmp: mut i64 = -1
    
    // If the function returns a union, allocate a return buffer
    if returns_union {
        ret_buf_tmp = fresh_tmp(ctx)
        val alloc_buf: ref char = @alloc(64) as ref char
        @snprintf(alloc_buf, 64, "    %%t%lld =l alloc8 16\n", {ret_buf_tmp})
        emit(ctx, alloc_buf)
        @free(alloc_buf)
    }

    if is_fn_ptr {
        val dqt: ref char = cg_direct_type(ctx, callee_name)
        if str.rchar_cmp(dqt, "") != 0 {
            @snprintf(hdr, 256, "    %%t%lld =%s call %%%s(", {tmp, ret_qtype, callee_name})
        } else {
            val ptr_tmp: i64 = fresh_tmp(ctx)
            val load_buf: ref char = @alloc(64) as ref char
            @snprintf(load_buf, 64, "    %%t%lld =l loadl %%%s\n", {ptr_tmp, callee_name})
            emit(ctx, load_buf)
            @free(load_buf)
            @snprintf(hdr, 256, "    %%t%lld =%s call %%t%lld(", {tmp, ret_qtype, ptr_tmp})
        }
    } else {
        val effective_name: mut ref char = callee_name
        if resolved_callee != 0 as ref char {
            effective_name = resolved_callee
        }
        @snprintf(hdr, 256, "    %%t%lld =%s call $%s(", {tmp, ret_qtype, effective_name})
    }
    val hdr_len: mut i64 = str.len_raw(hdr)
    @memcpy(@ptradd(call_buf as ref void, call_pos), hdr as ref void, hdr_len)
    call_pos = call_pos + hdr_len
    @free(hdr)

    val tlen: i64 = @len(arg_tmps) as i64

    // If returning a union, add the return buffer as the first argument
    if returns_union {
        val ret_arg: ref char = @alloc(32) as ref char
        @snprintf(ret_arg, 32, "l %%t%lld", {ret_buf_tmp})
        val ret_arg_len: mut i64 = str.len_raw(ret_arg)
        @memcpy(@ptradd(call_buf as ref void, call_pos), ret_arg as ref void, ret_arg_len)
        call_pos = call_pos + ret_arg_len
        @free(ret_arg)
        if tlen > 0 {
            @memcpy(@ptradd(call_buf as ref void, call_pos), ", " as ref void, 2)
            call_pos = call_pos + 2
        }
    }

    val ti: mut i64 = 0
    for {
        if ti >= tlen { break }
        val t_opt = @get(arg_tmps, ti as usize)
        match t_opt {
            some t => {
                val tbuf: ref char = @alloc(64) as ref char
                if ti > 0 {
                    @memcpy(@ptradd(call_buf as ref void, call_pos), ", " as ref void, 2)
                    call_pos = call_pos + 2
                }

                val arg_qtype: mut ref char = "l"
                if fn_params_list != 0 as ref void {
                    val params_len: i64 = @len(fn_params_list as list[ref void]) as i64
                    if ti < params_len {
                        val param_opt = @get(fn_params_list as list[ref void], ti as usize)
                        match param_opt {
                            some param => {
                                val param_node: ref parser.Node = param as ref parser.Node
                                if param_node != 0 as ref parser.Node {
                                    val param_ty: ref parser.Node = param_node.d1 as ref parser.Node
                                    if param_ty != 0 as ref parser.Node {
                                        arg_qtype = qbe_type_of(param_ty)
                                    }
                                }
                            }
                            none => {}
                        }
                    }
                }
                @snprintf(tbuf, 64, "%s %s", {arg_qtype, t as ref char})
                val tlen2: mut i64 = str.len_raw(tbuf)
                @memcpy(@ptradd(call_buf as ref void, call_pos), tbuf as ref void, tlen2)
                call_pos = call_pos + tlen2
                @free(tbuf)
            }
            none => {}
        }
        ti++
    }
    @store8(@ptradd(call_buf as ref void, call_pos), 41) // ')'
    call_pos = call_pos + 1
    @store8(@ptradd(call_buf as ref void, call_pos), 0)
    emitln(ctx, call_buf)

    if ext_sym != 0 as ref char {
        val ret_ty2: ref void = cg_lookup_ext_ret(ctx, callee_raw)
        if ret_ty2 != 0 as ref void {
            val ret_qtype2: ref char = qbe_type_of(ret_ty2 as ref parser.Node)
            if str.rchar_cmp(ret_qtype2, "w") == 0 {
                val ext_tmp: i64 = fresh_tmp(ctx)
                val ext_buf: ref char = @alloc(64) as ref char
                @snprintf(ext_buf, 64, "    %%t%lld =l extsw %%t%lld\n", {ext_tmp, tmp})
                emit(ctx, ext_buf)
                @free(ext_buf)
                tmp = ext_tmp
            }
        }
    }

    // If the function returns a union, return the buffer pointer instead of the call result
    val result_tmp: mut i64 = tmp
    if returns_union {
        result_tmp = ret_buf_tmp
    }

    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t%lld", {result_tmp})
    return res
}

fn resolve_callee_name(node: ref parser.Node) ref char! = {
    val k: i64 = node.kind as i64
    if k == parser.NK_IDENT {
        return node.d0 as ref char
    }
    if k == parser.NK_FIELD {
        val base: ref char = resolve_callee_name(node.d0 as ref parser.Node)
        val field: ref char = node.d1 as ref char
        val buf: ref char = @alloc(256) as ref char
        @snprintf(buf, 256, "%s__%s", {base, field})
        return buf
    }
    return "unknown"
}

fn get_arg(ctx: ref CgCtx, args: ref void, i: i64) ref char! = {
    val opt = @get(args, i as usize)
    match opt {
        some a => { return gen_expr(ctx, a as ref parser.Node) }
        none => { return "0" }
    }
}

/// Like get_arg but for format strings - interns with format rewriting.
fn get_format_arg(ctx: ref CgCtx, args: ref void, i: i64) ref char! = {
    val opt = @get(args, i as usize)
    match opt {
        some a => {
            val node: ref parser.Node = a as ref parser.Node
            if node.kind == parser.NK_STR_LIT {
                val s: ref char = node.d0 as ref char
                val idx: i64 = intern_format_string(ctx, s)
                val tmp: i64 = fresh_tmp(ctx)
                val buf: ref char = @alloc(64) as ref char
                @snprintf(buf, 64, "    %%t%lld =l copy $__str%lld\n", {tmp, idx})
                emit(ctx, buf)
                @free(buf)
                val res: ref char = @alloc(16) as ref char
                @snprintf(res, 16, "%%t%lld", {tmp})
                return res
            } else {
                return gen_expr(ctx, node)
            }
        }
        none => { return "0" }
    }
}

/// Like get_arg but returns the address of the list header (for list builtins).
fn get_list_arg(ctx: ref CgCtx, args: ref void, i: i64) ref char! = {
    val opt = @get(args, i as usize)
    match opt {
        some a => { return gen_list_ptr(ctx, a as ref parser.Node) }
        none => { return "0" }
    }
}

/// Returns the QBE type ("d", "s", or "l") for an expression node without generating code.
fn expr_qtype(ctx: ref CgCtx, node: ref parser.Node) ref char! = {
    if node == 0 as ref parser.Node { return "l" }
    val k: i64 = node.kind
    if k == parser.NK_FLOAT_LIT { return "d" }
    if k == parser.NK_INT_LIT { return "l" }
    if k == parser.NK_IDENT {
        val vname: ref char = node.d0 as ref char
        val dqt: ref char = cg_direct_type(ctx, vname)
        if str.rchar_cmp(dqt, "") != 0 { return dqt }
        val ltype: ref char = cg_local_type(ctx, vname)
        if str.rchar_cmp(ltype, "f64") == 0 { return "d" }
        if str.rchar_cmp(ltype, "f32") == 0 { return "s" }
        if str.rchar_cmp(ltype, "i32") == 0 { return "w" }
        if str.rchar_cmp(ltype, "u32") == 0 { return "w" }
        if str.rchar_cmp(ltype, "bool") == 0 { return "w" }
    }
    if k == parser.NK_CAST {
        val ty: ref parser.Node = node.d1 as ref parser.Node
        return qbe_type_of(ty)
    }
    return "l"
}

fn gen_builtin(ctx: ref CgCtx, expr: ref parser.Node) ref char! = {
    val name: ref char = expr.d0 as ref char
    val args: ref void = expr.d1 as ref void

    val tmp: mut i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(512) as ref char

    if str.rchar_cmp(name, "alloc") == 0 {
        val sz: ref char = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    %%t%lld =l call $malloc(l %s)\n", {tmp, sz})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "free") == 0 {
        val ptr: ref char = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    call $free(l %s)\n    %%t%lld =l copy 0\n", {ptr, tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "realloc") == 0 {
        val ptr2: ref char = get_arg(ctx, args, 0)
        val sz2: ref char = get_arg(ctx, args, 1)
        @snprintf(buf, 512, "    %%t%lld =l call $realloc(l %s, l %s)\n", {tmp, ptr2, sz2})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "memcpy") == 0 {
        val dst: ref char = get_arg(ctx, args, 0)
        val src: ref char = get_arg(ctx, args, 1)
        val len: ref char = get_arg(ctx, args, 2)
        @snprintf(buf, 512, "    call $memcpy(l %s, l %s, l %s)\n    %%t%lld =l copy 0\n", {dst, src, len, tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "memset") == 0 {
        val dst2: ref char = get_arg(ctx, args, 0)
        val val2: ref char = get_arg(ctx, args, 1)
        val len2: ref char = get_arg(ctx, args, 2)
        @snprintf(buf, 512, "    call $memset(l %s, w %s, l %s)\n    %%t%lld =l copy 0\n", {dst2, val2, len2, tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "load") == 0 {
        val ptr3: ref char = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    %%t%lld =l loadl %s\n", {tmp, ptr3})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "store") == 0 {
        val ptr4: ref char = get_arg(ctx, args, 0)
        val val3_node_opt = @get(args, 1)
        val val3: ref char = get_arg(ctx, args, 1)
        val val3_qtype: mut ref char = "l"

        match val3_node_opt {
            some vn => {
                val3_qtype = expr_qbe_type(ctx, vn as ref parser.Node)
            }
            none => {}
        }
        
        if str.rchar_cmp(val3_qtype, "w") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref char = @alloc(128) as ref char
            @snprintf(ext_buf, 128, "    %%t%lld =l extsw %s\n", {ext_tmp, val3})
            emit(ctx, ext_buf)
            @free(ext_buf)
            @snprintf(buf, 512, "    storel %%t%lld, %s\n    %%t%lld =l copy 0\n", {ext_tmp, ptr4, tmp})
        } else {
            @snprintf(buf, 512, "    storel %s, %s\n    %%t%lld =l copy 0\n", {val3, ptr4, tmp})
        }
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "load8") == 0 {
        val ptr5: ref char = get_arg(ctx, args, 0)
        val w_tmp: i64 = fresh_tmp(ctx)
        val wbuf: ref char = @alloc(64) as ref char
        @snprintf(wbuf, 64, "    %%t%lld =w loadub %s\n", {w_tmp, ptr5})
        emit(ctx, wbuf)
        @free(wbuf)
        @snprintf(buf, 512, "    %%t%lld =l extsw %%t%lld\n", {tmp, w_tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "store8") == 0 {
        val ptr6: ref char = get_arg(ctx, args, 0)
        val val4: ref char = get_arg(ctx, args, 1)
        @snprintf(buf, 512, "    storeb %s, %s\n    %%t%lld =l copy 0\n", {val4, ptr6, tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "ptradd") == 0 {
        val ptr7: ref char = get_arg(ctx, args, 0)
        val off: ref char = get_arg(ctx, args, 1)
        @snprintf(buf, 512, "    %%t%lld =l add %s, %s\n", {tmp, ptr7, off})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "puts") == 0 {
        val s: ref char = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    %%t%lld =w call $puts(l %s)\n    call $fflush(l 0)\n", {tmp, s})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "printf") == 0 {
        val fmt: ref char = get_format_arg(ctx, args, 0)
        val call_buf2: ref char = @alloc(4096) as ref char
        val call_pos2: mut i64 = 0
        val hdr2: ref char = @alloc(256) as ref char
        @snprintf(hdr2, 256, "    %%t%lld =w call $printf(l %s, ...", {tmp, fmt})
        val hdr2_len: mut i64 = str.len_raw(hdr2 as ref char)
        @memcpy(@ptradd(call_buf2 as ref void, call_pos2), hdr2 as ref void, hdr2_len)
        call_pos2 = call_pos2 + hdr2_len
        @free(hdr2)
        if args != 0 as ref void {
            val alen2: i64 = @len(args) as i64
            if alen2 > 1 {
                val pack_opt = @get(args, 1)
                match pack_opt {
                    some pack_node => {
                        val pn: ref parser.Node = pack_node as ref parser.Node
                        if pn.kind == parser.NK_ARGS_PACK {
                            val pack: ref void = pn.d0 as ref void
                            val plen2: i64 = @len(pack) as i64
                            val pi2: mut i64 = 0
                            for {
                                if pi2 >= plen2 { break }
                                val pe_opt = @get(pack, pi2 as usize)
                                match pe_opt {
                                    some pe => {
                                        val pe_node: ref parser.Node = pe as ref parser.Node
                                        val pqt: ref char = expr_qtype(ctx, pe_node)
                                        val pv: ref char = gen_expr(ctx, pe_node)
                                        val pbuf2: ref char = @alloc(64) as ref char
                                        @snprintf(pbuf2, 64, ", %s %s", {pqt, pv})
                                        val pbuf2_len: mut i64 = str.len_raw(pbuf2)
                                        @memcpy(@ptradd(call_buf2 as ref void, call_pos2), pbuf2 as ref void, pbuf2_len)
                                        call_pos2 = call_pos2 + pbuf2_len
                                        @free(pbuf2)
                                    }
                                    none => {}
                                }
                                pi2++
                            }
                        }
                    }
                    none => {}
                }
            }
        }
        @store8(@ptradd(call_buf2 as ref void, call_pos2), 41) // ')'
        call_pos2++
        @store8(@ptradd(call_buf2 as ref void, call_pos2), 10) // '\n'
        call_pos2++
        @store8(@ptradd(call_buf2 as ref void, call_pos2), 0)
        emit(ctx, call_buf2)
    } elif str.rchar_cmp(name, "snprintf") == 0 {
        val sbuf: ref char = get_arg(ctx, args, 0)
        val ssz: ref char = get_arg(ctx, args, 1)
        val sfmt: ref char = get_format_arg(ctx, args, 2)
        val scall_buf: ref char = @alloc(4096) as ref char
        val scall_pos: mut i64 = 0
        val shdr: ref char = @alloc(256) as ref char
        @snprintf(shdr, 256, "    %%t%lld =w call $snprintf(l %s, l %s, l %s, ...", {tmp, sbuf, ssz, sfmt})
        val shdr_len: mut i64 = str.len_raw(shdr)
        @memcpy(@ptradd(scall_buf as ref void, scall_pos), shdr as ref void, shdr_len)
        scall_pos = scall_pos + shdr_len
        @free(shdr)
        if args != 0 as ref void {
            val salen: i64 = @len(args) as i64
            if salen > 3 {
                val spack_opt = @get(args, 3)
                match spack_opt {
                    some spack_node => {
                        val spn: ref parser.Node = spack_node as ref parser.Node
                        if spn.kind == parser.NK_ARGS_PACK {
                            val spack: ref void = spn.d0 as ref void
                            val splen: i64 = @len(spack) as i64
                            val spi: mut i64 = 0
                            for {
                                if spi >= splen { break }
                                val spe_opt = @get(spack, spi as usize)
                                match spe_opt {
                                    some spe => {
                                        val spe_node: ref parser.Node = spe as ref parser.Node
                                        val spqt: ref char = expr_qtype(ctx, spe_node)
                                        val spv: ref char = gen_expr(ctx, spe_node)
                                        val spbuf: mut ref char = @alloc(64) as ref char
                                        @snprintf(spbuf, 64, ", %s %s", {spqt, spv})
                                        val spbuf_len: mut i64 = str.len_raw(spbuf)
                                        @memcpy(@ptradd(scall_buf as ref void, scall_pos), spbuf as ref void, spbuf_len)
                                        scall_pos = scall_pos + spbuf_len
                                        @free(spbuf)
                                    }
                                    none => {}
                                }
                                spi++
                            }
                        }
                    }
                    none => {}
                }
            }
        }
        @store8(@ptradd(scall_buf as ref void, scall_pos), 41)
        scall_pos++
        @store8(@ptradd(scall_buf as ref void, scall_pos), 10)
        scall_pos++
        @store8(@ptradd(scall_buf as ref void, scall_pos), 0)
        emit(ctx, scall_buf)
        val sext_tmp: i64 = fresh_tmp(ctx)
        val sext_buf: ref char = @alloc(64) as ref char
        @snprintf(sext_buf, 64, "    %%t%lld =l extsw %%t%lld\n", {sext_tmp, tmp})
        emit(ctx, sext_buf)
        @free(sext_buf)
        @free(buf)
        val sres: ref char = @alloc(16) as ref char
        @snprintf(sres, 16, "%%t%lld", {sext_tmp})
        return sres
    } elif str.rchar_cmp(name, "strlen") == 0 {
        val s2: ref char = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    %%t%lld =l call $strlen(l %s)\n", {tmp, s2})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "strcmp") == 0 {
        val a: ref char = get_arg(ctx, args, 0)
        val b: ref char = get_arg(ctx, args, 1)
        @snprintf(buf, 512, "    %%t%lld =l call $strcmp(l %s, l %s)\n", {tmp, a, b})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "atoi") == 0 {
        val s3: ref char = get_arg(ctx, args, 0)
        @snprintf(buf, 512, "    %%t%lld =l call $atoi(l %s)\n", {tmp, s3})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "append") == 0 {
        val lst: ref char = get_list_arg(ctx, args, 0)
        val val5_node_opt = @get(args, 1)
        val val5_qtype: mut ref char = "l"
        val val5: ref char = get_arg(ctx, args, 1)
        match val5_node_opt {
            some vn => {
                val5_qtype = expr_qtype(ctx, vn as ref parser.Node)
            }
            none => {}
        }

        val len_slot: i64 = fresh_tmp(ctx)
        val cap_slot: i64 = fresh_tmp(ctx)
        val buf_app1: ref char = @alloc(256) as ref char
        @snprintf(buf_app1, 256, "    %%t%lld =l add %s, 8\n    %%t%lld =l add %s, 16\n", {len_slot, lst, cap_slot, lst})
        emit(ctx, buf_app1)
        @free(buf_app1)

        val len_val: i64 = fresh_tmp(ctx)
        val cap_val: i64 = fresh_tmp(ctx)
        val buf_app2: ref char = @alloc(256) as ref char
        @snprintf(buf_app2, 256, "    %%t%lld =l loadl %%t%lld\n    %%t%lld =l loadl %%t%lld\n", {len_val, len_slot, cap_val, cap_slot})
        emit(ctx, buf_app2)
        @free(buf_app2)

        val need_grow: i64 = fresh_tmp(ctx)
        val grow_lbl: i64 = fresh_lbl(ctx)
        val no_grow_lbl: i64 = fresh_lbl(ctx)
        val lt: i64 = fresh_tmp(ctx)
        val buf_app3: ref char = @alloc(256) as ref char
        @snprintf(buf_app3, 256, "    %%t%lld =w csltw %%t%lld, %%t%lld\n    %%t%lld =w ceqw %%t%lld, 0\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n", {lt, len_val, cap_val, need_grow, lt, need_grow, grow_lbl, no_grow_lbl})
        emit(ctx, buf_app3)
        @free(buf_app3)

        val buf_app4: ref char = @alloc(64) as ref char
        @snprintf(buf_app4, 64, "@lbl%lld\n", {grow_lbl})
        emit(ctx, buf_app4)
        @free(buf_app4)

        val new_cap_tmp: i64 = fresh_tmp(ctx)
        val new_cap: i64 = fresh_tmp(ctx)
        val buf_app5: ref char = @alloc(256) as ref char
        @snprintf(buf_app5, 256, "    %%t%lld =l mul %%t%lld, 2\n    %%t%lld =l add %%t%lld, 1\n", {new_cap_tmp, cap_val, new_cap, new_cap_tmp})
        emit(ctx, buf_app5)
        @free(buf_app5)

        val old_buf: i64 = fresh_tmp(ctx)
        val new_buf: i64 = fresh_tmp(ctx)
        val new_cap_bytes: i64 = fresh_tmp(ctx)
        val buf_app6: ref char = @alloc(512) as ref char
        @snprintf(buf_app6, 512, "    %%t%lld =l loadl %s\n    %%t%lld =l mul %%t%lld, 8\n    %%t%lld =l call $realloc(l %%t%lld, l %%t%lld)\n    storel %%t%lld, %s\n    storel %%t%lld, %%t%lld\n    jmp @lbl%lld\n",
            {old_buf, lst, new_cap_bytes, new_cap, new_buf, old_buf, new_cap_bytes, new_buf, lst, new_cap, cap_slot, no_grow_lbl})
        emit(ctx, buf_app6)
        @free(buf_app6)

        val buf_app7: ref char = @alloc(64) as ref char
        @snprintf(buf_app7, 64, "@lbl%lld\n", {no_grow_lbl})
        emit(ctx, buf_app7)
        @free(buf_app7)

        val buf_tmp: i64 = fresh_tmp(ctx)
        val off: i64 = fresh_tmp(ctx)
        val elem_ptr: i64 = fresh_tmp(ctx)
        val buf_app8a: ref char = @alloc(256) as ref char
        @snprintf(buf_app8a, 256, "    %%t%lld =l loadl %s\n    %%t%lld =l mul %%t%lld, 8\n    %%t%lld =l add %%t%lld, %%t%lld\n",
            {buf_tmp, lst, off, len_val, elem_ptr, buf_tmp, off})
        emit(ctx, buf_app8a)
        @free(buf_app8a)
        val store_val: mut ref char = val5
        if str.rchar_cmp(val5_qtype, "w") == 0 {
            val ext_tmp: i64 = fresh_tmp(ctx)
            val ext_buf: ref char = @alloc(64) as ref char
            val first_ch: i64 = @load8(@ptradd(val5 as ref void, 0)) as i64
            if ((first_ch >= 48 && first_ch <= 57) || first_ch == 45) {
                @snprintf(ext_buf, 64, "    %%t%lld =l copy %s\n", {ext_tmp, val5})
            } else {
                @snprintf(ext_buf, 64, "    %%t%lld =l extsw %s\n", {ext_tmp, val5})
            }
            emit(ctx, ext_buf)
            @free(ext_buf)
            val sv: ref char = @alloc(16) as ref char
            @snprintf(sv, 16, "%%t%lld", {ext_tmp})
            store_val = sv
        }
        val buf_app8b: ref char = @alloc(64) as ref char
        @snprintf(buf_app8b, 64, "    storel %s, %%t%lld\n", {store_val, elem_ptr})
        emit(ctx, buf_app8b)
        @free(buf_app8b)

        val new_len: i64 = fresh_tmp(ctx)
        val buf_app9: ref char = @alloc(256) as ref char
        @snprintf(buf_app9, 256, "    %%t%lld =l add %%t%lld, 1\n    storel %%t%lld, %%t%lld\n", {new_len, len_val, new_len, len_slot})
        emit(ctx, buf_app9)
        @free(buf_app9)

        @snprintf(buf, 512, "    %%t%lld =l copy 0\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "sizeof") == 0 {
        val arg_node_opt = @get(args, 0)
        val sizeof_val: mut i64 = 0
        match arg_node_opt {
            some arg_node => {
                val arg_nd: ref parser.Node = arg_node as ref parser.Node
                val arg_k: i64 = arg_nd.kind
                if arg_k == parser.NK_IDENT {
                    val vname: ref char = arg_nd.d0 as ref char
                    
                    val flds: ref void = cg_lookup_struct(ctx, vname)
                    if flds != 0 as ref void {
                        sizeof_val = struct_size(flds)
                    } else {
                        val ltype: ref char = cg_local_type(ctx, vname)
                        if str.rchar_cmp(ltype, "") != 0 {
                            val fake_ty: mut ref parser.Node = 0 as ref parser.Node
                            if str.rchar_cmp(ltype, "i8") == 0 || str.rchar_cmp(ltype, "u8") == 0 || str.rchar_cmp(ltype, "char") == 0 {
                                fake_ty = parser.make_node(parser.TY_NAMED, 0)
                                fake_ty.d0 = ltype as i64
                                sizeof_val = type_size(fake_ty)
                            } elif str.rchar_cmp(ltype, "i16") == 0 || str.rchar_cmp(ltype, "u16") == 0 {
                                fake_ty = parser.make_node(parser.TY_NAMED, 0)
                                fake_ty.d0 = ltype as i64
                                sizeof_val = type_size(fake_ty)
                            } elif str.rchar_cmp(ltype, "i32") == 0 || str.rchar_cmp(ltype, "u32") == 0 || str.rchar_cmp(ltype, "f32") == 0 {
                                fake_ty = parser.make_node(parser.TY_NAMED, 0)
                                fake_ty.d0 = ltype as i64
                                sizeof_val = type_size(fake_ty)
                            } elif str.rchar_cmp(ltype, "i64") == 0 || str.rchar_cmp(ltype, "u64") == 0 || str.rchar_cmp(ltype, "f64") == 0 {
                                sizeof_val = 8
                            } elif str.rchar_cmp(ltype, "bool") == 0 {
                                sizeof_val = 4
                            } else {
                                val flds2: ref void = cg_lookup_struct(ctx, ltype)
                                if flds2 != 0 as ref void {
                                    sizeof_val = struct_size(flds2)
                                } else {
                                    sizeof_val = 8
                                }
                            }
                        } else {
                            sizeof_val = 8
                        }
                    }
                } elif arg_k == parser.NK_CAST {
                    val ty: ref parser.Node = arg_nd.d1 as ref parser.Node
                    sizeof_val = type_size(ty)
                } else {
                    sizeof_val = 8
                }
            }
            none => {
                sizeof_val = 0
            }
        }
        @snprintf(buf, 512, "    %%t%lld =l copy %lld\n", {tmp, sizeof_val})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "len") == 0 {
        val lst2: ref char = get_list_arg(ctx, args, 0)
        val len_slot: i64 = fresh_tmp(ctx)
        val len_val: i64 = fresh_tmp(ctx)
        @snprintf(buf, 512, "    %%t%lld =l add %s, 8\n    %%t%lld =l loadl %%t%lld\n", {len_slot, lst2, len_val, len_slot})
        emit(ctx, buf)
        tmp = len_val
    } elif str.rchar_cmp(name, "get") == 0 {
        val lst3: ref char = get_list_arg(ctx, args, 0)
        val idx: ref char = get_arg(ctx, args, 1)

        val len_slot: i64 = fresh_tmp(ctx)
        val len_val: i64 = fresh_tmp(ctx)
        val buf_get1: ref char = @alloc(256) as ref char
        @snprintf(buf_get1, 256, "    %%t%lld =l add %s, 8\n    %%t%lld =l loadl %%t%lld\n", {len_slot, lst3, len_val, len_slot})
        emit(ctx, buf_get1)
        @free(buf_get1)

        val in_bounds: i64 = fresh_tmp(ctx)
        val some_lbl: i64 = fresh_lbl(ctx)
        val none_lbl: i64 = fresh_lbl(ctx)
        val end_lbl: i64 = fresh_lbl(ctx)
        val result_slot: i64 = fresh_tmp(ctx)

        val buf_get2: ref char = @alloc(256) as ref char
        @snprintf(buf_get2, 256, "    %%t%lld =l alloc8 8\n    %%t%lld =w csltl %s, %%t%lld\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n",
            {result_slot, in_bounds, idx, len_val, in_bounds, some_lbl, none_lbl})
        emit(ctx, buf_get2)
        @free(buf_get2)

        val buf_get3: ref char = @alloc(64) as ref char
        @snprintf(buf_get3, 64, "@lbl%lld\n", {some_lbl})
        emit(ctx, buf_get3)
        @free(buf_get3)

        val buf_get_tmp: i64 = fresh_tmp(ctx)
        val off: i64 = fresh_tmp(ctx)
        val elem_ptr: i64 = fresh_tmp(ctx)
        val elem_val: i64 = fresh_tmp(ctx)
        val some_val: i64 = fresh_tmp(ctx)

        val buf_get4: ref char = @alloc(512) as ref char
        @snprintf(buf_get4, 512, "    %%t%lld =l loadl %s\n    %%t%lld =l mul %s, 8\n    %%t%lld =l add %%t%lld, %%t%lld\n    %%t%lld =l loadl %%t%lld\n    %%t%lld =l add %%t%lld, 1\n    storel %%t%lld, %%t%lld\n    jmp @lbl%lld\n",
            {buf_get_tmp, lst3, off, idx, elem_ptr, buf_get_tmp, off, elem_val, elem_ptr, some_val, elem_val, some_val, result_slot, end_lbl})
        emit(ctx, buf_get4)
        @free(buf_get4)

        val buf_get5: ref char = @alloc(128) as ref char
        @snprintf(buf_get5, 128, "@lbl%lld\n    storel 0, %%t%lld\n    jmp @lbl%lld\n", {none_lbl, result_slot, end_lbl})
        emit(ctx, buf_get5)
        @free(buf_get5)

        val buf_get6: ref char = @alloc(128) as ref char
        @snprintf(buf_get6, 128, "@lbl%lld\n    %%t%lld =l loadl %%t%lld\n", {end_lbl, tmp, result_slot})
        emit(ctx, buf_get6)
        @free(buf_get6)
    } elif str.rchar_cmp(name, "remove") == 0 {
        val lst4: ref char = get_list_arg(ctx, args, 0)
        val idx2: ref char = get_arg(ctx, args, 1)

        val len_slot: i64 = fresh_tmp(ctx)
        val len_val: i64 = fresh_tmp(ctx)
        val buf_rem1: ref char = @alloc(256) as ref char
        @snprintf(buf_rem1, 256, "    %%t%lld =l add %s, 8\n    %%t%lld =l loadl %%t%lld\n", {len_slot, lst4, len_val, len_slot})
        emit(ctx, buf_rem1)
        @free(buf_rem1)

        val buf_tmp: i64 = fresh_tmp(ctx)
        val off: i64 = fresh_tmp(ctx)
        val elem_ptr: i64 = fresh_tmp(ctx)
        val elem_val: i64 = fresh_tmp(ctx)
        val buf_rem2: ref char = @alloc(512) as ref char
        @snprintf(buf_rem2, 512, "    %%t%lld =l loadl %s\n    %%t%lld =l mul %s, 8\n    %%t%lld =l add %%t%lld, %%t%lld\n    %%t%lld =l loadl %%t%lld\n",
            {buf_tmp, lst4, off, idx2, elem_ptr, buf_tmp, off, elem_val, elem_ptr})
        emit(ctx, buf_rem2)
        @free(buf_rem2)

        val shift_loop: i64 = fresh_lbl(ctx)
        val shift_body: i64 = fresh_lbl(ctx)
        val shift_end: i64 = fresh_lbl(ctx)
        val shift_idx: i64 = fresh_tmp(ctx)

        val buf_rem3: ref char = @alloc(256) as ref char
        @snprintf(buf_rem3, 256, "    %%t%lld =l copy %s\n    jmp @lbl%lld\n", {shift_idx, idx2, shift_loop})
        emit(ctx, buf_rem3)
        @free(buf_rem3)

        val buf_rem4: ref char = @alloc(64) as ref char
        @snprintf(buf_rem4, 64, "@lbl%lld\n", {shift_loop})
        emit(ctx, buf_rem4)
        @free(buf_rem4)

        val one_past_end: i64 = fresh_tmp(ctx)
        val should_shift: i64 = fresh_tmp(ctx)
        val buf_rem5: ref char = @alloc(256) as ref char
        @snprintf(buf_rem5, 256, "    %%t%lld =l sub %%t%lld, 1\n    %%t%lld =w csltl %%t%lld, %%t%lld\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n",
            {one_past_end, len_val, should_shift, shift_idx, one_past_end, should_shift, shift_body, shift_end})
        emit(ctx, buf_rem5)
        @free(buf_rem5)

        val buf_rem6: ref char = @alloc(64) as ref char
        @snprintf(buf_rem6, 64, "@lbl%lld\n", {shift_body})
        emit(ctx, buf_rem6)
        @free(buf_rem6)

        val src_off_tmp: i64 = fresh_tmp(ctx)
        val src_off_tmp2: i64 = fresh_tmp(ctx)
        val src_off: i64 = fresh_tmp(ctx)
        val dst_off: i64 = fresh_tmp(ctx)
        val src_ptr: i64 = fresh_tmp(ctx)
        val dst_ptr: i64 = fresh_tmp(ctx)
        val src_val: i64 = fresh_tmp(ctx)
        val buf_rem7: ref char = @alloc(512) as ref char
        @snprintf(buf_rem7, 512, "    %%t%lld =l add %%t%lld, 1\n    %%t%lld =l mul %%t%lld, 8\n    %%t%lld =l mul %%t%lld, 8\n    %%t%lld =l add %%t%lld, %%t%lld\n    %%t%lld =l add %%t%lld, %%t%lld\n    %%t%lld =l loadl %%t%lld\n    storel %%t%lld, %%t%lld\n",
            {src_off_tmp, shift_idx, src_off_tmp2, src_off_tmp, src_off, src_off_tmp2, src_ptr, buf_tmp, src_off, dst_ptr, buf_tmp, dst_off, src_val, src_ptr, src_val, dst_ptr})
        emit(ctx, buf_rem7)
        @free(buf_rem7)

        val shift_idx_new: i64 = fresh_tmp(ctx)
        val buf_rem8: ref char = @alloc(256) as ref char
        @snprintf(buf_rem8, 256, "    %%t%lld =l add %%t%lld, 1\n    %%t%lld =l copy %%t%lld\n    jmp @lbl%lld\n",
            {shift_idx_new, shift_idx, shift_idx, shift_idx_new, shift_loop})
        emit(ctx, buf_rem8)
        @free(buf_rem8)

        val buf_rem9: ref char = @alloc(64) as ref char
        @snprintf(buf_rem9, 64, "@lbl%lld\n", {shift_end})
        emit(ctx, buf_rem9)
        @free(buf_rem9)

        val new_len: i64 = fresh_tmp(ctx)
        val buf_rem10: ref char = @alloc(256) as ref char
        @snprintf(buf_rem10, 256, "    %%t%lld =l sub %%t%lld, 1\n    storel %%t%lld, %%t%lld\n", {new_len, len_val, new_len, len_slot})
        emit(ctx, buf_rem10)
        @free(buf_rem10)

        tmp = elem_val
    } elif str.rchar_cmp(name, "insert") == 0 {
        val lst_ins: ref char = get_list_arg(ctx, args, 0)
        val idx_ins: ref char = get_arg(ctx, args, 1)
        val val_ins: ref char = get_arg(ctx, args, 2)

        val len_slot: i64 = fresh_tmp(ctx)
        val cap_slot: i64 = fresh_tmp(ctx)
        val len_val: i64 = fresh_tmp(ctx)
        val cap_val: i64 = fresh_tmp(ctx)
        val buf_ins1: ref char = @alloc(512) as ref char
        @snprintf(buf_ins1, 512, "    %%t%lld =l add %s, 8\n    %%t%lld =l add %s, 16\n    %%t%lld =l loadl %%t%lld\n    %%t%lld =l loadl %%t%lld\n",
            {len_slot, lst_ins, cap_slot, lst_ins, len_val, len_slot, cap_val, cap_slot})
        emit(ctx, buf_ins1)
        @free(buf_ins1)

        val need_grow: i64 = fresh_tmp(ctx)
        val grow_lbl: i64 = fresh_lbl(ctx)
        val no_grow_lbl: i64 = fresh_lbl(ctx)
        val lt: i64 = fresh_tmp(ctx)
        val buf_ins2: ref char = @alloc(256) as ref char
        @snprintf(buf_ins2, 256, "    %%t%lld =w csltw %%t%lld, %%t%lld\n    %%t%lld =w ceqw %%t%lld, 0\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n", {lt, len_val, cap_val, need_grow, lt, need_grow, grow_lbl, no_grow_lbl})
        emit(ctx, buf_ins2)
        @free(buf_ins2)

        val buf_ins3: ref char = @alloc(64) as ref char
        @snprintf(buf_ins3, 64, "@lbl%lld\n", {grow_lbl})
        emit(ctx, buf_ins3)
        @free(buf_ins3)

        val new_cap: i64 = fresh_tmp(ctx)
        val new_cap2: i64 = fresh_tmp(ctx)
        val buf_ins4: ref char = @alloc(256) as ref char
        @snprintf(buf_ins4, 256, "    %%t%lld =l mul %%t%lld, 2\n    %%t%lld =l add %%t%lld, 1\n", {new_cap, cap_val, new_cap2, new_cap})
        emit(ctx, buf_ins4)
        @free(buf_ins4)

        val old_buf: i64 = fresh_tmp(ctx)
        val new_buf: i64 = fresh_tmp(ctx)
        val new_cap2_bytes: i64 = fresh_tmp(ctx)
        val buf_ins5: ref char = @alloc(512) as ref char
        @snprintf(buf_ins5, 512, "    %%t%lld =l loadl %s\n    %%t%lld =l mul %%t%lld, 8\n    %%t%lld =l call $realloc(l %%t%lld, l %%t%lld)\n    storel %%t%lld, %s\n    storel %%t%lld, %%t%lld\n    jmp @lbl%lld\n",
            {old_buf, lst_ins, new_cap2_bytes, new_cap2, new_buf, old_buf, new_cap2_bytes, new_buf, lst_ins, new_cap2, cap_slot, no_grow_lbl})
        emit(ctx, buf_ins5)
        @free(buf_ins5)

        val buf_ins6: ref char = @alloc(64) as ref char
        @snprintf(buf_ins6, 64, "@lbl%lld\n", {no_grow_lbl})
        emit(ctx, buf_ins6)
        @free(buf_ins6)

        val shift_loop: i64 = fresh_lbl(ctx)
        val shift_body: i64 = fresh_lbl(ctx)
        val shift_end: i64 = fresh_lbl(ctx)
        val shift_idx: i64 = fresh_tmp(ctx)

        val buf_ins7: ref char = @alloc(256) as ref char
        @snprintf(buf_ins7, 256, "    %%t%lld =l sub %%t%lld, 1\n    jmp @lbl%lld\n", {shift_idx, len_val, shift_loop})
        emit(ctx, buf_ins7)
        @free(buf_ins7)

        val buf_ins8: ref char = @alloc(64) as ref char
        @snprintf(buf_ins8, 64, "@lbl%lld\n", {shift_loop})
        emit(ctx, buf_ins8)
        @free(buf_ins8)

        val should_shift: i64 = fresh_tmp(ctx)
        val buf_ins9: ref char = @alloc(256) as ref char
        @snprintf(buf_ins9, 256, "    %%t%lld =w cslel %s, %%t%lld\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n",
            {should_shift, idx_ins, shift_idx, should_shift, shift_body, shift_end})
        emit(ctx, buf_ins9)
        @free(buf_ins9)

        val buf_ins10: ref char = @alloc(64) as ref char
        @snprintf(buf_ins10, 64, "@lbl%lld\n", {shift_body})
        emit(ctx, buf_ins10)
        @free(buf_ins10)

        val src_off: i64 = fresh_tmp(ctx)
        val dst_off_tmp: i64 = fresh_tmp(ctx)
        val dst_off: i64 = fresh_tmp(ctx)
        val src_ptr: i64 = fresh_tmp(ctx)
        val dst_ptr: i64 = fresh_tmp(ctx)
        val src_val: i64 = fresh_tmp(ctx)
        val buf2: i64 = fresh_tmp(ctx)
        val buf_ins11: ref char = @alloc(512) as ref char
        @snprintf(buf_ins11, 512, "    %%t%lld =l mul %%t%lld, 8\n    %%t%lld =l add %%t%lld, 1\n    %%t%lld =l mul %%t%lld, 8\n    %%t%lld =l loadl %s\n    %%t%lld =l add %%t%lld, %%t%lld\n    %%t%lld =l add %%t%lld, %%t%lld\n    %%t%lld =l loadl %%t%lld\n    storel %%t%lld, %%t%lld\n",
            {src_off, shift_idx, dst_off_tmp, shift_idx, dst_off, dst_off_tmp, buf2, lst_ins, src_ptr, buf2, src_off, dst_ptr, buf2, dst_off, src_val, src_ptr, src_val, dst_ptr})
        emit(ctx, buf_ins11)
        @free(buf_ins11)

        val shift_idx_new: i64 = fresh_tmp(ctx)
        val buf_ins12: ref char = @alloc(256) as ref char
        @snprintf(buf_ins12, 256, "    %%t%lld =l sub %%t%lld, 1\n    %%t%lld =l copy %%t%lld\n    jmp @lbl%lld\n",
            {shift_idx_new, shift_idx, shift_idx, shift_idx_new, shift_loop})
        emit(ctx, buf_ins12)
        @free(buf_ins12)

        val buf_ins13: ref char = @alloc(64) as ref char
        @snprintf(buf_ins13, 64, "@lbl%lld\n", {shift_end})
        emit(ctx, buf_ins13)
        @free(buf_ins13)

        val buf3: i64 = fresh_tmp(ctx)
        val elem_off: i64 = fresh_tmp(ctx)
        val elem_ptr: i64 = fresh_tmp(ctx)
        val buf_ins14: ref char = @alloc(512) as ref char
        @snprintf(buf_ins14, 512, "    %%t%lld =l loadl %s\n    %%t%lld =l mul %s, 8\n    %%t%lld =l add %%t%lld, %%t%lld\n    storel %s, %%t%lld\n",
            {buf3, lst_ins, elem_off, idx_ins, elem_ptr, buf3, elem_off, val_ins, elem_ptr})
        emit(ctx, buf_ins14)
        @free(buf_ins14)

        val new_len: i64 = fresh_tmp(ctx)
        val buf_ins15: ref char = @alloc(256) as ref char
        @snprintf(buf_ins15, 256, "    %%t%lld =l add %%t%lld, 1\n    storel %%t%lld, %%t%lld\n", {new_len, len_val, new_len, len_slot})
        emit(ctx, buf_ins15)
        @free(buf_ins15)

        @snprintf(buf, 512, "    %%t%lld =l copy 0\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "reserve") == 0 {
        val lst5: ref char = get_list_arg(ctx, args, 0)
        val cap: ref char = get_arg(ctx, args, 1)

        val cap_slot: i64 = fresh_tmp(ctx)
        val cur_cap: i64 = fresh_tmp(ctx)
        val buf_res1: ref char = @alloc(256) as ref char
        @snprintf(buf_res1, 256, "    %%t%lld =l add %s, 16\n    %%t%lld =l loadl %%t%lld\n", {cap_slot, lst5, cur_cap, cap_slot})
        emit(ctx, buf_res1)
        @free(buf_res1)

        val need_grow: i64 = fresh_tmp(ctx)
        val grow_lbl: i64 = fresh_lbl(ctx)
        val end_lbl: i64 = fresh_lbl(ctx)
        val buf_res2: ref char = @alloc(256) as ref char
        @snprintf(buf_res2, 256, "    %%t%lld =w csgtl %s, %%t%lld\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n",
            {need_grow, cap, cur_cap, need_grow, grow_lbl, end_lbl})
        emit(ctx, buf_res2)
        @free(buf_res2)

        val buf_res3: ref char = @alloc(64) as ref char
        @snprintf(buf_res3, 64, "@lbl%lld\n", {grow_lbl})
        emit(ctx, buf_res3)
        @free(buf_res3)

        val old_buf: i64 = fresh_tmp(ctx)
        val new_buf: i64 = fresh_tmp(ctx)
        val new_bytes: i64 = fresh_tmp(ctx)
        val buf_res4: ref char = @alloc(512) as ref char
        @snprintf(buf_res4, 512, "    %%t%lld =l loadl %s\n    %%t%lld =l mul %s, 8\n    %%t%lld =l call $realloc(l %%t%lld, l %%t%lld)\n    storel %%t%lld, %s\n    storel %s, %%t%lld\n",
            {old_buf, lst5, new_bytes, cap, new_buf, old_buf, new_bytes, new_buf, lst5, cap, cap_slot})
        emit(ctx, buf_res4)
        @free(buf_res4)

        val buf_res5: ref char = @alloc(64) as ref char
        @snprintf(buf_res5, 64, "@lbl%lld\n", {end_lbl})
        emit(ctx, buf_res5)
        @free(buf_res5)

        @snprintf(buf, 512, "    %%t%lld =l copy 0\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "capacity") == 0 {
        val lst6: ref char = get_list_arg(ctx, args, 0)
        val cap_slot: i64 = fresh_tmp(ctx)
        val cap_val: i64 = fresh_tmp(ctx)
        @snprintf(buf, 512, "    %%t%lld =l add %s, 16\n    %%t%lld =l loadl %%t%lld\n", {cap_slot, lst6, cap_val, cap_slot})
        emit(ctx, buf)
        tmp = cap_val
    } elif str.rchar_cmp(name, "fmt") == 0 {
        val fmt2: ref char = get_format_arg(ctx, args, 0)
        val fmt_buf: i64 = fresh_tmp(ctx)
        val fmt_written_w: i64 = fresh_tmp(ctx)
        val fmt_written: i64 = fresh_tmp(ctx)
        val fmt_copy_size: i64 = fresh_tmp(ctx)
        val fmt_copy: i64 = fresh_tmp(ctx)
        val fmt_nul: i64 = fresh_tmp(ctx)
        val fmt_call_buf: ref char = @alloc(4096) as ref char
        val fmt_call_pos: mut i64 = 0
        val fmt_hdr: ref char = @alloc(256) as ref char

        @snprintf(fmt_hdr, 256, "    %%t%lld =l call $malloc(l 4096)\n", {fmt_buf})
        val fmt_hdr_len: mut i64 = str.len_raw(fmt_hdr)
        @memcpy(@ptradd(fmt_call_buf as ref void, fmt_call_pos), fmt_hdr as ref void, fmt_hdr_len)
        fmt_call_pos = fmt_call_pos + fmt_hdr_len
        @free(fmt_hdr)
        emit(ctx, fmt_call_buf)
        fmt_call_pos = 0

        val snp_hdr: ref char = @alloc(256) as ref char
        @snprintf(snp_hdr, 256, "    %%t%lld =w call $snprintf(l %%t%lld, l 4096, l %s", {fmt_written_w, fmt_buf, fmt2})
        val snp_hdr_len: mut i64 = str.len_raw(snp_hdr)
        @memcpy(@ptradd(fmt_call_buf as ref void, fmt_call_pos), snp_hdr as ref void, snp_hdr_len)
        fmt_call_pos = fmt_call_pos + snp_hdr_len
        @free(snp_hdr)

        if args != 0 as ref void {
            val falen: i64 = @len(args) as i64
            if falen > 1 {
                val fpack_opt = @get(args, 1)
                match fpack_opt {
                    some fpack_node => {
                        val fpn: ref parser.Node = fpack_node as ref parser.Node
                        if fpn.kind == parser.NK_ARGS_PACK {
                            val fpack: ref void = fpn.d0 as ref void
                            val fplen: i64 = @len(fpack) as i64
                            if fplen > 0 {
                                val sep_buf: ref char = @alloc(8) as ref char
                                @snprintf(sep_buf, 8, ", ...,")
                                val sep_len: mut i64 = str.len_raw(sep_buf)
                                @memcpy(@ptradd(fmt_call_buf as ref void, fmt_call_pos), sep_buf as ref void, sep_len)
                                fmt_call_pos = fmt_call_pos + sep_len
                                @free(sep_buf)
                                val fpi: mut i64 = 0
                                for {
                                    if fpi >= fplen { break }
                                    val fpe_opt = @get(fpack, fpi as usize)
                                    match fpe_opt {
                                        some fpe => {
                                            val fpe_node: ref parser.Node = fpe as ref parser.Node
                                            val fpqt: ref char = expr_qtype(ctx, fpe_node)
                                            val fpv: ref char = gen_expr(ctx, fpe_node)
                                            val fpbuf: ref char = @alloc(64) as ref char
                                            if fpi == 0 {
                                                @snprintf(fpbuf, 64, " %s %s", {fpqt, fpv})
                                            } else {
                                                @snprintf(fpbuf, 64, ", %s %s", {fpqt, fpv})
                                            }
                                            val fpbuf_len: mut i64 = str.len_raw(fpbuf)
                                            @memcpy(@ptradd(fmt_call_buf as ref void, fmt_call_pos), fpbuf as ref void, fpbuf_len)
                                            fmt_call_pos = fmt_call_pos + fpbuf_len
                                            @free(fpbuf)
                                        }
                                        none => {}
                                    }
                                    fpi++
                                }
                            }
                        }
                    }
                    none => {}
                }
            }
        }
        @store8(@ptradd(fmt_call_buf as ref void, fmt_call_pos), 41) // ')'
        fmt_call_pos++
        @store8(@ptradd(fmt_call_buf as ref void, fmt_call_pos), 10) // '\n'
        fmt_call_pos++
        @store8(@ptradd(fmt_call_buf as ref void, fmt_call_pos), 0)
        emit(ctx, fmt_call_buf)
        // extsw, malloc copy, memcpy, nul-terminate, free buf
        val tail_buf: ref char = @alloc(512) as ref char
        @snprintf(tail_buf, 512, "    %%t%lld =l extsw %%t%lld\n    %%t%lld =l add %%t%lld, 1\n    %%t%lld =l call $malloc(l %%t%lld)\n    call $memcpy(l %%t%lld, l %%t%lld, l %%t%lld)\n    %%t%lld =l add %%t%lld, %%t%lld\n    storeb 0, %%t%lld\n    call $free(l %%t%lld)\n",
            {fmt_written, fmt_written_w,
             fmt_copy_size, fmt_written,
             fmt_copy, fmt_copy_size,
             fmt_copy, fmt_buf, fmt_written,
             fmt_nul, fmt_copy, fmt_written,
             fmt_nul,
             fmt_buf})
        emit(ctx, tail_buf)
        @free(tail_buf)
        @snprintf(buf, 512, "    %%t%lld =l copy %%t%lld\n", {tmp, fmt_copy})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "args") == 0 {
        @snprintf(buf, 512, "    %%t%lld =l call $__sx_get_args()\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "stdin") == 0 {
        @snprintf(buf, 512, "    %%t%lld =l call $sx_stdin()\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "stdout") == 0 {
        @snprintf(buf, 512, "    %%t%lld =l call $sx_stdout()\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "stderr") == 0 {
        @snprintf(buf, 512, "    %%t%lld =l call $sx_stderr()\n", {tmp})
        emit(ctx, buf)
    } elif str.rchar_cmp(name, "call") == 0 {
        val fn_ptr: ref char = get_arg(ctx, args, 0)
        val call_sb2: ref void = str.StringBuilder.new()
        val hdr3: ref void = str.format("    %%t%lld =l call %s(", {tmp, fn_ptr})
        str.StringBuilder.append(call_sb2, hdr3)
        if args != 0 as ref void {
            val alen3: i64 = @len(args) as i64
            val ai3: mut i64 = 1
            val first3: mut bool = true
            for {
                if ai3 >= alen3 { break }
                val a3_opt = @get(args, ai3 as usize)
                match a3_opt {
                    some a3 => {
                        val a3_node: ref parser.Node = a3 as ref parser.Node
                        val at3: ref char = gen_expr(ctx, a3_node)
                        if !first3 { str.StringBuilder.append_cstr(call_sb2, ", ") }
                        val qtype3: ref char = expr_qtype(ctx, a3_node)
                        val tbuf4: ref void = str.format("%s %s", {qtype3, at3})
                        str.StringBuilder.append(call_sb2, tbuf4)
                        first3 = false
                    }
                    none => {}
                }
                ai3++
            }
        }
        str.StringBuilder.append_cstr(call_sb2, ")\n")
        val call_line3: ref void = str.StringBuilder.build(call_sb2)
        str.StringBuilder.free(call_sb2)
        emit(ctx, str.cstr(call_line3))
    } else {
        val call_sb: ref void = str.StringBuilder.new()
        val hdr2: mut ref void = str.format("    %%t%lld =l call $%s(", {tmp, name})
        str.StringBuilder.append(call_sb, hdr2)
        if args != 0 as ref void {
            val alen: i64 = @len(args) as i64
            val ai: mut i64 = 0
            val arg_nodes: mut list[ref parser.Node] = []
            val arg_tmps2: mut list[ref char] = []
            for {
                if ai >= alen { break }
                val a_opt = @get(args, ai as usize)
                match a_opt {
                    some a => {
                        val a_node: ref parser.Node = a as ref parser.Node
                        val ak: i64 = a_node.kind
                        if ak == parser.NK_ARGS_PACK {
                            val pack: ref void = a_node.d0 as ref void
                            val plen: i64 = @len(pack) as i64
                            val pi: mut i64 = 0
                            for {
                                if pi >= plen { break }
                                val pe_opt = @get(pack, pi as usize)
                                match pe_opt {
                                    some pe => {
                                        val pe_node: ref parser.Node = pe as ref parser.Node
                                        val at: ref char = gen_expr(ctx, pe_node)
                                        @append(arg_nodes, pe_node)
                                        @append(arg_tmps2, at)
                                    }
                                    none => {}
                                }
                                pi++
                            }
                        } else {
                            val at: ref char = gen_expr(ctx, a_node)
                            @append(arg_nodes, a_node)
                            @append(arg_tmps2, at)
                        }
                    }
                    none => {}
                }
                ai++
            }
            val tlen3: i64 = @len(arg_tmps2) as i64
            val ti3: mut i64 = 0
            for {
                if ti3 >= tlen3 { break }
                val t3_opt = @get(arg_tmps2, ti3 as usize)
                val n_opt = @get(arg_nodes, ti3 as usize)
                match t3_opt {
                    some t3 => {
                        if ti3 > 0 { str.StringBuilder.append_cstr(call_sb, ", ") }
                        val qtype: mut ref char = "l"
                        match n_opt {
                            some n => {
                                val qt: ref char = expr_qtype(ctx, n as ref parser.Node)
                                if str.rchar_cmp(qt, "") != 0 {
                                    qtype = qt
                                }
                            }
                            none => {}
                        }
                        val tbuf3: ref void = str.format("%s %s", {qtype, t3 as ref char})
                        str.StringBuilder.append(call_sb, tbuf3)
                    }
                    none => {}
                }
                ti3++
            }
        }
        str.StringBuilder.append_cstr(call_sb, ")")
        val call_line2: ref void = str.StringBuilder.build(call_sb)
        str.StringBuilder.free(call_sb)
        emitln(ctx, str.cstr(call_line2))
    }

    @free(buf)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t%lld", {tmp})
    return res
}

fn gen_list_lit(ctx: ref CgCtx, expr: ref parser.Node) ref char! = {
    val elems: ref void = expr.d0 as ref void
    val elen: mut i64 = 0
    if elems != 0 as ref void { elen = @len(elems) as i64 }

    val cap: mut i64 = 1
    if elen > 0 { cap = elen }

    val hdr_ptr: i64 = fresh_tmp(ctx)
    val buf_ptr: i64 = fresh_tmp(ctx)
    val buf1: ref char = @alloc(128) as ref char
    @snprintf(buf1, 128, "    %%t%lld =l call $malloc(l 24)\n", {hdr_ptr})
    emit(ctx, buf1)
    @free(buf1)

    val buf2: ref char = @alloc(128) as ref char
    @snprintf(buf2, 128, "    %%t%lld =l call $malloc(l %lld)\n", {buf_ptr, cap * 8})
    emit(ctx, buf2)
    @free(buf2)

    val buf3: ref char = @alloc(128) as ref char
    @snprintf(buf3, 128, "    storel %%t%lld, %%t%lld\n", {buf_ptr, hdr_ptr})
    emit(ctx, buf3)
    @free(buf3)

    val len_slot: i64 = fresh_tmp(ctx)
    val cap_slot: i64 = fresh_tmp(ctx)
    val buf4: ref char = @alloc(128) as ref char
    @snprintf(buf4, 128, "    %%t%lld =l add %%t%lld, 8\n", {len_slot, hdr_ptr})
    emit(ctx, buf4)
    @free(buf4)

    val buf5: ref char = @alloc(128) as ref char
    @snprintf(buf5, 128, "    %%t%lld =l add %%t%lld, 16\n", {cap_slot, hdr_ptr})
    emit(ctx, buf5)
    @free(buf5)

    val buf6: ref char = @alloc(128) as ref char
    @snprintf(buf6, 128, "    storel %lld, %%t%lld\n", {elen, len_slot})
    emit(ctx, buf6)
    @free(buf6)

    val buf7: ref char = @alloc(128) as ref char
    @snprintf(buf7, 128, "    storel %lld, %%t%lld\n", {cap, cap_slot})
    emit(ctx, buf7)
    @free(buf7)

    if elems != 0 as ref void {
        val ei: mut i64 = 0
        for {
            if ei >= elen { break }
            val e_opt = @get(elems, ei as usize)
            match e_opt {
                some e => {
                    val val_tmp: ref char = gen_expr(ctx, e as ref parser.Node)
                    val off: i64 = fresh_tmp(ctx)
                    val elem_ptr: i64 = fresh_tmp(ctx)

                    val buf8: ref char = @alloc(128) as ref char
                    @snprintf(buf8, 128, "    %%t%lld =l mul %lld, 8\n", {off, ei})
                    emit(ctx, buf8)
                    @free(buf8)

                    val buf9: ref char = @alloc(128) as ref char
                    @snprintf(buf9, 128, "    %%t%lld =l add %%t%lld, %%t%lld\n", {elem_ptr, buf_ptr, off})
                    emit(ctx, buf9)
                    @free(buf9)

                    val buf10: ref char = @alloc(128) as ref char
                    @snprintf(buf10, 128, "    storel %s, %%t%lld\n", {val_tmp, elem_ptr})
                    emit(ctx, buf10)
                    @free(buf10)
                }
                none => {}
            }
            ei++
        }
    }

    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t%lld", {hdr_ptr})
    return res
}

fn gen_struct_lit(ctx: ref CgCtx, expr: ref parser.Node) ref char! = {
    val fields: ref void = expr.d0 as ref void
    val flen: mut i64 = 0
    if fields != 0 as ref void { flen = @len(fields) as i64 }

    val struct_fields: mut ref void = 0 as ref void
    if flen > 0 {
        val f0_opt = @get(fields, 0)
        match f0_opt {
            some f0 => {
                val fname0: ref char = (f0 as ref parser.Node).d0 as ref char
                val snames: ref void = cg_snames(ctx)
                val slen: i64 = @len(snames as list[ref char]) as i64
                val si: mut i64 = 0
                for {
                    if si >= slen { break }
                    val sn_opt = @get(snames as list[ref char], si as usize)
                    match sn_opt {
                        some sn => {
                            val sf_opt = @get(cg_sfields(ctx) as list[ref void], si as usize)
                            match sf_opt {
                                some sf => {
                                    val sfields: ref void = sf as ref void
                                    val off: i64 = field_offset(sfields, fname0)
                                    if off >= 0 {
                                        struct_fields = sfields
                                        si = slen // break
                                    }
                                }
                                none => {}
                            }
                        }
                        none => {}
                    }
                    si++
                }
            }
            none => {}
        }
    }

    // Compute the total allocation size using the actual field sizes
    // (instead of some arbitrary number)
    val size: mut i64 = flen * 8
    if struct_fields != 0 as ref void {
        val sflen: i64 = @len(struct_fields as list[ref void]) as i64
        val has_fa: bool = fields_have_fixed_arr(struct_fields)
        val total: mut i64 = 0
        val sfi: mut i64 = 0
        for {
            if sfi >= sflen { break }
            val sf_opt = @get(struct_fields as list[ref void], sfi as usize)
            match sf_opt {
                some sf => {
                    val sfnode: ref parser.Node = sf as ref parser.Node
                    val sfty: ref parser.Node = sfnode.d2 as ref parser.Node
                    val fsize: i64 = type_size(sfty)
                    if has_fa {
                        val align: i64 = type_align(sfty)
                        total = align_to(total, align) + fsize
                    } else {
                        total = total + align_to(fsize, 8)
                    }
                }
                none => {}
            }
            sfi++
        }
        size = total
    }

    val tmp: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(128) as ref char
    @snprintf(buf, 128, "    %%t%lld =l call $malloc(l %lld)\n", {tmp, size})
    emit(ctx, buf)
    @free(buf)
    val fi: mut i64 = 0
    for {
        if fi >= flen { break }
        val f_opt = @get(fields, fi as usize)
        match f_opt {
            some f => {
                val fnode: ref parser.Node = f as ref parser.Node
                val fname: ref char = fnode.d0 as ref char
                val fexpr_node: ref parser.Node = fnode.d1 as ref parser.Node
                val off: mut i64 = fi * 8
                val fty_node: mut ref parser.Node = 0 as ref parser.Node
                if struct_fields != 0 as ref void {
                    val real_off: i64 = field_offset(struct_fields, fname)
                    if real_off >= 0 { off = real_off }
                    val sflen2: i64 = @len(struct_fields as list[ref void]) as i64
                    val sfi2: mut i64 = 0
                    for {
                        if sfi2 >= sflen2 { break }
                        val sf2_opt = @get(struct_fields as list[ref void], sfi2 as usize)
                        match sf2_opt {
                            some sf2 => {
                                val sfn2: ref parser.Node = sf2 as ref parser.Node
                                val sfname2: ref char = sfn2.d0 as ref char
                                if str.rchar_cmp(sfname2, fname) == 0 {
                                    fty_node = sfn2.d2 as ref parser.Node
                                    sfi2 = sflen2 // break
                                }
                            }
                            none => {}
                        }
                        sfi2++
                    }
                }
                val is_fa: bool = fty_node != 0 as ref parser.Node && fty_node.kind == parser.TY_FIXED_ARR
                if is_fa {
                    val fa_size: i64 = type_size(fty_node)
                    val off_tmp2: i64 = fresh_tmp(ctx)
                    val fbuf2: ref char = @alloc(256) as ref char
                    @snprintf(fbuf2, 256, "    %%t%lld =l add %%t%lld, %lld\n", {off_tmp2, tmp, off})
                    emit(ctx, fbuf2)
                    @free(fbuf2)
                    val is_zero: bool = fexpr_node.kind == parser.NK_INT_LIT && str.rchar_cmp(fexpr_node.d0 as ref char, "0") == 0
                    if is_zero {
                        val fbuf3: ref char = @alloc(128) as ref char
                        @snprintf(fbuf3, 128, "    call $memset(l %%t%lld, w 0, l %lld)\n", {off_tmp2, fa_size})
                        emit(ctx, fbuf3)
                        @free(fbuf3)
                    } else {
                        val fval2: ref char = gen_expr(ctx, fexpr_node)
                        val fbuf3: ref char = @alloc(128) as ref char
                        @snprintf(fbuf3, 128, "    call $memcpy(l %%t%lld, l %s, l %lld)\n", {off_tmp2, fval2, fa_size})
                        emit(ctx, fbuf3)
                        @free(fbuf3)
                    }
                } else {
                    val fval: ref char = gen_expr(ctx, fexpr_node)
                    val fbuf: ref char = @alloc(128) as ref char
                    val off_tmp: i64 = fresh_tmp(ctx)
                    if off == 0 {
                        @snprintf(fbuf, 128, "    storel %s, %%t%lld\n", {fval, tmp})
                    } else {
                        @snprintf(fbuf, 128, "    %%t%lld =l add %%t%lld, %lld\n    storel %s, %%t%lld\n",
                            {off_tmp, tmp, off, fval, off_tmp})
                    }
                    emit(ctx, fbuf)
                    @free(fbuf)
                }
            }
            none => {}
        }
        fi++
    }
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t%lld", {tmp})
    return res
}

fn gen_try(ctx: ref CgCtx, expr: ref parser.Node) ref char! = {
    // expr? — if tag==0 (ok), unwrap value; if tag==1 (err), return result as-is
    val inner_node: ref parser.Node = expr.d0 as ref parser.Node
    val inner: ref char = gen_expr(ctx, inner_node)
    val tag_tmp: i64 = fresh_tmp(ctx)
    val ok_lbl: i64 = fresh_lbl(ctx)
    val err_lbl: i64 = fresh_lbl(ctx)
    val is_ok: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(256) as ref char
    @snprintf(buf, 256,
        "    %%t%lld =l loadl %s\n    %%t%lld =w ceql %%t%lld, 0\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n@lbl%lld\n",
        {tag_tmp, inner, is_ok, tag_tmp, is_ok, ok_lbl, err_lbl, err_lbl})
    emit(ctx, buf)
    @free(buf)

    // err branch: return the result as-is
    val rbuf: ref char = @alloc(64) as ref char
    @snprintf(rbuf, 64, "    ret %s\n@lbl%lld\n", {inner, ok_lbl})
    emit(ctx, rbuf)
    @free(rbuf)

    // ok branch: load value at offset 8
    val off_tmp: i64 = fresh_tmp(ctx)
    val val_tmp: i64 = fresh_tmp(ctx)
    val vbuf: ref char = @alloc(128) as ref char
    @snprintf(vbuf, 128, "    %%t%lld =l add %s, 8\n    %%t%lld =l loadl %%t%lld\n",
        {off_tmp, inner, val_tmp, off_tmp})
    emit(ctx, vbuf)
    @free(vbuf)
    val res: ref char = @alloc(16) as ref char
    @snprintf(res, 16, "%%t%lld", {val_tmp})
    return res
}

/// Returns true if the last statement in a list is a terminator (return/break/continue).
fn stmts_terminated(stmts: ref parser.Node) bool! = {
    if stmts == 0 as ref parser.Node { return false }
    val len: i64 = @len(stmts) as i64
    if len == 0 { return false }
    val last_opt = @get(stmts, (len - 1) as usize)
    match last_opt {
        some last => {
            val s: ref parser.Node = last as ref parser.Node
            val k: i64 = s.kind
            if k == parser.NK_RETURN  { return true }
            if k == parser.NK_BREAK   { return true }
            if k == parser.NK_CONTINUE { return true }
            return false
        }
        none => { return false }
    }
}

/// Returns true if the active branch of a NK_WHEN_STMT is terminated.
fn when_stmt_terminated(stmt: ref parser.Node) bool! = {
    val plat: ref char = stmt.d0 as ref char
    if platform_matches(plat) {
        return stmts_terminated(stmt.d1 as ref parser.Node)
    }
    val or_when_branches: ref void = stmt.d2 as ref void
    if or_when_branches != 0 as ref void {
        for ow_node in or_when_branches as list[ref parser.Node] {
            val ow_plat: ref char = ow_node.d0 as ref char
            if platform_matches(ow_plat) {
                return stmts_terminated(ow_node.d1 as ref parser.Node)
            }
        }
    }
    val otherwise_stmts: ref void = stmt.d3 as ref void
    if otherwise_stmts != 0 as ref void {
        return stmts_terminated(stmt.d3 as ref parser.Node)
    }
    return false
}

fn gen_stmts(ctx: ref CgCtx, stmts: ref parser.Node) void! = {
    if stmts == 0 as ref parser.Node { return }
    val len: i64 = @len(stmts) as i64
    val i: mut i64 = 0
    for {
        if i >= len { break }
        val s_opt = @get(stmts, i as usize)
        match s_opt {
            some s => {
                val snode: ref parser.Node = s as ref parser.Node
                gen_stmt(ctx, snode)
                if snode.kind == parser.NK_WHEN_STMT {
                    if when_stmt_terminated(snode) { break }
                }
            }
            none => {}
        }
        i++
    }
}

fn gen_stmt(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    if stmt == 0 as ref parser.Node { return }
    val k: i64 = stmt.kind

    if k == parser.NK_VAL {
        val name: ref char = stmt.d0 as ref char
        val mutable: i64 = stmt.d1
        val ty_node: ref parser.Node = stmt.d2 as ref parser.Node
        val expr: ref parser.Node = stmt.d3 as ref parser.Node
        val val_tmp: ref char = gen_expr(ctx, expr)

        if ty_node != 0 as ref parser.Node {
            val tname: ref char = unwrap_type_name(ty_node)
            if str.rchar_cmp(tname, "") != 0 {
                cg_register_local_type(ctx, name, tname)
            }
            // Track if this is a reference type
            if is_ref_type(ty_node) {
                cg_register_local_ref_type(ctx, name)
            }
        }

        if mutable != 0 {
            val qbe_tmp: i64 = fresh_tmp(ctx)
            val qbe_name: ref char = @alloc(32) as ref char
            @snprintf(qbe_name, 32, "%lld", {qbe_tmp})

            val buf: ref char = @alloc(256) as ref char
            val store_op: mut ref char = "storel"
            val is_ref: bool = ty_node != 0 as ref parser.Node && is_ref_type(ty_node)

            if !is_ref {
                val ltype2: ref char = cg_local_type(ctx, name)
                if str.rchar_cmp(ltype2, "f64") == 0 { store_op = "stored" }
                elif str.rchar_cmp(ltype2, "f32") == 0 { store_op = "stores" }
                elif is_word_type_name(ltype2) { store_op = "storew" }
            }

            @snprintf(buf, 256, "    %%t%lld =l alloc8 8\n    %s %s, %%t%lld\n", {qbe_tmp, store_op, val_tmp, qbe_tmp})
            emit(ctx, buf)
            @free(buf)

            cg_register_local_var(ctx, name, qbe_name)
            cg_mark_as_slot(ctx, name)
        } else {
            val tmp_num: ref char = @alloc(32) as ref char
            val c0: u8 = @load8(val_tmp) as u8
            val c1: u8 = @load8(val_tmp + 1) as u8
            if c0 == 37 && c1 == 116 {
                @snprintf(tmp_num, 32, "%s", {val_tmp + 2})
                cg_register_local_var(ctx, name, tmp_num)
            } elif c0 == 37 {
                val copy_tmp: i64 = fresh_tmp(ctx)
                val buf_copy: ref char = @alloc(128) as ref char
                @snprintf(buf_copy, 128, "    %%t%lld =l copy %s\n", {copy_tmp, val_tmp})
                emit(ctx, buf_copy)
                @free(buf_copy)
                @snprintf(tmp_num, 32, "%lld", {copy_tmp})
                cg_register_local_var(ctx, name, tmp_num)
            } else {
                @free(tmp_num)
            }
        }
        return
    }

    if k == parser.NK_ASSIGN {
        val target: ref parser.Node = stmt.d0 as ref parser.Node
        val value: ref parser.Node = stmt.d1 as ref parser.Node
        val val_tmp2: ref char = gen_expr(ctx, value)
        val tk: i64 = target.kind as i64
        if tk == parser.NK_IDENT {
            val tname: ref char = target.d0 as ref char
            val qbe_var: ref char = cg_lookup_local_var(ctx, tname)
            val buf2: ref char = @alloc(128) as ref char
            val store_op2: mut ref char = "storel"
            val is_ref2: bool = cg_is_local_ref_type(ctx, tname)

            if !is_ref2 {
                val ltype3: ref char = cg_local_type(ctx, tname)
                if str.rchar_cmp(ltype3, "f64") == 0 { store_op2 = "stored" }
                elif str.rchar_cmp(ltype3, "f32") == 0 { store_op2 = "stores" }
                elif is_word_type_name(ltype3) { store_op2 = "storew" }
            }

            if str.rchar_cmp(qbe_var, "") != 0 {
                val is_global_store: bool = @load8(qbe_var as ref void) == 36 // '$'
                if is_global_store {
                    @snprintf(buf2, 128, "    %s %s, %s\n", {store_op2, val_tmp2, qbe_var})
                } else {
                    @snprintf(buf2, 128, "    %s %s, %%t%s\n", {store_op2, val_tmp2, qbe_var})
                }
            } else {
                @snprintf(buf2, 128, "    %s %s, %%%s\n", {store_op2, val_tmp2, tname})
            }
            emit(ctx, buf2)
            @free(buf2)
        } elif tk == parser.NK_FIELD {
            val ftarget: ref parser.Node = target.d0 as ref parser.Node
            val fname: ref char = target.d1 as ref char
            val foffset: mut i64 = 0
            if ftarget.kind == parser.NK_IDENT {
                val bname: ref char = ftarget.d0 as ref char
                val tname2: ref char = cg_local_type(ctx, bname)
                if str.rchar_cmp(tname2, "") != 0 {
                    val flds2: ref void = cg_lookup_struct(ctx, tname2)
                    if flds2 != 0 as ref void {
                        val off2: i64 = field_offset(flds2, fname)
                        if off2 >= 0 { foffset = off2 }
                    }
                }
            }
            val base: ref char = gen_expr(ctx, ftarget)
            val buf3: ref char = @alloc(128) as ref char
            if foffset == 0 {
                @snprintf(buf3, 128, "    storel %s, %s\n", {val_tmp2, base})
            } else {
                val fptr: i64 = fresh_tmp(ctx)
                val buf3b: ref char = @alloc(128) as ref char
                @snprintf(buf3b, 128, "    %%t%lld =l add %s, %lld\n", {fptr, base, foffset})
                emit(ctx, buf3b)
                @free(buf3b)
                @snprintf(buf3, 128, "    storel %s, %%t%lld\n", {val_tmp2, fptr})
            }
            emit(ctx, buf3)
            @free(buf3)
        } elif tk == parser.NK_DEREF {
            val ptr: ref char = gen_expr(ctx, target.d0 as ref parser.Node)
            val buf4: ref char = @alloc(128) as ref char
            @snprintf(buf4, 128, "    storel %s, %s\n", {val_tmp2, ptr})
            emit(ctx, buf4)
            @free(buf4)
        }
        return
    }

    if k == parser.NK_RETURN {
        val expr2: ref parser.Node = stmt.d0 as ref parser.Node
        if expr2 == 0 as ref parser.Node {
            cg_emit_defers(ctx)
            emitln(ctx, "    ret 0")
        } else {
            val rv: ref char = gen_expr(ctx, expr2)
            cg_emit_defers(ctx)
            
            // If returning a union, use memcpy to copy to %__ret
            if str.rchar_cmp(ctx.current_fn_ret_union, "") != 0 {
                val buf5: ref char = @alloc(128) as ref char
                @snprintf(buf5, 128, "    call $memcpy(l %%__ret, l %s, l 16)\n    ret %%__ret\n", {rv})
                emit(ctx, buf5)
                @free(buf5)
            } else {
                val buf5: ref char = @alloc(64) as ref char
                @snprintf(buf5, 64, "    ret %s\n", {rv})
                emit(ctx, buf5)
                @free(buf5)
            }
        }
        return
    }

    if k == parser.NK_EXPR_STMT {
        gen_expr(ctx, stmt.d0 as ref parser.Node)
        return
    }

    if k == parser.NK_IF {
        gen_if_stmt(ctx, stmt)
        return
    }

    if k == parser.NK_FOR {
        gen_for_stmt(ctx, stmt)
        return
    }

    if k == parser.NK_FORIN {
        gen_forin_stmt(ctx, stmt)
        return
    }

    if k == parser.NK_BREAK {
        val blbl: i64 = cg_break_lbl(ctx)
        val bbuf: ref char = @alloc(64) as ref char
        @snprintf(bbuf, 64, "    jmp @lbl%lld\n", {blbl})
        emit(ctx, bbuf)
        @free(bbuf)
        return
    }

    if k == parser.NK_CONTINUE {
        val clbl: i64 = cg_cont_lbl(ctx)
        val cbuf: ref char = @alloc(64) as ref char
        @snprintf(cbuf, 64, "    jmp @lbl%lld\n", {clbl})
        emit(ctx, cbuf)
        @free(cbuf)
        return
    }

    if k == parser.NK_DEFER {
        cg_defer_push(ctx, stmt.d0 as ref parser.Node)
        return
    }

    if k == parser.NK_ASSERT {
        val cond: ref char = gen_expr(ctx, stmt.d0 as ref parser.Node)
        val ok_lbl: i64 = fresh_lbl(ctx)
        val fail_lbl: i64 = fresh_lbl(ctx)
        val buf6: ref char = @alloc(128) as ref char
        @snprintf(buf6, 128, "    jnz %s, @lbl%lld, @lbl%lld\n@lbl%lld\n", {cond, ok_lbl, fail_lbl, fail_lbl})
        emit(ctx, buf6)
        @free(buf6)
        val node: ref parser.Node = stmt as ref parser.Node
        val fn_name: ref char = cg_fn_name(ctx)
        val msg_buf: ref char = @alloc(512) as ref char
        @snprintf(msg_buf, 512, "spectre: assertion failed at line %lld\n", {node.line})
        val msg_idx: i64 = intern_string(ctx, msg_buf)
        @free(msg_buf)
        val msg_tmp: i64 = fresh_tmp(ctx)
        val abuf: ref char = @alloc(256) as ref char
        @snprintf(abuf, 256,
            "    %%t%lld =l copy $__str%lld\n    call $dprintf(w 2, l %%t%lld)\n    call $fflush(l 0)\n    call $abort()\n    hlt\n@lbl%lld\n",
            {msg_tmp, msg_idx, msg_tmp, ok_lbl})
        emit(ctx, abuf)
        @free(abuf)
        return
    }

    if k == parser.NK_PRE || k == parser.NK_GUARDED_PRE ||
       k == parser.NK_POST || k == parser.NK_GUARDED_POST {
        val is_pre: bool = k == parser.NK_PRE || k == parser.NK_GUARDED_PRE
        val kind_str: mut ref char = "precondition"
        if !is_pre { kind_str = "postcondition" }
        val fn_name: ref char = cg_fn_name(ctx)
        val clist: ref void = stmt.d0 as ref void
        if clist != 0 as ref void {
            val clen: i64 = @len(clist) as i64
            val ci: mut i64 = 0
            for {
                if ci >= clen { break }
                val c_opt = @get(clist, ci as usize)
                match c_opt {
                    some c => {
                        val cnode: ref parser.Node = c as ref parser.Node
                        val label: ref char = cnode.d0 as ref char
                        val cexpr: ref parser.Node = cnode.d1 as ref parser.Node
                        val cv: ref char = gen_expr(ctx, cexpr)
                        val ok_lbl: i64 = fresh_lbl(ctx)
                        val fail_lbl: i64 = fresh_lbl(ctx)
                        val jbuf: ref char = @alloc(128) as ref char
                        @snprintf(jbuf, 128, "    jnz %s, @lbl%lld, @lbl%lld\n@lbl%lld\n",
                            {cv, ok_lbl, fail_lbl, fail_lbl})
                        emit(ctx, jbuf)
                        @free(jbuf)
                        val msg_buf: ref char = @alloc(512) as ref char
                        if label != 0 as ref char {
                            @snprintf(msg_buf, 512, "spectre: %s '%s' violated in function '%s'\n",
                                {kind_str, label, fn_name})
                        } else {
                            @snprintf(msg_buf, 512, "spectre: %s violated in function '%s'\n",
                                {kind_str, fn_name})
                        }
                        val msg_idx: i64 = intern_string(ctx, msg_buf)
                        @free(msg_buf)
                        val msg_tmp: i64 = fresh_tmp(ctx)
                        val call_buf: ref char = @alloc(256) as ref char
                        @snprintf(call_buf, 256,
                            "    %%t%lld =l copy $__str%lld\n    call $dprintf(w 2, l %%t%lld)\n    call $fflush(l 0)\n    call $abort()\n    hlt\n@lbl%lld\n",
                            {msg_tmp, msg_idx, msg_tmp, ok_lbl})
                        emit(ctx, call_buf)
                        @free(call_buf)
                    }
                    none => {}
                }
                ci++
            }
        }
        return
    }

    if k == parser.NK_MATCH_OPT {
        gen_match_opt(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_RES {
        gen_match_res(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_ENUM {
        gen_match_enum(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_STR {
        gen_match_str(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_UNION {
        // union match: emit tag-based dispatch
        gen_match_union(ctx, stmt)
        return
    }

    if k == parser.NK_MATCH_TAGGED_UNION {
        gen_match_tagged_union(ctx, stmt)
        return
    }

    if k == parser.NK_WHEN_STMT {
        val plat: ref char = stmt.d0 as ref char
        if platform_matches(plat) {
            gen_stmts(ctx, stmt.d1 as ref parser.Node)
        } else {
            val or_when_branches: ref void = stmt.d2 as ref void
            val matched: mut bool = false
            if or_when_branches != 0 as ref void {
                for ow_node in or_when_branches as list[ref parser.Node] {
                    if !matched {
                        val ow_plat: ref char = ow_node.d0 as ref char
                        if platform_matches(ow_plat) {
                            gen_stmts(ctx, ow_node.d1 as ref parser.Node)
                            matched = true
                        }
                    }
                }
            }
            if !matched {
                val otherwise_stmts: ref void = stmt.d3 as ref void
                if otherwise_stmts != 0 as ref void {
                    gen_stmts(ctx, stmt.d3 as ref parser.Node)
                }
            }
        }
        return
    }

    if k == parser.NK_INCREMENT {
        val target2: ref parser.Node = stmt.d0 as ref parser.Node
        val tname2: mut ref char = 0 as ref char
        if target2.kind == parser.NK_IDENT {
            tname2 = target2.d0 as ref char
        } else {
            tname2 = stmt.d0 as ref char
        }
        if tname2 != 0 as ref char {
            // Look up QBE temporary name for local variables
            val qbe_var: ref char = cg_lookup_local_var(ctx, tname2)
            val var_ref: ref char = @alloc(64) as ref char
            if str.rchar_cmp(qbe_var, "") != 0 {
                val is_g: bool = @load8(qbe_var as ref void) == 36
                if is_g { @snprintf(var_ref, 64, "%s", {qbe_var}) }
                else    { @snprintf(var_ref, 64, "%%t%s", {qbe_var}) }
            } else {
                @snprintf(var_ref, 64, "%%%s", {tname2})
            }

            val cur: i64 = fresh_tmp(ctx)
            val nxt: i64 = fresh_tmp(ctx)
            val buf9: ref char = @alloc(256) as ref char
            val ltype_inc: ref char = cg_local_type(ctx, tname2)
            if is_word_type_name(ltype_inc) {
                val w_cur: i64 = fresh_tmp(ctx)
                @snprintf(buf9, 256, "    %%t%lld =w loadw %s\n    %%t%lld =l extsw %%t%lld\n    %%t%lld =l add %%t%lld, 1\n    storew %%t%lld, %s\n",
                    {w_cur, var_ref, cur, w_cur, nxt, cur, nxt, var_ref})
            } else {
                @snprintf(buf9, 256, "    %%t%lld =l loadl %s\n    %%t%lld =l add %%t%lld, 1\n    storel %%t%lld, %s\n",
                    {cur, var_ref, nxt, cur, nxt, var_ref})
            }
            emit(ctx, buf9)
            @free(buf9)
            @free(var_ref)
        }
        return
    }

    if k == parser.NK_DECREMENT {
        val target3: ref parser.Node = stmt.d0 as ref parser.Node
        val tname3: mut ref char = 0 as ref char
        if target3.kind == parser.NK_IDENT {
            tname3 = target3.d0 as ref char
        } else {
            tname3 = stmt.d0 as ref char
        }
        if tname3 != 0 as ref char {
            val qbe_var: ref char = cg_lookup_local_var(ctx, tname3)
            val var_ref: ref char = @alloc(64) as ref char
            if str.rchar_cmp(qbe_var, "") != 0 {
                val is_g: bool = @load8(qbe_var as ref void) == 36
                if is_g { @snprintf(var_ref, 64, "%s", {qbe_var}) }
                else    { @snprintf(var_ref, 64, "%%t%s", {qbe_var}) }
            } else {
                @snprintf(var_ref, 64, "%%%s", {tname3})
            }

            val cur2: i64 = fresh_tmp(ctx)
            val nxt2: i64 = fresh_tmp(ctx)
            val buf10: ref char = @alloc(256) as ref char
            val ltype_dec: ref char = cg_local_type(ctx, tname3)
            if is_word_type_name(ltype_dec) {
                val w_cur2: i64 = fresh_tmp(ctx)
                @snprintf(buf10, 256, "    %%t%lld =w loadw %s\n    %%t%lld =l extsw %%t%lld\n    %%t%lld =l sub %%t%lld, 1\n    storew %%t%lld, %s\n",
                    {w_cur2, var_ref, cur2, w_cur2, nxt2, cur2, nxt2, var_ref})
            } else {
                @snprintf(buf10, 256, "    %%t%lld =l loadl %s\n    %%t%lld =l sub %%t%lld, 1\n    storel %%t%lld, %s\n",
                    {cur2, var_ref, nxt2, cur2, nxt2, var_ref})
            }
            emit(ctx, buf10)
            @free(buf10)
            @free(var_ref)
        }
        return
    }

    if k == parser.NK_ADD_ASSIGN {
        val target4: ref parser.Node = stmt.d0 as ref parser.Node
        val rhs: ref char = gen_expr(ctx, stmt.d1 as ref parser.Node)
        val tname4: mut ref char = 0 as ref char
        if target4.kind == parser.NK_IDENT {
            tname4 = target4.d0 as ref char
        } else {
            tname4 = stmt.d0 as ref char
        }
        if tname4 != 0 as ref char {
            val qbe_var: ref char = cg_lookup_local_var(ctx, tname4)
            val var_ref: ref char = @alloc(64) as ref char
            if str.rchar_cmp(qbe_var, "") != 0 {
                val is_g: bool = @load8(qbe_var as ref void) == 36
                if is_g { @snprintf(var_ref, 64, "%s", {qbe_var}) }
                else    { @snprintf(var_ref, 64, "%%t%s", {qbe_var}) }
            } else {
                @snprintf(var_ref, 64, "%%%s", {tname4})
            }

            val cur3: i64 = fresh_tmp(ctx)
            val nxt3: i64 = fresh_tmp(ctx)
            val buf11: ref char = @alloc(256) as ref char
            @snprintf(buf11, 256, "    %%t%lld =l loadl %s\n    %%t%lld =l add %%t%lld, %s\n    storel %%t%lld, %s\n",
                {cur3, var_ref, nxt3, cur3, rhs, nxt3, var_ref})
            emit(ctx, buf11)
            @free(buf11)
            @free(var_ref)
        }
        return
    }

    if k == parser.NK_SUB_ASSIGN {
        val target5: ref parser.Node = stmt.d0 as ref parser.Node
        val rhs2: ref char = gen_expr(ctx, stmt.d1 as ref parser.Node)
        val tname5: mut ref char = 0 as ref char
        if target5.kind == parser.NK_IDENT {
            tname5 = target5.d0 as ref char
        } else {
            tname5 = stmt.d0 as ref char
        }
        if tname5 != 0 as ref char {
            val qbe_var: ref char = cg_lookup_local_var(ctx, tname5)
            val var_ref: ref char = @alloc(64) as ref char
            if str.rchar_cmp(qbe_var, "") != 0 {
                val is_g: bool = @load8(qbe_var as ref void) == 36
                if is_g { @snprintf(var_ref, 64, "%s", {qbe_var}) }
                else    { @snprintf(var_ref, 64, "%%t%s", {qbe_var}) }
            } else {
                @snprintf(var_ref, 64, "%%%s", {tname5})
            }

            val cur4: i64 = fresh_tmp(ctx)
            val nxt4: i64 = fresh_tmp(ctx)
            val buf12: ref char = @alloc(256) as ref char
            @snprintf(buf12, 256, "    %%t%lld =l loadl %s\n    %%t%lld =l sub %%t%lld, %s\n    storel %%t%lld, %s\n",
                {cur4, var_ref, nxt4, cur4, rhs2, nxt4, var_ref})
            emit(ctx, buf12)
            @free(buf12)
            @free(var_ref)
        }
        return
    }
}

fn block_ends_with_terminator(stmts: ref parser.Node) bool! = {
    if stmts == 0 as ref parser.Node { return false }
    val len: i64 = @len(stmts) as i64
    if len == 0 { return false }
    val last_opt = @get(stmts, (len - 1) as usize)
    match last_opt {
        some last => {
            val lk: i64 = (last as ref parser.Node).kind
            return lk == parser.NK_RETURN || lk == parser.NK_BREAK || lk == parser.NK_CONTINUE
        }
        none => { return false }
    }
}

/// Like block_ends_with_terminator but takes a body wrapper node (d0 = stmts list).
fn body_ends_with_terminator(body_node: ref parser.Node) bool! = {
    if body_node == 0 as ref parser.Node { return false }
    return block_ends_with_terminator(body_node.d0 as ref parser.Node)
}

fn gen_if_stmt(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val then_lbl: i64 = fresh_lbl(ctx)
    val end_lbl: i64 = fresh_lbl(ctx)
    val has_else: bool = stmt.d3 != 0
    val elif_list: ref void = stmt.d2 as ref void
    val has_elif: bool = elif_list != 0 as ref void && @len(elif_list as list[ref void]) > 0

    // Determine where the main if/false branch jumps.
    // If there are elifs, we need to pre-allocate their condition labels so we
    // can chain them. We collect them first, then emit everything in order.
    //
    // So, the strategy here is: allocate one "next" label per elif plus one for else/end.
    //   next_lbls[i] = label to jump to when elif[i-1] condition is false
    //   next_lbls[0] = first elif cond label (or else_lbl or end_lbl)
    val next_lbls: mut list[i64] = []
    val body_lbls: mut list[i64] = []

    if has_elif {
        val elen: i64 = @len(elif_list) as i64
        val pi: mut i64 = 0
        for {
            if pi >= elen { break }
            @append(next_lbls, fresh_lbl(ctx))
            @append(body_lbls, fresh_lbl(ctx))
            pi++
        }
    }

    val else_lbl: i64 = fresh_lbl(ctx)
    val first_false: mut i64 = end_lbl

    if has_elif {
        val fl_opt = @get(next_lbls, 0 as usize)
        match fl_opt {
            some fl => { first_false = fl as i64 }
            none => {}
        }
    } elif has_else {
        first_false = else_lbl
    }

    val cond: ref char = gen_expr(ctx, stmt.d0 as ref parser.Node)
    val buf: ref char = @alloc(128) as ref char
    @snprintf(buf, 128, "    jnz %s, @lbl%lld, @lbl%lld\n@lbl%lld\n", {cond, then_lbl, first_false, then_lbl})
    emit(ctx, buf)
    @free(buf)

    gen_stmts(ctx, stmt.d1 as ref parser.Node)

    if !block_ends_with_terminator(stmt.d1 as ref parser.Node) {
        val buf2: ref char = @alloc(64) as ref char
        @snprintf(buf2, 64, "    jmp @lbl%lld\n", {end_lbl})
        emit(ctx, buf2)
        @free(buf2)
    }

    if has_elif {
        val elen: i64 = @len(elif_list) as i64
        val ei: mut i64 = 0
        for {
            if ei >= elen { break }
            val ep_opt = @get(elif_list, ei as usize)
            val cl_opt = @get(next_lbls, ei as usize)
            val bl_opt = @get(body_lbls, ei as usize)
            match ep_opt {
                some ep => {
                    match cl_opt {
                        some cl => {
                            match bl_opt {
                                some bl => {
                                    val cond_lbl: i64 = cl as i64
                                    val body_lbl: i64 = bl as i64
                                    val false_lbl: mut i64 = end_lbl

                                    if ei + 1 < elen {
                                        val nl_opt = @get(next_lbls, (ei + 1) as usize)
                                        match nl_opt {
                                            some nl => { false_lbl = nl as i64 }
                                            none => {}
                                        }
                                    } elif has_else {
                                        false_lbl = else_lbl
                                    }

                                    val clbuf: ref char = @alloc(32) as ref char
                                    @snprintf(clbuf, 32, "@lbl%lld\n", {cond_lbl})
                                    emit(ctx, clbuf)
                                    @free(clbuf)

                                    val econd: ref char = gen_expr(ctx, (ep as ref parser.Node).d0 as ref parser.Node)
                                    val ebuf: ref char = @alloc(128) as ref char
                                    @snprintf(ebuf, 128, "    jnz %s, @lbl%lld, @lbl%lld\n@lbl%lld\n",
                                        {econd, body_lbl, false_lbl, body_lbl})
                                    emit(ctx, ebuf)
                                    @free(ebuf)

                                    gen_stmts(ctx, (ep as ref parser.Node).d1 as ref parser.Node)

                                    if !block_ends_with_terminator((ep as ref parser.Node).d1 as ref parser.Node) {
                                        val ejbuf: ref char = @alloc(64) as ref char
                                        @snprintf(ejbuf, 64, "    jmp @lbl%lld\n", {end_lbl})
                                        emit(ctx, ejbuf)
                                        @free(ejbuf)
                                    }
                                }
                                none => {}
                            }
                        }
                        none => {}
                    }
                }
                none => {}
            }
            ei++
        }
    }

    if has_else {
        val ebuf2: ref char = @alloc(32) as ref char
        @snprintf(ebuf2, 32, "@lbl%lld\n", {else_lbl})
        emit(ctx, ebuf2)
        @free(ebuf2)
        gen_stmts(ctx, (stmt.d3 as ref parser.Node).d0 as ref parser.Node)
        if !block_ends_with_terminator((stmt.d3 as ref parser.Node).d0 as ref parser.Node) {
            val ejbuf3: ref char = @alloc(64) as ref char
            @snprintf(ejbuf3, 64, "    jmp @lbl%lld\n", {end_lbl})
            emit(ctx, ejbuf3)
            @free(ejbuf3)
        }
    }

    val endbuf: ref char = @alloc(32) as ref char
    @snprintf(endbuf, 32, "@lbl%lld\n", {end_lbl})
    emit(ctx, endbuf)
    @free(endbuf)
}

fn gen_for_stmt(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val loop_lbl: i64 = fresh_lbl(ctx)
    val body_lbl: i64 = fresh_lbl(ctx)
    val cont_lbl: i64 = fresh_lbl(ctx)
    val break_lbl: i64 = fresh_lbl(ctx)
    val init_name: ref char = stmt.d0 as ref char
    val prev_break: i64 = cg_break_lbl(ctx)
    val prev_cont: i64 = cg_cont_lbl(ctx)

    cg_set_break_lbl(ctx, break_lbl)
    cg_set_cont_lbl(ctx, cont_lbl)

    if init_name != 0 as ref char {
        val init_val: ref char = gen_expr(ctx, stmt.d1 as ref parser.Node)
        val buf: ref char = @alloc(128) as ref char
        val already_local: bool = str.rchar_cmp(cg_local_type(ctx, init_name), "") != 0
        val already_direct: bool = str.rchar_cmp(cg_direct_type(ctx, init_name), "") != 0
        if already_local || already_direct {
            @snprintf(buf, 128, "    storel %s, %%%s\n", {init_val, init_name})
        } else {
            @snprintf(buf, 128, "    %%%s =l alloc8 8\n    storel %s, %%%s\n", {init_name, init_val, init_name})
        }
        emit(ctx, buf)
        @free(buf)
    }

    val ljbuf: ref char = @alloc(64) as ref char
    @snprintf(ljbuf, 64, "    jmp @lbl%lld\n@lbl%lld\n", {loop_lbl, loop_lbl})
    emit(ctx, ljbuf)
    @free(ljbuf)

    val cond_node: ref void = stmt.d2 as ref void
    if cond_node != 0 as ref void {
        val cond: ref char = gen_expr(ctx, cond_node as ref parser.Node)
        val cbuf: ref char = @alloc(128) as ref char
        @snprintf(cbuf, 128, "    jnz %s, @lbl%lld, @lbl%lld\n@lbl%lld\n",
            {cond, body_lbl, break_lbl, body_lbl})
        emit(ctx, cbuf)
        @free(cbuf)
    } else {
        val ibuf: ref char = @alloc(64) as ref char
        @snprintf(ibuf, 64, "    jmp @lbl%lld\n@lbl%lld\n", {body_lbl, body_lbl})
        emit(ctx, ibuf)
        @free(ibuf)
    }

    gen_stmts(ctx, stmt.d4 as ref parser.Node)

    if !block_ends_with_terminator(stmt.d4 as ref parser.Node) {
        val cjbuf: ref char = @alloc(64) as ref char
        @snprintf(cjbuf, 64, "    jmp @lbl%lld\n", {cont_lbl})
        emit(ctx, cjbuf)
        @free(cjbuf)
    }

    val clbuf: ref char = @alloc(32) as ref char
    @snprintf(clbuf, 32, "@lbl%lld\n", {cont_lbl})
    emit(ctx, clbuf)
    @free(clbuf)

    val post_step: ref void = stmt.d3 as ref void
    if post_step != 0 as ref void {
        gen_stmt(ctx, post_step as ref parser.Node)
    }

    val jbuf: ref char = @alloc(64) as ref char
    @snprintf(jbuf, 64, "    jmp @lbl%lld\n@lbl%lld\n", {loop_lbl, break_lbl})
    emit(ctx, jbuf)
    @free(jbuf)

    cg_set_break_lbl(ctx, prev_break)
    cg_set_cont_lbl(ctx, prev_cont)
}

fn gen_forin_stmt(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val binding: ref char = stmt.d0 as ref char
    val iter: ref char = gen_expr(ctx, stmt.d1 as ref parser.Node)
    val body: ref void = stmt.d2 as ref void

    val idx: i64 = fresh_tmp(ctx)
    val len: i64 = fresh_tmp(ctx)
    val loop_lbl: i64 = fresh_lbl(ctx)
    val body_lbl: i64 = fresh_lbl(ctx)
    val break_lbl: i64 = fresh_lbl(ctx)

    val prev_break2: i64 = cg_break_lbl(ctx)
    val prev_cont2: i64 = cg_cont_lbl(ctx)
    cg_set_break_lbl(ctx, break_lbl)
    cg_set_cont_lbl(ctx, loop_lbl)

    val len_slot: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(512) as ref char
    @snprintf(buf, 512,
        "    %%t%lld =l alloc8 8\n    storel 0, %%t%lld\n    %%t%lld =l add %s, 8\n    %%t%lld =l loadl %%t%lld\n@lbl%lld\n",
        {idx, idx, len_slot, iter, len, len_slot, loop_lbl})
    emit(ctx, buf)
    @free(buf)

    val cur_idx: i64 = fresh_tmp(ctx)
    val cmp: i64 = fresh_tmp(ctx)
    val buf2: ref char = @alloc(256) as ref char
    @snprintf(buf2, 256,
        "    %%t%lld =l loadl %%t%lld\n    %%t%lld =w csltl %%t%lld, %%t%lld\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n@lbl%lld\n",
        {cur_idx, idx, cmp, cur_idx, len, cmp, body_lbl, break_lbl, body_lbl})
    emit(ctx, buf2)
    @free(buf2)

    val buf_tmp: i64 = fresh_tmp(ctx)
    val off: i64 = fresh_tmp(ctx)
    val elem_ptr: i64 = fresh_tmp(ctx)
    val elem: i64 = fresh_tmp(ctx)
    val binding_tmp: i64 = fresh_tmp(ctx)
    val binding_qbe: ref char = @alloc(32) as ref char
    @snprintf(binding_qbe, 32, "%lld", {binding_tmp})

    val buf3: ref char = @alloc(512) as ref char
    @snprintf(buf3, 512,
        "    %%t%lld =l loadl %s\n    %%t%lld =l mul %%t%lld, 8\n    %%t%lld =l add %%t%lld, %%t%lld\n    %%t%lld =l loadl %%t%lld\n    %%t%lld =l alloc8 8\n    storel %%t%lld, %%t%lld\n",
        {buf_tmp, iter, off, cur_idx, elem_ptr, buf_tmp, off, elem, elem_ptr, binding_tmp, elem, binding_tmp})
    emit(ctx, buf3)
    @free(buf3)

    cg_register_local_var(ctx, binding, binding_qbe)
    cg_mark_as_slot(ctx, binding)

    gen_stmts(ctx, body as ref parser.Node)

    val nxt: i64 = fresh_tmp(ctx)
    val buf4: ref char = @alloc(128) as ref char
    @snprintf(buf4, 128,
        "    %%t%lld =l add %%t%lld, 1\n    storel %%t%lld, %%t%lld\n    jmp @lbl%lld\n@lbl%lld\n",
        {nxt, cur_idx, nxt, idx, loop_lbl, break_lbl})
    emit(ctx, buf4)
    @free(buf4)

    cg_set_break_lbl(ctx, prev_break2)
    cg_set_cont_lbl(ctx, prev_cont2)
}

fn gen_match_opt(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr: ref char = gen_expr(ctx, stmt.d0 as ref parser.Node)
    val some_bind: ref char = stmt.d1 as ref char
    val some_body_node: ref parser.Node = stmt.d2 as ref parser.Node
    val none_body_node: ref parser.Node = stmt.d3 as ref parser.Node

    val some_lbl: i64 = fresh_lbl(ctx)
    val none_lbl: i64 = fresh_lbl(ctx)
    val end_lbl: i64 = fresh_lbl(ctx)

    // option encoding: none=0, some(v)=v+1
    val tag: i64 = fresh_tmp(ctx)
    val buf: ref char = @alloc(256) as ref char
    @snprintf(buf, 256,
        "    %%t%lld =w cnel %s, 0\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n@lbl%lld\n",
        {tag, expr, tag, some_lbl, none_lbl, some_lbl})
    emit(ctx, buf)
    @free(buf)

    if some_bind != 0 as ref char {
        val val_tmp: i64 = fresh_tmp(ctx)
        val vbuf: ref char = @alloc(128) as ref char
        @snprintf(vbuf, 128,
            "    %%t%lld =l sub %s, 1\n    %%%s =l alloc8 8\n    storel %%t%lld, %%%s\n",
            {val_tmp, expr, some_bind, val_tmp, some_bind})
        emit(ctx, vbuf)
        @free(vbuf)
    }

    if some_body_node != 0 as ref parser.Node {
        gen_stmts(ctx, some_body_node.d0 as ref parser.Node)
    }

    val jbuf: ref char = @alloc(64) as ref char
    if !body_ends_with_terminator(some_body_node) {
        @snprintf(jbuf, 64, "    jmp @lbl%lld\n@lbl%lld\n", {end_lbl, none_lbl})
        emit(ctx, jbuf)
    } else {
        @snprintf(jbuf, 64, "@lbl%lld\n", {none_lbl})
        emit(ctx, jbuf)
    }
    @free(jbuf)

    if none_body_node != 0 as ref parser.Node {
        gen_stmts(ctx, none_body_node.d0 as ref parser.Node)
    }

    val endbuf: ref char = @alloc(32) as ref char
    if !body_ends_with_terminator(none_body_node) {
        @snprintf(endbuf, 32, "    jmp @lbl%lld\n@lbl%lld\n", {end_lbl, end_lbl})
        emit(ctx, endbuf)
    } else {
        @snprintf(endbuf, 32, "@lbl%lld\n", {end_lbl})
        emit(ctx, endbuf)
    }
    @free(endbuf)
}

fn gen_match_res(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr: ref char = gen_expr(ctx, stmt.d0 as ref parser.Node)
    val ok_bind: ref char = stmt.d1 as ref char
    val ok_body_node: ref parser.Node = stmt.d2 as ref parser.Node
    val err_bind: ref char = stmt.d3 as ref char
    val err_body_node: ref parser.Node = stmt.d4 as ref parser.Node
    val tag: i64 = fresh_tmp(ctx)
    val is_ok: i64 = fresh_tmp(ctx)
    val ok_lbl: i64 = fresh_lbl(ctx)
    val err_lbl: i64 = fresh_lbl(ctx)
    val end_lbl: i64 = fresh_lbl(ctx)
    val buf: ref char = @alloc(256) as ref char
    val is_direct_param: mut bool = false

    if @load8(expr) as i64 == 37 {  // '%'
        val second_char: i64 = @load8(@ptradd(expr, 1)) as i64
        if second_char != 116 {  // not 't'
            is_direct_param = true
        }
    }
    
    if is_direct_param {
        @snprintf(buf, 256,
            "    %%t%lld =l copy %s\n    %%t%lld =w ceql %%t%lld, 0\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n@lbl%lld\n",
            {tag, expr, is_ok, tag, is_ok, ok_lbl, err_lbl, ok_lbl})
    } else {
        @snprintf(buf, 256,
            "    %%t%lld =l loadl %s\n    %%t%lld =w ceql %%t%lld, 0\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n@lbl%lld\n",
            {tag, expr, is_ok, tag, is_ok, ok_lbl, err_lbl, ok_lbl})
    }

    emit(ctx, buf)
    @free(buf)

    if ok_bind != 0 as ref char {
        val off_ok: i64 = fresh_tmp(ctx)
        val val_ok: i64 = fresh_tmp(ctx)
        val vbuf: ref char = @alloc(256) as ref char
        @snprintf(vbuf, 256,
            "    %%t%lld =l add %s, 8\n    %%t%lld =l loadl %%t%lld\n    %%%s =l copy %%t%lld\n",
            {off_ok, expr, val_ok, off_ok, ok_bind, val_ok})
        emit(ctx, vbuf)
        @free(vbuf)
        cg_dvars_add(ctx, ok_bind, "l")
    }
    if ok_body_node != 0 as ref parser.Node {
        gen_stmts(ctx, ok_body_node.d0 as ref parser.Node)
    }

    val jbuf: ref char = @alloc(64) as ref char
    if !body_ends_with_terminator(ok_body_node) {
        @snprintf(jbuf, 64, "    jmp @lbl%lld\n@lbl%lld\n", {end_lbl, err_lbl})
        emit(ctx, jbuf)
    } else {
        @snprintf(jbuf, 64, "@lbl%lld\n", {err_lbl})
        emit(ctx, jbuf)
    }
    @free(jbuf)

    if err_bind != 0 as ref char {
        val off_err: i64 = fresh_tmp(ctx)
        val val_err: i64 = fresh_tmp(ctx)
        val vbuf2: ref char = @alloc(256) as ref char
        @snprintf(vbuf2, 256,
            "    %%t%lld =l add %s, 8\n    %%t%lld =l loadl %%t%lld\n    %%%s =l copy %%t%lld\n",
            {off_err, expr, val_err, off_err, err_bind, val_err})
        emit(ctx, vbuf2)
        @free(vbuf2)
        cg_dvars_add(ctx, err_bind, "l")
    }
    if err_body_node != 0 as ref parser.Node {
        gen_stmts(ctx, err_body_node.d0 as ref parser.Node)
    }

    val endbuf: ref char = @alloc(32) as ref char
    if !body_ends_with_terminator(err_body_node) {
        @snprintf(endbuf, 32, "    jmp @lbl%lld\n@lbl%lld\n", {end_lbl, end_lbl})
        emit(ctx, endbuf)
    } else {
        @snprintf(endbuf, 32, "@lbl%lld\n", {end_lbl})
        emit(ctx, endbuf)
    }
    @free(endbuf)
}

fn gen_match_enum(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr: ref char = gen_expr(ctx, stmt.d0 as ref parser.Node)
    val arms: ref void = stmt.d1 as ref void
    val end_lbl: i64 = fresh_lbl(ctx)

    if arms == 0 as ref void {
        return
    }
    val alen: i64 = @len(arms) as i64
    val ai: mut i64 = 0
    for {
        if ai >= alen { break }
        val arm_opt = @get(arms, ai as usize)
        match arm_opt {
            some arm => {
                val body_lbl: i64 = fresh_lbl(ctx)
                val next_lbl: i64 = fresh_lbl(ctx)
                val cmp: i64 = fresh_tmp(ctx)
                val buf: ref char = @alloc(256) as ref char
                @snprintf(buf, 256,
                    "    %%t%lld =w ceql %s, %lld\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n@lbl%lld\n",
                    {cmp, expr, ai, cmp, body_lbl, next_lbl, body_lbl})
                emit(ctx, buf)
                @free(buf)
                gen_stmts(ctx, (arm as ref parser.Node).d1 as ref parser.Node)
                val jbuf: ref char = @alloc(64) as ref char
                if !block_ends_with_terminator((arm as ref parser.Node).d1 as ref parser.Node) {
                    @snprintf(jbuf, 64, "    jmp @lbl%lld\n@lbl%lld\n", {end_lbl, next_lbl})
                } else {
                    @snprintf(jbuf, 64, "@lbl%lld\n", {next_lbl})
                }
                emit(ctx, jbuf)
                @free(jbuf)
            }
            none => {}
        }
        ai++
    }
    val endbuf: ref char = @alloc(32) as ref char
    @snprintf(endbuf, 32, "@lbl%lld\n", {end_lbl})
    emit(ctx, endbuf)
    @free(endbuf)
}

fn gen_match_str(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr: ref char = gen_expr(ctx, stmt.d0 as ref parser.Node)
    val arms: ref void = stmt.d1 as ref void
    val else_body: ref parser.Node = stmt.d2 as ref parser.Node
    val end_lbl: i64 = fresh_lbl(ctx)

    if arms != 0 as ref void {
        val alen: i64 = @len(arms) as i64
        val ai: mut i64 = 0
        for {
            if ai >= alen { break }
            val arm_opt = @get(arms, ai as usize)
            match arm_opt {
                some arm => {
                    val pat: ref char = (arm as ref parser.Node).d0 as ref char
                    val pat_idx: i64 = intern_string(ctx, pat)
                    val body_lbl: i64 = fresh_lbl(ctx)
                    val next_lbl: i64 = fresh_lbl(ctx)
                    val cmp: i64 = fresh_tmp(ctx)
                    val cmp2: i64 = fresh_tmp(ctx)
                    val buf: ref char = @alloc(256) as ref char
                    @snprintf(buf, 256,
                        "    %%t%lld =l call $strcmp(l %s, l $__str%lld)\n    %%t%lld =w ceql %%t%lld, 0\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n@lbl%lld\n",
                        {cmp, expr, pat_idx, cmp2, cmp, cmp2, body_lbl, next_lbl, body_lbl})
                    emit(ctx, buf)
                    @free(buf)
                    gen_stmts(ctx, (arm as ref parser.Node).d1 as ref parser.Node)
                    val jbuf: ref char = @alloc(64) as ref char
                    if !block_ends_with_terminator((arm as ref parser.Node).d1 as ref parser.Node) {
                        @snprintf(jbuf, 64, "    jmp @lbl%lld\n@lbl%lld\n", {end_lbl, next_lbl})
                    } else {
                        @snprintf(jbuf, 64, "@lbl%lld\n", {next_lbl})
                    }
                    emit(ctx, jbuf)
                    @free(jbuf)
                }
                none => {}
            }
            ai++
        }
    }

    if else_body != 0 as ref void {
        gen_stmts(ctx, else_body)
    }

    val endbuf: ref char = @alloc(32) as ref char
    @snprintf(endbuf, 32, "@lbl%lld\n", {end_lbl})
    emit(ctx, endbuf)
    @free(endbuf)
}

fn gen_match_union(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr_node: ref parser.Node = stmt.d0 as ref parser.Node
    val expr: ref char = gen_expr(ctx, expr_node)
    val arms: ref void = stmt.d1 as ref void
    val else_body: ref void = stmt.d2 as ref void
    val end_lbl: i64 = fresh_lbl(ctx)
    val tag: i64 = fresh_tmp(ctx)
    val tbuf: ref char = @alloc(64) as ref char

    @snprintf(tbuf, 64, "    %%t%lld =w loadw %s\n", {tag, expr})
    emit(ctx, tbuf)
    @free(tbuf)

    val union_variants: mut ref void = 0 as ref void
    if expr_node.kind == parser.NK_IDENT {
        val ename: ref char = expr_node.d0 as ref char
        val local_ty: ref char = cg_local_type(ctx, ename)
        if str.rchar_cmp(local_ty, "") != 0 {
            union_variants = cg_lookup_union(ctx, local_ty)
        }
    }

    if arms != 0 as ref void {
        val alen: i64 = @len(arms) as i64
        val ai: mut i64 = 0
        for {
            if ai >= alen { break }
            val arm_opt = @get(arms, ai as usize)
            match arm_opt {
                some arm => {
                    val arm_node: ref parser.Node = arm as ref parser.Node
                    val arm_ty: ref parser.Node = arm_node.d0 as ref parser.Node
                    val tag_idx: mut i64 = ai

                    if union_variants != 0 as ref void && arm_ty != 0 as ref parser.Node {
                        if arm_ty.kind == parser.TY_NAMED {
                            val arm_tname: ref char = arm_ty.d0 as ref char
                            val vlen: i64 = @len(union_variants) as i64
                            val vi: mut i64 = 0
                            for {
                                if vi >= vlen { break }
                                val v_opt = @get(union_variants, vi as usize)
                                match v_opt {
                                    some v => {
                                        if str.rchar_cmp(v as ref char, arm_tname) == 0 {
                                            tag_idx = vi
                                            break
                                        }
                                    }
                                    none => {}
                                }
                                vi++
                            }
                        }
                    }

                    val body_lbl: i64 = fresh_lbl(ctx)
                    val next_lbl: i64 = fresh_lbl(ctx)
                    val cmp: i64 = fresh_tmp(ctx)
                    val buf: ref char = @alloc(256) as ref char
                    @snprintf(buf, 256,
                        "    %%t%lld =w ceqw %%t%lld, %lld\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n@lbl%lld\n",
                        {cmp, tag, tag_idx, cmp, body_lbl, next_lbl, body_lbl})
                    emit(ctx, buf)
                    @free(buf)
                    gen_stmts(ctx, arm_node.d1 as ref parser.Node)
                    val jbuf: ref char = @alloc(64) as ref char
                    if !block_ends_with_terminator(arm_node.d1 as ref parser.Node) {
                        @snprintf(jbuf, 64, "    jmp @lbl%lld\n@lbl%lld\n", {end_lbl, next_lbl})
                    } else {
                        @snprintf(jbuf, 64, "@lbl%lld\n", {next_lbl})
                    }
                    emit(ctx, jbuf)
                    @free(jbuf)
                }
                none => {}
            }
            ai++
        }
    }

    if else_body != 0 as ref void {
        val else_node: ref parser.Node = else_body as ref parser.Node
        gen_stmts(ctx, else_node.d0 as ref parser.Node)
    }

    val endbuf: ref char = @alloc(32) as ref char
    @snprintf(endbuf, 32, "@lbl%lld\n", {end_lbl})
    emit(ctx, endbuf)
    @free(endbuf)
}

/// Tagged union match: `match expr { VariantName binding => { ... } ... }`
/// Node layout: d0=expr, d1=list[arm], d2=else_arm
/// Arm layout: d0=variant_name(ref char), d1=list[ref char] bindings, d2=body stmts list
fn gen_match_tagged_union(ctx: ref CgCtx, stmt: ref parser.Node) void! = {
    val expr_node: ref parser.Node = stmt.d0 as ref parser.Node
    val expr: ref char = gen_expr(ctx, expr_node)
    val arms: ref void = stmt.d1 as ref void
    val else_body: ref void = stmt.d2 as ref void
    val end_lbl: i64 = fresh_lbl(ctx)
    val tag: i64 = fresh_tmp(ctx)
    val tbuf: ref char = @alloc(64) as ref char
    val is_direct_param: mut bool = false

    if @load8(expr) as i64 == 37 {  // '%'
        val second_char: i64 = @load8(@ptradd(expr, 1)) as i64
        if second_char != 116 {  // not 't'
            is_direct_param = true
        }
    }
    
    if is_direct_param {
        @snprintf(tbuf, 64, "    %%t%lld =l copy %s\n", {tag, expr})
    } else {
        @snprintf(tbuf, 64, "    %%t%lld =l loadl %s\n", {tag, expr})
    }
    emit(ctx, tbuf)
    @free(tbuf)

    if arms != 0 as ref void {
        val alen: i64 = @len(arms) as i64
        val ai: mut i64 = 0
        for {
            if ai >= alen { break }
            val arm_opt = @get(arms, ai as usize)
            match arm_opt {
                some arm => {
                    val arm_node: ref parser.Node = arm as ref parser.Node
                    val vname: ref char = arm_node.d0 as ref char
                    val bindings: ref void = arm_node.d1 as ref void

                    val owner_slot: ref void = @alloc(8)
                    val field_slot: ref void = @alloc(8)
                    @store(owner_slot, 0)
                    @store(field_slot, 0)
                    val tag_idx: i64 = cg_lookup_tv(ctx, vname, owner_slot, field_slot)
                    val field_ty_list: ref void = @load(field_slot) as ref void
                    @free(owner_slot)
                    @free(field_slot)
                    val actual_idx: mut i64 = ai
                    if tag_idx >= 0 { actual_idx = tag_idx }

                    val body_lbl: i64 = fresh_lbl(ctx)
                    val next_lbl: i64 = fresh_lbl(ctx)
                    val cmp: i64 = fresh_tmp(ctx)
                    val buf: ref char = @alloc(256) as ref char
                    @snprintf(buf, 256,
                        "    %%t%lld =w ceql %%t%lld, %lld\n    jnz %%t%lld, @lbl%lld, @lbl%lld\n@lbl%lld\n",
                        {cmp, tag, actual_idx, cmp, body_lbl, next_lbl, body_lbl})
                    emit(ctx, buf)
                    @free(buf)

                    if bindings != 0 as ref void {
                        val blen: i64 = @len(bindings as list[ref char]) as i64
                        val bi: mut i64 = 0
                        for {
                            if bi >= blen { break }
                            val b_opt = @get(bindings as list[ref char], bi as usize)
                            match b_opt {
                                some b => {
                                    val bname: ref char = b as ref char
                                    if str.rchar_cmp(bname, "_") != 0 {
                                        val offset: i64 = 8 + bi * 8
                                        val payload_ptr: i64 = fresh_tmp(ctx)
                                        val bbuf: ref char = @alloc(256) as ref char
                                        val is_struct: mut bool = false
                                        
                                        if field_ty_list != 0 as ref void {
                                            val ty_opt = @get(field_ty_list as list[ref parser.Node], bi as usize)
                                            match ty_opt {
                                                some ty_node => {
                                                    val field_ty_node: ref parser.Node = ty_node as ref parser.Node
                                                    if field_ty_node.kind == parser.TY_NAMED {
                                                        val field_ty_name: ref char = field_ty_node.d0 as ref char
                                                        val struct_fields: ref void = cg_lookup_struct(ctx, field_ty_name)
                                                        if struct_fields != 0 as ref void {
                                                            is_struct = true
                                                            cg_register_local_var_type(ctx, bname, field_ty_name)
                                                            cg_mark_local_ref_type(ctx, bname)
                                                        }
                                                    }
                                                }
                                                none => {}
                                            }
                                        }
                                        
                                        if is_struct {
                                            @snprintf(bbuf, 256,
                                                "    %%t%lld =l add %s, %lld\n    %%%s =l copy %%t%lld\n",
                                                {payload_ptr, expr, offset, bname, payload_ptr})
                                        } else {
                                            val payload_val: i64 = fresh_tmp(ctx)
                                            @snprintf(bbuf, 256,
                                                "    %%t%lld =l add %s, %lld\n    %%t%lld =l loadl %%t%lld\n    %%%s =l copy %%t%lld\n",
                                                {payload_ptr, expr, offset, payload_val, payload_ptr, bname, payload_val})
                                        }
                                        emit(ctx, bbuf)
                                        @free(bbuf)
                                        cg_dvars_add(ctx, bname, "l")
                                    }
                                }
                                none => {}
                            }
                            bi++
                        }
                    }

                    gen_stmts(ctx, arm_node.d2 as ref parser.Node)
                    val jbuf: ref char = @alloc(64) as ref char
                    if !block_ends_with_terminator(arm_node.d2 as ref parser.Node) {
                        @snprintf(jbuf, 64, "    jmp @lbl%lld\n@lbl%lld\n", {end_lbl, next_lbl})
                    } else {
                        @snprintf(jbuf, 64, "@lbl%lld\n", {next_lbl})
                    }
                    emit(ctx, jbuf)
                    @free(jbuf)
                }
                none => {}
            }
            ai++
        }
    }

    if else_body != 0 as ref void {
        val else_node: ref parser.Node = else_body as ref parser.Node
        gen_stmts(ctx, else_node.d0 as ref parser.Node)
    }

    val endbuf2: ref char = @alloc(32) as ref char
    @snprintf(endbuf2, 32, "@lbl%lld\n", {end_lbl})
    emit(ctx, endbuf2)
    @free(endbuf2)
}

fn gen_fn(ctx: ref CgCtx, fn_node: ref parser.Node) void! = {
    gen_fn_prefixed(ctx, fn_node, "")
}

fn gen_fn_prefixed(ctx: ref CgCtx, fn_node: ref parser.Node, mod_prefix: ref char) void! = {
    val public: i64 = fn_node.d0 as i64
    val ns: ref char = fn_node.d1 as ref char
    val name: ref char = fn_node.d2 as ref char
    val params: ref void = fn_node.d3 as ref void
    val ret_ty: ref parser.Node = fn_node.d4 as ref parser.Node
    val body: ref parser.Node = fn_node.d5 as ref parser.Node
    val mangled: ref char = @alloc(512) as ref char
    val base: ref char = @alloc(256) as ref char

    if ns != 0 as ref char {
        @snprintf(base, 256, "%s__%s", {ns, name})
    } else {
        @snprintf(base, 256, "%s", {name})
    }

    if str.rchar_cmp(mod_prefix, "") == 0 {
        @snprintf(mangled, 512, "%s", {base})
    } else {
        @snprintf(mangled, 512, "%s__%s", {mod_prefix, base})
    }

    cg_set_fn_name(ctx, mangled)

    if params != 0 as ref void {
        cg_register_fn(ctx, mangled, params, ret_ty as ref void)
    }

    val export_kw: mut ref char = ""
    if public == 1 { export_kw = "export " }
    val ret_qt: ref char = qbe_type_of(ret_ty)
    val sig_buf: ref char = @alloc(512) as ref char

    val ret_union_name: mut ref char = is_union_type(ctx, ret_ty)
    if str.rchar_cmp(ret_union_name, "") == 0 && ret_ty != 0 as ref parser.Node && ret_ty.kind == parser.TY_NAMED {
        val unprefixed_name: ref char = ret_ty.d0 as ref char
        if str.rchar_cmp(mod_prefix, "") != 0 {
            val prefixed_name: ref char = @alloc(256) as ref char
            @snprintf(prefixed_name, 256, "%s__%s", {mod_prefix, unprefixed_name})
            val union_vars: ref void = cg_lookup_union(ctx, prefixed_name)
            if union_vars != 0 as ref void {
                ret_union_name = prefixed_name
            }
        }
    }
    val returns_union: bool = str.rchar_cmp(ret_union_name, "") != 0

    @snprintf(sig_buf, 512, "%sfunction %s $%s(", {export_kw, ret_qt, mangled})
    emit(ctx, sig_buf)
    @free(sig_buf)

    if returns_union {
        emit(ctx, "l %__ret")
        if params != 0 as ref void && @len(params) as i64 > 0 {
            emit(ctx, ", ")
        }
    }

    if params != 0 as ref void {
        val plen: i64 = @len(params) as i64
        val pi: mut i64 = 0
        for {
            if pi >= plen { break }
            val p_opt = @get(params, pi as usize)
            match p_opt {
                some param => {
                    val pname: ref char = (param as ref parser.Node).d0 as ref char
                    val pty: ref parser.Node = (param as ref parser.Node).d1 as ref parser.Node
                    val pqt: ref char = qbe_type_of(pty)
                    val pbuf: ref char = @alloc(64) as ref char
                    if pi > 0 { emit(ctx, ", ") }
                    @snprintf(pbuf, 64, "%s %%%s", {pqt, pname})
                    emit(ctx, pbuf)
                    @free(pbuf)
                }
                none => {}
            }
            pi++
        }
    }

    emitln(ctx, ") {")
    emitln(ctx, "@start")

    if returns_union {
        ctx.current_fn_ret_union = ret_union_name
    } else {
        ctx.current_fn_ret_union = ""
    }

    cg_dvars_clear(ctx)

    val gnames_list: ref void = cg_global_src_names(ctx)
    val glen: i64 = @len(gnames_list) as i64
    val gi: mut i64 = 0
    for {
        if gi >= glen { break }
        val gn_opt = @get(gnames_list, gi as usize)
        match gn_opt {
            some gn => {
                val glbl_buf: ref char = @alloc(256) as ref char
                val gqt_buf: ref char = @alloc(8) as ref char
                val found: bool = cg_lookup_global(ctx, gn as ref char, glbl_buf, gqt_buf)
                if found {
                    val dollar_label: ref char = @alloc(260) as ref char
                    @snprintf(dollar_label, 260, "$%s", {glbl_buf})
                    cg_register_local_var(ctx, gn as ref char, dollar_label)
                    cg_mark_as_slot(ctx, gn as ref char)
                    if str.rchar_cmp(gqt_buf, "w") == 0 {
                        cg_register_local_type(ctx, gn as ref char, "bool")
                    }
                }
                @free(glbl_buf)
                @free(gqt_buf)
            }
            none => {}
        }
        gi++
    }

    if params != 0 as ref void {
        val plen2: i64 = @len(params) as i64
        val pi2: mut i64 = 0
        for {
            if pi2 >= plen2 { break }
            val p2_opt = @get(params, pi2 as usize)
            match p2_opt {
                some param2 => {
                    val pname2: ref char = (param2 as ref parser.Node).d0 as ref char
                    val pty2: ref parser.Node = (param2 as ref parser.Node).d1 as ref parser.Node
                    val ptk: i64 = pty2.kind
                    cg_dvars_add(ctx, pname2, qbe_type_of(pty2))
                    if ptk == parser.TY_NAMED {
                        val tname: ref char = pty2.d0 as ref char
                        cg_register_local_type(ctx, pname2, tname)
                    } elif ptk == parser.TY_MUT {
                        val inner: ref parser.Node = pty2.d0 as ref parser.Node
                        if inner != 0 as ref parser.Node && inner.kind == parser.TY_NAMED {
                            val tname2: ref char = inner.d0 as ref char
                            cg_register_local_type(ctx, pname2, tname2)
                        }
                    }
                }
                none => {}
            }
            pi2++
        }
    }

    gen_stmts(ctx, body)

    val blen: i64 = @len(body) as i64
    val needs_ret: mut bool = true
    if blen > 0 {
        val last_opt = @get(body, (blen - 1) as usize)
        match last_opt {
            some last => {
                val lk: i64 = (last as ref parser.Node).kind
                if lk == parser.NK_RETURN { needs_ret = false }
            }
            none => {}
        }
    }
    if needs_ret {
        cg_emit_defers(ctx)
        emitln(ctx, "    ret 0")
    }
    emitln(ctx, "}")
    emitln(ctx, "")
}

/// Register all variants of a tagged union into the ctx variant table.
fn gen_tagged_union_def(ctx: ref CgCtx, item: ref parser.Node, mod_prefix: ref char) void! = {
    val name: ref char = item.d1 as ref char
    val variants: ref void = item.d2 as ref void
    if variants == 0 as ref void { return }
    val vlen: i64 = @len(variants) as i64
    val mangled_name: ref char = @alloc(256) as ref char
    if str.rchar_cmp(mod_prefix, "") == 0 {
        @snprintf(mangled_name, 256, "%s", {name})
    } else {
        @snprintf(mangled_name, 256, "%s__%s", {mod_prefix, name})
    }
    
    cg_register_union(ctx, mangled_name, variants)
    
    val vi: mut i64 = 0
    for {
        if vi >= vlen { break }
        val v_opt = @get(variants, vi as usize)
        match v_opt {
            some v => {
                val vnode: ref parser.Node = v as ref parser.Node
                val vname: ref char = vnode.d0 as ref char
                val vty: ref void = vnode.d1 as ref void
                cg_register_tv(ctx, vname, mangled_name, vi, vty)
                if str.rchar_cmp(mod_prefix, "") != 0 {
                    val prefixed_vname: ref char = @alloc(256) as ref char
                    @snprintf(prefixed_vname, 256, "%s__%s", {mod_prefix, vname})
                    cg_register_tv(ctx, prefixed_vname, mangled_name, vi, vty)
                }
            }
            none => {}
        }
        vi++
    }
}

fn gen_extern_fn(ctx: ref CgCtx, item: ref parser.Node) void! = {
    val name: ref char = item.d1 as ref char
    val symbol: ref char = item.d2 as ref char
    val params: ref void = item.d4 as ref void
    val ret_ty: ref void = item.d5 as ref void
    cg_register_extern(ctx, name, symbol, ret_ty)
    if params != 0 as ref void {
        cg_register_fn(ctx, symbol, params, ret_ty)
    }
}

fn gen_enum_def(ctx: ref CgCtx, item: ref parser.Node) void! = {
    gen_enum_def_prefixed(ctx, item, "")
}

fn gen_union_def(ctx: ref CgCtx, item: ref parser.Node) void! = {
    gen_union_def_prefixed(ctx, item, "")
}

fn gen_union_def_prefixed(ctx: ref CgCtx, item: ref parser.Node, mod_prefix: ref char) void! = {
    val name: ref char = item.d1 as ref char
    val variants: ref void = item.d2 as ref void
    if variants == 0 as ref void { return }
    val vlen: i64 = @len(variants) as i64
    val vnames: mut list[ref char] = []
    val vi: mut i64 = 0
    for {
        if vi >= vlen { break }
        val v_opt = @get(variants, vi as usize)
        match v_opt {
            some v => {
                val vty: ref parser.Node = v as ref parser.Node
                val tname: mut ref char = "unknown"
                if vty.kind == parser.TY_NAMED {
                    tname = vty.d0 as ref char
                } elif vty.kind == parser.TY_REF {
                    tname = "ref"
                }
                @append(vnames, tname)
            }
            none => {}
        }
        vi++
    }
    val mangled_name: ref char = @alloc(256) as ref char
    if str.rchar_cmp(mod_prefix, "") == 0 {
        @snprintf(mangled_name, 256, "%s", {name})
    } else {
        @snprintf(mangled_name, 256, "%s__%s", {mod_prefix, name})
    }
    val vl: list[ref char] = vnames
    cg_register_union(ctx, mangled_name, vl as ref void)
}

fn gen_enum_def_prefixed(ctx: ref CgCtx, item: ref parser.Node, mod_prefix: ref char) void! = {
    val name: ref char = item.d1 as ref char
    val variants: ref void = item.d2 as ref void

    if variants == 0 as ref void { return }

    val vlen: i64 = @len(variants) as i64
    val vi: mut i64 = 0

    for {
        if vi >= vlen { break }
        val v_opt = @get(variants, vi as usize)
        match v_opt {
            some v => {
                val vname: ref char = v as ref char
                val const_key: ref char = @alloc(512) as ref char
                val idx_str: ref char = @alloc(32) as ref char

                @snprintf(idx_str, 32, "%lld", {vi})

                if str.rchar_cmp(mod_prefix, "") == 0 {
                    @snprintf(const_key, 512, "%s__%s", {name, vname})
                } else {
                    @snprintf(const_key, 512, "%s__%s__%s", {mod_prefix, name, vname})
                }

                cg_register_module_const(ctx, const_key, idx_str)
                if str.rchar_cmp(mod_prefix, "") != 0 {
                    val bare_key: ref char = @alloc(256) as ref char
                    @snprintf(bare_key, 256, "%s__%s", {name, vname})
                    val idx_str2: ref char = @alloc(32) as ref char
                    @snprintf(idx_str2, 32, "%lld", {vi})
                    cg_register_module_const(ctx, bare_key, idx_str2)
                }
            }
            none => {}
        }
        vi++
    }
}

/// Generate the assert_fail handler and any needed runtime helpers.
fn emit_runtime_helpers(ctx: ref CgCtx) void! = {
    emitln(ctx, `
data $str_w_mode = { b "w", b 0 }
data $str_r_mode = { b "r", b 0 }
data $sx_stdin_ptr = { l 0 }
data $sx_stdout_ptr = { l 0 }
data $sx_stderr_ptr = { l 0 }

function l $sx_stdout() {
@start
    %p =l loadl $sx_stdout_ptr
    %c =w cnel %p, 0
    jnz %c, @done, @init
@init
    %r =l call $fdopen(w 1, l $str_w_mode)
    storel %r, $sx_stdout_ptr
    ret %r
@done
    ret %p
}
function l $sx_stderr() {
@start
    %p =l loadl $sx_stderr_ptr
    %c =w cnel %p, 0
    jnz %c, @done, @init
@init
    %r =l call $fdopen(w 2, l $str_w_mode)
    storel %r, $sx_stderr_ptr
    ret %r
@done
    ret %p
}
function l $sx_stdin() {
@start
    %p =l loadl $sx_stdin_ptr
    %c =w cnel %p, 0
    jnz %c, @done, @init
@init
    %r =l call $fdopen(w 0, l $str_r_mode)
    storel %r, $sx_stdin_ptr
    ret %r
@done
    ret %p
}

data $sx_argc_store = { l 0 }
data $sx_argv_store = { l 0 }

function l $sx_get_args() {
@start
    %argc =l loadl $sx_argc_store
    %argv =l loadl $sx_argv_store
    %hdr =l call $malloc(l 24)
    %cap =l mul %argc, 8
    %buf =l call $malloc(l %cap)
    storel %buf, %hdr
    %len_slot =l add %hdr, 8
    storel 0, %len_slot
    %cap_slot =l add %hdr, 16
    storel %argc, %cap_slot
    %i =l copy 0
@args_loop
    %done =l csgtl %i, %argc
    jnz %done, @args_done, @args_body
@args_body
    %off =l mul %i, 8
    %slot =l add %argv, %off
    %str =l loadl %slot
    %cur_len =l loadl %len_slot
    %boff =l mul %cur_len, 8
    %bslot =l add %buf, %boff
    storel %str, %bslot
    %new_len =l add %cur_len, 1
    storel %new_len, %len_slot
    %i =l add %i, 1
    jmp @args_loop
@args_done
    ret %hdr
}

function l $__sx_get_args() {
@start
    %r =l call $sx_get_args()
    ret %r
}

function w $os__exit(w %code) {
@start
    call $exit(w %code)
    ret 0
}
`)
}

/// Pre-registration pass: register all function names and tagged union variants
/// before emitting any code, so forward references resolve correctly.
fn preregister_items(ctx: ref CgCtx, items: list[ref parser.Node], mod_prefix: ref char) void! = {
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_FN {
                    val ns: ref char = node.d1 as ref char
                    val name: ref char = node.d2 as ref char
                    val params: ref void = node.d3 as ref void
                    val ret_ty: ref void = node.d4 as ref void
                    val base: ref char = @alloc(256) as ref char
                    if ns != 0 as ref char {
                        @snprintf(base, 256, "%s__%s", {ns, name})
                    } else {
                        @snprintf(base, 256, "%s", {name})
                    }
                    val mangled: ref char = @alloc(512) as ref char
                    if str.rchar_cmp(mod_prefix, "") == 0 {
                        @snprintf(mangled, 512, "%s", {base})
                    } else {
                        @snprintf(mangled, 512, "%s__%s", {mod_prefix, base})
                    }
                    if params != 0 as ref void {
                        cg_register_fn(ctx, mangled, params, ret_ty)
                    }
                } elif k == parser.NK_TAGGED_UNIONDEF {
                    gen_tagged_union_def(ctx, node, mod_prefix)
                } elif k == parser.NK_UNIONDEF {
                    gen_union_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_ENUMDEF {
                    gen_enum_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_TYPEDEF {
                    val tname: ref char = node.d1 as ref char
                    val tfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, tname, tfields)
                } elif k == parser.NK_EXTERN_TYPE {
                    val etname: ref char = node.d1 as ref char
                    val etfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, etname, etfields)
                } elif k == parser.NK_WHEN_ITEMS {
                    val plat: ref char = node.d0 as ref char
                    if platform_matches(plat) {
                        val witems: list[ref parser.Node] = node.d1 as list[ref parser.Node]
                        preregister_items(ctx, witems, mod_prefix)
                    } else {
                        val or_when_branches2: ref void = node.d2 as ref void
                        val matched2: mut bool = false
                        if or_when_branches2 != 0 as ref void {
                            for ow2 in or_when_branches2 as list[ref parser.Node] {
                                if !matched2 {
                                    val ow_plat2: ref char = ow2.d0 as ref char
                                    if platform_matches(ow_plat2) {
                                        val ow_items2: list[ref parser.Node] = ow2.d1 as list[ref parser.Node]
                                        preregister_items(ctx, ow_items2, mod_prefix)
                                        matched2 = true
                                    }
                                }
                            }
                        }
                        if !matched2 {
                            val ow_otherwise2: ref void = node.d3 as ref void
                            if ow_otherwise2 != 0 as ref void {
                                val ow_oi2: list[ref parser.Node] = ow_otherwise2 as list[ref parser.Node]
                                preregister_items(ctx, ow_oi2, mod_prefix)
                            }
                        }
                    }
                }
            }
            none => {}
        }
        i++
    }
}

/// Emit all items from one module layer, using `mod_prefix` for name mangling.
fn gen_items_with_prefix(ctx: ref CgCtx, items: list[ref parser.Node], mod_prefix: ref char) void! = {
    preregister_items(ctx, items, mod_prefix)
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_FN {
                    gen_fn_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_EXTERN_FN {
                    gen_extern_fn(ctx, node)
                } elif k == parser.NK_ENUMDEF {
                    gen_enum_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_UNIONDEF {
                    gen_union_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_TAGGED_UNIONDEF {
                    gen_tagged_union_def(ctx, node, mod_prefix)
                } elif k == parser.NK_TYPEDEF {
                    val tname: ref char = node.d1 as ref char
                    val tfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, tname, tfields)
                } elif k == parser.NK_EXTERN_TYPE {
                    val etname: ref char = node.d1 as ref char
                    val etfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, etname, etfields)
                } elif k == parser.NK_WHEN_ITEMS {
                    val plat: ref char = node.d0 as ref char
                    if platform_matches(plat) {
                        val witems: list[ref parser.Node] = node.d1 as list[ref parser.Node]
                        gen_items_with_prefix(ctx, witems, mod_prefix)
                    } else {
                        val or_when_branches3: ref void = node.d2 as ref void
                        val matched3: mut bool = false
                        if or_when_branches3 != 0 as ref void {
                            for ow3 in or_when_branches3 as list[ref parser.Node] {
                                if !matched3 {
                                    val ow_plat3: ref char = ow3.d0 as ref char
                                    if platform_matches(ow_plat3) {
                                        val ow_items3: list[ref parser.Node] = ow3.d1 as list[ref parser.Node]
                                        gen_items_with_prefix(ctx, ow_items3, mod_prefix)
                                        matched3 = true
                                    }
                                }
                            }
                        }
                        if !matched3 {
                            val ow_otherwise3: ref void = node.d3 as ref void
                            if ow_otherwise3 != 0 as ref void {
                                val ow_oi3: list[ref parser.Node] = ow_otherwise3 as list[ref parser.Node]
                                gen_items_with_prefix(ctx, ow_oi3, mod_prefix)
                            }
                        }
                    }
                } elif k == parser.NK_VAL {
                    val gname: ref char = node.d0 as ref char
                    val gmut: i64 = node.d1 as i64
                    val gty_node: ref parser.Node = node.d2 as ref parser.Node
                    val gexpr: ref parser.Node = node.d3 as ref parser.Node
                    if gmut != 0 {
                        val gqtype: mut ref char = "l"
                        if gty_node != 0 as ref parser.Node {
                            gqtype = qbe_type_of(gty_node)
                        } elif gexpr != 0 as ref parser.Node {
                            if gexpr.kind == parser.NK_BOOL { gqtype = "w" }
                        }
                        val ginit: mut ref char = "0"
                        if gexpr != 0 as ref parser.Node {
                            if gexpr.kind == parser.NK_BOOL {
                                val bv: i64 = gexpr.d0 as i64
                                if bv != 0 { ginit = "1" } else { ginit = "0" }
                            } elif gexpr.kind == parser.NK_INT_LIT {
                                ginit = gexpr.d0 as ref char
                            }
                        }
                        val glabel: ref char = @alloc(512) as ref char
                        if str.rchar_cmp(mod_prefix, "") == 0 {
                            @snprintf(glabel, 512, "%s", {gname})
                        } else {
                            @snprintf(glabel, 512, "%s__%s", {mod_prefix, gname})
                        }
                        val data_buf: ref char = @alloc(256) as ref char
                        @snprintf(data_buf, 256, "data $%s = \{ %s %s \}\n", {glabel, gqtype, ginit})
                        emit(ctx, data_buf)
                        @free(data_buf)
                        cg_register_global(ctx, gname, glabel, gqtype)
                    }
                } elif k == parser.NK_CONST {                    val cname: ref char = node.d1 as ref char
                    val cexpr: ref parser.Node = node.d2 as ref parser.Node
                    if cexpr != 0 as ref parser.Node {
                        if cexpr.kind == parser.NK_INT_LIT {
                            cg_register_module_const(ctx, cname, cexpr.d0 as ref char)
                        } elif cexpr.kind == parser.NK_FLOAT_LIT {
                            val ftext: ref char = cexpr.d0 as ref char
                            val fval: ref char = @alloc(128) as ref char
                            @snprintf(fval, 128, "d_%s", {ftext})
                            cg_register_module_const(ctx, cname, fval)
                        } elif cexpr.kind == parser.NK_UNOP {
                            val uop: i64 = cexpr.d0 as i64
                            val inner: ref parser.Node = cexpr.d1 as ref parser.Node
                            if inner != 0 as ref parser.Node {
                                if uop == parser.UOP_NEG {
                                    if inner.kind == parser.NK_INT_LIT {
                                        val itext: ref char = inner.d0 as ref char
                                        val ival: ref char = @alloc(128) as ref char
                                        @snprintf(ival, 128, "-%s", {itext})
                                        cg_register_module_const(ctx, cname, ival)
                                    } elif inner.kind == parser.NK_FLOAT_LIT {
                                        val ftext2: ref char = inner.d0 as ref char
                                        val fval2: ref char = @alloc(128) as ref char
                                        @snprintf(fval2, 128, "d_-%s", {ftext2})
                                        cg_register_module_const(ctx, cname, fval2)
                                    }
                                }
                            }
                        } elif cexpr.kind == parser.NK_BOOL {
                            val bval: i64 = cexpr.d0 as i64
                            if bval != 0 {
                                cg_register_module_const(ctx, cname, "1")
                            } else {
                                cg_register_module_const(ctx, cname, "0")
                            }
                        }
                    }
                }
            }
            none => {}
        }
        i++
    }
}

/// Scan items for function calls to track which modules are used, without emitting code.
fn scan_items_for_usage(ctx: ref CgCtx, items: list[ref parser.Node], mod_prefix: ref char) void! = {
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_FN {
                    val body: ref void = node.d5 as ref void
                    if body != 0 as ref void {
                        val blen: i64 = @len(body as list[ref parser.Node]) as i64
                        val bi: mut i64 = 0
                        for {
                            if bi >= blen { break }
                            val stmt_opt = @get(body as list[ref parser.Node], bi as usize)
                            match stmt_opt {
                                some stmt_val => {
                                    val stmt: ref parser.Node = stmt_val as ref parser.Node
                                    scan_node_for_calls_depth(ctx, stmt)
                                }
                                none => {}
                            }
                            bi++
                        }
                    }
                } elif k == parser.NK_WHEN_ITEMS {
                    val plat: ref char = node.d0 as ref char
                    if platform_matches(plat) {
                        val witems: list[ref parser.Node] = node.d1 as list[ref parser.Node]
                        scan_items_for_usage(ctx, witems, mod_prefix)
                    }
                }
            }
            none => {}
        }
        i++
    }
}

/// Scan a statement list (function body) for calls.
fn scan_stmts_for_calls(ctx: ref CgCtx, stmts: ref void) void! = {
    if stmts == 0 as ref void { return }
    
    val slen: i64 = @len(stmts as list[ref parser.Node]) as i64
    if slen < 0 || slen > 100000 {
        return
    }
    val si: mut i64 = 0
    for {
        if si >= slen { break }
        val stmt_opt = @get(stmts as list[ref parser.Node], si as usize)
        match stmt_opt {
            some stmt_val => {
                val stmt: ref parser.Node = stmt_val as ref parser.Node
                scan_node_for_calls_depth(ctx, stmt, 0)
            }
            none => {}
        }
        si++
    }
}

/// Recursively scan a node tree for function calls to mark prefixes as used.
fn scan_node_for_calls(ctx: ref CgCtx, node: ref parser.Node) void! = {
    scan_node_for_calls_depth(ctx, node, 0)
}

/// Recursively scan a node tree for function calls to mark prefixes as used, with depth limit.
fn scan_node_for_calls_depth(ctx: ref CgCtx, node: ref parser.Node, depth: i64) void! = {
    if node == 0 as ref parser.Node { return }
    if depth > 100 { return }
    
    val k: i64 = node.kind
    
    if k == parser.NK_CALL {
        val args: ref void = node.d1 as ref void
        if args != 0 as ref void {
            val alen: i64 = @len(args as list[ref parser.Node]) as i64
            val ai: mut i64 = 0
            for {
                if ai >= alen { break }
                val arg_opt = @get(args as list[ref parser.Node], ai as usize)
                match arg_opt {
                    some arg => { scan_node_for_calls_depth(ctx, arg as ref parser.Node, depth + 1) }
                    none => {}
                }
                ai++
            }
        }
    } elif k == parser.NK_IF {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
        val then_stmts: ref void = node.d1 as ref void
        if then_stmts != 0 as ref void {
            scan_stmts_for_calls(ctx, then_stmts)
        }
        val else_stmts: ref void = node.d2 as ref void
        if else_stmts != 0 as ref void {
            scan_stmts_for_calls(ctx, else_stmts)
        }
    } elif k == parser.NK_FOR {
        val body: ref void = node.d4 as ref void
        if body != 0 as ref void {
            scan_stmts_for_calls(ctx, body)
        }
    } elif k == parser.NK_FORIN {
        scan_node_for_calls_depth(ctx, node.d2 as ref parser.Node, depth + 1)
        val body: ref void = node.d3 as ref void
        if body != 0 as ref void {
            scan_stmts_for_calls(ctx, body)
        }
    } elif k == parser.NK_MATCH_OPT {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
        val some_body: ref parser.Node = node.d2 as ref parser.Node
        if some_body != 0 as ref parser.Node {
            val some_stmts: ref void = some_body.d0 as ref void
            if some_stmts != 0 as ref void {
                scan_stmts_for_calls(ctx, some_stmts)
            }
        }
        val none_body: ref parser.Node = node.d3 as ref parser.Node
        if none_body != 0 as ref parser.Node {
            val none_stmts: ref void = none_body.d0 as ref void
            if none_stmts != 0 as ref void {
                scan_stmts_for_calls(ctx, none_stmts)
            }
        }
    } elif k == parser.NK_MATCH_RES {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
        val ok_body: ref parser.Node = node.d2 as ref parser.Node
        if ok_body != 0 as ref parser.Node {
            val ok_stmts: ref void = ok_body.d0 as ref void
            if ok_stmts != 0 as ref void {
                scan_stmts_for_calls(ctx, ok_stmts)
            }
        }
        val err_body: ref parser.Node = node.d3 as ref parser.Node
        if err_body != 0 as ref parser.Node {
            val err_stmts: ref void = err_body.d0 as ref void
            if err_stmts != 0 as ref void {
                scan_stmts_for_calls(ctx, err_stmts)
            }
        }
    } elif k == parser.NK_MATCH_ENUM || k == parser.NK_MATCH_UNION || k == parser.NK_MATCH_TAGGED_UNION || k == parser.NK_MATCH_STR {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
        val arms: ref void = node.d1 as ref void
        if arms != 0 as ref void {
            val alen: i64 = @len(arms as list[ref parser.Node]) as i64
            val ai: mut i64 = 0
            for {
                if ai >= alen { break }
                val arm_opt = @get(arms as list[ref parser.Node], ai as usize)
                match arm_opt {
                    some arm_val => {
                        val arm: ref parser.Node = arm_val as ref parser.Node
                        val arm_body: ref void = arm.d1 as ref void
                        if arm_body != 0 as ref void {
                            scan_stmts_for_calls(ctx, arm_body)
                        }
                    }
                    none => {}
                }
                ai++
            }
        }
    } elif k == parser.NK_RETURN {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_ASSIGN {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
        scan_node_for_calls_depth(ctx, node.d1 as ref parser.Node, depth + 1)
    } elif k == parser.NK_VAL {
        scan_node_for_calls_depth(ctx, node.d3 as ref parser.Node, depth + 1)
    } elif k == parser.NK_BINOP {
        scan_node_for_calls_depth(ctx, node.d1 as ref parser.Node, depth + 1)
        scan_node_for_calls_depth(ctx, node.d2 as ref parser.Node, depth + 1)
    } elif k == parser.NK_UNOP {
        scan_node_for_calls_depth(ctx, node.d1 as ref parser.Node, depth + 1)
    } elif k == parser.NK_FIELD {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_BUILTIN {
        val args: ref void = node.d1 as ref void
        if args != 0 as ref void {
            val alen: i64 = @len(args as list[ref parser.Node]) as i64
            val ai: mut i64 = 0
            for {
                if ai >= alen { break }
                val arg_opt = @get(args as list[ref parser.Node], ai as usize)
                match arg_opt {
                    some arg => { scan_node_for_calls_depth(ctx, arg as ref parser.Node, depth + 1) }
                    none => {}
                }
                ai++
            }
        }
    } elif k == parser.NK_CAST {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_STRUCT_LIT {
        val fields: ref void = node.d1 as ref void
        if fields != 0 as ref void {
            val flen: i64 = @len(fields as list[ref parser.Node]) as i64
            val fi: mut i64 = 0
            for {
                if fi >= flen { break }
                val field_opt = @get(fields as list[ref parser.Node], fi as usize)
                match field_opt {
                    some field_val => {
                        val field: ref parser.Node = field_val as ref parser.Node
                        scan_node_for_calls_depth(ctx, field.d1 as ref parser.Node, depth + 1)
                    }
                    none => {}
                }
                fi++
            }
        }
    } elif k == parser.NK_LIST_LIT {
        val elems: ref void = node.d0 as ref void
        if elems != 0 as ref void {
            val elen: i64 = @len(elems as list[ref parser.Node]) as i64
            val ei: mut i64 = 0
            for {
                if ei >= elen { break }
                val elem_opt = @get(elems as list[ref parser.Node], ei as usize)
                match elem_opt {
                    some elem_val => {
                        val elem: ref parser.Node = elem_val as ref parser.Node
                        scan_node_for_calls_depth(ctx, elem)
                    }
                    none => {}
                }
                ei++
            }
        }
    } elif k == parser.NK_EXPR_STMT {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_DEFER {
        val body: ref void = node.d0 as ref void
        if body != 0 as ref void {
            scan_stmts_for_calls(ctx, body)
        }
    } elif k == parser.NK_TRY {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_SOME {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_OK_VAL {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_ERR_VAL {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_ADDR {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    } elif k == parser.NK_DEREF {
        scan_node_for_calls_depth(ctx, node.d0 as ref parser.Node, depth + 1)
    }
}

/// Main entry for the resolved module tree.
/// Flattens children depth-first, emits each layer with its mangled prefix.
pub fn gen_module_resolved(root: ref module.ResolvedModule) ref char! = {
    val ctx: ref CgCtx = cg_new()
    emit_runtime_helpers(ctx)

    val out_prefixes: mut list[ref char] = []
    val out_items:    mut list[ref void] = []
    val seen:         list[String] = []

    module.flatten_modules(
        root, "",
        out_prefixes,
        out_items,
        seen
    )

    val layers: i64 = @len(out_prefixes) as i64
    
    cg_mark_prefix_used(ctx, "")
    
    val li: mut i64 = 0
    for {
        if li >= layers { break }
        val pfx_opt   = @get(out_prefixes, li as usize)
        val items_opt = @get(out_items,    li as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some items_ptr => {
                        val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                        preregister_items(ctx, items, pfx as ref char)
                    }
                    none => {}
                }
            }
            none => {}
        }
        li++
    }

    val li2: mut i64 = 0
    for {
        if li2 >= layers { break }
        val pfx_opt   = @get(out_prefixes, li2 as usize)
        val items_opt = @get(out_items,    li2 as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some items_ptr => {
                        val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                        gen_items_with_prefix(ctx, items, pfx as ref char)
                    }
                    none => {}
                }
            }
            none => {}
        }
        li2++
    }

    emit_string_data(ctx)

    val built: ref void = str.StringBuilder.build(cg_sb(ctx))
    val result: ref char = str.cstr(built)
    str.StringBuilder.free(cg_sb(ctx))
    return result
}

pub fn get_used_prefixes(root: ref module.ResolvedModule) list[ref char]! = {
    val ctx: ref CgCtx = cg_new()
    
    val out_prefixes: mut list[ref char] = []
    val out_items:    mut list[ref void] = []
    val seen:         list[String] = []

    module.flatten_modules(
        root, "",
        out_prefixes,
        out_items,
        seen
    )

    val layers: i64 = @len(out_prefixes) as i64
    
    cg_mark_prefix_used(ctx, "")
    
    val li: mut i64 = 0
    for {
        if li >= layers { break }
        val pfx_opt   = @get(out_prefixes, li as usize)
        val items_opt = @get(out_items,    li as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some items_ptr => {
                        val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                        preregister_items(ctx, items, pfx as ref char)
                    }
                    none => {}
                }
            }
            none => {}
        }
        li++
    }

    val li2: mut i64 = 0
    for {
        if li2 >= layers { break }
        val pfx_opt   = @get(out_prefixes, li2 as usize)
        val items_opt = @get(out_items,    li2 as usize)
        match pfx_opt {
            some pfx => {
                if cg_is_prefix_used(ctx, pfx as ref char) {
                    match items_opt {
                        some items_ptr => {
                            val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                            scan_items_for_usage(ctx, items, pfx as ref char)
                        }
                        none => {}
                    }
                }
            }
            none => {}
        }
        li2++
    }
    
    return ctx.used_prefixes
}

/// Emit a single test block as a numbered function. Returns the function name.
fn gen_test_fn(ctx: ref CgCtx, body_stmts: ref parser.Node, test_id: i64) void! = {
    cg_dvars_clear(ctx)
    val fname: ref char = @fmt("__sx_test_%lld", {test_id})
    val hdr: ref char = @fmt("export function w $%s() {\n@start\n", {fname})
    emit(ctx, hdr)
    val gnames_list: ref void = cg_global_src_names(ctx)
    val glen: i64 = @len(gnames_list) as i64
    val gi: mut i64 = 0
    for {
        if gi >= glen { break }
        val gn_opt = @get(gnames_list, gi as usize)
        match gn_opt {
            some gn => {
                val glbl_buf: ref char = @alloc(256) as ref char
                val gqt_buf: ref char = @alloc(8) as ref char
                val found: bool = cg_lookup_global(ctx, gn as ref char, glbl_buf, gqt_buf)
                if found {
                    val dollar_label: ref char = @alloc(260) as ref char
                    @snprintf(dollar_label, 260, "$%s", {glbl_buf})
                    cg_register_local_var(ctx, gn as ref char, dollar_label)
                    cg_mark_as_slot(ctx, gn as ref char)
                    if str.rchar_cmp(gqt_buf, "w") == 0 {
                        cg_register_local_type(ctx, gn as ref char, "bool")
                    }
                }
                @free(glbl_buf)
                @free(gqt_buf)
            }
            none => {}
        }
        gi++
    }
    gen_stmts(ctx, body_stmts)
    cg_emit_defers(ctx)
    emitln(ctx, "    ret 0")
    emitln(ctx, "}")
    emitln(ctx, "")
}

/// Emit a $main that calls all collected test functions and prints a summary.
fn gen_test_main(ctx: ref CgCtx, test_ids: list[i64]) void! = {
    emitln(ctx, "export function w $main() {")
    emitln(ctx, "@start")
    val tlen: i64 = @len(test_ids) as i64
    val ti: mut i64 = 0
    for {
        if ti >= tlen { break }
        val id_opt = @get(test_ids, ti as usize)
        match id_opt {
            some id => {
                val call: ref char = @fmt("    call $__sx_test_%lld()\n", {id as i64})
                emit(ctx, call)
            }
            none => {}
        }
        ti++
    }
    val ok_idx: i64 = intern_string(ctx, "all tests passed\n")
    val ok_tmp: i64 = fresh_tmp(ctx)
    val ok_buf: ref char = @alloc(128) as ref char
    @snprintf(ok_buf, 128, "    %%t%lld =l copy $__str%lld\n    call $printf(l %%t%lld)\n    ret 0\n}\n\n",
        {ok_tmp, ok_idx, ok_tmp})
    emit(ctx, ok_buf)
    @free(ok_buf)
}

/// Entry point for --test mode: emits test blocks from root module only,
/// suppresses main(), and emits a test runner $main.
pub fn gen_module_resolved_test(root: ref module.ResolvedModule) ref char! = {
    val ctx: ref CgCtx = cg_new()
    emit_runtime_helpers(ctx)

    val out_prefixes: mut list[ref char] = []
    val out_items:    mut list[ref void] = []
    val seen:         list[String] = []

    module.flatten_modules(
        root, "",
        out_prefixes,
        out_items,
        seen
    )

    val layers: i64 = @len(out_prefixes) as i64
    
    cg_mark_prefix_used(ctx, "")
    
    val root_imports: mut list[ref char] = root.import_names
    val rimp_len: i64 = @len(root_imports) as i64
    val ri_idx: mut i64 = 0
    for {
        if ri_idx >= rimp_len { break }
        val imp_opt = @get(root_imports, ri_idx as usize)
        match imp_opt {
            some imp_name => {
                cg_mark_prefix_used(ctx, imp_name as ref char)
            }
            none => {}
        }
        ri_idx++
    }
    
    val li: mut i64 = 0
    for {
        if li >= layers { break }
        val pfx_opt   = @get(out_prefixes, li as usize)
        val items_opt = @get(out_items,    li as usize)
        match pfx_opt {
            some pfx => {
                match items_opt {
                    some items_ptr => {
                        val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                        preregister_items(ctx, items, pfx as ref char)
                    }
                    none => {}
                }
            }
            none => {}
        }
        li++
    }
    
    val test_ids: mut list[i64] = []
    val test_counter: mut i64 = 0
    val root_items: mut list[ref parser.Node] = root.items
    val rlen: i64 = @len(root_items) as i64
    val ri: mut i64 = 0
    for {
        if ri >= rlen { break }
        val item_opt = @get(root_items, ri as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                if node.kind == parser.NK_TEST {
                    val body: ref void = node.d0 as ref void
                    if body != 0 as ref void {
                        scan_stmts_for_calls(ctx, body)
                    }
                }
            }
            none => {}
        }
        ri++
    }
    
    val scan_pass: mut i64 = 0
    for {
        if scan_pass >= 10 { break }
        scan_pass++
        
        val li_scan: mut i64 = 0
        for {
            if li_scan >= layers { break }
            val pfx_scan_opt   = @get(out_prefixes, li_scan as usize)
            val items_scan_opt = @get(out_items,    li_scan as usize)
            match pfx_scan_opt {
                some pfx_scan => {
                    if cg_is_prefix_used(ctx, pfx_scan as ref char) {
                        match items_scan_opt {
                            some items_scan_ptr => {
                                val items_scan: list[ref parser.Node] = items_scan_ptr as list[ref parser.Node]
                                scan_items_for_usage(ctx, items_scan, pfx_scan as ref char)
                            }
                            none => {}
                        }
                    }
                }
                none => {}
            }
            li_scan++
        }
    }

    val li2: mut i64 = 0
    for {
        if li2 >= layers { break }
        val pfx_opt   = @get(out_prefixes, li2 as usize)
        val items_opt = @get(out_items,    li2 as usize)
        match pfx_opt {
            some pfx => {
                val is_root: bool = str.rchar_cmp(pfx as ref char, "") == 0
                
                match items_opt {
                    some items_ptr => {
                        val items: list[ref parser.Node] = items_ptr as list[ref parser.Node]
                        if is_root {
                            gen_items_with_prefix_skip_main(ctx, items, "")
                        } else {
                            gen_items_with_prefix(ctx, items, pfx as ref char)
                        }
                    }
                    none => {}
                }
            }
            none => {}
        }
        li2++
    }

    val ri2: mut i64 = 0
    for {
        if ri2 >= rlen { break }
        val item_opt = @get(root_items, ri2 as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                if node.kind == parser.NK_TEST {
                    test_counter++
                    @append(test_ids, test_counter)
                    gen_test_fn(ctx, node.d0 as ref parser.Node, test_counter)
                }
            }
            none => {}
        }
        ri2++
    }

    gen_test_main(ctx, test_ids)
    emit_string_data(ctx)

    val built: ref void = str.StringBuilder.build(cg_sb(ctx))
    val result: ref char = str.cstr(built)
    str.StringBuilder.free(cg_sb(ctx))
    return result
}

/// Kinda like gen_items_with_prefix but skips NK_FN named "main" and handles NK_TEST.
fn gen_items_with_prefix_skip_main(ctx: ref CgCtx, items: list[ref parser.Node], mod_prefix: ref char) void! = {
    preregister_items(ctx, items, mod_prefix)
    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0
    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val node: ref parser.Node = item as ref parser.Node
                val k: i64 = node.kind
                if k == parser.NK_FN {
                    val fname: ref char = node.d2 as ref char
                    if str.rchar_cmp(fname, "main") != 0 {
                        gen_fn_prefixed(ctx, node, mod_prefix)
                    }
                } elif k == parser.NK_EXTERN_FN {
                    gen_extern_fn(ctx, node)
                } elif k == parser.NK_ENUMDEF {
                    gen_enum_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_UNIONDEF {
                    gen_union_def_prefixed(ctx, node, mod_prefix)
                } elif k == parser.NK_TAGGED_UNIONDEF {
                    gen_tagged_union_def(ctx, node, mod_prefix)
                } elif k == parser.NK_TYPEDEF {
                    val tname: ref char = node.d1 as ref char
                    val tfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, tname, tfields)
                } elif k == parser.NK_EXTERN_TYPE {
                    val etname: ref char = node.d1 as ref char
                    val etfields: ref void = node.d2 as ref void
                    cg_register_struct(ctx, etname, etfields)
                } elif k == parser.NK_WHEN_ITEMS {
                    val plat: ref char = node.d0 as ref char
                    if platform_matches(plat) {
                        val witems: list[ref parser.Node] = node.d1 as list[ref parser.Node]
                        gen_items_with_prefix_skip_main(ctx, witems, mod_prefix)
                    } else {
                        val or_when_branches4: ref void = node.d2 as ref void
                        val matched4: mut bool = false
                        if or_when_branches4 != 0 as ref void {
                            for ow4 in or_when_branches4 as list[ref parser.Node] {
                                if !matched4 {
                                    val ow_plat4: ref char = ow4.d0 as ref char
                                    if platform_matches(ow_plat4) {
                                        val ow_items4: list[ref parser.Node] = ow4.d1 as list[ref parser.Node]
                                        gen_items_with_prefix_skip_main(ctx, ow_items4, mod_prefix)
                                        matched4 = true
                                    }
                                }
                            }
                        }
                        if !matched4 {
                            val ow_otherwise4: ref void = node.d3 as ref void
                            if ow_otherwise4 != 0 as ref void {
                                val ow_oi4: list[ref parser.Node] = ow_otherwise4 as list[ref parser.Node]
                                gen_items_with_prefix_skip_main(ctx, ow_oi4, mod_prefix)
                            }
                        }
                    }
                } elif k == parser.NK_CONST {
                    val cname: ref char = node.d1 as ref char
                    val cexpr: ref parser.Node = node.d2 as ref parser.Node
                    if cexpr != 0 as ref parser.Node {
                        if cexpr.kind == parser.NK_INT_LIT {
                            cg_register_module_const(ctx, cname, cexpr.d0 as ref char)
                        } elif cexpr.kind == parser.NK_FLOAT_LIT {
                            val ftext3: ref char = cexpr.d0 as ref char
                            val fval3: ref char = @alloc(128) as ref char
                            @snprintf(fval3, 128, "d_%s", {ftext3})
                            cg_register_module_const(ctx, cname, fval3)
                        } elif cexpr.kind == parser.NK_UNOP {
                            val uop2: i64 = cexpr.d0 as i64
                            val inner2: ref parser.Node = cexpr.d1 as ref parser.Node
                            if inner2 != 0 as ref parser.Node {
                                if uop2 == parser.UOP_NEG {
                                    if inner2.kind == parser.NK_INT_LIT {
                                        val itext2: ref char = inner2.d0 as ref char
                                        val ival2: ref char = @alloc(128) as ref char
                                        @snprintf(ival2, 128, "-%s", {itext2})
                                        cg_register_module_const(ctx, cname, ival2)
                                    } elif inner2.kind == parser.NK_FLOAT_LIT {
                                        val ftext4: ref char = inner2.d0 as ref char
                                        val fval4: ref char = @alloc(128) as ref char
                                        @snprintf(fval4, 128, "d_-%s", {ftext4})
                                        cg_register_module_const(ctx, cname, fval4)
                                    }
                                }
                            }
                        } elif cexpr.kind == parser.NK_BOOL {
                            val bval2: i64 = cexpr.d0 as i64
                            if bval2 != 0 {
                                cg_register_module_const(ctx, cname, "1")
                            } else {
                                cg_register_module_const(ctx, cname, "0")
                            }
                        }
                    }
                } elif k == parser.NK_VAL {
                    val gname: ref char = node.d0 as ref char
                    val gmut: i64 = node.d1 as i64
                    val gty_node: ref parser.Node = node.d2 as ref parser.Node
                    val gexpr: ref parser.Node = node.d3 as ref parser.Node
                    if gmut != 0 {
                        val gqtype: mut ref char = "l"
                        if gty_node != 0 as ref parser.Node {
                            gqtype = qbe_type_of(gty_node)
                        } elif gexpr != 0 as ref parser.Node {
                            if gexpr.kind == parser.NK_BOOL { gqtype = "w" }
                        }
                        val ginit: mut ref char = "0"
                        if gexpr != 0 as ref parser.Node {
                            if gexpr.kind == parser.NK_BOOL {
                                val bv: i64 = gexpr.d0 as i64
                                if bv != 0 { ginit = "1" } else { ginit = "0" }
                            } elif gexpr.kind == parser.NK_INT_LIT {
                                ginit = gexpr.d0 as ref char
                            }
                        }
                        val glabel: ref char = @alloc(512) as ref char
                        if str.rchar_cmp(mod_prefix, "") == 0 {
                            @snprintf(glabel, 512, "%s", {gname})
                        } else {
                            @snprintf(glabel, 512, "%s__%s", {mod_prefix, gname})
                        }
                        val data_buf: ref char = @alloc(256) as ref char
                        @snprintf(data_buf, 256, "data $%s = \{ %s %s \}\n", {glabel, gqtype, ginit})
                        emit(ctx, data_buf)
                        @free(data_buf)
                        cg_register_global(ctx, gname, glabel, gqtype)
                    }
                }
            }
            none => {}
        }
        i++
    }
}

// Main entry: generate QBE IR for a module (single-file, no imports).
pub fn gen_module(items: list[ref parser.Node]) ref char! = {
    val ctx: ref CgCtx = cg_new()

    emit_runtime_helpers(ctx)

    val ilen: i64 = @len(items) as i64
    val i: mut i64 = 0

    for {
        if i >= ilen { break }
        val item_opt = @get(items, i as usize)
        match item_opt {
            some item => {
                val k: i64 = (item as ref parser.Node).kind
                if k == parser.NK_FN {
                    gen_fn_prefixed(ctx, item as ref parser.Node, "")
                } elif k == parser.NK_EXTERN_FN {
                    gen_extern_fn(ctx, item as ref parser.Node)
                } elif k == parser.NK_ENUMDEF {
                    gen_enum_def_prefixed(ctx, item as ref parser.Node, "")
                }
            }
            none => {}
        }
        i++
    }

    emit_string_data(ctx)

    val built: ref void = str.StringBuilder.build(cg_sb(ctx))
    val result: ref char = str.cstr(built)
    str.StringBuilder.free(cg_sb(ctx))
    return result
}
